digraph PPGL_QSP {
  graph [
    rankdir=LR
    fontname="Helvetica"
    fontsize=11
    label="Pheochromocytoma/Paraganglioma (PPGL) — QSP Mechanistic Map\nCatecholamine Biosynthesis · Adrenergic Signaling · Cardiovascular & Metabolic Effects · Drug PK/PD"
    labelloc=t
    labeljust=c
    splines=ortho
    nodesep=0.35
    ranksep=0.6
    bgcolor="#f9f9f9"
  ]
  node [fontname="Helvetica" fontsize=9 style=filled shape=box margin="0.12,0.06"]
  edge [fontname="Helvetica" fontsize=8 color="#444444" arrowsize=0.7]

  // ─────────────────────────────────────────────────────────────
  // CLUSTER 1: Genetic / Molecular Drivers
  // ─────────────────────────────────────────────────────────────
  subgraph cluster_genetics {
    label="① Genetic & Molecular Drivers"
    style=filled fillcolor="#FFF3E0" color="#E65100" penwidth=2
    fontcolor="#E65100" fontsize=11 fontname="Helvetica-Bold"

    SDHB [label="SDHB\n(Succinate DH B)" fillcolor="#FFCC80"]
    SDHC [label="SDHC" fillcolor="#FFCC80"]
    SDHD [label="SDHD" fillcolor="#FFCC80"]
    SDHA [label="SDHA" fillcolor="#FFCC80"]
    VHL  [label="VHL\ngene" fillcolor="#FF8A65"]
    RET  [label="RET\n(MEN2)" fillcolor="#FF8A65"]
    NF1  [label="NF1\ngene" fillcolor="#FF8A65"]
    MAX  [label="MAX\ngene" fillcolor="#FFCC80"]
    TMEM127 [label="TMEM127\ngene" fillcolor="#FFCC80"]
    EPAS1 [label="EPAS1/\nHIF-2α" fillcolor="#FFB74D"]
    succinate_accum [label="Succinate\nAccumulation" fillcolor="#FFA726"]
    pseudohypoxia [label="Pseudo-\nhypoxia" fillcolor="#FB8C00"]
    kinase_cluster [label="Kinase\nSignaling\nCluster" fillcolor="#FB8C00"]
    hereditary_ppgl [label="Hereditary\nPPGL (40%)" fillcolor="#FFCCBC"]
    sporadic_ppgl   [label="Sporadic\nPPGL (60%)" fillcolor="#FFCCBC"]
    malignant_ppgl  [label="Malignant\nPPGL\n(SDHB-mut)" fillcolor="#FF5722"]
  }

  // ─────────────────────────────────────────────────────────────
  // CLUSTER 2: Tumor Biology
  // ─────────────────────────────────────────────────────────────
  subgraph cluster_tumor {
    label="② Tumor Biology & Microenvironment"
    style=filled fillcolor="#FCE4EC" color="#880E4F" penwidth=2
    fontcolor="#880E4F" fontsize=11 fontname="Helvetica-Bold"

    chromaffin_cell [label="Chromaffin\nCell / Chief Cell" fillcolor="#F48FB1"]
    tumor_volume    [label="Tumor\nVolume (mL)" fillcolor="#F06292"]
    tumor_prolif    [label="Cell\nProliferation" fillcolor="#EC407A"]
    tumor_apoptosis [label="Apoptosis" fillcolor="#EC407A"]
    HIF1a  [label="HIF-1α" fillcolor="#CE93D8"]
    VEGF_t [label="VEGF-A\n(tumor)" fillcolor="#CE93D8"]
    PDGFb  [label="PDGF-β" fillcolor="#CE93D8"]
    FGF    [label="bFGF" fillcolor="#CE93D8"]
    angio  [label="Angiogenesis\n/ MVD" fillcolor="#AB47BC"]
    hypoxia_t [label="Tumor\nHypoxia" fillcolor="#E1BEE7"]
    necrosis  [label="Necrosis\nFraction" fillcolor="#CE93D8"]
    chromogranin_A [label="Chromogranin-A\n(CgA)" fillcolor="#F48FB1"]
    NSE    [label="NSE\n(Neuron-Specific\nEnolase)" fillcolor="#F48FB1"]
    metastasis [label="Metastasis\nRisk (SDHB)" fillcolor="#AD1457"]
  }

  // ─────────────────────────────────────────────────────────────
  // CLUSTER 3: Catecholamine Biosynthesis
  // ─────────────────────────────────────────────────────────────
  subgraph cluster_synthesis {
    label="③ Catecholamine Biosynthesis Pathway"
    style=filled fillcolor="#E8F5E9" color="#1B5E20" penwidth=2
    fontcolor="#1B5E20" fontsize=11 fontname="Helvetica-Bold"

    tyrosine   [label="L-Tyrosine\n(plasma)" fillcolor="#C8E6C9"]
    BH4        [label="Tetrahydrobiopterin\n(BH4 cofactor)" fillcolor="#A5D6A7"]
    TH         [label="Tyrosine\nHydroxylase (TH)\n[rate-limiting]" fillcolor="#4CAF50" fontcolor=white]
    DOPA       [label="L-DOPA" fillcolor="#C8E6C9"]
    AADC       [label="AADC\n(DOPA Decarboxylase)" fillcolor="#66BB6A"]
    PLP        [label="Pyridoxal-5'-P\n(PLP cofactor)" fillcolor="#A5D6A7"]
    dopamine   [label="Dopamine\n(DA)" fillcolor="#81C784"]
    DBH        [label="Dopamine β-\nHydroxylase (DBH)" fillcolor="#43A047"]
    ascorbate  [label="Ascorbate\n(DBH cofactor)" fillcolor="#A5D6A7"]
    NE_synth   [label="Norepinephrine\n(NE) — synthesized" fillcolor="#2E7D32" fontcolor=white]
    PNMT       [label="PNMT\n(phenylethanolamine\nN-methyltransferase)" fillcolor="#43A047"]
    SAM        [label="S-Adenosyl\nMethionine" fillcolor="#A5D6A7"]
    EPI_synth  [label="Epinephrine\n(EPI) — synthesized" fillcolor="#1B5E20" fontcolor=white]
    NMN_synth  [label="Normetanephrine\n(NMN) — O-methylation" fillcolor="#C8E6C9"]
    MN_synth   [label="Metanephrine\n(MN) — O-methylation" fillcolor="#C8E6C9"]
    COMT       [label="COMT\n(catechol-O-\nmethyltransferase)" fillcolor="#66BB6A"]
    MAO        [label="MAO-A/B\n(monoamine\noxidase)" fillcolor="#66BB6A"]
    VMA        [label="Vanillylmandelic Acid\n(VMA) — final metabolite" fillcolor="#DCEDC8"]
    HMVMA      [label="3-Methoxy-\n4-hydroxymandelic acid" fillcolor="#DCEDC8"]
  }

  // ─────────────────────────────────────────────────────────────
  // CLUSTER 4: Catecholamine Storage & Secretion
  // ─────────────────────────────────────────────────────────────
  subgraph cluster_storage {
    label="④ Catecholamine Storage & Secretion"
    style=filled fillcolor="#E3F2FD" color="#0D47A1" penwidth=2
    fontcolor="#0D47A1" fontsize=11 fontname="Helvetica-Bold"

    chromaffin_gran [label="Chromaffin\nGranules" fillcolor="#90CAF9"]
    VMAT2     [label="VMAT2\n(vesicular transporter)" fillcolor="#42A5F5"]
    ATP_gran  [label="ATP\n(co-stored)" fillcolor="#BBDEFB"]
    CgA_gran  [label="CgA\n(co-stored)" fillcolor="#BBDEFB"]
    Ca2_influx [label="Ca²⁺ Influx\n(N-type VGCC)" fillcolor="#1565C0" fontcolor=white]
    IP3_Ca    [label="IP3-gated\nCa²⁺ release" fillcolor="#42A5F5"]
    exocytosis [label="Exocytosis /\nVesicle Fusion" fillcolor="#1565C0" fontcolor=white]
    SNARE     [label="SNARE Complex\n(synaptobrevin)" fillcolor="#42A5F5"]
    Ach_nn    [label="Acetylcholine\n(splanchnic nerve)" fillcolor="#90CAF9"]
    nAChR     [label="Nicotinic\nAChR (α3β4)" fillcolor="#64B5F6"]
    NE_release [label="NE Released\n(extracellular)" fillcolor="#0D47A1" fontcolor=white]
    EPI_release [label="EPI Released\n(extracellular)" fillcolor="#0D47A1" fontcolor=white]
    NET_reup  [label="NET\n(norepinephrine\nreuptake transporter)" fillcolor="#42A5F5"]
    NET_vesicle [label="Reuptake →\nVesicle Re-storage" fillcolor="#BBDEFB"]
  }

  // ─────────────────────────────────────────────────────────────
  // CLUSTER 5: Adrenergic Receptor Signaling
  // ─────────────────────────────────────────────────────────────
  subgraph cluster_adrenergic {
    label="⑤ Adrenergic Receptor Signaling"
    style=filled fillcolor="#EDE7F6" color="#4527A0" penwidth=2
    fontcolor="#4527A0" fontsize=11 fontname="Helvetica-Bold"

    alpha1R  [label="α₁-AR\n(Gq-coupled)" fillcolor="#B39DDB"]
    alpha2R  [label="α₂-AR\n(Gi-coupled,\npresynaptic)" fillcolor="#9575CD"]
    beta1R   [label="β₁-AR\n(heart,\nGs-coupled)" fillcolor="#7E57C2"]
    beta2R   [label="β₂-AR\n(lung/vessels,\nGs-coupled)" fillcolor="#7E57C2"]
    beta3R   [label="β₃-AR\n(fat tissue)" fillcolor="#9575CD"]
    PLC      [label="PLC\n(phospholipase C)" fillcolor="#CE93D8"]
    IP3      [label="IP3" fillcolor="#CE93D8"]
    DAG      [label="DAG\n(diacylglycerol)" fillcolor="#CE93D8"]
    PKC      [label="PKC\n(protein kinase C)" fillcolor="#AB47BC"]
    Adenylyl_C [label="Adenylyl\nCyclase" fillcolor="#CE93D8"]
    cAMP     [label="cAMP\n↑ (β-stimulation)" fillcolor="#AB47BC"]
    PKA      [label="PKA\n(protein kinase A)" fillcolor="#8E24AA"]
    MAPK_sig [label="MAPK / ERK\nSignaling" fillcolor="#AB47BC"]
    Ca2_cell [label="Intracellular\nCa²⁺ ↑" fillcolor="#B39DDB"]
    Gi_inhib [label="Gi → ↓ cAMP\n(α₂ presynaptic)" fillcolor="#9575CD"]
  }

  // ─────────────────────────────────────────────────────────────
  // CLUSTER 6: Cardiovascular Effects
  // ─────────────────────────────────────────────────────────────
  subgraph cluster_cardio {
    label="⑥ Cardiovascular Effects"
    style=filled fillcolor="#FFEBEE" color="#B71C1C" penwidth=2
    fontcolor="#B71C1C" fontsize=11 fontname="Helvetica-Bold"

    SBP      [label="Systolic BP\n(mmHg)" fillcolor="#EF9A9A"]
    DBP      [label="Diastolic BP\n(mmHg)" fillcolor="#EF9A9A"]
    MAP      [label="Mean Arterial\nPressure (MAP)" fillcolor="#EF5350"]
    HR       [label="Heart Rate\n(bpm)" fillcolor="#EF9A9A"]
    CO       [label="Cardiac Output\n(L/min)" fillcolor="#E57373"]
    SVR      [label="Systemic Vascular\nResistance (SVR)" fillcolor="#EF5350"]
    LVEF     [label="LVEF (%)\nLV Function" fillcolor="#EF9A9A"]
    catecho_CM [label="Catecholamine\nCardiomyopathy" fillcolor="#C62828" fontcolor=white]
    takotsubo  [label="Takotsubo /\nTCM-like" fillcolor="#C62828" fontcolor=white]
    hyper_crisis [label="Hypertensive\nCrisis (>180/120)" fillcolor="#B71C1C" fontcolor=white]
    stroke_risk  [label="Stroke Risk\n(ICH/CVA)" fillcolor="#B71C1C" fontcolor=white]
    coronary_spasm [label="Coronary\nVasospasm" fillcolor="#E57373"]
    arrhythmia   [label="Arrhythmia\n(VT/VF)" fillcolor="#C62828" fontcolor=white]
    baroreflex   [label="Baroreceptor\nReflex" fillcolor="#EF9A9A"]
    RAAS         [label="RAAS Activation\n(renin↑)" fillcolor="#FFCDD2"]
  }

  // ─────────────────────────────────────────────────────────────
  // CLUSTER 7: Metabolic Effects
  // ─────────────────────────────────────────────────────────────
  subgraph cluster_metabolic {
    label="⑦ Metabolic Effects"
    style=filled fillcolor="#FFF8E1" color="#F57F17" penwidth=2
    fontcolor="#F57F17" fontsize=11 fontname="Helvetica-Bold"

    glycogenolysis [label="Hepatic\nGlycogenolysis\n(β₂/α₁)" fillcolor="#FFE082"]
    glucagon_sec   [label="Glucagon ↑\n(β₂ on α-cells)" fillcolor="#FFD54F"]
    insulin_suppr  [label="Insulin Suppression\n(α₂ on β-cells)" fillcolor="#FFD54F"]
    hyperglycemia  [label="Hyperglycemia\n(stress diabetes)" fillcolor="#FFA726"]
    FFA_mob        [label="FFA Mobilization\n(lipolysis)" fillcolor="#FFE082"]
    glycerol       [label="Glycerol ↑\n(β₃ on adipose)" fillcolor="#FFE082"]
    BAT_thermo     [label="BAT\nThermogenesis\n(β₃)" fillcolor="#FF8F00"]
    BMR_elev       [label="BMR Elevation\n(kcal/day)" fillcolor="#FFA726"]
    weight_loss    [label="Weight Loss /\nDiaphoresis" fillcolor="#FFB74D"]
    hyperlactate   [label="Hyperlactatemia\n(anaerobic shift)" fillcolor="#FFE082"]
    cortisol_sec   [label="Cortisol ↑\n(stress axis)" fillcolor="#FFD54F"]
    EPO_increase   [label="EPO ↑\n(erythrocytosis)" fillcolor="#FFE082"]
  }

  // ─────────────────────────────────────────────────────────────
  // CLUSTER 8: Drug PK — Alpha-blockers
  // ─────────────────────────────────────────────────────────────
  subgraph cluster_pk_alpha {
    label="⑧ Drug PK — Alpha-Blockers"
    style=filled fillcolor="#E8EAF6" color="#283593" penwidth=2
    fontcolor="#283593" fontsize=11 fontname="Helvetica-Bold"

    PHE_dose  [label="Phenoxybenzamine\nDose (PO)" fillcolor="#9FA8DA" shape=diamond]
    PHE_gut   [label="PHE\nGI Absorption" fillcolor="#7986CB"]
    PHE_C     [label="PHE Central\nCompartment" fillcolor="#5C6BC0"]
    PHE_P     [label="PHE Peripheral\nCompartment" fillcolor="#7986CB"]
    PHE_met   [label="PHE Hepatic\nMetabolism (CYP3A)" fillcolor="#9FA8DA"]
    DOX_dose  [label="Doxazosin\nDose (PO)" fillcolor="#9FA8DA" shape=diamond]
    DOX_gut   [label="DOX\nGI Absorption" fillcolor="#7986CB"]
    DOX_C     [label="DOX Central\nCompartment" fillcolor="#5C6BC0"]
    DOX_met   [label="DOX Hepatic\nElimination" fillcolor="#9FA8DA"]
    MET_dose  [label="Metyrosine\nDose (PO)" fillcolor="#9FA8DA" shape=diamond]
    MET_gut   [label="Metyrosine\nGI Absorption" fillcolor="#7986CB"]
    MET_C     [label="Metyrosine\nCentral" fillcolor="#5C6BC0"]
    MET_CNS   [label="Metyrosine\nCNS Penetration" fillcolor="#7986CB"]
    MET_elim  [label="Metyrosine\nRenal Elimination" fillcolor="#9FA8DA"]
    BB_dose   [label="β-Blocker\nDose (PO)" fillcolor="#9FA8DA" shape=diamond]
    BB_C      [label="β-Blocker\nCentral" fillcolor="#5C6BC0"]
    BB_met    [label="β-Blocker\nHepatic Elim." fillcolor="#9FA8DA"]
  }

  // ─────────────────────────────────────────────────────────────
  // CLUSTER 9: Drug PK — Systemic Therapies (Malignant PPGL)
  // ─────────────────────────────────────────────────────────────
  subgraph cluster_pk_systemic {
    label="⑨ Drug PK — Systemic Therapies (Malignant PPGL)"
    style=filled fillcolor="#E0F7FA" color="#006064" penwidth=2
    fontcolor="#006064" fontsize=11 fontname="Helvetica-Bold"

    SUNIT_dose  [label="Sunitinib\nDose (PO)" fillcolor="#80DEEA" shape=diamond]
    SUNIT_C     [label="Sunitinib\nCentral" fillcolor="#26C6DA"]
    SUNIT_P     [label="Sunitinib\nPeripheral" fillcolor="#26C6DA"]
    SUNIT_tumor [label="Sunitinib\nTumor Conc." fillcolor="#00ACC1"]
    SU12662     [label="SU12662\n(active metabolite)" fillcolor="#4DD0E1"]
    MIBG_dose   [label="¹³¹I-MIBG\nDose (IV)" fillcolor="#80DEEA" shape=diamond]
    MIBG_plasma [label="MIBG\nPlasma" fillcolor="#26C6DA"]
    MIBG_NET    [label="MIBG → NET\nTumor Uptake" fillcolor="#00ACC1"]
    DOTATATE_dose [label="¹⁷⁷Lu-DOTATATE\nDose (IV)" fillcolor="#80DEEA" shape=diamond]
    DOTATATE_C  [label="DOTATATE\nPlasma" fillcolor="#26C6DA"]
    DOTATATE_SSTR [label="SSTR2-mediated\nTumor Uptake" fillcolor="#00ACC1"]
    CVD_dose    [label="CVD Chemo\n(cyclophosphamide\n/vincristine/\ndacarbazine)" fillcolor="#80DEEA" shape=diamond]
    CVD_C       [label="CVD\nPlasma" fillcolor="#26C6DA"]
  }

  // ─────────────────────────────────────────────────────────────
  // CLUSTER 10: Drug PD & Clinical Endpoints
  // ─────────────────────────────────────────────────────────────
  subgraph cluster_pd {
    label="⑩ Drug PD & Biomarker Endpoints"
    style=filled fillcolor="#F1F8E9" color="#33691E" penwidth=2
    fontcolor="#33691E" fontsize=11 fontname="Helvetica-Bold"

    alpha1_occ  [label="α₁-AR\nOccupancy (PHE/DOX)" fillcolor="#AED581"]
    beta_occ    [label="β-AR\nOccupancy (BB)" fillcolor="#AED581"]
    TH_inhib    [label="TH Inhibition\n(Metyrosine Emax)" fillcolor="#8BC34A"]
    VEGFR_inhib [label="VEGFR/PDGFR\nInhibition (Sunitinib)" fillcolor="#7CB342"]
    tumor_TGI   [label="Tumor Growth\nInhibition (TGI%)" fillcolor="#558B2F" fontcolor=white]
    plasma_NMN  [label="Plasma\nNormetanephrine" fillcolor="#DCEDC8"]
    plasma_MN   [label="Plasma\nMetanephrine" fillcolor="#DCEDC8"]
    urine_cat   [label="24h Urine\nCatecholamines" fillcolor="#DCEDC8"]
    urine_VMA   [label="24h Urine\nVMA" fillcolor="#DCEDC8"]
    CgA_plasma  [label="Plasma CgA\n(tumor marker)" fillcolor="#DCEDC8"]
    RECIST_resp [label="RECIST\nResponse" fillcolor="#8BC34A"]
    surgical_cure [label="Surgical Cure\nRate (R0 resect)" fillcolor="#558B2F" fontcolor=white]
    recurrence  [label="Recurrence\nRisk (5-yr)" fillcolor="#8BC34A"]
    OS_ppgl     [label="Overall Survival\n(malignant)" fillcolor="#33691E" fontcolor=white]
  }

  // ─────────────────────────────────────────────────────────────
  // CLUSTER 11: Surgical & Perioperative Management
  // ─────────────────────────────────────────────────────────────
  subgraph cluster_surgical {
    label="⑪ Surgical & Perioperative Management"
    style=filled fillcolor="#FBE9E7" color="#BF360C" penwidth=2
    fontcolor="#BF360C" fontsize=11 fontname="Helvetica-Bold"

    preop_alpha [label="Preop Alpha-\nBlockade (10-14d)" fillcolor="#FFAB91"]
    preop_beta  [label="Preop Beta-\nBlockade (after α)" fillcolor="#FF8A65"]
    preop_metyrosine [label="Preop Metyrosine\n(high-risk/bilateral)" fillcolor="#FF7043"]
    volume_load [label="IV Fluid\nVolume Loading" fillcolor="#FFAB91"]
    laparoscopic [label="Laparoscopic\nAdrenalectomy" fillcolor="#BF360C" fontcolor=white]
    open_surgery [label="Open Adrenalectomy\n(large/malignant)" fillcolor="#BF360C" fontcolor=white]
    intraop_crisis [label="Intraop\nHypertensive Crisis" fillcolor="#E64A19" fontcolor=white]
    phentolamine  [label="IV Phentolamine\n(intraop rescue)" fillcolor="#FF7043"]
    sodium_nitro  [label="Sodium Nitroprusside\n(intraop)" fillcolor="#FF7043"]
    postop_hypotension [label="Postop\nHypotension Risk" fillcolor="#FF8A65"]
    cortisol_replace   [label="Cortisol\nReplacement\n(bilateral adrenalectomy)" fillcolor="#FFAB91"]
    cure_biomarker     [label="Biochemical Cure\n(NMN/MN → normal)" fillcolor="#D84315" fontcolor=white]
  }

  // ─────────────────────────────────────────────────────────────
  // EDGES: Genetic Drivers → Tumor & Synthesis
  // ─────────────────────────────────────────────────────────────
  SDHB -> succinate_accum [label="loss-of-function" color="#E65100"]
  SDHC -> succinate_accum
  SDHD -> succinate_accum
  SDHA -> succinate_accum
  succinate_accum -> pseudohypoxia [label="HIF stabilization" color="#E65100"]
  VHL  -> pseudohypoxia [label="VHL loss →\nHIF stabilization" color="#E65100"]
  pseudohypoxia -> HIF1a
  HIF1a -> VEGF_t
  HIF1a -> EPO_increase
  RET  -> kinase_cluster [label="gain-of-function" color="#E65100"]
  NF1  -> kinase_cluster [label="RAS disinhibition" color="#E65100"]
  TMEM127 -> kinase_cluster
  kinase_cluster -> tumor_prolif
  MAX  -> tumor_prolif [label="MYC de-repression" color="#E65100"]
  EPAS1 -> HIF1a
  SDHB -> malignant_ppgl [label="metastasis risk\n(14%→80%)" color="#B71C1C" style=bold]
  hereditary_ppgl -> SDHB
  hereditary_ppgl -> RET
  hereditary_ppgl -> VHL
  hereditary_ppgl -> NF1
  sporadic_ppgl -> tumor_prolif

  // ─────────────────────────────────────────────────────────────
  // EDGES: Tumor Biology
  // ─────────────────────────────────────────────────────────────
  chromaffin_cell -> tumor_prolif
  chromaffin_cell -> chromogranin_A
  chromaffin_cell -> NSE
  tumor_prolif -> tumor_volume [label="net growth"]
  tumor_apoptosis -> tumor_volume [label="cell loss" color="#1B5E20"]
  tumor_volume -> VEGF_t [style=dashed]
  tumor_volume -> hypoxia_t
  hypoxia_t -> HIF1a
  VEGF_t -> angio
  PDGFb -> angio
  FGF -> angio
  angio -> tumor_volume [label="oxygen supply\nsupports growth" color="#1B5E20"]
  necrosis -> tumor_volume [label="core necrosis\n(large tumor)" color="#B71C1C"]
  malignant_ppgl -> metastasis [label="liver/bone/lung\nmets"]
  chromogranin_A -> CgA_gran

  // ─────────────────────────────────────────────────────────────
  // EDGES: Catecholamine Biosynthesis
  // ─────────────────────────────────────────────────────────────
  tyrosine -> TH [label="substrate"]
  BH4 -> TH [label="cofactor"]
  TH -> DOPA [label="hydroxylation\n(rate-limiting)"]
  PLP -> AADC [label="cofactor"]
  DOPA -> AADC
  AADC -> dopamine
  dopamine -> DBH [label="substrate"]
  ascorbate -> DBH [label="cofactor"]
  DBH -> NE_synth
  NE_synth -> PNMT [label="substrate (adrenal medulla)"]
  SAM -> PNMT [label="methyl donor"]
  PNMT -> EPI_synth
  NE_synth -> COMT [label="O-methylation"]
  EPI_synth -> COMT [label="O-methylation"]
  COMT -> NMN_synth [label="NE → NMN"]
  COMT -> MN_synth [label="EPI → MN"]
  NE_synth -> MAO [label="oxidative\ndeamination"]
  EPI_synth -> MAO
  MAO -> VMA [label="→ MHPG → VMA"]
  MAO -> HMVMA
  NE_synth -> chromaffin_gran [label="VMAT2 loading" color="#0D47A1"]
  EPI_synth -> chromaffin_gran [label="VMAT2 loading" color="#0D47A1"]

  // ─────────────────────────────────────────────────────────────
  // EDGES: Storage & Secretion
  // ─────────────────────────────────────────────────────────────
  chromaffin_gran -> VMAT2
  VMAT2 -> ATP_gran
  VMAT2 -> CgA_gran
  Ach_nn -> nAChR [label="splanchnic\nstimulation"]
  nAChR -> Ca2_influx
  Ca2_influx -> exocytosis
  IP3 -> IP3_Ca
  IP3_Ca -> Ca2_influx
  exocytosis -> SNARE
  SNARE -> NE_release
  SNARE -> EPI_release
  chromaffin_gran -> exocytosis [label="granule fusion"]
  NE_release -> NET_reup [label="reuptake 75%"]
  NET_reup -> NET_vesicle

  // ─────────────────────────────────────────────────────────────
  // EDGES: Adrenergic Signaling
  // ─────────────────────────────────────────────────────────────
  NE_release -> alpha1R
  NE_release -> alpha2R
  NE_release -> beta1R
  NE_release -> beta2R
  EPI_release -> alpha1R
  EPI_release -> beta1R
  EPI_release -> beta2R
  EPI_release -> beta3R
  alpha1R -> PLC [label="Gq"]
  PLC -> IP3
  PLC -> DAG
  DAG -> PKC
  IP3 -> Ca2_cell
  Ca2_cell -> exocytosis [style=dashed label="augmented\nrelease" color="#4527A0"]
  alpha2R -> Gi_inhib [label="Gi"]
  Gi_inhib -> Adenylyl_C [label="↓ cAMP" color="#4527A0"]
  beta1R -> Adenylyl_C [label="Gs → ↑ cAMP"]
  beta2R -> Adenylyl_C [label="Gs"]
  Adenylyl_C -> cAMP
  cAMP -> PKA
  PKA -> MAPK_sig
  PKA -> glycogenolysis [color="#F57F17"]

  // ─────────────────────────────────────────────────────────────
  // EDGES: Cardiovascular Effects
  // ─────────────────────────────────────────────────────────────
  alpha1R -> SVR [label="vasoconstriction\n↑ SVR"]
  SVR -> SBP
  SVR -> DBP
  SVR -> MAP
  beta1R -> HR [label="positive\nchronotropy"]
  beta1R -> CO [label="positive\ninotropy"]
  HR -> CO [label="CO = HR × SV"]
  CO -> SBP [style=dashed]
  MAP -> baroreflex [label="baroreceptor\nresponse"]
  baroreflex -> HR [label="reflex bradycardia\n(vagal)" color="#1B5E20"]
  catecho_CM -> LVEF [label="↓ EF" color="#B71C1C"]
  NE_release -> catecho_CM [label="chronic\nstimulation" color="#B71C1C"]
  EPI_release -> catecho_CM [color="#B71C1C"]
  takotsubo -> LVEF [label="apical ballooning" color="#B71C1C"]
  MAP -> hyper_crisis [label="≥180 mmHg" color="#B71C1C" style=bold]
  hyper_crisis -> stroke_risk [color="#B71C1C"]
  hyper_crisis -> coronary_spasm [color="#B71C1C"]
  NE_release -> arrhythmia [label="QT prolongation\nVT/VF" color="#B71C1C"]
  MAP -> RAAS [label="renin release"]
  RAAS -> SVR [label="AII → vasoconstriction"]

  // ─────────────────────────────────────────────────────────────
  // EDGES: Metabolic Effects
  // ─────────────────────────────────────────────────────────────
  PKA -> glycogenolysis
  glucagon_sec -> hyperglycemia
  glycogenolysis -> hyperglycemia
  insulin_suppr -> hyperglycemia [label="↓ glucose uptake"]
  alpha2R -> insulin_suppr [label="α₂ on\nβ-cells"]
  beta2R -> glucagon_sec [label="β₂ on\nα-cells"]
  beta3R -> FFA_mob [label="lipolysis"]
  beta3R -> glycerol
  beta3R -> BAT_thermo
  BAT_thermo -> BMR_elev
  BMR_elev -> weight_loss
  hyperglycemia -> hyperlactate [style=dashed]
  cortisol_sec -> hyperglycemia [label="gluconeogenesis"]
  HIF1a -> EPO_increase [label="renal EPO\ninduction"]

  // ─────────────────────────────────────────────────────────────
  // EDGES: Alpha-blocker PK → PD
  // ─────────────────────────────────────────────────────────────
  PHE_dose -> PHE_gut
  PHE_gut -> PHE_C [label="ka=0.69 h⁻¹"]
  PHE_C -> PHE_P [label="CL_d"]
  PHE_P -> PHE_C [label="CL_d"]
  PHE_C -> PHE_met [label="CL=0.24 L/h/kg"]
  PHE_C -> alpha1_occ [label="irreversible\nalkylation\nIC50=2nM"]
  DOX_dose -> DOX_gut
  DOX_gut -> DOX_C [label="F=65%"]
  DOX_C -> DOX_met [label="t½=22h"]
  DOX_C -> alpha1_occ [label="competitive\nKi=0.1 nM"]
  MET_dose -> MET_gut
  MET_gut -> MET_C [label="ka=0.7 h⁻¹"]
  MET_C -> MET_CNS [label="BBB permeant"]
  MET_C -> MET_elim [label="renal 65%"]
  MET_C -> TH_inhib [label="competitive\nTH inhibition\nIC50=80 µM"]
  BB_dose -> BB_C [label="F=30-40%"]
  BB_C -> BB_met [label="t½=3-6h"]
  BB_C -> beta_occ [label="Ki=1-10 nM"]

  // ─────────────────────────────────────────────────────────────
  // EDGES: Systemic therapies
  // ─────────────────────────────────────────────────────────────
  SUNIT_dose -> SUNIT_C
  SUNIT_C -> SUNIT_P [label="CL_d"]
  SUNIT_P -> SUNIT_C
  SUNIT_C -> SU12662 [label="CYP3A4 oxidation"]
  SUNIT_C -> SUNIT_tumor [label="tumor\npenetration"]
  SUNIT_tumor -> VEGFR_inhib [label="VEGFR1/2/3\nPDGFRα/β\nIC50=1-10 nM"]
  VEGFR_inhib -> angio [label="↓ angiogenesis" color="#006064"]
  VEGFR_inhib -> tumor_TGI [label="anti-proliferative"]
  MIBG_dose -> MIBG_plasma
  MIBG_plasma -> MIBG_NET [label="NET-mediated\nuptake (NE analog)"]
  MIBG_NET -> tumor_TGI [label="β-radiation\ninternal therapy"]
  DOTATATE_dose -> DOTATATE_C
  DOTATATE_C -> DOTATATE_SSTR [label="SSTR2 receptor\n(>90% PPGL)"]
  DOTATATE_SSTR -> tumor_TGI [label="¹⁷⁷Lu β-radiation"]
  CVD_dose -> CVD_C
  CVD_C -> tumor_TGI [label="DNA damage\n(cyclophosphamide)\ntubule disruption\n(vincristine)"]

  // ─────────────────────────────────────────────────────────────
  // EDGES: Drug PD → Clinical Endpoints
  // ─────────────────────────────────────────────────────────────
  alpha1_occ -> SVR [label="↓ vasoconstriction" color="#283593"]
  alpha1_occ -> SBP [label="↓ SBP" color="#283593"]
  alpha1_occ -> DBP [label="↓ DBP" color="#283593"]
  beta_occ -> HR [label="↓ chronotropy" color="#283593"]
  beta_occ -> CO [label="↓ CO" color="#283593"]
  TH_inhib -> NE_synth [label="↓ synthesis 40-80%" color="#283593"]
  TH_inhib -> EPI_synth [label="↓ synthesis" color="#283593"]
  NE_synth -> plasma_NMN [label="O-methylation\n→ biomarker"]
  EPI_synth -> plasma_MN [label="O-methylation\n→ biomarker"]
  NE_release -> urine_cat
  EPI_release -> urine_cat
  NMN_synth -> plasma_NMN
  MN_synth -> plasma_MN
  VMA -> urine_VMA
  HMVMA -> urine_VMA
  chromogranin_A -> CgA_plasma
  tumor_TGI -> RECIST_resp [label="PR/CR/SD"]
  tumor_TGI -> tumor_volume [label="↓ volume" color="#1B5E20"]
  tumor_volume -> OS_ppgl [style=dashed]
  malignant_ppgl -> OS_ppgl
  recurrence -> OS_ppgl [style=dashed]

  // ─────────────────────────────────────────────────────────────
  // EDGES: Surgical Management
  // ─────────────────────────────────────────────────────────────
  PHE_dose -> preop_alpha [style=dashed color="#BF360C"]
  DOX_dose -> preop_alpha [style=dashed color="#BF360C"]
  preop_alpha -> volume_load [label="α-block → reflex\nfluid retention"]
  preop_alpha -> preop_beta [label="must precede β-block"]
  MET_dose -> preop_metyrosine [style=dashed color="#BF360C"]
  preop_alpha -> laparoscopic [label="10-14d prep\n→ adrenalectomy"]
  preop_alpha -> open_surgery
  preop_metyrosine -> laparoscopic
  laparoscopic -> intraop_crisis [label="manipulation\nrelease" color="#E64A19"]
  open_surgery -> intraop_crisis [color="#E64A19"]
  intraop_crisis -> phentolamine [label="IV rescue"]
  intraop_crisis -> sodium_nitro [label="IV rescue"]
  laparoscopic -> cure_biomarker [label="R0 → normalization"]
  open_surgery -> cure_biomarker
  cure_biomarker -> plasma_NMN [label="↓ to normal" color="#1B5E20"]
  cure_biomarker -> plasma_MN [label="↓ to normal" color="#1B5E20"]
  laparoscopic -> postop_hypotension [label="catecholamine\ndrop"]
  postop_hypotension -> volume_load [label="rescue"]
  laparoscopic -> cortisol_replace [label="bilateral\ncortisol deficit"]
  laparoscopic -> surgical_cure
  surgical_cure -> recurrence [label="5-yr risk: 7-17%"]
  recurrence -> plasma_NMN [label="≥3× ULN\nsuggests recurrence" style=dashed]
}
