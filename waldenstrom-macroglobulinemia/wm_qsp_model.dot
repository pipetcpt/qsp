  /* ============================================================
     CLUSTER 11 — Clinical Endpoints / Response Criteria
  ============================================================ */
  subgraph cluster_clinical {
    label="Clinical Endpoints & Response Criteria (Owen/IWWM)" style=filled fillcolor="#E8F8F5"
    color="#0E6655" penwidth=2.5 fontname="Helvetica-Bold" fontsize=13

    node [fillcolor="#A9DFBF"]
    IgM_resp  [label="IgM Response\n(serum g/L)"]
    BM_resp   [label="BM Biopsy\nLPC% response"]
    Hgb_resp  [label="Hemoglobin\nResponse\n(g/dL)"]
    CR_crit   [label="Complete Response (CR)\nIgM normal\nBM biopsy\nnormal\nno symptoms"]
    VGPR_crit [label="Very Good PR\nIgM ↓ >90%"]
    PR_crit   [label="Partial Response\nIgM ↓ >50%"]
    MR_crit   [label="Minor Response\nIgM ↓ 25-50%"]
    SD_crit   [label="Stable Disease\nIgM ↓ <25%\nor ↑ <25%"]
    PD_crit   [label="Progressive\nDisease\nIgM ↑ >25%"]
    PFS       [label="Progression-Free\nSurvival (PFS)"]
    OS        [label="Overall\nSurvival (OS)"]
    TTNT      [label="Time to Next\nTreatment"]
    ORR       [label="Overall\nResponse Rate\n(≥MR)"]
    MRD       [label="MRD (minimal\nresidual disease)"]
    QoL       [label="Quality of Life\nFACT-Lym·EORTC"]

    IgM_serum -> IgM_resp   [label="monitor"]
    BM_inf    -> BM_resp    [label="assess"]
    Hb_low    -> Hgb_resp   [label="Hgb\ntracking"]
    IgM_resp  -> CR_crit    [label="if normal"]
    IgM_resp  -> VGPR_crit  [label="↓>90%"]
    IgM_resp  -> PR_crit    [label="↓>50%"]
    IgM_resp  -> MR_crit    [label="↓25-50%"]
    IgM_resp  -> SD_crit    [label="minimal Δ"]
    IgM_resp  -> PD_crit    [label="↑>25%"]
    VGPR_crit -> PFS        [label="correlates"]
    PR_crit   -> PFS        [label="correlates"]
    PFS       -> OS         [label="surrogate"]
    PD_crit   -> TTNT       [label="triggers"]
    CR_crit   -> MRD        [label="assess\nifCR"]
    QoL       -> OS         [label="patient\nreport"]
    ORR       -> PR_crit    [label="≥PR"]
    ORR       -> MR_crit    [label="or ≥MR"]
  }

  /* ============================================================
     CLUSTER 12 — Genetic / Epigenetic Landscape
  ============================================================ */
  subgraph cluster_genetics {
    label="Genomic & Epigenetic Landscape of WM" style=filled fillcolor="#F0FFF0"
    color="#1B7A1B" penwidth=2.5 fontname="Helvetica-Bold" fontsize=13

    node [fillcolor="#90EE90"]
    MYD88_gene[label="MYD88 L265P\n★ ~95% WM\n(most common\nhematologic mut)"]
    CXCR4_gene[label="CXCR4 WHIM mut\n~35% WM\n(S338X, etc.)"]
    CD79B_mut [label="CD79B mut\n~15% WM\n(BCR signaling↑)"]
    TP53_del  [label="TP53 del/mut\n(rare, R/R WM)"]
    del6q     [label="6q deletion\n(TNFAIP3·PRDM1\n~50% WM)"]
    HIST_mut  [label="Histone mutations\n(ARID1A·KMT2D)\nepigenetic"]
    TRRAP_mut [label="TRRAP\nTRRSF13B\nmutations"]
    chr12_tri [label="Trisomy 4\nTrisomy 12\n(clonal evol.)"]
    IgH_del   [label="IgH translocation\n(rare vs MM)"]
    TP53_p    [label="p53 (TP53)\nDNA damage\nsensor"]
    p21       [label="p21/CDKN1A\nCDK2 inhibitor\ncell cycle arrest"]

    MYD88_gene -> MYD88_mut [label="drives\nonco signal"]
    CXCR4_gene -> CXCR4_whim[label="BM retention↑"]
    CD79B_mut  -> BCR       [label="hyperactivate"]
    TP53_del   -> TP53_p    [label="loss of function"]
    del6q      -> NFkB_nuc  [label="derepresses\nNF-κB"]
    HIST_mut   -> MYC_t     [label="epigenetic\nupregulate"]
    TP53_p     -> p21       [label="transcription"]
    p21        -> CCND1     [label="inhibits\nCDK4/6" color="#E74C3C"]
  }

  /* ============================================================
     INTER-CLUSTER CONNECTIONS
  ============================================================ */
  // MYD88→BTK feedback
  MYD88_mut  -> BTK_myd   [label="MYD88→HCK→BTK" color="#1A5276" style=bold lhead=cluster_myd88]
  BTK        -> NFkB_p65  [label="indirect NF-κB" color="#C0392B"]
  BTK        -> PI3K_d    [label="PI3K-δ act" color="#1E8449"]
  AKT_bcr    -> mTORC1    [label="→mTOR" color="#1E8449"]
  AKT_bcr    -> AKT_main  [label="converge"]
  CARD11     -> IKKb      [label="IKK\nactivation" color="#1A5276"]
  IKKb       -> IkBa      [label="pS32/36\ndegradation"]

  // BCR → BTK → NF-κB
  BTK        -> PLCg2     [color="#C0392B"]
  PKC_beta   -> IKKb      [label="PKCβ→IKK"]

  // CXCR4 → PI3K/AKT
  PI3K_cx    -> PIP3      [color="#1E8449"]

  // Drug effects on core nodes
  IBR_BTK    -> NFkB_nuc  [label="IBR blocks\nBTK→NF-κB\n↓" color="#C0392B" style=dashed]
  VEN_BCL2   -> BCL2_main [label="VEN binds\nBCL-2" color="#922B21" style=dashed]
  BOR_IkBa   -> NFkB_nuc  [label="BOR→IκBα stab\n→NF-κB↓" color="#922B21" style=dashed]

  // LPC proliferation feedback
  LPC        -> MYD88L265 [label="LPC\nharborsMut" style=invis]
  MYD88L265  -> NFkB_nuc  [label="constitutive\nNF-κB" color="#1A5276" lhead=cluster_myd88]
  NFkB_nuc   -> LPC       [label="surviv·prolif\ntargets" color="#1A5276"]

  // Cell death convergence
  CASP3      -> LPC       [label="apoptosis\nkills LPC" color="#922B21"]
  CASP3      -> PC_IgM    [label="kills PC" color="#922B21"]

  // IgM → clinical
  IgM_serum  -> IgM_resp  [label="serum\nconc" color="#0E6655"]
  Hb_low     -> Hgb_resp  [label="CBC" color="#0E6655"]

  // Plasmapheresis acute effect
  PLASM      -> IgM_serum [label="acutely\n↓IgM" color="#D68910" style=dashed]
}
