    EVE_mTOR -> mTORC1   [label="FKBP12\nallosteric" color="#C0392B"]
    IXAZ_prot-> proteasome[label="β5" color="#C0392B"]
    CARFIL   -> proteasome[label="β5 irrev" color="#C0392B"]
