digraph MigraineQSP {
    graph [
        label="Migraine QSP Model — Trigeminovascular, CGRP, CSD & Drug PK/PD"
        fontname="Helvetica" fontsize=22 fontcolor="#1a1a2e"
        bgcolor="#f8f9ff"
        rankdir=TB
        splines=true
        nodesep=0.45
        ranksep=0.7
        pad=0.6
        tooltip="Migraine QSP Mechanistic Map"
    ]
    node [fontname="Helvetica" fontsize=10 style="filled,rounded" shape=box]
    edge [fontname="Helvetica" fontsize=9 penwidth=1.2]

    /* =====================================================================
     * CLUSTER 1 — TRIGGER FACTORS
     * ===================================================================== */
    subgraph cluster_triggers {
        label="Trigger Factors" fontsize=14 fontcolor="#7b2d8b"
        style=filled fillcolor="#f3e8ff" color="#7b2d8b" penwidth=2
        node [fillcolor="#e8d5f5" color="#7b2d8b"]

        TRG_STRESS   [label="Psychological Stress\n(HPA activation)"]
        TRG_HORMONE  [label="Hormonal Fluctuation\n(estrogen drop)"]
        TRG_SLEEP    [label="Sleep Disruption\n(circadian misalignment)"]
        TRG_DIET     [label="Dietary Triggers\n(tyramine, nitrates, alcohol)"]
        TRG_SENSORY  [label="Sensory Stimuli\n(bright light, loud noise)"]
        TRG_WEATHER  [label="Weather/Barometric\nPressure Changes"]
        TRG_FASTING  [label="Fasting / Hypoglycemia\n(glucose ↓)"]
        TRG_CAFFEINE [label="Caffeine Withdrawal\n(adenosine rebound)"]
        TRG_NTG      [label="Nitroglycerin (NTG)\nExperimental Trigger"]
    }

    /* =====================================================================
     * CLUSTER 2 — CORTICAL SPREADING DEPRESSION (CSD)
     * ===================================================================== */
    subgraph cluster_csd {
        label="Cortical Spreading Depression (CSD) — Aura" fontsize=14 fontcolor="#c0392b"
        style=filled fillcolor="#fff0ee" color="#c0392b" penwidth=2
        node [fillcolor="#ffd5d0" color="#c0392b"]

        CSD_INIT     [label="CSD Initiation\n(cortical hyperexcitability)"]
        CSD_WAVE     [label="CSD Wave Propagation\n(3–5 mm/min anterior→posterior)"]
        CSD_K_RELEASE [label="K⁺ Release\n(extracellular [K⁺] 30–80 mM)"]
        CSD_GLU      [label="Glutamate Release\n(NMDA receptor activation)"]
        CSD_NMDAR    [label="NMDA Receptor\nActivation"]
        CSD_CA_INFLUX [label="Ca²⁺ Influx\n(intracellular [Ca²⁺] ↑)"]
        CSD_DEPOL    [label="Neuronal Depolarization\n(DC shift)"]
        CSD_SILENCE  [label="Neuronal Silencing\n(post-CSD suppression)"]
        CSD_CBF      [label="Cerebral Blood Flow\nBiphasic: ↑ then ↓"]
        CSD_AURA     [label="Visual Aura\n(scotoma, fortification spectra)"]
        CSD_HYPOXIA  [label="Cortical Hypoxia\n(oligemia phase)"]
        CSD_FREQ     [label="CSD Frequency\n(# events/attack)"]
        CSD_THRESH   [label="CSD Threshold\n(cortical excitability)"]
        CSD_pH       [label="Extracellular Acidosis\n(pH ↓ 0.2–0.5 units)"]
        CSD_NO       [label="NO Release from\nCortical Neurons"]
        CSD_PROSTA   [label="Prostaglandin Release\nfrom Cortex"]
    }

    /* =====================================================================
     * CLUSTER 3 — TRIGEMINOVASCULAR SYSTEM
     * ===================================================================== */
    subgraph cluster_tgv {
        label="Trigeminovascular System" fontsize=14 fontcolor="#1a5276"
        style=filled fillcolor="#e8f4fd" color="#1a5276" penwidth=2
        node [fillcolor="#c8e6f5" color="#1a5276"]

        TG_NEURON    [label="Trigeminal Ganglion\n(1st-order neuron, Aδ/C fibers)"]
        TG_SYNTH     [label="CGRP Synthesis\n(CALCA/CALCB gene)"]
        TG_STORE     [label="Neuropeptide Storage\n(vesicles: CGRP, SP, PACAP)"]
        TG_PERIVA    [label="Perivascular\nTrigeminal Afferents"]
        TG_DURAL     [label="Dural Nociceptors\n(meningeal sensitization)"]
        TG_RELEASE   [label="Neuropeptide Release\n(Ca²⁺-dependent exocytosis)"]
        TG_ANTIDROM  [label="Antidromic Signal\nPropagation"]
        TNC_2ND      [label="Trigeminal Nucleus Caudalis\n(TNC, 2nd-order neuron)"]
        TNC_GLUTAMATE [label="Glutamate/AMPA\nSignaling in TNC"]
        TNC_NK1      [label="NK1 Receptor\n(substance P binding)"]
        TNC_NMDAR_TNC [label="NMDA Receptor\n(TNC, central sensitization)"]
        TNC_WIND_UP  [label="Wind-up Phenomenon\n(temporal summation)"]
        TCC          [label="Trigeminocervical Complex\n(TCC, C1-C2 convergence)"]
        PAG          [label="Periaqueductal Gray\n(PAG, descending modulation)"]
        NRM          [label="Nucleus Raphe Magnus\n(NRM, serotonergic)"]
        LC           [label="Locus Coeruleus\n(LC, noradrenergic)"]
        THALAMUS     [label="Thalamus\n(3rd-order neuron, VPM/PO)"]
        CORTEX_PAIN  [label="Somatosensory Cortex\n(pain perception)"]
    }

    /* =====================================================================
     * CLUSTER 4 — CGRP SIGNALING
     * ===================================================================== */
    subgraph cluster_cgrp {
        label="CGRP Signaling Pathway" fontsize=14 fontcolor="#117a65"
        style=filled fillcolor="#e8f8f5" color="#117a65" penwidth=2
        node [fillcolor="#c3efea" color="#117a65"]

        CGRP_MOL     [label="CGRP (37 aa peptide)\nα-CGRP dominant in TG"]
        CGRP_R       [label="CGRP Receptor\n(CLR + RAMP1 heterodimer)"]
        CGRP_CAMP    [label="cAMP ↑\n(Gs-protein coupled)"]
        CGRP_PKA     [label="PKA Activation\n(phosphorylation cascades)"]
        CGRP_KATP    [label="KATP Channel Opening\n(vascular smooth muscle)"]
        CGRP_VASC    [label="Vasodilation\n(meningeal/dural vessels)"]
        CGRP_EDEMA   [label="Protein Extravasation\n(plasma leakage)"]
        CGRP_MAST    [label="Mast Cell Degranulation\n(histamine, serotonin)"]
        CGRP_MICRO   [label="Microglial Activation\n(neuroinflammation)"]
        CGRP_SP      [label="Substance P Release\n(co-transmitter)"]
        CGRP_PACAP   [label="PACAP-38/PACAP-27\n(VIP family, vasodilator)"]
        CGRP_PLASMA  [label="Plasma CGRP Level\n(ictal: ↑ 2–4×)"]
        CGRP_JV      [label="Jugular Venous CGRP\n(clinical biomarker)"]
    }

    /* =====================================================================
     * CLUSTER 5 — NITRIC OXIDE & PROSTANOID PATHWAYS
     * ===================================================================== */
    subgraph cluster_no {
        label="Nitric Oxide & Prostanoid Pathways" fontsize=14 fontcolor="#784212"
        style=filled fillcolor="#fdf3e7" color="#784212" penwidth=2
        node [fillcolor="#f9e3c8" color="#784212"]

        NTG_DOSE     [label="Nitroglycerin (NTG)\n0.5 μg/kg/min IV"]
        NO_SYNTH     [label="eNOS / nNOS\nNO Synthesis"]
        NO_MOL       [label="Nitric Oxide (NO)\n(free radical, t½ < 1 s)"]
        SGC          [label="Soluble Guanylyl Cyclase\n(sGC activation)"]
        CGMP         [label="cGMP ↑\n(vasodilation, TG sensitization)"]
        PDE5         [label="PDE5\n(cGMP degradation)"]
        COX1         [label="COX-1\n(constitutive)"]
        COX2         [label="COX-2\n(inducible, neuroinflammation)"]
        PGE2         [label="Prostaglandin E2 (PGE2)\n(EP1/EP2/EP3/EP4 receptors)"]
        TRPV1        [label="TRPV1 Channel\n(PGE2 sensitization → heat pain)"]
        TRPA1        [label="TRPA1 Channel\n(inflammatory mediators)"]
        PGI2         [label="Prostacyclin (PGI2)\n(IP receptor, vasodilation)"]
        TXA2         [label="Thromboxane A2\n(platelet aggregation)"]
        AA_POOL      [label="Arachidonic Acid Pool\n(membrane phospholipids)"]
        PLA2         [label="Phospholipase A2\n(cPLA2α, liberation of AA)"]
    }

    /* =====================================================================
     * CLUSTER 6 — SEROTONIN SYSTEM
     * ===================================================================== */
    subgraph cluster_5ht {
        label="Serotonin (5-HT) System" fontsize=14 fontcolor="#1b4f72"
        style=filled fillcolor="#eaf2fb" color="#1b4f72" penwidth=2
        node [fillcolor="#d0e8f8" color="#1b4f72"]

        SER_SYNTH    [label="5-HT Synthesis\n(Tryptophan → 5-HTP → 5-HT)"]
        SER_STORE    [label="5-HT Storage\n(platelets, enterochromaffin)"]
        SER_RELEASE  [label="5-HT Release\n(ictal: ↑ then ↓)"]
        R_5HT1B      [label="5-HT1B Receptor\n(presynaptic, vasoconstriction)"]
        R_5HT1D      [label="5-HT1D Receptor\n(TG neuron, CGRP inhibition)"]
        R_5HT1F      [label="5-HT1F Receptor\n(TNC neuron, no vasoconstriction)"]
        R_5HT2A      [label="5-HT2A Receptor\n(CSD threshold modulation)"]
        R_5HT3       [label="5-HT3 Receptor\n(nausea/vomiting pathway)"]
        SERT         [label="Serotonin Transporter\n(SERT, reuptake)"]
        SER_PLASM    [label="Plasma 5-HT\n(ictal ↓, postictal ↓)"]
        DRN          [label="Dorsal Raphe Nucleus\n(DRN, serotonergic)"]
        CIT          [label="Serotonin Deficiency\n(interictal, chronic migraine)"]
    }

    /* =====================================================================
     * CLUSTER 7 — CENTRAL SENSITIZATION & ALLODYNIA
     * ===================================================================== */
    subgraph cluster_central {
        label="Central Sensitization & Allodynia" fontsize=14 fontcolor="#4a235a"
        style=filled fillcolor="#f5eef8" color="#4a235a" penwidth=2
        node [fillcolor="#e8d5f0" color="#4a235a"]

        CS_INIT      [label="Central Sensitization\nInitiation (≥ 10 min attack)"]
        CS_2ND       [label="2nd-Order Neuron\nHyperexcitability"]
        CS_3RD       [label="3rd-Order Neuron\nHyperexcitability"]
        ALLODYNIA_M  [label="Mechanical Allodynia\n(cutaneous sensitization)"]
        ALLODYNIA_T  [label="Thermal Allodynia\n(cephalic/extracephalic)"]
        PHONO        [label="Phonophobia\n(auditory cortex sensitization)"]
        PHOTO        [label="Photophobia\n(retino-hypothalamic sensitization)"]
        OSMO         [label="Osmophobia\n(olfactory bulb sensitization)"]
        NAUSEA       [label="Nausea / Vomiting\n(CTZ, vestibular nucleus)"]
        PROST_SENS   [label="Post-Translational\nSensitization (AMPA/NMDA)"]
        PKC_EPS      [label="PKCε Activation\n(long-term sensitization)"]
        MAPK         [label="MAPK/ERK Signaling\n(transcription, chronic migraine)"]
        BDNF_CS      [label="BDNF Upregulation\n(TrkB signaling, CS perpetuation)"]
        CXCL3        [label="Cytokines (IL-1β, TNF-α)\n(glial activation, CS)"]
        MICROGLIA    [label="Microglial Activation\n(neuroinflammation, LTP)"]
    }

    /* =====================================================================
     * CLUSTER 8 — MENINGEAL INFLAMMATION
     * ===================================================================== */
    subgraph cluster_mening {
        label="Meningeal Inflammation" fontsize=14 fontcolor="#922b21"
        style=filled fillcolor="#fdedec" color="#922b21" penwidth=2
        node [fillcolor="#fadbd8" color="#922b21"]

        DURA_MAST    [label="Dural Mast Cells\n(CGRP-triggered degranulation)"]
        HIST_RELEASE [label="Histamine Release\n(H1/H2/H4 receptors)"]
        BRAD_RELEASE [label="Bradykinin Release\n(B1/B2 receptors)"]
        SEROT_MAST   [label="Serotonin from\nMast Cells"]
        TNF_DM       [label="TNF-α / IL-6 Release\n(dural mast cells)"]
        PLASMA_EXT   [label="Plasma Protein Extravasation\n(PPE, neurogenic edema)"]
        NFKB_ACT     [label="NF-κB Activation\n(COX-2 upregulation)"]
        ROS_DURA     [label="Reactive Oxygen Species\n(oxidative stress)"]
        ENDOTHELIN   [label="Endothelin-1 Release\n(ET-A/ET-B vasoconstriction)"]
        DURA_VES     [label="Dural Vessel Dilation\n(intracranial pressure ↑)"]
        BLOOD_BARRIER [label="Disrupted BBB\n(tight junction opening)"]
    }

    /* =====================================================================
     * CLUSTER 9 — DRUG PK COMPARTMENTS (Triptans)
     * ===================================================================== */
    subgraph cluster_pk_triptan {
        label="Triptan PK (Sumatriptan SC/Oral)" fontsize=14 fontcolor="#154360"
        style=filled fillcolor="#eaf1fb" color="#154360" penwidth=2 color="#154360"
        node [fillcolor="#c8dff5" color="#154360"]

        SUM_DOSE     [label="Sumatriptan Dose\nSC: 6 mg | Oral: 100 mg"]
        SUM_GUT      [label="Gut Absorption\n(F_oral ≈ 14%, F_SC ≈ 97%)"]
        SUM_CENT     [label="Central Compartment\n(Vd/F: 2.4 L/kg)"]
        SUM_PERI     [label="Peripheral Compartment\n(tissue distribution)"]
        SUM_MET      [label="MAO-A Metabolism\n(CL: 1.2 L/min)"]
        SUM_IIA      [label="Inactive Metabolite\n(indole acetic acid)"]
        SUM_ELIM     [label="Renal Elimination\n(t½ ≈ 2 h)"]
        SUM_CNS      [label="CNS Penetration\n(low BBB crossing, < 5%)"]
        SUM_EC50     [label="EC50 (5-HT1B/1D)\n≈ 3.2 nM free plasma"]

        LAM_DOSE     [label="Lasmiditan Dose\n100–200 mg oral"]
        LAM_GUT      [label="Gut Absorption\n(F ≈ 38%, Tmax ≈ 1.8 h)"]
        LAM_CENT     [label="Lasmiditan Central\n(Vd ≈ 2.0 L/kg)"]
        LAM_MET      [label="Hepatic Metabolism\n(CYP not primary, CL ≈ 2.2 L/h/kg)"]
        LAM_CNS      [label="Excellent CNS\nPenetration (P-gp substrate)"]
        LAM_EC50     [label="EC50 (5-HT1F)\n≈ 2.21 nM"]
    }

    /* =====================================================================
     * CLUSTER 10 — DRUG PK (CGRP-targeted therapies)
     * ===================================================================== */
    subgraph cluster_pk_cgrp {
        label="CGRP-Targeted Therapy PK" fontsize=14 fontcolor="#0e6655"
        style=filled fillcolor="#e8f8f5" color="#0e6655" penwidth=2
        node [fillcolor="#b3e8de" color="#0e6655"]

        EREI_DOSE    [label="Erenumab\n70/140 mg SC monthly"]
        EREI_SC      [label="SC Depot Absorption\n(Tmax ≈ 6 days, F ≈ 82%)"]
        EREI_CENT    [label="Erenumab Central\n(Vd ≈ 3.86 L)"]
        EREI_TMDD    [label="TMDD (Target-Mediated\nDrug Disposition)"]
        EREI_FCC     [label="FcRn Recycling\n(t½ ≈ 28 days)"]
        EREI_ELIM    [label="Elimination\n(t½ ≈ 28 days)"]

        FREM_DOSE    [label="Fremanezumab\n225 mg monthly /\n675 mg quarterly SC"]
        FREM_CENT    [label="Fremanezumab Central\n(Vd ≈ 3.6 L, t½ ≈ 31 days)"]
        FREM_TMDD    [label="TMDD (CGRP ligand)"]

        GALC_DOSE    [label="Galcanezumab\n120 mg SC monthly\n(240 mg loading)"]
        GALC_CENT    [label="Galcanezumab Central\n(Vd ≈ 7.0 L, t½ ≈ 27 days)"]

        RIM_DOSE     [label="Rimegepant 75 mg\nOral (gepant)"]
        RIM_GUT      [label="Gut Absorption\n(F ≈ 64%, Tmax ≈ 1.5 h)"]
        RIM_CENT     [label="Rimegepant Central\n(Vd ≈ 113 L)"]
        RIM_MET      [label="CYP3A4/2C9 Metabolism\n(t½ ≈ 11 h)"]
        RIM_EC50     [label="Ki (CGRP-R)\n≈ 0.027 nM"]

        UBR_DOSE     [label="Ubrogepant 50/100 mg\nOral (gepant)"]
        UBR_CENT     [label="Ubrogepant Central\n(Vd ≈ 350 L, t½ ≈ 5–7 h)"]
    }

    /* =====================================================================
     * CLUSTER 11 — PREVENTIVE THERAPY PK/PD
     * ===================================================================== */
    subgraph cluster_prevent {
        label="Preventive Therapy PK/PD" fontsize=14 fontcolor="#515a5a"
        style=filled fillcolor="#f2f3f4" color="#515a5a" penwidth=2
        node [fillcolor="#dde1e0" color="#515a5a"]

        TOPR_DOSE    [label="Topiramate 25–200 mg/day\n(carbonic anhydrase, AMPA)"]
        TOPR_PK      [label="Topiramate PK\n(F ≈ 80%, t½ ≈ 21 h, CL ≈ 30 mL/min)"]
        TOPR_AMPA    [label="AMPA/KA Block\n(↓ glutamatergic excitation)"]
        TOPR_CA2     [label="Carbonic Anhydrase II/IV\nInhibition (↓ CSD freq)"]
        TOPR_GABA    [label="GABA-A Enhancement\n(modulation)"]

        PROP_DOSE    [label="Propranolol 80–240 mg/day\n(β-blocker)"]
        PROP_PK      [label="Propranolol PK\n(F ≈ 26%, t½ ≈ 4 h, CLP ≈ 800 mL/min)"]
        PROP_BETA    [label="β1/β2-Adrenergic Block\n(↓ sympathetic tone)"]
        PROP_5HT2A   [label="5-HT2A Block\n(propranolol's antimigraine PD)"]

        VPA_DOSE     [label="Valproate 500–1500 mg/day\n(Na⁺ channel, GABA)"]
        VPA_PK       [label="Valproate PK\n(F ≈ 100%, t½ ≈ 15 h, protein bound 90%)"]
        VPA_GABA2    [label="GABA Transaminase\nInhibition (GABA ↑)"]
        VPA_NA       [label="Na⁺ Channel Inactivation\n(↓ high-freq firing, ↓ CSD)"]

        AMIT_DOSE    [label="Amitriptyline 10–75 mg/day\n(TCA)"]
        AMIT_PK      [label="Amitriptyline PK\n(F ≈ 45%, t½ ≈ 10–28 h)"]
        AMIT_SERT    [label="SERT + NET Inhibition\n(5-HT, NE reuptake block)"]
        AMIT_H1      [label="H1 Block (sedation)\nMuscarinic Block"]
    }

    /* =====================================================================
     * CLUSTER 12 — CLINICAL ENDPOINTS
     * ===================================================================== */
    subgraph cluster_endpoints {
        label="Clinical Endpoints & Biomarkers" fontsize=14 fontcolor="#212f3d"
        style=filled fillcolor="#f0f3f4" color="#212f3d" penwidth=2
        node [fillcolor="#d5d8dc" color="#212f3d"]

        END_PAIN     [label="Headache Pain Score\n(VAS 0–10, NRS)"]
        END_PAIN2H   [label="Pain Freedom at 2h\n(primary endpoint)"]
        END_PAIN24   [label="Sustained Pain Freedom\n(24h / 48h)"]
        END_MHD      [label="Monthly Headache Days\n(MHD, chronic: ≥ 15/month)"]
        END_MMD      [label="Monthly Migraine Days\n(MMD, key preventive endpoint)"]
        END_MIDAS    [label="MIDAS Score\n(disability/impairment)"]
        END_HIT6     [label="HIT-6 Score\n(headache impact test)"]
        END_RESCUE   [label="Rescue Medication Use\n(# doses)"]
        END_PHOTO    [label="Photophobia Resolution\n(2h endpoint)"]
        END_NAUSEA   [label="Nausea Resolution\n(2h endpoint)"]
        END_QOL      [label="Quality of Life\n(MSQ, SF-36)"]
        BIO_CGRP_PL  [label="Plasma CGRP\n(biomarker, pg/mL)"]
        BIO_CGRP_JV  [label="Jugular Venous CGRP\n(clinical biomarker)"]
        BIO_5HT_PL   [label="Platelet 5-HT Level\n(interictal ↑, ictal ↓)"]
        BIO_NOCICEP  [label="nPOD / Nociception\nThreshold (electrophysiology)"]
        BIO_CSD_FREQ [label="CSD Frequency\n(animal model endpoint)"]
    }

    /* =====================================================================
     * EDGES — TRIGGER → PATHWAYS
     * ===================================================================== */
    TRG_STRESS   -> CSD_INIT   [label="HPA→CRH→cortical\nexcitability ↑" color="#7b2d8b"]
    TRG_HORMONE  -> CSD_THRESH [label="estrogen ↓ →\nexcitability ↑" color="#7b2d8b"]
    TRG_SLEEP    -> CSD_THRESH [label="circadian\ndysregulation" color="#7b2d8b"]
    TRG_DIET     -> TG_RELEASE [label="tyramine → 5-HT\nplatelet release" color="#7b2d8b"]
    TRG_SENSORY  -> TG_DURAL   [label="thalamic\noverwhelm" color="#7b2d8b"]
    TRG_NTG      -> NO_MOL     [label="nitric oxide\ndonor" color="#7b2d8b" style=dashed]
    TRG_FASTING  -> CSD_INIT   [label="glucose ↓ →\nexcitability ↑" color="#7b2d8b"]
    TRG_CAFFEINE -> R_5HT1B    [label="adenosine\nrebound" color="#7b2d8b" style=dashed]
    TRG_WEATHER  -> TG_DURAL   [label="barometric\npressure" color="#7b2d8b" style=dashed]

    /* =====================================================================
     * EDGES — CSD PATHWAY
     * ===================================================================== */
    CSD_INIT     -> CSD_WAVE
    CSD_WAVE     -> CSD_K_RELEASE
    CSD_WAVE     -> CSD_GLU
    CSD_K_RELEASE -> CSD_DEPOL
    CSD_GLU      -> CSD_NMDAR
    CSD_NMDAR    -> CSD_CA_INFLUX
    CSD_CA_INFLUX -> CSD_DEPOL
    CSD_DEPOL    -> CSD_SILENCE   [label="refractory period"]
    CSD_WAVE     -> CSD_CBF
    CSD_WAVE     -> CSD_AURA
    CSD_CBF      -> CSD_HYPOXIA
    CSD_THRESH   -> CSD_INIT     [dir=back label="↓ threshold → ↑ CSD risk"]
    CSD_FREQ     -> CSD_WAVE
    CSD_WAVE     -> CSD_pH
    CSD_pH       -> NO_MOL       [label="pH ↓ → NOS activation"]
    CSD_WAVE     -> CSD_NO
    CSD_NO       -> NO_MOL
    CSD_WAVE     -> CSD_PROSTA
    CSD_PROSTA   -> PGE2
    CSD_WAVE     -> TG_DURAL     [label="CSD activates\ntrigeminal afferents" color="#c0392b" penwidth=2]

    /* =====================================================================
     * EDGES — TRIGEMINOVASCULAR PATHWAY
     * ===================================================================== */
    TG_NEURON    -> TG_SYNTH
    TG_SYNTH     -> TG_STORE
    TG_STORE     -> TG_RELEASE   [label="Ca²⁺-dependent"]
    TG_NEURON    -> TG_PERIVA    [label="innervation"]
    TG_PERIVA    -> TG_DURAL
    TG_DURAL     -> TG_RELEASE
    TG_RELEASE   -> CGRP_MOL
    TG_RELEASE   -> CGRP_SP
    TG_RELEASE   -> CGRP_PACAP
    TG_RELEASE   -> TG_ANTIDROM
    TG_ANTIDROM  -> PLASMA_EXT
    TG_NEURON    -> TNC_2ND      [label="ascending signal\nvia trigeminal root"]
    TNC_2ND      -> TNC_GLUTAMATE
    TNC_2ND      -> TNC_NK1
    TNC_2ND      -> TNC_NMDAR_TNC
    TNC_NMDAR_TNC -> TNC_WIND_UP
    TNC_WIND_UP  -> CS_INIT
    TNC_2ND      -> TCC
    TCC          -> THALAMUS
    THALAMUS     -> CORTEX_PAIN
    PAG          -> NRM          [label="descending\ninhibition"]
    NRM          -> TNC_2ND      [label="5-HT inhibitory\nprojections"]
    LC           -> TNC_2ND      [label="NE inhibitory\nprojections"]
    PAG          -> LC

    /* =====================================================================
     * EDGES — CGRP PATHWAY
     * ===================================================================== */
    CGRP_MOL     -> CGRP_R
    CGRP_R       -> CGRP_CAMP    [label="Gs coupling"]
    CGRP_CAMP    -> CGRP_PKA
    CGRP_PKA     -> CGRP_KATP    [label="phosphorylation"]
    CGRP_KATP    -> CGRP_VASC
    CGRP_VASC    -> DURA_VES
    CGRP_MOL     -> CGRP_MAST    [label="CGRP-R on\nmast cells"]
    CGRP_MAST    -> DURA_MAST
    CGRP_MAST    -> HIST_RELEASE
    CGRP_MOL     -> CGRP_MICRO
    CGRP_MOL     -> CGRP_EDEMA
    CGRP_EDEMA   -> PLASMA_EXT
    CGRP_SP      -> TNC_NK1      [label="SP → NK1 in TNC"]
    CGRP_PACAP   -> CGRP_VASC
    CGRP_MOL     -> CGRP_PLASMA
    CGRP_PLASMA  -> CGRP_JV
    CGRP_R       -> TG_RELEASE   [dir=back label="pre-synaptic\nauto-receptor feedback"]

    /* =====================================================================
     * EDGES — NITRIC OXIDE & PROSTANOID
     * ===================================================================== */
    NTG_DOSE     -> NO_MOL
    NO_SYNTH     -> NO_MOL
    NO_MOL       -> SGC
    SGC          -> CGMP
    CGMP         -> CGRP_VASC    [label="cGMP → PKG → KATP"]
    CGMP         -> TG_RELEASE   [label="NO sensitizes\ntrigeminal neurons"]
    PDE5         -> CGMP         [dir=back label="degrades cGMP"]
    AA_POOL      -> COX1
    AA_POOL      -> COX2
    PLA2         -> AA_POOL
    TG_DURAL     -> PLA2         [label="nociceptor\nactivation"]
    CGRP_MICRO   -> COX2         [label="glial COX-2\ninduction"]
    COX1         -> PGE2
    COX2         -> PGE2
    COX2         -> PGI2
    COX1         -> TXA2
    PGE2         -> TRPV1        [label="EP1 → TRPV1\nsensitization"]
    PGE2         -> TRPA1
    PGE2         -> TG_DURAL     [label="peripheral\nsensitization"]
    NFKB_ACT     -> COX2         [label="NF-κB → COX-2\ntranscription"]
    TNF_DM       -> NFKB_ACT

    /* =====================================================================
     * EDGES — SEROTONIN
     * ===================================================================== */
    SER_SYNTH    -> SER_STORE
    SER_STORE    -> SER_RELEASE
    SER_RELEASE  -> R_5HT1B
    SER_RELEASE  -> R_5HT1D
    SER_RELEASE  -> R_5HT2A
    SER_RELEASE  -> R_5HT3
    SER_RELEASE  -> SER_PLASM
    DRN          -> SER_SYNTH
    DRN          -> PAG          [label="DRN→PAG\n5-HT projection"]
    SERT         -> SER_RELEASE  [dir=back label="reuptake"]
    R_5HT1B      -> CGRP_VASC   [label="5-HT1B → vessel\nvasoconstriction" color="#1b4f72"]
    R_5HT1D      -> TG_RELEASE  [dir=back label="5-HT1D → ↓ CGRP\nrelease" color="#1b4f72"]
    R_5HT2A      -> CSD_THRESH  [label="5-HT2A → ↓ CSD\nthreshold" color="#1b4f72"]
    R_5HT3       -> NAUSEA       [label="5-HT3 →\nnausea circuit"]
    CIT          -> SER_PLASM    [dir=back label="interictal\ndeficiency"]

    /* =====================================================================
     * EDGES — CENTRAL SENSITIZATION
     * ===================================================================== */
    CS_INIT      -> CS_2ND
    CS_2ND       -> CS_3RD
    CS_3RD       -> ALLODYNIA_M
    CS_3RD       -> ALLODYNIA_T
    CS_2ND       -> PHONO
    CS_2ND       -> PHOTO
    CS_2ND       -> OSMO
    TNC_WIND_UP  -> CS_INIT
    CS_INIT      -> PROST_SENS
    PROST_SENS   -> PKC_EPS
    PKC_EPS      -> MAPK
    MAPK         -> BDNF_CS
    BDNF_CS      -> MICROGLIA
    MICROGLIA    -> CXCL3
    CXCL3        -> CS_INIT      [label="cytokine\nloop"]
    PGE2         -> CS_INIT      [label="PGE2 → spinal\nsensitization"]
    TRPV1        -> CS_INIT
    ALLODYNIA_M  -> END_PAIN
    PHOTO        -> END_PHOTO
    NAUSEA       -> END_NAUSEA

    /* =====================================================================
     * EDGES — MENINGEAL INFLAMMATION
     * ===================================================================== */
    DURA_MAST    -> HIST_RELEASE
    DURA_MAST    -> BRAD_RELEASE
    DURA_MAST    -> SEROT_MAST
    DURA_MAST    -> TNF_DM
    HIST_RELEASE -> TG_DURAL     [label="histamine H1\nnociceptor sensitization"]
    BRAD_RELEASE -> TG_DURAL     [label="bradykinin B2\nperipheral sensitization"]
    TNF_DM       -> ROS_DURA
    ROS_DURA     -> BLOOD_BARRIER
    DURA_VES     -> BLOOD_BARRIER
    PLASMA_EXT   -> DURA_VES
    ENDOTHELIN   -> DURA_VES     [dir=back label="ET-1 →\nvasoconstriction"]
    SEROT_MAST   -> R_5HT3      [label="peritoneal 5-HT\nreflex"]

    /* =====================================================================
     * EDGES — TRIPTAN PK/PD
     * ===================================================================== */
    SUM_DOSE     -> SUM_GUT
    SUM_GUT      -> SUM_CENT     [label="F_oral=14%\nF_SC=97%"]
    SUM_CENT     -> SUM_PERI
    SUM_CENT     -> SUM_MET
    SUM_MET      -> SUM_IIA
    SUM_CENT     -> SUM_CNS
    SUM_ELIM     <- SUM_CENT     [label="t½≈2h"]
    SUM_CENT     -> SUM_EC50
    SUM_EC50     -> R_5HT1B      [label="agonism →\nvasoconstriction" color="#154360"]
    SUM_EC50     -> R_5HT1D      [label="agonism →\n↓ CGRP release" color="#154360"]
    SUM_CNS      -> PAG          [label="CNS 5-HT1D/1B\nactivation"]

    LAM_DOSE     -> LAM_GUT
    LAM_GUT      -> LAM_CENT     [label="F≈38%"]
    LAM_CENT     -> LAM_MET
    LAM_CENT     -> LAM_CNS
    LAM_CNS      -> R_5HT1F      [label="selective\n5-HT1F agonism" color="#154360"]
    R_5HT1F      -> TNC_2ND      [dir=back label="↓ TNC neuron\nfiring" color="#154360"]
    R_5HT1F      -> TG_RELEASE   [dir=back label="↓ CGRP\nrelease" color="#154360"]

    /* =====================================================================
     * EDGES — CGRP-TARGETED THERAPY
     * ===================================================================== */
    EREI_DOSE    -> EREI_SC
    EREI_SC      -> EREI_CENT
    EREI_CENT    -> EREI_TMDD
    EREI_TMDD    -> CGRP_R       [label="blocks CGRP-R\n(competitive)" color="#0e6655" penwidth=2]
    EREI_CENT    -> EREI_FCC
    EREI_FCC     -> EREI_CENT    [label="recycles antibody"]
    EREI_ELIM    <- EREI_CENT

    FREM_DOSE    -> FREM_CENT
    FREM_CENT    -> FREM_TMDD
    FREM_TMDD    -> CGRP_MOL     [label="sequesters CGRP\nligand" color="#0e6655" penwidth=2]

    GALC_DOSE    -> GALC_CENT
    GALC_CENT    -> CGRP_MOL     [label="sequesters CGRP\nligand" color="#0e6655" penwidth=2]

    RIM_DOSE     -> RIM_GUT
    RIM_GUT      -> RIM_CENT     [label="F≈64%"]
    RIM_CENT     -> RIM_MET
    RIM_CENT     -> RIM_EC50
    RIM_EC50     -> CGRP_R       [label="competitive\nantagonist (gepant)" color="#0e6655" penwidth=2]

    UBR_DOSE     -> UBR_CENT
    UBR_CENT     -> CGRP_R       [label="gepant\nantagonist" color="#0e6655" penwidth=2]

    /* Effects of CGRP blockade */
    CGRP_R       -> CGRP_VASC   [label="blocked → ↓ vasodilation"]
    CGRP_R       -> CGRP_MAST   [label="blocked → ↓ mast\ncell activation"]

    /* =====================================================================
     * EDGES — PREVENTIVE THERAPY
     * ===================================================================== */
    TOPR_DOSE    -> TOPR_PK
    TOPR_PK      -> TOPR_AMPA
    TOPR_PK      -> TOPR_CA2
    TOPR_PK      -> TOPR_GABA
    TOPR_AMPA    -> TNC_GLUTAMATE [dir=back label="↓ AMPA excitation"]
    TOPR_CA2     -> CSD_THRESH   [label="↓ CSD\nsusceptibility"]
    TOPR_GABA    -> CS_INIT      [dir=back label="↑ GABA →\n↓ sensitization"]

    PROP_DOSE    -> PROP_PK
    PROP_PK      -> PROP_BETA
    PROP_PK      -> PROP_5HT2A
    PROP_BETA    -> CSD_THRESH   [label="β-block → ↓ cortical\nexcitability"]
    PROP_5HT2A   -> R_5HT2A     [dir=back label="5-HT2A block →\n↑ CSD threshold"]

    VPA_DOSE     -> VPA_PK
    VPA_PK       -> VPA_GABA2
    VPA_PK       -> VPA_NA
    VPA_GABA2    -> TOPR_GABA    [label="GABA ↑"]
    VPA_NA       -> CSD_INIT     [dir=back label="Na⁺ block →\n↓ CSD propagation"]

    AMIT_DOSE    -> AMIT_PK
    AMIT_PK      -> AMIT_SERT
    AMIT_PK      -> AMIT_H1
    AMIT_SERT    -> SERT         [dir=back label="SERT inhibition →\n5-HT ↑"]
    AMIT_SERT    -> DRN          [label="↑ descending\ninhibition"]

    /* =====================================================================
     * EDGES — CLINICAL ENDPOINTS
     * ===================================================================== */
    CORTEX_PAIN  -> END_PAIN
    ALLODYNIA_M  -> END_PAIN
    CS_3RD       -> END_PAIN
    END_PAIN     -> END_PAIN2H   [label="acute treatment\nresponse"]
    END_PAIN2H   -> END_PAIN24
    END_MHD      -> END_MMD
    END_MMD      -> END_MIDAS
    END_MMD      -> END_HIT6
    END_MMD      -> END_QOL
    END_PAIN     -> END_RESCUE   [label="if pain > threshold"]
    CGRP_PLASMA  -> BIO_CGRP_PL
    CGRP_JV      -> BIO_CGRP_JV
    SER_PLASM    -> BIO_5HT_PL
    TNC_2ND      -> BIO_NOCICEP
    CSD_FREQ     -> BIO_CSD_FREQ
    CSD_AURA     -> END_PAIN     [label="aura → headache\nphase transition"]
    NAUSEA       -> END_NAUSEA
    PHOTO        -> END_PHOTO

    /* Preventive effect on MMD */
    TOPR_CA2     -> END_MMD      [dir=back label="↓ 30–50% MMD" color="#515a5a" style=dashed]
    PROP_5HT2A   -> END_MMD      [dir=back label="↓ 35–50% MMD" color="#515a5a" style=dashed]
    VPA_NA       -> END_MMD      [dir=back label="↓ 30–50% MMD" color="#515a5a" style=dashed]
    EREI_TMDD    -> END_MMD      [dir=back label="↓ 50% responder\n>3.7 MMD reduction" color="#0e6655" style=dashed penwidth=1.5]
    FREM_TMDD    -> END_MMD      [dir=back label="↓ 4.3 MMD\n(quarterly dose)" color="#0e6655" style=dashed penwidth=1.5]
    GALC_CENT    -> END_MMD      [dir=back label="↓ 4.7 MMD\n(EVOLVE trials)" color="#0e6655" style=dashed penwidth=1.5]
    RIM_EC50     -> END_MMD      [dir=back label="↓ 1.75 MMD\n(ARTISAN-EM)" color="#0e6655" style=dashed penwidth=1.5]

    /* Acute treatment effect on pain freedom */
    SUM_EC50     -> END_PAIN2H   [dir=back label="pain freedom 2h:\n~30–40%" color="#154360" style=dashed]
    LAM_CNS      -> END_PAIN2H   [dir=back label="pain freedom 2h:\n~32–39%" color="#154360" style=dashed]
    RIM_EC50     -> END_PAIN2H   [dir=back label="pain freedom 2h:\n~21% (75mg)" color="#0e6655" style=dashed]
    UBR_CENT     -> END_PAIN2H   [dir=back label="pain freedom 2h:\n~19% (100mg)" color="#0e6655" style=dashed]
}
