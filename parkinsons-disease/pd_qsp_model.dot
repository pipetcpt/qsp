digraph ParkinsonsDisease_QSP {
    graph [
        label="Parkinson's Disease — Comprehensive QSP Mechanistic Map\nDopaminergic Neurodegeneration · Alpha-Synuclein Aggregation · Basal Ganglia Circuit · Drug PK/PD"
        labelloc="t"
        fontname="Helvetica-Bold"
        fontsize=18
        rankdir=TB
        splines=curved
        nodesep=0.4
        ranksep=0.6
        bgcolor="#FAFAFA"
        pad=0.5
    ]
    node [fontname="Helvetica" fontsize=9 style="filled,rounded" shape=box]
    edge [fontname="Helvetica" fontsize=8]

    // ===== CLUSTER 1: Genetic Risk Factors =====
    subgraph cluster_genetics {
        label="Genetic Risk Factors"
        style="filled,rounded"
        fillcolor="#FFF9C4"
        color="#F9A825"
        fontcolor="#E65100"
        fontsize=12
        fontname="Helvetica-Bold"

        SNCA [label="SNCA Gene\n(α-Synuclein)" fillcolor="#FFEB3B"]
        LRRK2 [label="LRRK2\n(Leucine-rich\nrepeat kinase 2)" fillcolor="#FFEB3B"]
        PINK1 [label="PINK1\n(PTEN-induced\nkinase 1)" fillcolor="#FFEB3B"]
        PRKN [label="PRKN\n(Parkin E3\nubiquitin ligase)" fillcolor="#FFEB3B"]
        DJ1 [label="DJ-1\n(PARK7)" fillcolor="#FFEB3B"]
        ATP13A2 [label="ATP13A2\n(PARK9/LYSOSOMAL)" fillcolor="#FFEB3B"]
        GBA [label="GBA\n(Glucocerebrosidase)" fillcolor="#FFEB3B"]
        VPS35 [label="VPS35\n(Retromer complex)" fillcolor="#FFEB3B"]
        MAPT [label="MAPT\n(Tau protein)" fillcolor="#FFF176"]
        APOE [label="APOE\n(risk modifier)" fillcolor="#FFF176"]
    }

    // ===== CLUSTER 2: Alpha-Synuclein Pathology =====
    subgraph cluster_alphasyn {
        label="α-Synuclein Aggregation Cascade"
        style="filled,rounded"
        fillcolor="#FCE4EC"
        color="#E91E63"
        fontcolor="#880E4F"
        fontsize=12
        fontname="Helvetica-Bold"

        aSyn_mono [label="α-Syn\nMonomer" fillcolor="#F48FB1"]
        aSyn_oligo [label="α-Syn\nOligomers\n(toxic)" fillcolor="#F06292"]
        aSyn_proto [label="α-Syn\nProtofibrils" fillcolor="#EC407A"]
        aSyn_fibril [label="α-Syn\nFibrils" fillcolor="#E91E63"]
        LewyBody [label="Lewy Bodies\n/ Neurites" fillcolor="#C2185B" fontcolor="white"]
        aSyn_secrete [label="Secreted\nα-Syn" fillcolor="#F48FB1"]
        aSyn_spread [label="Prion-like\nSpreading\n(Braak stages)" fillcolor="#AD1457" fontcolor="white"]
        post_trans [label="Post-translational\nMod: phospho-S129\nnitration, truncation" fillcolor="#FF80AB"]
        aSyn_clear [label="α-Syn\nClearance\n(UPS/autophagy)" fillcolor="#FFCDD2"]
    }

    // ===== CLUSTER 3: Mitochondrial Dysfunction =====
    subgraph cluster_mito {
        label="Mitochondrial Dysfunction & Oxidative Stress"
        style="filled,rounded"
        fillcolor="#E8F5E9"
        color="#43A047"
        fontcolor="#1B5E20"
        fontsize=12
        fontname="Helvetica-Bold"

        Complex_I [label="Complex I\n(NADH dehydrogenase)\nInhibition" fillcolor="#A5D6A7"]
        ROS [label="ROS\n(O2•−, H2O2, •OH)" fillcolor="#EF9A9A"]
        mPTP [label="mPTP\n(mitochondrial\npermeability\ntransition pore)" fillcolor="#FF8A80"]
        Cyt_c [label="Cytochrome c\nRelease" fillcolor="#EF9A9A"]
        mtDNA_damage [label="mtDNA Damage\n& Mutations" fillcolor="#A5D6A7"]
        DRP1 [label="DRP1\n(Fission)" fillcolor="#81C784"]
        MFN1_2 [label="MFN1/2\n(Fusion)" fillcolor="#81C784"]
        Mito_quality [label="Mitophagy\n(PINK1/Parkin)" fillcolor="#66BB6A"]
        Mito_biogen [label="Mitochondrial\nBiogenesis\n(PGC-1α)" fillcolor="#4CAF50"]
        GSH [label="Glutathione\n(GSH)" fillcolor="#A5D6A7"]
        SOD [label="SOD\n(Superoxide\ndismutase)" fillcolor="#A5D6A7"]
        NRF2 [label="NRF2\n(antioxidant\nresponse)" fillcolor="#C8E6C9"]
    }

    // ===== CLUSTER 4: Protein Quality Control =====
    subgraph cluster_pqc {
        label="Protein Quality Control & Proteostasis"
        style="filled,rounded"
        fillcolor="#E3F2FD"
        color="#1976D2"
        fontcolor="#0D47A1"
        fontsize=12
        fontname="Helvetica-Bold"

        UPS [label="Ubiquitin-\nProteasome System" fillcolor="#90CAF9"]
        Proteasome [label="26S Proteasome\n(degradation)" fillcolor="#64B5F6"]
        UPS_impair [label="UPS Impairment\n(by aSyn)" fillcolor="#EF9A9A"]
        Autophagy [label="Macroautophagy\n(ATG5/7/12)" fillcolor="#90CAF9"]
        CMA [label="Chaperone-mediated\nAutophagy (CMA)\nHSC70/LAMP-2A" fillcolor="#64B5F6"]
        Lysosome [label="Lysosomal\nDegradation" fillcolor="#42A5F5"]
        mTOR [label="mTORC1\n(autophagy\ninhibitor)" fillcolor="#FFB74D"]
        AMPK [label="AMPK\n(autophagy\nactivator)" fillcolor="#A5D6A7"]
        HSP70 [label="HSP70/HSPA\n(chaperone)" fillcolor="#90CAF9"]
        HSP90 [label="HSP90\n(chaperone)" fillcolor="#90CAF9"]
        Ubiquitin [label="Ubiquitin\nConjugation" fillcolor="#BBDEFB"]
        p62_SQSTM1 [label="p62/SQSTM1\n(autophagy receptor)" fillcolor="#BBDEFB"]
    }

    // ===== CLUSTER 5: Neuroinflammation =====
    subgraph cluster_neuro_inflam {
        label="Neuroinflammation"
        style="filled,rounded"
        fillcolor="#FFF3E0"
        color="#E65100"
        fontcolor="#BF360C"
        fontsize=12
        fontname="Helvetica-Bold"

        Microglia_rest [label="Resting\nMicroglia" fillcolor="#FFCC80"]
        Microglia_act [label="Activated\nMicroglia (M1)\nneurotoxic" fillcolor="#FF8A65"]
        Microglia_M2 [label="Anti-inflam\nMicroglia (M2)\nneuroprotective" fillcolor="#A5D6A7"]
        Astrocyte [label="Reactive\nAstrocytes" fillcolor="#FFAB40"]
        TNFa [label="TNF-α" fillcolor="#FF7043"]
        IL1b [label="IL-1β" fillcolor="#FF7043"]
        IL6 [label="IL-6" fillcolor="#FF7043"]
        IL10 [label="IL-10\n(anti-inflam)" fillcolor="#A5D6A7"]
        TLR4 [label="TLR4\n(aSyn receptor)" fillcolor="#FFCC80"]
        NF_kB [label="NF-κB\n(transcription factor)" fillcolor="#FF8A65"]
        NLRP3 [label="NLRP3\nInflammasome" fillcolor="#FF6E40"]
        Complement [label="Complement\nC1q/C3" fillcolor="#FFAB40"]
        BBB_break [label="BBB\nBreakdown" fillcolor="#EF9A9A"]
        T_cell_inflam [label="T Cell\nInfiltration\n(CD4+/CD8+)" fillcolor="#CE93D8"]
    }

    // ===== CLUSTER 6: Dopaminergic Neuron Biology =====
    subgraph cluster_da_neuron {
        label="Dopaminergic Neuron Pathophysiology"
        style="filled,rounded"
        fillcolor="#E8EAF6"
        color="#3F51B5"
        fontcolor="#1A237E"
        fontsize=12
        fontname="Helvetica-Bold"

        DA_neuron_pool [label="SNpc DA Neurons\n(intact pool)" fillcolor="#7986CB"]
        DA_neuron_vul [label="Vulnerable DA\nNeurons\n(α-syn+)" fillcolor="#EF9A9A"]
        DA_neuron_dead [label="Dead/Lost\nDA Neurons\n(>60% at sx onset)" fillcolor="#B71C1C" fontcolor="white"]
        Neuronal_death [label="Neuronal Death\n(apoptosis/\nnecroptosis)" fillcolor="#EF5350"]
        TH [label="Tyrosine\nHydroxylase (TH)\n(rate-limiting)" fillcolor="#9FA8DA"]
        AADC [label="AADC\n(DOPA\ndecarboxylase)" fillcolor="#9FA8DA"]
        MAO_B [label="MAO-B\n(DA catabolism)" fillcolor="#9FA8DA"]
        COMT [label="COMT\n(DA/DOPA\ncatabolism)" fillcolor="#9FA8DA"]
        DAT [label="DAT\n(DA transporter\nreuptake)" fillcolor="#7986CB"]
        VMAT2 [label="VMAT2\n(vesicular DA\npackaging)" fillcolor="#9FA8DA"]
        Vesicle_release [label="DA Vesicle\nRelease\n(exocytosis)" fillcolor="#7986CB"]
        Axon_terminal [label="Striatal Axon\nTerminals\n(nigrostriatal)" fillcolor="#7986CB"]
    }

    // ===== CLUSTER 7: Dopamine Synthesis & Metabolism =====
    subgraph cluster_da_metabolism {
        label="Dopamine Metabolism & Signaling"
        style="filled,rounded"
        fillcolor="#EDE7F6"
        color="#7B1FA2"
        fontcolor="#4A148C"
        fontsize=12
        fontname="Helvetica-Bold"

        Tyrosine [label="Tyrosine\n(dietary)" fillcolor="#CE93D8"]
        L_DOPA_endo [label="L-DOPA\n(endogenous)" fillcolor="#BA68C8"]
        Dopamine [label="Dopamine\n(synaptic DA)" fillcolor="#9C27B0" fontcolor="white"]
        DA_synaptic [label="Synaptic\nDA Conc." fillcolor="#8E24AA" fontcolor="white"]
        DOPAC [label="DOPAC\n(metabolite)" fillcolor="#CE93D8"]
        HVA [label="HVA\n(homovanillic acid)" fillcolor="#CE93D8"]
        DA_D1R [label="D1R\nStimulation\n(cAMP↑)" fillcolor="#AB47BC"]
        DA_D2R [label="D2R\nStimulation\n(cAMP↓)" fillcolor="#AB47BC"]
        DA_D3R [label="D3R\n(limbic)" fillcolor="#CE93D8"]
        DA_D4R [label="D4R\n(prefrontal)" fillcolor="#CE93D8"]
        D2R_presynaptic [label="D2R\nAutoreceptors\n(presynaptic)" fillcolor="#AB47BC"]
        ThreeMT [label="3-Methoxytyramine\n(3-MT)" fillcolor="#CE93D8"]
    }

    // ===== CLUSTER 8: Basal Ganglia Circuit =====
    subgraph cluster_bg {
        label="Basal Ganglia Motor Circuit"
        style="filled,rounded"
        fillcolor="#F3E5F5"
        color="#6A1B9A"
        fontcolor="#4A148C"
        fontsize=12
        fontname="Helvetica-Bold"

        Striatum [label="Striatum\n(Caudate/Putamen)" fillcolor="#CE93D8"]
        Striatum_D1 [label="Striatal D1\nMSNs\n(direct pathway)" fillcolor="#BA68C8"]
        Striatum_D2 [label="Striatal D2\nMSNs\n(indirect pathway)" fillcolor="#BA68C8"]
        GPi [label="GPi/SNpr\n(internal pallidum/\nSN pars reticulata)" fillcolor="#9C27B0" fontcolor="white"]
        GPe [label="GPe\n(external pallidum)" fillcolor="#AB47BC"]
        STN [label="STN\n(subthalamic\nnucleus)" fillcolor="#AB47BC"]
        Thalamus [label="Thalamus\n(VA/VL)" fillcolor="#CE93D8"]
        Motor_cortex [label="Motor Cortex\n(SMA, M1)" fillcolor="#CE93D8"]
        Cerebellum [label="Cerebellum\n(motor coordination)" fillcolor="#E1BEE7"]
        GABA_direct [label="GABA\nDirect Pathway\n(inhibitory)" fillcolor="#F48FB1"]
        Glutamate_STN [label="Glutamate\nSTN output\n(excitatory)" fillcolor="#FFAB40"]
        DA_modulation [label="DA Modulation\nof Striatum" fillcolor="#CE93D8"]
    }

    // ===== CLUSTER 9: Motor & Non-Motor Symptoms =====
    subgraph cluster_symptoms {
        label="Clinical Manifestations"
        style="filled,rounded"
        fillcolor="#EFEBE9"
        color="#4E342E"
        fontcolor="#3E2723"
        fontsize=12
        fontname="Helvetica-Bold"

        Tremor [label="Resting Tremor\n(4-6 Hz)" fillcolor="#BCAAA4"]
        Rigidity [label="Muscle Rigidity\n(cogwheel)" fillcolor="#BCAAA4"]
        Bradykinesia [label="Bradykinesia\n(slowness)" fillcolor="#BCAAA4"]
        Postural_instab [label="Postural\nInstability\n(falls)" fillcolor="#BCAAA4"]
        Freezing_gait [label="Freezing of Gait\n(FOG)" fillcolor="#A1887F"]
        Depression [label="Depression\n(mood)" fillcolor="#90A4AE"]
        Anxiety [label="Anxiety" fillcolor="#90A4AE"]
        Cognitive_impair [label="Cognitive\nImpairment\n(PD-MCI/PDD)" fillcolor="#90A4AE"]
        Sleep_disorder [label="REM Sleep\nBehavior Disorder\n(RBD)" fillcolor="#90A4AE"]
        Autonomic_dysfx [label="Autonomic\nDysfunction\n(constipation, OH)" fillcolor="#A1887F"]
        Anosmia [label="Hyposmia/\nAnosmia\n(early sx)" fillcolor="#A1887F"]
        Dyskinesia [label="Levodopa-induced\nDyskinesia (LID)" fillcolor="#EF9A9A"]
        UPDRS [label="UPDRS/MDS-UPDRS\n(motor score)" fillcolor="#8D6E63" fontcolor="white"]
        Hoehn_Yahr [label="Hoehn & Yahr\nScale (1-5)" fillcolor="#8D6E63" fontcolor="white"]
    }

    // ===== CLUSTER 10: Drug PK/PD — Levodopa =====
    subgraph cluster_ldopa {
        label="Drug PK/PD: Levodopa/Carbidopa"
        style="filled,rounded"
        fillcolor="#E0F7FA"
        color="#00838F"
        fontcolor="#004D40"
        fontsize=12
        fontname="Helvetica-Bold"

        Ldopa_oral [label="Levodopa\nOral Dose" fillcolor="#B2EBF2"]
        Carbidopa [label="Carbidopa\n(peripheral\nAADC inhibitor)" fillcolor="#80DEEA"]
        Ldopa_gut [label="L-DOPA\nGut Absorption\n(LAT1/2)" fillcolor="#4DD0E1"]
        Ldopa_plasma [label="L-DOPA\nPlasma\n(Cp)" fillcolor="#00BCD4"]
        Ldopa_BBB [label="L-DOPA\nBBB Transport\n(LAT1)" fillcolor="#00ACC1"]
        Ldopa_brain [label="L-DOPA\nBrain (Cb)" fillcolor="#0097A7"]
        Ldopa_convert [label="DOPA→DA\nConversion (AADC)" fillcolor="#00838F" fontcolor="white"]
        Ldopa_peripheral [label="Peripheral DOPA\nConversion\n(nausea source)" fillcolor="#80DEEA"]
        Wearing_off [label="Wearing-off\n(end-of-dose\ndeterior.)" fillcolor="#EF9A9A"]
        On_off [label="ON-OFF\nFluctuations" fillcolor="#EF9A9A"]
        Pulsatile_stim [label="Pulsatile DA\nReceptor Stim." fillcolor="#FFCC80"]
        CR_formulation [label="CR/ER Levodopa\n(Rytary, Duopa)" fillcolor="#B2EBF2"]
        Entacapone [label="Entacapone\n(COMT inhibitor)" fillcolor="#80DEEA"]
    }

    // ===== CLUSTER 11: Drug PK/PD — Dopamine Agonists =====
    subgraph cluster_dopa_agonist {
        label="Drug PK/PD: Dopamine Agonists"
        style="filled,rounded"
        fillcolor="#E8F5E9"
        color="#2E7D32"
        fontcolor="#1B5E20"
        fontsize=12
        fontname="Helvetica-Bold"

        Pramipexole [label="Pramipexole\n(D3>D2 agonist)" fillcolor="#A5D6A7"]
        Ropinirole [label="Ropinirole\n(D3>D2 agonist)" fillcolor="#A5D6A7"]
        Rotigotine [label="Rotigotine\n(D3>D2>D1\npatch)" fillcolor="#A5D6A7"]
        Apomorphine [label="Apomorphine\n(D1/D2 agonist\ninjection)" fillcolor="#81C784"]
        DA_agonist_Cp [label="DA Agonist\nPlasma Conc." fillcolor="#66BB6A"]
        DA_agonist_Cb [label="DA Agonist\nBrain Conc." fillcolor="#4CAF50"]
        D2_D3_occupancy [label="D2/D3\nReceptor\nOccupancy" fillcolor="#43A047"]
        Continuous_stim [label="Continuous\nReceptor\nStimulation" fillcolor="#388E3C" fontcolor="white"]
        ICD [label="Impulse Control\nDisorder (ICD)\nside effect" fillcolor="#FFCC02"]
        DA_agonist_meta [label="Agonist\nMetabolism\n(CYP1A2)" fillcolor="#A5D6A7"]
    }

    // ===== CLUSTER 12: MAO-B Inhibitors & COMT Inhibitors =====
    subgraph cluster_enzymeinhibit {
        label="Drug PK/PD: MAO-B & COMT Inhibitors"
        style="filled,rounded"
        fillcolor="#FFF8E1"
        color="#FF8F00"
        fontcolor="#E65100"
        fontsize=12
        fontname="Helvetica-Bold"

        Selegiline [label="Selegiline\n(MAO-B inhib.)" fillcolor="#FFE082"]
        Rasagiline [label="Rasagiline\n(MAO-B inhib.)" fillcolor="#FFE082"]
        Safinamide [label="Safinamide\n(MAO-B + Na\nchannel block)" fillcolor="#FFD740"]
        MAO_B_inhib_PK [label="MAO-B Inhibitor\nPlasma Conc." fillcolor="#FFCA28"]
        MAO_B_occupancy [label="MAO-B Enzyme\nOccupancy" fillcolor="#FFB300"]
        DA_level_increase [label="Synaptic DA\nLevel Increase" fillcolor="#FFA000"]
        Opicapone [label="Opicapone\n(COMT inhibitor)" fillcolor="#FFCC80"]
        Tolcapone [label="Tolcapone\n(COMT inhibitor\ncentral+periph.)" fillcolor="#FFCC80"]
        COMT_occupancy [label="COMT Enzyme\nOccupancy" fillcolor="#FFB74D"]
        Ldopa_halflife [label="L-DOPA\nHalf-life\nExtension" fillcolor="#FFA726"]
    }

    // ===== CLUSTER 13: Neuroprotection & Disease Modification =====
    subgraph cluster_neuroprotect {
        label="Neuroprotection & Disease Modification"
        style="filled,rounded"
        fillcolor="#F9FBE7"
        color="#827717"
        fontcolor="#33691E"
        fontsize=12
        fontname="Helvetica-Bold"

        Neurotrophins [label="Neurotrophins\n(BDNF, GDNF,\nneurturin)" fillcolor="#DCE775"]
        GDNF_therapy [label="GDNF Therapy\n(gene/protein\ndelivery)" fillcolor="#CDDC39"]
        LRRK2_inhibit [label="LRRK2 Kinase\nInhibitors\n(clinical trials)" fillcolor="#C6FF00"]
        aSyn_immunother [label="α-Syn\nImmunotherapy\n(antibodies)" fillcolor="#C5E1A5"]
        aSyn_vaccine [label="PD01A/PD03A\nvaccine (trial)" fillcolor="#AED581"]
        GCase_activator [label="GCase Activators\n(GBA-PD)" fillcolor="#9CCC65"]
        Exenatide_neuro [label="Exenatide/GLP-1\n(neuroprotection\ntrial)" fillcolor="#8BC34A"]
        Nilotinib [label="Nilotinib\n(c-Abl inhib)\nneuroprotective?" fillcolor="#7CB342"]
        DBS_therapy [label="Deep Brain\nStimulation (DBS)\nSTN/GPi" fillcolor="#9E9D24" fontcolor="white"]
        Gene_therapy [label="Gene Therapy\n(AAV-TH/AADC)" fillcolor="#AED581"]
    }

    // ===== CLUSTER 14: Gut-Brain Axis =====
    subgraph cluster_gut_brain {
        label="Gut-Brain Axis & Environmental Factors"
        style="filled,rounded"
        fillcolor="#FCE4EC"
        color="#880E4F"
        fontcolor="#880E4F"
        fontsize=12
        fontname="Helvetica-Bold"

        Gut_microbiome [label="Gut Microbiome\n(dysbiosis in PD)" fillcolor="#F48FB1"]
        Vagus_nerve [label="Vagus Nerve\n(aSyn spread\nhypothesis)" fillcolor="#F06292"]
        Enteric_NS [label="Enteric Nervous\nSystem (ENS)" fillcolor="#EC407A"]
        Gut_inflam [label="Gut Inflammation\n(leaky gut)" fillcolor="#E91E63"]
        SCFA [label="SCFAs\n(microbiome\nmetabolites)" fillcolor="#F48FB1"]
        Pesticides [label="Pesticides\n(MPTP, rotenone,\nparaquat)" fillcolor="#CE93D8"]
        Air_pollution [label="Air Pollution\nPM2.5, NO2" fillcolor="#CE93D8"]
        Head_trauma [label="Head Trauma\nhistory" fillcolor="#CE93D8"]
        Aging [label="Aging\n(key risk factor)" fillcolor="#FFCDD2"]
        Mitochondria_toxin [label="Mitochondrial\nToxins" fillcolor="#EF9A9A"]
    }

    // ===== CLUSTER 15: Biomarkers =====
    subgraph cluster_biomarkers {
        label="Biomarkers & Clinical Endpoints"
        style="filled,rounded"
        fillcolor="#E0F2F1"
        color="#004D40"
        fontcolor="#004D40"
        fontsize=12
        fontname="Helvetica-Bold"

        DaTscan [label="DaTscan\n(DAT imaging\nSPECT/PET)" fillcolor="#80CBC4"]
        PET_F18DOPA [label="PET 18F-DOPA\n(presynaptic DA)" fillcolor="#4DB6AC"]
        CSF_aSyn [label="CSF α-Syn\n(oligomers)" fillcolor="#26A69A"]
        Serum_NfL [label="Serum NfL\n(neurodegeneration\nmarker)" fillcolor="#00897B"]
        CSF_tau_pTau [label="CSF tau/p-tau\n(co-pathology)" fillcolor="#00796B"]
        GBA_activity [label="GBA Enzyme\nActivity (blood)" fillcolor="#00695C" fontcolor="white"]
        Urate [label="Urate\n(protective?)" fillcolor="#4DB6AC"]
