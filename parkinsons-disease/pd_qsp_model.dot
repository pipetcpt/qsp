    NRF2 -> SOD [label="induces SOD" color="#43A047"]
    GSH -> ROS [label="neutralize" color="#43A047" dir=back]
    SOD -> ROS [label="dismutate" color="#43A047" dir=back]
    ROS -> NRF2 [label="activate" color="#43A047"]
    AMPK -> Mito_biogen [label="via PGC-1α" color="#43A047"]

    // ===== EDGES: Protein Quality Control =====
    HSP70 -> aSyn_mono [label="chaperone\nrefold" color="#1976D2"]
