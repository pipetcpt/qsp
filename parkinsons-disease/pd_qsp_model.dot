    // ===== CLUSTER 16: Pharmacokinetics (Population PK) =====
    subgraph cluster_popPK {
        label="Population PK / Compartmental Model"
        style="filled,rounded"
        fillcolor="#E8EAF6"
        color="#283593"
        fontcolor="#283593"
        fontsize=12
        fontname="Helvetica-Bold"

        PK_Oral_abs [label="Oral Absorption\nKa (h-1)" fillcolor="#9FA8DA"]
        PK_Vd [label="Volume of\nDistribution (Vd)" fillcolor="#9FA8DA"]
        PK_CL [label="Clearance (CL)\nrenal/hepatic" fillcolor="#7986CB"]
        PK_BBB_trans [label="BBB Transport\nrate (kBBB)" fillcolor="#7986CB"]
        PK_protein_bind [label="Plasma Protein\nBinding (fu)" fillcolor="#9FA8DA"]
        PK_CYP_meta [label="CYP450\nMetabolism\n(CYP2D6, 3A4)" fillcolor="#7986CB"]
        PK_renal_CL [label="Renal CL\n(GFR-dependent)" fillcolor="#9FA8DA"]
        PK_food_effect [label="Food-Drug\nInteraction\n(LAA competition)" fillcolor="#C5CAE9"]
        PK_Tmax [label="Tmax / Cmax\n(LD fluctuation)" fillcolor="#9FA8DA"]
        PK_half_life [label="t1/2\n(plasma)" fillcolor="#9FA8DA"]
    }

    // ===== EDGES: Genetics → Pathology =====
    SNCA -> aSyn_mono [label="overexpress" color="#E91E63"]
    LRRK2 -> aSyn_oligo [label="phospho\naSyn" color="#E91E63"]
    PINK1 -> Mito_quality [label="PINK1 activates\nParkin" color="#43A047"]
    PRKN -> Mito_quality [label="ubiquitin\nligation" color="#43A047"]
    DJ1 -> ROS [label="scavenges" color="#43A047" style=dashed]
    GBA -> Lysosome [label="GBA deficiency\n→ lysosomal" color="#1976D2" style=dashed]
    VPS35 -> Autophagy [label="retromer\nendolysosomal" color="#1976D2"]
    ATP13A2 -> Lysosome [label="lysosomal Zn/Mn\nexport" color="#1976D2"]
    MAPT -> Neuronal_death [label="tau co-pathology" color="#880E4F" style=dashed]

    // ===== EDGES: α-Syn Cascade =====
    aSyn_mono -> aSyn_oligo [label="nucleation" color="#E91E63" penwidth=2]
    aSyn_oligo -> aSyn_proto [label="elongation" color="#E91E63" penwidth=2]
    aSyn_proto -> aSyn_fibril [label="maturation" color="#C2185B" penwidth=2]
    aSyn_fibril -> LewyBody [label="inclusion\nformation" color="#880E4F" penwidth=2]
    aSyn_oligo -> Neuronal_death [label="toxic" color="#B71C1C" penwidth=2]
    aSyn_oligo -> Complex_I [label="inhibit" color="#BF360C"]
    aSyn_oligo -> UPS_impair [label="impair" color="#BF360C"]
    aSyn_oligo -> CMA [label="block LAMP-2A" color="#BF360C"]
    aSyn_oligo -> mPTP [label="open" color="#BF360C"]
    post_trans -> aSyn_oligo [label="accelerates\naggregation" color="#E91E63"]
    LRRK2 -> post_trans [label="pS129\nphosphorylation" color="#E91E63"]
    aSyn_mono -> aSyn_secrete [label="secretion\nexocytosis" color="#E91E63" style=dashed]
