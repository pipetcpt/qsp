    UPS -> aSyn_clear [label="degrades" color="#1976D2"]
    Autophagy -> aSyn_clear [label="degrades" color="#1976D2"]
    CMA -> aSyn_clear [label="degrades" color="#1976D2"]
    GBA -> aSyn_clear [label="lysosomal\nclear" color="#1976D2"]

    // ===== EDGES: Mitochondria =====
    Pesticides -> Complex_I [label="inhibit\n(rotenone\nMPP+)" color="#BF360C" penwidth=2]
