digraph MDS_QSP {
    graph [bgcolor="#0a0a1a", fontname="Helvetica", splines=ortho, rankdir=LR,
           label="MDS QSP Mechanistic Map", fontcolor="white", fontsize=20,
           pad=0.5, nodesep=0.4, ranksep=0.8];
    node [style=filled, fontname="Helvetica", fontsize=9, fontcolor="white", shape=box];
    edge [color="#888888", fontcolor="#aaaaaa", fontsize=8, arrowsize=0.7];

    // ─────────────────────────────────────────────
    // Cluster 1: Normal Hematopoiesis
    // ─────────────────────────────────────────────
    subgraph cluster_hema {
        label="Normal Hematopoiesis";
        fontcolor="white"; fontsize=13;
        style=filled; fillcolor="#0d1f2d"; color="#1e90ff";

        node [fillcolor="#1a3a5c", color="#1e90ff"];
        HSC      [label="HSC\n(Hematopoietic\nStem Cell)"];
        ST_HSC   [label="ST-HSC\n(Short-term HSC)"];
        MPP      [label="MPP\n(Multipotent\nProgenitor)"];
        CMP      [label="CMP\n(Common Myeloid\nProgenitor)"];
        MEP      [label="MEP\n(Megakaryocyte\nErythroid\nProgenitor)"];
        GMP      [label="GMP\n(Granulocyte\nMono Progenitor)"];
        ProEry   [label="ProEry\n(ProErythroblast)"];
        NormEry  [label="NormEry\n(Normoblast)"];
        RBC      [label="RBC\n(Red Blood Cell)"];
        MkP      [label="MkP\n(Megakaryocyte\nProgenitor)"];
        PLT      [label="PLT\n(Platelet)"];
        GranuP   [label="GranuP\n(Granulocyte\nProgenitor)"];
        Neutro   [label="Neutro\n(Neutrophil)"];
        Mono     [label="Mono\n(Monocyte)"];
        Macro    [label="Macro\n(Macrophage)"];
        DC       [label="DC\n(Dendritic Cell)"];
    }

    // ─────────────────────────────────────────────
    // Cluster 2: Clonal Evolution & Driver Mutations
    // ─────────────────────────────────────────────
    subgraph cluster_mutation {
        label="Clonal Evolution & Driver Mutations";
        fontcolor="white"; fontsize=13;
        style=filled; fillcolor="#1a0d0d"; color="#ff4444";

        node [fillcolor="#3a1010", color="#ff4444"];
        CHIP         [label="CHIP\n(Clonal Hema of\nIndeterminate\nPotential)"];
        MDS_clone    [label="MDS Clone\n(Dominant\nMalignant Clone)"];
        SF3B1_mut    [label="SF3B1 mut\n(~20–30% MDS)"];
        SRSF2_mut    [label="SRSF2 mut\n(~15%)"];
        U2AF1_mut    [label="U2AF1 mut\n(~10%)"];
        ZRSR2_mut    [label="ZRSR2 mut\n(~5%)"];
        TET2_mut     [label="TET2 mut\n(~20–25%)"];
        DNMT3A_mut   [label="DNMT3A mut\n(~10–15%)"];
        IDH1_mut     [label="IDH1 mut\n(~5%)"];
        IDH2_mut     [label="IDH2 mut\n(~5%)"];
        ASXL1_mut    [label="ASXL1 mut\n(~20%)"];
        EZH2_mut     [label="EZH2 mut\n(~6%)"];
        RUNX1_mut    [label="RUNX1 mut\n(~10–15%)"];
        TP53_mut     [label="TP53 mut\n(~10%, complex\nkaryotype)"];
        DEL5Q        [label="del(5q)\n(~10–15%\nisolated 5q-)"];
        RPS14_loss   [label="RPS14 loss\n(chr5q31.1)"];
        miR145_146a  [label="miR-145/146a loss\n(chr5q)"];
        MON7         [label="Monosomy 7\n(-7/del7q)"];
        COMPLEX_kary [label="Complex\nKaryotype\n(≥3 abnorm)"];
    }

    // ─────────────────────────────────────────────
    // Cluster 3: Epigenetic Dysregulation
    // ─────────────────────────────────────────────
    subgraph cluster_epigenetic {
        label="Epigenetic Dysregulation";
        fontcolor="white"; fontsize=13;
        style=filled; fillcolor="#0d1a0d"; color="#44ff88";

        node [fillcolor="#153322", color="#44ff88"];
        DNA_meth        [label="DNA Methylation\n(CpG islands)"];
        Hypermeth_CDK2NB [label="Hypermethylation\nCDKN2B (p15)"];
        p15_silencing   [label="p15/INK4b\nSilencing"];
        TET2_fn         [label="TET2 Function\n(5mC→5hmC)"];
        fivemc_fivehmC  [label="5mC / 5hmC\nBalance"];
        OncoTET_2HG     [label="2-Hydroxyglutarate\n(IDH mut product)"];
        H3K27me3        [label="H3K27me3\n(PRC2 repression)"];
        ASXL1_fn        [label="ASXL1 Function\n(PRC2 co-factor)"];
        ChromRemod      [label="Chromatin\nRemodeling"];
        DNMT3A_fn       [label="DNMT3A Function\n(de novo meth)"];
    }

    // ─────────────────────────────────────────────
    // Cluster 4: Splicing Factor Dysregulation
    // ─────────────────────────────────────────────
    subgraph cluster_splicing {
        label="Splicing Factor Dysregulation";
        fontcolor="white"; fontsize=13;
        style=filled; fillcolor="#1a130d"; color="#ffaa33";

        node [fillcolor="#33220a", color="#ffaa33"];
        Pre_mRNA    [label="Pre-mRNA\nSplicing"];
        SF3B1_fn    [label="SF3B1 Function\n(3' SS recognition)"];
        cryptic_SS  [label="Cryptic Splice\nSite Usage"];
        SRSF2_fn    [label="SRSF2 Function\n(ESE binding)"];
        ESE_binding [label="Exonic Splicing\nEnhancer (ESE)"];
        Ring_sider  [label="Ring Sideroblasts\n(SF3B1 hallmark)"];
        ABCB7_loss  [label="ABCB7 mis-splicing\n→ mitochondrial Fe\naccumulation"];
        NMD_pathway [label="Nonsense-Mediated\nmRNA Decay (NMD)"];
        Isoform_shift [label="Pathologic\nIsoform Shift"];
        U2AF1_fn    [label="U2AF1 Function\n(3' SS AG\nrecognition)"];
    }

    // ─────────────────────────────────────────────
    // Cluster 5: BM Microenvironment
    // ─────────────────────────────────────────────
    subgraph cluster_bme {
        label="BM Microenvironment";
        fontcolor="white"; fontsize=13;
        style=filled; fillcolor="#0d0d1a"; color="#aa88ff";

        node [fillcolor="#1a1a3a", color="#aa88ff"];
        MSC             [label="MSC\n(Mesenchymal\nStem Cell)"];
        OB              [label="Osteoblast\n(Niche support)"];
        Adipo           [label="Adipocyte\n(Altered in MDS)"];
        Endoth          [label="Endothelium\n(Vascular niche)"];
        CXCL12          [label="CXCL12/SDF-1\n(Retention signal)"];
        SCF             [label="SCF/c-Kit L\n(Stem cell factor)"];
        TPO             [label="TPO\n(Thrombopoietin)"];
        EPO_endogenous  [label="Endogenous EPO\n(Hypoxia-driven)"];
        GCSF_endogenous [label="Endogenous G-CSF\n(Granulopoiesis)"];
        Ang1            [label="Angiopoietin-1\n(Niche quiescence)"];
        VEGF            [label="VEGF\n(Angiogenesis)"];
        Niche_signal    [label="Niche Signaling\n(HSC maintenance)"];
        Hypoxia         [label="BM Hypoxia\n(O₂ tension)"];
        HIF1a           [label="HIF-1α\n(Hypoxia response)"];
    }

    // ─────────────────────────────────────────────
    // Cluster 6: Cytokine & Immune
    // ─────────────────────────────────────────────
    subgraph cluster_cytokine {
        label="Cytokine & Immune Dysregulation";
        fontcolor="white"; fontsize=13;
        style=filled; fillcolor="#1a0d1a"; color="#ff88ff";

        node [fillcolor="#2d1a2d", color="#ff88ff"];
        TNFa       [label="TNF-α\n(Pro-apoptotic)"];
        IL6        [label="IL-6\n(Inflammatory)"];
        IFNg       [label="IFN-γ\n(HSC suppression)"];
        TGFb1      [label="TGF-β1\n(Anti-proliferative)"];
        GDF11      [label="GDF11\n(Erythropoiesis\nsuppressor)"];
        GDF15      [label="GDF15\n(Hepcidin\nsuppressor)"];
        Hepcidin   [label="Hepcidin\n(Iron regulator)"];
        Ferroportin [label="Ferroportin\n(Iron export)"];
        IronOverload [label="Iron Overload\n(Transfusion-related)"];
        Treg       [label="Treg\n(CD4+CD25+FoxP3+)"];
        CD8T       [label="CD8+ T cell\n(CTL activity)"];
        Th1        [label="Th1 cells\n(IFN-γ producers)"];
        MDSC       [label="MDSC\n(Myeloid-derived\nSuppressor Cells)"];
        NK_cell    [label="NK cells\n(Innate immunity)"];
        IL13       [label="IL-13\n(Th2/fibro)"];
        Activin_A  [label="Activin A\n(ActRIIA/B ligand)"];
    }

    // ─────────────────────────────────────────────
    // Cluster 7: Dysplasia & Apoptosis
    // ─────────────────────────────────────────────
    subgraph cluster_dysplasia {
        label="Dysplasia & Ineffective Hematopoiesis";
        fontcolor="white"; fontsize=13;
        style=filled; fillcolor="#1a1500"; color="#ffdd00";

        node [fillcolor="#2d2600", color="#ffdd00"];
        Dysplasia     [label="Multilineage\nDysplasia"];
        IneffEry      [label="Ineffective\nErythropoiesis"];
        IneffMK       [label="Ineffective\nMegakaryopoiesis"];
        IneffGranu    [label="Ineffective\nGranulopoiesis"];
        Apoptosis_early [label="Premature\nApoptosis\n(early progenitors)"];
        Escape_apop   [label="Apoptosis Escape\n(advanced MDS)"];
        CaspAct       [label="Caspase\nActivation"];
        BCL2fam       [label="BCL-2 Family\n(BCL-2/BCL-XL/MCL1)"];
        Fas_Trail     [label="Fas/TRAIL\nSignaling"];
        p53_apo       [label="p53-mediated\nApoptosis"];
        ROS_stress    [label="Reactive Oxygen\nSpecies (ROS)"];
        DNA_damage    [label="DNA Damage\n(DSB, SSB)"];
    }

    // ─────────────────────────────────────────────
    // Cluster 8: Clinical Endpoints
    // ─────────────────────────────────────────────
    subgraph cluster_clinical {
        label="Clinical Endpoints & Classification";
        fontcolor="white"; fontsize=13;
        style=filled; fillcolor="#001a1a"; color="#00ffee";

        node [fillcolor="#003333", color="#00ffee"];
        Anemia         [label="Anemia\n(Hgb < 10 g/dL)"];
        Thromb         [label="Thrombocytopenia\n(PLT < 100k)"];
        Neutrop        [label="Neutropenia\n(ANC < 1.8k)"];
        Transfusion_dep [label="Transfusion\nDependence\n(≥4 U/8wk)"];
        BlastBM_pct    [label="BM Blast %\n(0–19%)"];
        AML_trans      [label="AML\nTransformation\n(Blasts ≥20%)"];
        IPSS_R         [label="IPSS-R Score\n(Revised)"];
        IPSS_M         [label="IPSS-M Score\n(Molecular)"];
        VLRI_VLow      [label="IPSS-R\nVery Low\n(≤1.5)"];
        VLRI_Low       [label="IPSS-R\nLow\n(>1.5–3)"];
        VLRI_Int       [label="IPSS-R\nIntermediate\n(>3–4.5)"];
        VLRI_High      [label="IPSS-R\nHigh\n(>4.5–6)"];
        VLRI_VHigh     [label="IPSS-R\nVery High\n(>6)"];
        CytGood        [label="Cytogenetics\nGood Risk"];
        CytPoor        [label="Cytogenetics\nPoor Risk"];
        WHO_MDS_LB     [label="WHO MDS\nLow Blast"];
        WHO_MDS_IB1    [label="WHO MDS-IB1\n(5–9% blasts)"];
        WHO_MDS_IB2    [label="WHO MDS-IB2\n(10–19% blasts)"];
        WHO_MDS_RS     [label="WHO MDS-RS\n(Ring Sideroblasts)"];
        WHO_MDS_5q     [label="WHO MDS del(5q)"];
        OS_outcome     [label="Overall\nSurvival (OS)"];
        EFS_outcome    [label="Event-Free\nSurvival (EFS)"];
    }

    // ─────────────────────────────────────────────
    // Cluster 9: Drug PK/PD
    // ─────────────────────────────────────────────
    subgraph cluster_drug {
        label="Drug PK/PD";
        fontcolor="white"; fontsize=13;
        style=filled; fillcolor="#001100"; color="#00ff44";

        node [fillcolor="#002200", color="#00ff44"];
        AZA_dose      [label="Azacitidine\nDose (75 mg/m²/d)"];
        AZA_C         [label="AZA Plasma Conc\n(PK)"];
        AZA_P         [label="AZA Intracellular\nPhosphorylation"];
        AZA_DNMT_trap [label="AZA-DNMT\nCovalent Trap\n(Demethylation)"];
        DEC_dose      [label="Decitabine\nDose (20 mg/m²/d)"];
        DEC_C         [label="DAC Plasma Conc\n(PK)"];
        DEC_oral_ced  [label="Oral DEC-Cedazuridine\n(ASTX727)"];
        LEN_dose      [label="Lenalidomide\nDose (10 mg/d)"];
        LEN_C         [label="LEN Plasma Conc\n(PK)"];
        CRBN_binding  [label="Cereblon (CRBN)\nBinding"];
        CK1alpha_deg  [label="CK1α Degradation\n(del5q mechanism)"];
        RPS14_restore [label="RPS14\nFunctional Restore"];
        LUSP_dose     [label="Luspatercept\nDose (1 mg/kg)"];
        LUSP_C        [label="LUSP Plasma Conc\n(PK)"];
        ActRIIB_Fc    [label="ActRIIB-Fc\nLigand Trap"];
        Smad23_inh    [label="SMAD2/3\nPhosphorylation\nInhibition"];
        EPO_exog      [label="Exogenous EPO\n(ESA therapy)"];
        ESA_receptor  [label="EPOR Activation\n(ESA response)"];
        VEN_dose      [label="Venetoclax\nDose (400 mg/d)"];
        VEN_C         [label="VEN Plasma Conc\n(PK)"];
        BCL2_inh      [label="BCL-2 Inhibition\n(BH3 mimetic)"];
        Imet_dose     [label="Imetelstat\n(Telomerase inh)"];
        hTERT_inh     [label="hTERT Inhibition\n(Telomere\nshortening)"];
    }

    // ─────────────────────────────────────────────
    // Cluster 10: AlloSCT & Supportive Care
    // ─────────────────────────────────────────────
    subgraph cluster_transplant {
        label="AlloSCT & Supportive Care";
        fontcolor="white"; fontsize=13;
        style=filled; fillcolor="#0d0d00"; color="#ffff44";

        node [fillcolor="#1a1a00", color="#ffff44"];
        AlloSCT        [label="AlloSCT\n(Allogeneic SCT)"];
        RIC_cond       [label="RIC Conditioning\n(Reduced Intensity)"];
        MAC_cond       [label="MAC Conditioning\n(Myeloablative)"];
        GVL_effect     [label="GvL Effect\n(Graft-vs-Leukemia)"];
        GvHD_risk      [label="GvHD Risk\n(Graft-vs-Host)"];
        RBC_transfusion [label="RBC Transfusion\n(Supportive)"];
        PLT_transfusion [label="PLT Transfusion\n(Supportive)"];
        GCSF_support   [label="G-CSF Support\n(Neutropenia Rx)"];
        Iron_chelation [label="Iron Chelation\n(Deferoxamine/\nDeferasirox)"];
    }

    // =================================================
    // EDGES
    // =================================================

    // --- Hematopoiesis hierarchy ---
    HSC -> ST_HSC [label="self-renew /\ndifferentiate"];
    ST_HSC -> MPP [label="commitment"];
    MPP -> CMP    [label="myeloid fate"];
    CMP -> MEP    [label="erythroid/MK"];
    CMP -> GMP    [label="granulocyte/Mono"];
    MEP -> ProEry [label="EPO-driven"];
    ProEry -> NormEry [label="maturation"];
    NormEry -> RBC [label="enucleation"];
    MEP -> MkP    [label="TPO-driven"];
    MkP -> PLT    [label="proplatelet\nrelease"];
    GMP -> GranuP [label="G-CSF-driven"];
    GranuP -> Neutro [label="terminal diff."];
    GMP -> Mono   [label="M-CSF-driven"];
    Mono -> Macro [label="tissue egress"];
    Mono -> DC    [label="DC precursor"];

    // --- Clonal evolution ---
    CHIP -> MDS_clone [label="additional hits\n+ clonal expansion", color="#ff4444"];
    MDS_clone -> SF3B1_mut [style=dashed, color="#ff6666"];
    MDS_clone -> SRSF2_mut [style=dashed, color="#ff6666"];
    MDS_clone -> U2AF1_mut [style=dashed, color="#ff6666"];
    MDS_clone -> ZRSR2_mut [style=dashed, color="#ff6666"];
    MDS_clone -> TET2_mut  [style=dashed, color="#ff6666"];
    MDS_clone -> DNMT3A_mut [style=dashed, color="#ff6666"];
    MDS_clone -> IDH1_mut  [style=dashed, color="#ff6666"];
    MDS_clone -> IDH2_mut  [style=dashed, color="#ff6666"];
    MDS_clone -> ASXL1_mut [style=dashed, color="#ff6666"];
    MDS_clone -> EZH2_mut  [style=dashed, color="#ff6666"];
    MDS_clone -> RUNX1_mut [style=dashed, color="#ff6666"];
    MDS_clone -> TP53_mut  [style=dashed, color="#ff6666"];
    MDS_clone -> DEL5Q     [style=dashed, color="#ff6666"];
    MDS_clone -> MON7      [style=dashed, color="#ff6666"];
    MDS_clone -> COMPLEX_kary [style=dashed, color="#ff6666"];
    DEL5Q -> RPS14_loss    [label="5q31 del"];
    DEL5Q -> miR145_146a   [label="5q33 del"];
    COMPLEX_kary -> TP53_mut [label="co-occurrence", color="#ff4444"];

    // --- Epigenetic pathway ---
    TET2_mut -> TET2_fn      [label="LOF", arrowhead=tee, color="#44ff88"];
    TET2_fn -> fivemc_fivehmC [label="5mC→5hmC\nconversion"];
    IDH1_mut -> OncoTET_2HG  [label="2-HG\nproduction", color="#ff8888"];
    IDH2_mut -> OncoTET_2HG  [label="2-HG\nproduction", color="#ff8888"];
    OncoTET_2HG -> TET2_fn   [label="TET2 inhibition", arrowhead=tee, color="#ff4444"];
    DNMT3A_mut -> DNMT3A_fn  [label="LOF", arrowhead=tee, color="#44ff88"];
    DNMT3A_fn -> DNA_meth    [label="de novo\nmethylation"];
    DNA_meth -> Hypermeth_CDK2NB [label="CDKN2B\npromoter"];
    Hypermeth_CDK2NB -> p15_silencing [label="gene silencing"];
    ASXL1_mut -> ASXL1_fn    [label="LOF", arrowhead=tee, color="#44ff88"];
    ASXL1_fn -> H3K27me3     [label="PRC2\ndysregulation"];
    H3K27me3 -> ChromRemod   [label="repressive\nchromatin"];
    EZH2_mut -> H3K27me3     [label="EZH2 LOF/GOF", color="#ff8888"];
    fivemc_fivehmC -> ChromRemod [label="epigenetic\nlandscape"];

    // --- Splicing factor pathway ---
    SF3B1_mut -> SF3B1_fn    [label="LOF/neomorph", arrowhead=tee, color="#ffaa33"];
    SF3B1_fn -> Pre_mRNA     [label="U2 snRNP\nbranch point\nrecognition"];
    Pre_mRNA -> cryptic_SS   [label="aberrant\nusage"];
    cryptic_SS -> ABCB7_loss [label="mis-spliced\ntranscript"];
    ABCB7_loss -> Ring_sider [label="mitochondrial\nFe accumulation"];
    SRSF2_mut -> SRSF2_fn    [label="P95H/L/R mut", arrowhead=tee, color="#ffaa33"];
    SRSF2_fn -> ESE_binding  [label="altered ESE\naffinity"];
    U2AF1_mut -> U2AF1_fn    [label="S34F/Y, Q157R", arrowhead=tee, color="#ffaa33"];
    U2AF1_fn -> Pre_mRNA     [label="3' SS AG\nrecognition"];
    Pre_mRNA -> Isoform_shift [label="pathologic\nisoforms"];
    Isoform_shift -> NMD_pathway [label="PTC-containing\ntranscripts"];

    // --- BM microenvironment ---
    MSC -> CXCL12      [label="secretion"];
    MSC -> SCF         [label="secretion"];
    MSC -> Ang1        [label="secretion"];
    OB -> Niche_signal [label="osteoblastic\nniche"];
    Adipo -> Niche_signal [label="adipocytic\nniche"];
    Endoth -> VEGF     [label="angiogenic\nsupport"];
    CXCL12 -> HSC      [label="CXCR4\nretention"];
    SCF -> HSC         [label="c-Kit\nsurvival"];
    TPO -> MkP         [label="MPL\nsignaling"];
    EPO_endogenous -> ProEry [label="EPOR\nsurvival"];
    GCSF_endogenous -> GranuP [label="G-CSFR\nsignaling"];
    Hypoxia -> HIF1a   [label="stabilization"];
    HIF1a -> EPO_endogenous [label="EPO gene\ntranscription"];
    HIF1a -> VEGF      [label="VEGF\ntranscription"];
    Ang1 -> Niche_signal [label="Tie2\nsignaling"];
    Niche_signal -> HSC [label="quiescence\nmaintenance"];

    // --- Cytokine / immune edges ---
    TNFa -> Apoptosis_early [label="TNFR1-\nmediated", color="#ff88ff"];
    IFNg -> HSC    [label="IFNGR\nsuppression", arrowhead=tee, color="#ff88ff"];
    TGFb1 -> IneffEry [label="SMAD\nanti-prolif", arrowhead=tee, color="#ff88ff"];
    GDF11 -> IneffEry [label="ActRIIB\nsuppression", arrowhead=tee, color="#ff88ff"];
    Activin_A -> IneffEry [label="ActRIIA/B\nligand", arrowhead=tee, color="#ff88ff"];
    GDF15 -> Hepcidin [label="suppression", arrowhead=tee, color="#ff88ff"];
    Hepcidin -> Ferroportin [label="degradation", arrowhead=tee, color="#ff4444"];
    Ferroportin -> IronOverload [label="↓ Fe export\n→ accumulation", arrowhead=tee, color="#ff4444"];
    IL6 -> Hepcidin [label="hepatic\nproduction", color="#ff88ff"];
    Treg -> CD8T    [label="suppression", arrowhead=tee];
    MDSC -> NK_cell [label="NK inhibition", arrowhead=tee];
    Th1 -> IFNg     [label="IFN-γ\nproduction"];
    CD8T -> MDS_clone [label="immune\nevasion challenged", arrowhead=tee];
    NK_cell -> MDS_clone [label="ADCC", arrowhead=tee];
    miR145_146a -> IL6 [label="TLR/NF-κB\nde-repression", color="#ff4444"];

    // --- Dysplasia / apoptosis ---
    MDS_clone -> Dysplasia   [label="clonal\ndominance", color="#ffdd00"];
    Dysplasia -> IneffEry    [label="erythroid\ndysplasia"];
    Dysplasia -> IneffMK     [label="MK dysplasia"];
    Dysplasia -> IneffGranu  [label="granulocyte\ndysplasia"];
    IneffEry -> Apoptosis_early [label="intramedullary\ndeath"];
    IneffMK -> Apoptosis_early [label="MK apoptosis"];
    IneffGranu -> Apoptosis_early [label="granulocyte\napoptosis"];
    Apoptosis_early -> CaspAct [label="caspase\ncascade"];
    CaspAct -> Fas_Trail     [label="extrinsic\npathway"];
    TNFa -> Fas_Trail        [label="TRAIL-R\nactivation"];
    BCL2fam -> CaspAct       [label="BAX/BAK\nactivation", arrowhead=tee];
    TP53_mut -> Escape_apop  [label="p53 LOF→\napop escape", color="#ff4444"];
    Escape_apop -> AML_trans [label="blast\naccumulation", color="#ff4444"];
    p53_apo -> Apoptosis_early [label="p53 WT\napoptosis"];
    ROS_stress -> DNA_damage  [label="oxidative\nDNA damage"];
    DNA_damage -> p53_apo     [label="p53\nstabilization"];
    IronOverload -> ROS_stress [label="Fenton\nreaction", color="#ff4444"];

    // --- Hematopoiesis failure → clinical ---
    IneffEry -> Anemia        [label="↓ RBC output"];
    IneffMK -> Thromb         [label="↓ PLT output"];
    IneffGranu -> Neutrop     [label="↓ ANC"];
    Anemia -> Transfusion_dep [label="symptomatic\nanemia"];
    RBC -> Anemia             [label="↓ RBC count", arrowhead=tee, style=dashed];
    PLT -> Thromb             [label="↓ PLT count", arrowhead=tee, style=dashed];
    Neutro -> Neutrop         [label="↓ ANC", arrowhead=tee, style=dashed];
    BlastBM_pct -> IPSS_R     [label="blast %\ncomponent"];
    Anemia -> IPSS_R          [label="Hgb\ncomponent"];
    Neutrop -> IPSS_R         [label="ANC\ncomponent"];
    Thromb -> IPSS_R          [label="PLT\ncomponent"];
    CytGood -> IPSS_R         [label="cytogenetics\ncomponent"];
    CytPoor -> IPSS_R         [label="poor\ncytogenetics", color="#ff4444"];
    IPSS_R -> VLRI_VLow       [style=dashed];
    IPSS_R -> VLRI_Low        [style=dashed];
    IPSS_R -> VLRI_Int        [style=dashed];
    IPSS_R -> VLRI_High       [style=dashed];
    IPSS_R -> VLRI_VHigh      [style=dashed];
    IPSS_M -> OS_outcome      [label="molecular\nprognostication"];
    IPSS_R -> OS_outcome      [label="IPSS-R\nprognostication"];
    AML_trans -> EFS_outcome  [label="AML event", color="#ff4444"];
    BlastBM_pct -> WHO_MDS_IB1 [label="5–9%"];
