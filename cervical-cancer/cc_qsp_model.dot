digraph CervicalCancer_QSP {
  graph [
    layout=fdp, K=1.2, splines=true, overlap=false,
    fontname="Helvetica", fontsize=11, bgcolor="#FAFAFA",
    label="자궁경부암 (Cervical Cancer) QSP 기계론적 지도\nHPV-driven Cervical Carcinoma · v1.0 · 2026-07-01\n11 clusters · 190+ nodes · CCRT / Bevacizumab / Pembrolizumab / Tisotumab Vedotin",
    labelloc=t, labeljust=c
  ];
  node [shape=box, style="filled,rounded", fontname="Helvetica", fontsize=8, margin="0.05,0.03"];
  edge [fontname="Helvetica", fontsize=7, arrowsize=0.65];

  // ============================================================
  // Cluster 1: HPV 종양유전 경로 (HPV Oncogenesis)
  // ============================================================
  subgraph cluster_HPV {
    label="① HPV 종양유전 경로\n(HPV16/18 Oncogenesis)";
    style=filled; fillcolor="#FFE4E1"; color="#C0392B";
    fontsize=9; fontcolor="#C0392B";

    HPV_virion  [label="HPV16/18 Virion\n(dsDNA papillomavirus)", fillcolor="#FF6B6B"];
    HPV_entry   [label="Basal Cell Entry\n(microtrauma access)", fillcolor="#FFB3B3"];
    HPV_episome [label="Episomal HPV DNA\n(early infection)", fillcolor="#FFB3B3"];
    HPV_integ   [label="Viral Genome Integration\n(disrupts E2)", fillcolor="#E74C3C", fontcolor=white];
    E1_prot     [label="E1\n(viral helicase)", fillcolor="#FFCCCC"];
    E2_prot     [label="E2\n(transcription repressor)", fillcolor="#FFCCCC"];
    E5_prot     [label="E5\n(EGFR potentiation)", fillcolor="#FFB3B3"];
    E6_onco     [label="E6 Oncoprotein\n(HPV16/18)", fillcolor="#C0392B", fontcolor=white];
    E7_onco     [label="E7 Oncoprotein\n(HPV16/18)", fillcolor="#C0392B", fontcolor=white];
    E6AP        [label="E6AP/UBE3A\n(ubiquitin ligase)", fillcolor="#FFB3B3"];
    p53_tp      [label="p53\n(tumor suppressor)", fillcolor="#FF8C8C"];
    Ubiquitin   [label="Ubiquitin-Proteasome\n(26S proteasome)", fillcolor="#FFCCCC"];
    p53_degrade [label="p53 Degradation\n(loss of G1 checkpoint)", fillcolor="#E74C3C", fontcolor=white];
    pRb_prot    [label="pRb\n(retinoblastoma protein)", fillcolor="#FF8C8C"];
    E7_pRb_bind [label="E7-pRb Binding\n(LXCXE motif)", fillcolor="#E74C3C", fontcolor=white];
    E2F_release [label="E2F Release\n(unrestrained)", fillcolor="#FFAAAA"];
    p16INK4a    [label="p16INK4a\n(surrogate IHC marker)", fillcolor="#E74C3C", fontcolor=white];
    telomerase  [label="hTERT/Telomerase\n(E6-induced activation)", fillcolor="#FFB3B3"];
    viral_persist [label="Viral Persistence\n(vs clearance)", fillcolor="#FFCCCC"];
    viral_clear [label="Immune-Mediated Clearance\n(~90% transient)", fillcolor="#A9DFBF"];
    HPV_load    [label="HPV Viral Load\n(copies/cell)", fillcolor="#FFAAAA"];
    CIN1        [label="CIN1\n(mild dysplasia)", fillcolor="#FFCCCC"];
    CIN2        [label="CIN2\n(moderate dysplasia)", fillcolor="#FFAAAA"];
    CIN3        [label="CIN3/CIS\n(severe dysplasia/carcinoma in situ)", fillcolor="#FF7F7F"];
    micro_invasion [label="Microinvasion\n(stromal breach)", fillcolor="#E74C3C", fontcolor=white];
  }

  // ============================================================
  // Cluster 2: 세포주기 / 증식 / 아폽토시스 회피
  // ============================================================
  subgraph cluster_cellcycle {
    label="② 세포주기 / 증식 / 아폽토시스 회피\n(Cell Cycle & Apoptosis Evasion)";
    style=filled; fillcolor="#E8F5E9"; color="#2E7D32";
    fontsize=9; fontcolor="#2E7D32";

    CyclinE    [label="Cyclin E\n(G1/S driver)", fillcolor="#A5D6A7"];
    CyclinD1   [label="Cyclin D1\n(G1 progression)", fillcolor="#A5D6A7"];
    CDK2       [label="CDK2\n(S-phase kinase)", fillcolor="#81C784"];
    CDK46_c    [label="CDK4/6\n(G1/S kinase)", fillcolor="#81C784"];
    p21_c      [label="p21/CDKN1A\n(CDK inhibitor)", fillcolor="#C8E6C9"];
    p27_c      [label="p27/KIP1\n(CDK inhibitor)", fillcolor="#C8E6C9"];
    E2F1_c     [label="E2F1\n(S-phase TF)", fillcolor="#4CAF50"];
    PIK3CA_c   [label="PIK3CA\n(mutated ~30% SCC)", fillcolor="#A5D6A7"];
    AKT_c      [label="AKT\n(survival signaling)", fillcolor="#4CAF50"];
    mTOR_cc    [label="mTOR\n(protein synthesis)", fillcolor="#2E7D32", fontcolor=white];
    PTEN_c     [label="PTEN\n(tumor suppressor)", fillcolor="#A5D6A7"];
    BCL2_c     [label="BCL-2\n(anti-apoptotic)", fillcolor="#81C784"];
    BAX_c      [label="BAX\n(pro-apoptotic)", fillcolor="#81C784"];
    survivin_c [label="Survivin\n(IAP family, HPV-induced)", fillcolor="#66BB6A"];
    caspase_cc [label="Caspase-3/8/9\n(executioner cascade)", fillcolor="#388E3C", fontcolor=white];
    apop_rate  [label="Apoptosis Rate\n(net cell death)", fillcolor="#1B5E20", fontcolor=white];
    prolif_rate [label="Proliferation Rate\n(Ki-67 index)", fillcolor="#1B5E20", fontcolor=white];
    telomer_c  [label="Telomere Maintenance\n(immortalization)", fillcolor="#A5D6A7"];
    genome_instab [label="Genomic Instability\n(aneuploidy)", fillcolor="#66BB6A"];
  }

  // ============================================================
  // Cluster 3: 종양 미세환경 / 면역회피
  // ============================================================
  subgraph cluster_TME {
    label="③ 종양 미세환경 / 면역회피\n(Tumor Microenvironment & Immune Evasion)";
    style=filled; fillcolor="#F3E5F5"; color="#4A148C";
    fontsize=9; fontcolor="#4A148C";

    PDL1_c     [label="PD-L1\n(CD274, HPV-upregulated)", fillcolor="#CE93D8"];
    PD1_c      [label="PD-1\n(CD279, T cell)", fillcolor="#CE93D8"];
    CD8T_c     [label="CD8+ T cells\n(tumor-infiltrating)", fillcolor="#43A047"];
    CD4T_c     [label="CD4+ T cells\n(helper)", fillcolor="#66BB6A"];
    Treg_cc    [label="Tregs\n(FoxP3+, immunosuppressive)", fillcolor="#FFA726"];
    MDSC_c     [label="MDSCs\n(myeloid-derived suppressors)", fillcolor="#FF8A65"];
    TAM_c      [label="TAM (M2-like)\n(immunosuppressive macrophage)", fillcolor="#FFA726"];
    IDO1_c     [label="IDO1\n(tryptophan catabolism)", fillcolor="#BA68C8"];
    Kynuren_c  [label="Kynurenine\n(immunosuppressive metabolite)", fillcolor="#CE93D8"];
    TGFb_cc    [label="TGF-β\n(immunosuppression)", fillcolor="#FF8A65"];
    IL6_cc     [label="IL-6\n(pro-tumorigenic cytokine)", fillcolor="#FF8A65"];
    IL10_cc    [label="IL-10\n(anti-inflammatory)", fillcolor="#FF8A65"];
    IFNg_cc    [label="IFN-γ\n(anti-tumor cytokine)", fillcolor="#FFCA28"];
    MHC1_c     [label="MHC Class I\n(antigen presentation, downregulated)", fillcolor="#CE93D8"];
    T_exhaust_c [label="T Cell Exhaustion\n(chronic Ag stimulation)", fillcolor="#AB47BC"];
    LAG3_c     [label="LAG-3\n(checkpoint)", fillcolor="#CE93D8"];
    TIM3_c     [label="TIM-3\n(exhaustion marker)", fillcolor="#CE93D8"];
    E7_MHC_dn  [label="E7-induced MHC-I Downregulation\n(immune escape)", fillcolor="#8E24AA", fontcolor=white];
    TLS_c      [label="Tertiary Lymphoid Structures\n(TLS, favorable prognosis)", fillcolor="#CE93D8"];
    NK_cc      [label="NK Cells\n(cytotoxic, E5-suppressed)", fillcolor="#66BB6A"];
  }

  // ============================================================
  // Cluster 4: 혈관신생 (Angiogenesis)
  // ============================================================
  subgraph cluster_angio {
    label="④ 혈관신생\n(Tumor Angiogenesis)";
    style=filled; fillcolor="#E8EAF6"; color="#283593";
    fontsize=9; fontcolor="#283593";

    hypoxia_c  [label="Tumor Hypoxia\n(pO2 <10mmHg, radioresistant)", fillcolor="#7986CB"];
    HIF1a_c    [label="HIF-1α\n(hypoxia-inducible factor)", fillcolor="#9FA8DA"];
    VEGFA_c    [label="VEGF-A\n(key angiogenic driver)", fillcolor="#7986CB"];
    VEGFR2_c   [label="VEGFR2/KDR\n(main signaling receptor)", fillcolor="#283593", fontcolor=white];
    VEGFR1_c   [label="VEGFR1/FLT1\n(decoy receptor)", fillcolor="#5C6BC0"];
    endo_c     [label="Endothelial Cells\n(tip/stalk)", fillcolor="#7986CB"];
    tumor_vasc_c [label="Tumor Vasculature\n(abnormal/leaky)", fillcolor="#3949AB", fontcolor=white];
    PlGF_c     [label="PlGF\n(placental growth factor)", fillcolor="#9FA8DA"];
    Ang2_c     [label="Angiopoietin-2\n(vessel destabilization)", fillcolor="#9FA8DA"];
    pericyte_c [label="Pericytes\n(vessel stabilization)", fillcolor="#9FA8DA"];
    Bevacizumab [label="Bevacizumab\n(anti-VEGF-A mAb, 15mg/kg q3w)", fillcolor="#1A237E", fontcolor=white, shape=diamond];
    GI_perf_c  [label="Bowel/Fistula Risk\n(anti-angiogenic AE)", fillcolor="#C5CAE9"];
  }

  // ============================================================
  // Cluster 5: 침습 / 전이 (Invasion & Metastasis)
  // ============================================================
  subgraph cluster_invasion {
    label="⑤ 침습 / 전이 / 병기\n(Invasion, Metastasis & FIGO Staging)";
    style=filled; fillcolor="#E0F2F1"; color="#004D40";
    fontsize=9; fontcolor="#004D40";

    EMT_c      [label="EMT\n(epithelial-mesenchymal transition)", fillcolor="#00897B", fontcolor=white];
    Ecad_c     [label="E-cadherin\n(epithelial adhesion, lost)", fillcolor="#80CBC4"];
    Ncad_c     [label="N-cadherin\n(mesenchymal marker)", fillcolor="#80CBC4"];
    MMP2_c     [label="MMP-2\n(basement membrane degrade)", fillcolor="#4DB6AC"];
    MMP9_c     [label="MMP-9\n(matrix remodeling)", fillcolor="#4DB6AC"];
    LVSI_c     [label="Lymphovascular Space Invasion\n(LVSI)", fillcolor="#00695C", fontcolor=white];
    pelvic_LN  [label="Pelvic Lymph Nodes\n(1st echelon)", fillcolor="#4DB6AC"];
    paraaortic_LN [label="Para-aortic Lymph Nodes\n(2nd echelon)", fillcolor="#26A69A"];
    parametrial_inv [label="Parametrial Invasion\n(FIGO IIB)", fillcolor="#4DB6AC"];
    vaginal_ext [label="Vaginal Extension\n(FIGO IIA)", fillcolor="#80CBC4"];
    pelvic_wall [label="Pelvic Sidewall Fixation\n(FIGO IIIB)", fillcolor="#26A69A"];
    bladder_rectum [label="Bladder/Rectum Invasion\n(FIGO IVA)", fillcolor="#00695C", fontcolor=white];
    distant_mets [label="Distant Metastasis\n(lung/bone/liver, FIGO IVB)", fillcolor="#004D40", fontcolor=white];
    FIGO_stage_c [label="FIGO 2018 Stage\n(I–IV)", fillcolor="#00695C", fontcolor=white];
    tumor_size_c [label="Primary Tumor Diameter\n(cm)", fillcolor="#80CBC4"];
    hydronephrosis [label="Hydronephrosis\n(ureteral obstruction)", fillcolor="#4DB6AC"];
  }

  // ============================================================
  // Cluster 6: 백금 기반 동시화학방사선 PK/PD
  // ============================================================
  subgraph cluster_CCRT {
    label="⑥ 백금 기반 동시화학방사선 PK/PD\n(Cisplatin/Carboplatin Concurrent Chemoradiation)";
    style=filled; fillcolor="#FFF8E1"; color="#E65100";
    fontsize=9; fontcolor="#E65100";

    Cisp_dose  [label="Cisplatin\n(40mg/m² weekly IV ×5-6)", fillcolor="#FFE082", shape=diamond];
    Carbo_dose_c [label="Carboplatin\n(AUC2 weekly, cisplatin-intolerant)", fillcolor="#FFE082", shape=diamond];
    Pacli_dose_c [label="Paclitaxel\n(interval CT, recurrent setting)", fillcolor="#FFE082", shape=diamond];
    CIS_C1     [label="Cisplatin\n(central PK)", fillcolor="#FFC107"];
    CIS_C2     [label="Cisplatin\n(peripheral PK)", fillcolor="#FFC107"];
    CTR1_cc    [label="CTR1\n(copper transporter, Pt uptake)", fillcolor="#FFCA28"];
    Pt_DNA_c   [label="Pt-DNA Adducts\n(intra-strand cross-links)", fillcolor="#E65100", fontcolor=white];
    NER_c      [label="NER\n(nucleotide excision repair)", fillcolor="#FFCCBC"];
    GST_pi_c   [label="GST-π\n(platinum detoxification)", fillcolor="#FFCA28"];
    radiosensit [label="Radiosensitization\n(cisplatin-radiation synergy)", fillcolor="#E65100", fontcolor=white];
    chemo_apop_c [label="Chemo-Induced Apoptosis", fillcolor="#BF360C", fontcolor=white];
    nephrotox_c [label="Nephrotoxicity\n(cisplatin AE)", fillcolor="#FFCCBC"];
    neurotox_c [label="Peripheral Neuropathy\n(paclitaxel AE)", fillcolor="#FFCCBC"];
    myelosupp_c [label="Myelosuppression\n(CCRT AE)", fillcolor="#FFCCBC"];
  }

  // ============================================================
  // Cluster 7: 방사선치료 (EBRT + 근접치료)
  // ============================================================
  subgraph cluster_RT {
    label="⑦ 방사선치료\n(EBRT + Brachytherapy)";
    style=filled; fillcolor="#ECEFF1"; color="#37474F";
    fontsize=9; fontcolor="#37474F";

    EBRT_dose  [label="EBRT\n(45-50Gy/25fx pelvis ± para-aortic)", fillcolor="#B0BEC5", shape=diamond];
    brachy_dose [label="Brachytherapy Boost\n(HDR, ≥85Gy EQD2 total)", fillcolor="#B0BEC5", shape=diamond];
    LQ_model   [label="LQ Model\n(α/β = 10Gy tumor)", fillcolor="#607D8B", fontcolor=white];
    DNA_dsb_rt [label="Radiation-Induced DSBs", fillcolor="#78909C", fontcolor=white];
    SLD_repair [label="Sublethal Damage Repair", fillcolor="#B0BEC5"];
    surviving_frac [label="Surviving Fraction\n(SF = exp(-αD-βD²))", fillcolor="#455A64", fontcolor=white];
    TCP_model  [label="Tumor Control Probability\n(TCP)", fillcolor="#263238", fontcolor=white];
    EQD2_c     [label="EQD2\n(equivalent dose in 2Gy fractions)", fillcolor="#607D8B", fontcolor=white];
    OAR_tox    [label="OAR Toxicity\n(bladder/rectum/bowel)", fillcolor="#CFD8DC"];
    reoxygenation [label="Reoxygenation\n(between fractions)", fillcolor="#B0BEC5"];
    repopulation [label="Accelerated Repopulation\n(overall tx time)", fillcolor="#B0BEC5"];
  }

  // ============================================================
  // Cluster 8: 면역항암제 PK/PD (Pembrolizumab)
  // ============================================================
  subgraph cluster_ICI {
    label="⑧ 면역관문억제제 PK/PD\n(Pembrolizumab Checkpoint Blockade)";
    style=filled; fillcolor="#FCE4EC"; color="#880E4F";
    fontsize=9; fontcolor="#880E4F";

    Pembro_dose [label="Pembrolizumab\n(200mg q3w or 400mg q6w IV)", fillcolor="#F48FB1", shape=diamond];
    PEMBRO_C1  [label="Pembrolizumab\n(central PK)", fillcolor="#E91E63"];
    PEMBRO_C2  [label="Pembrolizumab\n(peripheral PK)", fillcolor="#C2185B", fontcolor=white];
    PD1_block  [label="PD-1 Receptor Occupancy\n(saturating >95%)", fillcolor="#880E4F", fontcolor=white];
    Tcell_reinvig [label="T Cell Reinvigoration", fillcolor="#AD1457", fontcolor=white];
    ICI_apop   [label="ICI-Enhanced Tumor Killing", fillcolor="#880E4F", fontcolor=white];
    irAE_c     [label="Immune-Related AEs\n(colitis/pneumonitis/thyroiditis)", fillcolor="#F48FB1"];
    CPS_score  [label="PD-L1 CPS Score\n(combined positive score)", fillcolor="#F48FB1"];
  }

  // ============================================================
  // Cluster 9: 항체-약물 접합체 PK/PD (Tisotumab Vedotin)
  // ============================================================
  subgraph cluster_ADC {
    label="⑨ 항체-약물 접합체 PK/PD\n(Tisotumab Vedotin ADC)";
    style=filled; fillcolor="#EDE7F6"; color="#1A237E";
    fontsize=9; fontcolor="#1A237E";

    TF_antigen [label="Tissue Factor (TF)\n(target antigen, overexpressed)", fillcolor="#9575CD"];
    TV_dose    [label="Tisotumab Vedotin\n(2.0mg/kg q3w IV)", fillcolor="#7E57C2", fontcolor=white, shape=diamond];
    TV_ADC_C1  [label="TV-ADC\n(central PK, conjugate)", fillcolor="#5E35B1", fontcolor=white];
    TV_ADC_C2  [label="TV-ADC\n(peripheral PK)", fillcolor="#5E35B1", fontcolor=white];
    ADC_internalize [label="TF-Mediated Internalization\n(receptor-mediated endocytosis)", fillcolor="#7E57C2", fontcolor=white];
    MMAE_release [label="MMAE Payload Release\n(protease-cleavable linker)", fillcolor="#4527A0", fontcolor=white];
    microtub_disrupt [label="Microtubule Disruption\n(MMAE mechanism)", fillcolor="#311B92", fontcolor=white];
    bystander_kill [label="Bystander Killing\n(membrane-permeable MMAE)", fillcolor="#4527A0", fontcolor=white];
    ADC_apop   [label="ADC-Induced Apoptosis\n(G2/M arrest)", fillcolor="#1A237E", fontcolor=white];
    ocular_tox [label="Ocular Toxicity\n(conjunctivitis, key AE)", fillcolor="#9575CD"];
    bleeding_tox [label="Bleeding Events\n(TF-related AE)", fillcolor="#9575CD"];
  }

  // ============================================================
  // Cluster 10: 임상 엔드포인트 / 바이오마커
  // ============================================================
  subgraph cluster_clinical {
    label="⑩ 임상 엔드포인트 / 바이오마커\n(Clinical Endpoints & Biomarkers)";
    style=filled; fillcolor="#F9FBE7"; color="#33691E";
    fontsize=9; fontcolor="#33691E";

    SCCAg_s    [label="SCC-Ag Serum\n(squamous cell carcinoma antigen)", fillcolor="#AED581"];
    HPV_DNA_s  [label="HPV DNA/Viral Load\n(serum/cervical swab)", fillcolor="#AED581"];
    TumorVol_ep [label="Tumor Volume/RECIST 1.1\n(CR/PR/SD/PD)", fillcolor="#8BC34A"];
    PFS_ep_c   [label="PFS\n(progression-free survival)", fillcolor="#8BC34A"];
    OS_ep_c    [label="OS\n(overall survival)", fillcolor="#33691E", fontcolor=white];
    ORR_ep_c   [label="ORR\n(CR+PR rate)", fillcolor="#7CB342"];
    pCR_ep     [label="Pathologic Complete Response\n(pCR)", fillcolor="#558B2F", fontcolor=white];
    DOR_ep_c   [label="DOR\n(duration of response)", fillcolor="#AED581"];
    QoL_ep_c   [label="QoL\n(EORTC QLQ-C30/CX24)", fillcolor="#DCEDC8"];
    tox_grade_c [label="Toxicity Grade\n(CTCAE v5.0)", fillcolor="#DCEDC8"];
    localrecur  [label="Local Recurrence\n(pelvic)", fillcolor="#AED581"];
    distantrecur [label="Distant Recurrence", fillcolor="#AED581"];
  }

  // ============================================================
  // Cluster 11: 선별검사/예방 (Screening & Prevention — 맥락)
  // ============================================================
  subgraph cluster_screen {
    label="⑪ 선별검사 / 예방 (맥락)\n(Screening & Prevention Context)";
    style=filled; fillcolor="#FFFDE7"; color="#F57F17";
    fontsize=9; fontcolor="#F57F17";

    HPV_vaccine [label="HPV Vaccination\n(9-valent, catch-up to age 45)", fillcolor="#FFF176"];
    Pap_test    [label="Pap Smear\n(cytology screening)", fillcolor="#FFEE58"];
    HPV_cotest  [label="HPV/Pap Co-testing\n(primary HPV screening)", fillcolor="#FFEE58"];
    colposcopy  [label="Colposcopy + Biopsy\n(diagnostic confirmation)", fillcolor="#FDD835"];
    LEEP_cone   [label="LEEP/Cone Excision\n(CIN2/3 treatment)", fillcolor="#F9A825", fontcolor=white];
    herd_immun  [label="Herd Immunity\n(population-level HPV reduction)", fillcolor="#FFF176"];
  }

  // ============================================================
  // EDGES — Cluster 1: HPV Oncogenesis
  // ============================================================
  HPV_virion  -> HPV_entry   [label="infect basal cells"];
  HPV_entry   -> HPV_episome [label="establish episome"];
  HPV_episome -> HPV_integ   [label="integrate (disrupt E2)"];
  HPV_integ   -> E2_prot     [label="disrupt repressor", arrowhead=tee, color="#C0392B"];
  E2_prot     -> E6_onco     [label="repress transcription", arrowhead=tee];
  E2_prot     -> E7_onco     [label="repress transcription", arrowhead=tee];
  E1_prot     -> HPV_episome [label="replicate viral DNA"];
  HPV_integ   -> E6_onco     [label="dysregulated overexpression"];
  HPV_integ   -> E7_onco     [label="dysregulated overexpression"];
  E6_onco     -> E6AP        [label="complex formation"];
  E6AP        -> p53_tp      [label="ubiquitinate"];
  p53_tp      -> Ubiquitin   [label="target for degradation"];
  Ubiquitin   -> p53_degrade [label="26S proteasome degrade"];
  p53_degrade -> apop_rate   [label="lose checkpoint", arrowhead=tee, color="#C0392B"];
  E7_onco     -> pRb_prot    [label="bind (LXCXE motif)"];
  pRb_prot    -> E7_pRb_bind [label="form complex"];
  E7_pRb_bind -> E2F_release [label="release from pRb"];
  E2F_release -> p16INK4a    [label="loss of feedback → accumulate"];
  E2F_release -> prolif_rate [label="drive S-phase entry"];
  E6_onco     -> telomerase  [label="activate hTERT promoter"];
  telomerase  -> telomer_c   [label="maintain telomeres"];
  E5_prot     -> NK_cc       [label="suppress NK recognition", arrowhead=tee, color="#C0392B"];
  viral_persist -> HPV_integ [label="enables integration"];
  viral_clear -> viral_persist [label="competing outcome", arrowhead=tee, style=dashed];
  HPV_load    -> viral_persist [label="high load favors"];
  HPV_episome -> CIN1        [label="productive infection"];
  CIN1        -> CIN2        [label="progression (~10-20%)"];
  CIN2        -> CIN3        [label="progression (~5%/yr)"];
  CIN3        -> micro_invasion [label="basement membrane breach"];
  micro_invasion -> tumor_size_c [label="develop invasive SCC"];
  p16INK4a    -> CIN2        [label="surrogate marker (+)"];

  // ============================================================
  // EDGES — Cluster 2: Cell Cycle / Apoptosis Evasion
  // ============================================================
  E2F_release -> CyclinE     [label="transcribe"];
  CyclinE     -> CDK2        [label="activate"];
  CDK2        -> E2F1_c      [label="phosphorylate, amplify"];
  CyclinD1    -> CDK46_c     [label="activate"];
  CDK46_c     -> pRb_prot    [label="hyperphosphorylate"];
  p21_c       -> CDK2        [label="inhibit", arrowhead=tee, color="#C0392B"];
  p27_c       -> CDK2        [label="inhibit", arrowhead=tee, color="#C0392B"];
  p53_degrade -> p21_c       [label="loss of induction", arrowhead=tee];
  PIK3CA_c    -> AKT_c       [label="activate (PI3K pathway)"];
  PTEN_c      -> AKT_c       [label="inhibit", arrowhead=tee, color="#C0392B"];
  AKT_c       -> mTOR_cc     [label="activate"];
  mTOR_cc     -> prolif_rate [label="↑ protein synthesis"];
  AKT_c       -> BCL2_c      [label="upregulate"];
  E6_onco     -> survivin_c  [label="upregulate (E6AP-independent)"];
  survivin_c  -> caspase_cc  [label="inhibit", arrowhead=tee, color="#C0392B"];
  BCL2_c      -> apop_rate   [label="inhibit", arrowhead=tee, color="#C0392B"];
  BAX_c       -> apop_rate   [label="promote"];
  caspase_cc  -> apop_rate   [label="execute"];
  E2F1_c      -> BAX_c       [label="pro-apoptotic feedback (partial)"];
  genome_instab -> prolif_rate [label="clonal selection"];
  E2F_release -> genome_instab [label="replication stress"];
  prolif_rate -> tumor_size_c [label="drive growth"];
  apop_rate   -> tumor_size_c [label="reduce", color="#27AE60"];

  // ============================================================
  // EDGES — Cluster 3: TME / Immune Evasion
  // ============================================================
  E7_onco     -> MHC1_c      [label="downregulate TAP1/MHC-I", arrowhead=tee, color="#C0392B"];
  MHC1_c      -> E7_MHC_dn   [label="mechanism"];
  E7_MHC_dn   -> CD8T_c      [label="reduce recognition", arrowhead=tee];
  IFNg_cc     -> PDL1_c      [label="upregulate (adaptive resistance)"];
  PDL1_c      -> PD1_c       [label="bind, suppress T cell", arrowhead=tee];
  PD1_c       -> CD8T_c      [label="exhaust", arrowhead=tee];
  T_exhaust_c -> CD8T_c      [label="impair function", arrowhead=tee];
  LAG3_c      -> CD8T_c      [label="checkpoint inhibit", arrowhead=tee];
  TIM3_c      -> CD8T_c      [label="exhaustion mark", arrowhead=tee];
  Treg_cc     -> CD8T_c      [label="suppress", arrowhead=tee];
  MDSC_c      -> CD8T_c      [label="suppress", arrowhead=tee];
  MDSC_c      -> NK_cc       [label="suppress", arrowhead=tee];
  TAM_c       -> IL10_cc     [label="secrete"];
  TAM_c       -> TGFb_cc     [label="secrete"];
  TGFb_cc     -> Treg_cc     [label="expand"];
  TGFb_cc     -> CD8T_c      [label="suppress", arrowhead=tee];
  IDO1_c      -> Kynuren_c   [label="catabolize tryptophan"];
  Kynuren_c   -> CD8T_c      [label="suppress", arrowhead=tee];
  Kynuren_c   -> Treg_cc     [label="expand"];
  IL6_cc      -> PDL1_c      [label="upregulate"];
  CD4T_c      -> CD8T_c      [label="help/prime"];
  TLS_c       -> CD8T_c      [label="local priming ↑"];
  CD8T_c      -> apop_rate   [label="cytotoxic (perforin/GzmB)"];
  NK_cc       -> apop_rate   [label="ADCC/NK kill"];

  // ============================================================
  // EDGES — Cluster 4: Angiogenesis
  // ============================================================
  hypoxia_c   -> HIF1a_c     [label="stabilize"];
  HIF1a_c     -> VEGFA_c     [label="transcribe"];
  VEGFA_c     -> VEGFR2_c    [label="bind, main signal"];
  VEGFA_c     -> VEGFR1_c    [label="bind (decoy)"];
  PlGF_c      -> VEGFR1_c    [label="compete with VEGF-A"];
  VEGFR2_c    -> endo_c      [label="proliferate/migrate"];
  endo_c      -> tumor_vasc_c [label="form vessels"];
  Ang2_c      -> tumor_vasc_c [label="destabilize"];
  pericyte_c  -> tumor_vasc_c [label="stabilize"];
  tumor_vasc_c -> hypoxia_c  [label="abnormal perfusion → hypoxia", style=dashed];
  Bevacizumab -> VEGFA_c     [label="neutralize", arrowhead=tee, color="#C0392B", style=dashed];
  tumor_vasc_c -> tumor_size_c [label="supply nutrients"];
  Bevacizumab -> GI_perf_c   [label="risk factor"];
  hypoxia_c   -> radiosensit [label="reduce (radioresistance)", arrowhead=tee, color="#C0392B"];

  // ============================================================
  // EDGES — Cluster 5: Invasion / Metastasis / Staging
  // ============================================================
  TGFb_cc     -> EMT_c       [label="induce"];
  EMT_c       -> Ecad_c      [label="downregulate", arrowhead=tee, color="#C0392B"];
  EMT_c       -> Ncad_c      [label="upregulate"];
  EMT_c       -> MMP2_c      [label="upregulate"];
  EMT_c       -> MMP9_c      [label="upregulate"];
  MMP2_c      -> parametrial_inv [label="degrade stroma"];
  MMP9_c      -> LVSI_c      [label="facilitate invasion"];
  tumor_size_c -> parametrial_inv [label="local extension"];
  tumor_size_c -> vaginal_ext [label="local extension"];
  parametrial_inv -> pelvic_wall [label="progression"];
  LVSI_c      -> pelvic_LN   [label="lymphatic spread"];
  pelvic_LN   -> paraaortic_LN [label="sequential spread"];
  paraaortic_LN -> distant_mets [label="systemic dissemination"];
  tumor_size_c -> hydronephrosis [label="ureteral compression"];
  hydronephrosis -> pelvic_wall [label="defines IIIB/IIIC"];
  vaginal_ext -> FIGO_stage_c [label="stage IIA"];
  parametrial_inv -> FIGO_stage_c [label="stage IIB"];
  pelvic_wall -> FIGO_stage_c [label="stage IIIB"];
  pelvic_LN   -> FIGO_stage_c [label="stage IIIC1"];
  paraaortic_LN -> FIGO_stage_c [label="stage IIIC2"];
  bladder_rectum -> FIGO_stage_c [label="stage IVA"];
  distant_mets -> FIGO_stage_c [label="stage IVB"];
  FIGO_stage_c -> TumorVol_ep [label="baseline staging"];

  // ============================================================
  // EDGES — Cluster 6: CCRT Platinum PK/PD
  // ============================================================
  Cisp_dose   -> CIS_C1      [label="IV weekly infusion"];
  CIS_C1      -> CIS_C2      [label="distribute (k12)"];
  CIS_C2      -> CIS_C1      [label="return (k21)"];
  CTR1_cc     -> CIS_C1      [label="intracellular uptake"];
  CIS_C1      -> Pt_DNA_c    [label="form intra-strand adducts"];
  Pt_DNA_c    -> chemo_apop_c [label="trigger apoptosis"];
  NER_c       -> Pt_DNA_c    [label="repair adducts", style=dashed, color="#27AE60"];
  GST_pi_c    -> Pt_DNA_c    [label="detoxify/prevent", arrowhead=tee];
  Cisp_dose   -> radiosensit [label="radiosensitize (DNA repair inhibition)"];
  radiosensit -> DNA_dsb_rt  [label="potentiate RT damage"];
  Carbo_dose_c -> CIS_C1     [label="alternative regimen"];
  Pacli_dose_c -> chemo_apop_c [label="microtubule stabilize, recurrent"];
  chemo_apop_c -> tumor_size_c [label="reduce tumor", color="#27AE60"];
  Cisp_dose   -> nephrotox_c [label="renal toxicity"];
  Cisp_dose   -> myelosupp_c [label="bone marrow suppression"];
  Pacli_dose_c -> neurotox_c [label="sensory neuropathy"];

  // ============================================================
  // EDGES — Cluster 7: Radiotherapy
  // ============================================================
  EBRT_dose   -> DNA_dsb_rt  [label="ionizing radiation damage"];
  brachy_dose -> DNA_dsb_rt  [label="dose-escalate tumor bed"];
  DNA_dsb_rt  -> LQ_model    [label="quantify (α, β)"];
  LQ_model    -> surviving_frac [label="SF=exp(-αD-βD²)"];
  SLD_repair  -> surviving_frac [label="repair between fx", style=dashed, color="#27AE60"];
  reoxygenation -> surviving_frac [label="improve radiosensitivity", style=dashed, color="#27AE60"];
  repopulation -> surviving_frac [label="counteract (prolonged tx)", arrowhead=tee, color="#C0392B"];
  EBRT_dose   -> EQD2_c      [label="convert fractionation"];
  brachy_dose -> EQD2_c      [label="convert fractionation"];
  EQD2_c      -> TCP_model   [label="predict local control"];
  surviving_frac -> TCP_model [label="tumor cell kill"];
  TCP_model   -> tumor_size_c [label="reduce tumor", color="#27AE60"];
  hypoxia_c   -> surviving_frac [label="increase SF (resistance)", arrowhead=tee, color="#C0392B"];
  EBRT_dose   -> OAR_tox     [label="pelvic organ dose"];
  brachy_dose -> OAR_tox     [label="high local dose"];
  pelvic_LN   -> EBRT_dose   [label="extend field (nodal)"];
  paraaortic_LN -> EBRT_dose [label="extended-field RT"];

  // ============================================================
  // EDGES — Cluster 8: Pembrolizumab ICI PK/PD
  // ============================================================
  Pembro_dose -> PEMBRO_C1   [label="IV infusion"];
  PEMBRO_C1   -> PEMBRO_C2   [label="distribute (k12)"];
  PEMBRO_C2   -> PEMBRO_C1   [label="return (k21)"];
  PEMBRO_C1   -> PD1_block   [label="bind PD-1, block"];
  PD1_block   -> PDL1_c      [label="prevent ligation", arrowhead=tee, color="#C0392B", style=dashed];
  PD1_block   -> Tcell_reinvig [label="restore effector function"];
  Tcell_reinvig -> CD8T_c    [label="reactivate"];
  Tcell_reinvig -> ICI_apop  [label="enhance tumor killing"];
  ICI_apop    -> tumor_size_c [label="reduce tumor", color="#27AE60"];
  CPS_score   -> PDL1_c      [label="quantify expression"];
  CPS_score   -> Pembro_dose [label="patient selection (CPS≥1)"];
  Pembro_dose -> irAE_c      [label="immune-related AE risk"];

  // ============================================================
  // EDGES — Cluster 9: Tisotumab Vedotin ADC PK/PD
  // ============================================================
  TF_antigen  -> TV_dose     [label="target expression"];
  TV_dose     -> TV_ADC_C1   [label="IV infusion"];
  TV_ADC_C1   -> TV_ADC_C2   [label="distribute (k12)"];
  TV_ADC_C2   -> TV_ADC_C1   [label="return (k21)"];
  TV_ADC_C1   -> ADC_internalize [label="bind TF, endocytose"];
  ADC_internalize -> MMAE_release [label="lysosomal cleavage"];
  MMAE_release -> microtub_disrupt [label="bind tubulin"];
  microtub_disrupt -> ADC_apop [label="G2/M arrest → apoptosis"];
  MMAE_release -> bystander_kill [label="diffuse to neighbor cells"];
  bystander_kill -> ADC_apop  [label="TF-low cell killing"];
  ADC_apop    -> tumor_size_c [label="reduce tumor", color="#27AE60"];
  TV_dose     -> ocular_tox   [label="conjunctivitis/keratitis AE"];
  TV_dose     -> bleeding_tox [label="TF pathway-related AE"];

  // ============================================================
  // EDGES — Cluster 10: Clinical Endpoints
  // ============================================================
  tumor_size_c -> TumorVol_ep [label="measure lesion size"];
  TumorVol_ep -> ORR_ep_c    [label="CR+PR"];
  TumorVol_ep -> PFS_ep_c    [label="time to progression"];
  PFS_ep_c    -> OS_ep_c     [label="surrogate/predict"];
  TumorVol_ep -> pCR_ep      [label="post-CCRT pathology"];
  pCR_ep      -> OS_ep_c     [label="favorable prognosis"];
  SCCAg_s     -> TumorVol_ep [label="parallel biomarker response"];
  HPV_DNA_s   -> TumorVol_ep [label="viral load decline correlate"];
  ORR_ep_c    -> DOR_ep_c    [label="responders tracked"];
  chemo_apop_c -> tox_grade_c [label="adverse events"];
  ICI_apop    -> tox_grade_c [label="irAE contribution"];
  ADC_apop    -> tox_grade_c [label="ocular/bleeding AE"];
  QoL_ep_c    -> OS_ep_c     [label="quality-adjusted"];
  PFS_ep_c    -> localrecur  [label="pelvic failure pattern"];
  PFS_ep_c    -> distantrecur [label="systemic failure pattern"];
  FIGO_stage_c -> OS_ep_c    [label="prognostic factor"];
  LVSI_c      -> localrecur  [label="risk factor"];

  // ============================================================
  // EDGES — Cluster 11: Screening & Prevention (context)
  // ============================================================
  HPV_vaccine -> HPV_virion  [label="prevent infection", arrowhead=tee, color="#C0392B", style=dashed];
  HPV_vaccine -> herd_immun  [label="population effect"];
  Pap_test    -> CIN1        [label="detect dysplasia"];
  HPV_cotest  -> HPV_DNA_s   [label="detect high-risk HPV"];
  HPV_cotest  -> colposcopy  [label="triage abnormal result"];
  colposcopy  -> CIN2        [label="biopsy confirm"];
  colposcopy  -> CIN3        [label="biopsy confirm"];
  LEEP_cone   -> CIN3        [label="excise lesion", arrowhead=tee, color="#C0392B", style=dashed];
  Pap_test    -> colposcopy  [label="abnormal cytology → refer"];

  // ============================================================
  // Cross-cluster connections
  // ============================================================
  HPV_load    -> HPV_DNA_s   [label="reflects serum/swab level"];
  E6_onco     -> p16INK4a    [label="indirect via pRb pathway"];
  hypoxia_c   -> EMT_c       [label="promote"];
  MMP9_c      -> tumor_vasc_c [label="remodel/angiogenesis"];
  CD8T_c      -> tumor_size_c [label="kill tumor", color="#27AE60"];
  VEGFA_c     -> tumor_vasc_c [label="drive formation"];
  IL6_cc      -> SCCAg_s     [label="upregulate acute phase-like"];
  TAM_c       -> tumor_vasc_c [label="pro-angiogenic support"];
  genome_instab -> Pt_DNA_c  [label="sensitize to platinum"];
  p53_degrade -> radiosensit [label="impaired DNA damage response"];
  E7_onco     -> DNA_dsb_rt  [label="replication stress ↑ radiosensitivity"];
  Treg_cc     -> Tcell_reinvig [label="limit ICI efficacy", arrowhead=tee, color="#C0392B"];
  PDL1_c      -> CPS_score   [label="quantified as"];
  distant_mets -> TV_dose    [label="recurrent/metastatic indication"];
  distant_mets -> Pembro_dose [label="recurrent/metastatic indication"];
  distant_mets -> Bevacizumab [label="recurrent/metastatic indication (GOG-240)"];
  viral_persist -> genome_instab [label="chronic E6/E7 drive"];
}
