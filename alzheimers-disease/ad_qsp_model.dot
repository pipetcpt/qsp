digraph AD_QSP_Model {
    rankdir=LR;
    fontsize=10;
    node [shape=box, style=filled, fontsize=9];
    edge [fontsize=7, arrowsize=0.7];

    // =========================================================
    // cluster_app: APP Processing
    // =========================================================
    subgraph cluster_app {
        label="APP Processing";
        style=filled;
        color=lightyellow;
        fillcolor="#FFFACD";
        fontsize=11;
        fontcolor=darkblue;

        APP           [label="APP\n(Amyloid Precursor Protein)", fillcolor=salmon];
        BACE1         [label="BACE1\n(β-secretase)", fillcolor="#FFD580"];
        gamma_secretase [label="γ-secretase\nComplex (PS1/PS2/NCT/APH1)", fillcolor="#FFD580"];
        sAPPalpha     [label="sAPPα\n(neuroprotective fragment)", fillcolor=lightgreen];
        sAPPbeta      [label="sAPPβ\n(amyloidogenic fragment)", fillcolor=salmon];
        CTF99         [label="CTF99 / C99\n(β-CTF)", fillcolor=salmon];
        CTF83         [label="CTF83 / C83\n(α-CTF)", fillcolor=lightgreen];
        AICD          [label="AICD\n(APP intracellular domain)", fillcolor=lightyellow];
        Abeta42       [label="Aβ42\n(amyloidogenic peptide)", fillcolor=salmon];
        Abeta40       [label="Aβ40\n(major secreted isoform)", fillcolor=salmon];
        alpha_secretase [label="α-secretase\n(non-amyloidogenic)", fillcolor="#FFD580"];
        ADAM10        [label="ADAM10\n(disintegrin metalloprotease)", fillcolor="#FFD580"];
        ADAM17        [label="ADAM17 / TACE\n(TNF-α converting enzyme)", fillcolor="#FFD580"];
    }

    // =========================================================
    // cluster_aggregation: Amyloid Aggregation & Clearance
    // =========================================================
    subgraph cluster_aggregation {
        label="Amyloid Aggregation & Clearance";
        style=filled;
        color=orange;
        fillcolor="#FFF3E0";
        fontsize=11;
        fontcolor=darkred;

        Abeta42_mono  [label="Aβ42 Monomer", fillcolor=salmon];
        Abeta42_oligo [label="Aβ42 Oligomer\n(toxic species)", fillcolor=salmon, penwidth=2];
        Abeta42_proto [label="Aβ42 Protofibril", fillcolor=salmon];
        Abeta42_fibril [label="Aβ42 Fibril", fillcolor=salmon];
        SenilePlaque  [label="Senile Plaque\n(amyloid plaque)", fillcolor=salmon, penwidth=2];
        RAGE          [label="RAGE\n(Aβ import receptor)", fillcolor=lightcyan];
        LRP1          [label="LRP1\n(Aβ clearance receptor)", fillcolor=lightcyan];
        IDE           [label="IDE\n(insulin-degrading enzyme)", fillcolor="#FFD580"];
        NEP           [label="NEP\n(neprilysin)", fillcolor="#FFD580"];
        ApoE4         [label="ApoE4\n(APOE ε4 protein)", fillcolor=lavender];
        Clusterin     [label="Clusterin / ApoJ\n(chaperone)", fillcolor=lightgreen];
        PICALM        [label="PICALM\n(clathrin assembly)", fillcolor=lightcyan];
        BIN1_prot     [label="BIN1\n(bridging integrator 1)", fillcolor=lightcyan];
    }

    // =========================================================
    // cluster_tau: Tau Pathology
    // =========================================================
    subgraph cluster_tau {
        label="Tau Pathology";
        style=filled;
        color=purple;
        fillcolor="#F3E5F5";
        fontsize=11;
        fontcolor=darkviolet;

        Tau_soluble   [label="Tau (soluble)\n(microtubule binding)", fillcolor=lightyellow];
        pTau_T181     [label="pTau-T181\n(CSF biomarker)", fillcolor=salmon];
        pTau_T231     [label="pTau-T231\n(early AD marker)", fillcolor=salmon];
        pTau_S202     [label="pTau-S202\n(AT8 epitope)", fillcolor=salmon];
        Tau_oligo     [label="Tau Oligomer\n(spreading species)", fillcolor=salmon];
        NFT           [label="NFT\n(neurofibrillary tangle)", fillcolor=salmon, penwidth=2];
        CDK5          [label="CDK5\n(cyclin-dependent kinase 5)", fillcolor="#FFD580"];
        GSK3beta      [label="GSK3β\n(glycogen synthase kinase 3β)", fillcolor="#FFD580"];
        PP2A          [label="PP2A\n(protein phosphatase 2A)", fillcolor=lightgreen];
        DYRK1A        [label="DYRK1A\n(dual specificity kinase)", fillcolor="#FFD580"];
        Fyn           [label="Fyn\n(tyrosine kinase)", fillcolor="#FFD580"];
        p25           [label="p25\n(CDK5 hyperactivator)", fillcolor=salmon];
        p35           [label="p35\n(CDK5 activator)", fillcolor=lightyellow];
        MARK4         [label="MARK4\n(microtubule affinity kinase)", fillcolor="#FFD580"];
        CaMKII        [label="CaMKII\n(Ca2+/calmodulin kinase II)", fillcolor="#FFD580"];
    }

    // =========================================================
    // cluster_neuroinflammation: Neuroinflammation
    // =========================================================
    subgraph cluster_neuroinflammation {
        label="Neuroinflammation";
        style=filled;
        color=red;
        fillcolor="#FFEBEE";
        fontsize=11;
        fontcolor=darkred;

        Microglia_resting  [label="Microglia\n(resting/homeostatic)", fillcolor=lightgreen];
        Microglia_M1       [label="Microglia M1\n(pro-inflammatory)", fillcolor=salmon, penwidth=2];
        Microglia_DAM      [label="Microglia DAM\n(disease-associated)", fillcolor=lightyellow];
        TREM2              [label="TREM2\n(microglial activating receptor)", fillcolor=lightcyan];
        TNFalpha           [label="TNFα\n(pro-inflammatory cytokine)", fillcolor=salmon];
        IL1beta            [label="IL-1β\n(pro-inflammatory cytokine)", fillcolor=salmon];
        IL6                [label="IL-6\n(pleiotropic cytokine)", fillcolor=salmon];
        TGFbeta            [label="TGFβ\n(anti-inflammatory cytokine)", fillcolor=lightgreen];
        Complement_C1q     [label="Complement C1q\n(synapse tagging)", fillcolor=salmon];
        Complement_C3      [label="Complement C3\n(opsonin)", fillcolor=salmon];
        Astrocyte_reactive [label="Reactive Astrocyte\n(A1 neurotoxic)", fillcolor=salmon];
        NLRP3              [label="NLRP3\n(inflammasome)", fillcolor=salmon];
        Caspase1           [label="Caspase-1\n(IL-1β processor)", fillcolor="#FFD580"];
        NFkB               [label="NF-κB\n(transcription factor)", fillcolor="#FFD580"];
        STAT3              [label="STAT3\n(JAK-STAT signaling)", fillcolor="#FFD580"];
        IFNgamma           [label="IFN-γ\n(type II interferon)", fillcolor=salmon];
        IL10               [label="IL-10\n(anti-inflammatory)", fillcolor=lightgreen];
        IL4                [label="IL-4\n(Th2 cytokine)", fillcolor=lightgreen];
        Neurodegeneration  [label="Neurodegeneration\n(neuronal loss)", fillcolor=salmon, penwidth=2];
        Glutamate          [label="Glutamate\n(excitatory neurotransmitter)", fillcolor=lightyellow];
    }

    // =========================================================
    // cluster_cholinergic: Cholinergic System
    // =========================================================
    subgraph cluster_cholinergic {
        label="Cholinergic System";
        style=filled;
        color=green;
        fillcolor="#E8F5E9";
        fontsize=11;
        fontcolor=darkgreen;

        ChAT             [label="ChAT\n(choline acetyltransferase)", fillcolor="#FFD580"];
        ACh              [label="ACh\n(acetylcholine)", fillcolor=lightgreen];
        AChE             [label="AChE\n(acetylcholinesterase)", fillcolor="#FFD580"];
        BuChE            [label="BuChE\n(butyrylcholinesterase)", fillcolor="#FFD580"];
        nAChR_alpha7     [label="nAChR α7\n(nicotinic receptor)", fillcolor=lightcyan];
        nAChR_alpha4beta2 [label="nAChR α4β2\n(nicotinic receptor)", fillcolor=lightcyan];
        mAChR_M1         [label="mAChR M1\n(muscarinic receptor)", fillcolor=lightcyan];
        mAChR_M2         [label="mAChR M2\n(muscarinic autoreceptor)", fillcolor=lightcyan];
        Choline          [label="Choline\n(precursor)", fillcolor=lightyellow];
        Acetyl_CoA       [label="Acetyl-CoA\n(mitochondrial metabolite)", fillcolor=lightyellow];
        VAChT            [label="VAChT\n(vesicular ACh transporter)", fillcolor=lightcyan];
        ChT1             [label="ChT1\n(high-affinity choline transporter)", fillcolor=lightcyan];
        Vesamicol        [label="Vesamicol\n(VAChT inhibitor)", fillcolor=lightblue];
    }

    // =========================================================
    // cluster_synaptic: Synaptic Function & Plasticity
    // =========================================================
    subgraph cluster_synaptic {
        label="Synaptic Function & Plasticity";
        style=filled;
        color=blue;
        fillcolor="#E3F2FD";
        fontsize=11;
        fontcolor=darkblue;

        NMDAR          [label="NMDAR\n(NMDA receptor)", fillcolor=lightcyan];
        AMPAR          [label="AMPAR\n(AMPA receptor)", fillcolor=lightcyan];
        LTP            [label="LTP\n(long-term potentiation)", fillcolor=lightgreen];
        LTD            [label="LTD\n(long-term depression)", fillcolor=salmon];
        Dendritic_spines [label="Dendritic Spines\n(structural plasticity)", fillcolor=lightyellow];
        Synaptic_vesicles [label="Synaptic Vesicles\n(neurotransmitter storage)", fillcolor=lightyellow];
        BDNF           [label="BDNF\n(neurotrophic factor)", fillcolor=lightgreen];
        TrkB           [label="TrkB\n(BDNF receptor)", fillcolor=lightcyan];
        PSD95          [label="PSD-95\n(postsynaptic scaffold)", fillcolor=lightyellow];
        Arc            [label="Arc / Arg3.1\n(immediate early gene)", fillcolor=lightyellow];
        CaMKII_syn     [label="CaMKII (synaptic)\n(synaptic plasticity kinase)", fillcolor="#FFD580"];
        Cofilin        [label="Cofilin\n(actin dynamics)", fillcolor=lightyellow];
        RhoA           [label="RhoA\n(Rho GTPase)", fillcolor=lightyellow];
        Rac1           [label="Rac1\n(Rho GTPase)", fillcolor=lightgreen];
        mTOR           [label="mTOR\n(protein synthesis/autophagy)", fillcolor=lightyellow];
    }

    // =========================================================
    // cluster_pk: Drug Pharmacokinetics
    // =========================================================
    subgraph cluster_pk {
        label="Drug Pharmacokinetics";
        style=filled;
        color=navy;
        fillcolor="#E8EAF6";
        fontsize=11;
        fontcolor=navy;

        Donepezil_gut     [label="Donepezil (gut)\n(AChEI, oral)", fillcolor=lightblue];
        Donepezil_plasma  [label="Donepezil (plasma)\nt½=70h, Vd=12L/kg", fillcolor=lightblue];
        Donepezil_brain   [label="Donepezil (brain)\nCNS active form", fillcolor=lightblue];
        Memantine_plasma  [label="Memantine (plasma)\nt½=60-80h, NMDAR antagonist", fillcolor=lightblue];
        Memantine_brain   [label="Memantine (brain)\nCNS active form", fillcolor=lightblue];
        Lecanemab_plasma  [label="Lecanemab (plasma)\nAnti-Aβ protofibril mAb", fillcolor=lightblue];
        Lecanemab_CNS     [label="Lecanemab (CNS)\nApproved 2023 (Leqembi)", fillcolor=lightblue];
        Donanemab_plasma  [label="Donanemab (plasma)\nAnti-N3pE Aβ mAb", fillcolor=lightblue];
        Donanemab_CNS     [label="Donanemab (CNS)\nApproved 2024 (Kisunla)", fillcolor=lightblue];
        Aducanumab_plasma [label="Aducanumab (plasma)\nAnti-aggregated Aβ mAb", fillcolor=lightblue];
        Aducanumab_CNS    [label="Aducanumab (CNS)\nApproved 2021 (Aduhelm)", fillcolor=lightblue];
    }

    // =========================================================
    // cluster_vascular: Vascular & BBB
    // =========================================================
    subgraph cluster_vascular {
        label="Vascular & Blood-Brain Barrier";
        style=filled;
        color=teal;
        fillcolor="#E0F2F1";
        fontsize=11;
        fontcolor=darkcyan;

        BBB_integrity   [label="BBB Integrity\n(blood-brain barrier)", fillcolor=lightyellow];
        CAA             [label="CAA\n(cerebral amyloid angiopathy)", fillcolor=salmon];
        CBF             [label="CBF\n(cerebral blood flow)", fillcolor=lightyellow];
        Glucose_metabolism [label="Glucose Metabolism\n(FDG-PET surrogate)", fillcolor=lightyellow];
        VEGF            [label="VEGF\n(angiogenic factor)", fillcolor=lightgreen];
        MMP9            [label="MMP-9\n(matrix metalloprotease 9)", fillcolor="#FFD580"];
        Pericyte        [label="Pericyte\n(BBB maintenance)", fillcolor=lightgreen];
        TightJunction   [label="Tight Junctions\n(claudin/occludin/ZO-1)", fillcolor=lightgreen];
        Aquaporin4      [label="Aquaporin-4\n(astrocyte water channel)", fillcolor=lightcyan];
        Glymphatic_flow [label="Glymphatic Flow\n(waste clearance)", fillcolor=lightgreen];
        P_glycoprotein  [label="P-glycoprotein / ABCB1\n(efflux transporter)", fillcolor=lightcyan];
    }

    // =========================================================
    // cluster_genetic: Genetic Risk Factors
    // =========================================================
    subgraph cluster_genetic {
        label="Genetic Risk Factors";
        style=filled;
        color=purple;
        fillcolor="#EDE7F6";
        fontsize=11;
        fontcolor=indigo;

        APOE4_gene    [label="APOE ε4 allele\n(strongest genetic risk)", fillcolor=lavender];
        PSEN1_mut     [label="PSEN1 mutation\n(FAD, early-onset)", fillcolor=lavender];
        PSEN2_mut     [label="PSEN2 mutation\n(FAD, early-onset)", fillcolor=lavender];
        APP_mut       [label="APP mutation\n(Swedish/Arctic/Indiana)", fillcolor=lavender];
        TREM2_variant [label="TREM2 variant\n(R47H, microglial risk)", fillcolor=lavender];
        CLU_gene      [label="CLU (Clusterin gene)\n(GWAS locus)", fillcolor=lavender];
        CR1_gene      [label="CR1 gene\n(complement receptor 1)", fillcolor=lavender];
        BIN1_gene     [label="BIN1 gene\n(GWAS top locus)", fillcolor=lavender];
        ABCA7         [label="ABCA7\n(lipid transporter gene)", fillcolor=lavender];
        SORL1         [label="SORL1\n(APP trafficking gene)", fillcolor=lavender];
        PITRM1        [label="PITRM1\n(mitochondrial protease gene)", fillcolor=lavender];
    }

    // =========================================================
    // cluster_endpoints: Clinical Endpoints & Biomarkers
    // =========================================================
    subgraph cluster_endpoints {
        label="Clinical Endpoints & Biomarkers";
        style=filled;
        color=goldenrod;
        fillcolor="#FFFDE7";
        fontsize=11;
        fontcolor=darkorange;

        MMSE           [label="MMSE\n(Mini-Mental State Exam)", fillcolor=lightyellow];
        ADAS_Cog13     [label="ADAS-Cog13\n(primary efficacy endpoint)", fillcolor=lightyellow];
        CDR_SB         [label="CDR-SB\n(Clinical Dementia Rating)", fillcolor=lightyellow];
        CSF_Abeta42    [label="CSF Aβ42\n(early AD biomarker ↓)", fillcolor=lightyellow];
        CSF_pTau181    [label="CSF pTau-181\n(AD biomarker ↑)", fillcolor=lightyellow];
        CSF_NfL        [label="CSF NfL\n(neurodegeneration marker)", fillcolor=lightyellow];
        Amyloid_PET    [label="Amyloid PET\n(florbetapir/flutemetamol)", fillcolor=lightyellow];
        Tau_PET        [label="Tau PET\n(flortaucipir/MK-6240)", fillcolor=lightyellow];
        MRI_hippocampus [label="MRI Hippocampal Volume\n(atrophy marker)", fillcolor=lightyellow];
        Cognitive_decline [label="Cognitive Decline\n(primary outcome)", fillcolor=salmon, penwidth=2];
        ADL_score      [label="ADL Score\n(activities of daily living)", fillcolor=lightyellow];
        NPI_score      [label="NPI Score\n(neuropsychiatric inventory)", fillcolor=lightyellow];
    }

    // =========================================================
    // DIRECTED EDGES — cluster_app
    // =========================================================
    APP -> BACE1 [label="cleavage site"];
    BACE1 -> sAPPbeta [label="cleaves"];
    BACE1 -> CTF99 [label="generates"];
    gamma_secretase -> CTF99 [label="cleaves"];
    gamma_secretase -> Abeta42 [label="releases"];
    gamma_secretase -> Abeta40 [label="releases (major)"];
    gamma_secretase -> AICD [label="releases"];
    APP -> alpha_secretase [label="non-amyloidogenic"];
    alpha_secretase -> sAPPalpha [label="releases"];
    alpha_secretase -> CTF83 [label="generates"];
    ADAM10 -> alpha_secretase [label="is"];
    ADAM17 -> alpha_secretase [label="partial activity"];

    // =========================================================
    // DIRECTED EDGES — cluster_aggregation
    // =========================================================
    Abeta42 -> Abeta42_mono [label="monomers"];
    Abeta42_mono -> Abeta42_oligo [label="oligomerization"];
    Abeta42_oligo -> Abeta42_proto [label="elongation"];
    Abeta42_proto -> Abeta42_fibril [label="fibrillation"];
    Abeta42_fibril -> SenilePlaque [label="deposits"];
    Abeta42_oligo -> NMDAR [label="blocks (toxic)"];
    Abeta42_oligo -> Tau_soluble [label="induces phosphorylation"];
    LRP1 -> Abeta42 [label="clears (transport)"];
    RAGE -> Abeta42 [label="imports CNS"];
    IDE -> Abeta42_mono [label="degrades"];
    NEP -> Abeta42_mono [label="degrades"];
    ApoE4 -> Abeta42_fibril [label="promotes aggregation"];
    ApoE4 -> LRP1 [label="inhibits clearance"];
    APOE4_gene -> ApoE4 [label="encodes"];
    PICALM -> LRP1 [label="assists endocytosis"];
    BIN1_prot -> Tau_oligo [label="facilitates spreading"];
    Clusterin -> Abeta42_fibril [label="inhibits aggregation"];
    CLU_gene -> Clusterin [label="encodes"];

    // =========================================================
    // DIRECTED EDGES — cluster_tau
    // =========================================================
    Tau_soluble -> CDK5 [label="substrate"];
    Tau_soluble -> GSK3beta [label="substrate"];
    CDK5 -> pTau_T181 [label="phosphorylates"];
    CDK5 -> pTau_S202 [label="phosphorylates"];
    GSK3beta -> pTau_T231 [label="phosphorylates"];
    GSK3beta -> pTau_T181 [label="phosphorylates"];
    PP2A -> pTau_T181 [label="dephosphorylates"];
    DYRK1A -> pTau_T181 [label="phosphorylates"];
    Fyn -> Tau_soluble [label="phosphorylates Y18"];
    p25 -> CDK5 [label="hyperactivates"];
    p35 -> CDK5 [label="activates normally"];
    Abeta42_oligo -> p25 [label="induces calpain cleavage"];
    pTau_T181 -> Tau_oligo [label="aggregates"];
    Tau_oligo -> NFT [label="forms"];
    NFT -> Cognitive_decline [label="correlates strongly"];
    MARK4 -> Tau_soluble [label="phosphorylates KXGS"];
    CaMKII -> pTau_S202 [label="phosphorylates"];

    // =========================================================
    // DIRECTED EDGES — cluster_neuroinflammation
    // =========================================================
    Microglia_resting -> Microglia_M1 [label="pro-inflammatory activation"];
    Microglia_resting -> Microglia_DAM [label="DAM state"];
    Abeta42_oligo -> Microglia_M1 [label="activates"];
    SenilePlaque -> Complement_C1q [label="activates"];
    Complement_C1q -> Complement_C3 [label="cleaves"];
    Complement_C3 -> Microglia_M1 [label="opsonizes"];
    Microglia_M1 -> TNFalpha [label="secretes"];
    Microglia_M1 -> IL1beta [label="secretes"];
    Microglia_M1 -> IL6 [label="secretes"];
    NLRP3 -> Caspase1 [label="activates"];
    Caspase1 -> IL1beta [label="matures"];
    Abeta42_oligo -> NLRP3 [label="activates"];
    TNFalpha -> NFkB [label="activates"];
    NFkB -> IL1beta [label="transcribes"];
    NFkB -> BACE1 [label="upregulates"];
    IL1beta -> GSK3beta [label="activates via IRS-1"];
    TREM2 -> Microglia_DAM [label="activates"];
    TREM2_variant -> TREM2 [label="loss of function"];
    Microglia_DAM -> SenilePlaque [label="phagocytoses"];
    TGFbeta -> Microglia_M1 [label="inhibits"];
    TGFbeta -> Astrocyte_reactive [label="modulates"];
    Astrocyte_reactive -> Glutamate [label="excess release"];
    IL10 -> Microglia_M1 [label="inhibits"];
    IL4 -> Microglia_M1 [label="suppresses (M2 skew)"];
    IFNgamma -> STAT3 [label="activates"];
    STAT3 -> IL6 [label="transcribes"];
    Microglia_M1 -> Neurodegeneration [label="contributes"];
    NFT -> Neurodegeneration [label="causes"];
    Neurodegeneration -> CSF_NfL [label="biomarker"];

    // =========================================================
    // DIRECTED EDGES — cluster_cholinergic
    // =========================================================
    ChAT -> ACh [label="synthesizes"];
    Acetyl_CoA -> ChAT [label="substrate"];
    Choline -> ChAT [label="substrate"];
    ACh -> AChE [label="hydrolyzed by"];
    ACh -> BuChE [label="hydrolyzed by"];
    ACh -> nAChR_alpha7 [label="binds"];
    ACh -> nAChR_alpha4beta2 [label="binds"];
    ACh -> mAChR_M1 [label="binds"];
    ACh -> mAChR_M2 [label="binds (autoreceptor)"];
    nAChR_alpha7 -> BDNF [label="upregulates"];
    mAChR_M1 -> LTP [label="facilitates"];
    mAChR_M2 -> ACh [label="inhibits release"];
    Abeta42_oligo -> nAChR_alpha7 [label="high affinity binding"];
    VAChT -> Synaptic_vesicles [label="loads ACh"];
    ChT1 -> Choline [label="reuptake"];
    AChE -> Choline [label="produces"];
    Vesamicol -> VAChT [label="blocks"];

    // =========================================================
    // DIRECTED EDGES — cluster_synaptic
    // =========================================================
    NMDAR -> LTP [label="enables"];
    NMDAR -> LTD [label="enables"];
    AMPAR -> LTP [label="mediates expression"];
    BDNF -> TrkB [label="binds"];
    TrkB -> LTP [label="facilitates"];
    TrkB -> Dendritic_spines [label="maintains"];
    TrkB -> mTOR [label="activates"];
    LTP -> Dendritic_spines [label="increases"];
    LTD -> Dendritic_spines [label="decreases"];
    Abeta42_oligo -> Dendritic_spines [label="removes (toxic)"];
    PSD95 -> NMDAR [label="scaffolds"];
    Abeta42_oligo -> PSD95 [label="reduces"];
    Cofilin -> Dendritic_spines [label="remodels"];
    RhoA -> Cofilin [label="regulates"];
    Rac1 -> Dendritic_spines [label="promotes"];
    CaMKII_syn -> LTP [label="required for induction"];
    Arc -> AMPAR [label="internalizes"];
    mTOR -> Arc [label="regulates translation"];
    Glutamate -> NMDAR [label="activates (excess=excitotoxic)"];
    Glutamate -> AMPAR [label="activates"];
    Dendritic_spines -> Cognitive_decline [label="determines"];

    // =========================================================
    // DIRECTED EDGES — cluster_pk
    // =========================================================
    Donepezil_gut -> Donepezil_plasma [label="absorption (F=100%)"];
    Donepezil_plasma -> Donepezil_brain [label="BBB crossing (Kp=0.6)"];
    Donepezil_brain -> AChE [label="inhibits (IC50=6nM)"];
    Donepezil_brain -> BuChE [label="inhibits (IC50=7300nM)"];
    Memantine_plasma -> Memantine_brain [label="BBB crossing (Kp=1.0)"];
    Memantine_brain -> NMDAR [label="blocks (IC50=1uM)"];
    Lecanemab_plasma -> Lecanemab_CNS [label="transcytosis (Kp~0.001)"];
    Lecanemab_CNS -> Abeta42_proto [label="binds (high affinity)"];
    Lecanemab_CNS -> Abeta42_oligo [label="binds"];
    Donanemab_plasma -> Donanemab_CNS [label="transcytosis"];
    Donanemab_CNS -> SenilePlaque [label="binds N3pE Abeta"];
    Aducanumab_plasma -> Aducanumab_CNS [label="transcytosis"];
    Aducanumab_CNS -> Abeta42_fibril [label="binds aggregated"];

    // =========================================================
    // DIRECTED EDGES — cluster_vascular
    // =========================================================
    BBB_integrity -> Lecanemab_CNS [label="controls access"];
    BBB_integrity -> Memantine_brain [label="controls access"];
    CAA -> BBB_integrity [label="impairs"];
    Abeta42_fibril -> CAA [label="deposits in vessel wall"];
    MMP9 -> BBB_integrity [label="degrades TJ"];
    TightJunction -> BBB_integrity [label="maintains"];
    Pericyte -> BBB_integrity [label="maintains"];
    CBF -> Glymphatic_flow [label="drives"];
    Glymphatic_flow -> Abeta42_mono [label="clears"];
    Glymphatic_flow -> pTau_T181 [label="clears"];
    VEGF -> CBF [label="promotes angiogenesis"];
    Glucose_metabolism -> Acetyl_CoA [label="produces"];
    Glucose_metabolism -> mTOR [label="links to"];
    P_glycoprotein -> Abeta42_mono [label="efflux transport"];
    Aquaporin4 -> Glymphatic_flow [label="enables"];
    CAA -> Microglia_M1 [label="activates perivascular"];

    // =========================================================
    // DIRECTED EDGES — cluster_genetic
    // =========================================================
    APOE4_gene -> ApoE4 [label="encodes risk allele"];
    PSEN1_mut -> gamma_secretase [label="increases Abeta42/40 ratio"];
    PSEN2_mut -> gamma_secretase [label="increases Abeta42/40 ratio"];
    APP_mut -> BACE1 [label="increases cleavage"];
    TREM2_variant -> TREM2 [label="loss of function"];
    CLU_gene -> Clusterin [label="encodes"];
    CR1_gene -> Complement_C1q [label="modulates"];
    BIN1_gene -> BIN1_prot [label="encodes"];
    ABCA7 -> ApoE4 [label="lipid transport interaction"];
