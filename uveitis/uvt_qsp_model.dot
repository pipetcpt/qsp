digraph UveitisQSP {
  graph [
    label="Uveitis QSP Mechanistic Map\nAutoimmune/Infectious Ocular Inflammation\nPK/PD: Corticosteroids · DMARDs · Anti-TNF · Anti-VEGF · Anti-IL-6"
    labelloc=t fontsize=22 fontname="Helvetica-Bold"
    bgcolor="#F8F9FA" rankdir=LR
    splines=ortho nodesep=0.4 ranksep=1.0
    compound=true
  ]
  node [fontname="Helvetica" fontsize=10 style="filled,rounded" shape=box]
  edge [fontname="Helvetica" fontsize=8 color="#444444"]

  /* ─────────────────────────────────────────
     CLUSTER 0: Ocular Anatomy & Immune Privilege
  ───────────────────────────────────────── */
  subgraph cluster_anatomy {
    label="Ocular Anatomy & Immune Privilege"
    style=filled fillcolor="#EBF5FB" color="#2E86C1" penwidth=2
    fontname="Helvetica-Bold" fontsize=13 fontcolor="#2E86C1"

    ant_chamber [label="Anterior Chamber\n(Aqueous Humor)" fillcolor="#AED6F1"]
    post_segment [label="Posterior Segment\n(Vitreous / Retina)" fillcolor="#AED6F1"]
    uveal_tract [label="Uveal Tract\n(Iris/Ciliary/Choroid)" fillcolor="#5DADE2"]
    retina [label="Retina\n(Photoreceptors/RPE)" fillcolor="#85C1E9"]
    cornea [label="Cornea" fillcolor="#D6EAF8"]
    lens [label="Lens" fillcolor="#D6EAF8"]
    vitreous [label="Vitreous Body" fillcolor="#D6EAF8"]
    macula [label="Macula\n(Central Vision)" fillcolor="#1A5276" fontcolor=white]
    optic_nerve [label="Optic Nerve" fillcolor="#D6EAF8"]
    ip_loss [label="Immune Privilege\nLoss" fillcolor="#E74C3C" fontcolor=white]
    fasc_ant [label="FasL+ /\nIDO+ Expression" fillcolor="#D6EAF8"]
    tgfb2_aq [label="TGF-β2\n(Aqueous)" fillcolor="#D6EAF8"]
    acaid [label="ACAID\n(Anterior Chamber\nAssociated Immune Dev.)" fillcolor="#AED6F1"]

    uveal_tract -> ant_chamber [label="drainage"]
    ant_chamber -> post_segment [label="diffusion"]
    post_segment -> retina [label="borders"]
    retina -> macula [label="central zone"]
    retina -> optic_nerve [label="ganglion axons"]
    fasc_ant -> ip_loss [label="disrupted by inflammation" color="#E74C3C"]
    tgfb2_aq -> ip_loss [label="reduced" color="#E74C3C"]
    acaid -> ip_loss [label="impaired" color="#E74C3C"]
  }

  /* ─────────────────────────────────────────
     CLUSTER 1: Triggering Mechanisms
  ───────────────────────────────────────── */
  subgraph cluster_trigger {
    label="Triggering Mechanisms"
    style=filled fillcolor="#FEF9E7" color="#D4AC0D" penwidth=2
    fontname="Helvetica-Bold" fontsize=13 fontcolor="#D4AC0D"

    ocular_antigen [label="Ocular Autoantigens\n(IRBP, S-Ag, Recoverin)" fillcolor="#F9E79F"]
    molecular_mimicry [label="Molecular Mimicry\n(HLA-B27, HLA-A29)" fillcolor="#F9E79F"]
    infect_trigger [label="Infectious Triggers\n(HSV, CMV, Toxoplasma)" fillcolor="#F0B27A"]
    trauma [label="Trauma / Surgery" fillcolor="#F9E79F"]
    systemic_disease [label="Systemic Disease\n(AS, BD, SLE, JIA)" fillcolor="#F9E79F"]
    birdshot [label="Birdshot Chorioretinopathy\n(HLA-A29>95%)" fillcolor="#F9E79F"]
    vkh [label="VKH Syndrome\n(Anti-melanocyte)" fillcolor="#F9E79F"]
    fuch_het [label="Fuchs Heterochromic\nIridocyclitis" fillcolor="#F9E79F"]
    hlab27 [label="HLA-B27+\n(AS·ReA·PsA·IBD)" fillcolor="#FAD7A0"]
    antigen_present [label="Antigen\nPresentation" fillcolor="#D4AC0D" fontcolor=white]

    ocular_antigen -> antigen_present
    molecular_mimicry -> antigen_present
    infect_trigger -> antigen_present
    trauma -> antigen_present
    systemic_disease -> antigen_present
    hlab27 -> molecular_mimicry
    birdshot -> antigen_present
    vkh -> antigen_present
    fuch_het -> antigen_present
  }

  /* ─────────────────────────────────────────
     CLUSTER 2: Innate Immune Activation
  ───────────────────────────────────────── */
  subgraph cluster_innate {
    label="Innate Immune Activation"
    style=filled fillcolor="#FDEDEC" color="#C0392B" penwidth=2
    fontname="Helvetica-Bold" fontsize=13 fontcolor="#C0392B"

    dc [label="Dendritic Cells\n(mDC / pDC)" fillcolor="#F5B7B1"]
    macro [label="Macrophages\nM1/M2" fillcolor="#F5B7B1"]
    neutrophil [label="Neutrophils" fillcolor="#FADBD8"]
    nk_cell [label="NK Cells" fillcolor="#FADBD8"]
    mast_cell [label="Mast Cells" fillcolor="#FADBD8"]
    complement [label="Complement System\n(C3a, C5a)" fillcolor="#EC7063"]
    nlrp3 [label="NLRP3 Inflammasome" fillcolor="#E74C3C" fontcolor=white]
    il1b_innate [label="IL-1β\n(Inflammasome)" fillcolor="#F5B7B1"]
    il18 [label="IL-18" fillcolor="#FADBD8"]
    tnf_innate [label="TNF-α\n(Early)" fillcolor="#F1948A"]
    il6_innate [label="IL-6\n(Acute)" fillcolor="#F1948A"]
    ros [label="ROS / Oxidative\nStress" fillcolor="#FADBD8"]
    tlr_pathway [label="TLR Signaling\n(TLR2/4/9)" fillcolor="#F5B7B1"]
    nfkb_innate [label="NF-κB\n(Innate)" fillcolor="#E74C3C" fontcolor=white]

    antigen_present -> dc [label="MHC-II" lhead=cluster_innate]
    dc -> macro [label="activation"]
    tlr_pathway -> nfkb_innate
    nfkb_innate -> tnf_innate
    nfkb_innate -> il6_innate
    nlrp3 -> il1b_innate
    nlrp3 -> il18
    macro -> ros
    macro -> tnf_innate
    macro -> il6_innate
    complement -> neutrophil [label="C5a recruit"]
    mast_cell -> tnf_innate [label="degranulation"]
  }

  /* ─────────────────────────────────────────
     CLUSTER 3: Adaptive Immune Response (T cells)
  ───────────────────────────────────────── */
  subgraph cluster_tcell {
    label="T Cell Adaptive Immunity"
    style=filled fillcolor="#EBF5FB" color="#1A5276" penwidth=2
    fontname="Helvetica-Bold" fontsize=13 fontcolor="#1A5276"

    tnaive [label="Naïve T Cells\n(CD4+/CD8+)" fillcolor="#AED6F1"]
    teff_cd4 [label="CD4+ Teff\n(Th1/Th17)" fillcolor="#5DADE2" fontcolor=white]
    th1 [label="Th1 Cells\n(IFN-γ, IL-2)" fillcolor="#2980B9" fontcolor=white]
    th17 [label="Th17 Cells\n(IL-17A, IL-22)" fillcolor="#1A5276" fontcolor=white]
    treg [label="Tregs\n(CD4+CD25+FoxP3+)" fillcolor="#48C9B0"]
    cd8 [label="CD8+ Cytotoxic\nT Cells" fillcolor="#7FB3D3"]
    tmem [label="Memory T Cells" fillcolor="#AED6F1"]
    tcr_signal [label="TCR/CD28\nSignaling" fillcolor="#85C1E9"]
    costim [label="Co-stimulation\n(CD80/CD86-CD28)" fillcolor="#AED6F1"]
    il2 [label="IL-2\n(Proliferation)" fillcolor="#5DADE2" fontcolor=white]
    il12 [label="IL-12\n(Th1 Polarization)" fillcolor="#2980B9" fontcolor=white]
    il23 [label="IL-23\n(Th17 Maint.)" fillcolor="#1A5276" fontcolor=white]
    ifng [label="IFN-γ" fillcolor="#2980B9" fontcolor=white]
    il17a [label="IL-17A" fillcolor="#1A5276" fontcolor=white]
    il10_treg [label="IL-10\n(Anti-inflam)" fillcolor="#48C9B0"]
    tgfb_treg [label="TGF-β\n(Treg suppress)" fillcolor="#48C9B0"]
    foxp3 [label="FoxP3\n(Treg master TF)" fillcolor="#48C9B0"]
    ctla4 [label="CTLA-4\nCheckpoint" fillcolor="#A9CCE3"]
    pd1 [label="PD-1/PD-L1\nCheckpoint" fillcolor="#A9CCE3"]

    dc -> tnaive [label="MHC-II + TCR"]
    tnaive -> tcr_signal
    tcr_signal -> costim
    costim -> il2
    il2 -> teff_cd4 [label="proliferation"]
    il2 -> cd8 [label="proliferation"]
    il12 -> th1 [label="polarization"]
    teff_cd4 -> th1
    teff_cd4 -> th17
    il23 -> th17 [label="maintenance"]
    th1 -> ifng
    th17 -> il17a
    treg -> il10_treg
    treg -> tgfb_treg
    foxp3 -> treg [label="master regulator"]
    teff_cd4 -> tmem [label="memory formation"]
    ctla4 -> teff_cd4 [label="inhibition" color="#27AE60"]
    pd1 -> cd8 [label="exhaustion" color="#27AE60"]
  }

  /* ─────────────────────────────────────────
     CLUSTER 4: B Cells & Autoantibodies
  ───────────────────────────────────────── */
  subgraph cluster_bcell {
    label="B Cell & Humoral Immunity"
    style=filled fillcolor="#F4ECF7" color="#7D3C98" penwidth=2
    fontname="Helvetica-Bold" fontsize=13 fontcolor="#7D3C98"

    bnaive [label="Naïve B Cells" fillcolor="#D7BDE2"]
    plasma_cell [label="Plasma Cells\n(IgG/IgA)" fillcolor="#A569BD"]
    gc_reaction [label="Germinal Center\nReaction" fillcolor="#C39BD3"]
    autoab [label="Autoantibodies\n(Anti-Recoverin\nAnti-IRBP)" fillcolor="#7D3C98" fontcolor=white]
    ic_form [label="Immune Complex\nFormation" fillcolor="#A569BD"]
    bcr [label="BCR Signaling" fillcolor="#D7BDE2"]
    cd20 [label="CD20\n(B cell marker)" fillcolor="#D7BDE2"]
    il10_b [label="IL-10\n(Regulatory B)" fillcolor="#C39BD3"]

    bnaive -> bcr
    bcr -> gc_reaction
    gc_reaction -> plasma_cell
    plasma_cell -> autoab
    autoab -> ic_form
    ic_form -> complement [label="activates" lhead=cluster_innate]
    bnaive -> cd20
    bnaive -> il10_b [label="Bregs"]
    th1 -> gc_reaction [label="T helper"]
  }

  /* ─────────────────────────────────────────
     CLUSTER 5: Cytokine & Chemokine Network
  ───────────────────────────────────────── */
  subgraph cluster_cytokine {
    label="Cytokine & Chemokine Network"
    style=filled fillcolor="#FEF9E7" color="#E67E22" penwidth=2
    fontname="Helvetica-Bold" fontsize=13 fontcolor="#E67E22"

    tnfa [label="TNF-α\n(Central Mediator)" fillcolor="#E67E22" fontcolor=white]
    il6 [label="IL-6\n(STAT3 activation)" fillcolor="#F0B27A"]
    il1b [label="IL-1β" fillcolor="#F0B27A"]
    il8_cxcl8 [label="IL-8/CXCL8\n(Neutrophil chemo)" fillcolor="#FAD7A0"]
    ccl2 [label="CCL2/MCP-1\n(Monocyte chemo)" fillcolor="#FAD7A0"]
    cxcl10 [label="CXCL10/IP-10\n(T cell chemo)" fillcolor="#FAD7A0"]
    il33 [label="IL-33\n(Alarmins)" fillcolor="#FAD7A0"]
    il4 [label="IL-4\n(Th2)" fillcolor="#FAD7A0"]
    vegf [label="VEGF-A\n(Vascular perm.)" fillcolor="#E74C3C" fontcolor=white]
    vegfr2 [label="VEGFR2\n(Endothelial)" fillcolor="#F1948A"]
    mmp [label="MMPs\n(ECM remodeling)" fillcolor="#FAD7A0"]
    cox2 [label="COX-2 / PGE2\n(Prostaglandins)" fillcolor="#F0B27A"]
    stat3 [label="STAT3\n(IL-6 signal)" fillcolor="#E67E22" fontcolor=white]
    jak_path [label="JAK1/2\nPathway" fillcolor="#F0B27A"]
    nfkb_cyto [label="NF-κB\n(Cytokine hub)" fillcolor="#E67E22" fontcolor=white]

    tnf_innate -> tnfa
    il6_innate -> il6
    il1b_innate -> il1b
    ifng -> nfkb_cyto [label="synergy"]
    il17a -> nfkb_cyto [label="synergy"]
    nfkb_cyto -> tnfa
    nfkb_cyto -> il6
    nfkb_cyto -> il1b
    nfkb_cyto -> il8_cxcl8
    nfkb_cyto -> ccl2
    nfkb_cyto -> cox2
    nfkb_cyto -> mmp
    il6 -> stat3 [label="gp130"]
    stat3 -> jak_path
    il1b -> vegf [label="upregulation"]
    tnfa -> vegf [label="upregulation"]
    vegf -> vegfr2
    il8_cxcl8 -> neutrophil [label="chemotaxis" lhead=cluster_innate]
    cxcl10 -> teff_cd4 [label="chemotaxis" lhead=cluster_tcell]
    ccl2 -> macro [label="chemotaxis" lhead=cluster_innate]
  }

  /* ─────────────────────────────────────────
     CLUSTER 6: Blood-Ocular Barrier Disruption
  ───────────────────────────────────────── */
  subgraph cluster_barrier {
    label="Blood-Ocular Barrier Disruption"
    style=filled fillcolor="#EAFAF1" color="#1D8348" penwidth=2
    fontname="Helvetica-Bold" fontsize=13 fontcolor="#1D8348"

    bab [label="Blood-Aqueous Barrier\n(BAB) Integrity" fillcolor="#82E0AA"]
    brb_inner [label="Inner BRB\n(Retinal Endothelium)" fillcolor="#58D68D"]
    brb_outer [label="Outer BRB\n(RPE Tight Junctions)" fillcolor="#58D68D"]
    zo1 [label="ZO-1/Occludin\nTight Junctions" fillcolor="#A9DFBF"]
    vegf_perm [label="VEGF-Induced\nPermeability" fillcolor="#E74C3C" fontcolor=white]
    endothelial_act [label="Endothelial Activation\n(ICAM-1, VCAM-1)" fillcolor="#F1948A"]
    leukostasis [label="Leukostasis\n(WBC adhesion)" fillcolor="#F1948A"]
    flare [label="Anterior Flare\n(Protein leakage)" fillcolor="#FAD7A0"]
    cells_ah [label="Cells in Aqueous\n(WBC count)" fillcolor="#F0B27A"]
    protein_ah [label="Protein in Aqueous\n(Tyndall effect)" fillcolor="#FAD7A0"]
    cme [label="Cystoid Macular\nEdema (CME)" fillcolor="#E74C3C" fontcolor=white]
    srnv [label="Subretinal\nNeovascularization" fillcolor="#E74C3C" fontcolor=white]
    epiretinal_mem [label="Epiretinal\nMembrane" fillcolor="#F1948A"]

    tnfa -> endothelial_act [label="ICAM-1 up"]
    il1b -> endothelial_act [label="VCAM-1 up"]
    vegf -> vegf_perm
    vegf_perm -> brb_inner [label="disrupts" color="#E74C3C"]
    vegf_perm -> brb_outer [label="disrupts" color="#E74C3C"]
    vegf_perm -> bab [label="disrupts" color="#E74C3C"]
    endothelial_act -> leukostasis
    leukostasis -> bab [label="disrupts" color="#E74C3C"]
    zo1 -> brb_inner [label="maintains"]
    brb_inner -> cme [label="leakage → edema" color="#E74C3C"]
    bab -> flare [label="disrupted" color="#E74C3C"]
    bab -> cells_ah [label="WBC influx"]
    flare -> protein_ah
    cme -> srnv [label="chronic → neovascularization" color="#E74C3C"]
    srnv -> epiretinal_mem [label="tractional"]
    mmp -> zo1 [label="degrades" color="#E74C3C"]
  }

  /* ─────────────────────────────────────────
     CLUSTER 7: Clinical Manifestations & Endpoints
  ───────────────────────────────────────── */
  subgraph cluster_clinical {
    label="Clinical Manifestations & Endpoints"
    style=filled fillcolor="#FDFEFE" color="#5D6D7E" penwidth=2
    fontname="Helvetica-Bold" fontsize=13 fontcolor="#5D6D7E"

    va [label="Visual Acuity\n(logMAR/BCVA)" fillcolor="#5D6D7E" fontcolor=white]
    iop [label="Intraocular Pressure\n(mmHg)" fillcolor="#85929E"]
    vitreous_haze [label="Vitreous Haze\n(Grade 0-4)" fillcolor="#AEB6BF"]
    keratic_prec [label="Keratic\nPrecipitates (KP)" fillcolor="#BFC9CA"]
    posterior_synech [label="Posterior\nSynechiae" fillcolor="#AEB6BF"]
    band_keratopathy [label="Band Keratopathy\n(Chronic Ca2+)" fillcolor="#CCD1D1"]
    cataract [label="Cataract\n(Inflammation/Steroid)" fillcolor="#99A3A4"]
    glaucoma_sec [label="Secondary\nGlaucoma" fillcolor="#717D7E" fontcolor=white]
    retinal_detach [label="Retinal\nDetachment" fillcolor="#717D7E" fontcolor=white]
    optic_atrophy [label="Optic Atrophy\n(Chronic papillitis)" fillcolor="#616A6B" fontcolor=white]
    blindness [label="BLINDNESS\n(End-stage)" fillcolor="#1C2833" fontcolor=white]
    pain_redness [label="Pain & Redness\n(Anterior uveitis)" fillcolor="#F1948A"]
    photophobia [label="Photophobia" fillcolor="#FADBD8"]
    floaters [label="Floaters\n(Posterior uveitis)" fillcolor="#FADBD8"]

    cme -> va [label="↓ vision" color="#E74C3C"]
    srnv -> va [label="↓ vision" color="#E74C3C"]
    optic_atrophy -> va [label="↓ vision" color="#E74C3C"]
    cells_ah -> vitreous_haze [label="posterior spread"]
    cells_ah -> keratic_prec
    cells_ah -> posterior_synech [label="fibrin"]
    posterior_synech -> glaucoma_sec [label="pupil block"]
    iop -> glaucoma_sec [label="elevated"]
    glaucoma_sec -> optic_atrophy
    optic_atrophy -> blindness
    retinal_detach -> blindness
    cme -> blindness [label="chronic untreated"]
    band_keratopathy -> va [label="↓ vision"]
    cataract -> va [label="↓ vision"]
    pain_redness -> photophobia
    vitreous_haze -> floaters
  }

  /* ─────────────────────────────────────────
     CLUSTER 8: Drug PK
  ───────────────────────────────────────── */
  subgraph cluster_pk {
    label="Drug Pharmacokinetics"
    style=filled fillcolor="#F5EEF8" color="#6C3483" penwidth=2
    fontname="Helvetica-Bold" fontsize=13 fontcolor="#6C3483"

    dose_topical [label="Topical Drops\n(Prednisolone 1%)" fillcolor="#D7BDE2"]
    dose_perioc [label="Periocular Injection\n(Triamcinolone 40mg)" fillcolor="#C39BD3"]
    dose_ivt [label="Intravitreal\n(Ozurdex/Yutiq)" fillcolor="#A569BD"]
    dose_systemic [label="Systemic Oral\n(Pred 1mg/kg)" fillcolor="#D7BDE2"]
    dose_iv [label="IV Infusion\n(Adalimumab/Tocilizumab)" fillcolor="#D7BDE2"]
    dose_sc [label="SC Injection\n(Adalimumab 40mg q2w)" fillcolor="#D7BDE2"]
    dose_mtx [label="Oral/SC MTX\n(7.5-25mg/wk)" fillcolor="#D7BDE2"]

    pk_central [label="Central Compartment\n(Plasma)" fillcolor="#A569BD"]
    pk_periph [label="Peripheral\nCompartment" fillcolor="#C39BD3"]
    pk_ant_eye [label="Anterior Chamber\nConcentration" fillcolor="#8E44AD" fontcolor=white]
    pk_post_eye [label="Posterior Segment\nConcentration" fillcolor="#6C3483" fontcolor=white]
    pk_depot_ivt [label="IVT Depot\n(Slow release)" fillcolor="#D2B4DE"]
    pk_retina_conc [label="Retinal\nConcentration" fillcolor="#7D3C98" fontcolor=white]
    gr_occupancy [label="Glucocorticoid\nReceptor Occupancy" fillcolor="#C39BD3"]
    drug_cl [label="Clearance\n(CL, Vd, ka)" fillcolor="#D7BDE2"]
    aq_humor_flow [label="Aqueous Humor\nFlow (2.5μL/min)" fillcolor="#C39BD3"]
    bab_transfer [label="BAB\nTransfer Rate" fillcolor="#A569BD"]

    dose_topical -> pk_ant_eye [label="corneal absorption\nBio~3%"]
    dose_perioc -> pk_central [label="systemic absorption"]
    dose_perioc -> pk_post_eye [label="direct diffusion"]
    dose_ivt -> pk_depot_ivt [label="depot release"]
    pk_depot_ivt -> pk_post_eye [label="sustained release\n(months)"]
    dose_systemic -> pk_central [label="oral absorption F~80%"]
    dose_iv -> pk_central [label="IV bolus/infusion"]
    dose_sc -> pk_central [label="SC absorption\nF~65%"]
    dose_mtx -> pk_central [label="oral F~70%"]
    pk_central -> pk_periph [label="distribution\nk12/k21"]
    pk_central -> pk_ant_eye [label="BAB\npenetration" style=dashed]
    pk_central -> pk_post_eye [label="BRB\npenetration" style=dashed]
    pk_ant_eye -> pk_post_eye [label="diffusion"]
    pk_post_eye -> pk_retina_conc [label="tissue distribution"]
    pk_ant_eye -> aq_humor_flow [label="washout"]
    pk_central -> drug_cl [label="CL/Vd"]
    pk_ant_eye -> gr_occupancy [label="Emax model"]
    bab -> bab_transfer [label="modulates\npenetration"]
  }

  /* ─────────────────────────────────────────
     CLUSTER 9: Drug PD Mechanisms
  ───────────────────────────────────────── */
  subgraph cluster_pd {
    label="Drug Pharmacodynamics"
    style=filled fillcolor="#EBF5FB" color="#117A65" penwidth=2
    fontname="Helvetica-Bold" fontsize=13 fontcolor="#117A65"

    /* Corticosteroids */
    cs_gr [label="GR Activation\n(Corticosteroids)" fillcolor="#1ABC9C" fontcolor=white]
    cs_nfkb [label="NF-κB Inhibition\n(Transrepression)" fillcolor="#17A589" fontcolor=white]
    cs_apoptosis [label="T/B Cell\nApoptosis" fillcolor="#A2D9CE"]
    cs_bab_restore [label="BAB Restoration\n(Steroid effect)" fillcolor="#76D7C4"]
    cs_iop_raise [label="IOP Elevation\n(Steroid glaucoma)" fillcolor="#E74C3C" fontcolor=white]
    cs_cataract [label="Posterior Subcapsular\nCataract (PSC)" fillcolor="#E74C3C" fontcolor=white]

    /* Anti-TNF */
    anti_tnf [label="Anti-TNF\n(Adalimumab/Inf)" fillcolor="#2ECC71" fontcolor=white]
    tnf_neutralize [label="TNF Neutralization\n(Soluble TNF)" fillcolor="#27AE60" fontcolor=white]
    tmTNF_lysis [label="tmTNF-bearing Cell\nApoptosis" fillcolor="#A9DFBF"]

    /* Anti-IL-6 */
    anti_il6 [label="Tocilizumab\n(IL-6R blockade)" fillcolor="#3498DB" fontcolor=white]
    il6r_block [label="IL-6R Blockade\n(STAT3 off)" fillcolor="#2980B9" fontcolor=white]

    /* Anti-VEGF */
    anti_vegf [label="Anti-VEGF\n(Ranibizumab\nBevacizumab)" fillcolor="#E74C3C" fontcolor=white]
    vegf_block [label="VEGF Neutralization\n(Angiogenesis off)" fillcolor="#F1948A"]

    /* MTX / DMARDs */
    mtx_dhfr [label="MTX: DHFR Inhibition\n→ Purine/Pyrimidine ↓" fillcolor="#F39C12" fontcolor=white]
    mtx_adenosine [label="Adenosine Release\n(Anti-inflammatory)" fillcolor="#FAD7A0"]
    mmf_pd [label="MMF: IMPDH Inhibition\n→ Lymphocyte ↓" fillcolor="#F0B27A"]
    csa_pd [label="Cyclosporin A:\nCalcineurin Inhibition" fillcolor="#F0B27A"]
    il2_block [label="IL-2 Production\n↓ (Calcineurin off)" fillcolor="#FAD7A0"]

    /* JAK inhibitors */
    jak_inh [label="JAK Inhibitors\n(Baricitinib)" fillcolor="#85C1E9"]
    jak1_block [label="JAK1 Inhibition\n→ IL-6/IFN-γ ↓" fillcolor="#7FB3D3"]

    gr_occupancy -> cs_gr
    cs_gr -> cs_nfkb [label="transrepression"]
    cs_nfkb -> nfkb_cyto [label="inhibits" color="#27AE60"]
    cs_gr -> cs_apoptosis
    cs_gr -> cs_bab_restore [label="junction ↑"]
    cs_gr -> cs_iop_raise [label="trabecular ↓" color="#E74C3C"]
    cs_gr -> cs_cataract [label="chronic use" color="#E74C3C"]

    anti_tnf -> tnf_neutralize
    tnf_neutralize -> tnfa [label="neutralizes" color="#27AE60"]
    tnf_neutralize -> tmTNF_lysis

    anti_il6 -> il6r_block
    il6r_block -> il6 [label="blocks signal" color="#27AE60"]
    il6r_block -> stat3 [label="↓ activation" color="#27AE60"]

    anti_vegf -> vegf_block
    vegf_block -> vegf [label="neutralizes" color="#27AE60"]
    vegf_block -> cme [label="↓ edema" color="#27AE60"]

    mtx_dhfr -> mtx_adenosine
    mtx_adenosine -> teff_cd4 [label="↓ proliferation" color="#27AE60" lhead=cluster_tcell]
    mmf_pd -> plasma_cell [label="↓ proliferation" color="#27AE60" lhead=cluster_bcell]
    csa_pd -> il2_block
    il2_block -> il2 [label="↓ production" color="#27AE60" lhead=cluster_tcell]

    jak_inh -> jak1_block
    jak1_block -> jak_path [label="inhibits" color="#27AE60"]
  }

  /* ─────────────────────────────────────────
     CLUSTER 10: Ocular Complications & Comorbidities
  ───────────────────────────────────────── */
  subgraph cluster_comorbid {
    label="Ocular Complications & Disease Course"
    style=filled fillcolor="#FEF5E7" color="#E67E22" penwidth=2
    fontname="Helvetica-Bold" fontsize=13 fontcolor="#E67E22"

    uv_class [label="Uveitis Classification\n(Anterior/Intermediate\nPosterior/Panuveitis)" fillcolor="#F8C471"]
    acute_uv [label="Acute Uveitis\n(< 3 months)" fillcolor="#F5CBA7"]
    chronic_uv [label="Chronic Uveitis\n(> 3 months / recurrent)" fillcolor="#F0B27A"]
    recurrence [label="Recurrence\n(Flare rate/year)" fillcolor="#EB984E"]
    remission [label="Remission\n(Quiet eye)" fillcolor="#82E0AA"]
    structural_damage [label="Structural Damage\n(Irreversible)" fillcolor="#E74C3C" fontcolor=white]
    systemic_involvement [label="Systemic Disease\n(HLA-B27 · IBD · AS)" fillcolor="#F8C471"]
    biologic_fail [label="Biologic\nFailure/Switch" fillcolor="#FDEBD0"]
    drug_taper [label="Drug Taper\n(Steroid sparing)" fillcolor="#FDEBD0"]

    uv_class -> acute_uv
    uv_class -> chronic_uv
    acute_uv -> remission [label="treatment"]
    acute_uv -> chronic_uv [label="inadequate Rx"]
    chronic_uv -> recurrence [label="immunological memory"]
    recurrence -> structural_damage [label="cumulative damage"]
    remission -> drug_taper
    biologic_fail -> anti_tnf [label="switch" lhead=cluster_pd]
    systemic_involvement -> uv_class [label="guides treatment"]
  }

  /* ─────────────────────────────────────────
     CLUSTER 11: Biomarkers & Lab Monitoring
  ───────────────────────────────────────── */
  subgraph cluster_biomarker {
    label="Biomarkers & Monitoring"
    style=filled fillcolor="#E9F7EF" color="#239B56" penwidth=2
    fontname="Helvetica-Bold" fontsize=13 fontcolor="#239B56"

    aq_humor_cells [label="Aqueous Cells/Flare\n(SUN Grade 0-4)" fillcolor="#A9DFBF"]
    oct_cst [label="OCT: CST\n(Central Subfield\nThickness μm)" fillcolor="#52BE80"]
    ffa_leakage [label="FFA Leakage\nScore" fillcolor="#82E0AA"]
    iop_monitor [label="IOP Monitoring\n(mmHg)" fillcolor="#A9DFBF"]
    serum_tnf [label="Serum TNF-α\n(pg/mL)" fillcolor="#A9DFBF"]
    serum_il6 [label="Serum IL-6\n(pg/mL)" fillcolor="#A9DFBF"]
    crp [label="hsCRP\n(mg/L)" fillcolor="#A9DFBF"]
    esr [label="ESR\n(mm/h)" fillcolor="#A9DFBF"]
    hlab27_test [label="HLA-B27 Testing" fillcolor="#FDFEFE"]
    sace [label="Serum ACE\n(Sarcoidosis)" fillcolor="#D5F5E3"]
    toxo_ab [label="Toxoplasma\nSerology" fillcolor="#D5F5E3"]
    cmv_pcr [label="CMV/HSV PCR\n(Aqueous tap)" fillcolor="#D5F5E3"]
    drug_level [label="Drug Level\n(Adalimumab trough)" fillcolor="#82E0AA"]
    ada_ab [label="Anti-Drug Antibodies\n(ADA)" fillcolor="#F1948A"]

    cells_ah -> aq_humor_cells [label="measure"]
    cme -> oct_cst [label="measure"]
    brb_inner -> ffa_leakage [label="assess"]
    iop -> iop_monitor [label="monitor"]
    tnfa -> serum_tnf
    il6 -> serum_il6
    nfkb_cyto -> crp [label="acute phase"]
    nfkb_cyto -> esr [label="indirect"]
    anti_tnf -> drug_level [label="trough level" lhead=cluster_pd]
    drug_level -> ada_ab [label="immunogenicity"]
    ada_ab -> anti_tnf [label="↓ efficacy" color="#E74C3C" lhead=cluster_pd]
  }

  /* ─────────────────────────────────────────
     CROSS-CLUSTER EDGES
  ───────────────────────────────────────── */
  antigen_present -> dc [label="T cell priming" ltail=cluster_trigger lhead=cluster_innate]
  dc -> tnaive [label="MHC-II/TCR" ltail=cluster_innate lhead=cluster_tcell]
  teff_cd4 -> tnfa [label="cytokine prod." ltail=cluster_tcell lhead=cluster_cytokine]
  th1 -> macro [label="IFN-γ → M1" ltail=cluster_tcell lhead=cluster_innate]
  cytokine_net_to_barrier [label="" style=invis]
  tnfa -> bab [label="barrier disrupt" ltail=cluster_cytokine lhead=cluster_barrier color="#E74C3C"]
  il6 -> brb_inner [label="permeability ↑" ltail=cluster_cytokine lhead=cluster_barrier color="#E74C3C"]
  bab -> cells_ah [label="WBC influx" ltail=cluster_barrier lhead=cluster_clinical]
  cme -> va [label="vision ↓" ltail=cluster_barrier lhead=cluster_clinical color="#E74C3C"]
  cs_bab_restore -> bab [label="restores ↑" ltail=cluster_pd lhead=cluster_barrier color="#27AE60"]
  cs_nfkb -> nfkb_cyto [label="inhibits" ltail=cluster_pd lhead=cluster_cytokine color="#27AE60"]
  anti_tnf -> tnfa [label="neutralize" ltail=cluster_pd lhead=cluster_cytokine color="#27AE60"]
  anti_vegf -> vegf [label="block" ltail=cluster_pd lhead=cluster_cytokine color="#27AE60"]
  pk_ant_eye -> cs_gr [label="[Drug]→ER" ltail=cluster_pk lhead=cluster_pd]
  pk_post_eye -> anti_vegf [label="[Drug]" ltail=cluster_pk lhead=cluster_pd]
  aq_humor_cells -> aq_humor_flow [label="washout" ltail=cluster_biomarker lhead=cluster_pk]
  oct_cst -> va [label="predict BCVA" ltail=cluster_biomarker lhead=cluster_clinical]
  uv_class -> dose_topical [label="anterior → drops" ltail=cluster_comorbid lhead=cluster_pk]
  uv_class -> dose_ivt [label="posterior → IVT" ltail=cluster_comorbid lhead=cluster_pk]
  chronic_uv -> dose_mtx [label="steroid sparing" ltail=cluster_comorbid lhead=cluster_pk]

  /* Legend */
  subgraph cluster_legend {
    label="Legend" style=filled fillcolor="#FDFEFE" color="#888888"
    fontname="Helvetica-Bold" fontsize=11
    leg1 [label="→ Activation/Upregulation" style=filled fillcolor=white shape=plaintext]
    leg2 [label="→ (green) Inhibition/Drug Action" style=filled fillcolor=white shape=plaintext fontcolor="#27AE60"]
    leg3 [label="→ (red) Pathological effect" style=filled fillcolor=white shape=plaintext fontcolor="#E74C3C"]
    leg4 [label="Boxes: Molecules/Cells/Compartments" style=filled fillcolor=white shape=plaintext]
    leg5 [label="Clusters: Biological Modules" style=filled fillcolor=white shape=plaintext]
  }
}
