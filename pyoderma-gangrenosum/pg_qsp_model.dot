digraph PG_QSP_Model {
    graph [
        label = "Pyoderma Gangrenosum (PG) — Quantitative Systems Pharmacology Model\nMechanistic Map: Neutrophilic Dermatosis · Pathergy · IL-1/IL-17/IL-23 · NETosis · Tissue Destruction · Drug PK/PD · Clinical Endpoints"
        labelloc = "t"
        fontsize = 16
        fontname = "Helvetica-Bold"
        rankdir = "TB"
        compound = true
        splines = ortho
        bgcolor = "#F8F9FA"
        overlap = false
        nodesep = 0.25
        ranksep = 0.5
        pad = 0.5
    ]
    node [fontname="Helvetica" fontsize=9 style="filled,rounded" shape=box]
    edge [fontname="Helvetica" fontsize=7 arrowsize=0.7]

    // ============================================================
    // CLUSTER 1: Predisposing, Genetic & Triggering Factors
    // ============================================================
    subgraph cluster_triggers {
        label = "1. Predisposing, Genetic & Triggering Factors"
        style = "filled,rounded"
        color = "#8B4513"
        fillcolor = "#FFF8F0"
        fontsize = 12
        fontcolor = "#8B4513"

        PSTPIP1   [label="PSTPIP1\nMutation\n(PAPA/PASH)"  fillcolor="#FFB347" shape=diamond]
        MEFV      [label="MEFV\n(Pyrin) Variant"           fillcolor="#FFB347" shape=diamond]
        NLRP3v    [label="NLRP3\nGain-of-Function"         fillcolor="#FFB347" shape=diamond]
        NCF2      [label="NCF2/NCF4\nVariant"              fillcolor="#FFB347" shape=diamond]
        JAK2v     [label="JAK2\nVariant"                   fillcolor="#FFB347" shape=diamond]
        IL1RN     [label="IL1RN\nDeficiency"               fillcolor="#FFB347" shape=diamond]
        Pathergy  [label="Pathergy\n(Trauma/Surgery) ★"    fillcolor="#FFA07A"]
        Insect    [label="Insect Bite /\nSkin Injury"      fillcolor="#D3D3D3"]
        Cocaine   [label="Cocaine /\nLevamisole"           fillcolor="#FFCCCC"]
        PTU_trig  [label="Propylthiouracil\nHydralazine"   fillcolor="#FFCCCC"]
        GMCSF_tr  [label="G-CSF/GM-CSF\n(Drug-induced)"    fillcolor="#FFCCCC"]
        TKI_trig  [label="TKI (Imatinib)\nIsotretinoin"    fillcolor="#FFCCCC"]
        IBD_comb  [label="IBD\n(UC/Crohn)"                 fillcolor="#FFDAB9"]
        RA_comb   [label="Rheumatoid\nArthritis"           fillcolor="#FFDAB9"]
        Heme_comb [label="Hematologic\nMalignancy (AML/MDS)" fillcolor="#FFDAB9"]
        MGUS_co   [label="Monoclonal\nGammopathy (IgA)"    fillcolor="#FFDAB9"]
        Behcet_co [label="Behçet Disease\nAxSpA"           fillcolor="#FFDAB9"]
        Hep_comb  [label="Chronic\nHepatitis (B/C)"        fillcolor="#FFDAB9"]
        Stress_p  [label="Psychosocial\nStress"            fillcolor="#D3D3D3"]
        Obese_t   [label="Obesity /\nMetabolic Syn"        fillcolor="#FFA07A"]
        Smoke_t   [label="Cigarette\nSmoking"              fillcolor="#D3D3D3"]
    }

    // ============================================================
    // CLUSTER 2: Innate Immune Activation & Inflammasome
    // ============================================================
    subgraph cluster_innate {
        label = "2. Innate Immune Activation & Inflammasome"
        style = "filled,rounded"
        color = "#8B0000"
        fillcolor = "#FFF0F0"
        fontsize = 12
        fontcolor = "#8B0000"

        TLR2   [label="TLR2"   fillcolor="#FF6B6B"]
        TLR4   [label="TLR4"   fillcolor="#FF6B6B"]
        TLR7   [label="TLR7"   fillcolor="#FF6B6B"]
        TLR9   [label="TLR9"   fillcolor="#FF6B6B"]
        NOD2   [label="NOD2"   fillcolor="#FF9999"]
        Pyrin  [label="Pyrin\nInflammasome"     fillcolor="#DC143C" fontcolor="white"]
        NLRP3  [label="NLRP3\nInflammasome ★"   fillcolor="#DC143C" fontcolor="white"]
        AIM2   [label="AIM2\nInflammasome"      fillcolor="#CC1122" fontcolor="white"]
        Casp1  [label="Caspase-1\n(Active) ★"   fillcolor="#B22222" fontcolor="white"]
        GSDMD  [label="Gasdermin-D\n(N-frag) → Pore" fillcolor="#B22222" fontcolor="white"]
        Pyroptosis [label="Pyroptosis ★"        fillcolor="#8B0000" fontcolor="white"]

        DAMP_HMGB [label="HMGB1\nDAMP"          fillcolor="#FFB6C1"]
        DAMP_S100 [label="S100A8/A9\n(Calprotectin)" fillcolor="#FFB6C1"]
        DAMP_HSP  [label="HSP70/90\nDAMP"       fillcolor="#FFB6C1"]
        DAMP_ATP  [label="Extracellular\nATP"   fillcolor="#FFB6C1"]
        PAMP_bac  [label="Bacterial\nPAMPs"     fillcolor="#FFCCCC"]

        proIL1b   [label="Pro-IL-1β\n(inactive)" fillcolor="#FFA07A"]
        IL1b      [label="IL-1β ★★"  fillcolor="#FF4500" fontcolor="white"]
        IL18      [label="IL-18 ★"   fillcolor="#FF6347" fontcolor="white"]
        IL1a      [label="IL-1α"      fillcolor="#FF6347" fontcolor="white"]
        IL1RA_e   [label="IL-1Ra\n(endogenous)"   fillcolor="#FFD700"]

        NFkB      [label="NF-κB\nActivation ★"  fillcolor="#B22222" fontcolor="white"]
        IKK       [label="IKKβ\nComplex"        fillcolor="#CD5C5C"]
        AP1       [label="AP-1\n(Jun/Fos)"     fillcolor="#CD5C5C"]
        MyD88     [label="MyD88\nAdaptor"      fillcolor="#CD5C5C"]
        TRIF      [label="TRIF\nAdaptor"        fillcolor="#CD5C5C"]
        IRAK4     [label="IRAK4"               fillcolor="#CD5C5C"]
        TBK1     [label="TBK1\nKinase"          fillcolor="#CD5C5C"]
    }

    // ============================================================
    // CLUSTER 3: Neutrophil Biology — Recruitment, Activation, NETosis
    // ============================================================
    subgraph cluster_neutrophil {
        label = "3. Neutrophil Biology — Recruitment, Activation, NETosis"
        style = "filled,rounded"
        color = "#FF8C00"
        fillcolor = "#FFF8E7"
        fontsize = 12
        fontcolor = "#FF8C00"

        CXCL1     [label="CXCL1\n(GROα)"        fillcolor="#FFA07A"]
        CXCL2     [label="CXCL2\n(GROβ)"        fillcolor="#FFA07A"]
        CXCL5     [label="CXCL5"                fillcolor="#FFA07A"]
        IL8       [label="IL-8/CXCL8 ★★"        fillcolor="#FF8C00" fontcolor="white"]
        CXCR1     [label="CXCR1"                fillcolor="#FFB347"]
        CXCR2     [label="CXCR2"                fillcolor="#FFB347"]
        LTB4      [label="LTB4"                 fillcolor="#FFA500"]
        C5a       [label="C5a ★"                fillcolor="#FF4444" fontcolor="white"]
        fMLF      [label="fMLF\n(formyl peptide)" fillcolor="#FFA07A"]
        ICAM1     [label="ICAM-1\n(endothelial)" fillcolor="#FFD700"]
        VCAM1     [label="VCAM-1"               fillcolor="#FFD700"]
        Selectin  [label="E/P-Selectin"         fillcolor="#FFD700"]
        Integrin  [label="LFA-1/Mac-1\n(β2 integrin)" fillcolor="#FFD700"]

        Neutroph  [label="Neutrophil ★★★\n(Tissue-Infiltrating)" fillcolor="#FF4500" fontcolor="white"]
        NeutBlood [label="Circulating\nNeutrophil"   fillcolor="#FFA07A"]
        NeutActiv [label="Neutrophil\nHyperactivation ★" fillcolor="#FF4500" fontcolor="white"]
        ROS       [label="ROS / O₂⁻\n(NOX2)"      fillcolor="#DC143C" fontcolor="white"]
        NADPHox   [label="NADPH Oxidase\n(NOX2)"  fillcolor="#FF6347" fontcolor="white"]
        MPO       [label="Myeloperoxidase\n(MPO) ★" fillcolor="#FF4500" fontcolor="white"]
        Elastase  [label="Neutrophil\nElastase ★"  fillcolor="#FF4500" fontcolor="white"]
        Cathepsin [label="Cathepsin G\nProteinase-3" fillcolor="#FF6347" fontcolor="white"]
        Defensin  [label="α-Defensins\n(HNP1-3)"   fillcolor="#FFA07A"]
        LL37      [label="Cathelicidin\nLL-37"     fillcolor="#FFA07A"]

        NET       [label="NETosis ★★★\n(NET Release)" fillcolor="#B22222" fontcolor="white"]
        PAD4      [label="PAD4\n(Citrullination)" fillcolor="#CD5C5C"]
        CitH3     [label="Citrullinated\nHistone H3" fillcolor="#CD5C5C"]
        NETcomp   [label="NET\nComponents\n(DNA/MPO/NE)" fillcolor="#8B0000" fontcolor="white"]

        IFN1_pg   [label="Type-I IFN\n(IFN-α/β)"   fillcolor="#FFA500"]
    }

    // ============================================================
    // CLUSTER 4: Adaptive Immunity — Th17 / IL-23 Axis
    // ============================================================
    subgraph cluster_adaptive {
        label = "4. Adaptive Immunity — Th17 / IL-23 Axis"
        style = "filled,rounded"
        color = "#4B0082"
        fillcolor = "#F5F0FF"
        fontsize = 12
        fontcolor = "#4B0082"

        DC_cell    [label="Dendritic Cell\n(DC) — APC" fillcolor="#9370DB" fontcolor="white"]
        Mono       [label="Monocyte /\nMacrophage M1 ★" fillcolor="#9370DB" fontcolor="white"]
        Macro_M2   [label="Macrophage M2"        fillcolor="#BA55D3"]
        IL12       [label="IL-12"                fillcolor="#9370DB" fontcolor="white"]
        IL23       [label="IL-23 (p19/p40) ★★"   fillcolor="#8B008B" fontcolor="white"]
        IL23R      [label="IL-23R"                fillcolor="#BA55D3"]

        naive_T    [label="Naïve CD4⁺\nT Cell"   fillcolor="#DDA0DD"]
        Th17       [label="Th17 Cell ★★"          fillcolor="#9932CC" fontcolor="white"]
        Th1        [label="Th1 Cell"              fillcolor="#9932CC" fontcolor="white"]
        Th22       [label="Th22 Cell"             fillcolor="#9932CC" fontcolor="white"]
        Treg       [label="Treg\n(↓ in PG lesion)" fillcolor="#E6E6FA"]
        Tc17       [label="Tc17 (CD8⁺)\nCytotoxic"  fillcolor="#9932CC" fontcolor="white"]

        RORgt      [label="RORγt\nTranscription" fillcolor="#BA55D3"]
        STAT3      [label="STAT3\nActivation"     fillcolor="#BA55D3"]
        JAK1_2     [label="JAK1/JAK2/TYK2"        fillcolor="#BA55D3"]

        IL17A      [label="IL-17A ★★★"            fillcolor="#8B008B" fontcolor="white"]
        IL17F      [label="IL-17F"                fillcolor="#9932CC" fontcolor="white"]
        IL17AF     [label="IL-17A/F\nHeterodimer" fillcolor="#9932CC" fontcolor="white"]
        IL22_n     [label="IL-22"                 fillcolor="#9932CC" fontcolor="white"]
        IL21_n     [label="IL-21"                 fillcolor="#9932CC" fontcolor="white"]
        IL17RA     [label="IL-17RA"               fillcolor="#DDA0DD"]
        IL17RC     [label="IL-17RC"               fillcolor="#DDA0DD"]
        IFNg_n     [label="IFN-γ"                 fillcolor="#9932CC" fontcolor="white"]
        GMCSF_n    [label="GM-CSF\n(Endogenous)"  fillcolor="#9370DB" fontcolor="white"]
    }

    // ============================================================
    // CLUSTER 5: Cytokine Amplification & Feed-forward Loop
    // ============================================================
    subgraph cluster_cytokines {
        label = "5. Cytokine Amplification & Feed-forward Loop"
        style = "filled,rounded"
        color = "#B22222"
        fillcolor = "#FFE4E1"
        fontsize = 12
        fontcolor = "#B22222"

        TNFa       [label="TNF-α ★★★"           fillcolor="#B22222" fontcolor="white"]
        TNFR1      [label="TNFR1"                fillcolor="#CD5C5C"]
        TNFR2      [label="TNFR2"                fillcolor="#CD5C5C"]
        TRADD      [label="TRADD/TRAF2"          fillcolor="#CD5C5C"]
        ADAM17     [label="ADAM17\n(TACE)"       fillcolor="#CD5C5C"]
        IL6        [label="IL-6 ★★"              fillcolor="#FF4500" fontcolor="white"]
        IL6R       [label="IL-6Rα /\nIL-6ST(gp130)" fillcolor="#FF7F50"]
        JAK1_c     [label="JAK1 / JAK2"          fillcolor="#FF7F50"]
        STAT3_c    [label="STAT3\n(Lesion)"      fillcolor="#FF7F50"]
        SAA        [label="Serum Amyloid A\n(SAA)" fillcolor="#FF9999"]
        CRP        [label="CRP\n(Hepatic)"        fillcolor="#FF9999"]
        Fibrinog   [label="Fibrinogen ↑"          fillcolor="#FF9999"]
        Ferritin_n [label="Ferritin ↑"            fillcolor="#FF9999"]

        IL36a      [label="IL-36α"                fillcolor="#FFA500"]
        IL36g      [label="IL-36γ ★"              fillcolor="#FF6347" fontcolor="white"]
        IL36R      [label="IL-36R"                fillcolor="#FFA500"]
        IL36Ra     [label="IL-36Ra\n(Antagonist)" fillcolor="#FFD700"]
    }

    // ============================================================
    // CLUSTER 6: Tissue Destruction, Ulceration, Vasculopathy
    // ============================================================
    subgraph cluster_tissue {
        label = "6. Tissue Destruction, Ulceration & Vasculopathy"
        style = "filled,rounded"
        color = "#556B2F"
        fillcolor = "#F0F5E1"
        fontsize = 12
        fontcolor = "#556B2F"

        Keratino   [label="Keratinocyte\n(Lesional)" fillcolor="#9ACD32"]
        KeratApop  [label="Keratinocyte\nApoptosis"  fillcolor="#6B8E23" fontcolor="white"]
        Fibrobl    [label="Fibroblast\n(Dermal)"     fillcolor="#9ACD32"]
        Endoth     [label="Endothelial\nCell"        fillcolor="#9ACD32"]
        Endoth_dys [label="Endothelial\nDysfunction" fillcolor="#6B8E23" fontcolor="white"]

        MMP2       [label="MMP-2\n(Gelatinase A)" fillcolor="#8FBC8F"]
        MMP9       [label="MMP-9\n(Gelatinase B) ★" fillcolor="#556B2F" fontcolor="white"]
        MMP3       [label="MMP-3"                fillcolor="#8FBC8F"]
        MMP10      [label="MMP-10"               fillcolor="#8FBC8F"]
        TIMP1      [label="TIMP-1/2\n(↓)"         fillcolor="#E6E6E6"]

        epi_loss   [label="Epidermal\nLoss"       fillcolor="#6B8E23" fontcolor="white"]
        dermal_dest[label="Dermal Matrix\nDigestion ★" fillcolor="#556B2F" fontcolor="white"]
        Ulcer      [label="Ulceration ★★★\n(Sterile)" fillcolor="#2F4F2F" fontcolor="white"]
        Border_v   [label="Violaceous Edge\n(Hallmark)" fillcolor="#9932CC" fontcolor="white"]
        Cribrif    [label="Cribriform\nScar"     fillcolor="#8B4513" fontcolor="white"]
        Bullous_v  [label="Bullous Variant\n(superficial)" fillcolor="#9ACD32"]
        Pustular_v [label="Pustular Variant\n(early)" fillcolor="#9ACD32"]
        Vegetat_v  [label="Vegetative Variant\n(superficial granulomatous)" fillcolor="#9ACD32"]
        Periostom  [label="Peristomal Variant"   fillcolor="#9ACD32"]

        Vasc_inj   [label="Vascular\nMicro-injury" fillcolor="#8FBC8F"]
        Thromb     [label="Thrombosis\n(localized)" fillcolor="#6B8E23" fontcolor="white"]
        Edema      [label="Tissue\nEdema"         fillcolor="#9ACD32"]
        Pain_s     [label="Nociception\n(Pain) ★" fillcolor="#FF0000" fontcolor="white"]
    }

    // ============================================================
    // CLUSTER 7: Wound Healing Failure & Fibrosis
    // ============================================================
    subgraph cluster_healing {
        label = "7. Wound Healing Failure & Fibrosis"
        style = "filled,rounded"
        color = "#A0522D"
        fillcolor = "#FFE4C4"
        fontsize = 12
        fontcolor = "#A0522D"

        TGFb     [label="TGF-β"                  fillcolor="#DEB887"]
        VEGF_p   [label="VEGF\n(↓ angiogenesis)" fillcolor="#DEB887"]
        PDGF_p   [label="PDGF"                   fillcolor="#DEB887"]
        myofib   [label="Myofibroblast"          fillcolor="#CD853F" fontcolor="white"]
        col_dep  [label="Collagen\nDeposition (↓)" fillcolor="#CD853F" fontcolor="white"]
        Epith_mig[label="Re-epithelialization\n(impaired) ★" fillcolor="#A0522D" fontcolor="white"]
        Granul   [label="Granulation\nTissue (impaired)" fillcolor="#A0522D" fontcolor="white"]
        Scar     [label="Cribriform\nScar Formation" fillcolor="#8B4513" fontcolor="white"]
        WoundFD  [label="Wound Healing\nFailure ★★" fillcolor="#8B4513" fontcolor="white"]
    }

    // ============================================================
    // CLUSTER 8: Comorbidities & Systemic Bridges
    // ============================================================
    subgraph cluster_comorb {
        label = "8. Comorbidities & Systemic Bridges"
        style = "filled,rounded"
        color = "#2F4F4F"
        fillcolor = "#E0EEEE"
        fontsize = 12
        fontcolor = "#2F4F4F"

        Gut_perm  [label="Gut Barrier\nDysfunction (IBD)" fillcolor="#B0C4DE"]
        Synovitis [label="Synovitis (RA)"        fillcolor="#B0C4DE"]
        Clonal_h  [label="Clonal Hematopoiesis\n(MDS/AML)" fillcolor="#B0C4DE"]
        MGUS_b    [label="Monoclonal IgA\n(Bridge to PG)" fillcolor="#B0C4DE"]
        Behcet_b  [label="Behçet Pathway"        fillcolor="#B0C4DE"]
        PAPA_b    [label="PAPA Syndrome\n(PG + Acne)" fillcolor="#B0C4DE"]
        PASH_b    [label="PASH Syndrome\n(PG + Acne + HS)" fillcolor="#B0C4DE"]
        Bowel_p   [label="Bowel-bypass\nDermatosis"   fillcolor="#B0C4DE"]
    }

    // ============================================================
    // CLUSTER 9: Drug Pharmacology — PK/PD
    // ============================================================
    subgraph cluster_drug {
        label = "9. Drug Pharmacology — PK / PD"
        style = "filled,rounded"
        color = "#000080"
        fillcolor = "#E6E6FA"
        fontsize = 12
        fontcolor = "#000080"

        // Topical / Local
        TopicalCS [label="Topical Class I CS\n(Clobetasol)" fillcolor="#9999FF"]
        TopicalTac[label="Topical Tacrolimus\n0.1%" fillcolor="#9999FF"]

        // Systemic corticosteroids
        Pred      [label="Prednisone\n0.5–1 mg/kg/d ★" fillcolor="#6A5ACD" fontcolor="white"]
        IVMP      [label="Methylpred\nIV Pulse (1g×3d)" fillcolor="#6A5ACD" fontcolor="white"]
        GR_recep  [label="Glucocorticoid\nReceptor (GR)" fillcolor="#9999FF"]

        // Calcineurin inhibitor
        CsA       [label="Cyclosporine\n4–5 mg/kg/d ★" fillcolor="#6A5ACD" fontcolor="white"]
        CalcN     [label="Calcineurin\n(NFAT axis)"    fillcolor="#9999FF"]
        NFAT_p    [label="NFAT\n(T-cell)"             fillcolor="#9999FF"]

        // Anti-TNF biologics
        IFX       [label="Infliximab ★★\n5 mg/kg q6-8w" fillcolor="#191970" fontcolor="white"]
        ADA       [label="Adalimumab\n40–80 mg q1-2w" fillcolor="#191970" fontcolor="white"]
        ETN       [label="Etanercept\n50 mg qw" fillcolor="#191970" fontcolor="white"]
        GOLI      [label="Golimumab\n50 mg q4w" fillcolor="#191970" fontcolor="white"]

        // Anti-IL-1 family
        ANA       [label="Anakinra\n100 mg/d s.c."  fillcolor="#191970" fontcolor="white"]
        CANA      [label="Canakinumab\n150 mg q4-8w" fillcolor="#191970" fontcolor="white"]
        RILO      [label="Rilonacept\n160 mg qw"    fillcolor="#191970" fontcolor="white"]

        // Anti-IL-23 / Anti-IL-17
        UST       [label="Ustekinumab\n45–90 mg q12w" fillcolor="#191970" fontcolor="white"]
        GUSEL     [label="Guselkumab\n100 mg q8w"    fillcolor="#191970" fontcolor="white"]
        SECU      [label="Secukinumab\n300 mg qw→q4w"   fillcolor="#191970" fontcolor="white"]
        BRODA     [label="Brodalumab\n210 mg qw→q2w"    fillcolor="#191970" fontcolor="white"]

        // Anti-IL-6
        TCZ       [label="Tocilizumab\n8 mg/kg q4w" fillcolor="#191970" fontcolor="white"]

        // JAK inhibitors / SMI
        TOFA      [label="Tofacitinib\n5–10 mg BID" fillcolor="#4682B4" fontcolor="white"]
        UPADA     [label="Upadacitinib\n15–30 mg/d" fillcolor="#4682B4" fontcolor="white"]
        BARI      [label="Baricitinib\n2–4 mg/d"    fillcolor="#4682B4" fontcolor="white"]
        APRE      [label="Apremilast\n30 mg BID\n(PDE4i)" fillcolor="#4682B4" fontcolor="white"]

        // Conventional immunosuppressants / IVIG
        AZA       [label="Azathioprine\n2–3 mg/kg/d" fillcolor="#7B68EE" fontcolor="white"]
        MMF       [label="Mycophenolate\n2–3 g/d"    fillcolor="#7B68EE" fontcolor="white"]
        MTX_p     [label="Methotrexate\n15–25 mg qw" fillcolor="#7B68EE" fontcolor="white"]
        Dapsone_p [label="Dapsone\n100 mg/d"          fillcolor="#7B68EE" fontcolor="white"]
        Colchic   [label="Colchicine\n0.5 mg BID"     fillcolor="#7B68EE" fontcolor="white"]
        IVIG      [label="IVIG\n2 g/kg q4w"           fillcolor="#7B68EE" fontcolor="white"]

        // Wound care
        Wcare     [label="Wound Care\n(non-adherent + moist)" fillcolor="#B0C4DE"]
    }

    // ============================================================
    // CLUSTER 10: Clinical Endpoints & Biomarkers
    // ============================================================
    subgraph cluster_endpoints {
        label = "10. Clinical Endpoints & Biomarkers"
        style = "filled,rounded"
        color = "#006400"
        fillcolor = "#E5FFE5"
        fontsize = 12
        fontcolor = "#006400"

        PARACELSUS [label="PARACELSUS\nScore ★ (0–60)"      fillcolor="#228B22" fontcolor="white"]
        PGA        [label="Physician Global\nAssessment (PGA)" fillcolor="#228B22" fontcolor="white"]
        UlcerArea  [label="Ulcer Area (cm²) ★"              fillcolor="#228B22" fontcolor="white"]
        UlcerDepth [label="Ulcer Depth"                     fillcolor="#32CD32"]
        TimeHeal   [label="Time to Healing\n(weeks)"        fillcolor="#228B22" fontcolor="white"]
        BSAulcer   [label="% BSA Involved"                  fillcolor="#32CD32"]
        Pain_VAS   [label="Pain VAS\n(0–10)"               fillcolor="#32CD32"]
        DLQI_p     [label="DLQI\n(0–30)"                    fillcolor="#32CD32"]
        CRP_e      [label="CRP\n(mg/L)"                     fillcolor="#90EE90"]
        ESR        [label="ESR\n(mm/h)"                     fillcolor="#90EE90"]
        WBC_p      [label="WBC / ANC"                       fillcolor="#90EE90"]
        Calprot_s  [label="Serum S100A8/A9\nCalprotectin"   fillcolor="#90EE90"]
        Relapse    [label="Relapse Rate\n(per year)"        fillcolor="#90EE90"]
        Compl_he   [label="Complete\nHealing (Re-epi)"      fillcolor="#228B22" fontcolor="white"]
    }

    // ============================================================
    // EDGES — Cluster 1 → 2 (triggers → innate)
    // ============================================================
    PSTPIP1 -> Pyrin [label="↑ pyrin agg"]
    MEFV    -> Pyrin [label="GoF"]
    NLRP3v  -> NLRP3 [label="GoF"]
    JAK2v   -> Clonal_h [label="↑ clonal HSC"]
    IL1RN   -> IL1RA_e [label="↓"]
    NCF2    -> NADPHox [label="dysfunction"]
    Pathergy -> DAMP_HMGB
    Pathergy -> DAMP_S100
    Pathergy -> DAMP_ATP
    Pathergy -> Vasc_inj
    Insect  -> Pathergy
    Cocaine -> NET [label="direct NETosis"]
    PTU_trig -> NET
    GMCSF_tr -> NeutBlood [label="↑"]
    TKI_trig -> NET
    Stress_p -> NFkB
    Obese_t  -> NLRP3
    Smoke_t  -> NLRP3
    Hep_comb -> TLR7

    // Cluster 1 → 8 (comorbidities)
    IBD_comb -> Gut_perm
    RA_comb  -> Synovitis
    Heme_comb -> Clonal_h
    MGUS_co  -> MGUS_b
    Behcet_co -> Behcet_b
    PSTPIP1  -> PAPA_b

    // ============================================================
    // EDGES — Cluster 2 internal (Innate cascade)
    // ============================================================
    DAMP_HMGB -> TLR4
    DAMP_S100 -> TLR4
    DAMP_HSP  -> TLR4
    DAMP_ATP  -> NLRP3
    PAMP_bac  -> TLR2
    PAMP_bac  -> TLR9
    TLR2 -> MyD88
    TLR4 -> MyD88
    TLR7 -> MyD88
    TLR9 -> MyD88
    TLR4 -> TRIF
    MyD88 -> IRAK4
    IRAK4 -> IKK
    TRIF  -> TBK1
    TBK1  -> IFN1_pg
    IKK   -> NFkB
    NFkB  -> AP1
    NFkB  -> proIL1b [label="↑ transcription"]
    NLRP3 -> Casp1
    Pyrin -> Casp1
    AIM2  -> Casp1
    Casp1 -> IL1b   [label="cleaves"]
    Casp1 -> IL18   [label="cleaves"]
    Casp1 -> GSDMD
    GSDMD -> Pyroptosis
    Pyroptosis -> IL1b [label="release"]
    Pyroptosis -> DAMP_HMGB [label="amplify"]
    proIL1b -> IL1b
    IL1b -> NFkB    [label="autocrine/paracrine"]
    IL1RA_e -> IL1b [label="competitive" arrowhead=tee color="#B22222"]

    // ============================================================
    // EDGES — Cluster 2/5 → Cluster 3 (Cytokines drive neutrophils)
    // ============================================================
    IL1b -> IL8
    IL1a -> IL8
    TNFa -> IL8
    IL17A -> IL8
    IL17A -> CXCL1
    IL17A -> CXCL2
    IL17A -> CXCL5
    IL36g -> IL8
    NFkB  -> CXCL1
    NFkB  -> CXCL2

    // Neutrophil recruitment
    IL8   -> CXCR1 [label="bind"]
    IL8   -> CXCR2
    CXCL1 -> CXCR2
    CXCL2 -> CXCR2
    LTB4  -> NeutBlood [label="chemoattract"]
    C5a   -> NeutBlood
    fMLF  -> NeutBlood
    TNFa  -> ICAM1
    IL1b  -> ICAM1
    TNFa  -> Selectin
    ICAM1 -> Integrin [label="firm adhesion"]
    Selectin -> Integrin
    NeutBlood -> Neutroph [label="extravasation"]
    Integrin -> Neutroph
    CXCR2 -> Neutroph

    // Neutrophil activation & degranulation
    Neutroph -> NeutActiv
    NeutActiv -> NADPHox
    NADPHox -> ROS
    NeutActiv -> MPO
    NeutActiv -> Elastase
    NeutActiv -> Cathepsin
    NeutActiv -> Defensin
    NeutActiv -> LL37

    // NETosis
    NeutActiv -> PAD4
    PAD4      -> CitH3
    CitH3     -> NET
    ROS       -> NET
    Elastase  -> NET
    MPO       -> NET
    NET       -> NETcomp
    NETcomp   -> DAMP_HMGB [label="release"]
    NETcomp   -> NLRP3     [label="amplify"]
    NETcomp   -> IFN1_pg   [label="dsDNA"]

    // ============================================================
    // EDGES — Cluster 4 (Adaptive Th17 axis)
    // ============================================================
    DC_cell -> IL12
    DC_cell -> IL23
    Mono    -> IL23
    Macro_M2 -> Th17 [label="suppress (low)" arrowhead=tee color="#B22222"]
    IL12 -> Th1
    IL23 -> IL23R [label="bind"]
    IL23R -> JAK1_2
    JAK1_2 -> STAT3
    STAT3  -> RORgt
    RORgt  -> Th17 [label="lineage"]
    naive_T -> Th17
    naive_T -> Th1
    naive_T -> Th22
    Th17 -> IL17A
    Th17 -> IL17F
    Th17 -> IL21_n
    Th17 -> IL22_n
    Th17 -> GMCSF_n
    Th1  -> IFNg_n
    Tc17 -> IL17A
    IL17A -> IL17RA
    IL17F -> IL17RC
    IL17AF -> IL17RA
    Treg  -> Th17 [label="↓ in PG" arrowhead=tee color="#B22222"]

    // ============================================================
    // EDGES — Cluster 5 (TNF / IL-6 amplification)
    // ============================================================
    Mono     -> TNFa
    Macro_M2 -> TNFa [label="lower"]
    Neutroph -> TNFa
    NeutActiv -> TNFa
    Th17     -> TNFa
    TNFa  -> TNFR1
    TNFa  -> TNFR2
    TNFR1 -> TRADD
    TRADD -> IKK [label="amplify"]
    ADAM17 -> TNFa [label="shed"]
    TNFa  -> IL6
    IL1b  -> IL6
    IL17A -> IL6
    IL6   -> IL6R
    IL6R  -> JAK1_c
    JAK1_c -> STAT3_c
    STAT3_c -> RORgt [label="reinforce Th17"]
    IL6   -> CRP   [label="hepatic"]
    IL6   -> SAA
    IL6   -> Fibrinog
    IL6   -> Ferritin_n

    // IL-36 axis
    Keratino -> IL36g [label="autocrine"]
    Neutroph -> IL36g
    IL36g -> IL36R
    IL36R -> NFkB
    IL36Ra -> IL36R [arrowhead=tee color="#B22222"]
    IL36g -> IL8

    // ============================================================
    // EDGES — Cluster 6 (Tissue destruction)
    // ============================================================
    Neutroph -> Elastase
    Neutroph -> MMP9
    Neutroph -> MMP3
    MMP9 -> dermal_dest
    MMP2 -> dermal_dest
    MMP3 -> dermal_dest
    MMP10 -> dermal_dest
    Elastase -> dermal_dest
    Cathepsin -> dermal_dest
    TIMP1 -> MMP9 [label="(low)" arrowhead=tee color="#B22222"]
    ROS  -> KeratApop
    Elastase -> KeratApop
    NETcomp -> Endoth_dys
    ROS  -> Endoth_dys
    Endoth_dys -> Vasc_inj
    Vasc_inj -> Thromb
    Thromb   -> Ulcer
    KeratApop -> epi_loss
    epi_loss -> Ulcer
    dermal_dest -> Ulcer
    Ulcer -> Border_v
    Ulcer -> Pain_s
    Edema -> Ulcer
    Ulcer -> Bullous_v
    Ulcer -> Pustular_v
    Ulcer -> Vegetat_v
    Ulcer -> Periostom

    // ============================================================
    // EDGES — Cluster 7 (Healing failure)
    // ============================================================
    TGFb  -> myofib
    myofib -> col_dep
    VEGF_p -> Granul
    PDGF_p -> Granul
    TNFa  -> Epith_mig [label="impair" arrowhead=tee color="#B22222"]
    IL17A -> Epith_mig [arrowhead=tee color="#B22222"]
    Elastase -> Epith_mig [arrowhead=tee color="#B22222"]
    Granul -> Epith_mig
    Epith_mig -> Compl_he
    col_dep -> Scar
    Ulcer  -> WoundFD
    WoundFD -> Scar
    Compl_he -> Scar [label="cribriform"]

    // ============================================================
    // EDGES — Cluster 8 (Comorbid bridges feeding immunity)
    // ============================================================
    Gut_perm -> PAMP_bac [label="translocation"]
    Gut_perm -> TLR4
    Synovitis -> TNFa
    Clonal_h -> NeutBlood [label="↑ dysplastic"]
    MGUS_b -> NeutActiv [label="paraprotein"]
    Behcet_b -> NLRP3
    PAPA_b -> Pyrin
    PASH_b -> NLRP3
    Bowel_p -> PAMP_bac

    // ============================================================
    // EDGES — Cluster 9 (Drug effects)
    // ============================================================
    TopicalCS -> GR_recep
    TopicalTac -> CalcN
    Pred -> GR_recep
    IVMP -> GR_recep
    GR_recep -> NFkB [label="trans-rep" arrowhead=tee color="#B22222"]
    GR_recep -> AP1 [arrowhead=tee color="#B22222"]
    GR_recep -> IL1b [arrowhead=tee color="#B22222"]
    GR_recep -> TNFa [arrowhead=tee color="#B22222"]
    GR_recep -> IL6 [arrowhead=tee color="#B22222"]

    CsA  -> CalcN
    CalcN -> NFAT_p [label="dephos block" arrowhead=tee color="#B22222"]
    NFAT_p -> Th17 [label="↓ activation" arrowhead=tee color="#B22222"]
    NFAT_p -> IL2  [label="↓" arrowhead=tee color="#B22222"]

    IFX  -> TNFa [label="neutralize" arrowhead=tee color="#B22222"]
    ADA  -> TNFa [arrowhead=tee color="#B22222"]
    ETN  -> TNFa [arrowhead=tee color="#B22222"]
    GOLI -> TNFa [arrowhead=tee color="#B22222"]
    ANA  -> IL1b [label="IL-1R antagonist" arrowhead=tee color="#B22222"]
    ANA  -> IL1a [arrowhead=tee color="#B22222"]
    CANA -> IL1b [arrowhead=tee color="#B22222"]
    RILO -> IL1b [arrowhead=tee color="#B22222"]
    UST  -> IL12 [label="p40" arrowhead=tee color="#B22222"]
    UST  -> IL23 [arrowhead=tee color="#B22222"]
    GUSEL -> IL23 [label="p19" arrowhead=tee color="#B22222"]
    SECU -> IL17A [arrowhead=tee color="#B22222"]
    BRODA -> IL17RA [arrowhead=tee color="#B22222"]
    TCZ  -> IL6R [arrowhead=tee color="#B22222"]
    TOFA -> JAK1_c [arrowhead=tee color="#B22222"]
    TOFA -> JAK1_2 [arrowhead=tee color="#B22222"]
    UPADA -> JAK1_c [arrowhead=tee color="#B22222"]
    UPADA -> JAK1_2 [arrowhead=tee color="#B22222"]
    BARI -> JAK1_c [arrowhead=tee color="#B22222"]
    APRE -> TNFa [label="↓ via cAMP" arrowhead=tee color="#B22222"]
    APRE -> IL17A [arrowhead=tee color="#B22222"]
    AZA -> Neutroph [arrowhead=tee color="#B22222"]
    MMF -> Th17 [arrowhead=tee color="#B22222"]
    MTX_p -> TNFa [arrowhead=tee color="#B22222"]
    Dapsone_p -> Neutroph [label="↓ chemotaxis" arrowhead=tee color="#B22222"]
    Colchic -> Neutroph [label="microtubule" arrowhead=tee color="#B22222"]
    Colchic -> NLRP3 [arrowhead=tee color="#B22222"]
    IVIG -> C5a [arrowhead=tee color="#B22222"]
    IVIG -> Neutroph [arrowhead=tee color="#B22222"]
    Wcare -> Granul [label="optimal env"]

    // ============================================================
    // EDGES — Endpoints (Cluster 10)
    // ============================================================
    Ulcer    -> PARACELSUS
    UlcerArea -> PARACELSUS
    Border_v -> PARACELSUS
    Pain_VAS -> PARACELSUS
