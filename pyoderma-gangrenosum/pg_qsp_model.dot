    IL6      -> CRP_e
    Calprot_s -> Neutroph
    SAA      -> ESR
    NeutBlood -> WBC_p
    DAMP_S100 -> Calprot_s
    NeutActiv -> Calprot_s
    Ulcer    -> Relapse
    WoundFD  -> Relapse

    // Drug → endpoint shortcuts (efficacy arrows for graph clarity)
    IFX  -> Compl_he [style=dashed color="#000080" label="↑ healing"]
    ANA  -> Compl_he [style=dashed color="#000080"]
    CANA -> Compl_he [style=dashed color="#000080"]
    Pred -> Compl_he [style=dashed color="#000080"]
    CsA  -> Compl_he [style=dashed color="#000080"]
    UST  -> Compl_he [style=dashed color="#000080"]
    TOFA -> Compl_he [style=dashed color="#000080"]

    // Layout hints
    {rank=same; Pathergy; PSTPIP1; MEFV; NLRP3v}
    {rank=same; IL1b; TNFa; IL17A; IL6; IL23}
    {rank=same; PARACELSUS; UlcerArea; Compl_he; TimeHeal}
