  IGF1R -> Tongue_hyp [label="→ macroglossia" color="#d35400" fontcolor="#d35400"]
  GH_plasma -> Kidney_GFR [label="GFR↑\n(early)" color="#2980b9" fontcolor="#2980b9"]
  Liver_IGF1 -> IGF1_liver [label="production site" color="#27ae60" fontcolor="#27ae60"]

  // ============================================================
