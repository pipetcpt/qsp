digraph AcromegalyQSP {
  graph [
    label="Acromegaly QSP Model\nGH-Secreting Pituitary Adenoma: Pathophysiology, Pharmacology & Clinical Outcomes"
    labelloc=t labeljust=c fontsize=20 fontname="Helvetica-Bold"
    bgcolor="#1a1a2e" rankdir=TB splines=ortho nodesep=0.35 ranksep=0.6
    pad=0.6
  ]
  node [shape=box style="filled,rounded" fontname="Helvetica" fontsize=10 width=1.8 height=0.45]
  edge [fontname="Helvetica" fontsize=8 penwidth=1.1]

  // ============================================================
  // CLUSTER 1: HYPOTHALAMUS
  // ============================================================
  subgraph cluster_hypothalamus {
    label="Hypothalamus" fontsize=13 fontcolor="white"
    style=filled color="#16213e" fillcolor="#16213e"

    GHRH [label="GHRH\n(Growth Hormone-\nReleasing Hormone)" fillcolor="#4a90d9" fontcolor=white]
    Somatostatin_hypo [label="Somatostatin\n(SRIF)" fillcolor="#2ecc71" fontcolor=white]
    Ghrelin [label="Ghrelin\n(stomach / hypothal.)" fillcolor="#e67e22" fontcolor=white]
    Dopamine_hypo [label="Dopamine\n(tuberoinfundibular)" fillcolor="#9b59b6" fontcolor=white]
    TRH [label="TRH" fillcolor="#3498db" fontcolor=white]
    CRH [label="CRH" fillcolor="#3498db" fontcolor=white]
    Serotonin_inp [label="Serotonin\n(CNS input)" fillcolor="#e8d44d" fontcolor=black]
    Alpha_adren [label="α-Adrenergic\ninput" fillcolor="#e8d44d" fontcolor=black]
    Beta_adren [label="β-Adrenergic\ninput" fillcolor="#e8d44d" fontcolor=black]
    GHRH_R [label="GHRH-R\n(Gs-coupled)" fillcolor="#4a90d9" fontcolor=white shape=oval]
    SRIF_R_hypo [label="SSTR1-5\n(pituitary surface)" fillcolor="#2ecc71" fontcolor=white shape=oval]
    Ghrelin_R [label="GHSR-1a\n(ghrelin receptor)" fillcolor="#e67e22" fontcolor=white shape=oval]
  }

  // ============================================================
  // CLUSTER 2: PITUITARY ADENOMA
  // ============================================================
  subgraph cluster_adenoma {
    label="GH-Secreting Pituitary Adenoma (Somatotropinoma)" fontsize=13 fontcolor="white"
    style=filled color="#0f3460" fillcolor="#0f3460"

    Adenoma [label="Somatotroph\nAdenoma" fillcolor="#e74c3c" fontcolor=white shape=doubleoctagon]
    GNAS_mut [label="GNAS Mutation\n(Gsα R201H/C)\n~40% sporadic" fillcolor="#c0392b" fontcolor=white]
    cAMP_pit [label="cAMP↑\n(pituitary)" fillcolor="#f39c12" fontcolor=black]
    PKA_pit [label="PKA\nactivation" fillcolor="#f39c12" fontcolor=black]
    CREB_pit [label="CREB\nphosphorylation" fillcolor="#f39c12" fontcolor=black]
    Pit1_TF [label="Pit-1\nTranscription Factor" fillcolor="#8e44ad" fontcolor=white]
    SF1_TF [label="SF-1 (NR5A1)" fillcolor="#8e44ad" fontcolor=white]
    AIP_gene [label="AIP Gene\n(FIPA/familial)" fillcolor="#c0392b" fontcolor=white]
    MEN1_gene [label="MEN1 Mutation\n(MEN1 syndrome)" fillcolor="#c0392b" fontcolor=white]
    PRKACA_mut [label="PRKACA\nMutation (rare)" fillcolor="#c0392b" fontcolor=white]
    GH_gene [label="GH1 Gene\nTranscription" fillcolor="#e74c3c" fontcolor=white]
    Adenoma_vol [label="Adenoma Volume\n(cm³, MRI)" fillcolor="#e74c3c" fontcolor=white]
    VEGF_tumor [label="VEGF\n(tumor angiogenesis)" fillcolor="#e74c3c" fontcolor=white]
    Ki67_idx [label="Ki-67 Index\n(proliferation)" fillcolor="#c0392b" fontcolor=white]
    IGF1R_auto [label="IGF-1R\n(autocrine loop)" fillcolor="#e67e22" fontcolor=white shape=oval]
    Cyclin_D1 [label="Cyclin D1\n(cell cycle driver)" fillcolor="#c0392b" fontcolor=white]
    p27_Kip1 [label="p27/Kip1\n(CDK inhibitor)" fillcolor="#27ae60" fontcolor=white]
    Cavernous_inv [label="Cavernous Sinus\nInvasion (Knosp)" fillcolor="#922b21" fontcolor=white]
  }

  // ============================================================
  // CLUSTER 3: GH SIGNALING — JAK-STAT
  // ============================================================
  subgraph cluster_gh_signal {
    label="GH Secretion & JAK2-STAT5b Signaling" fontsize=13 fontcolor="white"
    style=filled color="#1a3a5c" fillcolor="#1a3a5c"

    GH_secretion [label="GH Secretion\n(pulsatile, adenoma)" fillcolor="#e74c3c" fontcolor=white]
    GH_plasma [label="GH Plasma\n(ng/mL)" fillcolor="#e74c3c" fontcolor=white]
    GH_pulse [label="GH Pulse\nGenerator\n(ultradian ~3 h)" fillcolor="#c0392b" fontcolor=white]
    GHR [label="GH Receptor\n(GHR / GH-BP)" fillcolor="#3498db" fontcolor=white shape=oval]
    GH_GHBP [label="GH Binding Protein\n(GHBP, 50% bound)" fillcolor="#3498db" fontcolor=white]
    JAK2 [label="JAK2 kinase" fillcolor="#f39c12" fontcolor=black]
    STAT5b [label="STAT5b\n(latent)" fillcolor="#f39c12" fontcolor=black]
    STAT5b_p [label="pSTAT5b\n(tyrosine-phos.)" fillcolor="#e67e22" fontcolor=white]
    STAT5b_dim [label="STAT5b Homodimer\n(nuclear)" fillcolor="#e67e22" fontcolor=white]
    SOCS2 [label="SOCS2\n(JAK-STAT\nneg. feedback)" fillcolor="#2ecc71" fontcolor=white]
    IGF1_gene_hep [label="IGF1 Gene\n(hepatic STAT5b\ntarget)" fillcolor="#27ae60" fontcolor=white]
    ERK_gh [label="ERK1/2\n(MAPK—GH)" fillcolor="#f39c12" fontcolor=black]
    IRS1_gh [label="IRS-1/IRS-2\n(GH path)" fillcolor="#f39c12" fontcolor=black]
    PI3K_gh [label="PI3K\n(GH path)" fillcolor="#f39c12" fontcolor=black]
    CIS_protein [label="CIS\n(STAT5 target,\nneg. FB)" fillcolor="#2ecc71" fontcolor=white]
  }

  // ============================================================
  // CLUSTER 4: IGF-1 SYSTEM
  // ============================================================
  subgraph cluster_igf1 {
    label="IGF-1 System & Downstream Signaling" fontsize=13 fontcolor="white"
    style=filled color="#1a3a4c" fillcolor="#1a3a4c"

    IGF1_liver [label="IGF-1 (liver)\nproduction ng/mL/h" fillcolor="#27ae60" fontcolor=white]
    IGF1_plasma [label="IGF-1 (plasma)\nng/mL" fillcolor="#27ae60" fontcolor=white]
    IGFBP1 [label="IGFBP-1\n(insulin regulated)" fillcolor="#16a085" fontcolor=white]
    IGFBP2 [label="IGFBP-2" fillcolor="#16a085" fontcolor=white]
    IGFBP3 [label="IGFBP-3\n(main carrier,\nSTAT5 target)" fillcolor="#1abc9c" fontcolor=white]
    IGFBP5 [label="IGFBP-5" fillcolor="#16a085" fontcolor=white]
    ALS [label="ALS\n(acid-labile subunit)" fillcolor="#1abc9c" fontcolor=white]
    Ternary_cpx [label="IGF1-IGFBP3-ALS\nTernary Complex\n(150 kDa, t½~15h)" fillcolor="#1abc9c" fontcolor=white]
    IGF1R [label="IGF-1 Receptor\n(IGF1R)" fillcolor="#27ae60" fontcolor=white shape=oval]
    IRS1_igf [label="IRS-1/IRS-2\n(IGF path)" fillcolor="#f39c12" fontcolor=black]
    PI3K_igf [label="PI3K\n(IGF path)" fillcolor="#f39c12" fontcolor=black]
    AKT [label="AKT/PKB" fillcolor="#e67e22" fontcolor=white]
    mTOR_igf [label="mTOR\n(protein synthesis)" fillcolor="#e67e22" fontcolor=white]
    ERK_igf [label="ERK1/2\n(IGF-MAPK)" fillcolor="#f39c12" fontcolor=black]
    Free_IGF1 [label="Free IGF-1\n(~1%, bioactive)" fillcolor="#2ecc71" fontcolor=white]
    PTEN [label="PTEN\n(PI3K inhibitor)" fillcolor="#2ecc71" fontcolor=white]
  }

  // ============================================================
  // CLUSTER 5: SOMATOSTATIN RECEPTOR SIGNALING
  // ============================================================
  subgraph cluster_sstr {
    label="Somatostatin Receptor Pharmacology" fontsize=13 fontcolor="white"
    style=filled color="#1c3340" fillcolor="#1c3340"

    SSTR1 [label="SSTR1\n(weak GH control)" fillcolor="#2ecc71" fontcolor=white shape=oval]
    SSTR2 [label="SSTR2\n(★ octreotide/\nlanreotide target)" fillcolor="#27ae60" fontcolor=white shape=oval]
    SSTR3 [label="SSTR3" fillcolor="#2ecc71" fontcolor=white shape=oval]
    SSTR4 [label="SSTR4" fillcolor="#2ecc71" fontcolor=white shape=oval]
    SSTR5 [label="SSTR5\n(★ pasireotide\nstronger affinity)" fillcolor="#16a085" fontcolor=white shape=oval]
    Gi_prot [label="Gᵢ Protein\ncoupling" fillcolor="#7f8c8d" fontcolor=white]
    AC_inhib [label="Adenylyl Cyclase↓\n(AC inhibition)" fillcolor="#7f8c8d" fontcolor=white]
    cAMP_dec [label="cAMP↓\n(somatotroph)" fillcolor="#2ecc71" fontcolor=white]
    VGCC_inhib [label="VGCC Ca²⁺\nchannel↓" fillcolor="#7f8c8d" fontcolor=white]
    K_chan_act [label="K⁺ channel\nactivation\n(hyperpolarization)" fillcolor="#7f8c8d" fontcolor=white]
    PTP_act [label="Protein Tyrosine\nPhosphatase↑" fillcolor="#7f8c8d" fontcolor=white]
    GH_exo_block [label="GH Exocytosis\n↓↓ (50-70%)" fillcolor="#e74c3c" fontcolor=white]
    SSTR_desensit [label="SSTR2\nDesensitization\n(internalization)" fillcolor="#95a5a6" fontcolor=black]
  }

  // ============================================================
  // CLUSTER 6: DRUG PK/PD
  // ============================================================
  subgraph cluster_drugs {
    label="Pharmacotherapy — PK/PD Mechanisms" fontsize=13 fontcolor="white"
    style=filled color="#2c1654" fillcolor="#2c1654"

    Oct_LAR [label="Octreotide LAR\n10/20/30 mg IM q28d\nSSA 1st gen" fillcolor="#8e44ad" fontcolor=white]
    Lan_AG [label="Lanreotide\nAutogel\n60/90/120 mg SC q28d" fillcolor="#9b59b6" fontcolor=white]
    Pas_LAR [label="Pasireotide LAR\n40/60 mg IM q28d\nSSA (multireceptor)" fillcolor="#6c3483" fontcolor=white]
    Peg_drug [label="Pegvisomant\n(PEGylated GH\nanalog)\n10-30 mg SC/d" fillcolor="#1a5276" fontcolor=white]
    Cab_drug [label="Cabergoline\n(D2 agonist)\n0.5-3.5 mg/wk\n~30% IGF-1 norm" fillcolor="#154360" fontcolor=white]
    Surgery_tx [label="Transsphenoidal\nSurgery\n(1st line, curative\nintent)" fillcolor="#7b241c" fontcolor=white]
    Radiotherapy_tx [label="Stereotactic\nRadiosurgery (SRS)\n(adjunct/salvage)" fillcolor="#7b241c" fontcolor=white]
    Depot_SSA [label="SSA Depot\n(injection site\nabsorption)" fillcolor="#8e44ad" fontcolor=white shape=trapezium]
    Central_SSA [label="SSA Central\nCompartment\n(plasma)" fillcolor="#9b59b6" fontcolor=white shape=trapezium]
    Periph_SSA [label="SSA Peripheral\nCompartment\n(tissue)" fillcolor="#9b59b6" fontcolor=white shape=trapezium]
    Peg_central [label="Pegvisomant\nCentral\nCompartment" fillcolor="#1a5276" fontcolor=white shape=trapezium]
    Peg_tissue [label="Pegvisomant\nTissue\nCompartment" fillcolor="#1a5276" fontcolor=white shape=trapezium]
    D2R_pit [label="D2 Receptor\n(pituitary)" fillcolor="#154360" fontcolor=white shape=oval]
    SSA_efflux [label="SSA Elimination\n(biliary/hepatic\nCL ~9 L/h)" fillcolor="#7f8c8d" fontcolor=white]
  }

  // ============================================================
  // CLUSTER 7: TARGET ORGANS & COMPLICATIONS
  // ============================================================
  subgraph cluster_organs {
    label="Target Organs & Systemic Complications" fontsize=13 fontcolor="white"
    style=filled color="#0d2b1e" fillcolor="#0d2b1e"

    Bone [label="Bone\n(periosteum)" fillcolor="#784212" fontcolor=white]
    Periosteal [label="Periosteal\nExpansion\n(hands/feet/skull)" fillcolor="#784212" fontcolor=white]
    Arthropathy [label="Arthropathy\n(cartilage damage)" fillcolor="#6e2f1a" fontcolor=white]
    Carpal_tunnel [label="Carpal Tunnel\nSyndrome" fillcolor="#6e2f1a" fontcolor=white]
    Heart [label="Heart\n(myocardium)" fillcolor="#c0392b" fontcolor=white]
    LVH [label="LV Hypertrophy\n(LV mass index\ng/m²)" fillcolor="#c0392b" fontcolor=white]
    Cardiomyop [label="Acromegalic\nCardiomyopathy" fillcolor="#c0392b" fontcolor=white]
    Arrhythmia [label="Arrhythmia\n(AF, VT risk ↑)" fillcolor="#c0392b" fontcolor=white]
    Upper_airway [label="Upper Airway\nSoft Tissue\nHypertrophy" fillcolor="#2980b9" fontcolor=white]
    Sleep_apnea [label="Sleep Apnea\n(OSA+CSA, 50-80%)" fillcolor="#2980b9" fontcolor=white]
    Colon_mucosa [label="Colon\n(mucosa)" fillcolor="#d35400" fontcolor=white]
    Colon_polyp [label="Colonic Polyps\n(adenomatous 2-3×)" fillcolor="#d35400" fontcolor=white]
    Liver_IGF1 [label="Liver\n(IGF-1 factory)" fillcolor="#27ae60" fontcolor=white]
    Kidney_GFR [label="Kidney GFR↑\n(early/hyperfilt.)" fillcolor="#2980b9" fontcolor=white]
    Skin_acral [label="Skin/Soft Tissue\n(acral changes)" fillcolor="#d35400" fontcolor=white]
    Pituitary_norm [label="Normal Pituitary\n(compressed)" fillcolor="#7f8c8d" fontcolor=white]
    Hypopituit [label="Hypopituitarism\n(gonadal/thyroid/\nadrenal axes)" fillcolor="#7f8c8d" fontcolor=white]
    Tongue_hyp [label="Macroglossia\nVoice changes" fillcolor="#d35400" fontcolor=white]
  }

  // ============================================================
  // CLUSTER 8: METABOLIC EFFECTS
  // ============================================================
  subgraph cluster_metab {
    label="Metabolic & Endocrine Effects" fontsize=13 fontcolor="white"
    style=filled color="#1a2518" fillcolor="#1a2518"

    Insulin_res [label="Insulin\nResistance\n(direct GH effect)" fillcolor="#e67e22" fontcolor=white]
    Glucose_fast [label="Fasting\nGlucose↑" fillcolor="#e67e22" fontcolor=white]
    HbA1c_met [label="HbA1c↑" fillcolor="#e67e22" fontcolor=white]
    T2DM_risk [label="T2DM\n(30-56%\nof patients)" fillcolor="#e67e22" fontcolor=white]
    Lipolysis_met [label="Lipolysis↑\n(FFA↑, GH direct)" fillcolor="#f39c12" fontcolor=black]
    TG_serum [label="Serum TG\n(variable)" fillcolor="#f39c12" fontcolor=black]
    Cortisol_stress [label="Cortisol\n(anti-insulin)" fillcolor="#f39c12" fontcolor=black]
    Phos_renal [label="Renal PO₄\nreabsorption↑" fillcolor="#3498db" fontcolor=white]
    Ca_absorb [label="Ca²⁺ Absorption↑\n(IGF-1→1,25-D₃)" fillcolor="#3498db" fontcolor=white]
    Pas_hyper [label="Pasireotide-\nInduced\nHyperglycemia\n(inhibits GLP-1/GIP)" fillcolor="#c0392b" fontcolor=white]
    IGF1_ins_xt [label="IGF-1/Insulin\nCrosstalk\n(partial sensitiz.)" fillcolor="#27ae60" fontcolor=white]
    Adiponect [label="Adiponectin↓" fillcolor="#e67e22" fontcolor=white]
    Leptin_met [label="Leptin\n(variable)" fillcolor="#e67e22" fontcolor=white]
  }

  // ============================================================
  // CLUSTER 9: CLINICAL ENDPOINTS
  // ============================================================
  subgraph cluster_endpoints {
    label="Clinical Endpoints & Disease Activity" fontsize=13 fontcolor="white"
    style=filled color="#1a1a2e" fillcolor="#1a1a2e"

    GH_nadir [label="GH Nadir (OGTT)\n<1 ng/mL\n= biochemical cure" fillcolor="#27ae60" fontcolor=white]
    IGF1_norm [label="IGF-1\nNormalization\n(age/sex SDS ≤2)" fillcolor="#27ae60" fontcolor=white]
    Remission [label="Biochemical\nREMISSION\n(GH+IGF-1 ctrl)" fillcolor="#27ae60" fontcolor=white shape=doubleoctagon]
    Active_dis [label="ACTIVE\nAcromegaly\n(ongoing excess)" fillcolor="#e74c3c" fontcolor=white shape=doubleoctagon]
    Tumor_ctrl [label="Tumor\nControl\n(stable/shrinkage)" fillcolor="#8e44ad" fontcolor=white]
    Headache_s [label="Headache\nSeverity" fillcolor="#7f8c8d" fontcolor=white]
    Visual_fld [label="Visual Field\nDefect\n(bitemporal)" fillcolor="#7f8c8d" fontcolor=white]
    Acral_score [label="Acral Changes\nScore\n(ring/shoe size)" fillcolor="#d35400" fontcolor=white]
    CV_mort [label="CV Mortality↑\n(SMR 1.3-2.0)" fillcolor="#c0392b" fontcolor=white]
    QoL [label="Quality of Life\n(AcroQoL score)" fillcolor="#27ae60" fontcolor=white]
    Recurrence [label="Recurrence\n(post-surgery\n~30%)" fillcolor="#e74c3c" fontcolor=white]
    Remission_rate [label="Remission Rate\n(surgery: 60-85%\nSSA: 25-45%)" fillcolor="#27ae60" fontcolor=white]
  }

  // ============================================================
  // CLUSTER 10: BIOMARKERS & MONITORING
  // ============================================================
  subgraph cluster_biomarkers {
    label="Biomarkers & Clinical Monitoring" fontsize=13 fontcolor="white"
    style=filled color="#1a1530" fillcolor="#1a1530"

    Ser_GH [label="Serum GH\n(random, ng/mL)" fillcolor="#e74c3c" fontcolor=white]
    OGTT_GH [label="OGTT GH\n(75 g glucose\nsuppression)" fillcolor="#e74c3c" fontcolor=white]
    Ser_IGF1 [label="Serum IGF-1\n(ng/mL, SDS)" fillcolor="#27ae60" fontcolor=white]
    Ser_IGFBP3 [label="Serum IGFBP-3\n(ng/mL)" fillcolor="#1abc9c" fontcolor=white]
    MRI_pit [label="Pituitary MRI\n(tumor size/\ninvasion grade)" fillcolor="#8e44ad" fontcolor=white]
    Echo_bm [label="Echocardiogram\n(LV mass,\nEF, diastolic)" fillcolor="#c0392b" fontcolor=white]
    HbA1c_bm [label="HbA1c (%)\n(metabolic)" fillcolor="#e67e22" fontcolor=white]
    Colonoscopy_bm [label="Colonoscopy\n(polyp surveillance\nq5yr)" fillcolor="#d35400" fontcolor=white]
    Bone_den [label="DEXA\n(BMD, T/Z-score)" fillcolor="#784212" fontcolor=white]
    GH_AUC [label="GH 24-h AUC\n(profile area)" fillcolor="#e74c3c" fontcolor=white]
    Acro_score [label="Acromegaly\nActivity Score\n(composite)" fillcolor="#e74c3c" fontcolor=white]
    Liver_fn [label="Liver Function\n(pegvisomant\nmonitoring)" fillcolor="#27ae60" fontcolor=white]
    Sleep_study [label="Polysomnography\n(AHI, SpO₂)" fillcolor="#2980b9" fontcolor=white]
  }

  // ============================================================
  // EDGES — Hypothalamus to Pituitary
  // ============================================================
  GHRH -> GHRH_R [label="binds" color="#4a90d9" fontcolor="#4a90d9"]
  GHRH_R -> cAMP_pit [label="Gsα → AC↑" color="#4a90d9" fontcolor="#4a90d9"]
  Somatostatin_hypo -> SRIF_R_hypo [label="binds\n(inhibits)" color="#2ecc71" fontcolor="#2ecc71"]
  Ghrelin -> Ghrelin_R [label="binds" color="#e67e22" fontcolor="#e67e22"]
  Ghrelin_R -> GH_secretion [label="↑ GH release" color="#e67e22" fontcolor="#e67e22"]
  Dopamine_hypo -> D2R_pit [label="binds" color="#9b59b6" fontcolor="#9b59b6"]
  Serotonin_inp -> GH_secretion [label="stimulates" color="#e8d44d" fontcolor="#e8d44d"]
  Alpha_adren -> GH_secretion [label="stimulates" color="#e8d44d" fontcolor="#e8d44d"]
  Beta_adren -> GH_secretion [label="may inhibit" color="#e8d44d" fontcolor="#e8d44d" style=dashed]

  // ============================================================
  // EDGES — Adenoma genetics & signaling
  // ============================================================
  GNAS_mut -> cAMP_pit [label="constitutive\nGsα activation" color="#c0392b" fontcolor="#c0392b" style=bold penwidth=2]
  cAMP_pit -> PKA_pit [label="activates" color="#f39c12" fontcolor="#f39c12"]
  PKA_pit -> CREB_pit [label="phosphorylates" color="#f39c12" fontcolor="#f39c12"]
  CREB_pit -> GH_gene [label="→ transcription" color="#e74c3c" fontcolor="#e74c3c"]
  Pit1_TF -> GH_gene [label="activates" color="#8e44ad" fontcolor="#8e44ad"]
  AIP_gene -> Adenoma [label="loss-of-function\n→ tumor formation" color="#c0392b" fontcolor="#c0392b" style=dashed]
  MEN1_gene -> Adenoma [label="loss-of-function\n→ tumor formation" color="#c0392b" fontcolor="#c0392b" style=dashed]
  PRKACA_mut -> cAMP_pit [label="direct PKA\nactivation" color="#c0392b" fontcolor="#c0392b" style=dashed]
  GH_gene -> GH_secretion [label="→ GH protein\nsynthesis" color="#e74c3c" fontcolor="#e74c3c"]
  GHRH_R -> cAMP_pit [label="normally Gsα" color="#4a90d9" fontcolor="#4a90d9"]
  Adenoma -> Adenoma_vol [label="defines size" color="#e74c3c" fontcolor="#e74c3c"]
  VEGF_tumor -> Adenoma [label="angiogenesis\nsupport" color="#e74c3c" fontcolor="#e74c3c"]
  Ki67_idx -> Adenoma_vol [label="reflects\nproliferation rate" color="#c0392b" fontcolor="#c0392b"]
  Cyclin_D1 -> Adenoma [label="drives G1→S\ncell cycle" color="#c0392b" fontcolor="#c0392b"]
  p27_Kip1 -> Cyclin_D1 [label="inhibits" color="#27ae60" fontcolor="#27ae60" style=dashed]
  Adenoma_vol -> Cavernous_inv [label="macroadenoma\n→ invasion" color="#922b21" fontcolor="#922b21"]

  // ============================================================
  // EDGES — GH secretion & JAK-STAT
  // ============================================================
  GH_secretion -> GH_plasma [label="→ circulation" color="#e74c3c" fontcolor="#e74c3c"]
  GH_pulse -> GH_secretion [label="governs\npulse rhythm\n(~3 h ultradian)" color="#c0392b" fontcolor="#c0392b"]
  GH_plasma -> GHR [label="binds (2:1\ndimer)" color="#3498db" fontcolor="#3498db"]
  GH_plasma -> GH_GHBP [label="~50% bound\n(circulation)" color="#3498db" fontcolor="#3498db"]
  GHR -> JAK2 [label="trans-\nphosphorylates" color="#f39c12" fontcolor="#f39c12"]
  JAK2 -> STAT5b [label="phosphorylates\n(Y699)" color="#f39c12" fontcolor="#f39c12"]
  STAT5b -> STAT5b_p [label="pSTAT5b" color="#e67e22" fontcolor="#e67e22"]
  STAT5b_p -> STAT5b_dim [label="dimerizes\n→ nucleus" color="#e67e22" fontcolor="#e67e22"]
  STAT5b_dim -> IGF1_gene_hep [label="→ hepatic IGF1\ntranscription" color="#27ae60" fontcolor="#27ae60"]
  STAT5b_dim -> SOCS2 [label="induces" color="#2ecc71" fontcolor="#2ecc71"]
  STAT5b_dim -> CIS_protein [label="induces\n(neg. FB)" color="#2ecc71" fontcolor="#2ecc71"]
  SOCS2 -> JAK2 [label="inhibits\n(neg. FB)" color="#2ecc71" fontcolor="#2ecc71" style=dashed arrowhead=tee]
  CIS_protein -> STAT5b_p [label="dephosphorylates\n(neg. FB)" color="#2ecc71" fontcolor="#2ecc71" style=dashed arrowhead=tee]
  JAK2 -> ERK_gh [label="→ MAPK\npath" color="#f39c12" fontcolor="#f39c12"]
  JAK2 -> IRS1_gh [label="→ IRS1" color="#f39c12" fontcolor="#f39c12"]
  IRS1_gh -> PI3K_gh [label="→" color="#f39c12" fontcolor="#f39c12"]

  // ============================================================
  // EDGES — IGF-1 system
  // ============================================================
  IGF1_gene_hep -> IGF1_liver [label="production" color="#27ae60" fontcolor="#27ae60"]
  IGF1_liver -> IGF1_plasma [label="secretion\n→ portal" color="#27ae60" fontcolor="#27ae60"]
  IGF1_plasma -> IGFBP3 [label="binds (73%)" color="#1abc9c" fontcolor="#1abc9c"]
  IGF1_plasma -> IGFBP1 [label="binds" color="#16a085" fontcolor="#16a085"]
  IGF1_plasma -> IGFBP2 [label="binds" color="#16a085" fontcolor="#16a085"]
  IGF1_plasma -> IGFBP5 [label="binds" color="#16a085" fontcolor="#16a085"]
  IGFBP3 -> ALS [label="+ ALS tertiary\ncomplexation" color="#1abc9c" fontcolor="#1abc9c"]
  ALS -> Ternary_cpx [label="forms 150 kDa\ncomplex" color="#1abc9c" fontcolor="#1abc9c"]
  IGF1_plasma -> Free_IGF1 [label="~1% free\n(bioactive)" color="#2ecc71" fontcolor="#2ecc71"]
  Free_IGF1 -> IGF1R [label="binds (high\naff. <1 nM)" color="#27ae60" fontcolor="#27ae60"]
  IGF1R -> IRS1_igf [label="→ IRS1/2" color="#f39c12" fontcolor="#f39c12"]
  IRS1_igf -> PI3K_igf [label="→" color="#f39c12" fontcolor="#f39c12"]
  PI3K_igf -> AKT [label="→ PI(3,4,5)P₃" color="#e67e22" fontcolor="#e67e22"]
  PTEN -> PI3K_igf [label="inhibits" color="#2ecc71" fontcolor="#2ecc71" style=dashed arrowhead=tee]
  AKT -> mTOR_igf [label="→ mTORC1\ngrowth" color="#e67e22" fontcolor="#e67e22"]
  Free_IGF1 -> ERK_igf [label="→ RAS-MAPK\npath" color="#f39c12" fontcolor="#f39c12"]
  IGF1_plasma -> GH_secretion [label="long-loop\nneg. FB (–)" color="#27ae60" fontcolor="#27ae60" style=dashed arrowhead=tee penwidth=2]
  Free_IGF1 -> IGF1R_auto [label="autocrine\npituitary" color="#e67e22" fontcolor="#e67e22"]
  IGF1R_auto -> Adenoma [label="autocrine\ngrowth support" color="#e67e22" fontcolor="#e67e22"]

  // ============================================================
  // EDGES — SSTR signaling
  // ============================================================
  SRIF_R_hypo -> SSTR2 [label="same receptor\nfamily" color="#2ecc71" fontcolor="#2ecc71" style=dashed]
  SSTR2 -> Gi_prot [label="couples\n(Gᵢ)" color="#27ae60" fontcolor="#27ae60"]
  SSTR5 -> Gi_prot [label="couples\n(Gᵢ/Gz)" color="#16a085" fontcolor="#16a085"]
  Gi_prot -> AC_inhib [label="inhibits\nadenylyl cyclase" color="#7f8c8d" fontcolor="#7f8c8d"]
  AC_inhib -> cAMP_dec [label="→" color="#2ecc71" fontcolor="#2ecc71"]
  cAMP_dec -> GH_exo_block [label="↓ GH\nexocytosis" color="#e74c3c" fontcolor="#e74c3c"]
  Gi_prot -> VGCC_inhib [label="inhibits\nVGCC" color="#7f8c8d" fontcolor="#7f8c8d"]
  VGCC_inhib -> GH_exo_block [label="Ca²⁺↓\n→ GH↓" color="#e74c3c" fontcolor="#e74c3c"]
  Gi_prot -> K_chan_act [label="→ GIRK\nchannels" color="#7f8c8d" fontcolor="#7f8c8d"]
  K_chan_act -> GH_exo_block [label="hyperpolariz.\n→ GH↓" color="#e74c3c" fontcolor="#e74c3c"]
  SSTR2 -> PTP_act [label="→ SHP-1/SHP-2" color="#27ae60" fontcolor="#27ae60"]
  PTP_act -> GH_exo_block [label="→" color="#e74c3c" fontcolor="#e74c3c"]
  GH_exo_block -> GH_secretion [label="inhibits\n(–) 50-70%" color="#2ecc71" fontcolor="#2ecc71" style=dashed arrowhead=tee penwidth=2]
  GH_exo_block -> SSTR_desensit [label="chronic exposure\n→ receptor\ndownregulation" color="#95a5a6" fontcolor="#95a5a6" style=dashed]

  // ============================================================
  // EDGES — Drug PK/PD
  // ============================================================
  Oct_LAR -> Depot_SSA [label="IM microspheres\n(PLGA matrix)" color="#8e44ad" fontcolor="#8e44ad"]
  Lan_AG -> Depot_SSA [label="SC nanotube\nself-assembly" color="#9b59b6" fontcolor="#9b59b6"]
  Pas_LAR -> Depot_SSA [label="IM microspheres\n(PLGA)" color="#6c3483" fontcolor="#6c3483"]
  Depot_SSA -> Central_SSA [label="ka (slow\nzero-order\nrelease ~2 wk)" color="#9b59b6" fontcolor="#9b59b6"]
