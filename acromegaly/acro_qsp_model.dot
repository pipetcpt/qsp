  Peg_tissue -> Peg_central [label="redistribution" color="#1a5276" fontcolor="#1a5276"]
  Peg_central -> GHR [label="competitive\nantagonist\n(blocks GH binding)" color="#1a5276" fontcolor="#1a5276" style=bold penwidth=2 arrowhead=tee]
  D2R_pit -> cAMP_pit [label="Gᵢ → cAMP↓\n(GH↓ ~20%)" color="#154360" fontcolor="#154360"]
  Cab_drug -> D2R_pit [label="D2 agonist" color="#154360" fontcolor="#154360"]
  Surgery_tx -> Adenoma [label="removes\n(curative intent)" color="#7b241c" fontcolor="#7b241c" style=bold penwidth=2]
  Radiotherapy_tx -> Adenoma [label="kills cells\n(slow, years)" color="#7b241c" fontcolor="#7b241c"]

  // ============================================================
  // EDGES — Target organs
  // ============================================================
  IGF1R -> Bone [label="stimulates\nperiosteal OBs" color="#784212" fontcolor="#784212"]
