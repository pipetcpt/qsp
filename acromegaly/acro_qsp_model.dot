  Periph_SSA -> Central_SSA [label="redistribution" color="#9b59b6" fontcolor="#9b59b6"]
  Central_SSA -> SSA_efflux [label="CL ~9 L/h\n(hepatic/biliary)" color="#7f8c8d" fontcolor="#7f8c8d"]
