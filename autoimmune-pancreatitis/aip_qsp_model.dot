digraph AIP_QSP_Model {
    // =========================================================
    // Autoimmune Pancreatitis (AIP) — QSP Mechanistic Map
    // Quantitative Systems Pharmacology Model
    // Nodes: 110+  |  Clusters: 10  |  rankdir: TB
    // =========================================================

    graph [
        label       = "Autoimmune Pancreatitis (AIP) — QSP Mechanistic Map\nIgG4-Related Disease Pancreatic Module with PK/PD Drug Compartments"
        labelloc    = t
        labeljust   = c
        fontsize    = 22
        fontname    = "Helvetica-Bold"
        bgcolor     = "#FAFAFA"
        splines     = ortho
        nodesep     = 0.55
        ranksep     = 0.75
        rankdir     = TB
        compound    = true
    ]

    node [fontname="Helvetica" fontsize=10]
    edge [fontname="Helvetica" fontsize=9]

    // =========================================================
    // CLUSTER 0 — Antigenic Triggers & Innate Immune Activation
    // =========================================================
    subgraph cluster_innate {
        label       = "Innate Immune Activation & Antigen Presentation"
        style       = filled
        fillcolor   = "#FFF3E0"
        color       = "#E65100"
        fontsize    = 13
        fontcolor   = "#E65100"

        // Antigens
        Lactoferrin     [label="Lactoferrin\n(self-antigen)"    shape=ellipse style=filled fillcolor=salmon]
        CA_II           [label="Carbonic\nAnhydrase II"          shape=ellipse style=filled fillcolor=salmon]
        PBP             [label="Pancreatic\nSecretory Trypsin\nInhibitor (PSTI)"  shape=ellipse style=filled fillcolor=salmon]
        Plasminogen     [label="Plasminogen\nBinding Protein"   shape=ellipse style=filled fillcolor=salmon]

        // PRRs
        TLR3            [label="TLR3"  shape=ellipse style=filled fillcolor="#FFCCBC"]
        TLR4            [label="TLR4"  shape=ellipse style=filled fillcolor="#FFCCBC"]
        TLR7            [label="TLR7"  shape=ellipse style=filled fillcolor="#FFCCBC"]
        TLR9            [label="TLR9"  shape=ellipse style=filled fillcolor="#FFCCBC"]
        NLR_NLRP3       [label="NLRP3\nInflammasome"  shape=ellipse style=filled fillcolor="#FFCCBC"]

        // Innate cells
        DC_immature     [label="Immature\nDendritic Cell"   shape=box style=filled fillcolor=lightblue]
        DC_mature       [label="Mature DC\n(CD83+/CD86+)"  shape=box style=filled fillcolor=lightblue]
        Macrophage_M0   [label="Macrophage\n(M0)"          shape=box style=filled fillcolor=lightblue]
        Macrophage_M1   [label="M1 Macrophage\n(pro-inflam)" shape=box style=filled fillcolor="#BBDEFB"]
        Macrophage_M2   [label="M2 Macrophage\n(anti-inflam)" shape=box style=filled fillcolor="#BBDEFB"]
        Neutrophil      [label="Neutrophil"                shape=box style=filled fillcolor=lightblue]
        pDC             [label="Plasmacytoid DC\n(IFN-α producer)" shape=box style=filled fillcolor=lightblue]

        // MHC / HLA
        HLA_DRB1        [label="HLA-DRB1*0405\n(AIP risk allele)"  shape=ellipse style=filled fillcolor="#FFAB91"]
        MHC_II          [label="MHC Class II\nPeptide Complex"     shape=ellipse style=filled fillcolor="#FFAB91"]
        CTLA4_T         [label="CTLA-4\n(Treg co-inhibitory)"      shape=ellipse style=filled fillcolor="#FFAB91"]
    }

    // =========================================================
    // CLUSTER 1 — T Cell Differentiation
    // =========================================================
    subgraph cluster_tcell {
        label       = "T Cell Differentiation & Cytokine Network"
        style       = filled
        fillcolor   = "#E3F2FD"
        color       = "#1565C0"
        fontsize    = 13
        fontcolor   = "#1565C0"

        // Naive
        Tcell_naive     [label="Naïve CD4+\nT Cell"     shape=box style=filled fillcolor=lightblue]
        Tcell_CD8       [label="CD8+ CTL"               shape=box style=filled fillcolor=lightblue]

        // Effector subsets
        Th1             [label="Th1 Cell"               shape=box style=filled fillcolor="#90CAF9"]
        Th2             [label="Th2 Cell"               shape=box style=filled fillcolor="#90CAF9"]
        Th17            [label="Th17 Cell"              shape=box style=filled fillcolor="#90CAF9"]
        Treg            [label="Treg Cell\n(FOXP3+)"    shape=box style=filled fillcolor="#B3E5FC"]
        Tfh             [label="Tfh Cell\n(CXCR5+)"    shape=box style=filled fillcolor="#90CAF9"]

        // Cytokines
        IFN_gamma       [label="IFN-γ"     shape=ellipse style=filled fillcolor=lightgreen]
        IL_4            [label="IL-4"      shape=ellipse style=filled fillcolor=lightgreen]
        IL_5            [label="IL-5"      shape=ellipse style=filled fillcolor=lightgreen]
        IL_10           [label="IL-10"     shape=ellipse style=filled fillcolor=lightgreen]
        IL_13           [label="IL-13"     shape=ellipse style=filled fillcolor=lightgreen]
        IL_17           [label="IL-17A"    shape=ellipse style=filled fillcolor=lightgreen]
        IL_21           [label="IL-21"     shape=ellipse style=filled fillcolor=lightgreen]
        IL_6            [label="IL-6"      shape=ellipse style=filled fillcolor=lightgreen]
        IL_33           [label="IL-33\n(alarmins)"     shape=ellipse style=filled fillcolor=lightgreen]
        TGF_beta        [label="TGF-β"    shape=ellipse style=filled fillcolor=lightgreen]
        TNF_alpha       [label="TNF-α"    shape=ellipse style=filled fillcolor=lightgreen]
        IL_2            [label="IL-2"      shape=ellipse style=filled fillcolor=lightgreen]
        IL_12           [label="IL-12"     shape=ellipse style=filled fillcolor=lightgreen]
        IL_23           [label="IL-23"     shape=ellipse style=filled fillcolor=lightgreen]

        // T cell transcription factors
        STAT4           [label="STAT4\n(Th1 TF)"    shape=ellipse style=filled fillcolor="#C8E6C9"]
        STAT6           [label="STAT6\n(Th2 TF)"    shape=ellipse style=filled fillcolor="#C8E6C9"]
        RORgt           [label="RORγt\n(Th17 TF)"   shape=ellipse style=filled fillcolor="#C8E6C9"]
        FOXP3           [label="FOXP3\n(Treg TF)"   shape=ellipse style=filled fillcolor="#C8E6C9"]
        BCL6            [label="BCL-6\n(Tfh TF)"    shape=ellipse style=filled fillcolor="#C8E6C9"]
    }

    // =========================================================
    // CLUSTER 2 — B Cell Activation & IgG4 Class Switching
    // =========================================================
    subgraph cluster_bcell {
        label       = "B Cell Activation, GC Reaction & IgG4 Class Switching"
        style       = filled
        fillcolor   = "#F3E5F5"
        color       = "#6A1B9A"
        fontsize    = 13
        fontcolor   = "#6A1B9A"

        Bcell_naive     [label="Naïve B Cell"          shape=box style=filled fillcolor="#CE93D8"]
        GC_Bcell        [label="Germinal Center\nB Cell"         shape=box style=filled fillcolor="#BA68C8"]
        Memory_Bcell    [label="Memory B Cell\n(IgG4+)"          shape=box style=filled fillcolor="#BA68C8"]
        PlasmaBcell     [label="IgG4+ Plasma Cell\n(long-lived)" shape=box style=filled fillcolor="#9C27B0"]
        PC_short        [label="Short-lived\nPlasma Cell"        shape=box style=filled fillcolor="#CE93D8"]

        // B cell surface / survival signals
        CD20            [label="CD20\n(B cell marker)"    shape=ellipse style=filled fillcolor="#E1BEE7"]
        BAFF            [label="BAFF\n(BLyS)"             shape=ellipse style=filled fillcolor="#E1BEE7"]
        APRIL           [label="APRIL"                    shape=ellipse style=filled fillcolor="#E1BEE7"]
        BAFF_R          [label="BAFF-R\n(on B cell)"      shape=ellipse style=filled fillcolor="#E1BEE7"]
        FcgRIIb         [label="FcγRIIb\n(inhibitory FcR)" shape=ellipse style=filled fillcolor="#E1BEE7"]
        AID             [label="AID\n(class switch recomb)" shape=ellipse style=filled fillcolor="#E1BEE7"]
        IgG4_serum      [label="Serum IgG4\n(biomarker)"  shape=ellipse style=filled fillcolor="#9C27B0" fontcolor=white]
        IgG1            [label="IgG1\n(complement-fixing)" shape=ellipse style=filled fillcolor="#E1BEE7"]
        IgE             [label="IgE"                       shape=ellipse style=filled fillcolor="#E1BEE7"]

        // GC reaction elements
        FDC             [label="Follicular DC\n(FDC)"      shape=box style=filled fillcolor="#CE93D8"]
        SHM             [label="Somatic\nHypermutation"    shape=diamond style=filled fillcolor="#E1BEE7"]
        CSR_IgG4        [label="Class Switch\nRecombination\n(→ IgG4)"  shape=diamond style=filled fillcolor="#AB47BC"]
    }

    // =========================================================
    // CLUSTER 3 — IgG4 Effector Mechanisms & Complement
    // =========================================================
    subgraph cluster_effector {
        label       = "IgG4 Effector Mechanisms & Complement Pathway"
        style       = filled
        fillcolor   = "#FCE4EC"
        color       = "#880E4F"
        fontsize    = 13
        fontcolor   = "#880E4F"

        IgG4_IC         [label="IgG4 Immune\nComplexes"           shape=ellipse style=filled fillcolor="#F48FB1"]
        IgG4_Fab2       [label="IgG4 Fab2\nArm Exchange\n(asymmetric)" shape=diamond style=filled fillcolor="#F48FB1"]
        FcRn            [label="FcRn\n(IgG recycling)"            shape=ellipse style=filled fillcolor="#F8BBD0"]
        FcgR_eff        [label="FcγR (effector)\non macrophages"  shape=ellipse style=filled fillcolor="#F8BBD0"]

        // Complement (limited activation by IgG4)
        C1q             [label="C1q"    shape=ellipse style=filled fillcolor="#FFCDD2"]
        C3              [label="C3"     shape=ellipse style=filled fillcolor="#FFCDD2"]
        C4              [label="C4"     shape=ellipse style=filled fillcolor="#FFCDD2"]
        C3b             [label="C3b\n(opsonin)"   shape=ellipse style=filled fillcolor="#FFCDD2"]
        MAC             [label="MAC\n(C5b-9)"     shape=ellipse style=filled fillcolor="#EF9A9A"]
        C3a_C5a         [label="C3a/C5a\n(anaphylatoxins)" shape=ellipse style=filled fillcolor="#FFCDD2"]
        Comp_inhib      [label="Complement\nInhibition\n(by IgG4)"  shape=diamond style=filled fillcolor="#EF9A9A"]
    }

    // =========================================================
    // CLUSTER 4 — Pancreatic Pathology
    // =========================================================
    subgraph cluster_pancreas {
        label       = "Pancreatic Pathology: Duct, Exocrine & Endocrine"
        style       = filled
        fillcolor   = "#FFF8E1"
        color       = "#E65100"
        fontsize    = 13
        fontcolor   = "#E65100"

        Duct_normal     [label="Normal Pancreatic\nDuct Epithelium"   shape=box style=filled fillcolor="#FFE082"]
        Duct_inflam     [label="Periductal\nInflammation"             shape=box style=filled fillcolor="#FFB300"]
        Duct_stricture  [label="Duct Stricture\n(stenosis)"           shape=diamond style=filled fillcolor="#FF8F00"]
        Duct_diam       [label="Pancreatic Duct\nDiameter (PD)\n[biomarker]" shape=ellipse style=filled fillcolor=plum]

        Acinar_normal   [label="Acinar Cells\n(normal)"               shape=box style=filled fillcolor="#FFE082"]
        Acinar_atrophy  [label="Acinar Atrophy\n(loss of exocrine)"   shape=diamond style=filled fillcolor="#FFB300"]

        Exocrine_func   [label="Exocrine Function\n(FE-1, lipase)"    shape=ellipse style=filled fillcolor=plum]
        Lipase_serum    [label="Serum Lipase\n[biomarker]"            shape=ellipse style=filled fillcolor=plum]
        FE1             [label="Fecal Elastase-1\n(FE-1) [biomarker]" shape=ellipse style=filled fillcolor=plum]

        Beta_cell       [label="β-cells\n(islets of Langerhans)"     shape=box style=filled fillcolor="#FFE082"]
        Beta_impair     [label="β-cell\nImpairment"                  shape=diamond style=filled fillcolor="#FFB300"]
        Insulin_sec     [label="Insulin\nSecretion"                  shape=ellipse style=filled fillcolor="#FFE082"]
        HbA1c           [label="HbA1c\n[clinical endpoint]"          shape=ellipse style=filled fillcolor=plum]
        Glucagon        [label="Glucagon\n(α-cells)"                 shape=ellipse style=filled fillcolor="#FFE082"]

        CA19_9          [label="CA 19-9\n[tumor/inflam marker]"      shape=ellipse style=filled fillcolor=plum]
    }

    // =========================================================
    // CLUSTER 5 — Fibrosis Pathway
    // =========================================================
    subgraph cluster_fibrosis {
        label       = "Fibrosis: Stellate Cells → ECM Remodeling"
        style       = filled
        fillcolor   = "#EFEBE9"
        color       = "#4E342E"
        fontsize    = 13
        fontcolor   = "#4E342E"

        PSC_quiescent   [label="Quiescent Pancreatic\nStelate Cell (PSC)" shape=box style=filled fillcolor=burlywood]
        PSC_activated   [label="Activated PSC\n(myofibroblast-like)"      shape=box style=filled fillcolor="#A1887F"]
        Myofibroblast   [label="Myofibroblast\n(αSMA+)"                   shape=box style=filled fillcolor="#795548"]
        Collagen_I      [label="Collagen I/III\nDeposition"               shape=diamond style=filled fillcolor=burlywood]
        Fibronectin     [label="Fibronectin"                              shape=ellipse style=filled fillcolor=burlywood]
        MMP             [label="MMPs\n(matrix metalloproteinase)"         shape=ellipse style=filled fillcolor=burlywood]
        TIMP            [label="TIMPs\n(MMP inhibitors)"                  shape=ellipse style=filled fillcolor=burlywood]
        PDGF            [label="PDGF\n(PSC activation)"                   shape=ellipse style=filled fillcolor=burlywood]
        CTGF            [label="CTGF/CCN2\n(fibrosis amplifier)"          shape=ellipse style=filled fillcolor=burlywood]
        Storiform_fib   [label="Storiform\nFibrosis (histology)"          shape=diamond style=filled fillcolor="#8D6E63"]
        Obliterative_ph [label="Obliterative\nPhlebitis"                  shape=diamond style=filled fillcolor="#8D6E63"]

        // Fibrosis resolution
        Fibrosis_score  [label="Fibrosis Score\n(CT response)"            shape=ellipse style=filled fillcolor=plum]
    }

    // =========================================================
    // CLUSTER 6 — Extra-Pancreatic Manifestations
    // =========================================================
    subgraph cluster_extrapancreatic {
        label       = "Extra-Pancreatic IgG4-RD Manifestations"
        style       = filled
        fillcolor   = "#E8EAF6"
        color       = "#283593"
        fontsize    = 13
        fontcolor   = "#283593"

        Biliary         [label="Bile Duct\nEpithelium"         shape=box style=filled fillcolor="#9FA8DA"]
        Biliary_strict  [label="Biliary Stricture\n(IgG4-SC)"  shape=diamond style=filled fillcolor="#5C6BC0"]
        Bilirubin       [label="Serum Bilirubin\n[biomarker]"  shape=ellipse style=filled fillcolor=plum]

        Salivary_gland  [label="Submandibular\nGland"          shape=box style=filled fillcolor="#9FA8DA"]
        Salivary_swel   [label="Salivary Gland\nSwelling"      shape=diamond style=filled fillcolor="#5C6BC0"]

        Kidney_TIN      [label="Kidney TIN\n(tubulointerstitial nephritis)" shape=box style=filled fillcolor="#9FA8DA"]
        Creatinine      [label="Serum Creatinine\n[biomarker]" shape=ellipse style=filled fillcolor=plum]
        eGFR            [label="eGFR\n[renal endpoint]"        shape=ellipse style=filled fillcolor=plum]

        Retro_fib       [label="Retroperitoneal\nFibrosis"     shape=diamond style=filled fillcolor="#5C6BC0"]
        Orbital_pseudo  [label="Orbital\nPseudotumor"          shape=diamond style=filled fillcolor="#5C6BC0"]
        Lymphadenopathy [label="Lymphadenopathy"               shape=diamond style=filled fillcolor="#9FA8DA"]
        Aortitis        [label="Periaortitis"                  shape=diamond style=filled fillcolor="#9FA8DA"]
    }

    // =========================================================
    // CLUSTER 7 — Corticosteroid PK/PD
    // =========================================================
    subgraph cluster_steroid {
        label       = "Corticosteroid PK/PD (Prednisolone)"
        style       = filled
        fillcolor   = "#FFFDE7"
        color       = "#F9A825"
        fontsize    = 13
        fontcolor   = "#F9A825"

        Pred_dose       [label="Prednisolone\nOral Dose\n(0.6 mg/kg/day)"  shape=hexagon style=filled fillcolor=gold]
        Pred_gut        [label="GI Absorption\n(F~80%)"                     shape=ellipse style=filled fillcolor="#FFF9C4"]
        Pred_plasma     [label="Prednisolone\nPlasma (Cp)"                  shape=ellipse style=filled fillcolor="#FFF176"]
        Pred_protein    [label="Protein Binding\n(CBG, albumin, ~70%)"      shape=ellipse style=filled fillcolor="#FFF9C4"]
        Pred_free       [label="Free Prednisolone\n(Cp,free)"               shape=ellipse style=filled fillcolor="#FFF176"]
        GR_cytosol      [label="Cytosolic GR\n(glucocorticoid receptor)"    shape=ellipse style=filled fillcolor="#FFE57F"]
        GR_complex      [label="Pred·GR Complex\n(cytoplasm)"               shape=ellipse style=filled fillcolor="#FFE57F"]
        GR_nuclear      [label="GR·GR Homodimer\n(nuclear)"                 shape=ellipse style=filled fillcolor="#FFD740"]
        GRE             [label="GRE\n(glucocorticoid\nresponse element)"    shape=ellipse style=filled fillcolor="#FFD740"]
        NFkB_inhib      [label="NF-κB Inhibition\n(transrepression)"        shape=diamond style=filled fillcolor="#FFB300"]
        AP1_inhib       [label="AP-1 Inhibition"                            shape=diamond style=filled fillcolor="#FFB300"]
        IkBa_induce     [label="IκBα Induction\n(NF-κB sequestration)"     shape=ellipse style=filled fillcolor="#FFE082"]
        Pred_metab      [label="Hepatic Metabolism\n(CYP3A4 → prednisone)" shape=diamond style=filled fillcolor="#FFF9C4"]
        Pred_elim       [label="Renal Elimination\n(t½ ~2-3 h)"            shape=diamond style=filled fillcolor="#FFF9C4"]
    }

    // =========================================================
    // CLUSTER 8 — Rituximab PK/PD
    // =========================================================
    subgraph cluster_rituximab {
        label       = "Rituximab PK/PD (Anti-CD20)"
        style       = filled
        fillcolor   = "#E0F7FA"
        color       = "#006064"
        fontsize    = 13
        fontcolor   = "#006064"

        RTX_dose        [label="Rituximab IV\n(375 mg/m² × 4\nor 1g × 2)"  shape=hexagon style=filled fillcolor="#00BCD4" fontcolor=white]
        RTX_central     [label="Rituximab\nCentral Compartment (Vc)"        shape=ellipse style=filled fillcolor="#80DEEA"]
        RTX_peripheral  [label="Peripheral\nCompartment (Vp)"               shape=ellipse style=filled fillcolor="#80DEEA"]
        RTX_CD20_bind   [label="RTX·CD20\nBinding (Kd~1 nM)"               shape=diamond style=filled fillcolor="#26C6DA"]
        ADCC_RTX        [label="ADCC\n(NK cell-mediated)"                   shape=diamond style=filled fillcolor="#26C6DA"]
        CDC_RTX         [label="CDC\n(complement-mediated)"                 shape=diamond style=filled fillcolor="#26C6DA"]
        Apoptosis_RTX   [label="Direct\nApoptosis"                          shape=diamond style=filled fillcolor="#26C6DA"]
        Bcell_depletion [label="B Cell Depletion\n(>99% peripheral)"       shape=diamond style=filled fillcolor="#00ACC1"]
        Bcell_repletion [label="B Cell Repopulation\n(6-12 months)"        shape=diamond style=filled fillcolor="#4DD0E1"]
        RTX_elim        [label="Elimination\n(t½ ~22 days)\nTarget-mediated" shape=diamond style=filled fillcolor="#80DEEA"]
    }

    // =========================================================
    // CLUSTER 9 — Azathioprine & MMF PK/PD (Steroid-Sparing)
    // =========================================================
    subgraph cluster_immunosupp {
        label       = "Steroid-Sparing Agents: Azathioprine & MMF PK/PD"
        style       = filled
        fillcolor   = "#F1F8E9"
        color       = "#33691E"
        fontsize    = 13
        fontcolor   = "#33691E"

        AZA_dose        [label="Azathioprine\nOral Dose (1-2 mg/kg/day)"   shape=hexagon style=filled fillcolor="#AED581"]
        AZA_gut         [label="GI Absorption\n(prodrug AZA)"              shape=ellipse style=filled fillcolor="#DCEDC8"]
        SMP_convert     [label="Non-enzymatic\nConversion → 6-MP"          shape=diamond style=filled fillcolor="#C5E1A5"]
        SixMP           [label="6-Mercaptopurine\n(6-MP)"                  shape=ellipse style=filled fillcolor="#AED581"]
        TPMT            [label="TPMT\n(enzyme, inactivates 6-MP)"          shape=ellipse style=filled fillcolor="#C5E1A5"]
        XO_enz          [label="Xanthine Oxidase\n(XO, inactivates)"       shape=ellipse style=filled fillcolor="#C5E1A5"]
        SixTGN          [label="6-TGN\n(active metabolite)"                shape=ellipse style=filled fillcolor="#7CB342"]
        HPRT_enz        [label="HPRT\n(salvage pathway)"                   shape=ellipse style=filled fillcolor="#C5E1A5"]
        Purine_inhib    [label="Purine Synthesis\nInhibition"              shape=diamond style=filled fillcolor="#558B2F"]
        Lymph_inhib_AZA [label="Lymphocyte\nProliferation Inhibition"      shape=diamond style=filled fillcolor="#558B2F"]

        MMF_dose        [label="MMF Oral Dose\n(1-3 g/day)"               shape=hexagon style=filled fillcolor="#AED581"]
        MMF_gut         [label="MMF → MPA\n(intestinal esterase)"         shape=diamond style=filled fillcolor="#DCEDC8"]
        MPA             [label="Mycophenolic Acid\n(MPA)"                  shape=ellipse style=filled fillcolor="#AED581"]
        IMPDH           [label="IMPDH Inhibition\n(de novo GMP)"          shape=diamond style=filled fillcolor="#558B2F"]
        GMP_inhib       [label="GMP Depletion\n(lymphocyte selective)"    shape=diamond style=filled fillcolor="#558B2F"]
        Lymph_inhib_MMF [label="T & B Cell\nSuppression"                  shape=diamond style=filled fillcolor="#558B2F"]
        MPA_MPAG        [label="MPA → MPAG\n(UGT1A9 glucuronide)"        shape=diamond style=filled fillcolor="#DCEDC8"]
        EHC             [label="Enterohepatic\nCirculation (MPA)"         shape=diamond style=filled fillcolor="#DCEDC8"]
    }

    // =========================================================
    // CLUSTER 10 — Clinical Endpoints & Disease Activity
    // =========================================================
    subgraph cluster_endpoints {
        label       = "Clinical Endpoints, Biomarkers & Disease Activity"
        style       = filled
        fillcolor   = "#EDE7F6"
        color       = "#4A148C"
        fontsize    = 13
        fontcolor   = "#4A148C"

        IgG4_resp       [label="IgG4 Response\n(>50% reduction)"          shape=ellipse style=filled fillcolor=lavender]
        CT_score        [label="CT Response Score\n(pancreas morphology)"  shape=ellipse style=filled fillcolor=lavender]
        AIP_relapse     [label="AIP Relapse\nRate"                         shape=ellipse style=filled fillcolor=plum]
        ICDC_score      [label="ICDC Diagnostic\nCriteria Score"           shape=ellipse style=filled fillcolor=lavender]
        HISORt          [label="HISORt Score\n(histology/imaging)"         shape=ellipse style=filled fillcolor=lavender]
        Steroid_resp    [label="Steroid\nResponsiveness"                   shape=ellipse style=filled fillcolor=lavender]
        EXO_insuff      [label="Exocrine\nInsufficiency Grade"             shape=ellipse style=filled fillcolor=lavender]
        ENDO_dm         [label="New-onset DM\n(pancreatogenic)"            shape=ellipse style=filled fillcolor=lavender]
        Relapse_risk    [label="Relapse Risk\nFactors"                     shape=diamond style=filled fillcolor=plum]
        Proximal_duct   [label="Proximal Duct\nInvolvement"                shape=ellipse style=filled fillcolor=lavender]
    }

    // =========================================================
    // INTER-CLUSTER EDGES
    // =========================================================

    // --- Innate activation edges ---
    Lactoferrin -> TLR4        [label="binds/activates" color="#E65100"]
    CA_II       -> MHC_II      [label="peptide loading" color="#E65100"]
    PBP         -> MHC_II      [label="peptide loading" color="#E65100"]
    TLR3        -> DC_immature [label="activates" color="#E65100"]
    TLR4        -> DC_immature [label="activates" color="#E65100"]
    TLR7        -> pDC         [label="activates" color="#E65100"]
    TLR9        -> pDC         [label="activates" color="#E65100"]
    TLR4        -> NLR_NLRP3   [label="primes" color="#E65100"]
    NLR_NLRP3   -> IL_6        [label="releases" color="#1565C0"]
    DC_immature -> DC_mature   [label="matures (CD83↑)" color="#1565C0" arrowhead=normal]
    DC_mature   -> MHC_II      [label="presents antigen" color="#E65100"]
    HLA_DRB1    -> MHC_II      [label="encodes" color="#E65100"]
    DC_mature   -> Tcell_naive [label="primes" color="#1565C0" lhead=cluster_tcell]
    Macrophage_M0 -> Macrophage_M1 [label="M1 polarization\n(IFN-γ, LPS)" color="#1565C0"]
    Macrophage_M0 -> Macrophage_M2 [label="M2 polarization\n(IL-4, IL-13)" color="#1565C0"]
    Macrophage_M1 -> TNF_alpha [label="secretes" color="#1565C0"]
    Macrophage_M1 -> IL_12     [label="secretes" color="#1565C0"]
    Macrophage_M2 -> IL_10     [label="secretes" color="#1565C0"]
    Macrophage_M2 -> TGF_beta  [label="secretes" color="#1565C0"]
    Neutrophil  -> IL_17       [label="secretes" color="#1565C0"]
    pDC         -> IFN_gamma   [label="induces (via IFN-α)" color="#1565C0" style=dashed]

    // --- T cell differentiation ---
    Tcell_naive -> Th1   [label="IL-12, IFN-γ drive" color="#1565C0"]
    Tcell_naive -> Th2   [label="IL-4 drives" color="#1565C0"]
    Tcell_naive -> Th17  [label="IL-6+TGF-β drive" color="#1565C0"]
    Tcell_naive -> Treg  [label="TGF-β+IL-2 drive" color="#1565C0"]
    Tcell_naive -> Tfh   [label="IL-6+BCL6 drive" color="#1565C0"]
    IL_12 -> STAT4       [label="activates" color="#1565C0"]
    STAT4 -> Th1         [label="programs" color="#1565C0"]
    IL_4  -> STAT6       [label="activates" color="#1565C0"]
    STAT6 -> Th2         [label="programs" color="#1565C0"]
    IL_6  -> RORgt       [label="+ TGF-β activates" color="#1565C0"]
    RORgt -> Th17        [label="programs" color="#1565C0"]
    TGF_beta -> FOXP3    [label="induces" color="#1565C0"]
    FOXP3 -> Treg        [label="programs" color="#1565C0"]
    IL_6  -> BCL6        [label="activates" color="#1565C0"]
    BCL6  -> Tfh         [label="programs" color="#1565C0"]
    Th1   -> IFN_gamma   [label="produces" color="#1565C0"]
    Th2   -> IL_4        [label="produces" color="#1565C0"]
    Th2   -> IL_5        [label="produces" color="#1565C0"]
    Th2   -> IL_13       [label="produces" color="#1565C0"]
    Th17  -> IL_17       [label="produces" color="#1565C0"]
    Tfh   -> IL_21       [label="produces" color="#1565C0"]
    Tfh   -> IL_4        [label="co-produces" color="#1565C0" style=dashed]
    Treg  -> IL_10       [label="produces" color="#1565C0"]
    Treg  -> TGF_beta    [label="produces" color="#1565C0"]
    CTLA4_T -> Tcell_naive [label="co-inhibits\nactivation" color="#E65100" arrowhead=tee]
    Treg  -> CTLA4_T     [label="expresses" color="#1565C0"]
    IL_33 -> Th2         [label="amplifies" color="#1565C0"]
    IL_33 -> Tfh         [label="amplifies" color="#1565C0"]
    IFN_gamma -> Macrophage_M1 [label="polarizes" color="#1565C0"]
    IL_4  -> Macrophage_M2     [label="polarizes" color="#1565C0"]

    // --- B cell activation & IgG4 class switch ---
    Tcell_naive -> Bcell_naive [label="T-B cooperation" color="#6A1B9A" style=dashed]
    Tfh   -> GC_Bcell  [label="helps (CD40L-CD40)" color="#6A1B9A"]
    Tfh   -> FDC       [label="interacts with" color="#6A1B9A" style=dashed]
    FDC   -> GC_Bcell  [label="antigen retention" color="#6A1B9A"]
    Bcell_naive -> GC_Bcell  [label="enters GC" color="#6A1B9A"]
    GC_Bcell -> SHM    [label="undergoes" color="#6A1B9A"]
    SHM   -> AID       [label="requires" color="#6A1B9A"]
    IL_4  -> CSR_IgG4  [label="drives IgG1→IgG4" color="#6A1B9A"]
    IL_10 -> CSR_IgG4  [label="drives IgG4 switch" color="#6A1B9A"]
    IL_13 -> CSR_IgG4  [label="co-drives" color="#6A1B9A"]
    IL_33 -> CSR_IgG4  [label="promotes (via Th2)" color="#6A1B9A"]
    BAFF  -> BAFF_R    [label="binds" color="#6A1B9A"]
    BAFF_R -> GC_Bcell [label="survival signal" color="#6A1B9A"]
    APRIL -> GC_Bcell  [label="survival signal" color="#6A1B9A"]
    AID   -> CSR_IgG4  [label="mediates" color="#6A1B9A"]
    CSR_IgG4 -> PlasmaBcell [label="differentiates to" color="#6A1B9A"]
    CSR_IgG4 -> Memory_Bcell [label="differentiates to" color="#6A1B9A"]
    GC_Bcell -> PC_short [label="short-lived PC" color="#6A1B9A" style=dashed]
    PlasmaBcell -> IgG4_serum [label="secretes" color="#6A1B9A"]
    PC_short -> IgG1   [label="secretes" color="#6A1B9A"]
    FcgRIIb -> CSR_IgG4 [label="promotes IgG4\n(inhibitory signaling)" color="#6A1B9A"]
    IL_21 -> GC_Bcell  [label="promotes GC reaction" color="#6A1B9A"]
    CD20  -> Bcell_naive [label="expressed on" color="#6A1B9A" dir=back]

    // --- IgG4 effector & complement ---
    IgG4_serum -> IgG4_IC   [label="forms" color="#880E4F"]
    IgG4_serum -> IgG4_Fab2 [label="undergoes" color="#880E4F"]
    IgG4_IC    -> FcgR_eff  [label="engages" color="#880E4F" style=dashed]
    IgG4_IC    -> C1q       [label="poorly activates" color="#880E4F" style=dashed arrowhead=tee]
    IgG4_Fab2  -> Comp_inhib [label="blocks complement" color="#880E4F"]
    C1q -> C4              [label="cleaves" color="#880E4F"]
    C1q -> C3              [label="activates pathway" color="#880E4F"]
    C3  -> C3b             [label="cleaves to" color="#880E4F"]
    C3  -> C3a_C5a         [label="releases" color="#880E4F"]
    C3b -> MAC             [label="leads to" color="#880E4F"]
    Comp_inhib -> C3       [label="inhibits" color="#880E4F" arrowhead=tee]
    FcRn -> IgG4_serum     [label="prolongs t½" color="#880E4F" arrowhead=normal]

    // --- Pancreatic pathology ---
    IgG4_IC   -> Duct_inflam    [label="periductal\ninfiltration" color="#E65100"]
    Macrophage_M1 -> Duct_inflam [label="promotes" color="#E65100"]
    IL_17     -> Duct_inflam    [label="amplifies" color="#1565C0"]
    TNF_alpha -> Duct_inflam    [label="amplifies" color="#1565C0"]
    Duct_inflam -> Duct_stricture [label="leads to" color="#E65100"]
    Duct_stricture -> Duct_diam  [label="increases" color="#E65100"]
    Duct_inflam -> Acinar_atrophy [label="leads to" color="#E65100"]
    Acinar_atrophy -> Exocrine_func [label="reduces" color="#E65100" arrowhead=tee]
    Exocrine_func -> Lipase_serum [label="reduces" color="#E65100" arrowhead=tee]
    Exocrine_func -> FE1         [label="reduces" color="#E65100" arrowhead=tee]
    Duct_inflam -> Beta_impair   [label="leads to" color="#E65100"]
    Beta_impair -> Insulin_sec   [label="reduces" color="#E65100" arrowhead=tee]
    Insulin_sec -> HbA1c         [label="inversely" color="#E65100" arrowhead=tee]
    Beta_impair -> ENDO_dm       [label="causes" color="#E65100"]
    Duct_stricture -> CA19_9     [label="elevates" color="#E65100"]

    // --- Fibrosis pathway ---
    TGF_beta -> PSC_quiescent  [label="activates" color="#4E342E"]
    PDGF     -> PSC_quiescent  [label="activates" color="#4E342E"]
    IL_33    -> PSC_quiescent  [label="activates" color="#4E342E"]
    PSC_quiescent -> PSC_activated [label="transdifferentiates" color="#4E342E"]
    PSC_activated -> Myofibroblast [label="becomes" color="#4E342E"]
    Myofibroblast -> Collagen_I   [label="secretes" color="#4E342E"]
    Myofibroblast -> Fibronectin  [label="secretes" color="#4E342E"]
    Myofibroblast -> CTGF         [label="secretes" color="#4E342E"]
    TGF_beta -> TIMP              [label="upregulates" color="#4E342E"]
    TIMP -> MMP                   [label="inhibits" color="#4E342E" arrowhead=tee]
    CTGF -> Collagen_I            [label="amplifies" color="#4E342E"]
    Collagen_I -> Storiform_fib   [label="constitutes" color="#4E342E"]
    IgG4_IC -> Obliterative_ph    [label="contributes to" color="#880E4F"]
    Storiform_fib -> Fibrosis_score [label="reflects" color="#4E342E"]
    Collagen_I -> Fibrosis_score   [label="quantifies" color="#4E342E"]
    PSC_activated -> PDGF          [label="autocrine loop" color="#4E342E" style=dashed]

    // --- Extra-pancreatic ---
    IgG4_serum -> Biliary       [label="infiltrates" color="#283593"]
    IgG4_IC    -> Biliary       [label="deposits in" color="#283593"]
    Biliary    -> Biliary_strict [label="stricture forms" color="#283593"]
    Biliary_strict -> Bilirubin  [label="elevates" color="#283593"]
    IgG4_serum -> Salivary_gland [label="infiltrates" color="#283593"]
    Salivary_gland -> Salivary_swel [label="swells" color="#283593"]
    IgG4_serum -> Kidney_TIN    [label="infiltrates" color="#283593"]
    Kidney_TIN -> Creatinine    [label="elevates" color="#283593"]
    Kidney_TIN -> eGFR          [label="reduces" color="#283593" arrowhead=tee]
    IgG4_serum -> Retro_fib     [label="causes" color="#283593"]
    IgG4_serum -> Orbital_pseudo [label="causes" color="#283593"]
    IgG4_serum -> Aortitis       [label="causes" color="#283593"]
    IgG4_serum -> Lymphadenopathy [label="causes" color="#283593"]

    // --- Prednisolone PK/PD ---
    Pred_dose   -> Pred_gut      [label="oral absorption" color="#F9A825"]
    Pred_gut    -> Pred_plasma   [label="Cp (total)" color="#F9A825"]
    Pred_plasma -> Pred_protein  [label="binds (70%)" color="#F9A825"]
    Pred_plasma -> Pred_free     [label="free fraction (30%)" color="#F9A825"]
    Pred_free   -> GR_cytosol    [label="binds" color="#F9A825"]
    GR_cytosol  -> GR_complex    [label="forms" color="#F9A825"]
    GR_complex  -> GR_nuclear    [label="translocates to nucleus" color="#F9A825"]
    GR_nuclear  -> GRE           [label="binds GRE" color="#F9A825"]
    GRE         -> IkBa_induce   [label="transcribes IκBα" color="#F9A825"]
    IkBa_induce -> NFkB_inhib    [label="sequesters NF-κB" color="#F9A825"]
    GR_nuclear  -> AP1_inhib     [label="tethering" color="#F9A825"]
    NFkB_inhib  -> IL_6          [label="suppresses" color="#F9A825" arrowhead=tee]
    NFkB_inhib  -> TNF_alpha     [label="suppresses" color="#F9A825" arrowhead=tee]
    NFkB_inhib  -> IL_17         [label="suppresses" color="#F9A825" arrowhead=tee]
    NFkB_inhib  -> IFN_gamma     [label="suppresses" color="#F9A825" arrowhead=tee]
    AP1_inhib   -> MMP           [label="suppresses MMP" color="#F9A825" arrowhead=tee]
    GR_nuclear  -> Treg          [label="promotes Treg" color="#F9A825"]
    Pred_free   -> Pred_metab    [label="CYP3A4" color="#F9A825"]
    Pred_free   -> Pred_elim     [label="renal" color="#F9A825"]
    Pred_plasma -> Steroid_resp  [label="drives" color="#F9A825"]

    // --- Rituximab PK/PD ---
    RTX_dose    -> RTX_central    [label="IV infusion" color="#006064"]
    RTX_central -> RTX_peripheral [label="distribution (Q)" color="#006064"]
    RTX_central -> RTX_CD20_bind  [label="binds CD20" color="#006064"]
    RTX_CD20_bind -> ADCC_RTX    [label="induces ADCC" color="#006064"]
    RTX_CD20_bind -> CDC_RTX     [label="induces CDC" color="#006064"]
    RTX_CD20_bind -> Apoptosis_RTX [label="induces apoptosis" color="#006064"]
    ADCC_RTX    -> Bcell_depletion [label="kills B cells" color="#006064"]
    CDC_RTX     -> Bcell_depletion [label="kills B cells" color="#006064"]
    Apoptosis_RTX -> Bcell_depletion [label="kills B cells" color="#006064"]
    Bcell_depletion -> IgG4_serum  [label="reduces" color="#006064" arrowhead=tee]
    Bcell_depletion -> Bcell_repletion [label="followed by" color="#006064" style=dashed]
    RTX_central -> RTX_elim       [label="target-mediated\nclearance" color="#006064"]
    RTX_dose -> CD20               [label="targets" color="#006064"]

    // --- AZA PK/PD ---
    AZA_dose   -> AZA_gut       [label="oral absorption" color="#33691E"]
    AZA_gut    -> SMP_convert   [label="non-enzymatic" color="#33691E"]
    SMP_convert -> SixMP        [label="converts to" color="#33691E"]
    SixMP      -> TPMT          [label="inactivated by" color="#33691E" arrowhead=tee]
    SixMP      -> XO_enz        [label="inactivated by" color="#33691E" arrowhead=tee]
    SixMP      -> HPRT_enz      [label="activated by" color="#33691E"]
    HPRT_enz   -> SixTGN        [label="produces" color="#33691E"]
    SixTGN     -> Purine_inhib  [label="inhibits\npurine synthesis" color="#33691E"]
    Purine_inhib -> Lymph_inhib_AZA [label="suppresses" color="#33691E"]
    Lymph_inhib_AZA -> Th1      [label="suppresses" color="#33691E" arrowhead=tee]
    Lymph_inhib_AZA -> Th17     [label="suppresses" color="#33691E" arrowhead=tee]
    Lymph_inhib_AZA -> GC_Bcell [label="suppresses" color="#33691E" arrowhead=tee]

    // --- MMF PK/PD ---
    MMF_dose   -> MMF_gut       [label="oral absorption" color="#33691E"]
    MMF_gut    -> MPA           [label="rapid conversion" color="#33691E"]
    MPA        -> IMPDH         [label="selectively inhibits" color="#33691E" arrowhead=tee]
    IMPDH      -> GMP_inhib     [label="depletion" color="#33691E"]
    GMP_inhib  -> Lymph_inhib_MMF [label="suppresses\nlymphocytes" color="#33691E"]
    Lymph_inhib_MMF -> GC_Bcell [label="suppresses" color="#33691E" arrowhead=tee]
    Lymph_inhib_MMF -> PlasmaBcell [label="suppresses" color="#33691E" arrowhead=tee]
    Lymph_inhib_MMF -> Th17     [label="suppresses" color="#33691E" arrowhead=tee]
    MPA        -> MPA_MPAG      [label="glucuronidation" color="#33691E"]
    MPA_MPAG   -> EHC           [label="undergoes EHC" color="#33691E"]
    EHC        -> MPA           [label="recirculates" color="#33691E" style=dashed]

    // --- Clinical endpoint connections ---
    IgG4_serum   -> IgG4_resp     [label="monitors" color="#4A148C"]
    Fibrosis_score -> CT_score    [label="assessed by" color="#4A148C"]
    Duct_stricture -> CT_score    [label="assessed by" color="#4A148C"]
    Memory_Bcell -> AIP_relapse   [label="drives relapse" color="#4A148C"]
    IgG4_serum   -> AIP_relapse   [label="predicts" color="#4A148C"]
    Proximal_duct -> AIP_relapse  [label="risk factor" color="#4A148C"]
    ICDC_score   -> HISORt        [label="incorporates" color="#4A148C"]
    HISORt       -> Steroid_resp  [label="predicts" color="#4A148C"]
    Exocrine_func -> EXO_insuff   [label="quantifies" color="#4A148C"]
    Beta_impair  -> ENDO_dm       [label="leads to" color="#4A148C"]
    ENDO_dm      -> HbA1c         [label="elevates" color="#4A148C"]
    Relapse_risk -> Proximal_duct [label="includes" color="#4A148C"]
    Steroid_resp -> CT_score      [label="leads to improvement" color="#4A148C"]
    NFkB_inhib   -> IgG4_serum    [label="reduces IgG4 production" color="#F9A825" arrowhead=tee style=dashed]
    NFkB_inhib   -> Duct_inflam   [label="reduces" color="#F9A825" arrowhead=tee style=dashed]
    NFkB_inhib   -> PSC_activated [label="suppresses activation" color="#F9A825" arrowhead=tee style=dashed]
}
