digraph WilsonDisease_QSP {
    graph [
        label="Wilson's Disease (WD) — QSP Mechanistic Map\nCopper Metabolism Disorders, ATP7B Dysfunction & Pharmacological Interventions"
        fontname="Helvetica" fontsize=20 labelloc=t
        bgcolor="#0d1117" fontcolor=white
        splines=curved rankdir=TB
        nodesep=0.35 ranksep=0.6
    ]
    node [fontname="Helvetica" fontsize=9 style=filled shape=box bordercolor=white]
    edge [fontname="Helvetica" fontsize=7 color="#8892a4"]

    // ============================================================
    // CLUSTER 1: Dietary Copper & GI Absorption
    // ============================================================
    subgraph cluster_GI {
        label="GI Copper Absorption"
        style=filled fillcolor="#0d2137" fontcolor=white color="#1e5590"
        node [fillcolor="#1e5590" fontcolor=white]

        Cu_diet        [label="Dietary Copper\n(1.0-1.5 mg/day)"]
        Cu_GI_lumen    [label="GI Lumen Copper\n(Stomach + Duodenum)"]
        CTR1_gut       [label="CTR1/SLC31A1\n(High-affinity Cu transporter)"]
        CTR2_gut       [label="CTR2\n(Low-affinity transporter)"]
        DMT1_gut       [label="DMT1\n(Divalent Metal Transporter 1)"]
        Cu_enterocyte  [label="Enterocyte\nCytoplasmic Cu Pool"]
        MT_gut         [label="Gut Metallothionein\n(MT1/MT2, storage buffer)"]
        ATP7A_gut      [label="ATP7A (Menkes protein)\nBasolateral Cu export"]
        Cu_portal      [label="Portal Vein\nCopper"]
        Albumin_portal [label="Albumin-Cu Complex\n(Portal blood)"]
        Hist_portal    [label="Histidine-Cu Complex\n(Portal blood)"]
    }

    // ============================================================
    // CLUSTER 2: Hepatocyte Copper Chaperones & Metabolism
    // ============================================================
    subgraph cluster_hepatocyte {
        label="Hepatocyte Copper Metabolism"
        style=filled fillcolor="#0d2e0d" fontcolor=white color="#2d7a2d"
        node [fillcolor="#2d7a2d" fontcolor=white]

        Cu_hepatocyte [label="Hepatocyte Cytoplasmic\nCopper Pool"]
        ATOX1         [label="ATOX1 Chaperone\n(Delivers Cu to ATP7B)"]
        CCS           [label="CCS Chaperone\n(Delivers Cu to SOD1)"]
        COX17         [label="COX17 Chaperone\n(Mitochondrial Cu)"]
        SOD1_Cu       [label="Cu/Zn-SOD1\n(Antioxidant enzyme)"]
        COX_complex   [label="Cytochrome c Oxidase\n(Mitochondrial ETC)"]
        MT_hepatic    [label="Hepatic Metallothionein\n(MT1A/MT2A buffer)"]
        COMMD1        [label="COMMD1 (MURR1)\n(Ubiquitin signaling)"]
        XIAP          [label="XIAP (X-linked IAP)\n(Anti-apoptosis regulator)"]
        DNAJB12       [label="DNAJB12 (HSP40)\n(ATP7B quality control)"]
    }

    // ============================================================
    // CLUSTER 3: ATP7B Pathway & Biliary Excretion
    // ============================================================
    subgraph cluster_ATP7B {
        label="ATP7B (Wilson Disease Protein) & Biliary Excretion"
        style=filled fillcolor="#2e0d0d" fontcolor=white color="#b03030"
        node [fillcolor="#b03030" fontcolor=white]

        ATP7B_WT      [label="ATP7B Wild-type\nP-type Cu-ATPase\n(21 exons)"]
        ATP7B_mut     [label="ATP7B Mutant\n(p.His1069Gln most common\nLoss-of-function)"]
        ATP7B_class   [label="Mutation Class\n(I: Traffick | II: Kinase\nIII: Transmembrane)"]
        TGN_Cu        [label="Trans-Golgi Network\nCopper Loading"]
        Golgi_traf    [label="Golgi Vesicle\nTrafficking (canalicular)"]
        Bil_vesicle   [label="Biliary Secretory\nVesicles"]
        Cu_bile       [label="Biliary Copper\nExcretion (primary route)"]
        Cp_apo        [label="Apoceruloplasmin\n(Apo-Cp, inactive)"]
        Cp_holo       [label="Holoceruloplasmin\n(Holo-Cp, 6 Cu/molecule)"]
        Cp_secretion  [label="Ceruloplasmin\nSecretion into blood"]
    }

    // ============================================================
    // CLUSTER 4: Systemic Copper & Biomarkers
    // ============================================================
    subgraph cluster_systemic {
        label="Systemic Copper Compartments & Diagnostic Biomarkers"
        style=filled fillcolor="#2e1e0d" fontcolor=white color="#c07030"
        node [fillcolor="#c07030" fontcolor=white]

        Cp_serum       [label="Serum Ceruloplasmin\n(Normal: 20-60 mg/dL)\n↓ in WD (<20)"]
        Cu_serum_total [label="Total Serum Copper\n(Normal: 70-140 μg/dL)\n↓ in WD"]
        NCBC           [label="Non-Ceruloplasmin\nBound Copper (NCBC)\n(Normal <10; WD >20 μg/dL)"]
        CuEXC          [label="Exchangeable Copper\n(CuEXC; Direct free Cu\nmeasurement)"]
        Cu24h_urine    [label="24-hr Urine Copper\n(Normal <100 μg/day)\n(WD >100, often >1000)"]
        Liver_Cu_bx    [label="Liver Biopsy Copper\n(Normal <50 μg/g dw)\n(WD >250 μg/g dw)"]
        Leipzig_score  [label="Leipzig Diagnostic Score\n(≥4 = WD confirmed)"]
        Cu_RBC         [label="Erythrocyte Copper\n(Elevated in hemolysis)"]
    }

    // ============================================================
    // CLUSTER 5: Hepatic Pathology & Fibrosis
    // ============================================================
    subgraph cluster_liver {
        label="Hepatic Pathology, Inflammation & Fibrosis"
        style=filled fillcolor="#1e0d2e" fontcolor=white color="#7040b0"
        node [fillcolor="#7040b0" fontcolor=white]

        Cu_ROS          [label="Copper-induced ROS\n(H₂O₂, OH•, O₂•-)"]
        Ox_stress       [label="Hepatic Oxidative\nStress (8-OHdG ↑)"]
        Mito_dysfn      [label="Mitochondrial\nDysfunction"]
        Lipid_perox     [label="Lipid Peroxidation\n(4-HNE, MDA ↑)"]
        DNA_damage      [label="Hepatocyte DNA\nDamage"]
        Hep_apoptosis   [label="Hepatocyte\nApoptosis"]
        Kupffer_act     [label="Kupffer Cell\nActivation"]
        TNFa_liver      [label="TNF-α (Liver)\nInflammatory cytokine"]
        IL6_liver       [label="IL-6 (Liver)\nAcute phase response"]
        IL1b_liver      [label="IL-1β (Liver)\nNLRP3 inflammasome"]
        HSC_act         [label="Hepatic Stellate\nCell (HSC) Activation"]
        TGFb_liver      [label="TGF-β1\n(Pro-fibrotic driver)"]
        PDGF_liver      [label="PDGF-BB\n(HSC proliferation)"]
        Col_depo        [label="Collagen Deposition\n(Type I/III fibers)"]
        Fibrosis_score  [label="Hepatic Fibrosis\n(Metavir F0-F4)"]
        ALT_serum       [label="Serum ALT\n(Hepatocyte damage marker)"]
        AST_serum       [label="Serum AST"]
        Bilirubin       [label="Total Bilirubin\n(↑ = hepatocellular damage)"]
        INR             [label="INR / Prothrombin Time\n(Coagulation function)"]
        Albumin_low     [label="Serum Albumin ↓\n(Synthetic function)"]
        Portal_HTN      [label="Portal Hypertension\n(Cirrhosis complication)"]
        ALF             [label="Acute Liver Failure\n(Kayser-Fleischer absent!\nCoombs– hemolysis)"]
    }

    // ============================================================
    // CLUSTER 6: Brain Copper & Neuropsychiatric
    // ============================================================
    subgraph cluster_brain {
        label="Brain Copper Accumulation & Neuropsychiatric Manifestations"
        style=filled fillcolor="#0d1e2e" fontcolor=white color="#3070a0"
        node [fillcolor="#3070a0" fontcolor=white]

        Cu_BBB         [label="Blood-Brain Barrier\nCopper Transport (CTR1)"]
        Cu_bg          [label="Basal Ganglia Cu\n(Putamen ↑↑↑)"]
        Cu_cerebellum  [label="Cerebellar Copper\n(Dentate nucleus)"]
        Cu_brainstem   [label="Brainstem Copper\n(Pons, midbrain)"]
        Cu_cortex      [label="Cortical Copper\n(Frontal/Temporal)"]
        DA_neurons     [label="Dopaminergic Neurons\n(Substantia nigra\nDysfunction)"]
        NE_pathway     [label="Noradrenergic Pathway\n(DBH is Cu-dependent)"]
        Serotonin_path [label="Serotonin Pathway\n(MAO Cu-dependent)"]
        Astrocyte_dysfn [label="Astrocyte Dysfunction\n(Glutamate clearance ↓)"]
        Microglia_act  [label="Microglial Activation\n(Brain immune)"]
        Neuroinfl      [label="Neuroinflammation\n(IL-6, TNF-α, IL-1β)"]
        Neuron_apo     [label="Neuronal Apoptosis\n(Irreversible damage)"]
        NMDA_dysfn     [label="NMDA Receptor\nDysfunction (glutamate)"]
        Tremor         [label="Tremor\n(Wing-beating, resting)"]
        Dysarthria     [label="Dysarthria\n(Speech impairment)"]
        Dystonia       [label="Dystonia\n(Involuntary posturing)"]
        Psychiatric    [label="Psychiatric Symptoms\n(Depression, psychosis,\nbehavior change)"]
        UWDRS          [label="UWDRS Score\n(Unified WD Rating)"]
        MRI_T2         [label="Brain MRI\nT2/FLAIR Changes\n(Putamen 'face of giant panda')"]
    }

    // ============================================================
    // CLUSTER 7: Other Organ Toxicity
    // ============================================================
    subgraph cluster_other {
        label="Multi-Organ Toxicity"
        style=filled fillcolor="#1e2e0d" fontcolor=white color="#5a9030"
        node [fillcolor="#5a9030" fontcolor=white]

        Cornea_Cu      [label="Corneal Copper\nDeposition (Descemet)"]
        KF_rings       [label="Kayser-Fleischer Rings\n(Slit-lamp diagnosis)"]
        SC_cataract    [label="Sunflower Cataract\n(Anterior lens capsule)"]
        Cu_kidney      [label="Renal Cortex Copper\n(Proximal tubules)"]
        Fanconi        [label="Renal Fanconi\nSyndrome"]
        Tubular_dmg    [label="Proximal Tubule\nCell Damage"]
        Aminoaciduria  [label="Aminoaciduria /\nPhosphaturia"]
        Hematuria      [label="Hematuria /\nNephrolithiasis"]
        Hemolytic_an   [label="Coombs-negative\nHemolytic Anemia"]
        RBC_tox        [label="RBC Oxidative Damage\n(Cu-mediated)"]
        Bone_dis       [label="Metabolic Bone Disease\n(Osteoporosis/Rickets)"]
        Cardiac_Cu     [label="Cardiac Copper\n(Cardiomyopathy – rare)"]
    }

    // ============================================================
    // CLUSTER 8: D-Penicillamine PK/PD
    // ============================================================
    subgraph cluster_DPA {
        label="D-Penicillamine (DPA) PK/PD"
        style=filled fillcolor="#2e2e0d" fontcolor=white color="#b0a030"
        node [fillcolor="#b0a030" fontcolor=white]

        DPA_dose     [label="D-Penicillamine\n250-500 mg TID PO\n(1st-line, historical)"]
        DPA_abs      [label="DPA GI Absorption\n(F ≈ 50–70%)"]
        DPA_plasma   [label="DPA Plasma Conc\n(Cmax ≈ 1-3 μM)"]
        DPA_Cu_chel  [label="DPA-Cu Chelate\nComplex"]
        DPA_urine    [label="DPA-Cu Urinary\nExcretion (↑↑ urine Cu)"]
        DPA_tox      [label="DPA Adverse Effects\n(Nephrotoxicity, SLE-like,\nGoodpasture, myasthenia)"]
        B6_depletion [label="Pyridoxine (B6)\nDepletion (→ neuropathy)"]
        Neuro_worse  [label="Neurological Worsening\non DPA Initiation\n(Paradox, ~50% pts)"]
    }

    // ============================================================
    // CLUSTER 9: Zinc PK/PD
    // ============================================================
    subgraph cluster_zinc {
        label="Zinc Acetate / Zinc Gluconate PK/PD"
        style=filled fillcolor="#0d2e2e" fontcolor=white color="#20a0a0"
        node [fillcolor="#20a0a0" fontcolor=white]

        Zn_dose        [label="Zinc Acetate\n50 mg TID PO\n(Maintenance / pediatrics)"]
        Zn_abs         [label="Zinc GI Absorption\n(Active Zn uptake)"]
        Zn_plasma      [label="Zinc Plasma Conc\n(Normal 70-120 μg/dL)"]
        MT_gut_Zn      [label="Gut MT Induction\n(MT1/MT2 by zinc)"]
        Zn_blocks      [label="Zinc-MT Traps\nEndogenous Cu in Feces"]
        Cu_feces_Zn    [label="Fecal Cu Excretion\n(Blocked absorption route)"]
        Zn_minor_tox   [label="Minor GI Side Effects\n(Gastric irritation)"]
        Zn_Fe_inter    [label="Zinc-Iron Interaction\n(Sideroblastic anemia\nif overcorrected)"]
    }

    // ============================================================
    // CLUSTER 10: Trientine & ALXN1840 (bis-TTM) PK/PD
    // ============================================================
    subgraph cluster_TTM {
        label="Trientine (TETA) & ALXN1840 (Bis-choline Tetrathiomolybdate) PK/PD"
        style=filled fillcolor="#2e0d2e" fontcolor=white color="#b030b0"
        node [fillcolor="#b030b0" fontcolor=white]

        Tri_dose       [label="Trientine (TETA)\n250-500 mg TID PO\n(2nd-line chelator)"]
        Tri_abs        [label="Trientine GI Abs\n(F ≈ 40-50%)"]
        Tri_plasma     [label="Trientine Plasma Conc"]
        Tri_Cu_chel    [label="Trientine-Cu\nChelate Complex"]
        Tri_urine      [label="Trientine-Cu\nUrinary Excretion"]
        ALXN1840_dose  [label="ALXN1840 (WTR-001)\n15 mg QD PO\n(Approved 2023, EU)"]
        ALXN1840_abs   [label="ALXN1840 GI Abs\n(Oral bioavailability ~30%)"]
        ALXN1840_plas  [label="ALXN1840 Plasma\n(t½ ≈ 19 hr)"]
        TTM_tri_complex [label="TTM-Cu-Albumin\nTripartite Complex\n(Stable, non-exchangeable)"]
        TTM_feces      [label="Fecal Cu Excretion\n(Primary route for TTM)"]
        ALXN1840_eff   [label="ALXN1840 Efficacy\nNCBC ↓ ~98% from baseline\n(ATLAS trial 2022)"]
    }

    // ============================================================
    // CLUSTER 11: Clinical Endpoints & Outcomes
    // ============================================================
    subgraph cluster_outcomes {
        label="Clinical Endpoints & Long-term Outcomes"
        style=filled fillcolor="#1a1a1a" fontcolor=white color="#606060"
        node [fillcolor="#505050" fontcolor=white]

        WD_staging      [label="WD Disease Staging\n(I: Asymptomatic\nII: Hepatic, III: Neuro)"]
        Treatment_resp  [label="Treatment Response\n(Partial / Complete /\nNo response)"]
        Neuro_improve   [label="Neurological\nImprovement\n(UWDRS ↓ ≥2 pts)"]
        KF_regression   [label="KF Ring Regression\n(>5 yr treatment)"]
        Hepatic_improve [label="Hepatic Improvement\n(ALT ↓, fibrosis reversal)"]
        LT_indication   [label="Liver Transplantation\nIndication\n(ALF or decompensated)"]
        Compliance_mon  [label="Treatment Compliance\n(Drug holiday risk:\ncopper surge)"]
        Pregnancy_WD    [label="WD in Pregnancy\n(Zinc preferred;\nDPA teratogenicity)"]
        QOL             [label="Quality of Life\n(SF-36 / EQ-5D ↑)"]
        Survival        [label="Long-term Survival\n(Near-normal with\nearly treatment)"]
    }

    // ============================================================
    // EDGES — GI Absorption
    // ============================================================
    Cu_diet -> Cu_GI_lumen
    Cu_GI_lumen -> CTR1_gut [label="high-affinity\nuptake"]
    Cu_GI_lumen -> CTR2_gut [label="low-affinity"]
    Cu_GI_lumen -> DMT1_gut [label="divalent form"]
    CTR1_gut -> Cu_enterocyte
    CTR2_gut -> Cu_enterocyte
    DMT1_gut -> Cu_enterocyte
    Cu_enterocyte -> MT_gut [label="storage\nbuffer"]
    Cu_enterocyte -> ATP7A_gut [label="basolateral\nexport"]
    ATP7A_gut -> Cu_portal
    MT_gut -> Cu_enterocyte [label="slow\nrelease" style=dashed]
    Cu_portal -> Albumin_portal
    Cu_portal -> Hist_portal

    // ============================================================
    // EDGES — Portal to Hepatocyte
    // ============================================================
    Albumin_portal -> Cu_hepatocyte [label="first-pass\nextraction"]
    Hist_portal -> Cu_hepatocyte
    Cu_hepatocyte -> ATOX1 [label="chaperone\nrouting"]
    Cu_hepatocyte -> CCS
    Cu_hepatocyte -> COX17
    Cu_hepatocyte -> MT_hepatic [label="excess\nstorage"]
    Cu_hepatocyte -> COMMD1 [label="ubiquitin\nregulation"]
    ATOX1 -> ATP7B_WT [label="Cu delivery\nto ATP7B"]
    ATOX1 -> ATP7B_mut [style=dashed color=red label="impaired\ndelivery"]
    CCS -> SOD1_Cu [label="Cu loading\n→ SOD1 active"]
    COX17 -> COX_complex [label="mitochondrial\nCu loading"]
    DNAJB12 -> ATP7B_WT [label="quality\ncontrol"]
    XIAP -> Hep_apoptosis [style=dashed arrowhead=tee color=green label="inhibits"]
    COMMD1 -> ATP7B_WT [label="ubiquitin\nregulation"]

    // ============================================================
    // EDGES — ATP7B & Biliary Excretion
    // ============================================================
    ATP7B_WT -> TGN_Cu [label="Cu pumped\nto TGN"]
    TGN_Cu -> Cp_apo [label="Cu loading\nof Cp"]
    Cp_apo -> Cp_holo [label="6 Cu2+\nincorporated"]
    Cp_holo -> Cp_secretion -> Cp_serum
    TGN_Cu -> Golgi_traf [label="vesicle\nrouting"]
    Golgi_traf -> Bil_vesicle [label="canalicular\ndirection"]
    Bil_vesicle -> Cu_bile [label="exocytosis\ninto bile canaliculus"]
    ATP7B_mut -> Cu_hepatocyte [label="Cu accumulates\n↑↑↑ (>250 μg/g)" color=red fontcolor=red]
    ATP7B_mut -> Cp_apo [style=dashed color=red arrowhead=tee label="fails Cu\nloading"]
    ATP7B_mut -> Cu_bile [style=dashed color=red arrowhead=tee label="↓↓↓ biliary\nexcretion"]
    ATP7B_class -> ATP7B_mut [label="determines\nseverity"]

    // ============================================================
    // EDGES — Systemic Copper & Biomarkers
    // ============================================================
    Cp_serum -> Cu_serum_total [label="~60-70%\nof serum Cu"]
    NCBC -> Cu_serum_total [label="~30-40%\n(↑↑ in WD)"]
    Cu_hepatocyte -> NCBC [label="overflow\nwhen MT saturated"]
    MT_hepatic -> NCBC [label="MT saturation\n→ release" style=dashed]
    NCBC -> Cu24h_urine [label="glomerular\nfiltration"]
    NCBC -> Cu_BBB [label="crosses BBB\n(free fraction)"]
    NCBC -> Cu_kidney [label="tubular\naccumulation"]
    NCBC -> Cornea_Cu [label="slow\ndeposition"]
    NCBC -> Hemolytic_an [label="RBC membrane\noxidative damage"]
    NCBC -> Cardiac_Cu [label="rare\ndeposition"]
    CuEXC -> NCBC [dir=none style=dashed label="≈ equivalent"]
    Liver_Cu_bx -> Cu_hepatocyte [dir=none]
    Leipzig_score -> Cp_serum [dir=none style=dashed]
    Leipzig_score -> Cu24h_urine [dir=none style=dashed]
    Leipzig_score -> Liver_Cu_bx [dir=none style=dashed]
    Leipzig_score -> KF_rings [dir=none style=dashed]

    // ============================================================
    // EDGES — Hepatic Pathology
    // ============================================================
    Cu_hepatocyte -> Cu_ROS [label="Fenton-Haber-Weiss\nreaction (Cu+/Cu2+)"]
    Cu_ROS -> Ox_stress [label="ROS burst"]
    Ox_stress -> Mito_dysfn [label="ETC\ndamage"]
    Ox_stress -> Lipid_perox [label="PUFA\noxidation"]
    Ox_stress -> DNA_damage [label="8-OHdG\nformation"]
    Mito_dysfn -> Hep_apoptosis [label="cyt c\nrelease"]
    Lipid_perox -> Hep_apoptosis [label="membrane\ndestruction"]
    DNA_damage -> Hep_apoptosis [label="p53\nactivation"]
    SOD1_Cu -> Ox_stress [style=dashed arrowhead=tee color=green label="ROS\nscavenging"]
    COX_complex -> Mito_dysfn [style=dashed arrowhead=tee color=green label="ETC\nfunction"]
    Hep_apoptosis -> ALT_serum [label="cytoplasmic\nrelease"]
    Hep_apoptosis -> AST_serum
    Hep_apoptosis -> Kupffer_act [label="DAMPs\nrelease"]
    Kupffer_act -> TNFa_liver [label="NF-κB\nactivation"]
    Kupffer_act -> IL6_liver
    Kupffer_act -> IL1b_liver [label="NLRP3\ninflammasome"]
    TNFa_liver -> HSC_act [label="paracrine\nactivation"]
    IL6_liver -> HSC_act
    TGFb_liver -> HSC_act [label="canonical\nfibrosis signal"]
    HSC_act -> TGFb_liver [label="autocrine\nloop"]
    HSC_act -> PDGF_liver [label="autocrine"]
    PDGF_liver -> HSC_act [label="proliferation"]
    HSC_act -> Col_depo [label="ECM\nproduction"]
    Col_depo -> Fibrosis_score [label="progressive\naccumulation"]
    Fibrosis_score -> Portal_HTN [label="F3-F4\ncirrhosis"]
    Portal_HTN -> ALF [label="variceal\nbleeding\ndecompensation"]
    Bilirubin -> ALF [label="rapid rise\nin ALF-WD"]
    INR -> ALF [label="coagulopathy"]
    Hep_apoptosis -> Bilirubin [label="hepatocellular\nrelease"]
    Fibrosis_score -> INR [label="coagulation\nfactor ↓"]
    Fibrosis_score -> Albumin_low [label="synthetic\nfunction ↓"]

    // ============================================================
    // EDGES — Brain Copper & Neuropsychiatric
    // ============================================================
    Cu_BBB -> Cu_bg [label="preferential\naccumulation"]
    Cu_BBB -> Cu_cerebellum
    Cu_BBB -> Cu_brainstem
    Cu_BBB -> Cu_cortex
    Cu_bg -> DA_neurons [label="dopamine neuron\nCu-ROS toxicity"]
    Cu_bg -> Astrocyte_dysfn [label="astrocyte\nswelling"]
    Cu_bg -> Microglia_act [label="innate\nimmune sensor"]
    Microglia_act -> Neuroinfl [label="IL-6, TNF-α\nproduction"]
    Astrocyte_dysfn -> Neuroinfl [label="glutamate\nexcitotoxicity"]
    Neuroinfl -> Neuron_apo [label="chronic\nneurodegeneration"]
    DA_neurons -> Tremor [label="nigrostriatal\ncircuit"]
    DA_neurons -> Dystonia [label="basal ganglia\ndysregulation"]
    Cu_brainstem -> Dysarthria [label="corticobulbar\npath damage"]
    Cu_bg -> NMDA_dysfn [label="Cu2+ modulates\nNMDA receptor"]
    NMDA_dysfn -> Psychiatric [label="glutamate\nexcitotoxicity"]
    Neuron_apo -> UWDRS [label="cumulative\nmotor deficit"]
    Cu_bg -> MRI_T2 [label="T2\nhyperintensity"]
    Cu_cerebellum -> Tremor [label="cerebellar\noutflow"]
    NE_pathway -> Cu_bg [dir=none]
    Serotonin_path -> Psychiatric [dir=none]

    // ============================================================
    // EDGES — Other Organs
    // ============================================================
    Cornea_Cu -> KF_rings [label="Descemet\nmembrane ring"]
    Cornea_Cu -> SC_cataract [label="anterior lens\ncapsule"]
    Cu_kidney -> Tubular_dmg [label="PCT Cu toxicity"]
    Tubular_dmg -> Fanconi [label="global PCT\ndysfunction"]
    Fanconi -> Aminoaciduria
    Fanconi -> Hematuria
    Fanconi -> Bone_dis [label="phosphate\nwasting"]
    Hemolytic_an -> RBC_tox [dir=none]
    Cu_hepatocyte -> Bone_dis [label="impaired Vit D\nactivation"]

    // ============================================================
    // EDGES — D-Penicillamine PK/PD
    // ============================================================
    DPA_dose -> DPA_abs [label="oral\nF≈50%"]
    DPA_abs -> DPA_plasma [label="Tmax 1-3 hr"]
    DPA_plasma -> DPA_Cu_chel [label="chelates NCBC\n& liver Cu"]
    DPA_Cu_chel -> DPA_urine [label="renal\nexcretion"]
    DPA_urine -> Cu24h_urine [label="adds to\nurine Cu↑"]
    DPA_plasma -> DPA_tox [label="dose-\ndependent"]
    DPA_plasma -> B6_depletion [label="pyridoxal\ncomplexing"]
    DPA_Cu_chel -> NCBC [style=dashed color=cyan arrowhead=tee label="↓ NCBC\n(mobilization)"]
    DPA_plasma -> Neuro_worse [label="initial Cu\nmobilization\nparadox"]
    Neuro_worse -> UWDRS [label="transient\nworsening"]

    // ============================================================
    // EDGES — Zinc PK/PD
    // ============================================================
    Zn_dose -> Zn_abs [label="oral uptake"]
    Zn_abs -> Zn_plasma [label="systemic\ndistribution"]
    Zn_abs -> MT_gut_Zn [label="Zn induces\nMT in enterocytes"]
    MT_gut_Zn -> Zn_blocks [label="MT sequesters\nenteric Cu"]
    Zn_blocks -> Cu_feces_Zn [label="fecal Cu\nexcretion ↑"]
    Cu_feces_Zn -> CTR1_gut [style=dashed arrowhead=tee color=cyan label="reduced\nCu absorption"]
    Zn_plasma -> Zn_minor_tox [label="GI side\neffects"]
    Zn_plasma -> Zn_Fe_inter [label="competitive\nuptake"]
    MT_gut_Zn -> Cu_enterocyte [style=dashed arrowhead=tee color=cyan label="traps Cu\nin enterocyte"]

    // ============================================================
    // EDGES — Trientine & ALXN1840
    // ============================================================
    Tri_dose -> Tri_abs [label="oral F≈40%"]
    Tri_abs -> Tri_plasma [label="Tmax ~2 hr"]
    Tri_plasma -> Tri_Cu_chel [label="Cu chelation\n(less potent\nthan DPA)"]
    Tri_Cu_chel -> Tri_urine [label="renal\nexcretion"]
    Tri_urine -> Cu24h_urine
    Tri_Cu_chel -> NCBC [style=dashed arrowhead=tee color=cyan label="↓ NCBC\n(moderate)"]
    ALXN1840_dose -> ALXN1840_abs [label="oral\nbioavailability"]
    ALXN1840_abs -> ALXN1840_plas [label="Tmax ~2 hr\nt½ ~19 hr"]
    ALXN1840_plas -> TTM_tri_complex [label="forms\ntripartite\ncomplex"]
    TTM_tri_complex -> TTM_feces [label="biliary\nfecal excretion"]
    TTM_tri_complex -> NCBC [style=dashed arrowhead=tee color=cyan label="↓↓ NCBC\n~98% reduction"]
    ALXN1840_eff -> NCBC [dir=none style=dashed]

    // ============================================================
    // EDGES — Clinical Outcomes
    // ============================================================
    Cu_serum_total -> WD_staging
    Cu24h_urine -> WD_staging
    UWDRS -> WD_staging
    Fibrosis_score -> WD_staging
    NCBC -> Treatment_resp [label="NCBC ≤15 μg/dL\n= target reached"]
    Cu24h_urine -> Treatment_resp [label="monitoring"]
    UWDRS -> Neuro_improve [label="UWDRS ↓"]
    KF_rings -> KF_regression [label="regresses\n>5 yr Rx"]
    Neuro_improve -> KF_regression [dir=none]
    ALT_serum -> Hepatic_improve
    Fibrosis_score -> Hepatic_improve [label="reversal\npossible F1-F2"]
    ALF -> LT_indication [label="ALF = emergent\ntransplant"]
    Fibrosis_score -> LT_indication [label="F4 + MELD\n≥15"]
    Treatment_resp -> Compliance_mon [label="lifelong\nmonitoring"]
    Neuro_improve -> QOL
    Hepatic_improve -> QOL
    QOL -> Survival [label="QOL predicts\nlong-term adherence"]
    Fibrosis_score -> Survival [label="cirrhosis =\nsurvival risk"]
    Pregnancy_WD -> Zn_dose [dir=none style=dashed label="Zinc preferred\nin pregnancy"]
}
