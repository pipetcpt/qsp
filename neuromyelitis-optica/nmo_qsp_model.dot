digraph NMOSD_QSP {
  graph [fontname="Helvetica", fontsize=10, bgcolor="#F8F9FA",
         label="NMOSD / AQP4-IgG QSP Mechanistic Map\nNeuromyelitis Optica Spectrum Disorder — Comprehensive Pathophysiology & Pharmacology",
         labelloc=t, labelfontsize=14, labelfontname="Helvetica-Bold",
         nodesep=0.3, ranksep=0.5, compound=true];
  node [fontname="Helvetica", fontsize=8, style="filled,rounded", shape=box, margin="0.07,0.04"];
  edge [fontname="Helvetica", fontsize=7, arrowsize=0.5];

  // ==========================================================
  // CLUSTER 1: Genetic & Environmental Triggers
  // ==========================================================
  subgraph cluster_triggers {
    label="Genetic & Environmental Triggers";
    style=filled; bgcolor="#FFF3E0"; color="#E65100"; penwidth=2;
    fontname="Helvetica-Bold"; fontsize=9;
    HLA_DRB1   [label="HLA-DRB1*03:01\n(Genetic Risk)", fillcolor="#FFCC80"];
    HLA_DPB1   [label="HLA-DPB1*05:01\n(Asian Risk)", fillcolor="#FFCC80"];
    EBV        [label="EBV Infection\n(Molecular Mimicry)", fillcolor="#FFCC80"];
    gut_micro  [label="Gut Dysbiosis", fillcolor="#FFCC80"];
    env_trig   [label="Environmental\nTriggers", fillcolor="#FFCC80"];
    sex_horm   [label="Estrogen\n(F:M = 9:1)", fillcolor="#FFCC80"];
    AIRE_gene  [label="AIRE Dysfunction\n(Tolerance ↓)", fillcolor="#FFCC80"];
    NMO_suscept [label="NMOSD\nSusceptibility", fillcolor="#FF8F00", fontcolor=white, penwidth=2];
  }

  // ==========================================================
  // CLUSTER 2: B-Cell & Antibody Biology
  // ==========================================================
  subgraph cluster_bcell {
    label="B-Cell & AQP4-IgG Biology";
    style=filled; bgcolor="#E8F5E9"; color="#1B5E20"; penwidth=2;
    fontname="Helvetica-Bold"; fontsize=9;
    naive_B     [label="Naive B-Cell\n(CD19+)", fillcolor="#A5D6A7"];
    GC_react    [label="Germinal Center\nReaction", fillcolor="#81C784"];
    memory_B    [label="Memory B-Cell\n(CD27+ CD19+)", fillcolor="#66BB6A"];
    plasmablast [label="Plasmablast\n(CD19+ CD38+)", fillcolor="#4CAF50", fontcolor=white];
    plasma_cell [label="Long-lived\nPlasma Cell", fillcolor="#388E3C", fontcolor=white];
    AQP4_IgG    [label="AQP4-IgG\n(Autoantibody)", shape=ellipse, fillcolor="#2E7D32", fontcolor=white, penwidth=2];
    AQP4_IgG1   [label="AQP4-IgG1\n(Complement-fixing)", fillcolor="#66BB6A"];
    AQP4_IgG4   [label="AQP4-IgG4\n(Non-complement)", fillcolor="#66BB6A"];
    BAFF        [label="BAFF/BLyS\n(B-cell Survival)", fillcolor="#C8E6C9"];
    APRIL       [label="APRIL\n(LLPC Survival)", fillcolor="#C8E6C9"];
    Tfh_cell    [label="Tfh Cell\n(CD4+ CXCR5+)", fillcolor="#C8E6C9"];
    IL21        [label="IL-21\n(Tfh Cytokine)", fillcolor="#C8E6C9"];
    CD40L       [label="CD40L\n(T-B Cognate Help)", fillcolor="#C8E6C9"];
    SHM         [label="Somatic\nHypermutation", fillcolor="#A5D6A7"];
    CSR         [label="Class Switch\nRecombination", fillcolor="#A5D6A7"];
  }

  // ==========================================================
  // CLUSTER 3: Blood-Brain Barrier
  // ==========================================================
  subgraph cluster_bbb {
    label="Blood-Brain Barrier";
    style=filled; bgcolor="#E3F2FD"; color="#0D47A1"; penwidth=2;
    fontname="Helvetica-Bold"; fontsize=9;
    BBB_intact   [label="BBB Tight Junctions\n(ZO-1, Claudin-5)", fillcolor="#90CAF9"];
    transcytosis [label="IgG Transcytosis\n(FcRn-mediated)", fillcolor="#90CAF9"];
    MMP9         [label="MMP-9\n(BBB Breakdown)", fillcolor="#EF9A9A"];
    CXCL8        [label="CXCL-8\n(Neutrophil Chemokine)", fillcolor="#FFF176"];
    VEGF         [label="VEGF-A\n(Vascular Permeability)", fillcolor="#EF9A9A"];
    pericyte     [label="Pericyte\nDysfunction", fillcolor="#FFCC80"];
    BBB_breach   [label="BBB Permeability ↑\n(Disruption)", fillcolor="#EF5350", fontcolor=white];
    AQP4_endfeet [label="AQP4 on Astrocyte\nEndfeet (Perivascular)", fillcolor="#42A5F5", fontcolor=white];
    AQP4_M23     [label="AQP4-M23\n(OAP Aggregates)", fillcolor="#1E88E5", fontcolor=white];
    AQP4_M1      [label="AQP4-M1\n(Monomeric)", fillcolor="#42A5F5", fontcolor=white];
  }

  // ==========================================================
  // CLUSTER 4: Complement Cascade
  // ==========================================================
  subgraph cluster_complement {
    label="Complement Cascade (Primary Effector)";
    style=filled; bgcolor="#FCE4EC"; color="#880E4F"; penwidth=2;
    fontname="Helvetica-Bold"; fontsize=9;
    AQP4_bound  [label="AQP4-IgG\nBound Complex", fillcolor="#880E4F", fontcolor=white, penwidth=2];
    C1q_bind    [label="C1q Binding\n(Classical Pathway)", fillcolor="#F48FB1"];
    C1r_C1s     [label="C1r/C1s\nActivation", fillcolor="#F48FB1"];
    C4b2a       [label="C3 Convertase\n(C4b2a)", fillcolor="#F48FB1"];
    C3_activ    [label="C3 Activation", fillcolor="#EC407A", fontcolor=white];
    C3a         [label="C3a\n(Anaphylatoxin)", fillcolor="#F48FB1"];
    C3b_dep     [label="C3b Deposition", fillcolor="#EC407A", fontcolor=white];
    C5_conv     [label="C5 Convertase", fillcolor="#E91E63", fontcolor=white];
    C5_free     [label="Free C5", fillcolor="#F48FB1"];
    C5_clv      [label="C5 Cleavage\n(Rate-limiting)", fillcolor="#E91E63", fontcolor=white];
    C5a         [label="C5a\n(Anaphylatoxin)", fillcolor="#F48FB1"];
    C5b_assem   [label="C5b Assembly\n(MAC initiation)", fillcolor="#AD1457", fontcolor=white];
    C5b9_MAC    [label="C5b-9 MAC\n(Membrane Attack\nComplex)", shape=ellipse, fillcolor="#880E4F", fontcolor=white, penwidth=3];
    properdin   [label="Properdin\n(Alternative Path)", fillcolor="#F48FB1"];
    MBL_MASP    [label="MBL-MASP2\n(Lectin Pathway)", fillcolor="#F48FB1"];
    CD59_prot   [label="CD59 Protectin\n(MAC Inhibitor)", fillcolor="#A5D6A7"];
    CD46_MCP    [label="CD46/MCP\n(C3b Regulator)", fillcolor="#A5D6A7"];
    CFH         [label="Complement\nFactor H", fillcolor="#A5D6A7"];
    C1INH       [label="C1-Inhibitor\n(Serpin)", fillcolor="#A5D6A7"];
  }

  // ==========================================================
  // CLUSTER 5: Astrocyte Pathology
  // ==========================================================
  subgraph cluster_astrocyte {
    label="Astrocyte Pathology (Primary Lesion)";
    style=filled; bgcolor="#F3E5F5"; color="#4A148C"; penwidth=2;
    fontname="Helvetica-Bold"; fontsize=9;
    ast_normal    [label="Healthy Astrocyte", fillcolor="#CE93D8"];
    ast_react     [label="Reactive Astrocyte", fillcolor="#BA68C8"];
    ast_necrosis  [label="Astrocyte Necrosis\n(Apoptosis/Oncosis)", shape=ellipse, fillcolor="#6A1B9A", fontcolor=white, penwidth=2];
    GFAP_loss     [label="GFAP Loss\n(Astrocyte Marker)", fillcolor="#7B1FA2", fontcolor=white];
    AQP4_loss     [label="AQP4 Loss\n(Water Transport ↓)", fillcolor="#8E24AA", fontcolor=white];
    glu_release   [label="Glutamate\nRelease (↑↑)", fillcolor="#CE93D8"];
    EAAT2_loss    [label="EAAT2 Loss\n(Glu Re-uptake ↓)", fillcolor="#BA68C8"];
    IL6_ast       [label="IL-6\n(Astrocyte-derived)", fillcolor="#CE93D8"];
    CCL2_ast      [label="CCL-2/MCP-1\n(Monocyte Recruit)", fillcolor="#CE93D8"];
    CXCL1_ast     [label="CXCL-1\n(Neutrophil Recruit)", fillcolor="#CE93D8"];
    ROS_ast       [label="ROS\n(Oxidative Burst)", fillcolor="#FF8A65"];
    lipid_perox   [label="Lipid Peroxidation\n(4-HNE, MDA)", fillcolor="#FF7043"];
  }

  // ==========================================================
  // CLUSTER 6: Neuroinflammation
  // ==========================================================
  subgraph cluster_neuroinfl {
    label="Neuroinflammation & Immune Infiltration";
    style=filled; bgcolor="#FFF8E1"; color="#FF6F00"; penwidth=2;
    fontname="Helvetica-Bold"; fontsize=9;
    neutrophil [label="Neutrophil\nInfiltration", fillcolor="#FFF176"];
    eosinophil [label="Eosinophil\n(Prominent NMOSD)", fillcolor="#FFF176"];
    macro_M1   [label="M1 Macrophage\n(Pro-inflammatory)", fillcolor="#FFB300", fontcolor=white];
    macro_M2   [label="M2 Macrophage\n(Anti-inflammatory)", fillcolor="#FFF8E1"];
    NK_cell    [label="NK Cell\n(ADCC)", fillcolor="#FFF176"];
    mast_cell  [label="Mast Cell\nDegranulation", fillcolor="#FFF176"];
    histamine  [label="Histamine", fillcolor="#FFF9C4"];
    TNFa       [label="TNF-α", fillcolor="#FF8F00", fontcolor=white];
    IL1b       [label="IL-1β\n(NLRP3)", fillcolor="#FF8F00", fontcolor=white];
    IL17A      [label="IL-17A\n(Th17)", fillcolor="#FF8F00", fontcolor=white];
    GM_CSF     [label="GM-CSF", fillcolor="#FFB300", fontcolor=white];
    IFNg       [label="IFN-γ\n(Th1)", fillcolor="#FF8F00", fontcolor=white];
    MPO        [label="MPO\n(Neutrophil Enzyme)", fillcolor="#FFF176"];
    NE         [label="Neutrophil\nElastase", fillcolor="#FFF176"];
    NLRP3      [label="NLRP3\nInflammasome", fillcolor="#FFF176"];
  }

  // ==========================================================
  // CLUSTER 7: T-Cell Pathways
  // ==========================================================
  subgraph cluster_tcell {
    label="T-Cell Pathways (Th17 / Th1 / Treg)";
    style=filled; bgcolor="#E8EAF6"; color="#1A237E"; penwidth=2;
    fontname="Helvetica-Bold"; fontsize=9;
    naive_T    [label="Naive T-Cell\n(CD4+)", fillcolor="#9FA8DA"];
    Th1        [label="Th1 Cell\n(IFN-γ, IL-2)", fillcolor="#7986CB"];
    Th17       [label="Th17 Cell\n(IL-17A, IL-22)", fillcolor="#5C6BC0", fontcolor=white];
    Treg       [label="Regulatory T\n(Foxp3+, IL-10)", fillcolor="#9FA8DA"];
    CD8_CTL    [label="CD8+ CTL\n(Cytotoxic T)", fillcolor="#7986CB"];
    mDC        [label="Myeloid DC\n(Antigen Present)", fillcolor="#C5CAE9"];
    AQP4_pept  [label="AQP4 Peptide\n(MHC II)", fillcolor="#9FA8DA"];
    IL6_Th17   [label="IL-6 + TGF-β\n(Th17 Polarize)", fillcolor="#C5CAE9"];
    IL12_p70   [label="IL-12 p70\n(Th1 Polarize)", fillcolor="#C5CAE9"];
    RORgt      [label="RORγt\n(Th17 TF)", fillcolor="#9FA8DA"];
    Tbet       [label="T-bet\n(Th1 TF)", fillcolor="#9FA8DA"];
    IL10_Treg  [label="IL-10\n(Treg Anti-inflam)", fillcolor="#C8E6C9"];
    TGFb_imm   [label="TGF-β\n(Treg Induction)", fillcolor="#C8E6C9"];
  }

  // ==========================================================
  // CLUSTER 8: Oligodendrocyte & Myelin
  // ==========================================================
  subgraph cluster_myelin {
    label="Oligodendrocyte & Myelin Damage (Secondary)";
    style=filled; bgcolor="#EFEBE9"; color="#3E2723"; penwidth=2;
    fontname="Helvetica-Bold"; fontsize=9;
    oligo      [label="Oligodendrocyte", fillcolor="#D7CCC8"];
    myelin_sh  [label="Myelin Sheath", fillcolor="#BCAAA4"];
    OPC        [label="OPC\n(Precursor)", fillcolor="#D7CCC8"];
    demyelin   [label="Demyelination\n(Secondary)", fillcolor="#8D6E63", fontcolor=white];
    axon_bare  [label="Exposed Axon", fillcolor="#795548", fontcolor=white];
    remyelin   [label="Remyelination\n(Incomplete)", fillcolor="#A1887F"];
    MBP_loss   [label="MBP Loss", fillcolor="#8D6E63", fontcolor=white];
    excitotox  [label="Excitotoxicity\n(Glu-mediated)", fillcolor="#6D4C41", fontcolor=white];
    Ca_influx  [label="Ca²⁺ Influx\n(NMDA-R)", fillcolor="#795548", fontcolor=white];
    casp3      [label="Caspase-3\nApoptosis", fillcolor="#4E342E", fontcolor=white];
  }

  // ==========================================================
  // CLUSTER 9: CNS Lesion Pathology
  // ==========================================================
  subgraph cluster_lesion {
    label="CNS Lesion Pathology";
    style=filled; bgcolor="#FAFAFA"; color="#212121"; penwidth=2;
    fontname="Helvetica-Bold"; fontsize=9;
    SC_lesion  [label="Spinal Cord\nLesion (≥3 vert seg)", fillcolor="#BDBDBD"];
    ON_lesion  [label="Optic Nerve\nLesion (ON)", fillcolor="#BDBDBD"];
    AP_lesion  [label="Area Postrema\nLesion", fillcolor="#BDBDBD"];
    vas_edema  [label="Vasogenic Edema\n(Acute)", fillcolor="#EF9A9A"];
    tissue_nec [label="Tissue Necrosis", fillcolor="#757575", fontcolor=white];
    cavitation [label="Cavitation\n(Cystic Change)", fillcolor="#616161", fontcolor=white];
    Wallerian  [label="Wallerian\nDegeneration", fillcolor="#757575", fontcolor=white];
    LETM       [label="LETM\n(Longitudinally\nExtensive TM)", shape=ellipse, fillcolor="#424242", fontcolor=white, penwidth=2];
  }

  // ==========================================================
  // CLUSTER 10: Clinical Endpoints
  // ==========================================================
  subgraph cluster_endpoints {
    label="Clinical Endpoints & Outcomes";
    style=filled; bgcolor="#E0F2F1"; color="#004D40"; penwidth=2;
    fontname="Helvetica-Bold"; fontsize=9;
    EDSS       [label="EDSS (0-10)", shape=ellipse, fillcolor="#80CBC4", penwidth=2];
    ARR        [label="ARR\n(Relapses/year)", shape=ellipse, fillcolor="#4DB6AC", fontcolor=white, penwidth=2];
    vis_acuity [label="Visual Acuity\n(LogMAR)", shape=ellipse, fillcolor="#80CBC4"];
    pain_NRS   [label="Pain NRS\n(Neuropathic)", shape=ellipse, fillcolor="#80CBC4"];
    motor_func [label="Motor Function\n(MRC Grade)", shape=ellipse, fillcolor="#80CBC4"];
    bladder_dx [label="Bladder\nDysfunction", shape=ellipse, fillcolor="#80CBC4"];
    hiccup_vom [label="Hiccup/Vomiting\n(Area Postrema)", shape=ellipse, fillcolor="#80CBC4"];
    relapse_ev [label="Relapse Event", shape=ellipse, fillcolor="#00796B", fontcolor=white, penwidth=2];
    disab_prog [label="Disability\nProgression", shape=ellipse, fillcolor="#004D40", fontcolor=white, penwidth=2];
    TTP        [label="Time to 1st\nRelapse (TTP)", shape=ellipse, fillcolor="#4DB6AC", fontcolor=white];
    QoL_score  [label="QoL Score\n(NMOSD-QoL)", shape=ellipse, fillcolor="#80CBC4"];
  }

  // ==========================================================
  // CLUSTER 11: Disease Biomarkers
  // ==========================================================
  subgraph cluster_biomark {
    label="Disease Biomarkers";
    style=filled; bgcolor="#E1F5FE"; color="#01579B"; penwidth=2;
    fontname="Helvetica-Bold"; fontsize=9;
    AQP4_titer [label="AQP4-IgG Titer\n(Serum/CSF)", shape=diamond, fillcolor="#81D4FA", penwidth=2];
    MOG_IgG    [label="MOG-IgG\n(10-15% NMOSD)", shape=diamond, fillcolor="#81D4FA"];
    GFAP_ser   [label="serum GFAP\n(Astrocyte Damage)", shape=diamond, fillcolor="#4FC3F7"];
    NfL_ser    [label="serum NfL\n(Neurofilament Light)", shape=diamond, fillcolor="#4FC3F7"];
    CSF_pleo   [label="CSF Pleocytosis\n(WBC >5/mm³)", shape=diamond, fillcolor="#81D4FA"];
    compl_C3   [label="Complement C3\n(↓ attack)", shape=diamond, fillcolor="#81D4FA"];
    compl_C4   [label="Complement C4\n(↓ attack)", shape=diamond, fillcolor="#81D4FA"];
    IL6_ser    [label="IL-6 Serum\n(↑ attack)", shape=diamond, fillcolor="#4FC3F7"];
    MRI_T2     [label="MRI T2\n(Lesion Load)", shape=diamond, fillcolor="#0288D1", fontcolor=white];
    OCT_RNFL   [label="OCT-RNFL\n(Retinal Fiber ↓)", shape=diamond, fillcolor="#4FC3F7"];
    VEP_lat    [label="VEP Latency", shape=diamond, fillcolor="#81D4FA"];
    Bcell_cnt  [label="B-Cell Count\n(CD19+/CD20+)", shape=diamond, fillcolor="#4FC3F7"];
    IgG_total  [label="Total IgG\n(Serum)", shape=diamond, fillcolor="#81D4FA"];
  }

  // ==========================================================
  // CLUSTER 12: Drug PK — Approved Biologics
  // ==========================================================
  subgraph cluster_pk_bio {
    label="Drug PK — Approved Biologics";
    style=filled; bgcolor="#FFF9C4"; color="#F57F17"; penwidth=2;
    fontname="Helvetica-Bold"; fontsize=9;
    eculi_dose  [label="Eculizumab\n900mg IV q2w\n(Anti-C5)", shape=hexagon, fillcolor="#F9A825", penwidth=2];
    eculi_C1    [label="Eculizumab C1\n(Central)", fillcolor="#FFF176"];
    eculi_C2    [label="Eculizumab C2\n(Peripheral)", fillcolor="#FFF176"];
    eculi_C5cx  [label="Eculi-C5\nBound Complex", fillcolor="#F9A825"];

    ineb_dose   [label="Inebilizumab\n300mg IV d1,d15\nthen q6m (Anti-CD19)", shape=hexagon, fillcolor="#FB8C00", penwidth=2];
    ineb_C1     [label="Inebilizumab C1\n(Central)", fillcolor="#FFE0B2"];
    ineb_C2     [label="Inebilizumab C2\n(Peripheral)", fillcolor="#FFE0B2"];

    satra_dose  [label="Satralizumab\n120mg SC q4w\nthen q8w (Anti-IL6R)", shape=hexagon, fillcolor="#EF6C00", penwidth=2];
    satra_C1    [label="Satralizumab C1\n(Central)", fillcolor="#FFE0B2"];
    satra_C2    [label="Satralizumab C2\n(Peripheral)", fillcolor="#FFE0B2"];
    satra_IL6Rcx [label="Satra-IL6R\nBound Complex", fillcolor="#EF6C00", fontcolor=white];

    ubli_dose   [label="Ublituximab\n450mg IV q6m\n(Anti-CD20)", shape=hexagon, fillcolor="#E65100", fontcolor=white, penwidth=2];
    ubli_C1     [label="Ublituximab C1\n(Central)", fillcolor="#FFCCBC"];
  }

  // ==========================================================
  // CLUSTER 13: Drug PK — Conventional
  // ==========================================================
  subgraph cluster_pk_conv {
    label="Drug PK — Conventional & Rescue";
    style=filled; bgcolor="#F3E5F5"; color="#6A1B9A"; penwidth=2;
    fontname="Helvetica-Bold"; fontsize=9;
    ritu_dose   [label="Rituximab\n1000mg IV\n(Anti-CD20 off-label)", shape=hexagon, fillcolor="#CE93D8", penwidth=2];
    ritu_C1     [label="Rituximab C1\n(Central)", fillcolor="#E1BEE7"];
    ritu_C2     [label="Rituximab C2\n(Peripheral)", fillcolor="#E1BEE7"];

    pred_dose   [label="Prednisolone\n1mg/kg PO\n(Acute attack)", shape=hexagon, fillcolor="#BA68C8"];
    pred_C1     [label="Prednisolone\nPlasma", fillcolor="#E1BEE7"];
    pred_GR     [label="GR-Prednisolone\nNuclear Complex", fillcolor="#CE93D8"];

    aza_dose    [label="Azathioprine\n2-3mg/kg PO\n(Conventional)", shape=hexagon, fillcolor="#9C27B0", fontcolor=white];
    aza_6MP     [label="6-MP\n(Active Metabolite)", fillcolor="#CE93D8"];
    aza_6TGN    [label="6-TGN\n(Purine Inhibitor)", fillcolor="#9C27B0", fontcolor=white];

    mmf_dose    [label="MMF\n2g/day PO", shape=hexagon, fillcolor="#AB47BC"];
    mpa_plasma  [label="MPA\n(Active Metabolite)", fillcolor="#CE93D8"];
    mpa_IMPDH   [label="MPA-IMPDH\nInhibition", fillcolor="#AB47BC"];

    ivig_dose   [label="IVIG 2g/kg\n(5-day IV course)", shape=hexagon, fillcolor="#7B1FA2", fontcolor=white];
    ivig_C1     [label="IVIG Plasma\n(IgG)", fillcolor="#E1BEE7"];

    PE_proc     [label="Plasma Exchange\n(5-7 sessions)\n(Rescue)", shape=hexagon, fillcolor="#4A148C", fontcolor=white];
  }

  // ==========================================================
  // CLUSTER 14: Drug PD Effects
  // ==========================================================
  subgraph cluster_pd {
    label="Drug Pharmacodynamic Mechanisms";
    style=filled; bgcolor="#E8F5E9"; color="#1B5E20"; penwidth=2;
    fontname="Helvetica-Bold"; fontsize=9;
    C5_inhib    [label="C5 Inhibition\n(→ ↓ MAC)", fillcolor="#A5D6A7", penwidth=2];
    CD19_dep    [label="CD19+ B-Cell\nDepletion (Ineb)", fillcolor="#81C784", penwidth=2];
    CD20_dep    [label="CD20+ B-Cell\nDepletion (RTX/Ubli)", fillcolor="#66BB6A", penwidth=2];
    IL6R_block  [label="IL-6R Blockade\n(Satralizumab)", fillcolor="#A5D6A7", penwidth=2];
    GR_activ    [label="GR Activation\n(Steroid)", fillcolor="#81C784"];
    IMPDH_inh   [label="IMPDH Inhibition\n(MMF)", fillcolor="#A5D6A7"];
    pur_inhib   [label="Purine Synthesis ↓\n(AZA → 6-TGN)", fillcolor="#A5D6A7"];
    FcRn_block  [label="FcRn Saturation\n(IVIG → IgG ↑ CL)", fillcolor="#81C784"];
    Ab_removal  [label="Antibody Removal\n(Plasma Exchange)", fillcolor="#66BB6A"];
    ADCC_RTX    [label="ADCC\n(RTX via NK cells)", fillcolor="#A5D6A7"];
    B_mem_dep   [label="Memory B Depletion\n(Sustained Remission)", fillcolor="#C8E6C9"];
  }

  // ============================================================
  // EDGES — Disease Pathophysiology
  // ============================================================

  HLA_DRB1  -> NMO_suscept [color="#E65100"];
  HLA_DPB1  -> NMO_suscept [color="#E65100"];
  EBV       -> NMO_suscept [label="Mimicry", color="#E65100"];
  gut_micro -> NMO_suscept [color="#E65100"];
  env_trig  -> NMO_suscept [color="#E65100"];
  sex_horm  -> NMO_suscept [label="Estrogen↑Th17", color="#E65100"];
  AIRE_gene -> NMO_suscept [color="#E65100"];

  NMO_suscept -> naive_B  [color="#1B5E20"];
  NMO_suscept -> naive_T  [color="#1A237E"];

  naive_B   -> GC_react   [label="Activation", color="#1B5E20"];
  BAFF      -> GC_react   [label="Survival", color="#1B5E20"];
  APRIL     -> plasma_cell [label="LLPC survival", color="#1B5E20"];
  Tfh_cell  -> GC_react   [label="CD40L/IL-21", color="#1A237E"];
  IL21      -> GC_react   [color="#1A237E"];
  CD40L     -> GC_react   [color="#1A237E"];
  GC_react  -> SHM        [color="#1B5E20"];
  GC_react  -> CSR        [color="#1B5E20"];
  SHM       -> AQP4_IgG1  [color="#1B5E20"];
  CSR       -> AQP4_IgG4  [color="#1B5E20"];
  GC_react  -> memory_B   [color="#1B5E20"];
  GC_react  -> plasmablast [color="#1B5E20"];
  plasmablast -> plasma_cell [label="Differentiation", color="#1B5E20"];
  plasma_cell -> AQP4_IgG [label="Secrete", color="#1B5E20", penwidth=2];
  plasmablast -> AQP4_IgG [label="Secrete early", color="#1B5E20"];
  AQP4_IgG  -> AQP4_IgG1  [color="#1B5E20"];
  AQP4_IgG  -> AQP4_IgG4  [color="#1B5E20"];

  naive_T   -> Th1        [label="IL-12", color="#1A237E"];
  naive_T   -> Th17       [label="IL-6+TGFβ", color="#1A237E"];
  naive_T   -> Treg       [label="TGF-β", color="#1A237E"];
  naive_T   -> Tfh_cell   [color="#1A237E"];
