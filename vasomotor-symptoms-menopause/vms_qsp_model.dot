digraph VMS_QSP {
  graph [rankdir=LR, fontname="Helvetica", fontsize=11, labelloc=t,
         label="Vasomotor Symptoms of Menopause (폐경기 혈관운동증상) — Integrated QSP Mechanistic Map\nOvarian Follicle Depletion · HPG-Axis Feedback Loss · KNDy-Neuron Hypertrophy · NKB/NK3R Thermoregulatory Narrowing · Hot Flush/Night-Sweat Generation\nNK3R/NK1R antagonists (fezolinetant / elinzanetant) · Hormone therapy (estradiol ± progestogen) · SSRIs/SNRIs (paroxetine/venlafaxine) · Gabapentinoids · Clonidine · Oxybutynin",
         splines=spline, overlap=false, nodesep=0.30, ranksep=0.55,
         bgcolor="#fbfbfd"];
  node  [shape=box, style="rounded,filled", fontname="Helvetica", fontsize=10,
         fillcolor="#ffffff", color="#7d8590"];
  edge  [fontname="Helvetica", fontsize=9, color="#6e7681", arrowsize=0.7];

  /* ───────────────────────── 1. Reproductive Aging / Ovarian Depletion ───── */
  subgraph cluster_ovary {
    label="1. Ovarian Aging & Follicle Depletion (STRAW+10 stages)";
    style="filled,rounded"; color="#5c6370"; fillcolor="#f3f0ff"; fontsize=12;
    AGE_YR      [label="Chronological age\n(perimenopause ~47-51y)"];
    AMH         [label="AMH\n(ovarian reserve marker)\nprogressive decline"];
    PrimFoll    [label="Primordial follicle pool\n(non-renewing, ~1M at birth)"];
    AtresiaRate [label="Atresia rate\n(exponential ↑ with age)"];
    FollNumber  [label="Recruitable antral\nfollicle number ↓"];
    GranCell    [label="Granulosa-cell\nfunctional mass ↓"];
    InhibinB    [label="Inhibin B\n(FSH-suppressing)\n↓↓ early perimenopause"];
    STRAW       [label="STRAW+10 stage\n(-2 late repro → +1c late peri → +2 postmenopause)"];
    Menopause1y [label="Final menstrual period (FMP)\n+ 12 mo amenorrhea = menopause"];
    SurgMeno    [label="Surgical / iatrogenic menopause\n(BSO, chemo, RT, AI/tamoxifen)"];
    AGE_YR -> AtresiaRate -> PrimFoll;
    PrimFoll -> FollNumber;
    FollNumber -> GranCell;
    GranCell -> InhibinB;
    FollNumber -> AMH [style=dashed];
    InhibinB -> STRAW;
    FollNumber -> STRAW;
    STRAW -> Menopause1y;
    SurgMeno -> FollNumber [style=dashed, label="abrupt loss"];
  }

  /* ───────────────────────── 2. HPG-Axis Feedback Loss ───────────────────── */
  subgraph cluster_hpg {
    label="2. HPG-Axis Feedback (GnRH pulse generator → FSH/LH → E2)";
    style="filled,rounded"; color="#5c6370"; fillcolor="#fff4e6"; fontsize=12;
    GnRH_PG     [label="Arcuate GnRH\npulse generator"];
    GnRH_Freq   [label="GnRH pulse frequency ↑\n(loss of P4/E2 negative feedback)"];
    LH_Pulse    [label="LH pulse amplitude/\nfrequency ↑"];
    FSH_Rise    [label="FSH ↑↑\n(>25-40 IU/L postmenopause)"];
    LH_Rise     [label="LH ↑\n(>30 IU/L postmenopause)"];
    E2_Ovarian  [label="Ovarian E2 production\n↓↓ (<10-20 pg/mL)"];
    E1          [label="Estrone (E1)\n(adipose aromatization\nbecomes dominant source)"];
    Testo_Adr   [label="Adrenal/ovarian\nandrostenedione → T"];
    NegFeedback [label="E2/Inhibin-B negative\nfeedback on pituitary"];
    GranCell -> E2_Ovarian;
    E2_Ovarian -> NegFeedback;
    InhibinB -> NegFeedback;
    NegFeedback -> GnRH_Freq [style=dashed, label="loss of brake"];
    GnRH_PG -> GnRH_Freq -> LH_Pulse;
    LH_Pulse -> LH_Rise;
    GnRH_Freq -> FSH_Rise;
    Testo_Adr -> E1 [style=dashed, label="peripheral\naromatization"];
    E2_Ovarian -> E1 [style=dashed];
  }

  /* ───────────────────────── 3. KNDy-Neuron Biology ──────────────────────── */
  subgraph cluster_kndy {
    label="3. Arcuate KNDy Neurons (Kisspeptin·Neurokinin B·Dynorphin)";
    style="filled,rounded"; color="#5c6370"; fillcolor="#ffe6ec"; fontsize=12;
    KNDy_Neuron [label="Arcuate (infundibular)\nKNDy neuron population"];
    KNDy_Hyper  [label="KNDy neuron hypertrophy\n(↑ soma/nucleus size,\n Rance 1990/2010)"];
    Kiss1       [label="Kiss1 / Kisspeptin\nmRNA & peptide ↑"];
    TAC3_NKB    [label="TAC3 / Neurokinin B (NKB)\nmRNA & peptide ↑↑"];
    PDYN_Dyn    [label="PDYN / Dynorphin A\n(inhibitory co-transmitter)\nmRNA ↑ but tone ↓ net"];
    ERa_KNDy    [label="ERα (ESR1) on KNDy\nneurons — tonic brake"];
    NKB_Auto    [label="NKB autosynaptic\nfeed-forward loop\n(NK3R on KNDy itself)"];
    KissR_GnRH  [label="Kisspeptin → KISS1R\non GnRH neurons"];
    E2_Ovarian -> ERa_KNDy;
    ERa_KNDy -> KNDy_Hyper [style=dashed, label="loss of E2 brake"];
    KNDy_Hyper -> Kiss1;
    KNDy_Hyper -> TAC3_NKB;
    KNDy_Hyper -> PDYN_Dyn;
    TAC3_NKB -> NKB_Auto -> TAC3_NKB [label="feed-forward"];
    Kiss1 -> KissR_GnRH -> GnRH_PG;
    PDYN_Dyn -> KNDy_Neuron [style=dashed, label="κ-opioid\nself-inhibition (↓ net)"];
  }

  /* ───────────────────────── 4. NK3R Signaling & Thermoregulatory Center ── */
  subgraph cluster_thermo {
    label="4. NKB→NK3R Signaling & Median Preoptic (MnPO) Thermoregulatory Center";
    style="filled,rounded"; color="#5c6370"; fillcolor="#e6f6ff"; fontsize=12;
    NK3R        [label="NK3R (TACR3)\non MnPO/POA neurons\n& KNDy autoreceptor"];
    MnPO        [label="Median preoptic nucleus\n(MnPO) thermoregulatory\nintegrator"];
    DMH         [label="Dorsomedial hypothalamus\n(DMH) — heat-defense output"];
    RPa         [label="Raphe pallidus (RPa)\n— sympathetic premotor"];
    TNZ         [label="Thermoneutral zone (TNZ)\nwidth ↓↓ (narrows)"];
    SetpointSft [label="Sweating/vasodilation\nthreshold shifted downward"];
    CoreTemp    [label="Core body temperature\n(Tc) — small pre-flush rise"];
    SkinTemp    [label="Peripheral/skin\ntemperature"];
    TAC3_NKB -> NK3R;
    NK3R -> MnPO [label="excitatory"];
    MnPO -> TNZ [style=dashed, label="narrows"];
    MnPO -> DMH;
    DMH -> RPa;
    TNZ -> SetpointSft;
    CoreTemp -> MnPO [style=dashed, label="afferent\nthermosensory input"];
    SkinTemp -> MnPO [style=dashed];
  }

  /* ───────────────────────── 5. Autonomic / Peripheral Vasomotor Effector ── */
  subgraph cluster_auto {
    label="5. Sympathetic Effector Arm — Cutaneous Vasodilation & Sweating";
    style="filled,rounded"; color="#5c6370"; fillcolor="#eafbea"; fontsize=12;
    SNS_Skin    [label="Cutaneous sympathetic\nvasoconstrictor tone\n(paradoxically WITHDRAWN)"];
    CutBloodFlow[label="Cutaneous blood flow ↑↑\n(forearm/finger, Doppler)"];
    SweatGland  [label="Eccrine sweat gland\nactivation (cholinergic)"];
    SkinConduct [label="Skin conductance\n(sternal) ↑ — objective\nhot-flush marker"];
    HeartRate   [label="Heart rate ↑\n(transient tachycardia, +10-20 bpm)"];
    Flush       [label="Cutaneous flushing\n(chest/neck/face erythema)"];
    Chills      [label="Post-flush chills\n(after-drop, Tc undershoot)"];
    RPa -> SNS_Skin [style=dashed, label="disinhibits\nvasodilation"];
    SNS_Skin -> CutBloodFlow;
    RPa -> SweatGland;
    CutBloodFlow -> Flush;
    CutBloodFlow -> SkinConduct;
    SweatGland -> SkinConduct;
    RPa -> HeartRate [style=dashed];
    CutBloodFlow -> CoreTemp [style=dashed, label="heat loss\n→ Tc drop"];
    CoreTemp -> Chills [style=dashed];
  }

  /* ───────────────────────── 6. Clinical VMS Phenotype ───────────────────── */
  subgraph cluster_clinvms {
    label="6. Clinical VMS Phenotype (Hot Flush · Night Sweats)";
    style="filled,rounded"; color="#5c6370"; fillcolor="#fff9e6"; fontsize=12;
    HF_Trigger  [label="Trigger threshold crossed\n(stress, caffeine, heat, alcohol)"];
    HF_Event    [label="Hot-flush event\n(subjective + physiologic)"];
    HF_Freq     [label="Hot-flush frequency\n(events/24h)"];
    HF_Severity [label="Hot-flush severity\n(mild/moderate/severe)"];
    NightSweat  [label="Night sweats\n(nocturnal HF)"];
    Duration    [label="VMS duration\n(median 7.4 y, SWAN)"];
    TNZ -> HF_Trigger [style=dashed];
    HF_Trigger -> HF_Event;
    Flush -> HF_Event;
    SkinConduct -> HF_Event [style=dashed, label="objective\nconfirmation"];
    HF_Event -> HF_Freq;
    HF_Event -> HF_Severity;
    HF_Event -> NightSweat [style=dashed, label="if nocturnal"];
    HF_Freq -> Duration [style=dashed];
  }

  /* ───────────────────────── 7. Sleep & CNS/Mood Consequences ────────────── */
  subgraph cluster_sleep {
    label="7. Sleep Architecture & CNS/Mood Consequences";
    style="filled,rounded"; color="#5c6370"; fillcolor="#f0e6ff"; fontsize=12;
    NightSweat2 [label="Nocturnal awakening\n(NightSweat trigger)"];
    SleepFrag   [label="Sleep fragmentation\n(↓ SWS, ↑ WASO)"];
    Insomnia    [label="Insomnia symptoms\n(ISI score ↑)"];
    Fatigue     [label="Daytime fatigue"];
    Irritab     [label="Irritability /\nconcentration deficit"];
    MoodDep     [label="Depressive symptoms\n(PHQ-9 ↑, perimenopausal\ndepression risk window)"];
    Cognition   [label="Verbal memory /\nprocessing-speed dip"];
    NightSweat -> NightSweat2 -> SleepFrag;
    SleepFrag -> Insomnia;
    SleepFrag -> Fatigue;
    Insomnia -> Irritab;
    Irritab -> MoodDep [style=dashed];
    E2_Ovarian -> MoodDep [style=dashed, label="direct central\nE2 withdrawal effect"];
    SleepFrag -> Cognition [style=dashed];
  }

  /* ───────────────────────── 8. Bone Metabolism ──────────────────────────── */
  subgraph cluster_bone {
    label="8. Skeletal Consequences of Estrogen Deficiency";
    style="filled,rounded"; color="#5c6370"; fillcolor="#e6fff5"; fontsize=12;
    RANKL       [label="RANKL expression\n(osteoblast/stromal) ↑"];
    OPG         [label="Osteoprotegerin (OPG) ↓"];
    Osteoclast  [label="Osteoclastogenesis /\nactivity ↑"];
    BoneResorp  [label="Bone resorption\n(CTX-I) ↑"];
    BoneForm    [label="Bone formation\n(P1NP) — lags resorption"];
    BMD_loss    [label="BMD decline\n(~2%/yr peri-, spine>hip)"];
    FxRisk      [label="Fragility fracture risk ↑\n(vertebral/hip)"];
    E2_Ovarian -> RANKL [style=dashed, label="loss of\nE2 suppression"];
    RANKL -> Osteoclast; OPG -> Osteoclast [style=dashed, label="inhibits"];
    E2_Ovarian -> OPG [style=dashed];
    Osteoclast -> BoneResorp -> BMD_loss;
    BoneForm -> BMD_loss [style=dashed, label="partial\ncoupling"];
    BMD_loss -> FxRisk;
  }

  /* ───────────────────────── 9. Cardiometabolic / Lipid Effects ──────────── */
  subgraph cluster_cardio {
    label="9. Cardiometabolic & Lipid Consequences";
    style="filled,rounded"; color="#5c6370"; fillcolor="#ffe6d9"; fontsize=12;
    LDL_rise    [label="LDL-C ↑ (~10-15%)"];
    HDL_fall    [label="HDL-C ↓ modestly"];
    EndoFx      [label="Endothelial function ↓\n(FMD, NO bioavailability)"];
    ArtStiff    [label="Arterial stiffness ↑\n(PWV)"];
    VisceralFat [label="Visceral adiposity ↑\n(fat redistribution)"];
    InsulinRes  [label="Insulin sensitivity ↓"];
    VMS_CVrisk  [label="Frequent/persistent VMS\nassociated with ↑ subclinical\nCVD markers (SWAN Heart)"];
    E2_Ovarian -> LDL_rise [style=dashed, label="loss of\nhepatic LDLR upreg."];
    E2_Ovarian -> HDL_fall [style=dashed];
    E2_Ovarian -> EndoFx [style=dashed];
    EndoFx -> ArtStiff;
    E2_Ovarian -> VisceralFat [style=dashed];
    VisceralFat -> InsulinRes;
    HF_Freq -> VMS_CVrisk [style=dashed];
  }

  /* ───────────────────────── 10. Genitourinary Syndrome of Menopause ────── */
  subgraph cluster_gsm {
    label="10. Genitourinary Syndrome of Menopause (GSM)";
    style="filled,rounded"; color="#5c6370"; fillcolor="#ffeef2"; fontsize=12;
    VagEpith    [label="Vaginal epithelial\nthinning / ↓ rugae"];
    VagPH       [label="Vaginal pH ↑\n(>4.5, loss of lactobacilli)"];
    VagBloodFlow[label="Vaginal blood flow /\nlubrication ↓"];
    Dyspareunia [label="Dyspareunia"];
    UrgeSx      [label="Urinary urgency /\nrecurrent UTI"];
    E2_Ovarian -> VagEpith [style=dashed];
    VagEpith -> VagPH;
    VagEpith -> VagBloodFlow -> Dyspareunia;
    VagEpith -> UrgeSx [style=dashed];
  }

  /* ───────────────────────── 11. Drug PK — NK3R/NK1R Antagonists ─────────── */
  subgraph cluster_pk_nk3 {
    label="11. Drug PK/PD — NK3R Antagonist (Fezolinetant) & NK1/3 Dual (Elinzanetant)";
    style="filled,rounded"; color="#5c6370"; fillcolor="#e6f0ff"; fontsize=12;
    FEZ_dose    [label="Fezolinetant 45 mg PO QD\n(VEOZAH)"];
    FEZ_gut     [label="Gut/absorption\ncompartment"];
    FEZ_plasma  [label="Plasma fezolinetant\n(CYP1A2 metabolism)"];
    FEZ_NK3block[label="NK3R blockade\n(direct antagonism)"];
    ELZ_dose    [label="Elinzanetant 120 mg PO QD\n(OASIS trials)"];
    ELZ_plasma  [label="Plasma elinzanetant"];
    ELZ_block   [label="NK1R + NK3R\ndual blockade"];
    LFT_flag    [label="Hepatic transaminase\nmonitoring (rare ALT↑)"];
    FEZ_dose -> FEZ_gut -> FEZ_plasma;
    FEZ_plasma -> FEZ_NK3block;
    FEZ_NK3block -> NK3R [style=dashed, label="competitive\nantagonism"];
    ELZ_dose -> ELZ_plasma -> ELZ_block;
    ELZ_block -> NK3R [style=dashed];
    FEZ_plasma -> LFT_flag [style=dashed];
  }

  /* ───────────────────────── 12. Drug PK — Hormone Therapy ───────────────── */
  subgraph cluster_pk_hrt {
    label="12. Drug PK/PD — Hormone Therapy (Estrogen ± Progestogen)";
    style="filled,rounded"; color="#5c6370"; fillcolor="#e6fff0"; fontsize=12;
    E2_oral     [label="Oral estradiol 1 mg QD\n(1st-pass → E1 dominant)"];
    E2_patch    [label="Transdermal E2 patch\n0.05 mg/day (zero-order)"];
    CEE_dose    [label="Conjugated equine\nestrogens (CEE) 0.625 mg"];
    ExogE2      [label="Exogenous plasma E2"];
    Progestogen [label="Progestogen add\n(MPA / micronized P4)\n— endometrial protection"];
    HRT_ERa     [label="Systemic ERα/β\nreceptor occupancy"];
    E2_oral -> ExogE2; E2_patch -> ExogE2; CEE_dose -> ExogE2;
    ExogE2 -> HRT_ERa;
    HRT_ERa -> ERa_KNDy [style=dashed, label="restores\nE2 brake"];
    HRT_ERa -> RANKL [style=dashed, label="suppresses"];
    HRT_ERa -> VagEpith [style=dashed, label="restores"];
    Progestogen -> HRT_ERa [style=dashed, label="endometrial\nsafety, no VMS effect"];
  }

  /* ───────────────────────── 13. Drug PK — Nonhormonal Agents ─────────────── */
  subgraph cluster_pk_nonhorm {
    label="13. Drug PK/PD — Nonhormonal Agents (SSRI/SNRI · Gabapentinoid · α2-agonist)";
    style="filled,rounded"; color="#5c6370"; fillcolor="#fff0e6"; fontsize=12;
    PAROX_dose  [label="Paroxetine 7.5 mg QD\n(Brisdelle, low-dose)"];
    PAROX_plasma[label="Plasma paroxetine\n(CYP2D6 substrate)"];
    VEN_dose    [label="Venlafaxine ER\n37.5-75 mg QD"];
    VEN_plasma  [label="Plasma venlafaxine"];
    ODV_plasma  [label="O-desmethyl-venlafaxine\n(active metabolite)"];
    GABA_dose   [label="Gabapentin\n300-900 mg/day (÷)"];
    GABA_plasma [label="Plasma gabapentin\n(saturable absorption)"];
    CLON_dose   [label="Clonidine 0.1 mg\n(patch/PO, α2-agonist)"];
    SERT_5HT    [label="5-HT/NE reuptake\ninhibition (raphe/LC)"];
    GABA_Ca     [label="α2δ Ca-channel\nbinding (GABA_dose action)"];
    PAROX_dose -> PAROX_plasma -> SERT_5HT;
    VEN_dose -> VEN_plasma -> ODV_plasma;
    VEN_plasma -> SERT_5HT; ODV_plasma -> SERT_5HT;
    GABA_dose -> GABA_plasma -> GABA_Ca;
    SERT_5HT -> RPa [style=dashed, label="modulates\nthermoregulatory\npremotor tone"];
    GABA_Ca -> MnPO [style=dashed, label="dampens\nexcitability"];
    CLON_dose -> RPa [style=dashed, label="α2-agonism →\n↓ sympathetic outflow"];
  }

  /* ───────────────────────── 14. Clinical Endpoints & Outcome Scales ─────── */
  subgraph cluster_endpoints {
    label="14. Clinical Endpoints, Biomarkers & PROs";
    style="filled,rounded"; color="#5c6370"; fillcolor="#f5f5f5"; fontsize=12;
    HFsc_wk     [label="Weekly moderate-to-severe\nHF frequency (SKYLIGHT primary)"];
    HFsc_sev    [label="HF severity composite score"];
    MENQOL      [label="MENQOL / VMS-specific\nQoL score"];
    PSQI        [label="PSQI / sleep-quality index"];
    GreeneScale [label="Greene Climacteric Scale"];
    TscoreDXA   [label="DXA T-score\n(spine/hip)"];
    LipidPanel  [label="Fasting lipid panel"];
    ALT_safety  [label="ALT/AST safety flag"];
    HF_Freq -> HFsc_wk; HF_Severity -> HFsc_sev;
    MoodDep -> GreeneScale [style=dashed]; Insomnia -> PSQI [style=dashed];
    HFsc_wk -> MENQOL [style=dashed]; PSQI -> MENQOL [style=dashed];
    BMD_loss -> TscoreDXA;
    LDL_rise -> LipidPanel; HDL_fall -> LipidPanel;
    LFT_flag -> ALT_safety;
  }

  /* ───────────────────────── Cross-cluster master feedback arrows ────────── */
  NK3R -> KNDy_Neuron [style=dashed, color="#c0392b", label="autoreceptor\nfeed-forward"];
  FEZ_NK3block -> HF_Freq [color="#1f6feb", penwidth=1.4, label="↓↓ frequency\n(SKYLIGHT 1/2)"];
  ELZ_block -> HF_Freq [color="#1f6feb", penwidth=1.4, label="↓↓ frequency\n(OASIS)"];
  ExogE2 -> HF_Freq [color="#2e7d32", penwidth=1.4, label="gold-standard\nefficacy"];
  SERT_5HT -> HF_Freq [color="#8e44ad", label="moderate ↓"];
  GABA_Ca -> HF_Freq [color="#8e44ad", label="moderate ↓, ↑ sleep"];
  CLON_dose -> HF_Freq [color="#8e44ad", label="modest ↓"];
  HRT_ERa -> BMD_loss [style=dashed, color="#2e7d32", label="prevents"];
  HRT_ERa -> LipidPanel [style=dashed, color="#2e7d32"];
}
