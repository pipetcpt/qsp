digraph Evans_Syndrome_QSP {
    graph [
        label = "Evans Syndrome (ES) – QSP Mechanistic Map\nCombined Autoimmune Hemolytic Anemia (AIHA) + Immune Thrombocytopenia (ITP)\nQuantitative Systems Pharmacology Model",
        labelloc = "t",
        fontname = "Helvetica-Bold",
        fontsize = 20,
        bgcolor = "#FAFAFA",
        rankdir = "TB",
        splines = "ortho",
        nodesep = 0.35,
        ranksep = 0.9,
        compound = true,
        tooltip = "Evans Syndrome QSP Model"
    ];
    node [fontname="Helvetica", fontsize=9, style=filled, margin="0.12,0.06", shape=box];
    edge [fontname="Helvetica", fontsize=8, arrowsize=0.65];

    /* ======================================================
       CLUSTER 1: Disease Triggers & Innate Immunity
       ====================================================== */
    subgraph cluster_trigger {
        label = "1. Disease Triggers & Innate Immune Activation";
        style = filled; fillcolor = "#FFF3E0"; color = "#BF360C";
        fontname = "Helvetica-Bold"; fontsize = 12; fontcolor = "#BF360C";
        node [fillcolor="#FFCC80", color="#BF360C"];

        EBV [label="EBV Infection\n(Epstein-Barr Virus)"];
        CMV [label="CMV Infection"];
        Viral_Trigger [label="Viral Trigger\n(Molecular Mimicry)"];
        ALPS_Mutation [label="ALPS\n(FAS/FASL Mutation)"];
        CTLA4_Haplo [label="CTLA4\nHaploinsufficiency"];
        LRBA_Def [label="LRBA Deficiency\n(Primary Immune Defect)"];
        PI3K_Dysreg [label="PI3Kδ Gain-of-\nFunction Mutation"];
        TLR7_9 [label="TLR7/9 Activation\n(ssRNA/CpG DNA)"];
        pDC [label="pDC Activation\n→ IFN-α/β↑"];
        DC_Mat [label="DC Maturation\nMHC-II Upregulation"];
        Type1_IFN [label="Type I IFN\nSignaling Cascade"];
        IL6_TNF [label="IL-6 / TNF-α\nPro-inflammatory"];
        Innate_Cyto [label="Innate Cytokine\nMilieu (IL-12, IL-18)"];
        NK_Dysfunct [label="NK Cell\nDysfunction"];
        Ag_Present [label="Self-Antigen\nPresentation (RBC/Plt)"];
    }

    /* ======================================================
       CLUSTER 2: B Cell Autoimmunity – Anti-RBC (AIHA)
       ====================================================== */
    subgraph cluster_bcell_rbc {
        label = "2. B Cell Autoimmunity – Anti-RBC (AIHA)";
        style = filled; fillcolor = "#FFEBEE"; color = "#B71C1C";
        fontname = "Helvetica-Bold"; fontsize = 12; fontcolor = "#B71C1C";
        node [fillcolor="#EF9A9A", color="#B71C1C"];

        Naive_B_RBC  [label="Naive B Cell\n(Anti-RBC specificity)"];
        GC_RBC       [label="Germinal Center\nReaction (anti-RBC)"];
        SHM_RBC      [label="Somatic\nHypermutation"];
        CSR_IgG_RBC  [label="IgM→IgG\nClass Switching"];
        Eff_B_RBC    [label="Anti-RBC\nB Effector Cell"];
        PC_RBC       [label="Long-Lived\nPlasma Cell (AIHA)"];
        Mem_B_RBC    [label="Memory B Cell\n(Anti-RBC)"];
        Ab_RBC       [label="Anti-RBC IgG\n(Warm Autoantibody)"];
        Anti_RhD     [label="Anti-RhD\nAutoantibody"];
        Anti_GlyA    [label="Anti-Glycophorin A\nAutoantibody"];
        Anti_Band3   [label="Anti-Band 3\nAutoantibody"];
        DAT_Pos      [label="DAT Positive\n(IgG ± C3d on RBC)"];
        Warm_AIHA    [label="Warm AIHA\n(IgG-mediated, 37°C)"];
        BAFF_RBC     [label="BAFF/APRIL\nB Cell Survival"];
        FCGR2B_Def   [label="FcγRIIB Deficiency\n(Less inhibitory signal)"];
    }

    /* ======================================================
       CLUSTER 3: B Cell Autoimmunity – Anti-Platelet (ITP)
       ====================================================== */
    subgraph cluster_bcell_plt {
        label = "3. B Cell Autoimmunity – Anti-Platelet (ITP)";
        style = filled; fillcolor = "#E8EAF6"; color = "#1A237E";
        fontname = "Helvetica-Bold"; fontsize = 12; fontcolor = "#1A237E";
        node [fillcolor="#9FA8DA", color="#1A237E"];

        Naive_B_Plt  [label="Naive B Cell\n(Anti-Plt specificity)"];
        GC_Plt       [label="Germinal Center\nReaction (anti-Plt)"];
        SHM_Plt      [label="Somatic\nHypermutation"];
        CSR_IgG_Plt  [label="IgM→IgG\nClass Switching"];
        Eff_B_Plt    [label="Anti-Platelet\nB Effector Cell"];
        PC_Plt       [label="Long-Lived\nPlasma Cell (ITP)"];
        Mem_B_Plt    [label="Memory B Cell\n(Anti-Plt)"];
        Anti_GPIb    [label="Anti-GPIbα\nIgG Autoantibody"];
        Anti_GPIIb   [label="Anti-GPIIb/IIIa\nIgG Autoantibody"];
        PAIgG        [label="PAIgG Elevated\n(Platelet-associated IgG)"];
        Breg_Def     [label="Breg IL-10\nDeficit (Regulatory B cell↓)"];
        BCR_Signal   [label="BCR Signaling\n(BTK/PI3K/PLCγ2)"];
        CD40L_CD40   [label="CD40L–CD40\nT–B Cooperation"];
    }

    /* ======================================================
       CLUSTER 4: T Cell & Regulatory Dysfunction
       ====================================================== */
    subgraph cluster_tcell {
        label = "4. T Cell Dysregulation (Treg / Teff Imbalance)";
        style = filled; fillcolor = "#E8F5E9"; color = "#1B5E20";
        fontname = "Helvetica-Bold"; fontsize = 12; fontcolor = "#1B5E20";
        node [fillcolor="#A5D6A7", color="#1B5E20"];

        Naive_T      [label="Naive CD4+ T Cell"];
        Th1          [label="Th1 Cell\n(IFN-γ, IL-2, TNF-β)"];
        Th2          [label="Th2 Cell\n(IL-4, IL-5, IL-13)"];
        Th17         [label="Th17 Cell\n(IL-17A, IL-22)"];
        Tfh          [label="Tfh Cell\n(CXCR5+ PD-1+ ICOS+)"];
        Treg         [label="Treg Cell\n(FOXP3+ CD25+ CD127low)"];
        FOXP3        [label="FOXP3 Expression\n(Treg master TF)"];
        Treg_Def     [label="Treg Deficiency /\nFunctional Impairment"];
        IL2_Def      [label="IL-2 Deficiency\n(Treg survival ↓)"];
        TGFb         [label="TGF-β\n(Treg effector)"];
        IL10_T       [label="IL-10\n(Anti-inflammatory)"];
        CTLA4_Treg   [label="CTLA-4 on Treg\n(CD80/86 competition)"];
        IFNg         [label="IFN-γ\n(Macrophage activation)"];
        IL17A        [label="IL-17A\n(Tissue inflammation)"];
        mTOR_T       [label="mTOR Pathway\n(T cell metabolic sensor)"];
    }

    /* ======================================================
       CLUSTER 5: Complement System
       ====================================================== */
    subgraph cluster_complement {
        label = "5. Complement System Activation";
        style = filled; fillcolor = "#F3E5F5"; color = "#4A148C";
        fontname = "Helvetica-Bold"; fontsize = 12; fontcolor = "#4A148C";
        node [fillcolor="#CE93D8", color="#4A148C"];

        C1q          [label="C1q Binding\nto IgG on RBC/Plt"];
        CP           [label="Classical Pathway\n(C1q–C1r–C1s complex)"];
        C4_Cleave    [label="C4 Cleavage\n→ C4a + C4b"];
        C3_Conv      [label="C3 Convertase\n(C4b2a)"];
        C3b_Ops      [label="C3b Opsonization\non RBC surface"];
        C3d_Dep      [label="C3d Deposition\n(DAT C3d+)"];
        C5_Conv      [label="C5 Convertase\n(C4b2a3b)"];
        C5a          [label="C5a Release\n(Anaphylatoxin, PMN chemotaxis)"];
        MAC          [label="MAC (C5b-9)\nIntravascular lysis"];
        AltP         [label="Alternative Pathway\n(Amplification loop)"];
        DAF_CD55     [label="DAF/CD55\n(Complement decay factor)"];
        CD59         [label="CD59 / Protectin\n(MAC inhibitor)"];
    }

    /* ======================================================
       CLUSTER 6: Erythrocyte Destruction (Hemolysis)
       ====================================================== */
    subgraph cluster_rbc {
        label = "6. Erythrocyte Destruction (Hemolysis)";
        style = filled; fillcolor = "#FCE4EC"; color = "#880E4F";
        fontname = "Helvetica-Bold"; fontsize = 12; fontcolor = "#880E4F";
        node [fillcolor="#F48FB1", color="#880E4F"];

        oRBC         [label="IgG/C3b-Opsonized RBC"];
        FcR_Mac_RBC  [label="FcγRI/III on\nSplenic Macrophage"];
        Erythrophago [label="Erythrophagocytosis\n(Splenic Red Pulp)"];
        EVH          [label="Extravascular\nHemolysis (Spleen/Liver)"];
        IVH          [label="Intravascular\nHemolysis (MAC)"];
        Hgb_Free     [label="Free Hemoglobin\nRelease"];
        LDH_El       [label="LDH Elevation\n(↑ tissue damage)"];
        InBili       [label="Indirect Bilirubin↑\n→ Jaundice"];
        Haptoglobin  [label="Haptoglobin\nDepletion"];
        Hemoglobinuria [label="Hemoglobinuria\n(Intravascular)"];
        RBC_Pool     [label="Circulating RBC Pool\n(Normal: ~5×10¹²/L)"];
        Hgb_Level    [label="Hemoglobin\nConcentration (g/dL)"];
    }

    /* ======================================================
       CLUSTER 7: Platelet Destruction (ITP)
       ====================================================== */
    subgraph cluster_plt {
        label = "7. Platelet Destruction (ITP Component)";
        style = filled; fillcolor = "#E3F2FD"; color = "#0D47A1";
        fontname = "Helvetica-Bold"; fontsize = 12; fontcolor = "#0D47A1";
        node [fillcolor="#90CAF9", color="#0D47A1"];

        oPlt         [label="IgG-Opsonized\nPlatelet"];
        FcR_Mac_Plt  [label="FcγRI/III on\nSplenic Macrophage"];
        Plt_Phago    [label="Platelet\nPhagocytosis"];
        Spleen_Seq   [label="Splenic Sequestration\n(30–90% of Plt)"];
        Thrombocyto  [label="Thrombocytopenia\n(<100×10⁹/L)"];
        Plt_Pool     [label="Circulating Platelet\nPool (10⁹/L)"];
        Bleeding     [label="Bleeding Risk\n(Plt <20–30×10⁹/L)"];
        Petechiae    [label="Petechiae /\nPurpura"];
        GI_Bleed     [label="GI Bleeding\nRisk"];
        ICH          [label="Intracranial\nHemorrhage Risk"];
        MK_Inhib     [label="Megakaryocyte\nDestruction (Ab-mediated)"];
        TPO_Insuff   [label="TPO Response\nInsufficient"];
    }

    /* ======================================================
       CLUSTER 8: Bone Marrow Hematopoiesis (Compensatory)
       ====================================================== */
    subgraph cluster_bm {
        label = "8. Bone Marrow Compensatory Hematopoiesis";
        style = filled; fillcolor = "#FFF8E1"; color = "#E65100";
        fontname = "Helvetica-Bold"; fontsize = 12; fontcolor = "#E65100";
        node [fillcolor="#FFE082", color="#E65100"];

        HSC          [label="Hematopoietic\nStem Cell (HSC)"];
        BFU_E        [label="BFU-E\n(Burst-forming unit-E)"];
        CFU_E        [label="CFU-E\n(Colony-forming unit-E)"];
        ProEryth     [label="Pro-Erythroblast"];
        BasoEryth    [label="Basophilic\nErythroblast"];
        OrthoEryth   [label="Orthochromatic\nErythroblast"];
        Retic        [label="Reticulocyte\n(Immature RBC)"];
        Mature_RBC   [label="Mature RBC\n→ Circulation"];
        EPO_Sig      [label="EPO Signaling\n(JAK2/STAT5)"];
        Serum_EPO    [label="Serum EPO↑\n(Hypoxia response)"];
        Pro_MK       [label="Megakaryocyte\nProgenitor (CFU-Mk)"];
        MK_BM        [label="Megakaryocyte\n(BM maturation)"];
        Plt_Rel      [label="Platelet Release\n→ Circulation"];
        TPO_Sig      [label="TPO Signaling\n(JAK2/STAT3/5/c-Mpl)"];
        BM_Exhaust   [label="BM Exhaustion\n(Chronic severe disease)"];
    }

    /* ======================================================
       CLUSTER 9: Clinical Manifestations & Endpoints
       ====================================================== */
    subgraph cluster_clinical {
        label = "9. Clinical Manifestations & Endpoints";
        style = filled; fillcolor = "#EFEBE9"; color = "#3E2723";
        fontname = "Helvetica-Bold"; fontsize = 12; fontcolor = "#3E2723";
        node [fillcolor="#BCAAA4", color="#3E2723"];

        Fatigue_Dysp [label="Fatigue &\nDyspnea (Anemia)"];
        Jaundice_Spl [label="Jaundice &\nSplenomegaly"];
        Bleed_Epi    [label="Bleeding Episodes\n(ITP component)"];
        Thromb_Risk  [label="Thromboembolic\nEvents (rare)"];
        AIHA_Resp    [label="AIHA Treatment\nResponse (Hb↑)"];
        ITP_Resp     [label="ITP Treatment\nResponse (Plt↑)"];
        CR           [label="Complete Response\n(Hb≥12g/dL, Plt≥100×10⁹/L)"];
        PR           [label="Partial Response\n(Improvement, not CR)"];
        Relapse      [label="Disease Relapse\n(50–80% in ES)"];
        Mortality    [label="Mortality Risk\n(Severe bleeding/hemolysis)"];
    }

    /* ======================================================
       CLUSTER 10: Drug PK/PD Mechanisms
       ====================================================== */
    subgraph cluster_drugs {
        label = "10. Drug PK/PD Mechanisms";
        style = filled; fillcolor = "#E0F7FA"; color = "#006064";
        fontname = "Helvetica-Bold"; fontsize = 12; fontcolor = "#006064";
        node [fillcolor="#80DEEA", color="#006064"];

        Pred_Dose    [label="Prednisone\n1–2 mg/kg/day PO"];
        Pred_PK      [label="Prednisolone PK\nF=0.82, Vd=0.97L/kg, t½=2.5h"];
        GR_Bind      [label="GR Binding\n→ GRE Transcription"];
        CS_B_Effect  [label="B Cell Apoptosis\n↓ Autoantibody production"];
        CS_Mac_Effect[label="Macrophage FcγR\nDownregulation"];

        IVIg_Dose    [label="IVIg\n1–2 g/kg IV (rapid)"];
        IVIg_PK      [label="IVIg PK\nt½=3–4 wk, Vd=0.06L/kg"];
        FcRn_Sat     [label="FcRn Saturation\n→ IgG catabolism↑"];
        IVIg_FcR     [label="FcγR Blockade\n(Splenic protection)"];

        Rtx_Dose     [label="Rituximab\n375mg/m² IV ×4 wk"];
        Rtx_PK       [label="Rituximab PK\nt½=22d, CL=0.33L/day"];
        CD20_Bind    [label="CD20 Binding\n(B cell surface antigen)"];
        B_Deplete    [label="B Cell Depletion\n(6–12 months)"];

        MMF_Dose     [label="MMF / Mycophenolate\n1–3 g/day PO"];
        MPA_Active   [label="MPA (Active)\nt½=17h, F=0.94"];
        IMPDH_Inhib  [label="IMPDH Inhibition\n→ Purine synthesis ↓"];
        Lympho_Anti  [label="Lymphocyte\nAntiproliferative"];

        Elt_Dose     [label="Eltrombopag\n50 mg/day PO"];
        Elt_PK       [label="Eltrombopag PK\nt½=26h, F=0.52"];
        TPO_R_Ag     [label="TPO-R Agonism\n(c-Mpl intracellular)"];
        MK_Stim      [label="Megakaryocyte\nStimulation → Plt↑"];

        Siro_Dose    [label="Sirolimus\n2–6 mg/day PO"];
        Siro_PK      [label="Sirolimus PK\nt½=62h, F=0.14"];
        mTOR_Inhib   [label="mTOR Inhibition\n(TORC1 complex)"];
        Treg_Exp     [label="Treg Expansion\n→ Immunosuppression"];

        Splenectomy  [label="Splenectomy\n(Surgical)"];
        Splen_Eff    [label="Splenectomy Effect:\nFcR macrophage removal"];

        Danazol      [label="Danazol\n200 mg TID PO"];
        Danazol_FcR  [label="Danazol: FcγR\nDownregulation"];

        CsA          [label="Cyclosporin A\n(3–5 mg/kg/day)"];
        CsA_Calci    [label="Calcineurin Inhibition\n→ IL-2 ↓ → T cell suppression"];
    }

    /* ====================================================
       EDGES – Trigger Cluster
       ==================================================== */
    EBV -> Viral_Trigger [label="molecular mimicry"];
    CMV -> Viral_Trigger;
    Viral_Trigger -> TLR7_9 [label="ssRNA/DNA release"];
    ALPS_Mutation -> Innate_Cyto [label="immune dysregulation"];
    CTLA4_Haplo -> DC_Mat [label="unchecked\nco-stimulation"];
    LRBA_Def -> CTLA4_Haplo [label="LRBA recycles CTLA4\n(loss → CTLA4↓)"];
    PI3K_Dysreg -> Naive_B_RBC [label="B cell\nhyper-activation"];
    TLR7_9 -> pDC;
    pDC -> Type1_IFN;
    Type1_IFN -> DC_Mat;
    DC_Mat -> Ag_Present [label="present RBC/Plt\nself-antigens"];
    IL6_TNF -> Innate_Cyto;
    TLR7_9 -> IL6_TNF;
    NK_Dysfunct -> Innate_Cyto;
    Innate_Cyto -> Naive_T;
    Ag_Present -> Naive_B_RBC;
    Ag_Present -> Naive_B_Plt;
    Ag_Present -> Naive_T;

    /* ====================================================
       EDGES – B Cell Anti-RBC
       ==================================================== */
    Naive_B_RBC -> GC_RBC [label="Ag activation"];
    GC_RBC -> SHM_RBC;
    SHM_RBC -> CSR_IgG_RBC;
    CSR_IgG_RBC -> Eff_B_RBC;
    Eff_B_RBC -> PC_RBC [label="differentiation"];
    Eff_B_RBC -> Mem_B_RBC;
    PC_RBC -> Ab_RBC [label="IgG secretion"];
    Ab_RBC -> Anti_RhD;
    Ab_RBC -> Anti_GlyA;
    Ab_RBC -> Anti_Band3;
    Ab_RBC -> DAT_Pos [label="detects bound IgG"];
    DAT_Pos -> Warm_AIHA [label="diagnostic"];
    BAFF_RBC -> PC_RBC [label="survival signal"];
    FCGR2B_Def -> GC_RBC [label="less inhibitory\nsignal → GC↑" color=red];

    /* ====================================================
       EDGES – B Cell Anti-Plt
       ==================================================== */
    Naive_B_Plt -> GC_Plt [label="Ag activation"];
    GC_Plt -> SHM_Plt;
    SHM_Plt -> CSR_IgG_Plt;
    CSR_IgG_Plt -> Eff_B_Plt;
    Eff_B_Plt -> PC_Plt [label="differentiation"];
    Eff_B_Plt -> Mem_B_Plt;
    PC_Plt -> Anti_GPIb [label="IgG secretion"];
    PC_Plt -> Anti_GPIIb [label="IgG secretion"];
    Anti_GPIb -> PAIgG;
    Anti_GPIIb -> PAIgG;
    FCGR2B_Def -> GC_Plt [label="hyperactivation" color=red];
    Breg_Def -> Eff_B_Plt [label="less IL-10\nsuppression"];
    BCR_Signal -> GC_Plt;
    CD40L_CD40 -> GC_Plt [label="T–B cooperation"];
    CD40L_CD40 -> GC_RBC [label="T–B cooperation"];

    /* ====================================================
       EDGES – T Cell Cluster
       ==================================================== */
    Naive_T -> Th1 [label="IL-12"];
    Naive_T -> Th2 [label="IL-4"];
    Naive_T -> Th17 [label="TGF-β+IL-6+IL-23"];
    Naive_T -> Tfh [label="ICOS/IL-21\nICOS-L signal"];
    Naive_T -> Treg [label="TGF-β+IL-2"];
    Treg -> FOXP3;
    Treg -> TGFb [label="effector cytokine"];
    Treg -> IL10_T;
    Treg -> CTLA4_Treg;
    Treg_Def -> Th17 [label="Treg↓ →\nTh17 unchecked" color=red];
    Treg_Def -> Tfh [label="→ GC hyperactivity" color=red];
    IL2_Def -> Treg_Def [label="Treg survival ↓"];
    mTOR_T -> Treg_Def [label="mTOR↑ → Treg↓" color=red];
    Tfh -> GC_RBC [label="IL-21 germinal\ncenter support"];
    Tfh -> GC_Plt [label="IL-21 help"];
    Th1 -> IFNg [label="secretion"];
    Th17 -> IL17A [label="secretion"];
    IFNg -> FcR_Mac_RBC [label="macrophage\nactivation"];
    Tfh -> CD40L_CD40 [label="CD40L expression"];

    /* ====================================================
       EDGES – Complement
       ==================================================== */
    Ab_RBC -> C1q [label="IgG Fc\nbinding"];
    Anti_GPIb -> C1q [label="IgG Fc"];
    C1q -> CP;
    CP -> C4_Cleave;
    C4_Cleave -> C3_Conv;
    C3_Conv -> C3b_Ops [label="C3 cleavage → C3b"];
    C3b_Ops -> C3d_Dep [label="C3b iC3b→C3d"];
    C3b_Ops -> C5_Conv [label="C3b joins\nconvertase"];
    C5_Conv -> C5a;
    C5_Conv -> MAC;
    C3b_Ops -> AltP [label="positive\namplification loop"];
    DAF_CD55 -> C3_Conv [label="INHIBITS\ndecay-acceleration" color=red style=dashed arrowhead=tee];
    CD59 -> MAC [label="INHIBITS\nMAC assembly" color=red style=dashed arrowhead=tee];

    /* ====================================================
       EDGES – RBC Destruction
       ==================================================== */
    Ab_RBC -> oRBC [label="opsonization"];
    C3b_Ops -> oRBC [label="C3b coating"];
    oRBC -> FcR_Mac_RBC [label="FcγR recognition"];
    FcR_Mac_RBC -> Erythrophago;
    Erythrophago -> EVH [label="splenic\nphagocytosis"];
    MAC -> IVH [label="complement\nlysis"];
    EVH -> Hgb_Free;
    IVH -> Hgb_Free;
    Hgb_Free -> LDH_El;
    Hgb_Free -> InBili [label="heme catabolism"];
    Hgb_Free -> Haptoglobin [label="Haptoglobin binds\nfree Hgb → depleted"];
    IVH -> Hemoglobinuria [label="overflow\nin urine"];
    EVH -> RBC_Pool [label="DEPLETES pool" color=red style=dashed arrowhead=tee];
    IVH -> RBC_Pool [label="DEPLETES pool" color=red style=dashed arrowhead=tee];
    RBC_Pool -> Hgb_Level [label="RBC×Hgb/cell"];

    /* ====================================================
       EDGES – Platelet Destruction
       ==================================================== */
    PAIgG -> oPlt [label="IgG bound\nto Plt surface"];
    Anti_GPIb -> oPlt [label="direct GPIb\nopsonization"];
    oPlt -> FcR_Mac_Plt;
    FcR_Mac_Plt -> Plt_Phago;
    Plt_Phago -> Spleen_Seq;
    Spleen_Seq -> Thrombocyto [label="Plt clearance↑"];
    Thrombocyto -> Plt_Pool [label="DEPLETES pool" color=red style=dashed arrowhead=tee];
    Plt_Pool -> Bleeding [label="Plt <30×10⁹/L"];
    Bleeding -> Petechiae;
    Bleeding -> GI_Bleed;
    Bleeding -> ICH;
    Anti_GPIIb -> MK_Inhib [label="cross-reactive\nto MK surface"];
    MK_Inhib -> TPO_Insuff [label="MK destruction\n→ TPO receptor↓"];

    /* ====================================================
       EDGES – Bone Marrow
       ==================================================== */
    HSC -> BFU_E;
    BFU_E -> CFU_E;
    CFU_E -> ProEryth [label="EPO-dependent"];
    ProEryth -> BasoEryth;
    BasoEryth -> OrthoEryth;
    OrthoEryth -> Retic [label="enucleation"];
    Retic -> Mature_RBC;
    Mature_RBC -> RBC_Pool [label="maturation\n(2 days)"];
    EPO_Sig -> BFU_E [label="proliferation↑"];
    EPO_Sig -> CFU_E [label="survival↑"];
    Serum_EPO -> EPO_Sig;
    Hgb_Level -> Serum_EPO [label="Hgb↓ →\nkidney EPO↑" color=darkgreen];
    HSC -> Pro_MK;
    Pro_MK -> MK_BM [label="TPO-driven"];
    MK_BM -> Plt_Rel [label="proplatelet\nformation"];
    Plt_Rel -> Plt_Pool [label="Plt released\nto circulation"];
    TPO_Sig -> MK_BM [label="maturation/\nproliferation"];
    Plt_Pool -> TPO_Sig [label="Plt↓ → TPO↑\n(inverse feedback)" color=darkgreen];
    BM_Exhaust -> Retic [label="inadequate\ncompensation" color=red style=dashed arrowhead=tee];
    MK_Inhib -> MK_BM [label="Ab destroys\nBM MK" color=red];

    /* ====================================================
       EDGES – Clinical
       ==================================================== */
    Hgb_Level -> Fatigue_Dysp [label="Hgb<8g/dL"];
    InBili -> Jaundice_Spl;
    Bleeding -> Bleed_Epi;
    ICH -> Mortality [label="severe ICH"];
    Hgb_Level -> AIHA_Resp [label="primary\nendpoint"];
    Plt_Pool -> ITP_Resp [label="primary\nendpoint"];
    AIHA_Resp -> CR [label="Hgb≥12g/dL"];
    ITP_Resp -> CR [label="Plt≥100×10⁹/L"];
    CR -> Relapse [label="50–80%\nrelapse rate" style=dashed];
    PR -> Relapse [style=dashed];
    Bleed_Epi -> Thromb_Risk [label="compensatory\nplatelet activation"];

    /* ====================================================
       EDGES – Drug PK/PD
       ==================================================== */
    Pred_Dose -> Pred_PK;
    Pred_PK -> GR_Bind;
    GR_Bind -> CS_B_Effect [label="↓ Ab production"];
    GR_Bind -> CS_Mac_Effect [label="FcγR↓"];
    CS_B_Effect -> Ab_RBC [label="SUPPRESSES" color=blue style=dashed arrowhead=tee];
    CS_B_Effect -> Ab_RBC [label="SUPPRESSES" color=blue style=dashed arrowhead=tee];
    CS_B_Effect -> PAIgG [label="SUPPRESSES" color=blue style=dashed arrowhead=tee];
    CS_Mac_Effect -> FcR_Mac_RBC [label="FcγR downreg" color=blue style=dashed arrowhead=tee];
    CS_Mac_Effect -> FcR_Mac_Plt [label="FcγR downreg" color=blue style=dashed arrowhead=tee];

    IVIg_Dose -> IVIg_PK;
    IVIg_PK -> FcRn_Sat;
    FcRn_Sat -> Ab_RBC [label="IgG catabolism↑" color=blue style=dashed arrowhead=tee];
    IVIg_PK -> IVIg_FcR;
    IVIg_FcR -> FcR_Mac_Plt [label="FcγR blockade\n→ Plt spared" color=blue style=dashed arrowhead=tee];
    IVIg_FcR -> FcR_Mac_RBC [label="FcγR blockade" color=blue style=dashed arrowhead=tee];

    Rtx_Dose -> Rtx_PK;
    Rtx_PK -> CD20_Bind;
    CD20_Bind -> B_Deplete;
    B_Deplete -> PC_RBC [label="B/PC depletion" color=blue style=dashed arrowhead=tee];
    B_Deplete -> PC_Plt [label="B/PC depletion" color=blue style=dashed arrowhead=tee];
    B_Deplete -> Eff_B_RBC [color=blue style=dashed arrowhead=tee];
    B_Deplete -> Eff_B_Plt [color=blue style=dashed arrowhead=tee];

    MMF_Dose -> MPA_Active;
    MPA_Active -> IMPDH_Inhib;
    IMPDH_Inhib -> Lympho_Anti;
    Lympho_Anti -> GC_RBC [label="↓ B prolif" color=blue style=dashed arrowhead=tee];
    Lympho_Anti -> GC_Plt [label="↓ B prolif" color=blue style=dashed arrowhead=tee];
    Lympho_Anti -> Th1 [label="↓ T prolif" color=blue style=dashed arrowhead=tee];

    Elt_Dose -> Elt_PK;
    Elt_PK -> TPO_R_Ag;
    TPO_R_Ag -> MK_Stim;
    MK_Stim -> MK_BM [label="↑ MK maturation\n& Plt production" color=blue style=dashed];

    Siro_Dose -> Siro_PK;
    Siro_PK -> mTOR_Inhib;
    mTOR_Inhib -> Treg_Exp;
    Treg_Exp -> Treg [label="Treg expansion\n(mTOR↓)" color=blue style=dashed];
    mTOR_Inhib -> mTOR_T [label="INHIBITS" color=blue style=dashed arrowhead=tee];

    Splenectomy -> Splen_Eff;
    Splen_Eff -> FcR_Mac_RBC [label="removes FcR\nmacrophage" color=blue style=dashed arrowhead=tee];
    Splen_Eff -> FcR_Mac_Plt [label="removes FcR\nmacrophage" color=blue style=dashed arrowhead=tee];
    Splen_Eff -> Spleen_Seq [label="eliminates\nsequestration" color=blue style=dashed arrowhead=tee];

    Danazol -> Danazol_FcR;
    Danazol_FcR -> FcR_Mac_RBC [label="FcγR modulation" color=blue style=dashed arrowhead=tee];
    Danazol_FcR -> FcR_Mac_Plt [label="FcγR modulation" color=blue style=dashed arrowhead=tee];

    CsA -> CsA_Calci;
    CsA_Calci -> IL2_Def [label="IL-2 ↓ → Treg/\nTeff suppression" color=blue];
    CsA_Calci -> Th1 [label="↓ T effector\nactivation" color=blue style=dashed arrowhead=tee];
}
