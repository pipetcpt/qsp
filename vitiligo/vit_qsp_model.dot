digraph vitiligo_qsp {
  graph [
    rankdir  = "LR",
    fontname = "Helvetica",
    fontsize = 12,
    bgcolor  = "#F8F9FA",
    splines  = "polyline",
    overlap  = false,
    nodesep  = 0.40,
    ranksep  = 1.10,
    label    = "Vitiligo QSP Mechanistic Map\nCD8⁺ T Cell–Mediated Melanocyte Destruction · JAK/STAT · CXCR3 Axis · Drug PK/PD\n(Ruxolitinib Cream · Afamelanotide · Tacrolimus · NB-UVB)",
    labelloc = "t",
    labeljust = "c"
  ];
  node [fontname="Helvetica", fontsize=8, style="filled,rounded", shape=box, margin="0.08,0.05"];
  edge [fontname="Helvetica", fontsize=7, arrowsize=0.65];

  //========================================================
  // CLUSTER 1 — Genetic & Environmental Risk
  //========================================================
  subgraph cluster_GER {
    label     = "① Genetic & Environmental Risk";
    style     = "filled,rounded";
    bgcolor   = "#FFF3E0";
    color     = "#E65100";
    penwidth  = 2.5;
    fontcolor = "#E65100";
    fontsize  = 10;
    fontname  = "Helvetica-Bold";
    node [fillcolor="#FFE0B2", color="#E65100"];

    HLA_A0201       [label="HLA-A*02:01\n(risk allele)"];
    HLA_DR4         [label="HLA-DR4\n(risk allele)"];
    PTPN22          [label="PTPN22\nR620W"];
    CTLA4_gene      [label="CTLA4+49G>A"];
    NLRP1_gene      [label="NLRP1\npolymorphism"];
    BACH2_gene      [label="BACH2 variant"];
    RERE_gene       [label="RERE variant"];
    GZMB_gene       [label="GZMB\npolymorphism"];
    CAT_gene        [label="Catalase gene\n(CAT)"];
    IL2RA_gene      [label="IL2RA variant"];
    UV_stress       [label="UV radiation\nstress"];
    chemical_exp    [label="Chemical exposure\n(catechols, phenols)"];
    mech_trauma     [label="Mechanical trauma\n(Koebner effect)"];
    emotional_stress [label="Emotional/\nphysical stress"];
    polygenic_risk  [label="Polygenic\nrisk score"];
    autoimmune_comorbid [label="Autoimmune\ncomorbidity\n(thyroid, T1D, RA)"];
  }

  //========================================================
  // CLUSTER 2 — Oxidative Stress & Melanocyte Vulnerability
  //========================================================
  subgraph cluster_OST {
    label     = "② Oxidative Stress & Melanocyte Vulnerability";
    style     = "filled,rounded";
    bgcolor   = "#FCE4EC";
    color     = "#AD1457";
    penwidth  = 2.5;
    fontcolor = "#AD1457";
    fontsize  = 10;
    fontname  = "Helvetica-Bold";
    node [fillcolor="#F8BBD9", color="#AD1457"];

    H2O2_acc    [label="H₂O₂\naccumulation"];
    ROS         [label="Reactive Oxygen\nSpecies (ROS)"];
    catalase_def [label="Catalase\ndeficiency"];
    BH4_dep     [label="BH4\ndepletion"];
    ER_stress   [label="ER Stress\n(UPR activation)"];
    ATF6        [label="ATF6\nactivation"];
    PERK_path   [label="PERK/eIF2α-P\npathway"];
    IRE1a       [label="IRE1α → XBP1\nsplicing"];
    HSP70       [label="HSP60/70\n(DAMP release)"];
    HMGB1       [label="HMGB1\n(alarmin)"];
    lipid_perox [label="Lipid peroxidation\n(4-HNE / MDA)"];
    mito_dysf   [label="Mitochondrial\ndysfunction"];
    GSH_dep     [label="Glutathione\ndepletion"];
    mel_vuln    [label="Melanocyte\nvulnerability ↑", shape=diamond, fillcolor="#F48FB1"];
  }

  //========================================================
  // CLUSTER 3 — Melanocyte Biology & Differentiation
  //========================================================
  subgraph cluster_MBD {
    label     = "③ Melanocyte Biology & Differentiation";
    style     = "filled,rounded";
    bgcolor   = "#F3E5F5";
    color     = "#6A1B9A";
    penwidth  = 2.5;
    fontcolor = "#6A1B9A";
    fontsize  = 10;
    fontname  = "Helvetica-Bold";
    node [fillcolor="#E1BEE7", color="#6A1B9A"];

    neural_crest    [label="Neural Crest\nOrigin"];
    mel_stem_cell   [label="Melanocyte Stem\nCell (MSC)\n[Hair follicle bulge]"];
    mel_progenitor  [label="Melanocyte\nProgenitor"];
    mature_mel      [label="Mature\nMelanocyte", shape=ellipse, fillcolor="#CE93D8"];
    MITF            [label="MITF\n(master TF)"];
    PAX3            [label="PAX3\n(melanoblast)"];
    SOX10           [label="SOX10\n(lineage)"];
    DCT             [label="DCT/DOPA chrome\ntautomerase"];
    TYR             [label="Tyrosinase\n(TYR)"];
    TYRP1           [label="TYRP1\n(TRP1)"];
    TYRP2           [label="TYRP2\n(TRP2)"];
    melanosome_synth [label="Melanosome\nsynthesis\n(Stage I→IV)"];
    melanin_synth   [label="Melanin\nsynthesis\n(eumelanin)"];
    mel_transfer    [label="Melanosome\ntransfer →\nkeratinocyte"];
    keratinocyte    [label="Keratinocyte\n(UV protection)"];
    alpha_MSH       [label="α-MSH\n(POMC product)"];
    MC1R            [label="MC1R\n(cAMP ↑)"];
    cAMP_mel        [label="cAMP\n→ PKA → MITF"];
    SCF_mel         [label="SCF\n(KIT ligand)"];
    cKIT            [label="c-KIT receptor\n(survival signal)"];
    ET1_mel         [label="Endothelin-1\n(ET-1)"];
    EDNRB_mel       [label="EDNRB\n(differentiation)"];
    Wnt3a_mel       [label="Wnt3a /\nβ-catenin\n(proliferation)"];
    MICA_mel        [label="MICA / MICB\nupregulation\n(stress-induced)"];
  }

  //========================================================
  // CLUSTER 4 — Innate Immunity
  //========================================================
  subgraph cluster_INN {
    label     = "④ Innate Immunity";
    style     = "filled,rounded";
    bgcolor   = "#E8F5E9";
    color     = "#1B5E20";
    penwidth  = 2.5;
    fontcolor = "#1B5E20";
    fontsize  = 10;
    fontname  = "Helvetica-Bold";
    node [fillcolor="#C8E6C9", color="#1B5E20"];

    pDC           [label="pDC\n(IFN-α/β)"];
    mDC           [label="mDC\n(Ag presentation)"];
    NK_cell       [label="NK cell\n(NKG2D⁺)"];
    mast_cell     [label="Mast cell"];
    macrophage_M1 [label="Macrophage\n(M1 polarized)"];
    ILC1          [label="ILC1\n(IFN-γ source)"];
    TLR3          [label="TLR3\n(dsRNA)"];
    TLR7          [label="TLR7\n(ssRNA)"];
    TLR9          [label="TLR9\n(CpG DNA)"];
    cGAS_inn      [label="cGAS\n(cytoplasmic DNA)"];
    STING         [label="STING\n(cGAMP → IRF3)"];
    NLRP1_inf     [label="NLRP1\ninflammasome\n(IL-1β / IL-18)"];
    NKG2D_rec     [label="NKG2D receptor\n(NK + CD8⁺)"];
    complement_C3 [label="Complement\nC3a / C5a"];
    innate_memory [label="Innate\nimmune memory"];
    cytokine_storm [label="Cytokine burst\n(acute flare)"];
  }

  //========================================================
  // CLUSTER 5 — Adaptive Immunity: T Cells
  //========================================================
  subgraph cluster_ADP {
    label     = "⑤ Adaptive Immunity — T Cells";
    style     = "filled,rounded";
    bgcolor   = "#E3F2FD";
    color     = "#0D47A1";
    penwidth  = 2.5;
    fontcolor = "#0D47A1";
    fontsize  = 10;
    fontname  = "Helvetica-Bold";
    node [fillcolor="#BBDEFB", color="#0D47A1"];

    CD8_naive  [label="CD8⁺ Naïve T\n(circulation)"];
    CD8_eff    [label="CD8⁺ Effector Tc1\n(perilesional skin)"];
    CD8_Trm    [label="CD8⁺ TRM\n(tissue-resident\nmemory)"];
    CD4_Th1    [label="CD4⁺ Th1\n(IFN-γ / IL-2)"];
    Treg       [label="CD4⁺ Treg\n(FoxP3⁺)"];
    TCR_act    [label="TCR activation\n(mel-specific Ag)"];
    CD28_cos   [label="CD28\nco-stimulation"];
    CTLA4_T    [label="CTLA-4\n(inhibitory)"];
    PD1        [label="PD-1\n(T cell)"];
    PDL1       [label="PD-L1\n(melanocyte)\n↓↓ in vitiligo"];
    GranB      [label="Granzyme B\n(cytotoxic)"];
    Perforin   [label="Perforin\n(pore-forming)"];
    FasL       [label="FasL\n(apoptosis)"];
    Fas_mel    [label="Fas (CD95)\n(melanocyte)"];
    CD8_prolif [label="CD8⁺\nproliferation\n(IL-15 driven)"];
    ADCC_mel   [label="ADCC\n(anti-mel Ab)"];
  }

  //========================================================
  // CLUSTER 6 — Cytokine & Chemokine Network
  //========================================================
  subgraph cluster_CYT {
    label     = "⑥ Cytokine & Chemokine Network";
    style     = "filled,rounded";
    bgcolor   = "#FFF8E1";
    color     = "#E65100";
    penwidth  = 2.5;
    fontcolor = "#E65100";
    fontsize  = 10;
    fontname  = "Helvetica-Bold";
    node [fillcolor="#FFECB3", color="#FF6F00"];

    IFNgamma   [label="IFN-γ\n(master regulator)", shape=ellipse, fillcolor="#FFB300"];
    CXCL9_net  [label="CXCL9 / MIG\n(CXCR3 ligand)"];
    CXCL10_net [label="CXCL10 / IP-10\n★ serum biomarker"];
    CXCL11_net [label="CXCL11 / I-TAC\n(CXCR3 ligand)"];
    CXCR3_net  [label="CXCR3\n(CD8⁺ / Th1\nreceptor)"];
    IL15_net   [label="IL-15\n(CD8⁺ / NK\nsurvival)"];
    TNFa_net   [label="TNF-α\n(pro-inflam)"];
    IL1b_net   [label="IL-1β\n(NLRP1)"];
    IL6_net    [label="IL-6\n(acute phase)"];
    IL33_net   [label="IL-33 / ST2\n(epithelial alarm)"];
    TSLP_net   [label="TSLP\n(keratinocyte\nalarm)"];
    IL10_net   [label="IL-10\n(Treg\nanti-inflam)"];
    TGFb_net   [label="TGF-β\n(Treg suppressor)"];
    IFNab_net  [label="IFN-α/β\n(type I IFN)"];
    SCF_cyt    [label="SCF\n(melanocyte\nsurvival)"];
  }

  //========================================================
  // CLUSTER 7 — JAK/STAT Signaling
  //========================================================
  subgraph cluster_JAK {
    label     = "⑦ JAK/STAT Signaling";
    style     = "filled,rounded";
    bgcolor   = "#E8EAF6";
    color     = "#1A237E";
    penwidth  = 2.5;
    fontcolor = "#1A237E";
    fontsize  = 10;
    fontname  = "Helvetica-Bold";
    node [fillcolor="#C5CAE9", color="#1A237E"];

    JAK1_jak  [label="JAK1\n(IFN-γR / IL-15R)"];
    JAK2_jak  [label="JAK2\n(IFN-γR)"];
    JAK3_jak  [label="JAK3\n(γc chain / IL-15)"];
    TYK2_jak  [label="TYK2\n(IFN-α/β)"];
    STAT1_jak [label="STAT1\n→ pSTAT1", fillcolor="#7986CB"];
    STAT3_jak [label="STAT3\n(survival)"];
    STAT5_jak [label="STAT5\n(CD8⁺ survival)"];
    IRF1_jak  [label="IRF1\n→ CXCL9/10/11\ngenes"];
    SOCS1_jak [label="SOCS1\n(neg feedback)"];
    SOCS3_jak [label="SOCS3\n(neg feedback)"];
    GBP1_jak  [label="GBP1/2\n(ISG feedforward)"];
    HLA_up    [label="HLA-I↑\n(MHC-I on mel)"];
    NF_kB_node [label="NF-κB\n(pro-inflam\ngenes)"];
  }

  //========================================================
  // CLUSTER 8 — Drug Pharmacokinetics
  //========================================================
  subgraph cluster_DPK {
    label     = "⑧ Drug Pharmacokinetics";
    style     = "filled,rounded";
    bgcolor   = "#E0F2F1";
    color     = "#004D40";
    penwidth  = 2.5;
    fontcolor = "#004D40";
    fontsize  = 10;
    fontname  = "Helvetica-Bold";
    node [fillcolor="#B2DFDB", color="#004D40"];

    ruxo_cream    [label="Ruxolitinib\ncream 1.5% BID\n★ TRuE-V", shape=box3d, fillcolor="#4DB6AC"];
    ruxo_oral     [label="Ruxolitinib\n10 mg BID oral\n(systemic)", shape=box3d, fillcolor="#4DB6AC"];
    afam_impl     [label="Afamelanotide\n16 mg SC q60d\n(MC1R agonist)", shape=box3d, fillcolor="#4DB6AC"];
    tacro_top     [label="Tacrolimus\n0.1% topical\n(FK506)", shape=box3d, fillcolor="#4DB6AC"];
    tofacit       [label="Tofacitinib\n5 mg BID oral\n(JAK1/3i)", shape=box3d, fillcolor="#4DB6AC"];
    NBUVB_phot    [label="NB-UVB\n311 nm\nPhototherapy\n3×/week", shape=box3d, fillcolor="#4DB6AC"];
    ruxo_skin_pk  [label="Ruxolitinib\nskin [nM]\n(topical PK)"];
    ruxo_cent_pk  [label="Ruxolitinib\nplasma Cp\n(oral PK)\nt½=3h, F=95%"];
    afam_depot_pk [label="Afamelanotide\nSC depot\n(slow release)"];
    afam_cent_pk  [label="Afamelanotide\nplasma [ng/mL]\nMC1R target"];
    tacro_skin_pk [label="Tacrolimus\nskin tissue [ng/g]\n(FK506)"];
    NBUVB_dose_pk [label="NB-UVB\nerythema dose\n(MED units)"];
  }

  //========================================================
  // CLUSTER 9 — Drug PD & Target Engagement
  //========================================================
  subgraph cluster_DPD {
    label     = "⑨ Drug PD & Target Engagement";
    style     = "filled,rounded";
    bgcolor   = "#F1F8E9";
    color     = "#33691E";
    penwidth  = 2.5;
    fontcolor = "#33691E";
    fontsize  = 10;
    fontname  = "Helvetica-Bold";
    node [fillcolor="#DCEDC8", color="#33691E"];

    JAK1_block      [label="JAK1 inhibition\n(ruxo IC50=3.3nM)\n(tofacitinib IC50=3.2nM)"];
    JAK2_block      [label="JAK2 inhibition\n(ruxo IC50=2.8nM)"];
    pSTAT1_inh      [label="p-STAT1\n↓ inhibition\n(% reduction)"];
    CXCL10_sup      [label="CXCL10/9\nsuppression\n→ CD8 recruit↓"];
    CD8_recruit_dn  [label="CD8⁺ skin\nrecruitment↓"];
    IFNg_break      [label="IFN-γ feedback\nloop interruption"];
    MC1R_act        [label="MC1R agonism\n(afamelanotide)\n→ cAMP↑"];
    cAMP_rise       [label="cAMP ↑↑\n(melanocyte)"];
    MITF_rise       [label="MITF ↑↑\n→ TYR/TYRP1↑"];
    melanogen_stim  [label="Melanogenesis\nstimulation\n(eumelanin ↑)"];
    calcineurin_blk [label="Calcineurin\nblockade\n(tacrolimus)"];
    NFAT_blk        [label="NFAT inhibition\n→ IL-2/IFN-γ↓"];
    Treg_expand     [label="Treg expansion\n(NB-UVB\ninduced)"];
    PD_L1_restore   [label="PD-L1\nrestoration\n(possible\nruxo mech)"];
  }

  //========================================================
  // CLUSTER 10 — Repigmentation Mechanisms
  //========================================================
  subgraph cluster_REP {
    label     = "⑩ Repigmentation Mechanisms";
    style     = "filled,rounded";
    bgcolor   = "#FBE9E7";
    color     = "#BF360C";
    penwidth  = 2.5;
    fontcolor = "#BF360C";
    fontsize  = 10;
    fontname  = "Helvetica-Bold";
    node [fillcolor="#FFCCBC", color="#BF360C"];

    follicle_res  [label="Follicular\nMelanocyte\nReservoir"];
    mel_prolif_r  [label="Melanocyte\nproliferation\n(Ki67⁺)"];
    mel_migr      [label="Melanocyte\nmigration\n(dermis→epidermis)"];
    dendrite_ext  [label="Dendrite\nextension &\nmelanosome\ntransfer"];
    perifol_repig [label="Perifollicular\nrepigmentation\n(earliest sign)"];
    marginal_repig [label="Marginal\nrepigmentation"];
    diffuse_repig [label="Diffuse\nrepigmentation"];
    complete_repig [label="Complete\nrepigmentation\n(sustained tx)"];
  }

  //========================================================
  // CLUSTER 11 — Clinical Endpoints & Disease Classification
  //========================================================
  subgraph cluster_CEP {
    label     = "⑪ Clinical Endpoints & Disease Classification";
    style     = "filled,rounded";
    bgcolor   = "#EDE7F6";
    color     = "#4A148C";
    penwidth  = 2.5;
    fontcolor = "#4A148C";
    fontsize  = 10;
    fontname  = "Helvetica-Bold";
    node [fillcolor="#D1C4E9", color="#4A148C"];

    VASI_score    [label="VASI Score\n(0–100)\n★ primary endpoint", shape=doubleoctagon, fillcolor="#B39DDB"];
    VASI50        [label="VASI50\n(≥50% reduction\nat week 24)"];
    VASI75        [label="VASI75\n(≥75% reduction)"];
    BSA_inv       [label="BSA%\ninvolvement"];
    nonseg_vit    [label="Non-segmental\nvitiligo (NSV)\n(most common)"];
    seg_vit       [label="Segmental\nvitiligo (SV)"];
    acrofacial    [label="Acrofacial\nvitiligo"];
    active_dis    [label="Active disease\n(Koebner+\nconfetti lesions)"];
    stable_dis    [label="Stable disease\n(>1y no spread)"];
    serum_CXCL10  [label="Serum CXCL10\n★ disease activity\nbiomarker"];
    DLQI_score    [label="DLQI / QoL\n(psychosocial\nimpact)"];
    rapid_spread  [label="Rapid spreading\n(trichome\nlesions)"];
  }

  //============================================================
  //  E D G E S
  //============================================================

  // --- Genetic risk → downstream ---
  HLA_A0201      -> CD8_naive     [label="CD8 risk\nallele", color="#9C27B0", style=dashed];
  HLA_A0201      -> TCR_act       [label="Ag restrict.", color="#9C27B0", style=dashed];
  HLA_DR4        -> CD4_Th1       [label="risk", color="#9C27B0", style=dashed];
  PTPN22         -> Treg          [label="Treg ↓\nfunction", color="red", style=dashed];
  CTLA4_gene     -> CTLA4_T       [label="↓ CTLA-4\nexpression", color="red", style=dashed];
  NLRP1_gene     -> NLRP1_inf     [label="gain-of-func", color="#FF5722", style=dashed];
  CAT_gene       -> catalase_def  [label="low activity", color="#AD1457"];
  UV_stress      -> ROS           [color="#E91E63"];
  UV_stress      -> MICA_mel      [label="upregulate", color="#E91E63"];
  chemical_exp   -> mel_vuln      [color="#E91E63"];
  mech_trauma    -> active_dis    [label="Koebner\nphenomenon", color="#E91E63", style=dashed];
  emotional_stress -> ROS         [color="#E91E63", style=dashed];
  polygenic_risk -> autoimmune_comorbid [style=dashed, color="#9C27B0"];

  // --- Oxidative stress cascade ---
  catalase_def -> H2O2_acc   [color="#AD1457"];
  H2O2_acc     -> ROS        [color="#AD1457"];
  ROS          -> ER_stress   [color="#AD1457"];
  ROS          -> mel_vuln    [color="red", penwidth=2];
  ROS          -> BH4_dep     [color="#AD1457"];
  ER_stress    -> ATF6        [color="#AD1457"];
  ER_stress    -> PERK_path   [color="#AD1457"];
  ER_stress    -> IRE1a       [color="#AD1457"];
  ATF6         -> HSP70       [color="#AD1457"];
  PERK_path    -> HSP70       [color="#AD1457"];
  HSP70        -> HMGB1       [label="DAMP\nrelease", color="#AD1457"];
  HMGB1        -> TLR3        [label="DAMP", color="#4CAF50"];
  HMGB1        -> TLR9        [label="DAMP", color="#4CAF50"];
  lipid_perox  -> mel_vuln    [color="#AD1457"];
  mito_dysf    -> ROS         [color="#AD1457"];
  GSH_dep      -> ROS         [color="#AD1457"];
  mel_vuln     -> MICA_mel    [label="stress-\ninduced", color="#AD1457"];
  mel_vuln     -> mature_mel  [label="vulnerability", color="red", penwidth=2];

  // --- Melanocyte biology ---
  neural_crest   -> mel_stem_cell  [label="embryo\norigin", color="#6A1B9A", style=dashed];
  mel_stem_cell  -> mel_progenitor [color="#6A1B9A"];
  mel_progenitor -> mature_mel     [color="#6A1B9A"];
  PAX3           -> MITF           [color="#6A1B9A"];
  SOX10          -> MITF           [color="#6A1B9A"];
  MITF           -> TYR            [color="#6A1B9A"];
  MITF           -> TYRP1          [color="#6A1B9A"];
  MITF           -> TYRP2          [color="#6A1B9A"];
  MITF           -> DCT            [color="#6A1B9A"];
  TYR            -> melanin_synth  [color="#6A1B9A"];
  TYRP1          -> melanin_synth  [color="#6A1B9A"];
  TYRP2          -> melanin_synth  [color="#6A1B9A"];
  melanin_synth  -> melanosome_synth [color="#6A1B9A"];
  melanosome_synth -> mel_transfer [color="#6A1B9A"];
  mel_transfer   -> keratinocyte   [label="UV\nprotection", color="#6A1B9A"];
  alpha_MSH      -> MC1R           [color="#6A1B9A"];
  MC1R           -> cAMP_mel       [color="#6A1B9A"];
  cAMP_mel       -> MITF           [color="#6A1B9A"];
  SCF_mel        -> cKIT           [color="#6A1B9A"];
  cKIT           -> mature_mel     [label="survival", color="#6A1B9A"];
  ET1_mel        -> EDNRB_mel      [color="#6A1B9A"];
  EDNRB_mel      -> mel_progenitor [label="differentiation", color="#6A1B9A"];
  Wnt3a_mel      -> MITF           [label="β-catenin", color="#6A1B9A"];
  mel_stem_cell  -> follicle_res   [label="niche", color="#6A1B9A"];

  // --- MICA → innate attack ---
  MICA_mel   -> NKG2D_rec  [label="ligand\nbinding", color="#1B5E20", penwidth=2];
  NKG2D_rec  -> NK_cell    [label="NK activation", color="#1B5E20"];
  NKG2D_rec  -> CD8_eff    [label="cytotoxicity↑", color="#0D47A1"];

  // --- Innate immunity ---
  TLR3       -> pDC        [color="#1B5E20"];
  TLR7       -> pDC        [color="#1B5E20"];
  TLR9       -> pDC        [color="#1B5E20"];
  cGAS_inn   -> STING      [label="cGAMP", color="#1B5E20"];
  STING      -> IFNab_net  [label="type I IFN", color="#1B5E20"];
  pDC        -> IFNab_net  [label="IFN-α/β", color="#1B5E20"];
  mDC        -> TCR_act    [label="Ag\npresent", color="#1B5E20"];
  NLRP1_inf  -> IL1b_net   [color="#1B5E20"];
  NK_cell    -> IFNgamma   [label="early\nIFN-γ", color="#1B5E20"];
  ILC1       -> IFNgamma   [color="#1B5E20"];
  macrophage_M1 -> TNFa_net [color="#1B5E20"];
  macrophage_M1 -> IL6_net  [color="#1B5E20"];
  complement_C3 -> NK_cell  [label="opsonize", color="#1B5E20", style=dashed];
  innate_memory -> cytokine_storm [style=dashed, color="#1B5E20"];
  cytokine_storm -> rapid_spread  [color="red", style=dashed];
  IL33_net   -> mast_cell   [color="#1B5E20"];
  TSLP_net   -> mDC         [color="#1B5E20"];

  // --- Type I IFN → JAK/STAT ---
  IFNab_net  -> TYK2_jak   [color="#1A237E"];
  IFNab_net  -> JAK1_jak   [color="#1A237E"];

  // --- Adaptive immunity T cells ---
  CD8_naive  -> CD8_eff    [label="activation", color="#0D47A1"];
  CD8_eff    -> CD8_Trm    [label="tissue\nresidency", color="#0D47A1"];
  CD4_Th1    -> CD8_prolif [label="IL-2\ncross-help", color="#0D47A1"];
  TCR_act    -> CD8_eff    [color="#0D47A1"];
  CD28_cos   -> TCR_act    [label="co-stim", color="#0D47A1"];
  CTLA4_T    -> TCR_act    [label="inhibit", color="red"];
  PD1        -> CD8_eff    [label="checkpoint\n↓activity", color="red"];
  PDL1       -> PD1        [label="tolerance\n(lost in vitiligo)", color="red", style=dashed];
  GranB      -> mature_mel [label="cytotoxic\nkilling", color="red", penwidth=2];
  Perforin   -> mature_mel [label="pore\nforming", color="red"];
  FasL       -> Fas_mel    [label="apoptosis\nsignal", color="red"];
  Fas_mel    -> mature_mel [label="death\nsignal", color="red", style=dashed];
  CD8_prolif -> CD8_eff    [color="#0D47A1"];
  ADCC_mel   -> mature_mel [label="Ab-mediated\ndestruction", color="red", style=dashed];
  Treg       -> IL10_net   [label="produce", color="#388E3C"];
  Treg       -> TGFb_net   [label="produce", color="#388E3C"];
  TGFb_net   -> CD8_eff    [label="suppress", color="red", style=dashed];
  IL10_net   -> IFNgamma   [label="suppress", color="red"];
  Treg       -> CD8_eff    [label="contact\nsuppress", color="red", style=dashed];

  // --- Cytokine network ---
  IFNgamma   -> JAK1_jak   [label="IFN-γR", color="#1A237E", penwidth=2];
  IFNgamma   -> JAK2_jak   [label="IFN-γR", color="#1A237E", penwidth=2];
  IFNgamma   -> CXCL9_net  [label="induce", color="#FF6F00"];
  IFNgamma   -> CXCL10_net [label="induce", color="#FF6F00", penwidth=2];
  IFNgamma   -> CXCL11_net [label="induce", color="#FF6F00"];
  IL15_net   -> JAK1_jak   [label="IL-15R", color="#1A237E"];
  IL15_net   -> JAK3_jak   [label="γc chain", color="#1A237E"];
  IL15_net   -> CD8_prolif [label="survival\n/ prolif", color="#0D47A1", penwidth=2];
  CXCL9_net  -> CXCR3_net  [color="#FF6F00"];
  CXCL10_net -> CXCR3_net  [color="#FF6F00", penwidth=2];
  CXCL11_net -> CXCR3_net  [color="#FF6F00"];
  CXCR3_net  -> CD8_naive  [label="recruit\nto skin", color="#0D47A1", penwidth=2];
  TNFa_net   -> NF_kB_node [label="activate", color="#FF6F00"];
  NF_kB_node -> IL6_net    [color="#FF6F00"];
  SCF_cyt    -> cKIT       [label="mel\nsurvival", color="#6A1B9A"];

  // --- JAK/STAT signaling ---
  JAK1_jak   -> STAT1_jak  [label="phospho", color="#1A237E", penwidth=2];
  JAK2_jak   -> STAT1_jak  [label="phospho", color="#1A237E", penwidth=2];
  JAK3_jak   -> STAT5_jak  [label="phospho", color="#1A237E"];
  TYK2_jak   -> STAT1_jak  [color="#1A237E"];
  TYK2_jak   -> STAT3_jak  [color="#1A237E"];
  STAT1_jak  -> IRF1_jak   [label="transcription", color="#1A237E"];
  IRF1_jak   -> CXCL10_net [label="gene\nexpression", color="#1A237E", penwidth=2];
  IRF1_jak   -> CXCL9_net  [label="gene\nexpression", color="#1A237E"];
  IRF1_jak   -> GBP1_jak   [label="ISG", color="#1A237E"];
  STAT5_jak  -> CD8_prolif [label="IL-15\nSTAT5", color="#1A237E"];
  SOCS1_jak  -> JAK1_jak   [label="neg\nfeedback", color="red", arrowhead="tee"];
  SOCS3_jak  -> JAK2_jak   [label="neg\nfeedback", color="red", arrowhead="tee"];
  GBP1_jak   -> IFNgamma   [label="ISG\nfeedfwd", color="#FF6F00", style=dashed];
  STAT1_jak  -> HLA_up     [label="MHC-I ↑\non mel", color="#1A237E"];
  HLA_up     -> TCR_act    [label="Ag present\n(mel autoPep)", color="#0D47A1"];

  // --- Drug PK flows ---
  ruxo_cream   -> ruxo_skin_pk  [label="topical\npermeation", color="#004D40", penwidth=2];
  ruxo_oral    -> ruxo_cent_pk  [label="oral F=95%\nka=1.5/h", color="#004D40"];
  afam_impl    -> afam_depot_pk [label="SC depot", color="#004D40"];
  afam_depot_pk -> afam_cent_pk [label="ka=0.018/h\nCmax~0.5ng/mL", color="#004D40"];
  tacro_top    -> tacro_skin_pk [label="FK506\ntopical", color="#004D40"];
  tofacit      -> ruxo_cent_pk  [label="alternate\nJAK1/3i\n(systemic)", color="#004D40", style=dashed];

  // --- Drug PD flows ---
  ruxo_skin_pk    -> JAK1_block     [label="IC50=3.3nM", color="#33691E", penwidth=2];
  ruxo_skin_pk    -> JAK2_block     [label="IC50=2.8nM", color="#33691E", penwidth=2];
  ruxo_cent_pk    -> JAK1_block     [label="systemic\nJAK1/2", color="#33691E", style=dashed];
  JAK1_block      -> pSTAT1_inh    [color="#33691E", penwidth=2];
  JAK2_block      -> pSTAT1_inh    [color="#33691E", penwidth=2];
  pSTAT1_inh      -> CXCL10_sup   [color="#33691E", penwidth=2];
  CXCL10_sup      -> CD8_recruit_dn [color="#33691E"];
  CD8_recruit_dn  -> IFNg_break    [color="#33691E"];
  IFNg_break      -> mature_mel    [label="melanocyte\nprotection ↑", color="#4CAF50", penwidth=2];
  afam_cent_pk    -> MC1R_act      [label="agonist\nbinding", color="#33691E", penwidth=2];
  MC1R_act        -> cAMP_rise     [color="#33691E", penwidth=2];
  cAMP_rise       -> MITF_rise     [color="#33691E", penwidth=2];
  MITF_rise       -> melanogen_stim [color="#33691E", penwidth=2];
  melanogen_stim  -> melanosome_synth [label="stimulate\nmelanosomes", color="#6A1B9A"];
  tacro_skin_pk   -> calcineurin_blk [color="#33691E"];
  calcineurin_blk -> NFAT_blk      [color="#33691E"];
  NFAT_blk        -> IFNgamma      [label="T cell\nIFN-γ ↓", color="red", arrowhead="tee"];
  NBUVB_phot      -> Treg_expand   [label="immuno-\nsuppress.", color="#33691E"];
  NBUVB_phot      -> mel_prolif_r  [label="MSC\nmobilize", color="#6A1B9A"];
  NBUVB_dose_pk   -> NBUVB_phot   [color="#004D40"];
  Treg_expand     -> Treg         [label="expand\nFoxP3⁺", color="#388E3C"];
  ruxo_skin_pk    -> PD_L1_restore [label="possible\nmechanism", color="#33691E", style=dashed];
  PD_L1_restore   -> PD1         [label="checkpoint\nrestore", color="red", style=dashed];

  // --- Repigmentation ---
  follicle_res   -> mel_prolif_r  [label="mobilize\nMSC", color="#BF360C", penwidth=2];
  mel_prolif_r   -> mel_migr      [color="#BF360C"];
  mel_migr       -> perifol_repig [label="perifollicular\npattern", color="#BF360C"];
  perifol_repig  -> marginal_repig [color="#BF360C"];
  marginal_repig -> diffuse_repig  [color="#BF360C"];
  diffuse_repig  -> complete_repig [label="sustained\ntreatment", color="#BF360C"];
  mel_migr       -> dendrite_ext   [color="#BF360C"];
  dendrite_ext   -> mel_transfer   [color="#6A1B9A"];
  IFNg_break     -> mel_prolif_r   [label="allow\nrepopulation", color="#BF360C"];
  MITF_rise      -> mel_prolif_r   [label="MITF-driven\nproliferation", color="#6A1B9A"];
  NBUVB_phot     -> follicle_res   [label="activate\nreservoir", color="#6A1B9A", style=dashed];

  // --- Clinical endpoints ---
  mature_mel     -> VASI_score  [label="mel loss\n→ VASI ↑", color="#4A148C", penwidth=2];
  complete_repig -> VASI_score  [label="mel gain\n→ VASI ↓", color="#4A148C", penwidth=2];
  VASI_score     -> VASI50      [color="#4A148C"];
  VASI_score     -> VASI75      [color="#4A148C"];
  BSA_inv        -> VASI_score  [label="area\ncalculation", color="#4A148C"];
  VASI_score     -> DLQI_score  [label="skin\nimpact", color="#4A148C"];
  active_dis     -> rapid_spread [color="#4A148C"];
  serum_CXCL10   -> active_dis  [label="biomarker\ncorrelation", color="#4A148C"];
  CXCL10_net     -> serum_CXCL10 [label="shed\nto serum", color="#FF6F00", penwidth=2];
  VASI50         -> stable_dis  [label="partial\nremission", color="#4A148C", style=dashed];
  nonseg_vit     -> BSA_inv     [color="#4A148C"];
  seg_vit        -> BSA_inv     [color="#4A148C"];
  acrofacial     -> BSA_inv     [color="#4A148C"];
  pSTAT1_inh     -> serum_CXCL10 [label="↓ CXCL10\nbiomarker", color="#33691E", penwidth=2];
}
