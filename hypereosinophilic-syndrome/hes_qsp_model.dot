digraph HES_QSP_Model {
    // ─────────────────────────────────────────────
    // Global graph attributes
    // ─────────────────────────────────────────────
    graph [
        label="Hypereosinophilic Syndrome (HES)\nQuantitative Systems Pharmacology Model\nIL-5/Eosinophil Kinetics · Cardiac/Pulmonary/GI Damage · Drug PK/PD",
        labelloc="t",
        fontsize=20,
        fontname="Helvetica",
        rankdir=TB,
        splines=ortho,
        nodesep=0.45,
        ranksep=0.7,
        bgcolor="#FAFAFA"
    ]
    node [fontname="Helvetica", fontsize=10, style=filled, shape=box]
    edge [fontname="Helvetica", fontsize=9]

    // ═══════════════════════════════════════════
    // CLUSTER 1: Upstream Immune Activation
    // ═══════════════════════════════════════════
    subgraph cluster_upstream {
        label="Upstream Immune Activation"
        style=filled; color="#E8F4FD"; fontsize=13; fontcolor="#1A5276"

        TSLP  [label="TSLP\n(Thymic Stromal\nLymphopoietin)", fillcolor="#AED6F1"]
        IL33  [label="IL-33\n(Alarmin)", fillcolor="#AED6F1"]
        IL25  [label="IL-25 / IL-17E\n(Epithelial)", fillcolor="#AED6F1"]
        EPIT  [label="Epithelial Barrier\nDamage / Allergen", fillcolor="#D6EAF8"]
        ILC2  [label="ILC2\n(Innate Lymphoid\nCell Type 2)", fillcolor="#85C1E9"]
        DC    [label="Dendritic Cell\n(mDC/pDC)", fillcolor="#85C1E9"]
        MAST  [label="Mast Cell\nActivation", fillcolor="#AED6F1"]
        IGE   [label="IgE\n(atopic response)", fillcolor="#D6EAF8"]
    }

    // ═══════════════════════════════════════════
    // CLUSTER 2: Th2 Cytokine Axis
    // ═══════════════════════════════════════════
    subgraph cluster_th2 {
        label="Th2 Cytokine Axis"
        style=filled; color="#E8F8E8"; fontsize=13; fontcolor="#1E8449"

        TH2   [label="Th2 CD4+ T Cell", fillcolor="#A9DFBF"]
        IL5   [label="IL-5\n(Key Eosinophil\nSurvival Factor)", fillcolor="#52BE80", fontcolor="white"]
        IL4   [label="IL-4\n(IgE class switching)", fillcolor="#A9DFBF"]
        IL13  [label="IL-13\n(Mucus, fibrosis)", fillcolor="#A9DFBF"]
        IL3   [label="IL-3\n(Eosinophil\nco-stimulator)", fillcolor="#A9DFBF"]
        GMCSF [label="GM-CSF\n(Eosinophil\ndifferentiation)", fillcolor="#A9DFBF"]
        TGFB  [label="TGF-β\n(Fibrogenic)", fillcolor="#D5DBDB"]
        CCL11 [label="Eotaxin-1\n(CCL11)", fillcolor="#A9DFBF"]
        CCL24 [label="Eotaxin-2\n(CCL24)", fillcolor="#A9DFBF"]
        CCL26 [label="Eotaxin-3\n(CCL26)", fillcolor="#A9DFBF"]
        CD4STAT6 [label="STAT6\nSignaling\n(IL-4Rα·IL-13Rα1)", fillcolor="#D5F5E3"]
    }

    // ═══════════════════════════════════════════
    // CLUSTER 3: PDGFRA Clonal HES
    // ═══════════════════════════════════════════
    subgraph cluster_clonal {
        label="Myeloid/Clonal HES (FIP1L1-PDGFRA)"
        style=filled; color="#FEF9E7"; fontsize=13; fontcolor="#7D6608"

        PDGFRA_WT  [label="PDGFRA\n(wild-type)", fillcolor="#FAD7A0"]
        FIP1L1     [label="FIP1L1-PDGFRA\nFusion Kinase\n(constitutive active)", fillcolor="#F39C12", fontcolor="white"]
        BCR_ABL    [label="BCR-ABL1\n(rare in HES)", fillcolor="#FAD7A0"]
        JAK2_V617F [label="JAK2 V617F\n(overlap MPN)", fillcolor="#FAD7A0"]
        RAS_MAPK   [label="RAS/MAPK\nSignaling", fillcolor="#FDEBD0"]
        PI3K_AKT   [label="PI3K/AKT\nSurvival", fillcolor="#FDEBD0"]
        STAT5_CL   [label="STAT5\n(clonal activation)", fillcolor="#F5CBA7"]
        EO_PROG_CL [label="Eosinophil Progenitor\n(clonal expansion)", fillcolor="#F5B041"]
        HSC        [label="Hematopoietic\nStem Cell (HSC)", fillcolor="#FAD7A0"]
    }

    // ═══════════════════════════════════════════
    // CLUSTER 4: Bone Marrow Eosinophilopoiesis
    // ═══════════════════════════════════════════
    subgraph cluster_bm {
        label="Bone Marrow Eosinophilopoiesis"
        style=filled; color="#F9EBEA"; fontsize=13; fontcolor="#922B21"

        CD34_PROG  [label="CD34+ Myeloid\nProgenitor", fillcolor="#F1948A"]
        IL5RA_BM   [label="IL-5Rα\n(on progenitors)", fillcolor="#F1948A"]
        EOP        [label="Eosinophil\nProgenitor (EoP)", fillcolor="#E74C3C", fontcolor="white"]
        IMMAT_EO   [label="Immature\nEosinophil", fillcolor="#F1948A"]
        MAT_EO_BM  [label="Mature Eosinophil\n(BM reservoir)", fillcolor="#CD6155"]
        STAT5_BM   [label="STAT5 Phosphorylation\n(IL-5Rα·JAK2)", fillcolor="#F1948A"]
        BCL2_BM    [label="BCL-2 / BCL-XL\n(anti-apoptosis)", fillcolor="#FADBD8"]
        PROL_RATE  [label="Proliferation Rate\n(EoP → EoI)", fillcolor="#FADBD8"]
        MATURATION [label="Maturation Rate\n(EoI → EoM-BM)", fillcolor="#FADBD8"]
        RELEASE    [label="BM → Blood\nRelease Rate", fillcolor="#FADBD8"]
    }

    // ═══════════════════════════════════════════
    // CLUSTER 5: Peripheral Blood Eosinophil Kinetics
    // ═══════════════════════════════════════════
    subgraph cluster_blood {
        label="Peripheral Blood Eosinophil Kinetics"
        style=filled; color="#EBF5FB"; fontsize=13; fontcolor="#154360"

        EO_BLOOD   [label="Blood Eosinophil\n(AEC · cells/µL)", fillcolor="#2E86C1", fontcolor="white"]
        IL5_SERUM  [label="IL-5\n(serum · pg/mL)", fillcolor="#5DADE2"]
        EO_HALFLIFE [label="Blood t½\n~18 hours", fillcolor="#AED6F1"]
        APOPTOSIS  [label="Eosinophil\nApoptosis", fillcolor="#AED6F1"]
        CCR3       [label="CCR3\n(Eotaxin receptor)", fillcolor="#AED6F1"]
        SIGLEC8    [label="Siglec-8\n(apoptotic signal)", fillcolor="#AED6F1"]
        IL5_SIGNAL [label="IL-5 Signaling\n(survival extension)", fillcolor="#AED6F1"]
        AEC_THRESH [label="AEC Threshold\n>1500/µL = HES", fillcolor="#5DADE2"]
        EO_DEPLETION [label="ADCC-mediated\nEosinophil Depletion\n(benralizumab)", fillcolor="#AED6F1"]
    }

    // ═══════════════════════════════════════════
    // CLUSTER 6: Tissue Eosinophil Infiltration
    // ═══════════════════════════════════════════
    subgraph cluster_tissue {
        label="Tissue Eosinophil Infiltration & Granule Toxins"
        style=filled; color="#FDF2F8"; fontsize=13; fontcolor="#6C3483"

        EO_CARDIAC [label="Cardiac\nEosinophils", fillcolor="#C39BD3"]
        EO_LUNG    [label="Pulmonary\nEosinophils", fillcolor="#C39BD3"]
        EO_GI      [label="GI Tract\nEosinophils", fillcolor="#C39BD3"]
        EO_SKIN    [label="Skin\nEosinophils", fillcolor="#C39BD3"]
        EO_NERVE   [label="Neural\nEosinophils", fillcolor="#C39BD3"]
        MBP        [label="MBP\n(Major Basic Protein)", fillcolor="#A569BD"]
        ECP        [label="ECP\n(Eosinophil Cationic\nProtein)", fillcolor="#A569BD"]
        EPO_ENZ    [label="EPO\n(Eosinophil\nPeroxidase)", fillcolor="#A569BD"]
        EDN        [label="EDN\n(Eosinophil-Derived\nNeurotoxin)", fillcolor="#A569BD"]
        LTC4       [label="LTC4\n(Leukotriene C4)", fillcolor="#D7BDE2"]
        PAF        [label="PAF\n(Platelet-Activating\nFactor)", fillcolor="#D7BDE2"]
        ROS_EO     [label="Reactive Oxygen\nSpecies (ROS)", fillcolor="#D7BDE2"]
    }

    // ═══════════════════════════════════════════
    // CLUSTER 7: Cardiac Pathophysiology
    // ═══════════════════════════════════════════
    subgraph cluster_cardiac {
        label="Cardiac Pathophysiology (Löffler Endocarditis)"
        style=filled; color="#FDEDEC"; fontsize=13; fontcolor="#922B21"

        LOEFFLER   [label="Löffler\nEndocarditis", fillcolor="#F1948A"]
        ENDO_THROMBUS [label="Endocardial\nThrombosis", fillcolor="#F1948A"]
        FIBROSIS_H [label="Endomyocardial\nFibrosis", fillcolor="#E74C3C", fontcolor="white"]
        RESTRICT_CM [label="Restrictive\nCardiomyopathy", fillcolor="#C0392B", fontcolor="white"]
        TROPONIN   [label="Troponin I/T\n(myocardial damage)", fillcolor="#FADBD8"]
        BNP_NT     [label="NT-proBNP\n(cardiac stress)", fillcolor="#FADBD8"]
        MITRAL_REG [label="Mitral / Tricuspid\nRegurgitation", fillcolor="#FADBD8"]
        LVEF       [label="LVEF\n(systolic function)", fillcolor="#FADBD8"]
        HF_CARD    [label="Heart Failure\n(HFpEF / HFrEF)", fillcolor="#EC7063"]
    }

    // ═══════════════════════════════════════════
    // CLUSTER 8: Pulmonary Pathophysiology
    // ═══════════════════════════════════════════
    subgraph cluster_pulm {
        label="Pulmonary Involvement"
        style=filled; color="#EBF5FB"; fontsize=13; fontcolor="#1A5276"

        EO_PNEUM   [label="Eosinophilic\nPneumonia", fillcolor="#85C1E9"]
        PULM_INFIL [label="Pulmonary\nInfiltrates", fillcolor="#85C1E9"]
        DLCO       [label="DLCO\n(diffusion capacity)", fillcolor="#AED6F1"]
        FEV1_HES   [label="FEV1\n(obstruction)", fillcolor="#AED6F1"]
        PULM_HTN   [label="Pulmonary\nHypertension", fillcolor="#85C1E9"]
        PLEURAL_EFF [label="Pleural\nEffusion", fillcolor="#AED6F1"]
    }

    // ═══════════════════════════════════════════
    // CLUSTER 9: Drug PK - Anti-IL-5 Biologics
    // ═══════════════════════════════════════════
    subgraph cluster_pk_biologic {
        label="Drug PK: Anti-IL-5 Biologics"
        style=filled; color="#EAFAF1"; fontsize=13; fontcolor="#1E8449"

        MEPO_SC    [label="Mepolizumab SC\n(anti-IL-5 IgG1)\n300 mg q4w", fillcolor="#27AE60", fontcolor="white"]
        MEPO_C1    [label="Mepolizumab\nCentral (C1)", fillcolor="#82E0AA"]
        MEPO_C2    [label="Mepolizumab\nPeripheral (C2)", fillcolor="#82E0AA"]
        MEPO_TMDD  [label="IL-5:Mepolizumab\nComplex (TMDD)", fillcolor="#ABEBC6"]
        RESLI_IV   [label="Reslizumab IV\n(anti-IL-5 IgG4)\n3 mg/kg q4w", fillcolor="#27AE60", fontcolor="white"]
        BENRA_SC   [label="Benralizumab SC\n(anti-IL-5Rα)\n30 mg q4w→q8w", fillcolor="#1E8449", fontcolor="white"]
        BENRA_C1   [label="Benralizumab\nCentral (C1)", fillcolor="#82E0AA"]
        BENRA_C2   [label="Benralizumab\nPeripheral (C2)", fillcolor="#82E0AA"]
        ADCC_MECH  [label="ADCC Mechanism\n(NK cell-mediated)", fillcolor="#ABEBC6"]
        FcRn       [label="FcRn Recycling\n(IgG t½ extension)", fillcolor="#D5F5E3"]
    }

    // ═══════════════════════════════════════════
    // CLUSTER 10: Drug PK - Small Molecules
    // ═══════════════════════════════════════════
    subgraph cluster_pk_sm {
        label="Drug PK: Small Molecules"
        style=filled; color="#FEF5E7"; fontsize=13; fontcolor="#784212"

        IMATIN_PO  [label="Imatinib PO\n(PDGFRA TKI)\n100-400 mg/day", fillcolor="#E67E22", fontcolor="white"]
        IMATIN_GUT [label="Imatinib Gut\nAbsorption (ka)", fillcolor="#F5CBA7"]
        IMATIN_C   [label="Imatinib\nCentral (C)", fillcolor="#F0B27A"]
        IMATIN_MET [label="Imatinib → N-desmethyl\n(active metabolite)", fillcolor="#F5CBA7"]
        PREDNISO   [label="Prednisolone PO\n(Glucocorticoid)\n1 mg/kg/day", fillcolor="#D4AC0D", fontcolor="white"]
        PRED_C     [label="Prednisolone\nCentral (C)", fillcolor="#F9E79F"]
        PRED_GR    [label="Glucocorticoid\nReceptor (GR)", fillcolor="#F9E79F"]
        HYDROXY    [label="Hydroxyurea\n(BM suppression)", fillcolor="#F5B041"]
        CYCLO      [label="Cyclophosphamide\n(refractory HES)", fillcolor="#F5B041"]
        CLADRIBINE [label="Cladribine\n(lymphocytic HES)", fillcolor="#FAD7A0"]
    }

    // ═══════════════════════════════════════════
    // CLUSTER 11: Glucocorticoid PD Effects
    // ═══════════════════════════════════════════
    subgraph cluster_gc {
        label="Glucocorticoid Pharmacodynamics"
        style=filled; color="#FDFEFE"; fontsize=13; fontcolor="#17202A"

        GR_TRANS   [label="GR Transactivation\n(anti-inflammatory genes)", fillcolor="#D5D8DC"]
        GR_TRANS2  [label="GR Transrepression\n(NF-κB inhibition)", fillcolor="#D5D8DC"]
        IL5_INHIB  [label="IL-5 Transcription\nInhibition (GC)", fillcolor="#BFC9CA"]
        EO_APOPT   [label="Eosinophil Apoptosis\nPromotion (GC)", fillcolor="#BFC9CA"]
        TH2_INHIB  [label="Th2 Cell\nSuppression (GC)", fillcolor="#BFC9CA"]
        BMD_LOSS   [label="Bone Mineral\nDensity Loss", fillcolor="#BFC9CA"]
        GLUCOSE_GC [label="Hyperglycemia\n(GC side effect)", fillcolor="#BFC9CA"]
        HPA_SUPP   [label="HPA Axis\nSuppression", fillcolor="#BFC9CA"]
    }

    // ═══════════════════════════════════════════
    // CLUSTER 12: Clinical Endpoints & Biomarkers
    // ═══════════════════════════════════════════
    subgraph cluster_endpoints {
        label="Clinical Endpoints & Biomarkers"
        style=filled; color="#F4ECF7"; fontsize=13; fontcolor="#6C3483"

        AEC_RESP   [label="AEC Response\n(<300/µL target)", fillcolor="#9B59B6", fontcolor="white"]
        HES_REMISS [label="HES Remission\n(AEC + symptoms)", fillcolor="#8E44AD", fontcolor="white"]
        EXACER     [label="HES Exacerbation\nRate", fillcolor="#BB8FCE"]
        ECHO_CARD  [label="Echocardiography\n(structural damage)", fillcolor="#BB8FCE"]
        SERUM_ECP  [label="Serum ECP\n(eosinophil activation)", fillcolor="#BB8FCE"]
        SERUM_TRYPT [label="Serum Tryptase\n(mast cell)", fillcolor="#BB8FCE"]
        ILL_SCORE  [label="Illness Severity\nScore", fillcolor="#BB8FCE"]
        QOL_HES    [label="QoL Score\n(SF-36 / EQ-5D)", fillcolor="#BB8FCE"]
        ORGAN_DMG  [label="Organ Damage\nScore (modified)", fillcolor="#BB8FCE"]
        STEROID_SPARE [label="Corticosteroid-\nSparing Effect", fillcolor="#BB8FCE"]
    }

    // ═══════════════════════════════════════════
    // CLUSTER 13: GI and Skin Involvement
    // ═══════════════════════════════════════════
    subgraph cluster_gi_skin {
        label="GI & Skin Manifestations"
        style=filled; color="#F0F4C3"; fontsize=13; fontcolor="#33691E"

        EO_ESOPH   [label="Eosinophilic\nEsophagitis (EoE)", fillcolor="#C5E1A5"]
        EO_GASTRO  [label="Eosinophilic\nGastroenteritis", fillcolor="#C5E1A5"]
        EO_COLITIS [label="Eosinophilic\nColitis", fillcolor="#C5E1A5"]
        URTICARIA  [label="Urticaria /\nAngioedema", fillcolor="#C5E1A5"]
        ERYTHROD   [label="Erythroderma /\nPruritus", fillcolor="#C5E1A5"]
        MUCOSAL_DMG [label="GI Mucosal\nDamage", fillcolor="#AED581"]
        ABDOMINAL  [label="Abdominal Pain /\nDiarrhea", fillcolor="#C5E1A5"]
    }

    // ═══════════════════════════════════════════
    // CLUSTER 14: Neurological Involvement
    // ═══════════════════════════════════════════
    subgraph cluster_neuro {
        label="Neurological Involvement"
        style=filled; color="#E8EAF6"; fontsize=13; fontcolor="#283593"

        PERIPH_NEURO [label="Peripheral\nNeuropathy", fillcolor="#9FA8DA"]
        ENCEPH     [label="HES\nEncephalopathy", fillcolor="#9FA8DA"]
        CNS_THROMBO [label="CNS Thromboembolism\n(from cardiac)", fillcolor="#9FA8DA"]
        COGNITIVE  [label="Cognitive\nImpairment", fillcolor="#C5CAE9"]
        FOCAL_DEFN [label="Focal Neurological\nDeficits", fillcolor="#C5CAE9"]
        NERVE_COND [label="Nerve Conduction\nStudy", fillcolor="#C5CAE9"]
    }

    // ═══════════════════════════════════════════
    // EDGES: Upstream Activation → Th2
    // ═══════════════════════════════════════════
    EPIT -> TSLP [color="#2E86C1"]
    EPIT -> IL33  [color="#2E86C1"]
    EPIT -> IL25  [color="#2E86C1"]
    TSLP -> DC    [color="#2E86C1"]
    TSLP -> ILC2  [color="#2E86C1"]
    IL33 -> ILC2  [color="#1ABC9C"]
    IL25 -> ILC2  [color="#1ABC9C"]
    DC   -> TH2   [label="antigen\npresentation", color="#2E86C1"]
    ILC2 -> IL5   [color="#1E8449"]
    ILC2 -> IL13  [color="#1E8449"]
    MAST -> IL5   [color="#E74C3C"]
    MAST -> LTC4  [color="#E74C3C"]

    // Th2 Cytokine production
    TH2  -> IL5   [color="#1E8449", penwidth=2]
    TH2  -> IL4   [color="#1E8449"]
    TH2  -> IL13  [color="#1E8449"]
    TH2  -> IL3   [color="#1E8449"]
    TH2  -> GMCSF [color="#1E8449"]
    TH2  -> TGFB  [color="#1E8449"]
    IL4  -> CD4STAT6 [color="#27AE60"]
    IL13 -> CD4STAT6 [color="#27AE60"]
    IL13 -> TGFB  [color="#27AE60"]
    CD4STAT6 -> CCL11 [color="#27AE60"]
    CD4STAT6 -> CCL24 [color="#27AE60"]
    CD4STAT6 -> CCL26 [color="#27AE60"]
    IL4  -> IGE   [label="B cell class\nswitching", color="#8E44AD"]
    IGE  -> MAST  [color="#8E44AD"]

    // ─── Clonal pathway ───
    HSC  -> PDGFRA_WT [color="#F39C12"]
    HSC  -> FIP1L1    [label="del(4q12)", color="#E74C3C", style=dashed]
    FIP1L1 -> RAS_MAPK [color="#E74C3C", penwidth=2]
    FIP1L1 -> PI3K_AKT [color="#E74C3C", penwidth=2]
    FIP1L1 -> STAT5_CL [color="#E74C3C", penwidth=2]
    JAK2_V617F -> STAT5_CL [color="#E67E22"]
    STAT5_CL -> EO_PROG_CL [color="#E74C3C", penwidth=2]
    RAS_MAPK -> EO_PROG_CL [color="#E74C3C"]
    PI3K_AKT -> EO_PROG_CL [color="#E74C3C"]

    // ─── BM Eosinophilopoiesis ───
    IL5   -> IL5RA_BM [color="#E74C3C", penwidth=2]
    IL3   -> CD34_PROG [color="#2E86C1"]
    GMCSF -> CD34_PROG [color="#2E86C1"]
    CD34_PROG -> EOP    [color="#E74C3C"]
    EO_PROG_CL -> EOP  [color="#E74C3C", style=dashed, label="clonal"]
    IL5RA_BM  -> STAT5_BM [color="#E74C3C"]
    STAT5_BM  -> BCL2_BM  [color="#E74C3C"]
    STAT5_BM  -> PROL_RATE [color="#E74C3C"]
    BCL2_BM   -> EOP       [label="survival", color="#E74C3C"]
    EOP       -> IMMAT_EO  [label="k_maturation", color="#C0392B"]
    IMMAT_EO  -> MAT_EO_BM [label="k_release", color="#C0392B"]
    PROL_RATE -> EOP       [color="#C0392B"]
    MATURATION -> IMMAT_EO [color="#C0392B"]
    RELEASE   -> EO_BLOOD  [color="#C0392B", penwidth=2]
    MAT_EO_BM -> RELEASE   [color="#C0392B"]

    // ─── Peripheral blood ───
    IL5_SERUM -> IL5_SIGNAL [color="#2E86C1", penwidth=2]
    IL5_SIGNAL -> EO_HALFLIFE [label="survival\nextension", color="#2E86C1"]
    EO_BLOOD  -> EO_HALFLIFE  [color="#85C1E9"]
    EO_BLOOD  -> APOPTOSIS    [color="#85C1E9"]
    CCR3      -> EO_BLOOD     [label="CCL11\nmigration", color="#E74C3C"]
    CCL11     -> CCR3         [color="#E74C3C"]
    CCL24     -> CCR3         [color="#E74C3C"]
    CCL26     -> CCR3         [color="#E74C3C"]
    SIGLEC8   -> APOPTOSIS    [color="#8E44AD"]
    EO_BLOOD  -> AEC_THRESH   [color="#2E86C1"]

    // ─── Tissue migration ───
    EO_BLOOD -> EO_CARDIAC [color="#C0392B"]
    EO_BLOOD -> EO_LUNG    [color="#2874A6"]
    EO_BLOOD -> EO_GI      [color="#27AE60"]
    EO_BLOOD -> EO_SKIN    [color="#7D3C98"]
    EO_BLOOD -> EO_NERVE   [color="#1F618D"]

    // ─── Granule release ───
    EO_CARDIAC -> MBP  [color="#A569BD"]
    EO_CARDIAC -> ECP  [color="#A569BD"]
    EO_CARDIAC -> EPO_ENZ [color="#A569BD"]
    EO_LUNG  -> MBP    [color="#A569BD"]
    EO_LUNG  -> ECP    [color="#A569BD"]
    EO_GI    -> MBP    [color="#A569BD"]
    EO_GI    -> EDN    [color="#A569BD"]
    EO_NERVE -> EDN    [color="#7D3C98", penwidth=2]
    MBP  -> ROS_EO     [color="#E74C3C"]
    EPO_ENZ -> ROS_EO  [color="#E74C3C"]
    EO_CARDIAC -> LTC4 [color="#A569BD"]
    EO_CARDIAC -> PAF  [color="#A569BD"]

    // ─── Cardiac pathology ───
    MBP    -> LOEFFLER   [color="#C0392B", penwidth=2]
    ECP    -> LOEFFLER   [color="#C0392B", penwidth=2]
    PAF    -> ENDO_THROMBUS [color="#E74C3C"]
    LOEFFLER -> ENDO_THROMBUS [color="#C0392B"]
    ENDO_THROMBUS -> FIBROSIS_H [color="#C0392B"]
    TGFB   -> FIBROSIS_H  [color="#7D3C98", penwidth=2]
    FIBROSIS_H -> RESTRICT_CM [color="#922B21", penwidth=2]
    RESTRICT_CM -> MITRAL_REG [color="#922B21"]
    RESTRICT_CM -> HF_CARD    [color="#922B21"]
    LOEFFLER -> TROPONIN      [color="#E74C3C"]
    HF_CARD  -> BNP_NT        [color="#E74C3C"]
    MITRAL_REG -> LVEF        [label="impairs", color="#E74C3C"]
    ENDO_THROMBUS -> CNS_THROMBO [color="#E74C3C", style=dashed]

    // ─── Pulmonary pathology ───
    EO_LUNG  -> EO_PNEUM  [color="#2874A6"]
    EO_PNEUM -> PULM_INFIL [color="#2874A6"]
    PULM_INFIL -> DLCO     [label="impairs", color="#2874A6"]
    PULM_INFIL -> FEV1_HES [label="impairs", color="#2874A6"]
    TGFB -> PULM_HTN       [color="#7D3C98"]
    EO_LUNG -> PLEURAL_EFF [color="#2874A6"]

    // ─── GI / Skin ───
    EO_GI   -> EO_ESOPH  [color="#27AE60"]
    EO_GI   -> EO_GASTRO [color="#27AE60"]
    EO_GI   -> EO_COLITIS [color="#27AE60"]
    EO_ESOPH -> MUCOSAL_DMG [color="#27AE60"]
    EO_GASTRO -> ABDOMINAL  [color="#27AE60"]
    EO_SKIN -> URTICARIA    [color="#7D3C98"]
    EO_SKIN -> ERYTHROD     [color="#7D3C98"]

    // ─── Neurological ───
    EO_NERVE -> PERIPH_NEURO [color="#1F618D"]
    EO_NERVE -> ENCEPH        [color="#1F618D"]
    EDN -> ENCEPH             [color="#1F618D"]
    EDN -> PERIPH_NEURO       [color="#1F618D"]
    CNS_THROMBO -> FOCAL_DEFN [color="#1F618D"]
    PERIPH_NEURO -> NERVE_COND [color="#1F618D"]
    ENCEPH -> COGNITIVE        [color="#1F618D"]

    // ─── Mepolizumab PK ───
    MEPO_SC -> MEPO_C1  [label="Bioavailability\nF=0.8", color="#27AE60"]
    MEPO_C1 -> MEPO_C2  [label="distribution", color="#27AE60"]
    MEPO_C2 -> MEPO_C1  [label="return", color="#27AE60"]
    MEPO_C1 -> MEPO_TMDD [label="IL-5 binding\nkon/koff", color="#1E8449"]
    IL5_SERUM -> MEPO_TMDD [color="#1E8449"]
    MEPO_TMDD -> IL5_SERUM [label="neutralize\n(kdeg)", color="#1E8449", style=dashed]
    FcRn    -> MEPO_C1   [label="recycles\nt½~22 days", color="#27AE60"]
    MEPO_C1 -> IL5_INHIB [label="↓IL-5", color="#27AE60", penwidth=2]

    // ─── Benralizumab PK ───
    BENRA_SC -> BENRA_C1 [label="F=0.59", color="#1E8449"]
    BENRA_C1 -> BENRA_C2 [color="#1E8449"]
    BENRA_C2 -> BENRA_C1 [color="#1E8449"]
    BENRA_C1 -> ADCC_MECH [label="IL-5Rα\nbinding", color="#1E8449", penwidth=2]
    ADCC_MECH -> EO_DEPLETION [color="#E74C3C", penwidth=2]
    EO_DEPLETION -> EO_BLOOD   [label="rapid depletion", color="#E74C3C", style=dashed]
    BENRA_C1 -> SIGLEC8        [label="co-activates\napoptosis", color="#1E8449"]

    // ─── Reslizumab PK ───
    RESLI_IV -> IL5_SERUM [label="anti-IL-5\nneutralization", color="#27AE60", style=dashed]

    // ─── Imatinib PK/PD ───
    IMATIN_PO  -> IMATIN_GUT [color="#E67E22"]
    IMATIN_GUT -> IMATIN_C   [label="ka, F~0.98", color="#E67E22"]
    IMATIN_C   -> IMATIN_MET [label="CYP3A4", color="#E67E22"]
    IMATIN_C   -> FIP1L1     [label="TKI inhibition\nIC50 ~0.1 nM", color="#E74C3C", penwidth=2, style=dashed, arrowhead=tee]
    IMATIN_C   -> BCR_ABL    [label="TKI inhibition", color="#E74C3C", style=dashed, arrowhead=tee]
    FIP1L1     -> STAT5_CL   [label="blocked by\nimatinib", color="#E67E22", style=dashed]

    // ─── Prednisolone PK/PD ───
    PREDNISO   -> PRED_C  [label="oral PO\nF~0.82", color="#D4AC0D"]
    PRED_C     -> PRED_GR [label="receptor\nbinding", color="#D4AC0D"]
    PRED_GR    -> GR_TRANS  [color="#D4AC0D"]
    PRED_GR    -> GR_TRANS2 [color="#D4AC0D"]
    GR_TRANS2  -> IL5_INHIB  [color="#D4AC0D", penwidth=2]
    GR_TRANS2  -> TH2_INHIB  [color="#D4AC0D"]
    GR_TRANS   -> EO_APOPT   [color="#D4AC0D"]
    GR_TRANS   -> BMD_LOSS   [color="#D4AC0D"]
    GR_TRANS   -> GLUCOSE_GC [color="#D4AC0D"]
    PRED_GR    -> HPA_SUPP   [color="#D4AC0D"]
    IL5_INHIB  -> IL5_SERUM  [label="reduces IL-5\nproduction", color="#D4AC0D", arrowhead=tee]
    EO_APOPT   -> APOPTOSIS  [color="#D4AC0D"]
    TH2_INHIB  -> TH2        [color="#D4AC0D", arrowhead=tee]

    // ─── Hydroxyurea / Cyclophosphamide ───
    HYDROXY -> EOP       [label="BM suppression", color="#E67E22", arrowhead=tee]
    CYCLO   -> EOP       [label="cytotoxic", color="#C0392B", arrowhead=tee]
    CLADRIBINE -> TH2    [label="lymphocyte\nsuppression", color="#7D3C98", arrowhead=tee]

    // ─── Clinical endpoints ───
    EO_BLOOD  -> AEC_RESP    [color="#8E44AD", penwidth=2]
    AEC_RESP  -> HES_REMISS  [color="#8E44AD"]
    HES_REMISS -> STEROID_SPARE [color="#8E44AD"]
    HES_REMISS -> QOL_HES    [color="#8E44AD"]
    FIBROSIS_H -> ORGAN_DMG  [color="#C0392B"]
    RESTRICT_CM -> ORGAN_DMG [color="#C0392B"]
    PULM_INFIL -> ORGAN_DMG  [color="#2874A6"]
    PERIPH_NEURO -> ORGAN_DMG [color="#1F618D"]
    EO_BLOOD  -> SERUM_ECP   [color="#A569BD"]
    ECP       -> SERUM_ECP   [color="#A569BD"]
    TROPONIN  -> ECHO_CARD   [color="#E74C3C"]
    BNP_NT    -> ECHO_CARD   [color="#E74C3C"]
    ORGAN_DMG -> ILL_SCORE   [color="#C0392B"]
    EXACER    -> ILL_SCORE   [color="#C0392B"]
    QOL_HES   -> ILL_SCORE   [color="#7D3C98"]

    // ─── Feedback loops ───
    HES_REMISS -> EPIT [label="disease control\nreduces triggers", color="#7D3C98", style=dashed]
    FIBROSIS_H -> TGFB [label="positive\nfeedback", color="#E74C3C", style=dashed]

    // ═══════════════════════════════════════════
    // LEGEND
    // ═══════════════════════════════════════════
    subgraph cluster_legend {
        label="Legend"
        style=filled; color="#F2F3F4"; fontsize=11

        LEG_PATH [label="Pathological\nPathway", fillcolor="#F1948A"]
        LEG_DRUG [label="Drug\nIntervention", fillcolor="#27AE60", fontcolor="white"]
        LEG_BIO  [label="Biomarker /\nEndpoint", fillcolor="#9B59B6", fontcolor="white"]
        LEG_CLONAL [label="Clonal /\nMyeloid", fillcolor="#F39C12", fontcolor="white"]
        LEG_PK   [label="PK\nCompartment", fillcolor="#82E0AA"]
    }
}
