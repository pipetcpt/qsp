digraph HES_QSP {
  graph [rankdir=LR, fontname="Helvetica", fontsize=11, labelloc=t,
         label="Hypereosinophilic Syndrome (HES) — Integrated QSP Mechanistic Map\nMyeloid/neoplastic (FIP1L1-PDGFRA·PDGFRB·FGFR1·JAK2) & lymphocytic-variant (clonal Th2) eosinophilopoiesis · Eosinophil effector/organ-damage cascade\nImatinib · Corticosteroids · Mepolizumab/Benralizumab (anti-IL-5 axis) · Hydroxyurea/Ruxolitinib/IFN-α · Cardiac(Loeffler)/pulmonary/dermatologic/neurologic/GI endpoints",
         splines=spline, overlap=false, nodesep=0.30, ranksep=0.55,
         bgcolor="#fbfbfd"];
  node  [shape=box, style="rounded,filled", fontname="Helvetica", fontsize=10,
         fillcolor="#ffffff", color="#7d8590"];
  edge  [fontname="Helvetica", fontsize=9, color="#6e7681", arrowsize=0.7];

  /* ───────────────────────── 1. Etiology & Molecular Classification ───────── */
  subgraph cluster_etiology {
    label="1. Etiology & Molecular Classification";
    style="filled,rounded"; color="#5c6370"; fillcolor="#f3f0ff"; fontsize=12;
    PersistentEosinophilia [label="Persistent blood eosinophilia\n(≥1500/µL ×2, ≥1 month apart)"];
    OrganDamageCriterion   [label="Eosinophil-mediated\norgan damage/dysfunction"];
    SecondaryExclusion     [label="Exclusion of secondary causes\n(parasites, drug hypersensitivity,\nallergy, malignancy)"];
    HES_Diagnosis          [label="HES diagnosis\n(WHO/ICOG-EO criteria)"];
    Chr4q12Deletion        [label="Cryptic del(4)(q12q12)\nCHIC2 deletion"];
    FIP1L1PDGFRA_Fusion    [label="FIP1L1-PDGFRA\nfusion gene (M-HES, ~10-20%)"];
    PDGFRB_Rearrange       [label="PDGFRB rearrangement\n(t(5;12) ETV6-PDGFRB etc.)"];
    FGFR1_Rearrange        [label="FGFR1 rearrangement\n(8p11 myeloproliferative syndrome)"];
    JAK2_Rearrange         [label="JAK2/FLT3/ABL1\nrearrangement (rare)"];
    KIT_Mutation           [label="KIT D816V\nmutation (overlap w/ SM)"];
    ChronicEosinLeukemiaNOS[label="Chronic eosinophilic\nleukemia, NOS"];
    ClonalTcellPop         [label="Aberrant clonal T-cell\npopulation (CD3-CD4+)"];
    LymphocyticVariantHES  [label="Lymphocytic-variant HES\n(L-HES)"];
    IdiopathicHES          [label="Idiopathic HES\n(no clonal marker found)"];
    FamilialHES            [label="Familial HES\n(chr 5q31-33 linkage)"];
    OverlapHES             [label="Organ-restricted overlap\n(EGPA/eosinophilic GI overlap)"];
    PersistentEosinophilia -> HES_Diagnosis;
    OrganDamageCriterion -> HES_Diagnosis;
    SecondaryExclusion -> HES_Diagnosis;
    HES_Diagnosis -> Chr4q12Deletion [style=dashed];
    Chr4q12Deletion -> FIP1L1PDGFRA_Fusion;
    HES_Diagnosis -> PDGFRB_Rearrange [style=dashed];
    HES_Diagnosis -> FGFR1_Rearrange [style=dashed];
    HES_Diagnosis -> JAK2_Rearrange [style=dashed];
    HES_Diagnosis -> KIT_Mutation [style=dashed];
    FIP1L1PDGFRA_Fusion -> ChronicEosinLeukemiaNOS [style=dotted, label="myeloid\nspectrum"];
    HES_Diagnosis -> ClonalTcellPop [style=dashed];
    ClonalTcellPop -> LymphocyticVariantHES;
    HES_Diagnosis -> IdiopathicHES [style=dashed];
    HES_Diagnosis -> FamilialHES [style=dashed];
    HES_Diagnosis -> OverlapHES [style=dashed];
  }

  /* ───────────────────────── 2. Bone Marrow Eosinophilopoiesis ─────────────── */
  subgraph cluster_marrow {
    label="2. Bone Marrow Eosinophilopoiesis & Cytokine Drivers";
    style="filled,rounded"; color="#5c6370"; fillcolor="#fff4e6"; fontsize=12;
    CD34Progenitor      [label="CD34+ hematopoietic\nprogenitor cell"];
    GATA1_Transcription [label="GATA-1\ntranscription factor"];
    PU1_CEBPa           [label="PU.1 / C/EBPα\nlineage commitment"];
    IL5_Cytokine        [label="Interleukin-5\n(IL-5)"];
    IL5R_alpha          [label="IL-5 receptor α\n(IL-5Rα, CD125)"];
    IL3_GMCSF           [label="IL-3 / GM-CSF\n(shared βc receptor)"];
    JAK2_STAT5_Marrow   [label="JAK2 → STAT5\nsignaling (cytokine-driven)"];
    EosinophilProgenitor[label="Eosinophil-lineage\ncommitted progenitor (EoP)"];
    EosinophilMaturation[label="Terminal eosinophil\nmaturation (marrow)"];
    MarrowRelease       [label="Marrow release into\nperipheral circulation"];
    CD34Progenitor -> GATA1_Transcription -> PU1_CEBPa -> EosinophilProgenitor;
    IL5_Cytokine -> IL5R_alpha -> JAK2_STAT5_Marrow;
    IL3_GMCSF -> JAK2_STAT5_Marrow;
    JAK2_STAT5_Marrow -> EosinophilProgenitor;
    EosinophilProgenitor -> EosinophilMaturation -> MarrowRelease;
  }

  /* ───────────────────────── 3. Myeloid/Neoplastic Kinase Signaling ────────── */
  subgraph cluster_myeloid {
    label="3. Myeloid/Neoplastic Kinase Signaling (M-HES)";
    style="filled,rounded"; color="#5c6370"; fillcolor="#e6f4ff"; fontsize=12;
    FIP1L1PDGFRA_Kinase [label="FIP1L1-PDGFRA\nconstitutively active TK"];
    PDGFRB_Kinase       [label="Fusion-partner-PDGFRB\nconstitutively active TK"];
    FGFR1_Kinase        [label="Fusion-partner-FGFR1\nconstitutively active TK"];
    STAT5_Constitutive  [label="Constitutive STAT5\nphosphorylation (pSTAT5)"];
    PI3K_AKT_Myeloid    [label="PI3K-AKT\nsurvival signaling"];
    RAS_MAPK_Myeloid    [label="RAS-RAF-MEK-ERK\nproliferation signaling"];
    ClonalEosinExpansion[label="Clonal eosinophil\nprogenitor expansion"];
    T674I_ResistanceMut [label="PDGFRA T674I\nresistance mutation"];
    ImatinibResistance  [label="Imatinib-resistant\nclonal outgrowth"];
    MastCellCoExpansion [label="Concurrent mast-cell/\nbasophil lineage expansion"];
    FIP1L1PDGFRA_Fusion -> FIP1L1PDGFRA_Kinase;
    PDGFRB_Rearrange -> PDGFRB_Kinase;
    FGFR1_Rearrange -> FGFR1_Kinase;
    FIP1L1PDGFRA_Kinase -> STAT5_Constitutive;
    FIP1L1PDGFRA_Kinase -> PI3K_AKT_Myeloid;
    FIP1L1PDGFRA_Kinase -> RAS_MAPK_Myeloid;
    PDGFRB_Kinase -> STAT5_Constitutive;
    FGFR1_Kinase -> STAT5_Constitutive;
    STAT5_Constitutive -> ClonalEosinExpansion;
    PI3K_AKT_Myeloid -> ClonalEosinExpansion [label="anti-apoptotic"];
    RAS_MAPK_Myeloid -> ClonalEosinExpansion;
    ClonalEosinExpansion -> MarrowRelease;
    FIP1L1PDGFRA_Kinase -> T674I_ResistanceMut [style=dashed, label="selective\npressure"];
    T674I_ResistanceMut -> ImatinibResistance;
    FIP1L1PDGFRA_Kinase -> MastCellCoExpansion [style=dashed];
  }

  /* ───────────────────────── 4. Lymphocytic-Variant T-cell Pathway ─────────── */
  subgraph cluster_lymphocytic {
    label="4. Lymphocytic-Variant (L-HES) T-cell Pathway";
    style="filled,rounded"; color="#5c6370"; fillcolor="#e8f9f0"; fontsize=12;
    AberrantCD3neg4pos  [label="CD3-CD4+\naberrant immunophenotype"];
    TCR_ClonalRearrange [label="TCR γ-chain\nclonal rearrangement"];
    Th2_Cytokine_Skew   [label="Th2 cytokine skew\n(GATA3-driven)"];
    IL5_LHES_Source     [label="Clonal T-cell-derived\nIL-5 secretion"];
    IL4_IL13_LHES       [label="IL-4 / IL-13\nco-secretion"];
    IgE_Elevation       [label="Polyclonal IgE\nelevation"];
    LymphomaTransform   [label="Risk of T-cell\nlymphoma transformation (~10-15%, years)"];
    LymphocyticVariantHES -> AberrantCD3neg4pos -> TCR_ClonalRearrange;
    TCR_ClonalRearrange -> Th2_Cytokine_Skew;
    Th2_Cytokine_Skew -> IL5_LHES_Source;
    Th2_Cytokine_Skew -> IL4_IL13_LHES -> IgE_Elevation;
    IL5_LHES_Source -> IL5_Cytokine;
    TCR_ClonalRearrange -> LymphomaTransform [style=dashed, label="long-term\nrisk"];
  }

  /* ───────────────────────── 5. Eosinophil Activation & Effectors ──────────── */
  subgraph cluster_effector {
    label="5. Eosinophil Activation & Tissue Effector Mediators";
    style="filled,rounded"; color="#5c6370"; fillcolor="#fff0f0"; fontsize=12;
    CirculatingEosinophil[label="Circulating eosinophil\npool (AEC)"];
    Eotaxin_CCL11       [label="Eotaxin (CCL11/CCL24)\nchemokine gradient"];
    CCR3_Receptor       [label="CCR3 receptor\n(eosinophil surface)"];
    EndothelialAdhesion [label="VCAM-1/VLA-4-mediated\nendothelial adhesion"];
    TissueTransmigration[label="Transendothelial\nmigration into tissue"];
    TissueEosinophilBurden[label="Tissue eosinophil\ninfiltration burden"];
    EosinDegranulation  [label="Eosinophil\ndegranulation"];
    MBP_Release         [label="Major basic protein\n(MBP)"];
    ECP_Release         [label="Eosinophil cationic\nprotein (ECP)"];
    EPO_Release         [label="Eosinophil peroxidase\n(EPO)"];
    EDN_Release         [label="Eosinophil-derived\nneurotoxin (EDN)"];
    ROS_Generation      [label="Reactive oxygen\nspecies generation"];
    CytotoxicTissueDamage[label="Direct cytotoxic\ntissue/endothelial damage"];
    TissueFactorRelease [label="Tissue factor /\nprocoagulant activation"];
    CirculatingEosinophil -> Eotaxin_CCL11 [dir=back, label="chemotactic\nrecruitment"];
    Eotaxin_CCL11 -> CCR3_Receptor -> EndothelialAdhesion -> TissueTransmigration -> TissueEosinophilBurden;
    TissueEosinophilBurden -> EosinDegranulation;
    EosinDegranulation -> MBP_Release;
    EosinDegranulation -> ECP_Release;
    EosinDegranulation -> EPO_Release;
    EosinDegranulation -> EDN_Release;
    EPO_Release -> ROS_Generation;
    MBP_Release -> CytotoxicTissueDamage;
    ROS_Generation -> CytotoxicTissueDamage;
    MBP_Release -> TissueFactorRelease;
    MarrowRelease -> CirculatingEosinophil;
    IL5_Cytokine -> CirculatingEosinophil [label="anti-apoptotic\nsurvival (Bcl-2/Bcl-xL↑)"];
  }

  /* ───────────────────────── 6. Cardiac Involvement (Loeffler) ─────────────── */
  subgraph cluster_cardiac {
    label="6. Cardiac Involvement — Loeffler Endocarditis";
    style="filled,rounded"; color="#5c6370"; fillcolor="#fdeef2"; fontsize=12;
    EndocardialNecrosis  [label="Acute endocardial\nnecrosis (eosinophilic)"];
    MuralThrombus        [label="Mural thrombus\nformation"];
    EndomyocardialFibrosis[label="Endomyocardial fibrosis\n(restrictive stage)"];
    ChordaeInvolvement    [label="Papillary muscle/chordae\nfibrotic entrapment"];
    ValvularRegurgitation [label="Mitral/tricuspid\nregurgitation"];
    RestrictiveCardiomyopathy[label="Restrictive\ncardiomyopathy physiology"];
    CardiacThromboembolism[label="Intracardiac thrombus\nembolization"];
    TroponinElevation     [label="Cardiac troponin\nelevation"];
    HeartFailureSymptoms  [label="Heart failure /\ndyspnea symptoms"];
    CytotoxicTissueDamage -> EndocardialNecrosis;
    TissueFactorRelease -> MuralThrombus;
    EndocardialNecrosis -> MuralThrombus -> EndomyocardialFibrosis;
    EndomyocardialFibrosis -> ChordaeInvolvement -> ValvularRegurgitation;
    EndomyocardialFibrosis -> RestrictiveCardiomyopathy -> HeartFailureSymptoms;
    MuralThrombus -> CardiacThromboembolism;
    EndocardialNecrosis -> TroponinElevation;
  }

  /* ───────────────────────── 7. Pulmonary/Dermatologic/Neurologic ──────────── */
  subgraph cluster_organ2 {
    label="7. Pulmonary, Dermatologic & Neurologic Involvement";
    style="filled,rounded"; color="#5c6370"; fillcolor="#fff8e1"; fontsize=12;
    PulmonaryInfiltrates [label="Transient pulmonary\ninfiltrates"];
    PleuralEffusion      [label="Pleural effusion"];
    PulmonaryFibrosisHES [label="Chronic pulmonary\nfibrosis"];
    CoughDyspnea         [label="Cough / dyspnea"];
    UrticariaAngioedema  [label="Urticaria /\nangioedema"];
    PruritusHES          [label="Pruritus"];
    EosinophilicDermatosis[label="Eosinophilic dermatosis /\nnodules"];
    PeripheralNeuropathyHES[label="Peripheral (mononeuritis\nmultiplex) neuropathy"];
    CNSThromboembolism   [label="CNS embolic\nstroke/TIA"];
    Encephalopathy_HES   [label="Eosinophilic\nencephalopathy"];
    TissueEosinophilBurden -> PulmonaryInfiltrates -> PleuralEffusion;
    PulmonaryInfiltrates -> PulmonaryFibrosisHES [style=dashed, label="chronic\nunresolved"];
    PulmonaryFibrosisHES -> CoughDyspnea;
    PleuralEffusion -> CoughDyspnea;
    TissueEosinophilBurden -> UrticariaAngioedema;
    MBP_Release -> PruritusHES;
    TissueEosinophilBurden -> EosinophilicDermatosis;
    EDN_Release -> PeripheralNeuropathyHES;
    CardiacThromboembolism -> CNSThromboembolism;
    TissueFactorRelease -> CNSThromboembolism [style=dashed];
    CNSThromboembolism -> Encephalopathy_HES;
  }

  /* ───────────────────────── 8. GI/Hepatosplenic & Thrombotic ──────────────── */
  subgraph cluster_organ3 {
    label="8. GI/Hepatosplenic Involvement & Hypercoagulable State";
    style="filled,rounded"; color="#5c6370"; fillcolor="#f1f8e9"; fontsize=12;
    EosinophilicGastroenteritisHES[label="Eosinophilic\ngastroenteritis"];
    AbdominalPainDiarrhea[label="Abdominal pain /\ndiarrhea / malabsorption"];
    Hepatosplenomegaly   [label="Hepatosplenomegaly"];
    LiverInfiltration    [label="Hepatic eosinophilic\ninfiltration / LFT elevation"];
    PlateletActivation   [label="Platelet activation\n(eosinophil-platelet crosstalk)"];
    HypercoagulableState [label="Systemic hypercoagulable\nstate"];
    VenousThrombosisHES  [label="Venous thromboembolism\nrisk"];
    TissueEosinophilBurden -> EosinophilicGastroenteritisHES -> AbdominalPainDiarrhea;
    TissueEosinophilBurden -> Hepatosplenomegaly;
    TissueEosinophilBurden -> LiverInfiltration;
    TissueFactorRelease -> PlateletActivation -> HypercoagulableState;
    HypercoagulableState -> VenousThrombosisHES;
    HypercoagulableState -> CardiacThromboembolism [style=dashed];
  }

  /* ───────────────────────── 9. Drug PK/PD — Imatinib ───────────────────────── */
  subgraph cluster_imatinib {
    label="9. Drug PK/PD — Imatinib (Tyrosine Kinase Inhibitor)";
    style="filled,rounded"; color="#5c6370"; fillcolor="#e8f0ff"; fontsize=12;
    ImatinibOralDose     [label="Imatinib oral dose\n(100-400 mg QD)"];
    ImatinibAbsorption   [label="GI absorption\n(F~0.98, CYP3A4 metab.)"];
    ImatinibPlasmaConc   [label="Imatinib plasma\nconcentration"];
    ImatinibATPCompetitive[label="ATP-competitive binding\nto PDGFRA/B kinase domain"];
    ImatinibKinaseInhibition[label="Inhibition of\nFIP1L1-PDGFRA/PDGFRB TK activity"];
    ImatinibHematResponse[label="Complete hematologic\nresponse (AEC normalization)"];
    ImatinibMolResponse  [label="Molecular remission\n(FIP1L1-PDGFRA transcript↓)"];
    ImatinibOralDose -> ImatinibAbsorption -> ImatinibPlasmaConc;
    ImatinibPlasmaConc -> ImatinibATPCompetitive;
    ImatinibATPCompetitive -> ImatinibKinaseInhibition;
    ImatinibKinaseInhibition -> FIP1L1PDGFRA_Kinase [arrowhead=tee, color="#c0392b", label="⊣ constitutive\nactivity"];
    ImatinibKinaseInhibition -> PDGFRB_Kinase [arrowhead=tee, color="#c0392b"];
    ImatinibKinaseInhibition -> ImatinibHematResponse;
    ImatinibKinaseInhibition -> ImatinibMolResponse;
    T674I_ResistanceMut -> ImatinibATPCompetitive [arrowhead=tee, color="#c0392b", label="⊣ binding\n(steric clash)"];
  }

  /* ───────────────────────── 10. Drug PK/PD — Corticosteroids ──────────────── */
  subgraph cluster_steroid {
    label="10. Drug PK/PD — Corticosteroids";
    style="filled,rounded"; color="#5c6370"; fillcolor="#fff3e0"; fontsize=12;
    PrednisoneOralDose   [label="Prednisone/prednisolone\noral dose (0.5-1 mg/kg/d)"];
    PrednisoneAbsorption [label="GI absorption &\nhepatic prednisone→prednisolone"];
    PrednisolonePlasmaConc[label="Prednisolone plasma\nconcentration"];
    GlucocorticoidReceptorHES[label="Glucocorticoid receptor\nbinding (cytosolic → nuclear)"];
    NFkB_Inhibition_HES  [label="NF-κB / AP-1\ntranscriptional inhibition"];
    EosinApoptosisInduction[label="Eosinophil apoptosis\ninduction (Bcl-2↓)"];
    IL5_Transcription_Suppress[label="IL-5 gene transcription\nsuppression (T cells)"];
    SteroidTaperRelapse  [label="Steroid-taper relapse\n(dose-dependent recurrence)"];
    SteroidRefractory    [label="Steroid-refractory /\ndependent HES"];
    PrednisoneOralDose -> PrednisoneAbsorption -> PrednisolonePlasmaConc;
    PrednisolonePlasmaConc -> GlucocorticoidReceptorHES -> NFkB_Inhibition_HES;
    NFkB_Inhibition_HES -> EosinApoptosisInduction;
    NFkB_Inhibition_HES -> IL5_Transcription_Suppress;
    IL5_Transcription_Suppress -> IL5_Cytokine [arrowhead=tee, color="#c0392b"];
    EosinApoptosisInduction -> CirculatingEosinophil [arrowhead=tee, color="#c0392b", label="⊣ survival"];
    PrednisolonePlasmaConc -> SteroidTaperRelapse [style=dashed];
    SteroidTaperRelapse -> SteroidRefractory [style=dashed];
  }

  /* ───────────────────────── 11. Drug PK/PD — Anti-IL-5 Axis Biologics ─────── */
  subgraph cluster_antiIL5 {
    label="11. Drug PK/PD — Anti-IL-5 Axis Biologics";
    style="filled,rounded"; color="#5c6370"; fillcolor="#e0f7fa"; fontsize=12;
    MepolizumabSCDose    [label="Mepolizumab SC dose\n(300 mg Q4W)"];
    MepolizumabAbsorption[label="SC absorption\n(F~0.80, slow lymphatic)"];
    MepolizumabPlasmaConc[label="Mepolizumab plasma\nconcentration"];
    MepolizumabIL5Binding[label="Free IL-5 neutralization\n(high-affinity binding)"];
    BenralizumabSCDose   [label="Benralizumab SC dose\n(30 mg Q4-8W)"];
    BenralizumabAbsorption[label="SC absorption\n(F~0.58)"];
    BenralizumabPlasmaConc[label="Benralizumab plasma\nconcentration"];
    BenralizumabReceptorBlock[label="IL-5Rα blockade\n(competitive)"];
    BenralizumabADCC     [label="Afucosylated Fc →\nNK-cell ADCC eosinophil depletion"];
    MepolizumabSCDose -> MepolizumabAbsorption -> MepolizumabPlasmaConc;
    MepolizumabPlasmaConc -> MepolizumabIL5Binding;
    MepolizumabIL5Binding -> IL5_Cytokine [arrowhead=tee, color="#c0392b", label="⊣ free IL-5"];
    BenralizumabSCDose -> BenralizumabAbsorption -> BenralizumabPlasmaConc;
    BenralizumabPlasmaConc -> BenralizumabReceptorBlock;
    BenralizumabReceptorBlock -> IL5R_alpha [arrowhead=tee, color="#c0392b"];
    BenralizumabPlasmaConc -> BenralizumabADCC;
    BenralizumabADCC -> CirculatingEosinophil [arrowhead=tee, color="#c0392b", label="⊣ direct\ndepletion (~100%)"];
  }

  /* ───────────────────────── 12. Drug PK/PD — Cytoreductive/JAK/IFN ────────── */
  subgraph cluster_cytoreductive {
    label="12. Drug PK/PD — Hydroxyurea / Ruxolitinib / IFN-α / Alemtuzumab";
    style="filled,rounded"; color="#5c6370"; fillcolor="#f3e5f5"; fontsize=12;
    HydroxyureaOralDose  [label="Hydroxyurea oral dose\n(500-1500 mg/d)"];
    HydroxyureaRibonucleotideRed[label="Ribonucleotide reductase\ninhibition"];
    HydroxyureaCytoreduction[label="Nonselective myeloid\ncytoreduction"];
    RuxolitinibOralDose  [label="Ruxolitinib oral dose\n(10-25 mg BID)"];
    JAK1JAK2Inhibition   [label="JAK1/JAK2\ninhibition"];
    IFNalphaSCDose       [label="Interferon-α\nSC dose"];
    IFNalphaImmunomodulation[label="Immunomodulation /\nclonal T-cell suppression"];
    AlemtuzumabIVDose    [label="Alemtuzumab\n(anti-CD52) IV dose"];
    LymphocyteDepletion  [label="Broad lymphocyte\ndepletion"];
    HydroxyureaOralDose -> HydroxyureaRibonucleotideRed -> HydroxyureaCytoreduction;
    HydroxyureaCytoreduction -> MarrowRelease [arrowhead=tee, color="#c0392b"];
    RuxolitinibOralDose -> JAK1JAK2Inhibition;
    JAK1JAK2Inhibition -> JAK2_STAT5_Marrow [arrowhead=tee, color="#c0392b"];
    JAK1JAK2Inhibition -> JAK2_Rearrange [arrowhead=tee, color="#c0392b"];
    IFNalphaSCDose -> IFNalphaImmunomodulation;
    IFNalphaImmunomodulation -> ClonalTcellPop [arrowhead=tee, color="#c0392b"];
    AlemtuzumabIVDose -> LymphocyteDepletion;
    LymphocyteDepletion -> ClonalTcellPop [arrowhead=tee, color="#c0392b"];
    LymphocyteDepletion -> IL5_LHES_Source [arrowhead=tee, color="#c0392b"];
  }

  /* ───────────────────────── 13. Clinical Endpoints & Biomarkers ───────────── */
  subgraph cluster_endpoints {
    label="13. Clinical Endpoints, Biomarkers & Monitoring";
    style="filled,rounded"; color="#5c6370"; fillcolor="#eceff1"; fontsize=12;
    AbsoluteEosinCount   [label="Absolute eosinophil\ncount (AEC, /µL)"];
    SerumECP_Biomarker   [label="Serum ECP\nbiomarker"];
    SerumIL5_Biomarker   [label="Serum IL-5\nbiomarker"];
    SerumTryptase_Biomarker[label="Serum tryptase\n(overlap w/ SM screen)"];
    HESSymptomScore      [label="HES clinical\nsymptom/flare score"];
    HESFlareRate         [label="Annualized flare\n/relapse rate"];
    OrganDamageComposite [label="Composite organ-damage\nscore (cardiac/pulm/derm/neuro)"];
    QualityOfLifeHES     [label="Health-related\nquality of life"];
    OverallSurvivalHES   [label="Overall survival /\nleukemic transformation-free survival"];
    CirculatingEosinophil -> AbsoluteEosinCount;
    ECP_Release -> SerumECP_Biomarker;
    IL5_Cytokine -> SerumIL5_Biomarker;
    MastCellCoExpansion -> SerumTryptase_Biomarker;
    AbsoluteEosinCount -> HESSymptomScore;
    OrganDamageComposite -> HESSymptomScore;
    HeartFailureSymptoms -> OrganDamageComposite;
    CoughDyspnea -> OrganDamageComposite;
    UrticariaAngioedema -> OrganDamageComposite;
    PeripheralNeuropathyHES -> OrganDamageComposite;
    AbdominalPainDiarrhea -> OrganDamageComposite;
    HESSymptomScore -> HESFlareRate;
    HESSymptomScore -> QualityOfLifeHES;
    OrganDamageComposite -> OverallSurvivalHES;
    LymphomaTransform -> OverallSurvivalHES;
    ImatinibHematResponse -> AbsoluteEosinCount [style=dashed, color="#2e7d32"];
    ImatinibHematResponse -> OverallSurvivalHES [style=dashed, color="#2e7d32", label="near-normal\nlife expectancy"];
  }
}
