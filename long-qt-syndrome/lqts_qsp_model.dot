digraph LQTS_QSP {
  graph [rankdir=LR, fontname="Helvetica", fontsize=11, labelloc=t,
         label="Congenital Long QT Syndrome (LQTS, 선천성 QT 연장 증후군) — Integrated QSP Mechanistic Map\nKCNQ1/IKs (LQT1) · KCNH2-hERG/IKr (LQT2) · SCN5A/late-INa (LQT3) · Rarer subtypes & Acquired/Drug-induced LQTS (CiPA)\nAP Prolongation -> EAD -> Dispersion of Repolarization -> Torsades de Pointes -> VF -> Sudden Cardiac Death\nBeta-blockers (propranolol/nadolol) · Mexiletine (late-INa) · K+/Spironolactone · LCSD · ICD · QT-prolonging drug challenge",
         splines=spline, overlap=false, nodesep=0.28, ranksep=0.60,
         bgcolor="#fbfbfd"];
  node  [shape=box, style="rounded,filled", fontname="Helvetica", fontsize=10,
         fillcolor="#ffffff", color="#7d8590"];
  edge  [fontname="Helvetica", fontsize=9, color="#6e7681", arrowsize=0.7];

  /* ───────────────────────── 1. Genetics — Channelopathy Subtypes ───────── */
  subgraph cluster_genetics {
    label="1. Genetics — Ion-Channel Genotypes";
    style="filled,rounded"; color="#5c6370"; fillcolor="#f3f0ff"; fontsize=12;
    KCNQ1_gene    [label="KCNQ1 gene\n(11p15.5)"];
    KCNQ1_LOF     [label="KCNQ1 loss-of-\nfunction variant\n(LQT1, ~35-40%)"];
    KCNE1_gene    [label="KCNE1 (minK)\nbeta-subunit"];
    KCNH2_gene    [label="KCNH2 (hERG)\ngene (7q36.1)"];
    KCNH2_LOF     [label="KCNH2 loss-of-\nfunction variant\n(LQT2, ~25-30%)"];
    KCNE2_gene    [label="KCNE2 (MiRP1)\nbeta-subunit"];
    SCN5A_gene    [label="SCN5A gene\n(3p22.2)"];
    SCN5A_GOF     [label="SCN5A gain-of-\nfunction variant\n(LQT3, ~5-10%)"];
    RareGenes     [label="Rarer subtypes:\nANK2(LQT4), CACNA1C\n(LQT8/Timothy), CALM1-3\n(LQT14-16), TRDN, AKAP9,\nAll grouped LQT4-16"];
    DeNovoInherit [label="Autosomal dominant\n(Romano-Ward) vs\nrecessive (Jervell-\nLange-Nielsen + deafness)"];
    GeneticTesting[label="Genetic testing /\ncascade family screening"];
    VUS_issue     [label="Variant of uncertain\nsignificance (VUS)"];
    KCNQ1_gene -> KCNQ1_LOF;
    KCNE1_gene -> KCNQ1_LOF [style=dashed, label="beta-subunit\nmodulation"];
    KCNH2_gene -> KCNH2_LOF;
    KCNE2_gene -> KCNH2_LOF [style=dashed, label="beta-subunit\nmodulation"];
    SCN5A_gene -> SCN5A_GOF;
    DeNovoInherit -> KCNQ1_LOF [style=dashed];
    DeNovoInherit -> KCNH2_LOF [style=dashed];
    DeNovoInherit -> SCN5A_GOF [style=dashed];
    GeneticTesting -> KCNQ1_LOF [style=dashed, label="confirms"];
    GeneticTesting -> KCNH2_LOF [style=dashed];
    GeneticTesting -> SCN5A_GOF [style=dashed];
    GeneticTesting -> VUS_issue [style=dashed];
  }

  /* ───────────────────────── 2. Ion Channel Dysfunction ───────────────────── */
  subgraph cluster_channel {
    label="2. Ion-Channel Dysfunction (Molecular)";
    style="filled,rounded"; color="#5c6370"; fillcolor="#e6f7ff"; fontsize=12;
    KCNQ1_Traffick [label="KCNQ1 channel\nmisfolding/trafficking\ndefect or gating defect"];
    IKs_Reduced    [label="IKs current density\nreduced (slow delayed\nrectifier K+)"];
    KCNH2_Traffick [label="hERG channel\ntrafficking defect\n(most common) or\npore/gating defect"];
    IKr_Reduced    [label="IKr current density\nreduced (rapid delayed\nrectifier K+)"];
    SCN5A_Inact    [label="Nav1.5 inactivation\ngate defect (incomplete\ninactivation)"];
    LateINa_Increase[label="Persistent/late INa\nincreased (sustained\ninward Na+ current)"];
    RareChannel_Effect[label="ANK2: trafficking of\nmultiple channels;\nCACNA1C: ICaL GOF;\nCALM: Ca2+-dependent\ninactivation of ICaL/\nRyR2 impaired"];
    JLN_Biallelic  [label="Biallelic KCNQ1/KCNE1\n(Jervell-Lange-Nielsen)\n-> severe IKs loss +\nsensorineural deafness"];
    KCNQ1_Traffick -> IKs_Reduced;
    KCNH2_Traffick -> IKr_Reduced;
    SCN5A_Inact -> LateINa_Increase;
    RareChannel_Effect -> IKs_Reduced [style=dashed];
    RareChannel_Effect -> IKr_Reduced [style=dashed];
    JLN_Biallelic -> IKs_Reduced [style=dashed, label="severe\nbiallelic"];
  }

  /* ───────────────────────── 3. Ventricular AP & Ionic Currents ──────────── */
  subgraph cluster_ap {
    label="3. Ventricular Action Potential & Ionic Currents";
    style="filled,rounded"; color="#5c6370"; fillcolor="#fff4e6"; fontsize=12;
    Phase0_INa    [label="Phase 0 — fast\ndepolarization (peak INa,\nNav1.5)"];
    Phase1_Ito    [label="Phase 1 — early\nrepolarization notch\n(Ito, transient outward)"];
    Phase2_Plateau[label="Phase 2 — plateau\n(ICaL inward vs IKs/IKr\noutward balance)"];
    ICaL_current  [label="ICaL (L-type Ca2+\ncurrent, Cav1.2)"];
    Phase3_Repol  [label="Phase 3 — rapid\nrepolarization (IKr, IKs,\nIK1 dominant)"];
    Phase4_Rest   [label="Phase 4 — resting\nmembrane potential\n(IK1)"];
    IK1_current   [label="IK1 (inward\nrectifier K+)"];
    INaK_pump     [label="INaK (Na+/K+-ATPase\npump current)"];
    INaCa_exch    [label="INaCa (Na+/Ca2+\nexchanger current)"];
    APD_prolong   [label="Action potential\nduration (APD)\nprolongation"];
    RepolReserve  [label="Repolarization\nreserve (net outward\ncurrent margin)"];
    IKs_Reduced -> Phase2_Plateau [label="less outward\ncurrent"];
    IKs_Reduced -> Phase3_Repol [label="delayed"];
    IKr_Reduced -> Phase3_Repol [label="delayed,\ndominant effect"];
    LateINa_Increase -> Phase2_Plateau [label="sustained\ninward current"];
    LateINa_Increase -> Phase3_Repol [label="delayed"];
    Phase0_INa -> Phase1_Ito;
    Phase1_Ito -> Phase2_Plateau;
    ICaL_current -> Phase2_Plateau;
    Phase2_Plateau -> Phase3_Repol;
    Phase3_Repol -> Phase4_Rest;
    IK1_current -> Phase4_Rest;
    IK1_current -> Phase3_Repol [style=dashed, label="terminal\nrepolarization"];
    INaK_pump -> Phase4_Rest [style=dashed];
    INaCa_exch -> Phase2_Plateau [style=dashed, label="electrogenic\n3Na:1Ca"];
    IKs_Reduced -> RepolReserve [label="reduces\nreserve", arrowhead=tee, color="#b02a37"];
    IKr_Reduced -> RepolReserve [label="reduces\nreserve", arrowhead=tee, color="#b02a37"];
    LateINa_Increase -> RepolReserve [label="reduces\nreserve", arrowhead=tee, color="#b02a37"];
    RepolReserve -> APD_prolong [arrowhead=tee, color="#b02a37", label="low reserve\n-> prolongation"];
    Phase3_Repol -> APD_prolong;
  }

  /* ───────────────────────── 4. Transmural Heterogeneity ─────────────────── */
  subgraph cluster_transmural {
    label="4. Transmural Heterogeneity & Dispersion";
    style="filled,rounded"; color="#5c6370"; fillcolor="#e6ffe9"; fontsize=12;
    Epicardium    [label="Epicardial cell\n(short APD, prominent\nIto notch)"];
    Mcell         [label="M-cell (mid-\nmyocardial, longest\nAPD, low IKs)"];
    Endocardium   [label="Endocardial cell\n(intermediate APD)"];
    Purkinje      [label="Purkinje fiber\n(longest APD at rest,\nbradycardia-dependent)"];
    TransmuralGrad[label="Transmural APD\ngradient"];
    TDR           [label="Transmural dispersion\nof repolarization (TDR)"];
    QTinterval    [label="QT interval\n(surface ECG surrogate\nof global APD)"];
    TpeakTend     [label="Tpeak-Tend interval\n(TDR surrogate)"];
    APD_prolong -> Epicardium [style=dashed];
    APD_prolong -> Mcell [style=dashed, label="M-cell most\nIKs-dependent"];
    APD_prolong -> Endocardium [style=dashed];
    APD_prolong -> Purkinje [style=dashed];
    Mcell -> TransmuralGrad;
    Epicardium -> TransmuralGrad;
    Endocardium -> TransmuralGrad;
    TransmuralGrad -> TDR;
    TDR -> TpeakTend;
    APD_prolong -> QTinterval;
  }

  /* ───────────────────────── 5. EAD / Substrate & Trigger Mechanism ──────── */
  subgraph cluster_ead {
    label="5. EAD / Arrhythmogenic Substrate & Trigger";
    style="filled,rounded"; color="#5c6370"; fillcolor="#ffe6ec"; fontsize=12;
    ICaL_Reactivation[label="ICaL window-current\nreactivation during\nprolonged phase 2/3"];
    EAD           [label="Early after-\ndepolarization (EAD)"];
    DAD           [label="Delayed after-\ndepolarization (DAD,\nCa2+-overload related)"];
    CaOverload    [label="Intracellular Ca2+\noverload (CaMKII\nactivation)"];
    CaMKII_Hyperact[label="CaMKII\nhyperactivation"];
    TriggeredActivity[label="Triggered activity\n(focal ectopic beat,\n'R-on-T')"];
    SourceSinkMismatch[label="Source-sink mismatch\n(EAD propagation\nfailure/success)"];
    ReentryCircuit[label="Functional reentry\n(phase-2 reentry via\nTDR gradient)"];
    Bigeminy      [label="Short-long-short\nsequence / pause-\ndependent bigeminy"];
    APD_prolong -> ICaL_Reactivation [label="prolonged\nplateau"];
    ICaL_Reactivation -> EAD;
    CaMKII_Hyperact -> CaOverload [style=dashed];
    CaOverload -> DAD;
    CaMKII_Hyperact -> ICaL_Reactivation [style=dashed, label="phosphorylates\nCav1.2"];
    EAD -> TriggeredActivity;
    DAD -> TriggeredActivity [style=dashed];
    TriggeredActivity -> SourceSinkMismatch;
    SourceSinkMismatch -> ReentryCircuit [label="successful\npropagation"];
    TDR -> ReentryCircuit [label="provides\nsubstrate"];
    Bigeminy -> TriggeredActivity [style=dashed, label="pause\ndependent (LQT2/3)"];
  }

  /* ───────────────────────── 6. Autonomic Nervous System Trigger ─────────── */
  subgraph cluster_ans {
    label="6. Autonomic Nervous System Triggers";
    style="filled,rounded"; color="#5c6370"; fillcolor="#fff9e6"; fontsize=12;
    SympatheticSurge[label="Sympathetic surge\n(exercise/emotion/\nstartle)"];
    BetaAdrenergic[label="Beta1-adrenergic\nreceptor activation"];
    PKA_activation[label="PKA-mediated\nphosphorylation\n(RyR2, PLB, Cav1.2)"];
    ICaL_Augment  [label="ICaL augmentation\n(sympathetic)"];
    IKs_Augment_Normal[label="IKs augmentation\n(normal 'safety valve'\nvia PKA-phospho-KCNQ1)"];
    IKs_Augment_Failed[label="IKs augmentation\nFAILS in LQT1\n(mutant channel can't\nrespond to PKA)"];
    ExerciseSwim  [label="Exercise / swimming\ntrigger (classic LQT1)"];
    AuditoryEmotion[label="Auditory stimulus /\nalarm clock / emotion\ntrigger (classic LQT2)"];
    Postpartum    [label="Postpartum period\n(LQT2 vulnerable\nwindow)"];
    RestSleepBrady[label="Rest / sleep /\nbradycardia trigger\n(classic LQT3)"];
    VagalTone     [label="Vagal tone increase\n(sleep, bradycardia)"];
    QTc_RateAdapt [label="QT-RR rate adaptation\n(inadequate shortening\nwith tachycardia)"];
    ExerciseSwim -> SympatheticSurge;
    AuditoryEmotion -> SympatheticSurge;
    SympatheticSurge -> BetaAdrenergic;
    BetaAdrenergic -> PKA_activation;
    PKA_activation -> ICaL_Augment;
    PKA_activation -> IKs_Augment_Normal;
    IKs_Reduced -> IKs_Augment_Failed [style=dashed, label="mutant KCNQ1\nunresponsive"];
    IKs_Augment_Failed -> RepolReserve [arrowhead=tee, color="#b02a37", label="no compensatory\nshortening"];
    ICaL_Augment -> ICaL_Reactivation [style=dashed, label="more EAD\nsubstrate"];
    Postpartum -> AuditoryEmotion [style=dashed, label="adrenergic\nvulnerability"];
    RestSleepBrady -> VagalTone;
    VagalTone -> QTc_RateAdapt [style=dashed];
    QTc_RateAdapt -> APD_prolong [style=dashed, label="bradycardia\nunmasks LQT3"];
    LateINa_Increase -> RestSleepBrady [style=dashed, label="worse at\nslow rate"];
  }

  /* ───────────────────────── 7. TdP -> VF -> SCD Cascade ─────────────────── */
  subgraph cluster_cascade {
    label="7. TdP -> VF -> SCD Cascade";
    style="filled,rounded"; color="#5c6370"; fillcolor="#f0f5ff"; fontsize=12;
    TdP_onset     [label="Torsades de Pointes\n(TdP) onset", shape=diamond, fillcolor="#ffd6db"];
    TdP_SelfTerm  [label="TdP self-terminates\n(syncope, no death)"];
    TdP_Sustained [label="TdP degenerates to\nsustained polymorphic VT"];
    VF            [label="Ventricular\nfibrillation (VF)", shape=diamond, fillcolor="#ff9aa8"];
    SCD           [label="Sudden cardiac\ndeath (SCD)", shape=diamond, fillcolor="#ff5c6c", fontcolor=white];
    Syncope       [label="Syncope /\naborted cardiac arrest"];
    ReentryCircuit -> TdP_onset;
    TDR -> TdP_onset [label="maintains\narrhythmia"];
    TdP_onset -> TdP_SelfTerm [label="~most\nepisodes"];
    TdP_onset -> TdP_Sustained [style=dashed, label="if not\nself-limited"];
    TdP_SelfTerm -> Syncope;
    TdP_Sustained -> VF;
    VF -> SCD [label="if unresuscitated"];
  }

  /* ───────────────────────── 8. CiPA / hERG Drug-Block Pharmacology ──────── */
  subgraph cluster_cipa {
    label="8. CiPA / hERG Drug-Block Pharmacology (Acquired LQTS)";
    style="filled,rounded"; color="#5c6370"; fillcolor="#f5f0ff"; fontsize=12;
    QTDrugX_Gut   [label="QT-prolonging\nchallenge drug X\n(GUT, e.g. fluoroquinolone/\nmacrolide-like generic)"];
    QTDrugX_Plasma[label="Drug X plasma\nconcentration"];
    hERG_Block    [label="hERG (IKr) channel\nblock (concentration-\ndependent, IC50/Hill)"];
    ICaL_Block_X  [label="Concomitant ICaL\nblock (multichannel,\nreduces net risk)"];
    LateINa_Block_X[label="Concomitant late-INa\nblock (multichannel,\nreduces net risk)"];
    qNet_Metric   [label="qNet / TdP-risk\nmetric (net charge:\nhERG vs ICaL/late-INa)"];
    CiPA_Risk_Cat [label="CiPA torsadogenic\nrisk category\n(high/intermediate/low)"];
    hERG_AssayIC50[label="Nonclinical hERG\npatch-clamp IC50\n(safety margin)"];
    DrugInduced_LQTS[label="Acquired/drug-induced\nLQTS (dose/level\ndependent)"];
    HypoK_Synergy [label="Hypokalemia synergy\nwith hERG block"];
    QTDrugX_Gut -> QTDrugX_Plasma;
    QTDrugX_Plasma -> hERG_Block [label="Hill/IC50\nmodel"];
    QTDrugX_Plasma -> ICaL_Block_X [style=dashed];
    QTDrugX_Plasma -> LateINa_Block_X [style=dashed];
    hERG_Block -> IKr_Reduced [label="pharmacologic\nphenocopy of LQT2", color="#b02a37"];
    hERG_Block -> qNet_Metric;
    ICaL_Block_X -> qNet_Metric [style=dashed, label="offsets risk"];
    LateINa_Block_X -> qNet_Metric [style=dashed, label="offsets risk"];
    qNet_Metric -> CiPA_Risk_Cat;
    hERG_AssayIC50 -> CiPA_Risk_Cat [style=dashed];
    DrugInduced_LQTS -> hERG_Block [style=dashed];
    HypoK_Synergy -> hERG_Block [label="low K+ ->\nmore block"];
    hERG_Block -> RepolReserve [arrowhead=tee, color="#b02a37", label="acquired-on-\ncongenital"];
  }

  /* ───────────────────────── 9. Beta-blocker PK/PD ────────────────────────── */
  subgraph cluster_bb {
    label="9. Drug PK/PD — Beta-blockers (Propranolol / Nadolol)";
    style="filled,rounded"; color="#5c6370"; fillcolor="#e6f0ff"; fontsize=12;
    Propranolol_Gut [label="Oral propranolol\n(GUT)"];
    Propranolol_Plasma[label="Propranolol\nplasma (nonselective,\nhigh first-pass)"];
    Propranolol_INaBlock[label="Propranolol mild\nuse-dependent INa\nblock (class I-like)"];
    Nadolol_Gut   [label="Oral nadolol\n(GUT)"];
    Nadolol_Plasma[label="Nadolol plasma\n(hydrophilic, renal\nclearance, long t1/2)"];
    Beta1_Blockade[label="Beta1-receptor\nblockade"];
    SympatheticBlunt[label="Blunted sympathetic-\ntriggered ICaL/IKs\nresponse"];
    HR_Reduction_BB[label="Heart rate\nreduction (bradycardia\ncaveat in LQT3)"];
    LQT1_BB_Efficacy[label="High efficacy in LQT1\n(exercise-triggered,\nIKs-dependent)"];
    LQT2_BB_Efficacy[label="Moderate efficacy\nin LQT2"];
    LQT3_BB_Limited[label="Limited/mixed efficacy\nin LQT3 (bradycardia\nmay worsen late-INa)"];
    NadololPropranolol_Compare[label="Nadolol non-inferior/\nsuperior adherence\n(once-daily, less CNS)"];
    Propranolol_Gut -> Propranolol_Plasma;
    Propranolol_Plasma -> Beta1_Blockade;
    Propranolol_Plasma -> Propranolol_INaBlock [style=dashed];
    Propranolol_INaBlock -> LateINa_Increase [style=dashed, arrowhead=tee, label="minor late-INa\nattenuation"];
    Nadolol_Gut -> Nadolol_Plasma;
    Nadolol_Plasma -> Beta1_Blockade;
    Beta1_Blockade -> SympatheticBlunt;
    SympatheticBlunt -> ICaL_Augment [arrowhead=tee, color="#0a7a3d"];
    SympatheticBlunt -> EAD [arrowhead=tee, color="#0a7a3d", label="suppresses\ntrigger"];
    Beta1_Blockade -> HR_Reduction_BB;
    HR_Reduction_BB -> RestSleepBrady [style=dashed, label="caution\nin LQT3"];
    Beta1_Blockade -> LQT1_BB_Efficacy [style=dashed];
    Beta1_Blockade -> LQT2_BB_Efficacy [style=dashed];
    Beta1_Blockade -> LQT3_BB_Limited [style=dashed];
    Nadolol_Plasma -> NadololPropranolol_Compare [style=dashed];
  }

  /* ───────────────────────── 10. Mexiletine PK/PD ─────────────────────────── */
  subgraph cluster_mex {
    label="10. Drug PK/PD — Mexiletine (Late-INa Blocker, LQT3-targeted)";
    style="filled,rounded"; color="#5c6370"; fillcolor="#ffe6f0"; fontsize=12;
    Mexiletine_Gut [label="Oral mexiletine\n(GUT)"];
    Mexiletine_Plasma[label="Mexiletine\nplasma"];
    CYP2D6_Mex    [label="CYP2D6 hepatic\nmetabolism (poor\nmetabolizer risk)"];
    Mexiletine_LateINaBlock[label="Preferential late-INa\nblock (use-dependent\nNav1.5 blocker)"];
    LQT3_QTcShorten[label="LQT3-specific QTc\nshortening (genotype-\ntargeted therapy)"];
    Mexiletine_ProarrhythmiaRisk[label="Mexiletine\nproarrhythmia risk\n(low at therapeutic dose)"];
    Mexiletine_Gut -> Mexiletine_Plasma;
    Mexiletine_Plasma -> CYP2D6_Mex [style=dashed];
    CYP2D6_Mex -> Mexiletine_Plasma [style=dashed, label="elimination"];
    Mexiletine_Plasma -> Mexiletine_LateINaBlock;
    Mexiletine_LateINaBlock -> LateINa_Increase [arrowhead=tee, color="#0a7a3d", label="genotype-\ntargeted block"];
    Mexiletine_LateINaBlock -> LQT3_QTcShorten;
    LQT3_QTcShorten -> RepolReserve [color="#0a7a3d", label="restores\nreserve"];
    Mexiletine_Plasma -> Mexiletine_ProarrhythmiaRisk [style=dashed];
  }

  /* ───────────────────────── 11. Potassium / Electrolyte Cluster ─────────── */
  subgraph cluster_k {
    label="11. Potassium / Electrolyte Modulation";
    style="filled,rounded"; color="#5c6370"; fillcolor="#fff4d6"; fontsize=12;
    OralK_Gut     [label="Oral potassium\nchloride (GUT)"];
    OralK_Plasma  [label="Serum K+\nconcentration"];
    Spironolactone_Gut[label="Spironolactone\n(GUT, K+-sparing\ndiuretic)"];
    Spironolactone_Plasma[label="Spironolactone/\ncanrenone plasma"];
    Aldosterone_Antag[label="Mineralocorticoid\nreceptor antagonism"];
    RenalK_Retention[label="Renal K+ retention"];
    IKr_Conductance_K[label="IKr single-channel\nconductance increases\nwith extracellular K+"];
    HypoK_Risk    [label="Hypokalemia risk\n(diuretics, vomiting,\nlow intake) — worsens QTc"];
    OralK_Gut -> OralK_Plasma;
    Spironolactone_Gut -> Spironolactone_Plasma;
    Spironolactone_Plasma -> Aldosterone_Antag;
    Aldosterone_Antag -> RenalK_Retention;
    RenalK_Retention -> OralK_Plasma [style=dashed, label="raises\nserum K+"];
    OralK_Plasma -> IKr_Conductance_K;
    IKr_Conductance_K -> IKr_Reduced [arrowhead=tee, color="#0a7a3d", label="paradoxical K+\nconductance effect\n(esp. LQT2)"];
    HypoK_Risk -> IKr_Conductance_K [arrowhead=tee, color="#b02a37"];
    HypoK_Risk -> HypoK_Synergy [style=dashed];
  }

  /* ───────────────────────── 12. Device / Procedural Interventions ───────── */
  subgraph cluster_device {
    label="12. Device & Procedural Interventions (LCSD / ICD)";
    style="filled,rounded"; color="#5c6370"; fillcolor="#e6fff2"; fontsize=12;
    LCSD_Procedure[label="Left cardiac\nsympathetic denervation\n(LCSD, T1-T4 ganglia)"];
    LCSD_SympReduction[label="Reduces cardiac\nsympathetic norepinephrine\nrelease (afferent+efferent)"];
    ICD_Implant   [label="ICD implantation\n(secondary/high-risk\nprimary prevention)"];
    ICD_Detection [label="ICD arrhythmia\ndetection algorithm"];
    ICD_ApprShock [label="Appropriate shock\n(terminates VF/TdP)"];
    ICD_InapprShock[label="Inappropriate shock\n(T-wave oversensing,\nlead issues, SVT)"];
    ICD_PsychMorbidity[label="Shock-related\npsychological morbidity\n(anxiety, PTSD)"];
    RescueSurvival[label="Rescue from cardiac\narrest -> survival"];
    LCSD_Procedure -> LCSD_SympReduction;
    LCSD_SympReduction -> SympatheticSurge [arrowhead=tee, color="#0a7a3d", label="reduces\ntrigger drive"];
    LCSD_SympReduction -> BetaAdrenergic [arrowhead=tee, color="#0a7a3d"];
    ICD_Implant -> ICD_Detection;
    ICD_Detection -> ICD_ApprShock [label="VF/TdP\ndetected"];
    ICD_Detection -> ICD_InapprShock [style=dashed, label="oversensing"];
    ICD_ApprShock -> RescueSurvival [color="#0a7a3d"];
    VF -> ICD_Detection [style=dashed, label="if device\npresent"];
    ICD_InapprShock -> ICD_PsychMorbidity [style=dashed];
  }

  /* ───────────────────────── 13. Clinical Diagnostics ─────────────────────── */
  subgraph cluster_dx {
    label="13. Clinical Diagnostics";
    style="filled,rounded"; color="#5c6370"; fillcolor="#f0fff5"; fontsize=12;
    SurfaceECG    [label="12-lead surface\nECG"];
    QTc_Bazett    [label="QTc (Bazett\ncorrection, QT/sqrt(RR))"];
    QTc_Fridericia[label="QTc (Fridericia\ncorrection, QT/RR^1/3)"];
    TWave_Morphology[label="T-wave morphology\nby genotype (broad-based\nLQT1, low-amplitude\nnotched LQT2, late-onset\npeaked LQT3)"];
    ExerciseStressTest[label="Exercise stress test\nQTc response (fails to\nshorten/paradoxical\nprolongation in LQT1)"];
    HolterMonitor [label="Ambulatory Holter\nmonitoring"];
    SchwartzScore [label="Schwartz risk\nscore (ECG + clinical\n+ family history)"];
    GeneticTestDx [label="Genetic panel /\ncascade testing"];
    EpinephrineChallenge[label="Epinephrine\nQT-stress challenge\n(unmasks LQT1)"];
    APD_prolong -> SurfaceECG [style=dashed];
    SurfaceECG -> QTc_Bazett;
    SurfaceECG -> QTc_Fridericia;
    SurfaceECG -> TWave_Morphology;
    ExerciseStressTest -> QTc_Bazett [style=dashed, label="dynamic\nresponse"];
    HolterMonitor -> TdP_onset [style=dashed, label="captures\nepisodes"];
    QTc_Bazett -> SchwartzScore;
    TWave_Morphology -> SchwartzScore;
    GeneticTestDx -> SchwartzScore [style=dashed];
    EpinephrineChallenge -> IKs_Augment_Failed [style=dashed, label="provokes"];
  }

  /* ───────────────────────── 14. Clinical Endpoints & Outcomes ───────────── */
  subgraph cluster_endpoints {
    label="14. Clinical Endpoints, Risk Stratification & Outcomes";
    style="filled,rounded"; color="#5c6370"; fillcolor="#fafafa"; fontsize=12;
    QTc_Endpoint  [label="QTc duration\n(ms, primary biomarker\nendpoint)", shape=ellipse, fillcolor="#dfe7ff"];
    TdP_Probability[label="TdP event probability\n/ annualized rate", shape=ellipse, fillcolor="#ffd6db"];
    CardiacEventRate[label="Cardiac event rate\n(syncope + aborted\narrest + SCD)"];
    SCD_Risk      [label="Sudden cardiac\ndeath risk (%/decade)", shape=ellipse, fillcolor="#ff9aa8"];
    RiskStratify  [label="Risk stratification\n(genotype + QTc + sex\n+ prior syncope)"];
    HighRiskFlag  [label="High-risk flag\n(QTc>500ms, LQT2 female,\nLQT3, prior arrest)"];
    GenotypePhenotype[label="Genotype-phenotype\ncorrelation (Priori 2004)"];
    TreatmentEfficacyComp[label="Treatment efficacy\ncomparison across\ngenotypes"];
    QoL_Endpoint  [label="Quality of life /\nactivity restriction\nburden"];
    RegistryData  [label="International LQTS\nRegistry longitudinal\noutcomes"];
    QTinterval -> QTc_Endpoint;
    TdP_onset -> TdP_Probability;
    TdP_Probability -> CardiacEventRate;
    Syncope -> CardiacEventRate;
    SCD -> SCD_Risk;
    CardiacEventRate -> RiskStratify;
    QTc_Endpoint -> RiskStratify;
    SchwartzScore -> RiskStratify;
    RiskStratify -> HighRiskFlag;
    HighRiskFlag -> ICD_Implant [style=dashed, label="triggers device\nconsideration"];
    GenotypePhenotype -> RiskStratify [style=dashed];
    LQT1_BB_Efficacy -> TreatmentEfficacyComp [style=dashed];
    LQT2_BB_Efficacy -> TreatmentEfficacyComp [style=dashed];
    LQT3_BB_Limited -> TreatmentEfficacyComp [style=dashed];
    RescueSurvival -> QoL_Endpoint [style=dashed];
    ICD_PsychMorbidity -> QoL_Endpoint [arrowhead=tee, color="#b02a37"];
    RegistryData -> GenotypePhenotype [style=dashed];
    RegistryData -> TreatmentEfficacyComp [style=dashed];
  }

  /* ───────────────────────── Cross-cluster genotype -> AP linkages ───────── */
  KCNQ1_LOF -> KCNQ1_Traffick;
  KCNH2_LOF -> KCNH2_Traffick;
  SCN5A_GOF -> SCN5A_Inact;
  QTc_Endpoint -> SchwartzScore [style=dashed];
  DrugInduced_LQTS -> CiPA_Risk_Cat [style=dashed];
  RareGenes -> RareChannel_Effect;
}
