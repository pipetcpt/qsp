digraph PAD_QSP {
  rankdir=LR;
  graph [fontname="Helvetica", fontsize=11, splines=ortho,
         label="Peripheral Arterial Disease (PAD): QSP Mechanistic Map\nDrug targets: Clopidogrel · Aspirin · Ticagrelor · Vorapaxar · Rivaroxaban · Cilostazol · Atorvastatin",
         labelloc=t, labeljust=c, fontsize=14];
  node [fontname="Helvetica", fontsize=10, style=filled, shape=box];
  edge [fontname="Helvetica", fontsize=8];

  // ========================
  // CLUSTER 1: Risk Factors
  // ========================
  subgraph cluster_risk {
    label="Risk Factors\n(Epidemiological)";
    color=darkred; fontcolor=darkred; style=rounded; bgcolor="#FFF0F0";
    node [fillcolor="#FFB6B6"];

    HTN         [label="Hypertension"];
    Smoking     [label="Cigarette\nSmoking"];
    DM_risk     [label="Diabetes\nMellitus"];
    Dyslip      [label="Dyslipidemia\n(LDL↑ / HDL↓)"];
    CKD_risk    [label="Chronic\nKidney Disease"];
    Age_risk    [label="Age > 50\nyrs"];
    Male_sex    [label="Male\nSex"];
    Homocyst    [label="Hyper-\nhomocysteinemia"];
    Obesity_r   [label="Obesity"];
    Sedentary   [label="Sedentary\nLifestyle"];
    Fam_hx      [label="Family\nHistory (CVD)"];
    Smk_oxidant [label="Tobacco\nOxidants / Acrolein"];
    Insulin_res [label="Insulin\nResistance"];
    InflamState [label="Chronic Low-grade\nInflammation"];
  }

  // ===================================
  // CLUSTER 2: Endothelial Dysfunction & Oxidative Stress
  // ===================================
  subgraph cluster_endo {
    label="Endothelial Dysfunction\n& Oxidative Stress";
    color=darkorange; fontcolor=darkorange; style=rounded; bgcolor="#FFF8F0";
    node [fillcolor="#FFD9A0"];

    eNOS_unc    [label="eNOS\nUncoupling"];
    NO_down     [label="NO↓\nBioavailability"];
    NADPH_ox    [label="NADPH\nOxidase (NOX2/4)"];
    ROS_O2      [label="ROS /\nSuperoxide (O₂⁻)"];
    oxLDL       [label="Oxidized LDL\n(ox-LDL)"];
    LOX1        [label="LOX-1\nReceptor"];
    ICAM1       [label="ICAM-1\nUpregulation"];
    VCAM1       [label="VCAM-1\nUpregulation"];
    MCP1        [label="MCP-1\n(CCL2) Chemokine"];
    E_sel       [label="E-Selectin\nExpression"];
    Mono_adh    [label="Monocyte\nAdhesion & Rolling"];
    EC_activ    [label="Endothelial\nActivation"];
    BH4_dep     [label="BH4\nDepletion"];
    Peroxynit   [label="Peroxynitrite\n(ONOO⁻)"];
    ET1_up      [label="Endothelin-1\n(ET-1) ↑"];
    Prostacyc   [label="Prostacyclin\n(PGI₂) ↓"];
  }

  // ================================
  // CLUSTER 3: Atherosclerosis Progression
  // ================================
  subgraph cluster_athero {
    label="Atherosclerosis Progression";
    color=saddlebrown; fontcolor=saddlebrown; style=rounded; bgcolor="#FFF5E6";
    node [fillcolor="#DEB887"];

    LDL_infil   [label="LDL\nInfiltration"];
    LDL_oxid    [label="LDL\nOxidation"];
    Foam_cell   [label="Foam Cell\nFormation"];
    Mac_M1      [label="M1 Macrophage\n(Pro-inflammatory)"];
    Mac_M2      [label="M2 Macrophage\n(Anti-inflammatory)"];
    VSMC_mig    [label="VSMC\nMigration"];
    VSMC_pro    [label="VSMC\nProliferation"];
    Lipid_core  [label="Lipid\nCore"];
    Fibrous_cap [label="Fibrous\nCap Formation"];
    Plaque_vol  [label="Plaque\nVolume ↑"];
    IL6_ath     [label="IL-6\n(Proinflammatory)"];
    TNFa_ath    [label="TNF-α"];
    MMPs_ath    [label="Matrix\nMetalloproteinases"];
    Necrot_core [label="Necrotic\nCore Expansion"];
    Calcif      [label="Vascular\nCalcification"];
    PDGF_ath    [label="PDGF-BB"];
    CD36_SR     [label="CD36 / SR-A\nScavenger Receptors"];
    TGFb_ath    [label="TGF-β\n(Fibrosis)"];
    PCSK9_ath   [label="PCSK9\nLDLR Degradation"];
  }

  // ==============================
  // CLUSTER 4: Plaque Vulnerability & Rupture
  // ==============================
  subgraph cluster_plaque {
    label="Plaque Vulnerability\n& Rupture / Erosion";
    color=crimson; fontcolor=crimson; style=rounded; bgcolor="#FFF0F4";
    node [fillcolor="#FFB6C1"];

    MMP1_p      [label="MMP-1\n(Collagenase)"];
    MMP9_p      [label="MMP-9\n(Gelatinase B)"];
    MMP13_p     [label="MMP-13\n(Collagenase 3)"];
    TF_p        [label="Tissue\nFactor (TF)"];
    Collag_deg  [label="Collagen\nDegradation"];
    Cap_thin    [label="Cap\nThinning"];
    Plaque_rupt [label="Plaque\nRupture"];
    Plaque_eros [label="Plaque\nErosion"];
    Thrombus_t  [label="Thrombosis\nTrigger"];
    PAI1_p      [label="PAI-1\n(t-PA Inhibitor)"];
    TIMP_p      [label="TIMP-1/2\n(MMP Inhibitor)"];
    Neutrophil  [label="Neutrophil\nExtracellular Traps"];
    Apoptosis   [label="Macrophage\nApoptosis"];
  }

  // ================================
  // CLUSTER 5: Platelet Activation & Thrombosis
  // ================================
  subgraph cluster_platelet {
    label="Platelet Activation\n& Thrombus Formation";
    color=darkblue; fontcolor=darkblue; style=rounded; bgcolor="#F0F4FF";
    node [fillcolor="#ADD8E6"];

    Plt_adh     [label="Platelet\nAdhesion"];
    vWF         [label="von Willebrand\nFactor (vWF)"];
    GPIb        [label="GP Ib-IX-V\nComplex"];
    GPVI        [label="GP VI\n(Collagen Receptor)"];
    ADP_rel     [label="ADP\nRelease (Dense Granule)"];
    P2Y12_plt   [label="P2Y12\nReceptor"];
    P2Y1_plt    [label="P2Y1\nReceptor"];
    TXA2_prod   [label="TXA2\nProduction (COX-1)"];
    TP_rec      [label="TP Receptor\n(TXA2 / PGH₂)"];
    PAR1_plt    [label="PAR-1\n(Thrombin Receptor)"];
    PAR4_plt    [label="PAR-4\n(Thrombin Receptor)"];
    GPIIbIIIa  [label="GP IIb/IIIa\nActivation"];
    Fibrin_plt  [label="Fibrinogen\nBinding"];
    Plt_agg     [label="Platelet\nAggregation"];
    Thrombus    [label="Thrombus\nFormation"];
    Serotonin   [label="Serotonin\n(5-HT) Release"];
    Plt_amp     [label="Platelet\nAmplification Loop"];
  }

  // =========================
  // CLUSTER 6: Coagulation Cascade
  // =========================
  subgraph cluster_coag {
    label="Coagulation Cascade\n(Intrinsic & Extrinsic)";
    color=navy; fontcolor=navy; style=rounded; bgcolor="#F0F0FF";
    node [fillcolor="#B0C4DE"];

    TF_FVIIa    [label="TF–FVIIa\nInitiation Complex"];
    FX_act      [label="Factor Xa\n(FXa)"];
    FV_act      [label="Factor Va\n(FVa)"];
    Protromb    [label="Prothrombinase\nComplex"];
    Thrombin_c  [label="Thrombin\n(FIIa)"];
    Fibrinogen  [label="Fibrinogen"];
    Fibrin_c    [label="Fibrin\nClot"];
    FXIII       [label="Factor XIIIa\nCrosslinking"];
    Antithromb  [label="Antithrombin\n(AT-III)"];
    TFPI_prot   [label="TFPI\n(TF Inhibitor)"];
    ProtC       [label="Protein C\nActivation"];
    FXII_intr   [label="Factor XIIa\n(Contact)"];
    FXI_intr    [label="Factor XIa"];
  }

  // ====================================
  // CLUSTER 7: Limb Ischemia & Skeletal Muscle
  // ====================================
  subgraph cluster_ischemia {
    label="Lower Limb Ischemia\n& Skeletal Muscle Pathology";
    color=darkgreen; fontcolor=darkgreen; style=rounded; bgcolor="#F0FFF4";
    node [fillcolor="#90EE90"];

    BF_red      [label="Blood Flow\nReduction ↓"];
    ABI_val     [label="ABI\n(Ankle-Brachial Index)"];
    Musc_O2     [label="Skeletal Muscle\nO₂ Delivery ↓"];
    Mito_dysfn  [label="Mitochondrial\nDysfunction"];
    ATP_dep     [label="ATP\nDepletion"];
    ROS_isch    [label="ROS\n(Ischemia-Reperfusion)"];
    Lactate_ac  [label="Lactate\nAccumulation"];
    TypeI_loss  [label="Type I Fiber\nLoss (Atrophy)"];
    Claudicatio [label="Intermittent\nClaudication"];
    Walk_dist   [label="Max Walking\nDistance ↓"];
    CLI         [label="Critical Limb\nIschemia (CLI)"];
    Rest_pain   [label="Rest\nPain"];
    Tiss_loss   [label="Tissue Loss\n/ Ulceration"];
    Amput_risk  [label="Amputation\nRisk"];
    Rutherford  [label="Rutherford\nClassification"];
    Fontaine    [label="Fontaine\nStage (I–IV)"];
    Neuropathy  [label="Peripheral\nNeuropathy"];
    Muscle_wast [label="Muscle\nWasting"];
  }

  // ====================================
  // CLUSTER 8: Collateral Vessel Formation & Angiogenesis
  // ====================================
  subgraph cluster_angio {
    label="Collateral Formation\n& Angiogenesis";
    color=teal; fontcolor=teal; style=rounded; bgcolor="#F0FFFF";
    node [fillcolor="#B2DFDB"];

    HIF1a       [label="HIF-1α\nTranscription"];
    VEGFA       [label="VEGF-A\nExpression"];
    VEGFR2      [label="VEGFR2\nSignaling"];
    Ang1        [label="Angiopoietin-1\nStabilization"];
    Ang2        [label="Angiopoietin-2\nRemodeling"];
    eNOS_angio  [label="eNOS (Angiogenic\nNO production)"];
    Collat      [label="Collateral\nVessels"];
    FGF2        [label="FGF-2\n(bFGF)"];
    SDF1        [label="SDF-1\n(CXCL12)"];
    CXCR4       [label="CXCR4\nReceptor"];
    EPC_mob     [label="EPC\nMobilization (BM)"];
    Arteriogen  [label="Arteriogenesis\n(Shear Stress)"];
    MCP1_ang    [label="MCP-1\nChemoattraction"];
    PlGF        [label="PLGF\n(Placental GF)"];
  }

  // ===================================================
  // CLUSTER 9: Drug PK/PD — Antiplatelet Agents
  // ===================================================
  subgraph cluster_antiplatelet {
    label="Drug PK/PD: Antiplatelet Agents";
    color=purple; fontcolor=purple; style=rounded; bgcolor="#FAF0FF";
    node [fillcolor="#E6E6FA"];

    Clopi_gut   [label="Clopidogrel\nGut (A₁)"];
    Clopi_cent  [label="Clopidogrel\nPlasma"];
    Clopi_AM    [label="Active Metabolite\n(AM-H4, CYP2C19)"];
    P2Y12_inh   [label="P2Y12\nInhibition (%)"];
    Asp_gut     [label="Aspirin\nGut"];
    Asp_cent    [label="Aspirin\nPlasma"];
    COX1_inh    [label="COX-1\nInhibition (Irreversible)"];
    TXA2_inh    [label="TXA2 Synthesis↓\n(Thromboxane)"];
    Tica_gut    [label="Ticagrelor\nGut"];
    Tica_cent   [label="Ticagrelor\nPlasma"];
    Vora_gut    [label="Vorapaxar\nGut"];
    Vora_cent   [label="Vorapaxar\nPlasma"];
    PAR1_inh    [label="PAR-1\nInhibition"];
    Dipyrid     [label="Dipyridamole\n(Adenosine ↑)"];
  }

  // ====================================================
  // CLUSTER 10: Drug PK/PD — Anticoagulant, Vasodilator, Statin
  // ====================================================
  subgraph cluster_otherdrg {
    label="Drug PK/PD: Anticoagulant,\nVasodilator & Statin";
    color=indigo; fontcolor=indigo; style=rounded; bgcolor="#F8F0FF";
    node [fillcolor="#D8D8FF"];

    Riva_gut    [label="Rivaroxaban\nGut"];
    Riva_cent   [label="Rivaroxaban\nPlasma"];
    FXa_inh     [label="FXa\nInhibition (%)"];
    Cilo_gut    [label="Cilostazol\nGut"];
    Cilo_cent   [label="Cilostazol\nPlasma"];
    PDE3_inh    [label="PDE3\nInhibition"];
    cAMP_up     [label="cAMP ↑\n(Antiplatelet/Vasodilation)"];
    Vasodil     [label="Arterial\nVasodilation"];
    Atst_gut    [label="Atorvastatin\nGut"];
    Atst_cent   [label="Atorvastatin\nPlasma"];
    HMGCoA_inh  [label="HMG-CoA Reductase\nInhibition"];
    LDL_red     [label="LDL-C\nReduction (%)"];
    Pleiotropic [label="Statin Pleiotropic\nEffects (Anti-inflammatory)"];
    Naftidro    [label="Naftidrofuryl\n(5-HT₂ Antagonist)"];
  }

  // =========================
  // CLUSTER 11: Biomarkers
  // =========================
  subgraph cluster_biom {
    label="Circulating Biomarkers\n& Diagnostic Indices";
    color=darkcyan; fontcolor=darkcyan; style=rounded; bgcolor="#F0FFFF";
    node [fillcolor="#AFEEEE"];

    hsCRP       [label="hs-CRP\n(Inflammation)"];
    Fibrinogen_b [label="Fibrinogen\nLevel ↑"];
    D_dimer     [label="D-Dimer\n(Fibrin Degradation)"];
    Homocyst_b  [label="Homocysteine\n(Endothelial Toxin)"];
    LPa         [label="Lp(a)\n(Pro-Atherogenic)"];
    ABI_meas    [label="ABI Measurement\n(0.9 = diagnostic)"];
    Ankle_sys   [label="Ankle Systolic\nPressure (mmHg)"];
    TBI_val     [label="Toe-Brachial\nIndex (TBI)"];
    MMP9_b      [label="MMP-9\n(Plasma, ng/mL)"];
    IL6_b       [label="IL-6\n(Plasma, pg/mL)"];
    sVCAM1_b    [label="sVCAM-1\n(Soluble)"];
    PAI1_b      [label="PAI-1\nLevel ↑"];
    TXB2_b      [label="Urinary TXB2\n(Platelet Activity)"];
    NT_proBNP   [label="NT-proBNP\n(Cardiac Strain)"];
  }

  // ==============================
  // CLUSTER 12: Clinical Endpoints
  // ==============================
  subgraph cluster_endpoints {
    label="Clinical Endpoints\n& Disease Outcomes";
    color=black; fontcolor=black; style=rounded; bgcolor="#F8F8F8";
    node [fillcolor="#DCDCDC"];

    MACE        [label="MACE\n(CV Death / MI / Stroke)"];
    MALE        [label="MALE\n(Major Adverse Limb Events)"];
    CV_death    [label="Cardiovascular\nDeath"];
    MI_risk     [label="Myocardial\nInfarction"];
    Stroke_risk [label="Ischemic\nStroke"];
    Limb_revasc [label="Limb\nRevascularization"];
    Maj_amput   [label="Major\nAmputation"];
    Symp_walk   [label="Symptom-free\nWalking Distance ↑"];
    QOL         [label="Quality of Life\n(VascuQol Score)"];
    Hospitalize [label="PAD-related\nHospitalization"];
    ABI_improv  [label="ABI\nImprovement"];
    Pain_score  [label="Pain Score\n(VAS)"];
  }

  // =================================================
  // EDGES: Risk Factors → Endothelial Dysfunction
  // =================================================
  HTN        -> NADPH_ox;
  HTN        -> EC_activ;
  HTN        -> ET1_up;
  Smoking    -> ROS_O2 [label="direct\noxidant"];
  Smoking    -> Smk_oxidant;
  Smk_oxidant -> eNOS_unc;
  Smk_oxidant -> NADPH_ox;
  DM_risk    -> ROS_O2;
  DM_risk    -> Insulin_res;
  Insulin_res -> NADPH_ox;
  DM_risk    -> oxLDL;
  Dyslip     -> LDL_infil;
  Dyslip     -> oxLDL;
  CKD_risk   -> Homocyst;
  Homocyst   -> eNOS_unc;
  Homocyst   -> ROS_O2;
  Age_risk   -> eNOS_unc;
  Age_risk   -> Calcif;
  Obesity_r  -> IL6_ath;
  Obesity_r  -> Insulin_res;
  Sedentary  -> Dyslip;
  Sedentary  -> Obesity_r;
  Fam_hx     -> Dyslip;
  Fam_hx     -> Homocyst;
  InflamState -> EC_activ;
  InflamState -> IL6_ath;
  PCSK9_ath  -> Dyslip;

  // Endothelial Dysfunction Internals
  eNOS_unc   -> NO_down;
  eNOS_unc   -> ROS_O2;
  BH4_dep    -> eNOS_unc;
  NADPH_ox   -> ROS_O2;
  ROS_O2     -> oxLDL;
  ROS_O2     -> Peroxynit;
  ROS_O2     -> BH4_dep;
  ROS_O2     -> ICAM1;
  ROS_O2     -> VCAM1;
  oxLDL      -> LOX1;
  LOX1       -> EC_activ;
  NO_down    -> EC_activ;
  NO_down    -> ET1_up;
  EC_activ   -> ICAM1;
  EC_activ   -> VCAM1;
  EC_activ   -> MCP1;
  EC_activ   -> E_sel;
  EC_activ   -> PAI1_p;
  EC_activ   -> Prostacyc;
  MCP1       -> Mono_adh;
  ICAM1      -> Mono_adh;
  VCAM1      -> Mono_adh;
  E_sel      -> Mono_adh;

  // Atherosclerosis Internals
  LDL_infil  -> LDL_oxid;
  LDL_oxid   -> oxLDL;
  Mono_adh   -> Mac_M1;
  Mac_M1     -> CD36_SR;
  CD36_SR    -> Foam_cell;
  Foam_cell  -> Lipid_core;
  Mac_M1     -> IL6_ath;
  Mac_M1     -> TNFa_ath;
  Mac_M1     -> MMPs_ath;
  Mac_M1     -> Apoptosis;
  Apoptosis  -> Necrot_core;
  IL6_ath    -> VSMC_pro;
  TNFa_ath   -> VSMC_mig;
  PDGF_ath   -> VSMC_mig;
  PDGF_ath   -> VSMC_pro;
  TGFb_ath   -> Fibrous_cap;
  VSMC_mig   -> Fibrous_cap;
  VSMC_pro   -> Fibrous_cap;
  Lipid_core -> Plaque_vol;
  Fibrous_cap -> Plaque_vol;
  Foam_cell  -> Necrot_core;
  Necrot_core -> Plaque_vol;
  MMPs_ath   -> Collag_deg;
  Calcif     -> Plaque_vol;
  Mac_M2     -> PDGF_ath;
  oxLDL      -> Mac_M1;

  // Plaque Vulnerability
  MMPs_ath   -> MMP1_p;
  MMPs_ath   -> MMP9_p;
  MMPs_ath   -> MMP13_p;
  MMP1_p     -> Collag_deg;
  MMP9_p     -> Collag_deg;
  MMP13_p    -> Collag_deg;
  Collag_deg -> Cap_thin;
  Cap_thin   -> Plaque_rupt;
  Necrot_core -> TF_p;
  TF_p       -> Thrombus_t;
  Plaque_rupt -> Thrombus_t;
  Plaque_eros -> Thrombus_t;
  PAI1_p     -> TF_p;
  TIMP_p     -> MMP1_p [label="inhibits", style=dashed, color=blue];
  TIMP_p     -> MMP9_p [label="inhibits", style=dashed, color=blue];
  Neutrophil -> Plaque_rupt [label="NET-mediated"];
  Mac_M1     -> Neutrophil;

  // Platelet Activation
  Thrombus_t -> Plt_adh;
  Plt_adh    -> vWF;
  vWF        -> GPIb;
  Plt_adh    -> GPVI;
  GPVI       -> ADP_rel;
  GPVI       -> TXA2_prod;
  ADP_rel    -> P2Y12_plt;
  ADP_rel    -> P2Y1_plt;
  P2Y12_plt  -> GPIIbIIIa;
  P2Y1_plt   -> GPIIbIIIa;
  TXA2_prod  -> TP_rec;
  TP_rec     -> GPIIbIIIa;
  Thrombin_c -> PAR1_plt;
  Thrombin_c -> PAR4_plt;
  PAR1_plt   -> GPIIbIIIa;
  PAR4_plt   -> GPIIbIIIa;
  GPIIbIIIa -> Fibrin_plt;
  Fibrin_plt -> Plt_agg;
  Plt_agg    -> Thrombus;
  TXA2_prod  -> Serotonin;
  Serotonin  -> Plt_amp;
  Plt_amp    -> Plt_agg;
  GPIb       -> Plt_adh;

  // Coagulation Cascade
  Thrombus_t -> TF_FVIIa;
  TF_FVIIa   -> FX_act;
  FX_act     -> FV_act;
  FX_act     -> Protromb;
  FV_act     -> Protromb;
  Protromb   -> Thrombin_c;
  Thrombin_c -> Fibrinogen;
  Fibrinogen -> Fibrin_c;
  Fibrin_c   -> FXIII;
  FXIII      -> Thrombus;
  Antithromb -> Thrombin_c [label="inhibits", style=dashed, color=blue];
  Antithromb -> FX_act     [label="inhibits", style=dashed, color=blue];
  TFPI_prot  -> TF_FVIIa   [label="inhibits", style=dashed, color=blue];
  Thrombin_c -> PAR1_plt;
  ProtC      -> FV_act     [label="degrades Va", style=dashed, color=blue];
  FXII_intr  -> FXI_intr;
  FXI_intr   -> FX_act;

  // Ischemia
  Thrombus   -> BF_red;
  Plaque_vol -> BF_red;
  ET1_up     -> BF_red;
  BF_red     -> ABI_val;
  BF_red     -> Musc_O2;
  Musc_O2    -> Mito_dysfn;
  Mito_dysfn -> ATP_dep;
  Mito_dysfn -> ROS_isch;
  ATP_dep    -> Lactate_ac;
  Lactate_ac -> Claudicatio;
  ABI_val    -> Claudicatio;
  TypeI_loss -> Walk_dist;
  Claudicatio -> Walk_dist;
  Claudicatio -> Rutherford;
  Claudicatio -> Fontaine;
  Walk_dist  -> QOL;
  ABI_val    -> CLI;
  CLI        -> Rest_pain;
  CLI        -> Tiss_loss;
  Tiss_loss  -> Amput_risk;
  Rest_pain  -> Rutherford;
  Mito_dysfn -> TypeI_loss;
  Neuropathy -> Claudicatio;
  DM_risk    -> Neuropathy;
  Muscle_wast -> Walk_dist;
  TypeI_loss -> Muscle_wast;

  // Collateral Formation
  Musc_O2    -> HIF1a;
  HIF1a      -> VEGFA;
  HIF1a      -> SDF1;
  HIF1a      -> FGF2;
  HIF1a      -> PlGF;
  VEGFA      -> VEGFR2;
  VEGFR2     -> eNOS_angio;
  VEGFR2     -> Collat;
  Ang1       -> Collat;
  Ang2       -> Collat;
  FGF2       -> Arteriogen;
  PlGF       -> Arteriogen;
  SDF1       -> CXCR4;
  CXCR4      -> EPC_mob;
  EPC_mob    -> Collat;
  MCP1_ang   -> EPC_mob;
  Arteriogen -> Collat;
  eNOS_angio -> Collat;
  Collat     -> BF_red [label="compensates↓", style=dashed, color=green];

  // Drug PK/PD: Antiplatelet
  Clopi_gut  -> Clopi_cent;
  Clopi_cent -> Clopi_AM [label="CYP2C19\nactivation"];
  Clopi_AM   -> P2Y12_inh;
  P2Y12_inh  -> P2Y12_plt [label="blocks", style=dashed, color=red];
  Asp_gut    -> Asp_cent;
  Asp_cent   -> COX1_inh;
  COX1_inh   -> TXA2_inh;
  TXA2_inh   -> TXA2_prod [label="inhibits", style=dashed, color=red];
  Tica_gut   -> Tica_cent;
  Tica_cent  -> P2Y12_inh;
  Vora_gut   -> Vora_cent;
  Vora_cent  -> PAR1_inh;
  PAR1_inh   -> PAR1_plt [label="blocks", style=dashed, color=red];
  Dipyrid    -> cAMP_up;

  // Drug PK/PD: Anticoagulant & Other
  Riva_gut   -> Riva_cent;
  Riva_cent  -> FXa_inh;
  FXa_inh    -> FX_act   [label="inhibits", style=dashed, color=red];
  FXa_inh    -> Thrombin_c [label="indirect↓", style=dashed, color=red];
  Cilo_gut   -> Cilo_cent;
  Cilo_cent  -> PDE3_inh;
  PDE3_inh   -> cAMP_up;
  cAMP_up    -> Vasodil;
  cAMP_up    -> Plt_agg  [label="inhibits↓", style=dashed, color=red];
  Vasodil    -> BF_red   [label="reduces↓", style=dashed, color=green];
  Vasodil    -> Walk_dist [label="improves↑", style=dashed, color=green];
  Naftidro   -> Serotonin [label="blocks 5-HT₂", style=dashed, color=red];
  Atst_gut   -> Atst_cent;
  Atst_cent  -> HMGCoA_inh;
  HMGCoA_inh -> LDL_red;
  LDL_red    -> Dyslip   [label="reduces↓", style=dashed, color=green];
  LDL_red    -> LDL_infil [label="reduces↓", style=dashed, color=green];
  HMGCoA_inh -> Pleiotropic;
  Pleiotropic -> EC_activ [label="reduces↓", style=dashed, color=green];
  Pleiotropic -> Mac_M1  [label="reduces↓", style=dashed, color=green];
  Pleiotropic -> eNOS_unc [label="reduces↓", style=dashed, color=green];

  // Biomarkers ← Pathophysiology
  EC_activ   -> sVCAM1_b;
  IL6_ath    -> IL6_b;
  IL6_ath    -> hsCRP;
  Fibrin_c   -> D_dimer;
  PAI1_p     -> PAI1_b;
  MMPs_ath   -> MMP9_b;
  BF_red     -> ABI_meas;
  ABI_meas   -> TBI_val;
  Ankle_sys  -> ABI_meas;
  Fibrinogen -> Fibrinogen_b;
  Homocyst   -> Homocyst_b;
  Dyslip     -> LPa;
  TXA2_prod  -> TXB2_b;
  CLI        -> NT_proBNP;

  // Clinical Endpoints ← Disease & Treatment
  Thrombus   -> MACE;
  Thrombus   -> MALE;
  MACE       -> CV_death;
  MACE       -> MI_risk;
  MACE       -> Stroke_risk;
  MALE       -> Limb_revasc;
  MALE       -> Maj_amput;
  Amput_risk -> Maj_amput;
  Walk_dist  -> Symp_walk;
  Symp_walk  -> QOL;
  CLI        -> Hospitalize;
  Hospitalize -> Maj_amput;
  ABI_val    -> ABI_improv;
  Rest_pain  -> Pain_score;
  Claudicatio -> Pain_score;

  // Drug effects → Endpoints
  P2Y12_inh  -> MACE      [label="reduces\n(CAPRIE/EUCLID)", style=dashed, color=darkgreen];
  P2Y12_inh  -> MALE      [label="reduces", style=dashed, color=darkgreen];
  PAR1_inh   -> MACE      [label="reduces\n(TRA 2°P-TIMI 50)", style=dashed, color=darkgreen];
  FXa_inh    -> MACE      [label="reduces\n(COMPASS)", style=dashed, color=darkgreen];
  FXa_inh    -> MALE      [label="reduces\n(COMPASS)", style=dashed, color=darkgreen];
  LDL_red    -> MACE      [label="reduces\n(statins)", style=dashed, color=darkgreen];
  Vasodil    -> Symp_walk [label="improves\n(CASTLE trial)", style=dashed, color=darkgreen];
  TBI_val    -> CLI;
}
