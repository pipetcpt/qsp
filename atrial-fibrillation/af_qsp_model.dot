// Atrial Fibrillation QSP Mechanistic Map
// Layout: fdp (force-directed placement)
// Nodes: ≥100 | Clusters: 10
graph AF_QSP_Model {
    graph [
        label="Atrial Fibrillation — Quantitative Systems Pharmacology Model\nComprehensive Mechanistic Map (Electrical · Structural · Thrombotic · Drug PK/PD)",
        labelloc=t,
        fontsize=18,
        fontname="Helvetica-Bold",
        bgcolor="#FAFAFA",
        splines=true,
        overlap=false,
        sep="+15",
        K=1.2
    ]
    node [shape=box, style="filled,rounded", fontsize=10, fontname="Helvetica"]
    edge [fontsize=8, fontname="Helvetica"]

    // =====================================================================
    // CLUSTER 1: UPSTREAM RISK FACTORS
    // =====================================================================
    subgraph cluster_risk {
        label="Upstream Risk Factors"
        style=filled
        fillcolor="#FFF8F0"
        color="#CC8800"
        fontsize=13

        HTN            [label="Hypertension", fillcolor="#FFCC99"]
        heart_failure  [label="Heart Failure", fillcolor="#FFCC99"]
        obesity        [label="Obesity / BMI", fillcolor="#FFCC99"]
        OSA            [label="Obstructive Sleep Apnea", fillcolor="#FFCC99"]
        T2DM           [label="Type 2 Diabetes", fillcolor="#FFCC99"]
        valvular_disease [label="Valvular Heart Disease", fillcolor="#FFCC99"]
        hyperthyroidism [label="Hyperthyroidism", fillcolor="#FFCC99"]
        alcohol        [label="Alcohol / Toxins", fillcolor="#FFCC99"]
        aging          [label="Aging", fillcolor="#FFCC99"]
        genetic_variants_PITX2 [label="PITX2 Variants (4q25)", fillcolor="#FFEECC"]
        genetic_variants_ZFHX3 [label="ZFHX3 Variants (16q22)", fillcolor="#FFEECC"]
        SCN5A_polymorphism [label="SCN5A Polymorphism", fillcolor="#FFEECC"]
        atrial_stretch [label="Atrial Wall Stretch", fillcolor="#FFCC99"]
        familial_AF    [label="Familial AF", fillcolor="#FFEECC"]
        pericarditis   [label="Pericarditis / Myocarditis", fillcolor="#FFCC99"]
        post_surgery   [label="Post-Cardiac Surgery", fillcolor="#FFCC99"]
    }

    // =====================================================================
    // CLUSTER 2: ATRIAL ELECTRICAL REMODELING
    // =====================================================================
    subgraph cluster_electrical {
        label="Atrial Electrical Remodeling"
        style=filled
        fillcolor="#FFF0F8"
        color="#880088"
        fontsize=13

        Nav1_5         [label="Nav1.5 (INa)\nSodium Channel", fillcolor="#FFAACC", shape=box]
        Cav1_2         [label="Cav1.2 (ICaL)\nL-type Ca Channel", fillcolor="#FFAACC"]
        Kv1_5          [label="Kv1.5 (IKur)\nUltrarapid K⁺", fillcolor="#FFAACC"]
        Kir2_1         [label="Kir2.1 (IK1)\nInward Rectifier K⁺", fillcolor="#FFAACC"]
        hERG           [label="hERG (IKr)\nRapid Delayed Rectifier", fillcolor="#FFAACC"]
        KCNQ1_KCNE1    [label="KCNQ1/KCNE1 (IKs)\nSlow Delayed Rectifier", fillcolor="#FFAACC"]
        Kir3_1_3_4     [label="Kir3.1/3.4 (IKACh)\nACh-activated K⁺", fillcolor="#FFAACC"]
        Kv4_3          [label="Kv4.3 (Ito)\nTransient Outward K⁺", fillcolor="#FFAACC"]
        HCN4           [label="HCN4 (If)\nFunny Current", fillcolor="#FFAACC"]
        ICaT           [label="ICaT (T-type Ca²⁺)", fillcolor="#FFAACC"]
        ERP_shortening [label="ERP Shortening\n(↓ Refractoriness)", fillcolor="#FF88AA"]
        conduction_velocity_decrease [label="Conduction Velocity ↓", fillcolor="#FF88AA"]
        wavelength_shortening [label="Wavelength Shortening\n(λ = CV × ERP)", fillcolor="#FF88AA"]
        Cx40           [label="Connexin-40 (Cx40)\nGap Junction", fillcolor="#FFBBDD"]
        Cx43           [label="Connexin-43 (Cx43)\nGap Junction", fillcolor="#FFBBDD"]
        anisotropic_conduction [label="Anisotropic Conduction", fillcolor="#FF88AA"]
        reentry_circuits [label="Reentry Circuits\n(Macro/Micro)", fillcolor="#FF4466", fontcolor=white]
        multiple_wavelets [label="Multiple Wavelet Theory", fillcolor="#FF4466", fontcolor=white]
        focal_triggers_PV [label="Focal Triggers\n(Pulm. Veins)", fillcolor="#FF4466", fontcolor=white]
        triggered_activity [label="Triggered Activity", fillcolor="#FF88AA"]
        EADs           [label="Early Afterdepolarizations\n(EADs)", fillcolor="#FF88AA"]
        DADs           [label="Delayed Afterdepolarizations\n(DADs)", fillcolor="#FF88AA"]
    }

    // =====================================================================
    // CLUSTER 3: Ca²⁺ HANDLING
    // =====================================================================
    subgraph cluster_calcium {
        label="Ca²⁺ Handling & Excitation-Contraction Coupling"
        style=filled
        fillcolor="#F5F0FF"
        color="#5500AA"
        fontsize=13

        SERCA2a        [label="SERCA2a\nSR Ca²⁺ ATPase", fillcolor="#CC99FF"]
        PLN            [label="Phospholamban (PLN)", fillcolor="#CC99FF"]
        NCX1           [label="NCX1\nNa⁺/Ca²⁺ Exchanger", fillcolor="#CC99FF"]
        RyR2           [label="RyR2\nRyanodine Receptor", fillcolor="#CC99FF"]
        calsequestrin  [label="Calsequestrin (CASQ2)\nSR Ca²⁺ Buffer", fillcolor="#CC99FF"]
        CaM            [label="Calmodulin (CaM)", fillcolor="#DDBBFF"]
        CaMKII         [label="CaMKII\nCa²⁺/CaM Kinase II", fillcolor="#BB77FF"]
        IP3R           [label="IP3R\nIP3 Receptor", fillcolor="#CC99FF"]
        LTCC           [label="LTCC (L-type Ca²⁺ Channel)\nICaL", fillcolor="#CC99FF"]
        SR_Ca_overload [label="SR Ca²⁺ Overload", fillcolor="#9944FF", fontcolor=white]
        FKBP12_6       [label="FKBP12.6\nRyR2 Stabilizer", fillcolor="#DDBBFF"]
        oxidized_CaMKII [label="Oxidized CaMKII\n(ROS-activated)", fillcolor="#9944FF", fontcolor=white]
        nitrosylated_RyR2 [label="S-nitrosylated RyR2\n(Leaky)", fillcolor="#9944FF", fontcolor=white]
        SOICR          [label="SOICR\nStore Overload-Induced\nCa²⁺ Release", fillcolor="#7722DD", fontcolor=white]
    }

    // =====================================================================
    // CLUSTER 4: STRUCTURAL REMODELING
    // =====================================================================
    subgraph cluster_structural {
        label="Atrial Structural Remodeling & Fibrosis"
        style=filled
        fillcolor="#F0FFF0"
        color="#006600"
        fontsize=13

        TGF_beta1      [label="TGF-β1\nTransforming Growth Factor", fillcolor="#AADDAA"]
        TGF_betaRI     [label="TGFβRI (ALK5)\nType I Receptor", fillcolor="#AADDAA"]
        TGF_betaRII    [label="TGFβRII\nType II Receptor", fillcolor="#AADDAA"]
        SMAD2_3        [label="SMAD2/3\nR-SMADs", fillcolor="#88CC88"]
        SMAD4          [label="SMAD4\nCo-SMAD", fillcolor="#88CC88"]
        AngII          [label="Angiotensin II\n(AngII)", fillcolor="#FFAA88"]
        AT1R           [label="AT1 Receptor", fillcolor="#FFCC99"]
        ACE            [label="ACE\nAngiotensin Converting Enzyme", fillcolor="#FFCC99"]
        aldosterone    [label="Aldosterone", fillcolor="#FFAA88"]
        MR             [label="Mineralocorticoid\nReceptor (MR)", fillcolor="#FFCC99"]
        PDGF           [label="PDGF\nPlatelet-Derived GF", fillcolor="#AADDAA"]
        fibroblast_activation [label="Fibroblast Activation", fillcolor="#88BB88"]
        myofibroblast  [label="Myofibroblast\nDifferentiation", fillcolor="#66AA66"]
        collagen_I     [label="Collagen Type I\nDeposition", fillcolor="#66AA66"]
        collagen_III   [label="Collagen Type III\nDeposition", fillcolor="#66AA66"]
        fibronectin    [label="Fibronectin", fillcolor="#88BB88"]
        MMP2           [label="MMP-2\nMatrix Metalloprotease 2", fillcolor="#AADDAA"]
        MMP9           [label="MMP-9\nMatrix Metalloprotease 9", fillcolor="#AADDAA"]
        TIMP1          [label="TIMP-1\nTissue Inhibitor MMP", fillcolor="#CCEECC"]
        TIMP2          [label="TIMP-2\nTissue Inhibitor MMP", fillcolor="#CCEECC"]
        LAA_enlargement [label="LA/LAA Enlargement", fillcolor="#44AA44", fontcolor=white]
        atrial_fibrosis [label="Atrial Fibrosis\n(Structural Substrate)", fillcolor="#228822", fontcolor=white]
        atrial_stiffness [label="Atrial Stiffness ↑", fillcolor="#448844", fontcolor=white]
    }

    // =====================================================================
    // CLUSTER 5: INFLAMMATION & OXIDATIVE STRESS
    // =====================================================================
    subgraph cluster_inflammation {
        label="Inflammation & Oxidative Stress"
        style=filled
        fillcolor="#FFF0F0"
        color="#AA0000"
        fontsize=13

        NLRP3          [label="NLRP3 Inflammasome", fillcolor="#FFAAAA"]
        caspase_1      [label="Caspase-1", fillcolor="#FFAAAA"]
        IL_1beta       [label="IL-1β", fillcolor="#FF8888"]
        IL_6           [label="IL-6", fillcolor="#FF8888"]
        TNF_alpha      [label="TNF-α", fillcolor="#FF8888"]
        CRP            [label="CRP\n(C-Reactive Protein)", fillcolor="#FF8888"]
        NF_kB          [label="NF-κB\nTranscription Factor", fillcolor="#FF6666"]
        IKK            [label="IKK Complex\n(IKKα/β/γ)", fillcolor="#FFAAAA"]
        NOX2           [label="NADPH Oxidase 2\n(NOX2)", fillcolor="#FF6666"]
        mitochondrial_ROS [label="Mitochondrial ROS\n(Superoxide)", fillcolor="#FF4444", fontcolor=white]
        superoxide     [label="Superoxide (O₂⁻)", fillcolor="#FF4444", fontcolor=white]
        peroxynitrite  [label="Peroxynitrite\n(ONOO⁻)", fillcolor="#FF4444", fontcolor=white]
        eNOS_uncoupling [label="eNOS Uncoupling", fillcolor="#FF8888"]
        BH4_deficiency [label="BH4 Deficiency\n(eNOS cofactor)", fillcolor="#FFAAAA"]
        macrophage_infiltration [label="Macrophage Infiltration\nM1 polarization", fillcolor="#FF8888"]
        mast_cell      [label="Mast Cell Activation", fillcolor="#FFAAAA"]
        ICAM_1         [label="ICAM-1\nAdhesion Molecule", fillcolor="#FFAAAA"]
        MCP_1          [label="MCP-1/CCL2\nChemoattractant", fillcolor="#FFAAAA"]
        XO             [label="Xanthine Oxidase (XO)\nROS source", fillcolor="#FF8888"]
    }

    // =====================================================================
    // CLUSTER 6: AUTONOMIC NERVOUS SYSTEM
    // =====================================================================
    subgraph cluster_autonomic {
        label="Autonomic Nervous System"
        style=filled
        fillcolor="#F0F8FF"
        color="#004488"
        fontsize=13

        vagal_tone     [label="Vagal Tone ↑\n(Parasympathetic)", fillcolor="#AAC8FF"]
        sympathetic_activity [label="Sympathetic Activity ↑", fillcolor="#FFBBAA"]
        beta1AR        [label="β1-Adrenergic Receptor", fillcolor="#FFBBAA"]
        M2R            [label="M2 Muscarinic Receptor", fillcolor="#AAC8FF"]
        cAMP           [label="cAMP\n(2nd Messenger)", fillcolor="#CCDDFF"]
        PKA            [label="PKA\n(Protein Kinase A)", fillcolor="#CCDDFF"]
        PLN_phosphorylation [label="PLN Phosphorylation\n(Ser16/Thr17)", fillcolor="#AABBFF"]
        RyR2_phosphorylation [label="RyR2 Phosphorylation\n(Ser2808/Ser2814)", fillcolor="#AABBFF"]
        norepinephrine [label="Norepinephrine (NE)\nSympathetic", fillcolor="#FFBBAA"]
        acetylcholine  [label="Acetylcholine (ACh)\nParasympathetic", fillcolor="#AAC8FF"]
        HCN4_If        [label="HCN4 If Activation\n(Pacemaker Current)", fillcolor="#CCDDFF"]
        GP_anterior_left [label="Ganglionated Plexus\n(Anterior Left)", fillcolor="#99BBFF"]
        GP_posterior_left [label="Ganglionated Plexus\n(Posterior Left)", fillcolor="#99BBFF"]
        sinoatrial_rate [label="Sinoatrial Rate\n(Modulated)", fillcolor="#BBCCFF"]
    }

    // =====================================================================
    // CLUSTER 7: THROMBOEMBOLISM
    // =====================================================================
    subgraph cluster_thrombosis {
        label="Thromboembolism & Stroke Risk (Virchow's Triad)"
        style=filled
        fillcolor="#FFFAF0"
        color="#884400"
        fontsize=13

        LAA_stasis     [label="LAA Blood Stasis\n(Reduced Flow)", fillcolor="#FFDDAA"]
        endothelial_dysfunction [label="Endothelial\nDysfunction", fillcolor="#FFCC88"]
        vWF            [label="von Willebrand Factor\n(vWF) ↑", fillcolor="#FFDDAA"]
        tPA            [label="tPA\n(Fibrinolytic)", fillcolor="#FFEECC"]
        PAI_1          [label="PAI-1\n(Anti-fibrinolytic) ↑", fillcolor="#FFCC88"]
        platelet_activation [label="Platelet Activation\nP-selectin ↑", fillcolor="#FFCC88"]
        GPIIbIIIa      [label="GPIIb/IIIa\nFibrinogen Receptor", fillcolor="#FFDDAA"]
        TXA2           [label="Thromboxane A₂\n(TXA2)", fillcolor="#FFCC88"]
        thrombin_F2a   [label="Thrombin (FIIa)\nCoagulation Amplifier", fillcolor="#FF9944"]
        FXa            [label="Factor Xa (FXa)\nCoagulation Pivot", fillcolor="#FF9944"]
        FVa            [label="Factor Va\nProthrombinase", fillcolor="#FFBBAA"]
        TF             [label="Tissue Factor (TF/F3)\nExtrinsic Pathway", fillcolor="#FFCC88"]
        F7a            [label="Factor VIIa\nExtrinsic Pathway", fillcolor="#FFBBAA"]
        fibrinogen     [label="Fibrinogen (Factor I)", fillcolor="#FFDDAA"]
        fibrin         [label="Fibrin Clot", fillcolor="#FF8800"]
        D_dimer        [label="D-Dimer\n(Clot Biomarker)", fillcolor="#FFBBAA"]
        protein_C      [label="Protein C\nAnticoagulant", fillcolor="#CCEECC"]
        antithrombin_III [label="Antithrombin III\n(AT-III)", fillcolor="#CCEECC"]
        stroke         [label="Ischemic Stroke\nSystemic Embolism", fillcolor="#FF4400", fontcolor=white]
        systemic_embolism [label="Systemic\nEmbolism", fillcolor="#FF6600", fontcolor=white]
        CHA2DS2VASc    [label="CHA₂DS₂-VASc\nScore", fillcolor="#FFEEAA"]
        HAS_BLED       [label="HAS-BLED\nBleeding Score", fillcolor="#FFEEAA"]
    }

    // =====================================================================
    // CLUSTER 8: DRUG PK
    // =====================================================================
    subgraph cluster_PK {
        label="Drug Pharmacokinetics (PK)"
        style=filled
        fillcolor="#F0F0FF"
        color="#000088"
        fontsize=13

        GI_AMIO        [label="GI_AMIO\nAmiodarone (Gut)", fillcolor="#AAAAFF"]
        C1_AMIO        [label="C1_AMIO\nAmiodarone (Central)\nTher. Range: 1–2.5 µg/mL", fillcolor="#8888FF"]
        C2_AMIO        [label="C2_AMIO\nAmiodarone (Fat Depot)\nV2 ~4200 L", fillcolor="#AAAAFF"]
        DEA            [label="DEA\nDesethylamiodarone\n(Active Metabolite)", fillcolor="#BBBBFF"]
        GI_DRONE       [label="GI_DRONE\nDronedarone (Gut)", fillcolor="#AAAAFF"]
        C1_DRONE       [label="C1_DRONE\nDronedarone (Central)", fillcolor="#AAAAFF"]
        GI_FLEC        [label="GI_FLEC\nFlecainide (Gut)", fillcolor="#AAAAFF"]
        C1_FLEC        [label="C1_FLEC\nFlecainide (Central)\nTher. Range: 0.2–1 µg/mL", fillcolor="#8888FF"]
        GI_METRO       [label="GI_METRO\nMetoprolol (Gut)", fillcolor="#AAAAFF"]
        C1_METRO       [label="C1_METRO\nMetoprolol (Central)\nTher. Range: 20–100 ng/mL", fillcolor="#8888FF"]
        GI_APIX        [label="GI_APIX\nApixaban (Gut)", fillcolor="#AAAAFF"]
        C1_APIX        [label="C1_APIX\nApixaban (Central)\nTher. Range: 50–200 ng/mL", fillcolor="#8888FF"]
        GI_RIVA        [label="GI_RIVA\nRivaroxaban (Gut)", fillcolor="#AAAAFF"]
        C1_RIVA        [label="C1_RIVA\nRivaroxaban (Central)", fillcolor="#8888FF"]
        GI_DABI        [label="GI_DABI\nDabigatran (Gut)", fillcolor="#AAAAFF"]
        C1_DABI        [label="C1_DABI\nDabigatran (Central)\nTher. Range: 64–443 ng/mL", fillcolor="#8888FF"]
        GI_WARF        [label="GI_WARF\nWarfarin (Gut)", fillcolor="#AAAAFF"]
        C1_WARF        [label="C1_WARF\nWarfarin (Central)", fillcolor="#8888FF"]
        FcRn_recycling_digoxin [label="FcRn / P-gp\nDigoxin Transporter", fillcolor="#CCCCFF"]
        C1_DIG         [label="C1_DIG\nDigoxin (Central)\nTher. Range: 0.5–2 ng/mL", fillcolor="#8888FF"]
    }

    // =====================================================================
    // CLUSTER 9: DRUG PD
    // =====================================================================
    subgraph cluster_PD {
        label="Drug Pharmacodynamics (PD) & Mechanism of Action"
        style=filled
        fillcolor="#F8FFF0"
        color="#005500"
        fontsize=13

        Nav1_5_blockade_class_Ic [label="Nav1.5 Blockade\n(Class Ic: Flecainide)", fillcolor="#AAFFAA"]
        IKur_blockade_atrial_selective [label="IKur Blockade\n(Atrial-Selective)", fillcolor="#AAFFAA"]
        IKr_blockade_class_III [label="IKr Blockade\n(Class III: Amiodarone/Drone)", fillcolor="#AAFFAA"]
        ICaL_blockade_class_IV  [label="ICaL Blockade\n(Class IV / Diltiazem/Verapamil)", fillcolor="#AAFFAA"]
        beta1AR_blockade_class_II [label="β1AR Blockade\n(Class II: Metoprolol)", fillcolor="#AAFFAA"]
        ERP_prolongation [label="ERP Prolongation\n(Antiarrhythmic Goal)", fillcolor="#88CC88"]
        QTc_prolongation [label="QTc Prolongation\n(Safety Concern)", fillcolor="#FFCC88"]
        rate_slowing   [label="Ventricular Rate Slowing\n(Rate Control)", fillcolor="#88CC88"]
        IKACh_blockade [label="IKACh Blockade\n(Atrial-Specific)", fillcolor="#AAFFAA"]
        FXa_inhibition_apixaban [label="FXa Inhibition\n(Apixaban — direct)", fillcolor="#AAFFAA"]
        FXa_inhibition_rivaroxaban [label="FXa Inhibition\n(Rivaroxaban — direct)", fillcolor="#AAFFAA"]
        FIIa_inhibition_dabigatran [label="FIIa (Thrombin) Inhibition\n(Dabigatran — direct)", fillcolor="#AAFFAA"]
        VitK_reductase_inhibition_warfarin [label="Vitamin K Reductase Inhibition\n(Warfarin — indirect)", fillcolor="#AAFFAA"]
        INR_elevation  [label="INR Elevation\n(Warfarin anticoag. monitor)", fillcolor="#88CC88"]
        antiXa_activity [label="Anti-Xa Activity\n(DOAC monitoring)", fillcolor="#88CC88"]
    }

    // =====================================================================
    // CLUSTER 10: CLINICAL ENDPOINTS & BIOMARKERS
    // =====================================================================
    subgraph cluster_endpoints {
        label="Clinical Endpoints & Biomarkers"
        style=filled
        fillcolor="#F0FFF8"
        color="#007733"
        fontsize=13

        AF_burden      [label="AF Burden\n(% time in AF)", fillcolor="#77DDAA", shape=ellipse]
        heart_rate_control [label="Heart Rate Control\n(Target <110 bpm)", fillcolor="#77DDAA", shape=ellipse]
        ERP_ms         [label="Atrial ERP\n(ms — Electrophysiology)", fillcolor="#55CC99", shape=ellipse]
        QTc_ms         [label="QTc Interval\n(ms — ECG Safety)", fillcolor="#55CC99", shape=ellipse]
        NT_proBNP      [label="NT-proBNP\n(Heart Failure Biomarker)", fillcolor="#55CC99", shape=ellipse]
        troponin_I     [label="Troponin I\n(Myocardial Injury)", fillcolor="#55CC99", shape=ellipse]
        CRP_serum      [label="Serum CRP\n(Inflammation Biomarker)", fillcolor="#55CC99", shape=ellipse]
        LA_diameter    [label="LA Diameter\n(mm — Echo)", fillcolor="#77DDAA", shape=ellipse]
        LAA_velocity_TEE [label="LAA Flow Velocity\n(cm/s — TEE)", fillcolor="#77DDAA", shape=ellipse]
        LVEF           [label="LVEF (%)\n(Systolic Function)", fillcolor="#55CC99", shape=ellipse]
        stroke_risk_per_year [label="Stroke Risk\n(%/year — CHA₂DS₂-VASc)", fillcolor="#33BB88", shape=ellipse]
        bleeding_risk  [label="Bleeding Risk\n(HAS-BLED Score)", fillcolor="#FFBB88", shape=ellipse]
        AF_recurrence_rate [label="AF Recurrence Rate\n(Post-cardioversion)", fillcolor="#77DDAA", shape=ellipse]
        AF_progression [label="AF Progression\n(Parox→Persistent→Permanent)", fillcolor="#44AA77", shape=ellipse]
        cardioversion_success [label="Cardioversion Success\n(SR Maintenance %)", fillcolor="#77DDAA", shape=ellipse]
        eGFR_drug_dosing [label="eGFR\n(Renal Dose Adjustment)", fillcolor="#55CC99", shape=ellipse]
    }

    // =====================================================================
    // INTER-CLUSTER EDGES: Risk Factors → Electrical/Structural/Inflammation
    // =====================================================================
    HTN -- atrial_stretch [label="induces", style=solid]
    HTN -- AngII [label="activates", style=solid]
    heart_failure -- atrial_stretch [label="causes", style=solid]
    heart_failure -- NT_proBNP [label="elevates", style=solid]
    obesity -- sympathetic_activity [label="increases", style=solid]
    obesity -- AngII [label="↑ RAAS", style=solid]
    OSA -- sympathetic_activity [label="activates", style=solid]
    OSA -- ROS [label="hypoxia→", style=solid]
    T2DM -- AngII [label="activates", style=solid]
    T2DM -- TGF_beta1 [label="upregulates", style=solid]
    valvular_disease -- atrial_stretch [label="pressure overload", style=solid]
    hyperthyroidism -- HCN4 [label="upregulates If", style=solid]
    hyperthyroidism -- beta1AR [label="sensitizes", style=solid]
    alcohol -- NF_kB [label="activates", style=solid]
    alcohol -- ERP_shortening [label="shortens ERP", style=solid]
    aging -- atrial_fibrosis [label="promotes", style=solid]
    aging -- Cx40 [label="remodels", style=solid]
    genetic_variants_PITX2 -- focal_triggers_PV [label="PV sleeve↑", style=solid]
    genetic_variants_ZFHX3 -- atrial_fibrosis [label="promotes", style=solid]
    SCN5A_polymorphism -- Nav1_5 [label="alters", style=solid]
    atrial_stretch -- TGF_beta1 [label="mechanical→", style=solid]
    atrial_stretch -- Cx40 [label="remodels", style=solid]
    pericarditis -- NF_kB [label="activates", style=solid]
    post_surgery -- macrophage_infiltration [label="triggers", style=solid]

    // Risk → AF Endpoints
    CHA2DS2VASc -- stroke_risk_per_year [label="predicts", style=solid]
    HAS_BLED -- bleeding_risk [label="predicts", style=solid]

    // =====================================================================
    // ELECTRICAL REMODELING EDGES
    // =====================================================================
    Cav1_2 -- ERP_shortening [label="ICaL↓→ERP↓", style=solid]
    Kv1_5 -- ERP_shortening [label="IKur↑→ERP↓", style=solid]
    Kir3_1_3_4 -- ERP_shortening [label="IKACh→hyperpol", style=solid]
    ERP_shortening -- wavelength_shortening [label="shortens λ", style=solid]
    conduction_velocity_decrease -- wavelength_shortening [label="shortens λ", style=solid]
    Cx40 -- conduction_velocity_decrease [label="lateralization", style=solid]
    Cx43 -- conduction_velocity_decrease [label="remodeling", style=solid]
    atrial_fibrosis -- anisotropic_conduction [label="creates substrate", style=solid]
    anisotropic_conduction -- conduction_velocity_decrease [label="local slowing", style=solid]
    wavelength_shortening -- reentry_circuits [label="enables reentry", style=solid]
    reentry_circuits -- multiple_wavelets [label="degrades to", style=solid]
    focal_triggers_PV -- reentry_circuits [label="initiates AF", style=solid]
    DADs -- triggered_activity [label="from DADs", style=solid]
    EADs -- triggered_activity [label="from EADs", style=solid]
    triggered_activity -- focal_triggers_PV [label="triggers PV firing", style=solid]
    multiple_wavelets -- AF_burden [label="maintains AF", style=solid]
    reentry_circuits -- AF_burden [label="drives AF", style=solid]

    // =====================================================================
    // Ca²⁺ HANDLING EDGES
    // =====================================================================
    LTCC -- SR_Ca_overload [label="Ca²⁺ entry", style=solid]
    NCX1 -- SR_Ca_overload [label="reverse mode", style=solid]
    SERCA2a -- SR_Ca_overload [label="SR refilling", style=solid]
    PLN -- SERCA2a [label="inhibits", style=dashed]
    RyR2 -- SOICR [label="spontaneous release", style=solid]
    SR_Ca_overload -- SOICR [label="triggers SOICR", style=solid]
    SOICR -- DADs [label="NCX→DAD", style=solid]
    CaM -- CaMKII [label="activates", style=solid]
    CaMKII -- RyR2 [label="phospho-Ser2814", style=solid]
    CaMKII -- PLN_phosphorylation [label="Thr17", style=solid]
    oxidized_CaMKII -- RyR2 [label="hyper-activates", style=solid]
