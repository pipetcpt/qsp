digraph AF_QSP {
    rankdir=LR;
    graph [fontname="Helvetica" fontsize=11 bgcolor="#f8f9fa" pad=0.5 nodesep=0.4 ranksep=1.2 splines=true layout=neato overlap=false];
    node  [fontname="Helvetica" fontsize=9 style=filled shape=box width=1.5 height=0.45];
    edge  [fontname="Helvetica" fontsize=7 arrowsize=0.7];

    /* =========================================================
       CLUSTER 0: Risk Factors & Triggers
    ========================================================= */
    subgraph cluster_0 {
        label="Risk Factors & Triggers";
        style=filled; fillcolor="#e8f5e9"; color="#388e3c"; fontsize=13; fontcolor="#1b5e20"; penwidth=2;

        pv_ectopy            [label="PV Ectopic Foci"           fillcolor="#a5d6a7"];
        ca_overload          [label="Ca2+ Overload"             fillcolor="#a5d6a7"];
        ead                  [label="Early Afterdepolarization\n(EAD)"  fillcolor="#a5d6a7"];
        dad                  [label="Delayed Afterdepolarization\n(DAD)" fillcolor="#a5d6a7"];
        triggered_activity   [label="Triggered Activity"        fillcolor="#a5d6a7"];
        sac_stretch          [label="Stretch-Activated Channels\n(SAC)" fillcolor="#a5d6a7"];
        adrenergic_trigger   [label="Adrenergic Trigger"        fillcolor="#a5d6a7"];
        vagal_trigger        [label="Vagal Trigger"             fillcolor="#a5d6a7"];
        ryr2_dysreg          [label="RyR2 Dysregulation"        fillcolor="#a5d6a7"];
        camkii_overact       [label="CaMKII Overactivation"     fillcolor="#a5d6a7"];
        oxidative_ca_leak    [label="Oxidative Ca2+ Leak"       fillcolor="#a5d6a7"];
        microreentry         [label="Micro-reentry Circuit"     fillcolor="#a5d6a7"];
    }

    /* =========================================================
       CLUSTER 1: Ion Channel Physiology
    ========================================================= */
    subgraph cluster_1 {
        label="Ion Channel Physiology";
        style=filled; fillcolor="#e3f2fd"; color="#1565c0"; fontsize=13; fontcolor="#0d47a1"; penwidth=2;

        ina_channel          [label="INa (Nav1.5)"              fillcolor="#90caf9"];
        ical_channel         [label="ICaL (Cav1.2)"             fillcolor="#90caf9"];
        icat_channel         [label="ICaT (Cav3.x)"             fillcolor="#90caf9"];
        ikr_channel          [label="IKr (hERG / Kv11.1)"      fillcolor="#90caf9"];
        iks_channel          [label="IKs (Kv7.1)"               fillcolor="#90caf9"];
        ik1_channel          [label="IK1 (Kir2.x)"              fillcolor="#90caf9"];
        ito_channel          [label="Ito (Kv4.x)"               fillcolor="#90caf9"];
        if_channel           [label="If (HCN4) - Funny"        fillcolor="#90caf9"];
        ikach_channel        [label="IKACh (Kir3.x)"            fillcolor="#90caf9"];
        ikur_channel         [label="IKur (Kv1.5) - Atrial"    fillcolor="#90caf9"];
        ncx_exchanger        [label="NCX (Na+/Ca2+ Exchanger)"  fillcolor="#90caf9"];
        nak_atpase           [label="Na+/K+-ATPase"             fillcolor="#90caf9"];
        serca_pump           [label="SERCA2a Pump"              fillcolor="#90caf9"];
        ryr2_channel         [label="RyR2 Ca2+ Release Channel" fillcolor="#90caf9"];
        camkii_kinase        [label="CaMKII Kinase Activity"    fillcolor="#90caf9"];
        calmodulin_ca        [label="Calmodulin-Ca2+ Complex"   fillcolor="#90caf9"];
    }

    /* =========================================================
       CLUSTER 2: Electrical Remodeling
    ========================================================= */
    subgraph cluster_2 {
        label="Electrical Remodeling";
        style=filled; fillcolor="#fff3e0"; color="#e65100"; fontsize=13; fontcolor="#bf360c"; penwidth=2;

        aerp                  [label="Atrial ERP (AERP)"        fillcolor="#ffcc80"];
        apd                   [label="Action Potential Duration\n(APD)" fillcolor="#ffcc80"];
        conduction_velocity   [label="Conduction Velocity (CV)" fillcolor="#ffcc80"];
        aerp_shortening       [label="AERP Shortening"          fillcolor="#ffcc80"];
        cv_aerp_wavelength    [label="Wavelength (CV x AERP)"   fillcolor="#ffcc80"];
        rate_adaptation_loss  [label="Loss of Rate Adaptation"  fillcolor="#ffcc80"];
        electrical_heterogeneity [label="Electrical Heterogeneity" fillcolor="#ffcc80"];
        atrial_cv_slowing     [label="Atrial CV Slowing"        fillcolor="#ffcc80"];
        fibrillatory_rate     [label="Fibrillatory Rate"        fillcolor="#ffcc80"];
        rotor_stabilization   [label="Rotor Stabilization"      fillcolor="#ffcc80"];
    }

    /* =========================================================
       CLUSTER 3: Structural Remodeling & Fibrosis
    ========================================================= */
    subgraph cluster_3 {
        label="Structural Remodeling & Fibrosis";
        style=filled; fillcolor="#fce4ec"; color="#880e4f"; fontsize=13; fontcolor="#4a148c"; penwidth=2;

        atrial_fibrosis       [label="Atrial Fibrosis"          fillcolor="#f48fb1"];
        fibroblast_activation [label="Fibroblast Activation"    fillcolor="#f48fb1"];
        tgfb1                 [label="TGF-b1 Signaling"         fillcolor="#f48fb1"];
        angII_fibrosis        [label="Ang II -> Fibrosis"        fillcolor="#f48fb1"];
        collagen_deposition   [label="Collagen Deposition\n(I/III)" fillcolor="#f48fb1"];
        mmp_timp_imbalance    [label="MMP/TIMP Imbalance"       fillcolor="#f48fb1"];
        atrial_dilation       [label="Atrial Dilation"          fillcolor="#f48fb1"];
        lav_enlargement       [label="LA Volume Enlargement"    fillcolor="#f48fb1"];
        myocyte_apoptosis     [label="Myocyte Apoptosis"        fillcolor="#f48fb1"];
        cx40_remodeling       [label="Cx40 Gap Junction\nRemodeling" fillcolor="#f48fb1"];
        cx43_remodeling       [label="Cx43 Gap Junction\nRemodeling" fillcolor="#f48fb1"];
        eat_adipose           [label="Epicardial Adipose Tissue\n(EAT)" fillcolor="#f48fb1"];
        eat_fibrosis_cytokines [label="EAT Fibrotic Cytokines"  fillcolor="#f48fb1"];
    }

    /* =========================================================
       CLUSTER 4: Neurohormonal Axis
    ========================================================= */
    subgraph cluster_4 {
        label="Neurohormonal Axis (RAAS/SNS)";
        style=filled; fillcolor="#f3e5f5"; color="#6a1b9a"; fontsize=13; fontcolor="#4a148c"; penwidth=2;

        raas_activation       [label="RAAS Activation"          fillcolor="#ce93d8"];
        renin                 [label="Renin Release"            fillcolor="#ce93d8"];
        angiotensinI          [label="Angiotensin I"            fillcolor="#ce93d8"];
        ace_enzyme            [label="ACE Enzyme"               fillcolor="#ce93d8"];
        angiotensinII         [label="Angiotensin II (Ang II)"  fillcolor="#ce93d8"];
        at1r_signaling        [label="AT1R Signaling"           fillcolor="#ce93d8"];
        aldosterone           [label="Aldosterone"              fillcolor="#ce93d8"];
        anp_bnp               [label="ANP/BNP Release"          fillcolor="#ce93d8"];
        sns_activation        [label="SNS Activation"           fillcolor="#ce93d8"];
        norepinephrine        [label="Norepinephrine Release"   fillcolor="#ce93d8"];
        catecholamine_arrhythmia [label="Catecholamine -> Arrhythmia" fillcolor="#ce93d8"];
        parasympathetic_tone  [label="Parasympathetic Tone\n(Vagal)" fillcolor="#ce93d8"];
    }

    /* =========================================================
       CLUSTER 5: Inflammation & Oxidative Stress
    ========================================================= */
    subgraph cluster_5 {
        label="Inflammation & Oxidative Stress";
        style=filled; fillcolor="#fff8e1"; color="#f57f17"; fontsize=13; fontcolor="#e65100"; penwidth=2;

        crp_elevation         [label="CRP Elevation"            fillcolor="#ffe082"];
        il6                   [label="IL-6"                     fillcolor="#ffe082"];
        tnf_alpha             [label="TNF-alpha"                fillcolor="#ffe082"];
        nfkb_pathway          [label="NF-kB Pathway"            fillcolor="#ffe082"];
        ros_production        [label="ROS Production"           fillcolor="#ffe082"];
        nadph_oxidase         [label="NADPH Oxidase (Nox2/4)"  fillcolor="#ffe082"];
        mito_dysfunction      [label="Mitochondrial Dysfunction" fillcolor="#ffe082"];
        nlrp3_inflammasome    [label="NLRP3 Inflammasome"       fillcolor="#ffe082"];
        macrophage_infiltration [label="Macrophage Infiltration" fillcolor="#ffe082"];
        fibrotic_cytokines    [label="Pro-fibrotic Cytokines"   fillcolor="#ffe082"];
    }

    /* =========================================================
       CLUSTER 6: Thromboembolism & Stroke Risk
    ========================================================= */
    subgraph cluster_6 {
        label="Thromboembolism & Stroke Risk";
        style=filled; fillcolor="#ffebee"; color="#b71c1c"; fontsize=13; fontcolor="#7f0000"; penwidth=2;

        virchow_stasis        [label="Blood Stasis (Virchow)"   fillcolor="#ef9a9a"];
        endothelial_dysfunction [label="Endothelial Dysfunction" fillcolor="#ef9a9a"];
        hypercoagulable       [label="Hypercoagulable State"    fillcolor="#ef9a9a"];
        laa_thrombus          [label="LAA Thrombus Formation"   fillcolor="#ef9a9a"];
        platelet_activation   [label="Platelet Activation"      fillcolor="#ef9a9a"];
        vwf                   [label="vWF Elevation"            fillcolor="#ef9a9a"];
        thrombin_generation   [label="Thrombin Generation"      fillcolor="#ef9a9a"];
        factor_xa             [label="Factor Xa Activity"       fillcolor="#ef9a9a"];
        fibrin_clot           [label="Fibrin Clot Formation"    fillcolor="#ef9a9a"];
        ddimer                [label="D-dimer Elevation"        fillcolor="#ef9a9a"];
        chads2vasc_score      [label="CHA2DS2-VASc Score"       fillcolor="#ef9a9a"];
        stroke_risk           [label="Stroke / Systemic Embolism\nRisk" fillcolor="#ef9a9a"];
    }

    /* =========================================================
       CLUSTER 7: Rate Control Drugs
    ========================================================= */
    subgraph cluster_7 {
        label="Rate Control Drugs (PK/PD)";
        style=filled; fillcolor="#fffde7"; color="#f9a825"; fontsize=13; fontcolor="#f57f17"; penwidth=2;

        metoprolol_pk         [label="Metoprolol PK\n(Cmax/AUC/t1/2)" fillcolor="#fff176"];
        metoprolol_beta1_block [label="Beta1-Receptor Blockade\n(Metoprolol)" fillcolor="#fff176"];
        av_node_slowing_rate  [label="AV Node Slowing\n(Rate)" fillcolor="#fff176"];
        diltiazem_pk          [label="Diltiazem PK\n(Cmax/AUC/t1/2)" fillcolor="#fff176"];
        diltiazem_ccb_av      [label="CCB: AV Nodal ICaL Block\n(Diltiazem)" fillcolor="#fff176"];
        digoxin_pk            [label="Digoxin PK\n(Vd/t1/2/renal CL)" fillcolor="#fff176"];
        digoxin_nakpump_inhib [label="Na+/K+-ATPase Inhibition\n(Digoxin)" fillcolor="#fff176"];
        ivabradine_pk         [label="Ivabradine PK\n(Cmax/AUC)" fillcolor="#fff176"];
        ivabradine_if_block   [label="If Channel Block\n(Ivabradine)" fillcolor="#fff176"];
        heart_rate_control    [label="Target Heart Rate <=80 bpm\n(Control)" fillcolor="#fff176"];
    }

    /* =========================================================
       CLUSTER 8: Rhythm Control Drugs
    ========================================================= */
    subgraph cluster_8 {
        label="Rhythm Control Drugs (PK/PD)";
        style=filled; fillcolor="#e8eaf6"; color="#283593"; fontsize=13; fontcolor="#1a237e"; penwidth=2;

        flecainide_pk         [label="Flecainide PK\n(Class IC)"    fillcolor="#9fa8da"];
        flecainide_ina_block  [label="INa Block (Flecainide)\nAPD in His-Purkinje" fillcolor="#9fa8da"];
        propafenone_pk        [label="Propafenone PK\n(Class IC)"   fillcolor="#9fa8da"];
        propafenone_multichannel [label="Multi-channel Block\n(Propafenone)" fillcolor="#9fa8da"];
        amiodarone_pk         [label="Amiodarone PK\n(Class III, t1/2 weeks)" fillcolor="#9fa8da"];
        amiodarone_multichannel [label="Multi-channel Block\n(Amiodarone)" fillcolor="#9fa8da"];
        amiodarone_beta_block [label="Non-competitive Beta-Block\n(Amiodarone)" fillcolor="#9fa8da"];
        dronedarone_pk        [label="Dronedarone PK\n(Class III)" fillcolor="#9fa8da"];
        dronedarone_multichannel [label="Multi-channel Block\n(Dronedarone)" fillcolor="#9fa8da"];
        sotalol_pk            [label="Sotalol PK\n(Class III/II)"  fillcolor="#9fa8da"];
        sotalol_ikr_beta      [label="IKr Block + Beta-Block\n(Sotalol)" fillcolor="#9fa8da"];
        vernakalant_pk        [label="Vernakalant PK\n(Atrial-selective)" fillcolor="#9fa8da"];
        vernakalant_ina_ikur  [label="INa + IKur Block\n(Vernakalant)" fillcolor="#9fa8da"];
        dofetilide_pk         [label="Dofetilide PK\n(Class III)"  fillcolor="#9fa8da"];
    }

    /* =========================================================
       CLUSTER 9: Anticoagulation
    ========================================================= */
    subgraph cluster_9 {
        label="Anticoagulation (PK/PD)";
        style=filled; fillcolor="#e0f7fa"; color="#006064"; fontsize=13; fontcolor="#004d40"; penwidth=2;

        warfarin_pk           [label="Warfarin PK\n(CYP2C9/VKORC1)" fillcolor="#80deea"];
        vkor_inhibition       [label="VKORC1 Inhibition\n(Warfarin)" fillcolor="#80deea"];
        vitk_cycle            [label="Vitamin K Cycle\nInterruption" fillcolor="#80deea"];
        inr_monitoring        [label="INR Monitoring\n(Target 2-3)"  fillcolor="#80deea"];
        apixaban_pk           [label="Apixaban PK\n(Factor Xa Inhib)" fillcolor="#80deea"];
        rivaroxaban_pk        [label="Rivaroxaban PK\n(Factor Xa Inhib)" fillcolor="#80deea"];
        edoxaban_pk           [label="Edoxaban PK\n(Factor Xa Inhib)" fillcolor="#80deea"];
        dabigatran_pk         [label="Dabigatran PK\n(DTI)" fillcolor="#80deea"];
        factor_xa_inhibition  [label="Factor Xa Inhibition\n(DOACs)" fillcolor="#80deea"];
        direct_thrombin_inhib [label="Direct Thrombin Inhibition\n(Dabigatran)" fillcolor="#80deea"];
        net_clinical_benefit  [label="Net Clinical Benefit\n(Stroke down vs Bleed up)" fillcolor="#80deea"];
    }

    /* =========================================================
       CLUSTER 10: Clinical Outcomes
    ========================================================= */
    subgraph cluster_10 {
        label="Clinical Outcomes";
        style=filled; fillcolor="#fbe9e7"; color="#bf360c"; fontsize=13; fontcolor="#870000"; penwidth=2;

        af_recurrence         [label="AF Recurrence"            fillcolor="#ffccbc"];
        af_burden             [label="AF Burden (% time in AF)" fillcolor="#ffccbc"];
        dccv_success          [label="DCCV Success Rate"        fillcolor="#ffccbc"];
        rhythm_maintenance    [label="Sinus Rhythm Maintenance" fillcolor="#ffccbc"];
        stroke_reduction      [label="Stroke Reduction (%)"     fillcolor="#ffccbc"];
        cv_mortality          [label="CV Mortality"             fillcolor="#ffccbc"];
        cv_hospitalization    [label="CV Hospitalization Rate"  fillcolor="#ffccbc"];
        qol_improvement       [label="QoL Improvement\n(SF-36/AFEQT)" fillcolor="#ffccbc"];
        exercise_tolerance    [label="Exercise Tolerance\n(6MWT/VO2max)" fillcolor="#ffccbc"];
        functional_status     [label="Functional Status\n(NYHA)" fillcolor="#ffccbc"];
    }

    /* =========================================================
       CLUSTER 11: Comorbidities
    ========================================================= */
    subgraph cluster_11 {
        label="Comorbidities";
        style=filled; fillcolor="#efebe9"; color="#4e342e"; fontsize=13; fontcolor="#3e2723"; penwidth=2;

        htn_comorbid          [label="Hypertension"             fillcolor="#d7ccc8"];
        heart_failure_comorbid [label="Heart Failure\n(HFrEF/HFpEF)" fillcolor="#d7ccc8"];
        cad_comorbid          [label="Coronary Artery Disease"  fillcolor="#d7ccc8"];
        dm_comorbid           [label="Diabetes Mellitus"        fillcolor="#d7ccc8"];
        ckd_comorbid          [label="Chronic Kidney Disease"   fillcolor="#d7ccc8"];
        valvular_disease      [label="Valvular Heart Disease"   fillcolor="#d7ccc8"];
        osa_comorbid          [label="Obstructive Sleep Apnea"  fillcolor="#d7ccc8"];
        hyperthyroidism       [label="Hyperthyroidism"          fillcolor="#d7ccc8"];
    }

    /* ==========================================================
       INTER-CLUSTER EDGES
    ========================================================== */

    /* --- Cluster 0 (Risk Factors) -> Cluster 1 (Ion Channels) --- */
    pv_ectopy            -> ina_channel          [label="Nav1.5 activation" color="#2e7d32"];
    ca_overload          -> ical_channel         [label="ICaL activation"   color="#2e7d32"];
    ca_overload          -> ryr2_channel         [label="SR Ca2+ release"   color="#2e7d32"];
    ca_overload          -> ncx_exchanger        [label="INCX up"           color="#2e7d32"];
    ead                  -> ical_channel         [label="ICaL window current" color="#2e7d32"];
    dad                  -> ncx_exchanger        [label="DAD via INCX"      color="#2e7d32"];
    ryr2_dysreg          -> ryr2_channel         [label="leaky RyR2"        color="#2e7d32"];
    camkii_overact       -> camkii_kinase        [label="CaMKII activity"   color="#2e7d32"];
    oxidative_ca_leak    -> ryr2_channel         [label="oxidation->leak"   color="#2e7d32"];
    sac_stretch          -> ical_channel         [label="mechano-sensitive" color="#2e7d32"];
    adrenergic_trigger   -> if_channel           [label="cAMP->If up"       color="#2e7d32"];
    vagal_trigger        -> ikach_channel        [label="ACh->IKACh"        color="#2e7d32"];

    /* --- Cluster 0 -> Cluster 2 (Electrical Remodeling) --- */
    triggered_activity   -> aerp_shortening      [label="remodeling initiation" color="#2e7d32"];
    microreentry         -> rotor_stabilization  [label="reentry sustain"   color="#2e7d32"];

    /* --- Cluster 1 (Ion Channels) -> Cluster 2 (Electrical Remodeling) --- */
    ical_channel         -> aerp_shortening      [label="ICaL down->APD down" color="#1565c0"];
    ikr_channel          -> apd                  [label="IKr->repolarization" color="#1565c0"];
    iks_channel          -> aerp                 [label="IKs->AERP"          color="#1565c0"];
    ik1_channel          -> conduction_velocity  [label="IK1->resting Vm"   color="#1565c0"];
    ina_channel          -> conduction_velocity  [label="INa->CV"            color="#1565c0"];
    ikur_channel         -> aerp_shortening      [label="IKur(atrial)->APD down" color="#1565c0"];
    ikach_channel        -> aerp_shortening      [label="IKACh->AERP down"  color="#1565c0"];
    ncx_exchanger        -> ead                  [label="NCX depol->EAD"    color="#1565c0"];
    serca_pump           -> ca_overload          [label="SERCA down->Ca2+ up" color="#1565c0" constraint=false];
    camkii_kinase        -> ical_channel         [label="CaMKII phospho"    color="#1565c0"];
    camkii_kinase        -> ryr2_channel         [label="RyR2 phospho"      color="#1565c0"];
    calmodulin_ca        -> camkii_kinase        [label="Ca-CaM activation" color="#1565c0"];
    ryr2_channel         -> ca_overload          [label="SR leak"           color="#1565c0" constraint=false];
    icat_channel         -> ca_overload          [label="ICaT->Ca2+ entry"  color="#1565c0"];
    ito_channel          -> apd                  [label="Ito->phase 1 repol" color="#1565c0"];
    nak_atpase           -> ncx_exchanger        [label="Na+ gradient"      color="#1565c0"];

    /* --- Cluster 2 -> Cluster 2 internal --- */
    aerp_shortening      -> cv_aerp_wavelength   [label="WL = CV x AERP"   color="#e65100"];
    atrial_cv_slowing    -> cv_aerp_wavelength   [label="CV component"      color="#e65100"];
    cv_aerp_wavelength   -> rotor_stabilization  [label="short WL->rotors" color="#e65100"];
    rotor_stabilization  -> fibrillatory_rate    [label="high freq drivers" color="#e65100"];
    electrical_heterogeneity -> microreentry     [label="substrate"         color="#e65100"];
    rate_adaptation_loss -> electrical_heterogeneity [label="->hetero up"  color="#e65100"];
    aerp                 -> aerp_shortening      [label="baseline AERP"     color="#e65100"];
    apd                  -> aerp                 [label="APD determines AERP" color="#e65100"];

    /* --- Cluster 3 (Structural) -> Cluster 2 --- */
    atrial_fibrosis      -> atrial_cv_slowing    [label="fibrosis->CV down" color="#880e4f"];
    cx40_remodeling      -> conduction_velocity  [label="Cx40 down->CV down" color="#880e4f"];
    cx43_remodeling      -> electrical_heterogeneity [label="hetero gap jxn" color="#880e4f"];
    lav_enlargement      -> aerp                 [label="stretch->AERP down" color="#880e4f"];
    atrial_fibrosis      -> electrical_heterogeneity [label="barrier->hetero" color="#880e4f"];
    myocyte_apoptosis    -> atrial_fibrosis       [label="apop->fibrosis"   color="#880e4f"];

    /* --- Cluster 4 (Neurohormonal) -> Cluster 3 --- */
    raas_activation      -> renin                [label="baroreceptor down" color="#6a1b9a"];
    renin                -> angiotensinI         [label="angiotensinogen->I" color="#6a1b9a"];
    angiotensinI         -> ace_enzyme           [label="ACE converts"      color="#6a1b9a"];
    ace_enzyme           -> angiotensinII        [label="->Ang II"          color="#6a1b9a"];
    angiotensinII        -> at1r_signaling       [label="AT1R binding"      color="#6a1b9a"];
    at1r_signaling       -> angII_fibrosis       [label="pro-fibrotic"      color="#6a1b9a"];
    angII_fibrosis       -> tgfb1               [label="Ang II->TGF-b1"    color="#6a1b9a"];
    tgfb1               -> fibroblast_activation [label="TGF-b1->fibroblast" color="#6a1b9a"];
    fibroblast_activation -> collagen_deposition [label="ECM production up" color="#6a1b9a"];
    collagen_deposition  -> atrial_fibrosis      [label="fibrosis"          color="#6a1b9a"];
    atrial_fibrosis      -> atrial_dilation      [label="stiffness->dilation" color="#6a1b9a"];
    atrial_dilation      -> lav_enlargement      [label="LA volume up"      color="#6a1b9a"];
    at1r_signaling       -> aldosterone          [label="->aldosterone"     color="#6a1b9a"];
    aldosterone          -> atrial_fibrosis      [label="MR->fibrosis"      color="#6a1b9a"];
    anp_bnp              -> raas_activation      [label="ANP inhibits RAAS" color="#6a1b9a" style=dashed constraint=false];
    sns_activation       -> norepinephrine       [label="sympathetic efferent" color="#6a1b9a"];
    norepinephrine       -> adrenergic_trigger   [label="beta-AR stim"      color="#6a1b9a"];
    norepinephrine       -> catecholamine_arrhythmia [label="arrhythmia risk" color="#6a1b9a"];
    catecholamine_arrhythmia -> camkii_overact  [label="beta-AR->CaMKII up" color="#6a1b9a"];
    parasympathetic_tone -> vagal_trigger        [label="ACh release"       color="#6a1b9a"];
    angiotensinII        -> ros_production       [label="Ang II->Nox"       color="#6a1b9a"];
    angiotensinII        -> nfkb_pathway         [label="Ang II->NF-kB"    color="#6a1b9a"];

    /* --- Cluster 5 (Inflammation) -> Cluster 3 --- */
    nfkb_pathway         -> il6                  [label="NF-kB->IL-6"       color="#f57f17"];
    nfkb_pathway         -> tnf_alpha            [label="NF-kB->TNF-a"     color="#f57f17"];
    il6                  -> crp_elevation        [label="acute phase"       color="#f57f17"];
    ros_production       -> nadph_oxidase        [label="Nox2 activated"    color="#f57f17"];
    nadph_oxidase        -> mito_dysfunction     [label="ROS->mito stress"  color="#f57f17"];
    mito_dysfunction     -> nlrp3_inflammasome   [label="DAMP release"      color="#f57f17"];
    nlrp3_inflammasome   -> il6                  [label="IL-1b/IL-18->IL-6" color="#f57f17"];
    macrophage_infiltration -> fibrotic_cytokines [label="M2->TGF-b/IL-13" color="#f57f17"];
    fibrotic_cytokines   -> fibroblast_activation [label="pro-fibrotic"     color="#f57f17"];
    ros_production       -> oxidative_ca_leak    [label="ROS->RyR2 oxidation" color="#f57f17"];
    tnf_alpha            -> mmp_timp_imbalance   [label="MMP up, TIMP down" color="#f57f17"];
    mmp_timp_imbalance   -> collagen_deposition  [label="ECM remodeling"    color="#f57f17"];
    eat_adipose          -> eat_fibrosis_cytokines [label="paracrine EAT"   color="#f57f17"];
    eat_fibrosis_cytokines -> atrial_fibrosis    [label="EAT->fibrosis"     color="#f57f17"];
    eat_fibrosis_cytokines -> nfkb_pathway       [label="inflammatory sig"  color="#f57f17"];
    il6                  -> atrial_fibrosis      [label="IL-6->fibrosis"    color="#f57f17"];
    nfkb_pathway         -> camkii_overact       [label="inflamm->CaMKII"   color="#f57f17"];
    ros_production       -> ina_channel          [label="ROS->INa down"     color="#f57f17"];
    ros_production       -> serca_pump           [label="ROS->SERCA down"   color="#f57f17"];

    /* --- Cluster 6 (Thromboembolism) --- */
    lav_enlargement      -> virchow_stasis       [label="LA stasis"         color="#b71c1c"];
    virchow_stasis       -> laa_thrombus         [label="LAA stasis"        color="#b71c1c"];
    endothelial_dysfunction -> vwf              [label="endothelium->vWF"   color="#b71c1c"];
    endothelial_dysfunction -> platelet_activation [label="->platelet act"  color="#b71c1c"];
    hypercoagulable      -> thrombin_generation  [label="coag cascade"      color="#b71c1c"];
    factor_xa            -> thrombin_generation  [label="Xa->thrombin"      color="#b71c1c"];
    thrombin_generation  -> fibrin_clot          [label="fibrinogen->fibrin" color="#b71c1c"];
    fibrin_clot          -> laa_thrombus         [label="clot in LAA"       color="#b71c1c"];
    laa_thrombus         -> stroke_risk          [label="embolism risk"     color="#b71c1c"];
    ddimer               -> hypercoagulable      [label="D-dimer marker"    color="#b71c1c" constraint=false];
    chads2vasc_score     -> stroke_risk          [label="risk stratification" color="#b71c1c"];
    atrial_fibrosis      -> endothelial_dysfunction [label="fibrosis->endo" color="#b71c1c"];
    platelet_activation  -> thrombin_generation  [label="platelet->coag"    color="#b71c1c"];
    vwf                  -> platelet_activation  [label="vWF->platelet"     color="#b71c1c"];

    /* --- Cluster 7 (Rate Control Drugs) --- */
    metoprolol_pk        -> metoprolol_beta1_block [label="PK->PD"          color="#f9a825"];
    metoprolol_beta1_block -> av_node_slowing_rate [label="beta1 block->AV down" color="#f9a825"];
    metoprolol_beta1_block -> adrenergic_trigger  [label="adrenergic trig down" color="#f9a825" style=dashed];
    diltiazem_pk         -> diltiazem_ccb_av      [label="PK->PD"          color="#f9a825"];
    diltiazem_ccb_av     -> ical_channel          [label="ICaL block AV"    color="#f9a825"];
    diltiazem_ccb_av     -> av_node_slowing_rate  [label="AV node block"    color="#f9a825"];
    digoxin_pk           -> digoxin_nakpump_inhib [label="PK->PD"          color="#f9a825"];
    digoxin_nakpump_inhib -> nak_atpase           [label="NaK-ATPase inhib" color="#f9a825"];
    digoxin_nakpump_inhib -> parasympathetic_tone [label="vagotonic"        color="#f9a825"];
    ivabradine_pk        -> ivabradine_if_block   [label="PK->PD"          color="#f9a825"];
    ivabradine_if_block  -> if_channel            [label="If block->HR down" color="#f9a825"];
    av_node_slowing_rate -> heart_rate_control    [label="->HR control"    color="#f9a825"];
    ivabradine_if_block  -> heart_rate_control    [label="->HR control"    color="#f9a825"];

    /* --- Cluster 8 (Rhythm Control) --- */
    flecainide_pk        -> flecainide_ina_block  [label="PK->PD"          color="#283593"];
    flecainide_ina_block -> ina_channel           [label="INa block"        color="#283593"];
    flecainide_ina_block -> conduction_velocity   [label="CV down"          color="#283593"];
    propafenone_pk       -> propafenone_multichannel [label="PK->PD"       color="#283593"];
    propafenone_multichannel -> ina_channel       [label="INa block"        color="#283593"];
    propafenone_multichannel -> ikr_channel       [label="IKr block"        color="#283593"];
    amiodarone_pk        -> amiodarone_multichannel [label="PK->PD"        color="#283593"];
    amiodarone_multichannel -> ikr_channel        [label="IKr block"        color="#283593"];
    amiodarone_multichannel -> iks_channel        [label="IKs block"        color="#283593"];
    amiodarone_multichannel -> ina_channel        [label="INa block"        color="#283593"];
    amiodarone_multichannel -> ical_channel       [label="ICaL block"       color="#283593"];
    amiodarone_beta_block -> adrenergic_trigger   [label="beta block"       color="#283593" style=dashed];
    dronedarone_pk       -> dronedarone_multichannel [label="PK->PD"       color="#283593"];
    dronedarone_multichannel -> ikr_channel       [label="IKr block"        color="#283593"];
    dronedarone_multichannel -> ina_channel       [label="INa block"        color="#283593"];
    sotalol_pk           -> sotalol_ikr_beta      [label="PK->PD"          color="#283593"];
    sotalol_ikr_beta     -> ikr_channel           [label="IKr block"        color="#283593"];
    sotalol_ikr_beta     -> adrenergic_trigger    [label="beta block"       color="#283593" style=dashed];
    vernakalant_pk       -> vernakalant_ina_ikur  [label="PK->PD"          color="#283593"];
    vernakalant_ina_ikur -> ina_channel           [label="INa block (atrial)" color="#283593"];
    vernakalant_ina_ikur -> ikur_channel          [label="IKur block"       color="#283593"];
    dofetilide_pk        -> ikr_channel           [label="selective IKr down" color="#283593"];
    aerp_shortening      -> af_recurrence         [label="AERP down->AF up" color="#283593"];
    rotor_stabilization  -> af_burden             [label="rotors->burden"   color="#283593"];
    flecainide_ina_block -> af_recurrence         [label="AF recur down"    color="#283593" style=dashed];
    amiodarone_multichannel -> rhythm_maintenance [label="sinus maint up"   color="#283593"];
    dronedarone_multichannel -> cv_hospitalization [label="CV admit down"   color="#283593"];

    /* --- Cluster 9 (Anticoagulation) --- */
    warfarin_pk          -> vkor_inhibition       [label="PK->PD"          color="#006064"];
    vkor_inhibition      -> vitk_cycle            [label="VKORC1 inhib"    color="#006064"];
    vitk_cycle           -> inr_monitoring        [label="->INR"           color="#006064"];
    inr_monitoring       -> net_clinical_benefit  [label="therapeutic range" color="#006064"];
    apixaban_pk          -> factor_xa_inhibition  [label="PK->PD"          color="#006064"];
    rivaroxaban_pk       -> factor_xa_inhibition  [label="PK->PD"          color="#006064"];
    edoxaban_pk          -> factor_xa_inhibition  [label="PK->PD"          color="#006064"];
    dabigatran_pk        -> direct_thrombin_inhib [label="PK->PD"          color="#006064"];
    factor_xa_inhibition -> factor_xa             [label="Xa down"         color="#006064" style=dashed];
    direct_thrombin_inhib -> thrombin_generation  [label="thrombin down"   color="#006064" style=dashed];
    factor_xa_inhibition -> net_clinical_benefit  [label="stroke down"     color="#006064"];
    direct_thrombin_inhib -> net_clinical_benefit [label="stroke down"     color="#006064"];
    chads2vasc_score     -> net_clinical_benefit  [label="anticoag decision" color="#006064"];

    /* --- Cluster 10 (Clinical Outcomes) --- */
    heart_rate_control   -> cv_hospitalization    [label="rate ctrl->admit down" color="#bf360c"];
    heart_rate_control   -> exercise_tolerance    [label="exercise cap up"  color="#bf360c"];
    net_clinical_benefit -> stroke_reduction      [label="DOAC effect"      color="#bf360c"];
    stroke_risk          -> cv_mortality          [label="stroke->mort"     color="#bf360c"];
    stroke_reduction     -> cv_mortality          [label="mortality down"   color="#bf360c" style=dashed];
    rhythm_maintenance   -> qol_improvement       [label="SR->QoL up"      color="#bf360c"];
    rhythm_maintenance   -> af_burden             [label="burden down"      color="#bf360c" style=dashed];
    dccv_success         -> rhythm_maintenance    [label="post-DCCV"        color="#bf360c"];
    af_burden            -> cv_hospitalization    [label="burden up->admit" color="#bf360c"];
    af_recurrence        -> af_burden             [label="recurrence->burden" color="#bf360c"];
    functional_status    -> qol_improvement       [label="NYHA->QoL"        color="#bf360c"];
    exercise_tolerance   -> functional_status     [label="exercise->function" color="#bf360c"];
    cv_mortality         -> functional_status     [label="mortality driver"  color="#bf360c"];
    af_burden            -> sns_activation        [label="AF->SNS up"       color="#bf360c" constraint=false];
    af_recurrence        -> heart_failure_comorbid [label="AF->HF"          color="#bf360c" constraint=false];

    /* --- Cluster 11 (Comorbidities) --- */
    htn_comorbid         -> raas_activation       [label="HTN->RAAS"        color="#4e342e"];
    htn_comorbid         -> sac_stretch           [label="wall stress up"   color="#4e342e"];
    htn_comorbid         -> lav_enlargement       [label="pressure overload" color="#4e342e"];
    htn_comorbid         -> chads2vasc_score      [label="CHA2DS2 H=1"     color="#4e342e"];
    heart_failure_comorbid -> anp_bnp             [label="HF->ANP/BNP up"  color="#4e342e"];
    heart_failure_comorbid -> sns_activation      [label="HF->SNS up"      color="#4e342e"];
    heart_failure_comorbid -> atrial_dilation     [label="LA pressure up"  color="#4e342e"];
    heart_failure_comorbid -> chads2vasc_score    [label="CHA2DS2 C=1"    color="#4e342e"];
    cad_comorbid         -> myocyte_apoptosis     [label="ischemia->apop"  color="#4e342e"];
    cad_comorbid         -> chads2vasc_score      [label="CHA2DS2 V=1"    color="#4e342e"];
    dm_comorbid          -> endothelial_dysfunction [label="AGE->endothel" color="#4e342e"];
    dm_comorbid          -> ros_production        [label="glycation->ROS"  color="#4e342e"];
    dm_comorbid          -> chads2vasc_score      [label="CHA2DS2 D=1"    color="#4e342e"];
    ckd_comorbid         -> raas_activation       [label="CKD->RAAS up"   color="#4e342e"];
    ckd_comorbid         -> warfarin_pk           [label="dose adjust"     color="#4e342e"];
    valvular_disease     -> lav_enlargement       [label="volume overload" color="#4e342e"];
    valvular_disease     -> atrial_dilation       [label="MR/MS->LA up"   color="#4e342e"];
    osa_comorbid         -> adrenergic_trigger    [label="hypoxia->SNS up" color="#4e342e"];
    osa_comorbid         -> ros_production        [label="IRI->ROS"        color="#4e342e"];
    osa_comorbid         -> parasympathetic_tone  [label="arousal->vagal"  color="#4e342e"];
    hyperthyroidism      -> adrenergic_trigger    [label="beta-AR sensitiv up" color="#4e342e"];
    hyperthyroidism      -> if_channel            [label="T3->If up"       color="#4e342e"];
    hyperthyroidism      -> serca_pump            [label="T3->SERCA up"    color="#4e342e"];
    hyperthyroidism      -> chads2vasc_score      [label="thyroid AF risk" color="#4e342e"];
}
