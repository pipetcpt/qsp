digraph PolycythemiaVera_QSP {
    graph [
        label="Polycythemia Vera (진성 다혈증) — QSP Mechanistic Map\nJAK2 V617F Mutation · Hematopoiesis · Drug PK/PD · Clinical Endpoints"
        labelloc=t
        fontsize=22
        fontname="Helvetica-Bold"
        rankdir=LR
        splines=ortho
        nodesep=0.4
        ranksep=0.7
        bgcolor="#FAFAFA"
        overlap=false
    ]
    node [fontname="Helvetica" fontsize=10 style=filled shape=box]
    edge [fontname="Helvetica" fontsize=8]

    /* ============================================================
       CLUSTER 1: Genetic Basis & Mutation
    ============================================================ */
    subgraph cluster_genetics {
        label="Genetic & Molecular Basis"
        style=filled
        fillcolor="#E8F4F8"
        color="#2196F3"
        fontsize=14
        fontname="Helvetica-Bold"

        JAK2_WT   [label="JAK2 Wild-type\n(Inactive)" fillcolor="#B3E5FC" shape=ellipse]
        JAK2_V617F [label="JAK2 V617F\n(Gain-of-Function)" fillcolor="#FF5722" fontcolor=white shape=ellipse]
        CALR_mut   [label="CALR Mutation\n(~5% PV)" fillcolor="#FFCCBC" shape=ellipse]
        MPL_mut    [label="MPL W515L/K\n(rare)" fillcolor="#FFCCBC" shape=ellipse]
        TET2       [label="TET2 Mutation\n(epigenetic)" fillcolor="#CFD8DC" shape=ellipse]
        ASXL1      [label="ASXL1 Mutation\n(chromatin)" fillcolor="#CFD8DC" shape=ellipse]
        SF3B1      [label="SF3B1/SRSF2\n(splicing)" fillcolor="#CFD8DC" shape=ellipse]
        IDH1_2     [label="IDH1/IDH2\n(progression risk)" fillcolor="#FFAB91" shape=ellipse]
        TP53       [label="TP53 Mutation\n(leukemic transform)" fillcolor="#FF7043" fontcolor=white shape=ellipse]
        allele_burden [label="JAK2 V617F\nAllele Burden (%)" fillcolor="#FFF9C4" shape=diamond]
        HSC_clone  [label="Malignant HSC\nClone" fillcolor="#FF5722" fontcolor=white shape=hexagon]

        JAK2_WT -> JAK2_V617F [label="somatic\nmutation" style=dashed color=red]
        JAK2_V617F -> allele_burden [label="clone\nexpansion"]
        allele_burden -> HSC_clone [label="dominance"]
        TET2 -> HSC_clone [label="cooperates" style=dashed]
        ASXL1 -> HSC_clone [label="cooperates" style=dashed]
        SF3B1 -> HSC_clone [label="cooperates" style=dashed]
        IDH1_2 -> TP53 [label="AML risk" style=dashed color=red]
    }

    /* ============================================================
       CLUSTER 2: JAK-STAT Signaling Pathway
    ============================================================ */
    subgraph cluster_jak_stat {
        label="JAK-STAT Signaling Cascade"
        style=filled
        fillcolor="#FFF3E0"
        color="#FF9800"
        fontsize=14
        fontname="Helvetica-Bold"

        JAK2_act   [label="JAK2 Activated\n(constitutive)" fillcolor="#FF9800" fontcolor=white shape=ellipse]
        JAK1_act   [label="JAK1\n(co-activation)" fillcolor="#FFB74D" shape=ellipse]
        TYK2       [label="TYK2\n(signal relay)" fillcolor="#FFB74D" shape=ellipse]
        STAT5A     [label="STAT5A\n(phosphorylated)" fillcolor="#E65100" fontcolor=white shape=ellipse]
        STAT5B     [label="STAT5B\n(phosphorylated)" fillcolor="#E65100" fontcolor=white shape=ellipse]
        STAT3      [label="STAT3\n(phosphorylated)" fillcolor="#BF360C" fontcolor=white shape=ellipse]
        STAT1      [label="STAT1\n(anti-apoptotic block)" fillcolor="#FF7043" shape=ellipse]
        PI3K       [label="PI3K\n(activation)" fillcolor="#FFA726" shape=ellipse]
        AKT        [label="AKT/PKB\n(phospho-AKT)" fillcolor="#FB8C00" shape=ellipse]
        mTOR       [label="mTOR Complex\n(cell growth)" fillcolor="#E65100" fontcolor=white shape=ellipse]
        ERK1_2     [label="ERK1/2\n(proliferation)" fillcolor="#EF6C00" shape=ellipse]
        MEK        [label="MEK\n(MAPK cascade)" fillcolor="#EF9A9A" shape=ellipse]
        RAS        [label="RAS-GTP\n(oncogenic)" fillcolor="#EF5350" fontcolor=white shape=ellipse]
        RAF        [label="RAF\n(kinase)" fillcolor="#E53935" fontcolor=white shape=ellipse]
        BCL2L      [label="BCL-XL/BCL-2\n(anti-apoptosis)" fillcolor="#FFCC02" shape=ellipse]
        CCND1      [label="Cyclin D1/D2\n(cell cycle)" fillcolor="#FFD54F" shape=ellipse]
        PIM1       [label="PIM1 Kinase\n(survival)" fillcolor="#FFB300" shape=ellipse]
        SOCS1      [label="SOCS1/SOCS3\n(negative feedback)" fillcolor="#A5D6A7" shape=ellipse]
        CISH       [label="CISH\n(inhibitor)" fillcolor="#C8E6C9" shape=ellipse]
        SHP2       [label="SHP2 Phosphatase\n(regulatory)" fillcolor="#DCEDC8" shape=ellipse]

        JAK2_act -> STAT5A [label="phospho\n(pY694)"]
        JAK2_act -> STAT5B
        JAK2_act -> STAT3
        JAK2_act -> STAT1
        JAK2_act -> PI3K
        JAK1_act -> JAK2_act [label="dimer\nactivation"]
        JAK2_act -> JAK1_act [style=dashed]
        TYK2 -> JAK2_act [style=dashed]
        PI3K -> AKT
        AKT -> mTOR
        AKT -> BCL2L
        AKT -> CCND1
        RAS -> RAF
        RAF -> MEK
        MEK -> ERK1_2
        STAT5A -> BCL2L [label="transcription"]
        STAT5A -> CCND1
        STAT5A -> PIM1
        STAT3 -> BCL2L
        STAT3 -> CCND1
        ERK1_2 -> CCND1
        SOCS1 -> JAK2_act [label="inhibit" color=red arrowhead=tee]
        CISH -> STAT5A [label="inhibit" color=red arrowhead=tee]
        SHP2 -> JAK2_act [label="dephospho" color=red arrowhead=tee]
    }

    /* ============================================================
       CLUSTER 3: Cytokine & Growth Factor Signaling
    ============================================================ */
    subgraph cluster_cytokines {
        label="Cytokine & Growth Factor Receptors"
        style=filled
        fillcolor="#F3E5F5"
        color="#9C27B0"
        fontsize=14
        fontname="Helvetica-Bold"

        EPO_R      [label="EPOR\n(EPO Receptor)" fillcolor="#CE93D8" shape=ellipse]
        EPO_serum  [label="Serum EPO\n(subnormal in PV)" fillcolor="#E1BEE7" shape=diamond]
        MPL_R      [label="MPL\n(TPO Receptor)" fillcolor="#CE93D8" shape=ellipse]
        TPO_serum  [label="Thrombopoietin\n(TPO)" fillcolor="#E1BEE7" shape=diamond]
        GCSFR      [label="G-CSF Receptor\n(CSF3R)" fillcolor="#CE93D8" shape=ellipse]
        GCSF       [label="G-CSF\n(neutrophil growth)" fillcolor="#E1BEE7" shape=diamond]
        IL3R       [label="IL-3 Receptor\n(CD123)" fillcolor="#CE93D8" shape=ellipse]
        IL6R       [label="IL-6/gp130\n(inflammation)" fillcolor="#CE93D8" shape=ellipse]
        SCF_R      [label="c-KIT/SCF-R\n(stem cell)" fillcolor="#BA68C8" shape=ellipse]
        FLT3       [label="FLT3\n(dendritic/progenitor)" fillcolor="#BA68C8" shape=ellipse]
        HIF1a      [label="HIF-1α\n(hypoxia sensor)" fillcolor="#9C27B0" fontcolor=white shape=ellipse]
        HIF2a      [label="HIF-2α\n(EPO regulator)" fillcolor="#7B1FA2" fontcolor=white shape=ellipse]
        VHL        [label="VHL\n(HIF degradation)" fillcolor="#D1C4E9" shape=ellipse]

        EPO_serum -> EPO_R [label="ligand\nbinding"]
        TPO_serum -> MPL_R
        GCSF -> GCSFR
        EPO_R -> JAK2_act [label="→ JAK2\nactivation"]
        MPL_R -> JAK2_act
        GCSFR -> JAK2_act
        IL3R -> JAK2_act [style=dashed]
        IL6R -> JAK1_act [style=dashed]
        SCF_R -> RAS [label="→ RAS"]
        HIF1a -> EPO_serum [label="transcription\n(kidney)" style=dashed]
        HIF2a -> EPO_serum
        VHL -> HIF1a [label="ubiquitin\ndegradation" color=red arrowhead=tee]
        JAK2_V617F -> EPO_R [label="hypersensitivity\n(constitutive)" style=bold color=red]
    }

    /* ============================================================
       CLUSTER 4: Bone Marrow Hematopoiesis
    ============================================================ */
    subgraph cluster_hematopoiesis {
        label="Bone Marrow Hematopoiesis Compartments"
        style=filled
        fillcolor="#E8F5E9"
        color="#4CAF50"
        fontsize=14
        fontname="Helvetica-Bold"

        HSC        [label="HSC\n(Hematopoietic Stem Cell)" fillcolor="#1B5E20" fontcolor=white shape=hexagon]
        MPP        [label="MPP\n(Multipotent Progenitor)" fillcolor="#2E7D32" fontcolor=white shape=hexagon]
        CMP        [label="CMP\n(Common Myeloid\nProgenitor)" fillcolor="#388E3C" fontcolor=white shape=hexagon]
        CLP        [label="CLP\n(Lymphoid Progenitor)" fillcolor="#43A047" fontcolor=white shape=hexagon]
        MEP        [label="MEP\n(Megakaryocyte-\nErythroid Prog)" fillcolor="#4CAF50" fontcolor=white shape=hexagon]
        GMP        [label="GMP\n(Granulocyte-Monocyte\nProgenitor)" fillcolor="#66BB6A" shape=hexagon]
        BFU_E      [label="BFU-E\n(Burst-Forming Unit\nErythroid)" fillcolor="#81C784" shape=box]
        CFU_E      [label="CFU-E\n(Colony-Forming Unit\nErythroid)" fillcolor="#A5D6A7" shape=box]
        ProEB      [label="Proerythroblast\n(Pro-EB)" fillcolor="#C8E6C9" shape=box]
        BasoEB     [label="Basophilic\nErythroblast" fillcolor="#DCEDC8" shape=box]
        PolyEB     [label="Polychromatophilic\nErythroblast" fillcolor="#F1F8E9" shape=box]
        OrthoEB    [label="Orthochromatic\nErythroblast" fillcolor="#F9FBE7" shape=box]
        Retic      [label="Reticulocyte\n(BM)" fillcolor="#E8F5E9" shape=box]
        Retic_circ [label="Reticulocyte\n(Circulating)" fillcolor="#B2DFDB" shape=box]
        RBC        [label="Red Blood Cell\n(Erythrocyte)" fillcolor="#EF9A9A" shape=ellipse]
        CFU_Mk     [label="CFU-Mk\n(Megakaryocyte\nProgenitor)" fillcolor="#B39DDB" shape=box]
        Megakaryocyte [label="Megakaryocyte\n(BM)" fillcolor="#9575CD" shape=box]
        Plt_BM     [label="Platelet\n(Released from BM)" fillcolor="#7E57C2" fontcolor=white shape=ellipse]
        CFU_G      [label="CFU-G\n(Granulocyte\nProgenitor)" fillcolor="#90CAF9" shape=box]
        Myeloblast [label="Myeloblast" fillcolor="#64B5F6" shape=box]
        Promyelo   [label="Promyelocyte" fillcolor="#42A5F5" shape=box]
        Myelocyte  [label="Myelocyte" fillcolor="#2196F3" fontcolor=white shape=box]
        Neutrophil_BM [label="Neutrophil\n(BM storage)" fillcolor="#1E88E5" fontcolor=white shape=box]

        HSC -> MPP [label="self-renewal\n& differentiation"]
        HSC_clone -> HSC [label="replaces\nnormal HSC" style=bold color=red]
        MPP -> CMP
        MPP -> CLP
        CMP -> MEP
        CMP -> GMP
        MEP -> BFU_E
        MEP -> CFU_Mk
        BFU_E -> CFU_E [label="EPO-dep"]
        CFU_E -> ProEB [label="EPO-dep"]
        ProEB -> BasoEB
        BasoEB -> PolyEB
        PolyEB -> OrthoEB
        OrthoEB -> Retic [label="enucleation"]
        Retic -> Retic_circ [label="BM exit"]
        Retic_circ -> RBC [label="maturation\n(1-2d)"]
        CFU_Mk -> Megakaryocyte [label="TPO"]
        Megakaryocyte -> Plt_BM [label="proplatelet\nformation"]
        GMP -> CFU_G
        CFU_G -> Myeloblast
        Myeloblast -> Promyelo
        Promyelo -> Myelocyte
        Myelocyte -> Neutrophil_BM

        JAK2_V617F -> BFU_E [label="EPO-\nindependent\ngrowth" style=bold color=red]
        JAK2_V617F -> CFU_E [label="hyperprolif" style=bold color=red]
        JAK2_V617F -> CFU_Mk [label="hyperprolif" style=bold color=red]
        JAK2_V617F -> CFU_G [label="hyperprolif" style=bold color=red]
        STAT5A -> BFU_E [label="anti-\napoptosis"]
    }

    /* ============================================================
       CLUSTER 5: Peripheral Blood Compartments
    ============================================================ */
    subgraph cluster_peripheral {
        label="Peripheral Blood & Spleen"
        style=filled
        fillcolor="#FFF8E1"
        color="#FFC107"
        fontsize=14
        fontname="Helvetica-Bold"

        RBC_pool   [label="Peripheral RBC Pool\n(increased mass)" fillcolor="#EF9A9A" shape=ellipse]
        Hgb        [label="Hemoglobin\n(g/dL, elevated)" fillcolor="#E57373" shape=diamond]
        Hct        [label="Hematocrit\n(>49%M/>48%F)" fillcolor="#EF5350" fontcolor=white shape=diamond]
        WBC        [label="WBC\n(leukocytosis)" fillcolor="#90CAF9" shape=diamond]
        ANC        [label="Absolute Neutrophil\nCount" fillcolor="#64B5F6" shape=diamond]
        Plt_circ   [label="Circulating Platelets\n(thrombocytosis)" fillcolor="#CE93D8" shape=diamond]
        Spleen_pool [label="Spleen RBC\n& Platelet Sequestration" fillcolor="#FFCC80" shape=ellipse]
        Spleen_vol [label="Spleen Volume\n(EMH)" fillcolor="#FF9800" shape=diamond]
        Spleen_EMH [label="Extramedullary\nHematopoiesis (EMH)" fillcolor="#F57C00" fontcolor=white shape=ellipse]
        BM_cellularity [label="BM Cellularity\n(hypercellular)" fillcolor="#BCAAA4" shape=diamond]
        BM_fibrosis   [label="BM Reticulin\nFibrosis (grade 0-3)" fillcolor="#8D6E63" fontcolor=white shape=diamond]
        erythropoietic_vol [label="Erythropoietic\nMass Volume" fillcolor="#FFAB91" shape=diamond]

        RBC -> RBC_pool [label="circulation\n(120d lifespan)"]
        RBC_pool -> Hgb [label="correlates"]
        RBC_pool -> Hct [label="correlates"]
        Plt_BM -> Plt_circ [label="circulation\n(8-10d)"]
        Neutrophil_BM -> WBC [label="demargination"]
        WBC -> ANC [label="includes"]
        Spleen_EMH -> Spleen_vol
        Spleen_EMH -> Spleen_pool
        BM_fibrosis -> Spleen_EMH [label="drives EMH"]
        erythropoietic_vol -> BM_cellularity
    }

    /* ============================================================
       CLUSTER 6: Thrombosis & Cardiovascular Pathophysiology
    ============================================================ */
    subgraph cluster_thrombosis {
        label="Thrombosis & Cardiovascular Risk"
        style=filled
        fillcolor="#FCE4EC"
        color="#E91E63"
        fontsize=14
        fontname="Helvetica-Bold"

        blood_viscosity [label="Blood Viscosity\n(elevated)" fillcolor="#F48FB1" shape=diamond]
        plt_activation [label="Platelet Activation\n(ADP, TXA2, P-selectin)" fillcolor="#F06292" shape=ellipse]
        NET_formation  [label="Neutrophil\nExtracellular Traps (NETs)" fillcolor="#EC407A" fontcolor=white shape=ellipse]
        coag_cascade   [label="Coagulation Cascade\nActivation (TF pathway)" fillcolor="#E91E63" fontcolor=white shape=ellipse]
        thrombin       [label="Thrombin Generation\n(FIIa)" fillcolor="#D81B60" fontcolor=white shape=ellipse]
        fibrin         [label="Fibrin Clot\nFormation" fillcolor="#C2185B" fontcolor=white shape=ellipse]
        DVT            [label="Deep Vein\nThrombosis (DVT)" fillcolor="#FF4081" shape=box]
        PE             [label="Pulmonary Embolism\n(PE)" fillcolor="#FF4081" shape=box]
        Stroke         [label="Stroke / TIA\n(arterial)" fillcolor="#FF4081" shape=box]
        MI             [label="Myocardial Infarction\n(arterial)" fillcolor="#FF4081" shape=box]
        Portal_thrombus [label="Portal / Hepatic\nVein Thrombosis" fillcolor="#FF4081" shape=box]
        pruritus       [label="Aquagenic Pruritus\n(histamine, serotonin)" fillcolor="#FFDDE7" shape=diamond]
        erythromelalgia [label="Erythromelalgia\n(extremity pain)" fillcolor="#FFB3C1" shape=diamond]
        thrombosis_risk [label="Annual Thrombosis\nRisk Score" fillcolor="#FF006B" fontcolor=white shape=diamond]
        CVRF           [label="Cardiovascular Risk\nFactors (HTN, DM, smoking)" fillcolor="#FFCDD2" shape=ellipse]

        Hct -> blood_viscosity [label="Hct↑→\nviscosity↑"]
        Plt_circ -> plt_activation [label="hyperactivation"]
        WBC -> NET_formation [label="JAK2+ neutrophil"]
        NET_formation -> coag_cascade [label="procoagulant"]
        blood_viscosity -> coag_cascade [label="stasis"]
        plt_activation -> coag_cascade
        coag_cascade -> thrombin
        thrombin -> fibrin
        fibrin -> DVT
        fibrin -> PE
        fibrin -> Stroke
        fibrin -> MI
        fibrin -> Portal_thrombus
        Hct -> thrombosis_risk
        Plt_circ -> thrombosis_risk
        CVRF -> thrombosis_risk
        plt_activation -> pruritus [label="histamine\nrelease"]
        plt_activation -> erythromelalgia
        JAK2_V617F -> plt_activation [label="JAK2+\nplatelet\nhyperactivity" style=bold color=red]
    }

    /* ============================================================
       CLUSTER 7: Drug PK — Ruxolitinib
    ============================================================ */
    subgraph cluster_rux_pk {
        label="Drug PK — Ruxolitinib (JAK1/2 Inhibitor)"
        style=filled
        fillcolor="#E3F2FD"
        color="#1565C0"
        fontsize=14
        fontname="Helvetica-Bold"

        RUX_dose   [label="Ruxolitinib\nDose (mg BID)" fillcolor="#90CAF9" shape=parallelogram]
        RUX_gut    [label="Ruxolitinib\nGut Absorption\n(F=95%)" fillcolor="#64B5F6" shape=box]
        RUX_cent   [label="Ruxolitinib\nCentral Compartment\n(Vc=72L)" fillcolor="#42A5F5" shape=box]
        RUX_peri   [label="Ruxolitinib\nPeripheral Compartment\n(Vp=28L)" fillcolor="#1E88E5" fontcolor=white shape=box]
        RUX_CYP3A4 [label="CYP3A4 Metabolism\n(major, t1/2≈3h)" fillcolor="#1565C0" fontcolor=white shape=ellipse]
        RUX_met1   [label="Active Metabolite 1\n(25-OH-ruxolitinib)" fillcolor="#BBDEFB" shape=box]
        RUX_met2   [label="Active Metabolite 2\n(27-OH-ruxolitinib)" fillcolor="#BBDEFB" shape=box]
        RUX_Cp     [label="Ruxolitinib Plasma\nConcentration (Cp)" fillcolor="#2196F3" fontcolor=white shape=diamond]
        RUX_elim   [label="Renal/Biliary\nElimination (CL=22L/h)" fillcolor="#B0BEC5" shape=ellipse]

        RUX_dose -> RUX_gut [label="oral\nadmin"]
        RUX_gut -> RUX_cent [label="ka=2.4/h\nF=0.95"]
        RUX_cent -> RUX_peri [label="distribution\n(Qp=16L/h)"]
        RUX_peri -> RUX_cent [label="return"]
        RUX_cent -> RUX_CYP3A4 [label="hepatic\nmetabolism"]
        RUX_CYP3A4 -> RUX_met1
        RUX_CYP3A4 -> RUX_met2
        RUX_cent -> RUX_Cp [label="measurement"]
        RUX_cent -> RUX_elim [label="CL=22L/h"]
    }

    /* ============================================================
       CLUSTER 8: Drug PK — Hydroxyurea & IFN
    ============================================================ */
    subgraph cluster_hyu_ifn_pk {
        label="Drug PK — Hydroxyurea & PEG-IFN-α2a"
        style=filled
        fillcolor="#F1F8E9"
        color="#558B2F"
        fontsize=14
        fontname="Helvetica-Bold"

        HYU_dose   [label="Hydroxyurea\nDose (mg/d)" fillcolor="#CCFF90" shape=parallelogram]
        HYU_cent   [label="Hydroxyurea\nPlasma (Vc=20L)" fillcolor="#B2FF59" shape=box]
        HYU_Cp     [label="Hydroxyurea\nPlasma Conc (μM)" fillcolor="#76FF03" shape=diamond]
        HYU_RBC    [label="Hydroxyurea\nin RBC" fillcolor="#64DD17" shape=box]
        HYU_elim   [label="Renal Elimination\n(t1/2=3.5h, CL=5L/h)" fillcolor="#B0BEC5" shape=ellipse]
        IFN_dose   [label="PEG-IFN-α2a\nDose (μg/wk SC)" fillcolor="#C8E6C9" shape=parallelogram]
        IFN_abs    [label="SC Absorption\n(ka_SC=0.03/h)" fillcolor="#A5D6A7" shape=box]
        IFN_cent   [label="PEG-IFN-α2a\nPlasma (Vc=6L)" fillcolor="#81C784" shape=box]
        IFN_Cp     [label="PEG-IFN-α2a\nConc (pg/mL)" fillcolor="#4CAF50" fontcolor=white shape=diamond]
        IFN_elim   [label="Proteolytic\nElimination (t1/2~80h)" fillcolor="#B0BEC5" shape=ellipse]
        PHLEBOT    [label="Phlebotomy\n(450-500 mL units)" fillcolor="#FFAB91" shape=parallelogram]
        ASA_dose   [label="Aspirin\n(81-100 mg/d)" fillcolor="#FFF9C4" shape=parallelogram]

        HYU_dose -> HYU_cent [label="oral, F=80%\nka=1.5/h"]
        HYU_cent -> HYU_Cp
        HYU_cent -> HYU_RBC [label="uptake"]
        HYU_cent -> HYU_elim [label="CL=5L/h"]
        IFN_dose -> IFN_abs [label="SC inject"]
        IFN_abs -> IFN_cent [label="Fabs=0.84"]
        IFN_cent -> IFN_Cp
        IFN_cent -> IFN_elim [label="t1/2=80h"]
    }

    /* ============================================================
       CLUSTER 9: Drug PD — Pharmacodynamic Effects
    ============================================================ */
    subgraph cluster_pd {
        label="Drug Pharmacodynamics & Biomarkers"
        style=filled
        fillcolor="#EDE7F6"
        color="#512DA8"
        fontsize=14
        fontname="Helvetica-Bold"

        JAK_inhib    [label="JAK1/2 Inhibition\n(% of max, Emax model)" fillcolor="#9575CD" shape=ellipse]
        STAT5_inhib  [label="pSTAT5 Reduction\n(PD biomarker)" fillcolor="#7E57C2" fontcolor=white shape=diamond]
        RUX_IC50     [label="Ruxolitinib IC50\n(JAK2: 2.8 nM\nJAK1: 3.3 nM)" fillcolor="#B39DDB" shape=box]
        Hct_reduction [label="Hematocrit\nReduction (%)" fillcolor="#EF9A9A" shape=diamond]
        Plt_reduction [label="Platelet Count\nReduction (%)" fillcolor="#CE93D8" shape=diamond]
        WBC_reduction [label="WBC Reduction\n(%)" fillcolor="#90CAF9" shape=diamond]
        Spleen_reduction [label="Spleen Volume\nReduction (SVR35)" fillcolor="#FFCC80" shape=diamond]
        allele_reduction [label="JAK2 V617F\nAllele Burden ↓" fillcolor="#FF9800" shape=diamond]
        ribonucleotide_R [label="Ribonucleotide\nReductase Inhibition\n(Hydroxyurea PD)" fillcolor="#A5D6A7" shape=ellipse]
        DNA_synth_inhib  [label="DNA Synthesis\nInhibition\n(S-phase specific)" fillcolor="#66BB6A" shape=ellipse]
        IFN_ISG   [label="Interferon-Stimulated\nGenes (ISG15, IFIT1)" fillcolor="#C8E6C9" shape=diamond]
        IFN_stem_target [label="IFN-α → JAK2+ HSC\nSelective Targeting" fillcolor="#4CAF50" fontcolor=white shape=ellipse]
        COX_inhib   [label="COX-1 Inhibition\n(Aspirin PD)" fillcolor="#FFF9C4" shape=ellipse]
        TXA2_inhib  [label="TXA2 Synthesis\nInhibition → Anti-plt" fillcolor="#FFE082" shape=ellipse]
        PHLEBOT_effect [label="RBC Mass\nReduction (phlebotomy)" fillcolor="#FFAB91" shape=diamond]

        RUX_Cp -> JAK_inhib [label="Emax: Imax=1\nHill=1.0"]
        RUX_IC50 -> JAK_inhib [label="IC50 param"]
        JAK_inhib -> STAT5_inhib [label="downstream"]
        JAK_inhib -> Hct_reduction [label="↓ erythroprolif"]
        JAK_inhib -> Plt_reduction [label="↓ thrombopoiesis"]
        JAK_inhib -> WBC_reduction
        JAK_inhib -> Spleen_reduction [label="SVR35"]
        IFN_Cp -> IFN_ISG [label="ISG\ninduction"]
        IFN_Cp -> IFN_stem_target [label="clonal\nsuppression"]
        IFN_stem_target -> allele_reduction [label="JAK2+ HSC\nelimination"]
        HYU_Cp -> ribonucleotide_R [label="inhib"]
        ribonucleotide_R -> DNA_synth_inhib
        DNA_synth_inhib -> Hct_reduction
        DNA_synth_inhib -> Plt_reduction
        ASA_dose -> COX_inhib
        COX_inhib -> TXA2_inhib
        TXA2_inhib -> plt_activation [label="inhibit" color=green arrowhead=tee]
        PHLEBOT -> PHLEBOT_effect
        PHLEBOT_effect -> Hct [label="target < 45%\n(goal)" color=green]
    }

    /* ============================================================
       CLUSTER 10: Clinical Endpoints & Outcomes
    ============================================================ */
    subgraph cluster_outcomes {
        label="Clinical Endpoints & Disease Outcomes"
        style=filled
        fillcolor="#FFEBEE"
        color="#B71C1C"
        fontsize=14
        fontname="Helvetica-Bold"

        CHR          [label="Complete Hematologic\nResponse (CHR)\nHct<45%, plt<400K,\nWBC<10K, no splenomegaly" fillcolor="#FFCDD2" shape=box]
        PHR          [label="Partial Hematologic\nResponse (PHR)" fillcolor="#FFCDD2" shape=box]
        NR           [label="No Response / Primary\nRefractory" fillcolor="#EF9A9A" shape=box]
        MPN_SAF_TSS  [label="Symptom Burden\n(MPN-SAF TSS)\nFatigue, Pruritus,\nSweats, Abdominal" fillcolor="#EF5350" fontcolor=white shape=box]
        PFS          [label="Progression-Free\nSurvival (PFS)" fillcolor="#FFAB91" shape=diamond]
        OS           [label="Overall Survival\n(OS)" fillcolor="#FF7043" shape=diamond]
        MF_transform [label="MF Transformation\n(post-PV MF)\n~10-20% at 20y" fillcolor="#D32F2F" fontcolor=white shape=box]
        AML_transform [label="AML/MDS\nTransformation\n(~2-7% at 20y)" fillcolor="#B71C1C" fontcolor=white shape=box]
        QoL          [label="Quality of Life\n(EQ-5D, EORTC)" fillcolor="#FFCC80" shape=diamond]
        response_criteria [label="ELN/IWG-MRT\n2013 Response\nCriteria" fillcolor="#FFE0B2" shape=box]

        Hct_reduction -> CHR [label="Hct <45%"]
        Plt_reduction -> CHR [label="plt <400K"]
        WBC_reduction -> CHR [label="WBC <10K"]
        Spleen_reduction -> CHR [label="no\nsplenomegaly"]
        CHR -> PFS [label="achievement\n→ better PFS"]
        CHR -> OS [label="→ better OS"]
        PHR -> PFS
        NR -> MF_transform [label="higher risk"]
        thrombosis_risk -> OS [label="major cause\nof death"]
        BM_fibrosis -> MF_transform [label="grade 2-3\n→ post-PV MF"]
        IDH1_2 -> AML_transform [label="mutation\n→ AML risk"]
        TP53 -> AML_transform [label="→ AML"]
        MPN_SAF_TSS -> QoL [label="inverse"]
        Spleen_vol -> MPN_SAF_TSS [label="splenomegaly\n→ symptoms"]
        CHR -> response_criteria
        PHR -> response_criteria
        NR -> response_criteria
    }

    /* ============================================================
       INTER-CLUSTER CONNECTIONS
    ============================================================ */
    HSC_clone -> JAK2_V617F [label="drives\nconstitutive\nactivation" style=bold color=red]
    JAK2_V617F -> JAK2_act [label="constitutive\nactivation" style=bold color=red]
    STAT5A -> BCL2L [label="anti-\napoptosis"]
    CCND1 -> BFU_E [label="cell cycle\nentry"]
    BCL2L -> BFU_E [label="survival"]
    RBC_pool -> erythropoietic_vol
    Hct -> Hct_reduction [label="measured"]
    Plt_circ -> Plt_reduction [label="measured"]
    WBC -> WBC_reduction [label="measured"]
    Spleen_vol -> Spleen_reduction [label="MRI/US\nmeasured"]
    allele_burden -> allele_reduction [label="PCR\nmeasured"]
    STAT5_inhib -> allele_reduction [label="→ clonal\nsuppression"]

    /* Treatment → Blood response */
    Hct_reduction -> Hct [label="treatment\neffect" color=green]
    Plt_reduction -> Plt_circ [label="treatment\neffect" color=green]
    WBC_reduction -> WBC [label="treatment\neffect" color=green]

    /* JAK2 signal → symptoms */
    JAK2_V617F -> MPN_SAF_TSS [label="driver of\nsymptom burden" style=dashed]
    JAK_inhib -> MPN_SAF_TSS [label="reduces\nsymptoms" color=green]

    /* Neutrophil → inflammation */
    NET_formation -> BM_fibrosis [label="TGF-β,\nPDGF release" style=dashed]
    Spleen_EMH -> Spleen_vol [label="drives volume"]

    /* Legend */
    subgraph cluster_legend {
        label="Legend"
        style=filled fillcolor=white color=black fontsize=12
        L1 [label="Disease Driver" fillcolor="#FF5722" fontcolor=white shape=ellipse]
        L2 [label="Drug Target / PK" fillcolor="#1E88E5" fontcolor=white shape=box]
        L3 [label="Clinical Endpoint" fillcolor="#EF5350" fontcolor=white shape=box]
        L4 [label="Biomarker" fillcolor="#FFF9C4" shape=diamond]
        L5 [label="Inhibition" color=red style="dashed" shape=plaintext]
        L6 [label="Activation / Treatment effect" color=green style=bold shape=plaintext]
    }
}
