digraph PV_QSP_Model {
    graph [rankdir=LR, fontname="Helvetica", fontsize=11, bgcolor="#FAFAFA",
           label="Polycythemia Vera — Quantitative Systems Pharmacology Model\n(JAK2V617F · Clonal Erythropoiesis · Thrombosis · Treatment)",
           labelloc=t, labelfontsize=14, splines=true, nodesep=0.35, ranksep=0.75]
    node [shape=box, style="filled,rounded", fontname="Helvetica", fontsize=9, margin="0.12,0.06"]
    edge [fontname="Helvetica", fontsize=8, arrowsize=0.7]

    // ============================================================
    // Cluster 1: Genetic & Molecular Origin
    // ============================================================
    subgraph cluster_genetic {
        label="1. Genetic & Molecular Basis"
        style=filled; bgcolor="#E8F4FD"; color="#1A5276"; penwidth=2; fontsize=11; fontcolor="#1A5276"

        JAK2V617F   [label="JAK2 V617F\nMutation (exon 14)", fillcolor="#E74C3C", fontcolor=white]
        JAK2_exon12 [label="JAK2 Exon 12\nMutation", fillcolor="#E74C3C", fontcolor=white]
        JAK2_homo   [label="JAK2 V617F\nHomozygosity (9pUPD)", fillcolor="#CB4335", fontcolor=white]
        Clone_HSC   [label="Mutant HSC\nClone", fillcolor="#D35400", fontcolor=white, shape=ellipse]
        VF_allele   [label="JAK2 V617F\nAllele Burden (%)", fillcolor="#E67E22", fontcolor=white]
        TET2        [label="TET2\nCo-mutation", fillcolor="#F1948A"]
        DNMT3A      [label="DNMT3A\nMutation", fillcolor="#F1948A"]
        ASXL1       [label="ASXL1 Mutation\n(MF risk ↑)", fillcolor="#F1948A"]
        SF3B1       [label="SF3B1\nSplicing Mutation", fillcolor="#F5CBA7"]
        IDH1_IDH2   [label="IDH1/IDH2\nMutation (AML risk)", fillcolor="#EC7063"]
        TP53        [label="TP53 Mutation\n(Genomic instability)", fillcolor="#C0392B", fontcolor=white]
        clonal_evol [label="Clonal\nEvolution", fillcolor="#CA6F1E", fontcolor=white]
        CHIP        [label="Clonal Hematopoiesis\nof Indeterminate Potential\n(CHIP)", fillcolor="#E59866"]
    }

    // ============================================================
    // Cluster 2: JAK-STAT Signaling Pathway
    // ============================================================
    subgraph cluster_jak_stat {
        label="2. JAK-STAT & Downstream Signaling"
        style=filled; bgcolor="#EBF5FB"; color="#1B4F72"; penwidth=2; fontsize=11; fontcolor="#1B4F72"

        EPO_R       [label="EPOR\n(Erythropoietin R)", fillcolor="#2ECC71", fontcolor=white]
        TPO_R       [label="MPL (c-Mpl)\nThrombopoietin R", fillcolor="#27AE60", fontcolor=white]
        G_CSFR      [label="G-CSFR (CSF3R)\nGranulocyte CSF R", fillcolor="#1ABC9C", fontcolor=white]
        JAK2_kinase [label="JAK2 Kinase\n(constitutively active)", fillcolor="#8E44AD", fontcolor=white]
        JAK1_kinase [label="JAK1 Kinase", fillcolor="#9B59B6", fontcolor=white]
        TYK2        [label="TYK2", fillcolor="#A569BD"]
        STAT5_act   [label="STAT5 Activation\n(p-STAT5)", fillcolor="#3498DB", fontcolor=white]
        STAT3_act   [label="STAT3\nActivation", fillcolor="#5DADE2"]
        STAT1_act   [label="STAT1\nActivation (IFN)", fillcolor="#5DADE2"]
        SOCS1       [label="SOCS1\n(Negative Regulator)", fillcolor="#BDC3C7"]
        SOCS3       [label="SOCS3\n(Negative Regulator)", fillcolor="#BDC3C7"]
        PI3K        [label="PI3K\n(p110α/δ)", fillcolor="#1F618D", fontcolor=white]
        AKT         [label="AKT\n(p-AKT Ser473)", fillcolor="#2E86C1", fontcolor=white]
        mTOR        [label="mTORC1\n(p-S6K1)", fillcolor="#2874A6", fontcolor=white]
        MAPK        [label="MAPK/ERK1-2\n(p-ERK)", fillcolor="#2980B9", fontcolor=white]
        RAS         [label="RAS/RAF/MEK\n(signaling)", fillcolor="#21618C", fontcolor=white]
        BCL2        [label="BCL-2 / BCL-XL\n(Anti-apoptosis)", fillcolor="#117A65", fontcolor=white]
        MCL1        [label="MCL-1\n(Anti-apoptosis)", fillcolor="#1E8449", fontcolor=white]
        PIM_kinase  [label="PIM1/2 Kinase\n(Cell survival)", fillcolor="#148F77", fontcolor=white]
        CDK4_6      [label="CDK4/6 → CycD\n(Cell cycle entry)", fillcolor="#0E6655", fontcolor=white]
    }

    // ============================================================
    // Cluster 3: Erythropoietic Compartment
    // ============================================================
    subgraph cluster_erythroid {
        label="3. Erythropoietic Compartment"
        style=filled; bgcolor="#FDEDEC"; color="#7B241C"; penwidth=2; fontsize=11; fontcolor="#7B241C"

        HSC_mut     [label="Mutant HSC\n(JAK2V617F)", fillcolor="#C0392B", fontcolor=white, shape=ellipse]
        HSC_wt      [label="Wild-type HSC", fillcolor="#85C1E9", shape=ellipse]
        CMP         [label="CMP (Common\nMyeloid Progenitor)", fillcolor="#D98880"]
        MEP_mut     [label="Mutant MEP\n(Megakaryocyte-\nErythroid Prog.)", fillcolor="#E74C3C", fontcolor=white]
        MEP_wt      [label="Wild-type MEP", fillcolor="#AED6F1"]
        BFU_E_mut   [label="Mutant BFU-E\n(EPO-independent)", fillcolor="#E74C3C", fontcolor=white]
        BFU_E_wt    [label="Wild-type BFU-E\n(EPO-dependent)", fillcolor="#85C1E9"]
        CFU_E_mut   [label="Mutant CFU-E\n(↑ sensitivity EPO)", fillcolor="#E67E22", fontcolor=white]
        CFU_E_wt    [label="Wild-type CFU-E", fillcolor="#AED6F1"]
        ProE        [label="Proerythroblast", fillcolor="#F0B27A"]
        BasoE       [label="Basophilic\nErythroblast", fillcolor="#F0B27A"]
        OrthoE      [label="Orthochromatic\nErythroblast", fillcolor="#F5CBA7"]
        Retic       [label="Reticulocyte\n(→ peripheral blood)", fillcolor="#EB984E"]
        RBC         [label="Mature RBC\n(×10¹²/L)", fillcolor="#CB4335", fontcolor=white, shape=ellipse]
        HCT         [label="Hematocrit (%)\n[Target: <45%]", fillcolor="#A93226", fontcolor=white, shape=diamond]
        Hgb         [label="Hemoglobin\n(g/dL, >16.5M/>16.5F)", fillcolor="#922B21", fontcolor=white]
        EPO_endo    [label="Endogenous EPO\n(Suppressed, <3 IU/L)", fillcolor="#D5D8DC"]
        RBC_lifespan [label="RBC Lifespan\n(~120 days)", fillcolor="#F5CBA7"]
        EEC         [label="Endogenous\nErythroid Colony\n(EEC — JAK2V617F hallmark)", fillcolor="#D98880"]
    }

    // ============================================================
    // Cluster 4: Myeloid & Megakaryocytic Compartment
    // ============================================================
    subgraph cluster_myeloid {
        label="4. Myeloid & Megakaryocytic Compartment"
        style=filled; bgcolor="#E9F7EF"; color="#1E8449"; penwidth=2; fontsize=11; fontcolor="#1E8449"

        GMP         [label="GMP (Granulocyte-\nMacrophage Prog.)", fillcolor="#27AE60", fontcolor=white]
        Neutrophil  [label="Neutrophil\n(×10⁹/L)", fillcolor="#82E0AA", shape=ellipse]
        Monocyte    [label="Monocyte / Macrophage", fillcolor="#58D68D"]
        Basophil    [label="Basophil\n(Histamine source)", fillcolor="#2ECC71", fontcolor=white]
        Eosinophil  [label="Eosinophil", fillcolor="#A9DFBF"]
        MKP         [label="Megakaryocyte\nProgenitor (MKP)", fillcolor="#1ABC9C", fontcolor=white]
        Megakaryocyte [label="Megakaryocyte\n(Polyploid, ↑ endomitosis)", fillcolor="#16A085", fontcolor=white]
        PLT         [label="Platelet\n(×10⁹/L)", fillcolor="#148F77", fontcolor=white, shape=ellipse]
        WBC         [label="Total WBC\n(×10⁹/L)", fillcolor="#1E8449", fontcolor=white, shape=diamond]
        TPO_level   [label="TPO Level\n(Consumed → ↓)", fillcolor="#D5D8DC"]
        PLT_activation [label="Platelet\nActivation / Aggregation", fillcolor="#A9DFBF"]
        TXA2        [label="Thromboxane A2\n(TXA2 — vasoconstriction)", fillcolor="#7DCEA0"]
        P_selectin  [label="P-selectin\nExpression (↑)", fillcolor="#7DCEA0"]
        Microagg    [label="Platelet\nMicroaggregates", fillcolor="#52BE80"]
        NET         [label="Neutrophil Extracellular\nTraps (NETs — thrombosis)", fillcolor="#1E8449", fontcolor=white]
    }

    // ============================================================
    // Cluster 5: Bone Marrow Microenvironment & Fibrosis
    // ============================================================
    subgraph cluster_bm {
        label="5. Bone Marrow Microenvironment & Fibrosis"
        style=filled; bgcolor="#F4ECF7"; color="#6C3483"; penwidth=2; fontsize=11; fontcolor="#6C3483"

        Stroma_cells [label="Stromal Cells\n(MSC / Osteoblast)", fillcolor="#9B59B6", fontcolor=white]
        CAR_cells   [label="CXCL12-Abundant\nReticular (CAR) Cells", fillcolor="#8E44AD", fontcolor=white]
        Osteoclast  [label="Osteoclast\n(RANKL-activated)", fillcolor="#7D3C98", fontcolor=white]
        Osteoblast  [label="Osteoblast\n(↑ in PV)", fillcolor="#A569BD"]
        TGFb1       [label="TGF-β1\n(Fibrosis driver)", fillcolor="#6C3483", fontcolor=white]
        PDGF        [label="PDGF-AB/BB\n(MSC proliferation)", fillcolor="#7D3C98", fontcolor=white]
        FGF2        [label="bFGF/FGF2\n(Angiogenesis)", fillcolor="#8E44AD", fontcolor=white]
        Reticulin   [label="Reticulin Fibrosis\n(Grade 0→3, Silver stain)", fillcolor="#A569BD"]
        Collagen    [label="Collagen Deposition\n(Type I / III)", fillcolor="#C39BD3"]
        MF_prog     [label="MF Progression Score\n(MF-0 → MF-3)", fillcolor="#D2B4DE", shape=diamond]
        CXCL12_SDF1 [label="CXCL12 / SDF-1α\n(HSC niche retention)", fillcolor="#BB8FCE"]
        VEGF        [label="VEGF\n(↑ in BM angiogenesis)", fillcolor="#C39BD3"]
        RANKL       [label="RANKL\n(↑ osteoclast activity)", fillcolor="#D7BDE2"]
        OPN         [label="Osteopontin (OPN)\n(Fibrosis biomarker)", fillcolor="#D2B4DE"]
    }

    // ============================================================
    // Cluster 6: Spleen & Extramedullary Hematopoiesis
    // ============================================================
    subgraph cluster_spleen {
        label="6. Spleen & Extramedullary Hematopoiesis (EMH)"
        style=filled; bgcolor="#FEF9E7"; color="#9A7D0A"; penwidth=2; fontsize=11; fontcolor="#9A7D0A"

        Spleen_vol  [label="Spleen Volume\n(mL, Normal <500mL)", fillcolor="#F1C40F", fontcolor=black, shape=ellipse]
        Splenic_CD34 [label="Splenic CD34+\nProgenitor Cells", fillcolor="#F39C12", fontcolor=white]
        EMH         [label="Extramedullary\nHematopoiesis (EMH)", fillcolor="#D68910", fontcolor=white]
        Splenic_Erythro [label="Splenic\nErythropoiesis", fillcolor="#D4AC0D"]
        Splenic_Myelo [label="Splenic\nMyelopoiesis", fillcolor="#B7950B", fontcolor=white]
        Portal_HT   [label="Portal Hypertension\n(Variceal bleed risk)", fillcolor="#9A7D0A", fontcolor=white]
        Spleno_symptoms [label="Splenomegaly Symptoms\n(Early satiety, LUQ pain)", fillcolor="#F9E79F"]
        SVR         [label="Spleen Volume\nReduction ≥35%\n(SVR35 — primary endpoint)", fillcolor="#F0E68C", shape=diamond]
        Liver_EMH   [label="Hepatomegaly\n(Liver EMH)", fillcolor="#EB984E"]
    }

    // ============================================================
    // Cluster 7: Vascular & Thrombotic Axis
    // ============================================================
    subgraph cluster_vascular {
        label="7. Vascular & Thrombotic Axis"
        style=filled; bgcolor="#FDEDEC"; color="#922B21"; penwidth=2; fontsize=11; fontcolor="#922B21"

        Blood_viscosity [label="Blood Viscosity\n(↑ with HCT >45%)", fillcolor="#E74C3C", fontcolor=white]
        Endothelial_act [label="Endothelial Cell\nActivation / Dysfunction", fillcolor="#CB4335", fontcolor=white]
        VWF         [label="Von Willebrand Factor\n(VWF — large multimers)", fillcolor="#E8DAEF"]
        Thrombin    [label="Thrombin Generation\n(↑ via coagulation)", fillcolor="#D98880"]
        Fibrin      [label="Fibrin Clot\nFormation", fillcolor="#F1948A"]
        DVT         [label="Deep Vein\nThrombosis (DVT)", fillcolor="#C0392B", fontcolor=white, shape=diamond]
        Stroke      [label="Ischemic Stroke / TIA", fillcolor="#922B21", fontcolor=white, shape=diamond]
        MI          [label="Myocardial\nInfarction", fillcolor="#922B21", fontcolor=white, shape=diamond]
        BuddChiari  [label="Budd-Chiari\nSyndrome", fillcolor="#A93226", fontcolor=white, shape=diamond]
        Erythromelalgia [label="Erythromelalgia\n(Microvascular occlusion)", fillcolor="#D35400", fontcolor=white]
        NO_bioavail [label="NO Bioavailability ↓\n(Endothelial dysfunction)", fillcolor="#E59866"]
        Hyperviscosity [label="Hyperviscosity\nSyndrome", fillcolor="#E67E22", fontcolor=white]
        Thromb_risk [label="Annual Thrombosis Risk\n(>2%/yr high-risk)", fillcolor="#C0392B", fontcolor=white, shape=diamond]
        Bleed_risk  [label="Bleeding Risk\n(Acquired VWD, PLT>1500)", fillcolor="#EC7063", shape=diamond]
    }

    // ============================================================
    // Cluster 8: Inflammatory Cytokine Network
    // ============================================================
    subgraph cluster_inflam {
        label="8. Inflammatory Cytokine Network & Symptoms"
        style=filled; bgcolor="#EAF2FF"; color="#1A5276"; penwidth=2; fontsize=11; fontcolor="#1A5276"

        IL6         [label="IL-6\n(↑ inflammation)", fillcolor="#2980B9", fontcolor=white]
        IL1b        [label="IL-1β\n(↑ fever, fatigue)", fillcolor="#3498DB", fontcolor=white]
        TNFa        [label="TNF-α\n(↑ cachexia, fatigue)", fillcolor="#5DADE2"]
        IL8         [label="IL-8 / CXCL8\n(Neutrophil chemotaxis)", fillcolor="#85C1E9"]
        IL13        [label="IL-13\n(Pruritus mediator)", fillcolor="#AED6F1"]
        IL5         [label="IL-5\n(Eosinophil survival)", fillcolor="#D6EAF8"]
        IFNg        [label="IFN-γ\n(Immune activation)", fillcolor="#2471A3", fontcolor=white]
        LDH_marker  [label="LDH\n(Proliferation marker, ↑)", fillcolor="#1A5276", fontcolor=white]
        Histamine   [label="Histamine\n(from Basophils)", fillcolor="#D2B4DE"]
        Pruritus    [label="Aquagenic\nPruritus", fillcolor="#A569BD", shape=diamond]
        Fatigue     [label="Fatigue /\nConstitutional Sx", fillcolor="#9B59B6", fontcolor=white, shape=diamond]
        Night_sweats [label="Night Sweats\n& Weight Loss", fillcolor="#6C3483", fontcolor=white]
        CRP         [label="CRP\n(Acute phase reactant)", fillcolor="#1F618D", fontcolor=white]
        MPN_SAF_TSS [label="MPN-SAF Total\nSymptom Score (TSS)\n[Endpoint: ≥50% reduction]", fillcolor="#2874A6", fontcolor=white, shape=diamond]
    }

    // ============================================================
    // Cluster 9: Disease Progression & Transformation
    // ============================================================
    subgraph cluster_progression {
        label="9. Disease Progression & Transformation"
        style=filled; bgcolor="#F9EBEA"; color="#922B21"; penwidth=2; fontsize=11; fontcolor="#922B21"

        PV_to_MF    [label="PV → Post-PV MF\n(10–25% at 15yr)", fillcolor="#C0392B", fontcolor=white, shape=diamond]
        MF_to_AML   [label="Post-PV MF → AML\n(Blast Transformation)", fillcolor="#922B21", fontcolor=white, shape=diamond]
        Additional_mut [label="Additional Somatic Mutations\n(TET2, ASXL1, IDH1/2, SRSF2)", fillcolor="#E74C3C", fontcolor=white]
        Genomic_instab [label="Genomic\nInstability", fillcolor="#D35400", fontcolor=white]
        ELN_risk    [label="ELN 2022 Risk\n(Low / High)", fillcolor="#F1948A", shape=diamond]
        IWG_MRT_resp [label="IWG-MRT Response\n(CR / PR / NR)", fillcolor="#D98880", shape=diamond]
        OS          [label="Overall Survival\n(Median ~14yr in PV)", fillcolor="#A93226", fontcolor=white, shape=diamond]
        TFS         [label="Transformation-Free\nSurvival", fillcolor="#E74C3C", fontcolor=white, shape=diamond]
        Leukocytosis_prog [label="Leukocytosis\nProgression (WBC>11)", fillcolor="#EB984E"]
    }

    // ============================================================
    // Cluster 10: Clinical Endpoints & Response Criteria
    // ============================================================
    subgraph cluster_endpoints {
        label="10. Clinical Endpoints & Response Criteria"
        style=filled; bgcolor="#E8F8F5"; color="#0E6655"; penwidth=2; fontsize=11; fontcolor="#0E6655"

        HCT_target  [label="Hematocrit Target\nControl (<45%)", fillcolor="#1ABC9C", fontcolor=white, shape=diamond]
        CBC_resp    [label="CBC Normalization\n(WBC<10, PLT<400)", fillcolor="#16A085", fontcolor=white]
        CHR         [label="Complete Hematologic\nResponse (CHR)", fillcolor="#148F77", fontcolor=white, shape=diamond]
        Phlebotomy_freq [label="Phlebotomy Frequency\n(n/yr, Target ≤1)", fillcolor="#1E8449", fontcolor=white]
        Allele_burden_out [label="JAK2 Allele Burden\nResponse (<50% / <10%)", fillcolor="#27AE60", fontcolor=white, shape=diamond]
        QoL_out     [label="Quality of Life\n(EORTC QLQ-C30)", fillcolor="#58D68D", shape=diamond]
        Mol_remission [label="Molecular\nRemission (IFN)", fillcolor="#82E0AA", shape=diamond]
        BMB_response [label="Bone Marrow Biopsy\nAge-adjusted Normocellularity", fillcolor="#A9DFBF"]
    }

    // ============================================================
    // Cluster 11: Drug Pharmacokinetics & Pharmacodynamics
    // ============================================================
    subgraph cluster_drug {
        label="11. Drug Pharmacokinetics & Pharmacodynamics"
        style=filled; bgcolor="#F8F9FA"; color="#2C3E50"; penwidth=2; fontsize=11; fontcolor="#2C3E50"

        // Ruxolitinib
        RUX_dose    [label="Ruxolitinib\n(5–25 mg BID, oral)", fillcolor="#2C3E50", fontcolor=white]
        RUX_gut     [label="Ruxolitinib\nGI Compartment", fillcolor="#566573", fontcolor=white]
        RUX_cent    [label="Ruxolitinib\nCentral Cp (ng/mL)", fillcolor="#6C757D", fontcolor=white]
        RUX_periph  [label="Ruxolitinib\nPeripheral", fillcolor="#868E96"]
        RUX_pd      [label="Ruxolitinib PD\nJAK1/2 Inhibition\n(IC50 JAK2 ~3 nM)", fillcolor="#ADB5BD"]

        // Hydroxyurea
        HU_dose     [label="Hydroxyurea\n(500–2000 mg/day)", fillcolor="#1A252F", fontcolor=white]
        HU_cent     [label="HU Central\nCp (mg/L)", fillcolor="#273746", fontcolor=white]
        HU_pd       [label="HU Mechanism\n(Ribonucleotide\nReductase Inhibition)", fillcolor="#2E4057", fontcolor=white]

        // Ropeginterferon
        ROPEG_dose  [label="Ropeg-IFN α-2b\n(100–250 mcg q2w → qmo)", fillcolor="#1B4F72", fontcolor=white]
        IFN_sc      [label="IFN-α2b\nSC Depot (IU)", fillcolor="#1F618D", fontcolor=white]
        IFN_cent    [label="IFN-α2b\nCentral (IU/mL)\nt½ ~80–130h", fillcolor="#2874A6", fontcolor=white]
        IFN_pd      [label="IFN PD\n(IFNAR → JAK1/TYK2 →\nSTAT1/2 activation)\nClone suppression", fillcolor="#2E86C1", fontcolor=white]

        // Low-dose aspirin
        ASP_dose    [label="Low-Dose Aspirin\n(75–100 mg/day)", fillcolor="#117A65", fontcolor=white]
        ASP_cent    [label="Aspirin\nCentral (mg/L)", fillcolor="#148F77", fontcolor=white]
        ASP_pd      [label="Aspirin PD\n(COX-1 Inhibition)\nTXA2 ↓", fillcolor="#1ABC9C", fontcolor=white]

        // Phlebotomy
        Phlebotomy  [label="Therapeutic Phlebotomy\n(450 mL/session)", fillcolor="#5D6D7E", fontcolor=white]

        // Fedratinib
        FED_dose    [label="Fedratinib\n(400 mg/day, oral)", fillcolor="#6C3483", fontcolor=white]
        FED_cent    [label="Fedratinib\nCentral Cp (ng/mL)", fillcolor="#7D3C98", fontcolor=white]
        FED_pd      [label="Fedratinib PD\n(JAK2/FLT3 Inhibition)\nSpleen reduction", fillcolor="#8E44AD", fontcolor=white]

        // Busulfan
        BUS_dose    [label="Busulfan\n(2–6 mg/day, oral)", fillcolor="#17202A", fontcolor=white]
        BUS_cent    [label="Busulfan\nCentral (ng/mL)", fillcolor="#212F3D", fontcolor=white]
        BUS_pd      [label="Busulfan PD\n(DNA Alkylation)\nHSC pool reduction", fillcolor="#2C3444", fontcolor=white]

        // Anagrelide
        ANA_dose    [label="Anagrelide\n(0.5–3 mg/day)\n(PLT-selective)", fillcolor="#154360", fontcolor=white]
        ANA_cent    [label="Anagrelide\nCentral Cp", fillcolor="#1A5276", fontcolor=white]
        ANA_pd      [label="Anagrelide PD\n(PDE3 Inhibition →\nMegakaryocyte maturation ↓)", fillcolor="#2471A3", fontcolor=white]
    }

    // ===================================================
    // EDGES — Genetic/Molecular
    // ===================================================
    JAK2V617F   -> JAK2_kinase [label="constitutive\nactivation", color="#E74C3C", penwidth=2.5]
    JAK2_exon12 -> JAK2_kinase [label="alternative\nactivation", color="#E74C3C", penwidth=1.5]
    JAK2_homo   -> JAK2_kinase [label="enhanced\nactivation (×2)", color="#C0392B", penwidth=3]
    JAK2V617F   -> Clone_HSC   [label="clonal expansion\nadvantage", color="#C0392B", penwidth=2]
    Clone_HSC   -> VF_allele   [label="% allele burden\n(0–100%)", color="#D35400"]
    TET2        -> Clone_HSC   [label="clonal advantage\n(co-mutation)", color="#E67E22"]
    DNMT3A      -> Clone_HSC   [label="epigenetic\nreprogramming", color="#E67E22"]
    ASXL1       -> clonal_evol [label="MF risk ↑", color="#C0392B"]
    IDH1_IDH2   -> clonal_evol [label="AML risk ↑", color="#922B21", penwidth=2]
    TP53        -> Genomic_instab [label="p53 loss", color="#922B21", penwidth=2]
    CHIP        -> JAK2V617F   [label="pre-existing\nCHIP → PV", color="#E59866", style=dashed]
    clonal_evol -> Additional_mut [color="#C0392B"]
    JAK2_homo   -> Clone_HSC   [label="increased\nfitness", color="#CB4335"]

    // ===================================================
    // EDGES — JAK-STAT Signaling
    // ===================================================
    JAK2_kinase -> STAT5_act [label="Tyr694\nphosphorylation", color="#8E44AD", penwidth=2.5]
    JAK2_kinase -> STAT3_act [color="#9B59B6"]
    JAK2_kinase -> STAT1_act [color="#9B59B6"]
    JAK2_kinase -> PI3K      [color="#2980B9"]
    JAK2_kinase -> RAS       [color="#21618C"]
    EPO_R       -> JAK2_kinase [label="ligand-\nindependent\nactivation", color="#2ECC71"]
    TPO_R       -> JAK2_kinase [color="#27AE60"]
    G_CSFR      -> JAK2_kinase [color="#1ABC9C"]
    JAK1_kinase -> STAT5_act [color="#9B59B6"]
    TYK2        -> STAT1_act  [label="IFN response", color="#A569BD"]
    PI3K        -> AKT        [color="#2874A6"]
    AKT         -> mTOR       [color="#2874A6"]
    RAS         -> MAPK       [color="#21618C"]
    STAT5_act   -> BCL2       [label="anti-apoptosis\ngene induction", color="#117A65"]
    STAT5_act   -> MCL1       [color="#1E8449"]
    STAT5_act   -> PIM_kinase [color="#148F77"]
    STAT5_act   -> CDK4_6     [label="cell cycle\nentry", color="#0E6655"]
    STAT5_act   -> SOCS1      [label="negative\nfeedback", color="#7F8C8D", style=dashed]
    STAT5_act   -> SOCS3      [color="#7F8C8D", style=dashed]
    SOCS1       -> JAK2_kinase [label="ubiquitin-\nmediated\ndegradation", color="#95A5A6", style=dashed, arrowhead=tee]
    SOCS3       -> JAK2_kinase [color="#95A5A6", style=dashed, arrowhead=tee]
    mTOR        -> BFU_E_mut  [label="S6K1 → protein\nsynthesis", color="#2874A6"]

    // ===================================================
    // EDGES — Erythropoiesis
    // ===================================================
    HSC_mut     -> CMP         [color="#E74C3C"]
    HSC_wt      -> CMP         [color="#3498DB", style=dashed]
    CMP         -> MEP_mut     [label="mutant\nlineage", color="#E74C3C"]
    CMP         -> MEP_wt      [label="wt lineage", color="#AED6F1", style=dashed]
    MEP_mut     -> BFU_E_mut   [color="#E74C3C"]
    MEP_wt      -> BFU_E_wt    [color="#85C1E9", style=dashed]
    STAT5_act   -> BFU_E_mut   [label="EPO-independent\nproliferation (EEC)", color="#8E44AD", penwidth=2.5]
    BCL2        -> BFU_E_mut   [label="apoptosis\nresistance", color="#117A65"]
    BFU_E_mut   -> CFU_E_mut   [color="#E74C3C"]
    BFU_E_wt    -> CFU_E_wt    [color="#3498DB", style=dashed]
    CFU_E_mut   -> ProE        [color="#E67E22"]
    CFU_E_wt    -> ProE        [color="#AED6F1", style=dashed]
    ProE        -> BasoE       [color="#F0B27A"]
    BasoE       -> OrthoE      [color="#F0B27A"]
    OrthoE      -> Retic       [color="#F5CBA7"]
    Retic       -> RBC         [label="~1 day\nmaturation", color="#EB984E"]
    RBC         -> HCT         [label="↑ erythrocyte\nmass", color="#A93226", penwidth=2.5]
    HCT         -> Hgb         [color="#922B21"]
    EPO_endo    -> BFU_E_wt    [label="EPO-dependent\nnormal pathway", color="#D5D8DC", style=dashed]
    EPO_R       -> EPO_endo    [label="feedback\nsuppression", color="#E74C3C", style=dashed, arrowhead=tee]
    BFU_E_mut   -> EEC         [label="growth in\nabsence EPO", color="#D98880"]
    RBC_lifespan -> RBC        [label="120d senescence\n→ splenic clearance", color="#F5CBA7", style=dashed, arrowhead=tee]
    Clone_HSC   -> HSC_mut     [label="clonal\noutgrowth", color="#C0392B"]

    // ===================================================
    // EDGES — Myeloid/Megakaryocyte
    // ===================================================
    CMP         -> GMP         [color="#27AE60"]
    GMP         -> Neutrophil  [color="#27AE60"]
    GMP         -> Monocyte    [color="#58D68D"]
    GMP         -> Basophil    [color="#2ECC71"]
    GMP         -> Eosinophil  [color="#A9DFBF"]
    MEP_mut     -> MKP         [color="#E74C3C"]
    MKP         -> Megakaryocyte [color="#16A085"]
    Megakaryocyte -> PLT       [label="platelet\nbiogenesis\n(proplatelet shed)", color="#148F77", penwidth=2]
    Basophil    -> Histamine   [label="IgE-\nindependent\nrelease", color="#D2B4DE"]
    Histamine   -> Pruritus    [label="H1/H4\nreceptors", color="#A569BD"]
    PLT         -> PLT_activation [color="#A9DFBF"]
    PLT_activation -> TXA2    [color="#A9DFBF"]
    PLT_activation -> P_selectin [color="#A9DFBF"]
    P_selectin  -> Thrombin    [label="coagulation\ncascade\nactivation", color="#D98880"]
    TXA2        -> Erythromelalgia [label="terminal\narteriole\nocclusion", color="#D35400"]
    PLT         -> Bleed_risk  [label="PLT>1500\nacquired VWD", color="#EC7063"]
    Neutrophil  -> NET         [label="NET\nformation", color="#1E8449"]
    NET         -> Thrombin    [label="NET-mediated\nthrombus", color="#D98880"]
    STAT5_act   -> Megakaryocyte [label="TPO-independent\nmegakaryopoiesis", color="#8E44AD"]
    Neutrophil  -> IL8         [color="#85C1E9"]
    Monocyte    -> IL6         [color="#2980B9"]
    Monocyte    -> IL1b        [color="#3498DB"]
    Monocyte    -> TNFa        [color="#5DADE2"]
    Basophil    -> IL13        [color="#AED6F1"]
    Eosinophil  -> IL5         [color="#D6EAF8"]

    // ===================================================
    // EDGES — Bone Marrow Microenvironment
    // ===================================================
    Megakaryocyte -> TGFb1     [label="release from\nabnormal MK", color="#6C3483"]
    Megakaryocyte -> PDGF      [label="α-granule\nrelease", color="#7D3C98"]
    Megakaryocyte -> VEGF      [color="#8E44AD"]
    TGFb1        -> Stroma_cells [label="MSC\nactivation", color="#6C3483"]
    PDGF         -> Stroma_cells [color="#7D3C98"]
    TGFb1        -> Reticulin   [label="collagen\ndeposition", color="#6C3483", penwidth=2.5]
    Reticulin    -> Collagen    [label="grade\nprogression", color="#A569BD"]
    Collagen     -> MF_prog     [label="histologic\ngrade 0–3", color="#C39BD3"]
    VEGF         -> CXCL12_SDF1 [label="niche\nremodeling", color="#D7BDE2"]
    Stroma_cells -> CXCL12_SDF1 [color="#BB8FCE"]
    CXCL12_SDF1  -> HSC_mut    [label="HSC\nniche retention", color="#8E44AD", style=dashed]
    Stroma_cells -> FGF2       [color="#9B59B6"]
    Megakaryocyte -> OPN       [label="OPN release", color="#D2B4DE"]
    OPN          -> MF_prog    [label="fibrosis\nbiomarker", color="#D2B4DE"]
    TGFb1        -> Osteoclast [label="RANKL\nactivation", color="#7D3C98"]
    RANKL        -> Osteoclast [color="#D7BDE2"]
    Osteoclast   -> MF_prog    [label="osteosclerosis", color="#7D3C98"]

    // ===================================================
    // EDGES — Spleen / EMH
    // ===================================================
    Clone_HSC   -> Splenic_CD34 [label="CD34+ mobilization\nto spleen", color="#D68910"]
    Splenic_CD34 -> EMH         [color="#D4AC0D"]
    EMH         -> Splenic_Erythro [color="#D68910"]
    EMH         -> Splenic_Myelo   [color="#B7950B"]
    Splenic_Erythro -> Spleen_vol  [label="EMH-driven\nenlargement", color="#D68910", penwidth=2]
    Splenic_Myelo   -> Spleen_vol  [color="#B7950B"]
    Spleen_vol  -> Portal_HT       [label="massive\nsplenomegaly", color="#9A7D0A"]
    Spleen_vol  -> Spleno_symptoms [color="#F0E68C"]
    IL6         -> Spleen_vol      [label="cytokine-driven\nEMH", color="#2874A6"]
    EMH         -> Liver_EMH       [label="hepatic\nEMH", color="#EB984E"]

    // ===================================================
    // EDGES — Vascular/Thrombotic
    // ===================================================
    HCT         -> Blood_viscosity [label="↑ viscosity\nHCT >45%", color="#E74C3C", penwidth=2.5]
    WBC         -> Blood_viscosity [label="leukocytosis\n↑ viscosity", color="#27AE60"]
    PLT         -> Blood_viscosity [label="thrombocytosis", color="#148F77"]
    Blood_viscosity -> Hyperviscosity [color="#E67E22", penwidth=2]
    Blood_viscosity -> Endothelial_act [color="#CB4335"]
    Endothelial_act -> VWF         [label="VWF\nabnormalities", color="#E8DAEF"]
    VWF         -> Thrombin        [color="#D98880"]
    Thrombin    -> Fibrin          [color="#F1948A"]
    Fibrin      -> DVT             [color="#C0392B", penwidth=2]
    Fibrin      -> Stroke          [color="#922B21", penwidth=2]
    Fibrin      -> MI              [color="#922B21", penwidth=2]
    Fibrin      -> BuddChiari      [color="#A93226"]
    Endothelial_act -> NO_bioavail [color="#E59866", arrowhead=tee]
    Blood_viscosity -> Thromb_risk  [label="major risk\nfactor", color="#E74C3C", penwidth=2]
    HCT         -> ELN_risk        [label="high HCT\n→ high-risk feature", color="#E74C3C"]

    // ===================================================
    // EDGES — Inflammatory/Symptoms
    // ===================================================
    IL13        -> Pruritus    [color="#A569BD"]
    IL6         -> CRP         [color="#1A5276"]
    IL1b        -> Fatigue     [color="#9B59B6"]
    TNFa        -> Night_sweats [color="#6C3483"]
    TNFa        -> Fatigue     [color="#9B59B6"]
    Pruritus    -> MPN_SAF_TSS [color="#A569BD", penwidth=2]
    Fatigue     -> MPN_SAF_TSS [color="#9B59B6", penwidth=2]
    Night_sweats -> MPN_SAF_TSS [color="#6C3483"]
    Spleno_symptoms -> MPN_SAF_TSS [color="#F0E68C"]
    STAT5_act   -> MPN_SAF_TSS [label="cytokine-driven\nsymptoms", color="#9B59B6"]
    LDH_marker  -> Leukocytosis_prog [color="#EB984E"]

    // ===================================================
    // EDGES — Disease Progression
    // ===================================================
    MF_prog     -> PV_to_MF    [label="fibrosis\ngrade 2–3", color="#C0392B", penwidth=2]
    Additional_mut -> PV_to_MF [color="#E74C3C"]
    PV_to_MF    -> MF_to_AML   [label="blast phase\ntransformation", color="#922B21", penwidth=2]
    Genomic_instab -> MF_to_AML [color="#922B21"]
    VF_allele   -> PV_to_MF    [label="high allele burden\n(>50%) → MF risk", color="#E74C3C"]
    MF_to_AML   -> OS          [color="#922B21"]
    PV_to_MF    -> OS          [color="#C0392B"]
    PV_to_MF    -> TFS         [color="#D98880"]
    ELN_risk    -> OS          [color="#E74C3C"]
    Thromb_risk -> OS          [label="CV events\n→ mortality", color="#C0392B"]
    PLT         -> ELN_risk    [label="PLT>1500\n→ high-risk", color="#148F77"]

    // ===================================================
    // EDGES — Clinical Endpoints
    // ===================================================
    HCT         -> HCT_target  [color="#1ABC9C"]
    PLT         -> CBC_resp    [color="#16A085"]
    WBC         -> CBC_resp    [color="#1E8449"]
    CBC_resp    -> CHR         [color="#148F77"]
    HCT_target  -> CHR         [color="#1ABC9C"]
    Spleen_vol  -> SVR         [color="#D4AC0D"]
    MPN_SAF_TSS -> QoL_out     [color="#58D68D"]
    VF_allele   -> Allele_burden_out [color="#27AE60"]
    Allele_burden_out -> Mol_remission [label="<10% allele burden\n= Mol. Remission", color="#82E0AA"]
    HCT_target  -> Thromb_risk [label="HCT control\nreduces thrombosis", color="#E74C3C", arrowhead=tee, style=dashed]
    Phlebotomy_freq -> HCT_target [color="#5D6D7E"]
    CHR         -> IWG_MRT_resp [color="#D98880"]

    // ===================================================
    // EDGES — Drug PK/PD
    // ===================================================
    // Ruxolitinib
    RUX_dose    -> RUX_gut  [label="oral (F≈95%)", color="#2C3E50"]
    RUX_gut     -> RUX_cent [label="ka=2.16/h\nTmax~1.5h", color="#566573"]
    RUX_cent    -> RUX_periph [label="Vd=72L", color="#6C757D"]
    RUX_cent    -> RUX_pd   [color="#ADB5BD"]
    RUX_pd      -> JAK2_kinase [label="JAK1/2 inhibition\nIC50(JAK2)~3nM", color="#E74C3C", arrowhead=tee, penwidth=2.5]
    RUX_pd      -> STAT5_act  [color="#3498DB", arrowhead=tee]
    RUX_pd      -> Spleen_vol [label="SVR35\n(~40% pts)", color="#D4AC0D", arrowhead=tee]
    RUX_pd      -> MPN_SAF_TSS [label="TSS reduction\n(~55%)", color="#9B59B6", arrowhead=tee]

    // Hydroxyurea
    HU_dose     -> HU_cent  [label="oral (F~80%)", color="#1A252F"]
    HU_cent     -> HU_pd    [color="#273746"]
    HU_pd       -> BFU_E_mut [label="cytoreduction\n(S-phase block)", color="#C0392B", arrowhead=tee, penwidth=2]
    HU_pd       -> PLT      [color="#148F77", arrowhead=tee]
    HU_pd       -> WBC      [color="#1E8449", arrowhead=tee]
    HU_pd       -> RBC      [color="#CB4335", arrowhead=tee]

    // Ropeginterferon
    ROPEG_dose  -> IFN_sc   [label="SC injection\n(depot formation)", color="#1B4F72"]
    IFN_sc      -> IFN_cent [label="ka=0.15/day\nAUC proportional", color="#1F618D"]
    IFN_cent    -> IFN_pd   [label="IFNAR1/2\nactivation", color="#2874A6"]
    IFN_pd      -> Clone_HSC [label="selective clone\nelimination", color="#E74C3C", arrowhead=tee, penwidth=2.5]
    IFN_pd      -> VF_allele  [label="allele burden\nreduction", color="#E74C3C", arrowhead=tee]
    IFN_pd      -> STAT1_act  [label="anti-proliferative\neffect", color="#2471A3"]
    IFN_pd      -> BFU_E_mut  [color="#C0392B", arrowhead=tee]

    // Aspirin
    ASP_dose    -> ASP_cent [label="oral (F~68%)", color="#117A65"]
    ASP_cent    -> ASP_pd   [color="#148F77"]
    ASP_pd      -> TXA2     [label="COX-1\nirreversible\ninhibition", color="#1ABC9C", arrowhead=tee, penwidth=2]
    ASP_pd      -> PLT_activation [color="#A9DFBF", arrowhead=tee]
    ASP_pd      -> Thromb_risk    [label="primary prevention\n(1x/day)", color="#E74C3C", arrowhead=tee]
    ASP_pd      -> Erythromelalgia [color="#D35400", arrowhead=tee]

    // Phlebotomy
    Phlebotomy  -> RBC      [label="450mL whole blood\nremoval", color="#5D6D7E", arrowhead=tee]
    Phlebotomy  -> HCT      [label="target HCT<45%", color="#A93226", arrowhead=tee, penwidth=2]
    Phlebotomy  -> Blood_viscosity [color="#E74C3C", arrowhead=tee]
    Phlebotomy  -> Phlebotomy_freq [color="#5D6D7E"]

    // Fedratinib
    FED_dose    -> FED_cent [label="oral (F~98%)\nTmax~3h", color="#6C3483"]
    FED_cent    -> FED_pd   [color="#7D3C98"]
    FED_pd      -> JAK2_kinase [label="JAK2/FLT3\ninhibition", color="#E74C3C", arrowhead=tee, penwidth=2]
    FED_pd      -> Spleen_vol  [color="#D4AC0D", arrowhead=tee]
    FED_pd      -> STAT5_act   [color="#3498DB", arrowhead=tee]

    // Busulfan
    BUS_dose    -> BUS_cent [label="oral (F~80%)", color="#17202A"]
    BUS_cent    -> BUS_pd   [color="#212F3D"]
    BUS_pd      -> Clone_HSC [label="alkylation\n→ clone ↓", color="#C0392B", arrowhead=tee]
    BUS_pd      -> RBC       [color="#CB4335", arrowhead=tee]

    // Anagrelide
    ANA_dose    -> ANA_cent [label="oral (F~70%)", color="#154360"]
    ANA_cent    -> ANA_pd   [color="#1A5276"]
    ANA_pd      -> Megakaryocyte [label="PDE3 inhibition\n→ MK maturation ↓", color="#16A085", arrowhead=tee]
    ANA_pd      -> PLT         [label="PLT-selective\ncytoreduction", color="#148F77", arrowhead=tee, penwidth=2]

    // Cross-pathway key connections
    VF_allele   -> STAT5_act     [label="allele burden\n→ STAT signal amplitude", color="#8E44AD"]
    IL6         -> Leukocytosis_prog [color="#EB984E"]
    MPN_SAF_TSS -> QoL_out       [color="#1ABC9C"]
    CHR         -> OS            [color="#922B21", style=dashed]
    BMB_response -> IWG_MRT_resp [color="#D98880"]
    Mol_remission -> IWG_MRT_resp [color="#82E0AA"]
}
