digraph sepsis_qsp {
    graph [
        rankdir=LR,
        fontname="Helvetica",
        fontsize=11,
        label="Sepsis & Septic Shock — QSP Mechanistic Map\nPathogen Recognition · Innate Immunity · Cytokine Storm · Coagulation · Organ Failure · Drug PK/PD",
        labelloc=t,
        labeljust=c,
        bgcolor="#FAFAFA",
        splines=ortho,
        nodesep=0.4,
        ranksep=0.7,
        compound=true
    ]
    node [fontname="Helvetica", fontsize=9, style="filled,rounded", shape=box]
    edge [fontname="Helvetica", fontsize=8, arrowsize=0.7]

    /* ============================================================
       CLUSTER 1: PATHOGEN RECOGNITION — PAMPs / DAMPs / PRRs
       ============================================================ */
    subgraph cluster_pathogen {
        label="1. Pathogen Recognition\n(PAMPs / DAMPs / PRRs)"
        style=filled; fillcolor="#FFF3E0"; color="#E65100"; penwidth=2

        LPS [label="LPS\n(Endotoxin)", fillcolor="#FFCC80"]
        PGN [label="PGN / LTA\n(Gram+)", fillcolor="#FFCC80"]
        BetaGlucan [label="β-Glucan\n(Fungal)", fillcolor="#FFCC80"]
        Flagellin [label="Flagellin\n(TLR5 ligand)", fillcolor="#FFCC80"]
        ViralRNA [label="dsRNA/ssRNA\n(Viral)", fillcolor="#FFCC80"]
        HMGB1_source [label="HMGB1\n(DAMP, late)", fillcolor="#FFB74D"]
        S100 [label="S100A8/A9\n(DAMP)", fillcolor="#FFB74D"]
        mtDNA [label="Mitochondrial DNA\n(DAMP)", fillcolor="#FFB74D"]
        ATP_DAMP [label="ATP\n(DAMP)", fillcolor="#FFB74D"]
        HSP [label="Heat Shock Proteins\n(HSP70/HSP90)", fillcolor="#FFB74D"]
        TLR4 [label="TLR4\n(LPS sensor)", fillcolor="#FF8F00", fontcolor="white"]
        TLR2 [label="TLR2\n(PGN/LTA)", fillcolor="#FF8F00", fontcolor="white"]
        TLR5 [label="TLR5\n(Flagellin)", fillcolor="#FF8F00", fontcolor="white"]
        TLR9 [label="TLR9\n(CpG DNA)", fillcolor="#FF8F00", fontcolor="white"]
        TLR3 [label="TLR3\n(dsRNA)", fillcolor="#FF8F00", fontcolor="white"]
        NLRP3 [label="NLRP3\nInflammasome", fillcolor="#F57F17", fontcolor="white"]
        NOD12 [label="NOD1/2\n(Intracellular)", fillcolor="#F57F17", fontcolor="white"]
        cGAS_STING [label="cGAS-STING\n(mtDNA sensor)", fillcolor="#F57F17", fontcolor="white"]
        MyD88 [label="MyD88\nAdaptor", fillcolor="#E65100", fontcolor="white"]
        TRIF [label="TRIF\nAdaptor", fillcolor="#E65100", fontcolor="white"]
        NFkB_act [label="NF-κB\nActivation", fillcolor="#BF360C", fontcolor="white", shape=diamond]
        IRF37 [label="IRF3/7\n(IFN induction)", fillcolor="#BF360C", fontcolor="white"]
    }

    /* ============================================================
       CLUSTER 2: INNATE IMMUNE ACTIVATION
       ============================================================ */
    subgraph cluster_innate {
        label="2. Innate Immune Activation"
        style=filled; fillcolor="#E8F5E9"; color="#1B5E20"; penwidth=2

        Neut_blood [label="Neutrophils\n(Blood)", fillcolor="#A5D6A7"]
        Neut_tissue [label="Neutrophils\n(Tissue/Infiltrating)", fillcolor="#81C784"]
        NET_form [label="NETs\n(Traps)", fillcolor="#66BB6A"]
        Mac_M1 [label="Macrophages\n(M1 Activated)", fillcolor="#43A047", fontcolor="white"]
        Mac_M2 [label="Macrophages\n(M2 Regulatory)", fillcolor="#388E3C", fontcolor="white"]
        Mono_blood [label="Monocytes\n(Circulating)", fillcolor="#A5D6A7"]
        DC_cell [label="Dendritic Cells\n(mDC)", fillcolor="#C8E6C9"]
        NK_cell [label="NK Cells", fillcolor="#C8E6C9"]
        Mast_cell [label="Mast Cells", fillcolor="#C8E6C9"]
        ROS_burst [label="ROS\n(Respiratory Burst)", fillcolor="#FF6F00", fontcolor="white"]
        MPO [label="Myeloperoxidase\n(MPO)", fillcolor="#FF8F00"]
        Elastase [label="Neutrophil\nElastase", fillcolor="#FF8F00"]
        MMP9 [label="MMP-9\n(Tissue remodeling)", fillcolor="#FFB300"]
        Phagocytosis [label="Phagocytosis\n(Bacterial clearance)", fillcolor="#4CAF50", fontcolor="white"]
        Apoptosis_imm [label="Immune Cell\nApoptosis", fillcolor="#E53935", fontcolor="white"]
    }

    /* ============================================================
       CLUSTER 3: CYTOKINE NETWORK (Pro- & Anti-inflammatory)
       ============================================================ */
    subgraph cluster_cytokines {
        label="3. Cytokine Storm Network"
        style=filled; fillcolor="#FCE4EC"; color="#880E4F"; penwidth=2

        TNFa [label="TNFα\n(Early mediator)", fillcolor="#F48FB1"]
        IL1b [label="IL-1β\n(Inflammasome)", fillcolor="#F48FB1"]
        IL6 [label="IL-6\n(Acute phase)", fillcolor="#EC407A", fontcolor="white"]
        IL8 [label="IL-8 (CXCL8)\n(Neutrophil chemo)", fillcolor="#F48FB1"]
        IL12 [label="IL-12\n(Th1 priming)", fillcolor="#CE93D8"]
        IL17 [label="IL-17\n(Neutrophil recruit)", fillcolor="#CE93D8"]
        IL18 [label="IL-18\n(IFNγ inducer)", fillcolor="#CE93D8"]
        IFNg [label="IFN-γ\n(Macrophage act.)", fillcolor="#AB47BC", fontcolor="white"]
        MCP1 [label="MCP-1 (CCL2)\n(Monocyte recruit)", fillcolor="#F8BBD9"]
        MIP1a [label="MIP-1α (CCL3)\n(Chemokine)", fillcolor="#F8BBD9"]
        HMGB1_cyto [label="HMGB1\n(Late cytokine)", fillcolor="#880E4F", fontcolor="white"]
        IL10 [label="IL-10\n(Anti-inflammatory)", fillcolor="#81D4FA"]
        TGFb [label="TGF-β\n(Immunosuppressive)", fillcolor="#81D4FA"]
        IL4 [label="IL-4\n(Th2/regulatory)", fillcolor="#B2EBF2"]
        VEGF [label="VEGF\n(Vascular permeability)", fillcolor="#FF8A65"]
        ANG2 [label="Angiopoietin-2\n(Endothelial destab.)", fillcolor="#FF7043", fontcolor="white"]
        PCT_prod [label="Procalcitonin\n(PCT production)", fillcolor="#FFCC80"]
        CRP_prod [label="CRP\n(Acute phase protein)", fillcolor="#FFCC80"]
    }

    /* ============================================================
       CLUSTER 4: COMPLEMENT CASCADE
       ============================================================ */
    subgraph cluster_complement {
        label="4. Complement System"
        style=filled; fillcolor="#E3F2FD"; color="#0D47A1"; penwidth=2

        C1q [label="C1q\n(Classical pathway)", fillcolor="#90CAF9"]
        MBL [label="MBL\n(Lectin pathway)", fillcolor="#90CAF9"]
        AltPath [label="Factor B/D\n(Alternative pathway)", fillcolor="#90CAF9"]
        C3_conv [label="C3 Convertase", fillcolor="#42A5F5"]
        C3_cleavage [label="C3 → C3a + C3b", fillcolor="#2196F3", fontcolor="white", shape=diamond]
        C3a [label="C3a\n(Anaphylatoxin)", fillcolor="#1976D2", fontcolor="white"]
        C3b [label="C3b\n(Opsonin)", fillcolor="#1976D2", fontcolor="white"]
        C5_conv [label="C5 Convertase", fillcolor="#42A5F5"]
        C5a [label="C5a\n(Potent anaphylatoxin)", fillcolor="#0D47A1", fontcolor="white"]
        C5b9_MAC [label="MAC (C5b-9)\n(Lysis)", fillcolor="#0D47A1", fontcolor="white"]
        C5aR [label="C5aR\n(on Neutrophils/Mac)", fillcolor="#1565C0", fontcolor="white"]
        C3aR [label="C3aR\n(on Mast cells)", fillcolor="#1E88E5"]
    }

    /* ============================================================
       CLUSTER 5: COAGULATION / DIC
       ============================================================ */
    subgraph cluster_coagulation {
        label="5. Coagulation Cascade / DIC"
        style=filled; fillcolor="#FFF8E1"; color="#F57F17"; penwidth=2

        TF_expr [label="Tissue Factor (TF)\nUpregulation", fillcolor="#FFF176"]
        TF_VIIa [label="TF–FVIIa\nComplex", fillcolor="#FDD835"]
        FXa [label="FXa\n(Prothrombinase)", fillcolor="#F9A825"]
        Thrombin [label="Thrombin (FIIa)\n(Central coag. enzyme)", fillcolor="#F57F17", fontcolor="white"]
        Fibrinogen [label="Fibrinogen\n(Plasma)", fillcolor="#FFE57F"]
        Fibrin [label="Fibrin\n(Clot formation)", fillcolor="#FFCA28"]
        FXIIIa [label="FXIIIa\n(Cross-linking)", fillcolor="#FFB300"]
        Plt_act [label="Platelet\nActivation", fillcolor="#FF8F00", fontcolor="white"]
        PAI1 [label="PAI-1\n(Fibrinolysis inhibitor)", fillcolor="#E65100", fontcolor="white"]
        tPA [label="tPA\n(Fibrinolysis)", fillcolor="#AED6F1"]
        ProtC_act [label="Protein C\n(Anticoagulant)", fillcolor="#A9DFBF"]
        APC [label="Activated Protein C\n(APC)", fillcolor="#27AE60", fontcolor="white"]
        ATIII [label="Antithrombin III\n(Thrombin inhibitor)", fillcolor="#A9DFBF"]
        DDimer [label="D-dimer\n(Fibrin degradation)", fillcolor="#FDEBD0"]
        DIC_state [label="DIC\n(Consumptive coagulation)", fillcolor="#C0392B", fontcolor="white", shape=diamond]
    }

    /* ============================================================
       CLUSTER 6: ENDOTHELIAL DYSFUNCTION
       ============================================================ */
    subgraph cluster_endothelial {
        label="6. Endothelial Dysfunction / Vascular"
        style=filled; fillcolor="#F3E5F5"; color="#4A148C"; penwidth=2

        VE_cadh [label="VE-Cadherin\n(Disrupted)", fillcolor="#E1BEE7"]
        TJ_prot [label="Tight Junctions\n(ZO-1, Occludin ↓)", fillcolor="#E1BEE7"]
        Glycocalyx [label="Glycocalyx\nShedding", fillcolor="#CE93D8"]
        ICAM1 [label="ICAM-1\n(Leukocyte adhesion)", fillcolor="#BA68C8"]
        VCAM1 [label="VCAM-1\n(Leukocyte rolling)", fillcolor="#BA68C8"]
        Eselectin [label="E-selectin\n(Early adhesion)", fillcolor="#AB47BC", fontcolor="white"]
        Pselectin [label="P-selectin\n(Platelet-endothelium)", fillcolor="#9C27B0", fontcolor="white"]
        Leuko_TEM [label="Leukocyte\nTransendothelial Migr.", fillcolor="#7B1FA2", fontcolor="white"]
        VascPerm [label="Vascular\nPermeability ↑", fillcolor="#6A1B9A", fontcolor="white"]
        Edema [label="Capillary Leak\n/ Edema", fillcolor="#E91E63", fontcolor="white"]
        iNOS [label="iNOS\n(NO synthesis)", fillcolor="#CE93D8"]
        NO [label="NO\n(Vasodilation)", fillcolor="#9575CD", fontcolor="white"]
        ET1 [label="Endothelin-1\n(Vasoconstriction)", fillcolor="#7E57C2", fontcolor="white"]
        PGI2 [label="Prostacyclin (PGI2)\n(Vasodilator/antiplat.)", fillcolor="#7986CB"]
        TXA2 [label="Thromboxane A2\n(Vasoconstriction)", fillcolor="#EF9A9A"]
        MAP_vasc [label="MAP Reduction\n(Vasodilatory shock)", fillcolor="#B71C1C", fontcolor="white", shape=diamond]
    }

    /* ============================================================
       CLUSTER 7: ORGAN FAILURE
       ============================================================ */
    subgraph cluster_organs {
        label="7. Multi-Organ Dysfunction Syndrome (MODS)"
        style=filled; fillcolor="#EFEBE9"; color="#3E2723"; penwidth=2

        /* Lung */
        Alveolar_damage [label="Alveolar\nEpithelial Damage", fillcolor="#BCAAA4"]
        Surfactant_loss [label="Surfactant\nDepletion", fillcolor="#BCAAA4"]
        Neutrophil_lung [label="Pulmonary Neutrophil\nSequestration", fillcolor="#A1887F"]
        ARDS [label="ARDS\n(Acute Resp. Distress Syn.)", fillcolor="#795548", fontcolor="white", shape=diamond]
        PF_ratio [label="PaO2/FiO2\nRatio ↓", fillcolor="#6D4C41", fontcolor="white"]
        SOFA_lung [label="SOFA Lung\n(0–4)", fillcolor="#5D4037", fontcolor="white"]

        /* Kidney */
        Tubular_injury [label="Renal Tubular\nInjury", fillcolor="#BCAAA4"]
        Creatinine [label="Serum Creatinine ↑\n(AKI marker)", fillcolor="#A1887F"]
        Oliguria [label="Oliguria\n(<0.5 mL/kg/hr)", fillcolor="#A1887F"]
        SOFA_renal [label="SOFA Renal\n(0–4)", fillcolor="#5D4037", fontcolor="white"]

        /* Liver */
        Hepatic_injury [label="Hepatic\nIschemia/Injury", fillcolor="#BCAAA4"]
        Bilirubin [label="Bilirubin ↑\n(Liver marker)", fillcolor="#A1887F"]
        SOFA_liver [label="SOFA Liver\n(0–4)", fillcolor="#5D4037", fontcolor="white"]

        /* CNS */
        BBB_break [label="Blood-Brain Barrier\nDisruption", fillcolor="#BCAAA4"]
        SAE [label="Sepsis-Associated\nEncephalopathy (SAE)", fillcolor="#8D6E63", fontcolor="white"]
        GCS_drop [label="GCS Drop\n(Consciousness ↓)", fillcolor="#6D4C41", fontcolor="white"]
        SOFA_CNS [label="SOFA CNS\n(0–4)", fillcolor="#5D4037", fontcolor="white"]

        /* Cardiovascular */
        Myocard_depress [label="Myocardial\nDepression", fillcolor="#BCAAA4"]
        Lactate_organ [label="Lactate ↑\n(Tissue hypoperfusion)", fillcolor="#FF7043", fontcolor="white"]
        SOFA_cardio [label="SOFA Cardiovascular\n(0–4)", fillcolor="#5D4037", fontcolor="white"]

        /* Platelets */
        Plt_count_drop [label="Platelet Count ↓\n(Thrombocytopenia)", fillcolor="#EF9A9A"]
        SOFA_coag [label="SOFA Coagulation\n(0–4)", fillcolor="#5D4037", fontcolor="white"]

        /* SOFA Total */
        SOFA_total [label="SOFA Total Score\n(0–24)", fillcolor="#212121", fontcolor="white", shape=diamond, width=1.5]
        Mortality_risk [label="28-Day Mortality\nRisk", fillcolor="#B71C1C", fontcolor="white", shape=pentagon]
    }

    /* ============================================================
       CLUSTER 8: DRUG PK/PD
       ============================================================ */
    subgraph cluster_drugs {
        label="8. Drug PK/PD — Antibiotics · Vasopressors · Steroids · Biologics"
        style=filled; fillcolor="#E8EAF6"; color="#1A237E"; penwidth=2

        /* Antibiotics */
        Abx_dose [label="Antibiotic\nDose/Infusion", fillcolor="#C5CAE9", shape=parallelogram]
        Abx_C [label="Abx Central\n(Plasma, mg/L)", fillcolor="#9FA8DA"]
        Abx_P [label="Abx Peripheral\n(Tissue)", fillcolor="#9FA8DA"]
        Abx_effect [label="Abx Effect\n(f·T>MIC)", fillcolor="#7986CB", fontcolor="white"]
        Bact_kill [label="Bacterial Kill\nRate (Emax model)", fillcolor="#5C6BC0", fontcolor="white"]

        /* Vasopressors */
        NE_dose [label="Norepinephrine\nInfusion Rate", fillcolor="#EF9A9A", shape=parallelogram]
        NE_plasma [label="NE Plasma\nConcentration", fillcolor="#EF9A9A"]
        Alpha1R [label="α1-Adrenoceptor\nStimulation", fillcolor="#E57373"]
        MAP_restore [label="MAP\nRestoration", fillcolor="#EF5350", fontcolor="white"]
        Beta1R [label="β1-Adrenoceptor\n(Cardiac output)", fillcolor="#E57373"]

        /* Corticosteroids */
        HC_dose [label="Hydrocortisone\n200 mg/day IV", fillcolor="#A5D6A7", shape=parallelogram]
        HC_plasma [label="HC Plasma\n(Free)", fillcolor="#81C784"]
        GR_occ [label="GR Occupancy\n(Cytokine supp.)", fillcolor="#4CAF50", fontcolor="white"]
        Cyto_supp [label="Cytokine\nSuppression (%)", fillcolor="#388E3C", fontcolor="white"]

        /* IL-6R Inhibitor */
        Toci_dose [label="Tocilizumab\n8 mg/kg IV", fillcolor="#FFCC80", shape=parallelogram]
        Toci_C [label="Tocilizumab\nPlasma (μg/mL)", fillcolor="#FFB74D"]
        IL6R_sat [label="IL-6R\nSaturation (%)", fillcolor="#FF8F00", fontcolor="white"]
        IL6_block [label="IL-6 Signaling\nBlockade", fillcolor="#E65100", fontcolor="white"]

        /* Fluid Resuscitation */
        Fluid_input [label="IV Fluid\nResuscitation", fillcolor="#B2EBF2", shape=parallelogram]
        Preload [label="Preload\nRestoration", fillcolor="#80DEEA"]
    }

    /* ============================================================
       CLUSTER 9: CLINICAL BIOMARKERS & ENDPOINTS
       ============================================================ */
    subgraph cluster_biomarkers {
        label="9. Clinical Biomarkers & Endpoints"
        style=filled; fillcolor="#F1F8E9"; color="#33691E"; penwidth=2

        Temp_endo [label="Temperature\n(Fever/Hypothermia)", fillcolor="#DCEDC8"]
        HR_endo [label="Heart Rate\n(Tachycardia)", fillcolor="#DCEDC8"]
        MAP_endo [label="MAP\n(<65 mmHg = shock)", fillcolor="#AED581"]
        Lactate_endo [label="Lactate\n(>2 mmol/L)", fillcolor="#8BC34A"]
        WBC_endo [label="WBC\n(>12 or <4 ×10⁹/L)", fillcolor="#DCEDC8"]
        PCT_endo [label="PCT\n(>0.5 ng/mL)", fillcolor="#C5E1A5"]
        CRP_endo [label="CRP\n(>100 mg/L)", fillcolor="#C5E1A5"]
        qSOFA [label="qSOFA Score\n(0–3)", fillcolor="#7CB342", fontcolor="white"]
        Sepsis_def [label="Sepsis Definition\n(Sepsis-3 2016)", fillcolor="#558B2F", fontcolor="white", shape=diamond]
        SepticShock_def [label="Septic Shock\n(MAP<65 + Lactate>2)", fillcolor="#33691E", fontcolor="white", shape=diamond]
        SIRS_score [label="SIRS Criteria\n(Old definition)", fillcolor="#F0F4C3"]
        Bacteria_load [label="Bacteremia\n(CFU/mL proxy)", fillcolor="#DCE775"]
        Cultures_pos [label="Blood Cultures\nPositivity", fillcolor="#DCEDC8"]
    }

    /* ============================================================
       CLUSTER 10: METABOLIC / MITOCHONDRIAL
       ============================================================ */
    subgraph cluster_metabolic {
        label="10. Metabolic & Mitochondrial Dysfunction"
        style=filled; fillcolor="#FFF9C4"; color="#F57F17"; penwidth=2

        Glycolysis [label="Aerobic Glycolysis\n(Warburg shift)", fillcolor="#FFF176"]
        Mito_dysfn [label="Mitochondrial\nDysfunction", fillcolor="#FFEE58"]
        ROS_mito [label="Mitochondrial\nROS / Oxidative Stress", fillcolor="#FDD835"]
        Lactate_meta [label="Lactate\nAccumulation", fillcolor="#FBC02D"]
        Pyruvate_DH [label="Pyruvate Dehydrogenase\n(Inhibited)", fillcolor="#F9A825"]
        Mito_membrane [label="Mitochondrial Membrane\nPotential ↓", fillcolor="#F57F17", fontcolor="white"]
        Adenosine [label="Adenosine\n(from ATP)", fillcolor="#FFB300"]
        O2_util [label="Oxygen Utilization\nDefect (Cytopathic hypoxia)", fillcolor="#FF6F00", fontcolor="white"]
    }

    /* ============================================================
       CLUSTER 11: ADAPTIVE IMMUNITY (Immunosuppression)
       ============================================================ */
    subgraph cluster_adaptive {
        label="11. Adaptive Immunity / Immunosuppression"
        style=filled; fillcolor="#E0F7FA"; color="#006064"; penwidth=2

        Tcell_act [label="T Cell\nActivation", fillcolor="#B2EBF2"]
        Th1 [label="Th1\n(IFNγ, IL-2)", fillcolor="#80DEEA"]
        Th2 [label="Th2\n(IL-4, IL-10)", fillcolor="#80DEEA"]
        Th17 [label="Th17\n(IL-17, IL-22)", fillcolor="#80DEEA"]
        Tcell_apo [label="T Cell\nApoptosis (↑ in ICU)", fillcolor="#26C6DA", fontcolor="white"]
        Treg [label="Regulatory T cells\n(Treg ↑)", fillcolor="#00BCD4", fontcolor="white"]
        MDSC [label="MDSCs\n(Myeloid-derived sup.)", fillcolor="#0097A7", fontcolor="white"]
        Bcell [label="B Cells\n(Antibody production)", fillcolor="#B2EBF2"]
        PD1 [label="PD-1/PD-L1\n(Immune exhaustion)", fillcolor="#006064", fontcolor="white"]
        CARS [label="CARS\n(Anti-inflam. response)", fillcolor="#00838F", fontcolor="white"]
        Immunosuppression [label="Late\nImmunosuppression", fillcolor="#004D40", fontcolor="white", shape=diamond]
    }

    /* ============================================================
       EDGES: CLUSTER 1 INTERNAL
       ============================================================ */
    LPS -> TLR4 [label="binds"]
    PGN -> TLR2 [label="binds"]
    BetaGlucan -> TLR2 [label="binds"]
    Flagellin -> TLR5 [label="binds"]
    ViralRNA -> TLR3 [label="binds"]
    HMGB1_source -> TLR4 [label="activates", style=dashed]
    S100 -> TLR4 [label="activates", style=dashed]
    mtDNA -> cGAS_STING [label="activates"]
    ATP_DAMP -> NLRP3 [label="P2X7 → activates"]
    HSP -> TLR4 [label="activates", style=dashed]
    TLR4 -> MyD88 [label="recruits"]
    TLR2 -> MyD88 [label="recruits"]
    TLR5 -> MyD88 [label="recruits"]
    TLR9 -> MyD88 [label="recruits"]
    TLR3 -> TRIF [label="recruits"]
    MyD88 -> NFkB_act [label="activates", color="#E65100", penwidth=2]
    TRIF -> NFkB_act [label="activates", style=dashed]
    TRIF -> IRF37 [label="activates"]
    cGAS_STING -> IRF37 [label="activates"]
    NLRP3 -> IL1b [label="cleaves\nPro-IL1β", color="#880E4F", penwidth=2]
    NOD12 -> NFkB_act [label="activates"]

    /* ============================================================
       EDGES: CLUSTER 1 → 2 (Activation of immune cells)
       ============================================================ */
    NFkB_act -> Mac_M1 [label="activates", lhead=cluster_innate, color="#E65100"]
    NFkB_act -> Neut_blood [label="primes"]
    NFkB_act -> DC_cell [label="matures"]

    /* ============================================================
       EDGES: CLUSTER 2 INTERNAL
       ============================================================ */
    Neut_blood -> Neut_tissue [label="recruitment\n(IL-8 gradient)"]
    Neut_tissue -> NET_form [label="forms"]
    Neut_tissue -> ROS_burst [label="generates"]
    Neut_tissue -> MPO [label="releases"]
    Neut_tissue -> Elastase [label="releases"]
    Neut_tissue -> MMP9 [label="releases"]
    Mac_M1 -> TNFa [label="secretes", color="#880E4F", penwidth=2]
    Mac_M1 -> IL6 [label="secretes", color="#880E4F"]
    Mac_M1 -> IL12 [label="secretes"]
    Mac_M1 -> ROS_burst [label="generates"]
    Mac_M2 -> IL10 [label="secretes", color="#0D47A1"]
    Mono_blood -> Mac_M1 [label="differentiates"]
    Phagocytosis -> Apoptosis_imm [label="leads to"]
    C3b -> Phagocytosis [label="opsonizes", lhead=cluster_innate]
    NK_cell -> IFNg [label="secretes", lhead=cluster_cytokines]
    NET_form -> Thrombin [label="activates coag.", lhead=cluster_coagulation, style=dashed]

    /* ============================================================
       EDGES: CLUSTER 2 → 3 (Cytokine production)
       ============================================================ */
    Mac_M1 -> HMGB1_cyto [label="late secretion\n(>8h)", style=dashed]
    Mac_M1 -> MCP1 [label="secretes"]
    Neut_tissue -> IL8 [label="secretes"]
    DC_cell -> IL12 [label="secretes"]

    /* ============================================================
       EDGES: CLUSTER 3 INTERNAL (Cytokine signaling loops)
       ============================================================ */
    NFkB_act -> TNFa [label="transcribes", color="#E65100", penwidth=2]
    NFkB_act -> IL6 [label="transcribes", color="#E65100"]
    NFkB_act -> IL8 [label="transcribes", color="#E65100"]
    NFkB_act -> MCP1 [label="transcribes"]
    TNFa -> NFkB_act [label="amplifies\n(feedback)", style=dashed, color="#880E4F"]
    TNFa -> IL6 [label="induces"]
    TNFa -> IL8 [label="induces"]
    TNFa -> ANG2 [label="induces"]
    TNFa -> Apoptosis_imm [label="induces"]
    IL6 -> CRP_prod [label="induces hepatic"]
    IL6 -> PCT_prod [label="induces"]
    IL6 -> Tcell_act [label="activates", lhead=cluster_adaptive, style=dashed]
    IL1b -> IL6 [label="induces"]
    IL1b -> NFkB_act [label="feeds back"]
    IL12 -> IFNg [label="induces\n(NK/Th1)"]
    IFNg -> Mac_M1 [label="activates", style=dashed]
    IFNg -> Th1 [label="promotes", lhead=cluster_adaptive]
    IL10 -> TNFa [label="inhibits", color="#0D47A1", style=dashed, arrowhead=tee]
    IL10 -> IL6 [label="inhibits", color="#0D47A1", style=dashed, arrowhead=tee]
    IL10 -> Mac_M1 [label="inhibits", style=dashed, arrowhead=tee]
    TGFb -> IL10 [label="induces"]
    VEGF -> VascPerm [label="increases", lhead=cluster_endothelial]
    ANG2 -> VascPerm [label="increases", lhead=cluster_endothelial]
    IL17 -> Neut_blood [label="recruits", style=dashed]
    IL8 -> Neut_blood [label="chemotaxis\n(CXCL8)"]
    MCP1 -> Mono_blood [label="recruits"]

    /* ============================================================
       EDGES: CLUSTER 4 (Complement)
       ============================================================ */
    LPS -> C1q [label="activates", lhead=cluster_complement]
    LPS -> AltPath [label="activates"]
    MBL -> C3_conv [label="activates"]
    AltPath -> C3_conv [label="activates"]
    C1q -> C3_conv [label="leads to"]
    C3_conv -> C3_cleavage [label="cleaves"]
    C3_cleavage -> C3a
    C3_cleavage -> C3b
    C3b -> C5_conv [label="forms"]
    C3a -> C3aR [label="binds"]
    C3aR -> Mast_cell [label="activates (degrn.)", lhead=cluster_innate]
    C5_conv -> C5a [label="generates"]
    C5_conv -> C5b9_MAC [label="generates"]
    C5a -> C5aR [label="binds"]
    C5aR -> Neut_blood [label="activates"]
    C5aR -> Mac_M1 [label="activates"]
    C5a -> TNFa [label="induces", style=dashed, lhead=cluster_cytokines]
    C5b9_MAC -> Bacteria_load [label="lyses", lhead=cluster_biomarkers, style=dashed, arrowhead=tee]

    /* ============================================================
       EDGES: CLUSTER 5 (Coagulation)
       ============================================================ */
    TNFa -> TF_expr [label="induces endothelial TF", lhead=cluster_coagulation]
    IL6 -> TF_expr [label="induces", style=dashed]
    Neut_tissue -> TF_expr [label="NET-induced"]
    TF_expr -> TF_VIIa [label="complex forms"]
    TF_VIIa -> FXa [label="activates"]
    FXa -> Thrombin [label="generates"]
    Thrombin -> Fibrinogen [label="cleaves"]
    Fibrinogen -> Fibrin [label="polymerizes"]
    Fibrin -> FXIIIa [label="cross-linked by"]
    Thrombin -> Plt_act [label="activates"]
    PAI1 -> tPA [label="inhibits", arrowhead=tee]
    tPA -> Fibrin [label="degrades → D-dimer", style=dashed, arrowhead=tee]
    Thrombin -> ProtC_act [label="activates (on endot.)"]
    ProtC_act -> APC [label="generates"]
    APC -> FXa [label="inhibits", arrowhead=tee, color="#27AE60"]
    APC -> PAI1 [label="inhibits", arrowhead=tee, color="#27AE60"]
    ATIII -> Thrombin [label="inhibits", arrowhead=tee, color="#27AE60"]
    Fibrin -> DDimer [label="degrades to"]
    Plt_act -> DIC_state [label="contributes"]
    Fibrin -> DIC_state [label="consumptive"]
    TNFa -> PAI1 [label="induces", style=dashed]

    /* ============================================================
       EDGES: CLUSTER 6 (Endothelial)
       ============================================================ */
    TNFa -> ICAM1 [label="upregulates", lhead=cluster_endothelial]
    TNFa -> VCAM1 [label="upregulates"]
    TNFa -> Eselectin [label="upregulates"]
    TNFa -> iNOS [label="induces"]
    IL1b -> ICAM1 [label="upregulates", style=dashed]
    LPS -> iNOS [label="induces", style=dashed]
    TNFa -> VE_cadh [label="disrupts", arrowhead=tee]
    ANG2 -> TJ_prot [label="disrupts", arrowhead=tee]
    ANG2 -> Glycocalyx [label="sheds"]
    VEGF -> VascPerm [label="increases", color="#E65100"]
    iNOS -> NO [label="generates"]
    NO -> MAP_vasc [label="causes\nvasodilation"]
    ET1 -> MAP_vasc [label="opposes", arrowhead=tee, color="#27AE60"]
    ICAM1 -> Leuko_TEM [label="mediates"]
    VCAM1 -> Leuko_TEM [label="mediates"]
    Eselectin -> Leuko_TEM [label="initiates"]
    VE_cadh -> VascPerm [label="→ permeability"]
    TJ_prot -> VascPerm [label="→ permeability"]
    VascPerm -> Edema [label="causes"]
    Glycocalyx -> VascPerm [label="shedding →"]
    MAP_vasc -> SOFA_cardio [label="scores", lhead=cluster_organs]
    TNFa -> TXA2 [label="promotes"]
    Plt_act -> TXA2 [label="releases"]
    Mast_cell -> PGI2 [label="releases"]

    /* ============================================================
       EDGES: CLUSTER 6 → 7 (Organ damage)
       ============================================================ */
    Edema -> Alveolar_damage [label="pulmonary\nedema", lhead=cluster_organs]
    Neut_tissue -> Neutrophil_lung [label="sequesters"]
    Neutrophil_lung -> ARDS [label="drives"]
    Alveolar_damage -> ARDS [label="leads to"]
    Surfactant_loss -> ARDS [label="worsens"]
    ARDS -> PF_ratio [label="↓ ratio"]
    PF_ratio -> SOFA_lung [label="determines score"]

    Edema -> Tubular_injury [label="renal\nischemia"]
    Thrombin -> Tubular_injury [label="microthrombosis", style=dashed]
    Tubular_injury -> Creatinine [label="↑ creatinine"]
    Tubular_injury -> Oliguria [label="causes"]
    Creatinine -> SOFA_renal [label="determines score"]

    TNFa -> Hepatic_injury [label="hepatocyte apoptosis"]
    Thrombin -> Hepatic_injury [label="sinusoidal\nmicrothrombosis", style=dashed]
    Hepatic_injury -> Bilirubin [label="↑ bilirubin"]
    Bilirubin -> SOFA_liver [label="determines score"]

    Edema -> BBB_break [label="cerebral\nedema"]
    TNFa -> BBB_break [label="disrupts", style=dashed]
    BBB_break -> SAE [label="causes"]
    SAE -> GCS_drop [label="lowers GCS"]
    GCS_drop -> SOFA_CNS [label="determines score"]

    Myocard_depress -> Lactate_organ [label="↓ CO → hypoperfusion"]
    TNFa -> Myocard_depress [label="depresses", style=dashed]
    MAP_vasc -> Lactate_organ [label="↓ MAP → hypoperfusion"]
    Lactate_organ -> SOFA_cardio [label="determines"]

    DIC_state -> Plt_count_drop [label="consumes platelets"]
    Plt_count_drop -> SOFA_coag [label="determines score"]

    SOFA_lung -> SOFA_total [label="sums"]
    SOFA_renal -> SOFA_total [label="sums"]
    SOFA_liver -> SOFA_total [label="sums"]
    SOFA_CNS -> SOFA_total [label="sums"]
    SOFA_cardio -> SOFA_total [label="sums"]
    SOFA_coag -> SOFA_total [label="sums"]
    SOFA_total -> Mortality_risk [label="predicts", color="#B71C1C", penwidth=2]

    /* ============================================================
       EDGES: CLUSTER 8 (Drug PK/PD)
       ============================================================ */
    Abx_dose -> Abx_C [label="IV infusion"]
    Abx_C -> Abx_P [label="distribution"]
    Abx_P -> Abx_C [label="redistribution", style=dashed]
    Abx_C -> Abx_effect [label="→ fT>MIC"]
    Abx_effect -> Bact_kill [label="→ bacterial kill"]
    Bact_kill -> Bacteria_load [label="reduces", arrowhead=tee, color="#27AE60", penwidth=2, lhead=cluster_biomarkers]
    Bacteria_load -> NFkB_act [label="drives", color="#E65100", penwidth=2]

    NE_dose -> NE_plasma [label="IV infusion"]
    NE_plasma -> Alpha1R [label="binds"]
    NE_plasma -> Beta1R [label="binds"]
    Alpha1R -> MAP_restore [label="vasoconstricts"]
    Beta1R -> MAP_restore [label="↑ CO"]
    MAP_restore -> MAP_endo [label="restores", color="#27AE60", arrowhead=tee, lhead=cluster_biomarkers]
    MAP_restore -> SOFA_cardio [label="improves", arrowhead=tee, style=dashed]

    HC_dose -> HC_plasma [label="IV bolus/infusion"]
    HC_plasma -> GR_occ [label="GR binding (Kd)"]
    GR_occ -> Cyto_supp [label="→ GR-mediated\ntransrepression"]
    Cyto_supp -> TNFa [label="suppresses", arrowhead=tee, color="#27AE60"]
    Cyto_supp -> IL6 [label="suppresses", arrowhead=tee, color="#27AE60"]
    Cyto_supp -> IL1b [label="suppresses", arrowhead=tee, color="#27AE60"]
    Cyto_supp -> MAP_restore [label="↑ vasopressor\nsensitivity"]

    Toci_dose -> Toci_C [label="IV infusion"]
    Toci_C -> IL6R_sat [label="IL-6R binding\n(Emax model)"]
    IL6R_sat -> IL6_block [label="→ STAT3 inhibition"]
    IL6_block -> CRP_prod [label="suppresses", arrowhead=tee, color="#27AE60"]
    IL6_block -> PCT_prod [label="suppresses", arrowhead=tee]
    IL6_block -> Tcell_act [label="modulates", style=dashed]

    Fluid_input -> Preload [label="IV crystalloid"]
    Preload -> MAP_restore [label="↑ preload → CO"]

    /* ============================================================
       EDGES: CLUSTER 9 (Biomarkers)
       ============================================================ */
    TNFa -> Temp_endo [label="fever via\nPGE2", lhead=cluster_biomarkers]
    IL6 -> Temp_endo [label="fever", style=dashed]
    IL6 -> CRP_prod [label="liver synthesis"]
    IL6 -> PCT_prod [label="systemic"]
    CRP_prod -> CRP_endo [label="→ measured"]
    PCT_prod -> PCT_endo [label="→ measured"]
    Neut_blood -> WBC_endo [label="→ WBC count"]
    Lactate_meta -> Lactate_endo [label="→ measured"]
    Lactate_organ -> Lactate_endo [label="contributes"]
    MAP_vasc -> MAP_endo [label="determines"]
    MAP_endo -> qSOFA [label="if <65"]
    GCS_drop -> qSOFA [label="if altered"]
    HR_endo -> SIRS_score [label="if >90"]
    Temp_endo -> SIRS_score [label="if >38°C/<36°C"]
    WBC_endo -> SIRS_score [label="if >12 or <4"]
    SIRS_score -> Sepsis_def [label="old def."]
    SOFA_total -> Sepsis_def [label="SOFA ≥2 (Sepsis-3)"]
    MAP_endo -> SepticShock_def [label="<65 mmHg"]
    Lactate_endo -> SepticShock_def [label=">2 mmol/L"]
    Bacteria_load -> Cultures_pos [label="→ bacteremia"]

    /* ============================================================
       EDGES: CLUSTER 10 (Metabolic)
       ============================================================ */
    ROS_burst -> ROS_mito [label="systemic ROS", lhead=cluster_metabolic]
    TNFa -> Mito_dysfn [label="disrupts complex I", style=dashed, lhead=cluster_metabolic]
    Mito_dysfn -> Mito_membrane [label="↓ potential"]
    Mito_dysfn -> ROS_mito [label="generates"]
    Mito_membrane -> O2_util [label="↓ ATP synthesis\n→ cytopathic hypoxia"]
    O2_util -> Lactate_meta [label="anaerobic glycolysis"]
    Pyruvate_DH -> Glycolysis [label="PDH inhibited →\nWarburg shift"]
    TNFa -> Glycolysis [label="drives shift", style=dashed]
    Glycolysis -> Lactate_meta [label="produces lactate"]
    ATP_DAMP -> Adenosine [label="degrades\n(CD39/CD73)"]
    Adenosine -> Tcell_act [label="suppresses", arrowhead=tee, style=dashed, lhead=cluster_adaptive]

    /* ============================================================
       EDGES: CLUSTER 11 (Adaptive Immunity)
       ============================================================ */
    IL12 -> Th1 [label="differentiates", lhead=cluster_adaptive]
    IL4 -> Th2 [label="differentiates"]
    IL6 -> Th17 [label="differentiates\n(+ TGFβ)"]
    TGFb -> Treg [label="induces"]
    IL10 -> Treg [label="from Treg"]
    Treg -> Tcell_apo [label="promotes\n(apoptosis signal)"]
    MDSC -> Tcell_act [label="suppresses", arrowhead=tee]
    PD1 -> Tcell_act [label="exhaustion", arrowhead=tee]
    TNFa -> Tcell_apo [label="induces", style=dashed]
    Tcell_apo -> Immunosuppression [label="→ lymphopenia"]
    MDSC -> Immunosuppression [label="contributes"]
    Treg -> CARS [label="drives"]
    IL10 -> CARS [label="drives"]
    TGFb -> CARS [label="drives"]
    CARS -> Immunosuppression [label="leads to"]
    Immunosuppression -> Bacteria_load [label="↑ re-infection risk", arrowhead=normal, style=dashed, lhead=cluster_biomarkers]

    /* ============================================================
       LEGEND
       ============================================================ */
    subgraph cluster_legend {
        label="Legend"
        style=filled; fillcolor="#F5F5F5"; color="#616161"; penwidth=1

        L1 [label="→ Activation/Production", fillcolor="#A5D6A7", shape=box]
        L2 [label="⊣ Inhibition", fillcolor="#EF9A9A", shape=box]
        L3 [label="Drug Input", fillcolor="#CE93D8", shape=parallelogram]
        L4 [label="Clinical Endpoint", fillcolor="#FFD54F", shape=diamond]
    }
}
