digraph SepsisQSP {

    // ─────────────────────────────────────────────
    // Graph-level attributes
    // ─────────────────────────────────────────────
    graph [
        label       = "Sepsis / Systemic Inflammatory Response Syndrome\nQuantitative Systems Pharmacology (QSP) Mechanistic Map"
        labelloc    = "t"
        fontname    = "Helvetica-Bold"
        fontsize    = 22
        fontcolor   = "#e0e0e0"
        bgcolor     = "#1a1a2e"
        rankdir     = TB
        splines     = ortho
        nodesep     = 0.55
        ranksep     = 0.9
        pad         = 0.6
        compound    = true
    ]

    node [
        fontname  = "Helvetica"
        fontsize  = 10
        style     = "filled,rounded"
        shape     = box
        margin    = "0.15,0.08"
        penwidth  = 1.4
    ]

    edge [
        fontname  = "Helvetica"
        fontsize  = 9
        penwidth  = 1.4
    ]

    // =========================================================
    // CLUSTER 1 — INFECTION / PATHOGENS
    // =========================================================
    subgraph cluster_infection {
        label     = "Infection / Pathogens"
        style     = "filled,rounded"
        fillcolor = "#3d0000"
        color     = "#ff6666"
        fontcolor = "#ffcccc"
        fontsize  = 13
        fontname  = "Helvetica-Bold"
        penwidth  = 2.0

        node [fillcolor="#8b0000" fontcolor=white color="#ff6666"]

        Bacteria          [label="Bacteria\n(Gram-/+)"]
        LPS               [label="LPS\n(Lipopolysaccharide)"]
        LTA               [label="LTA\n(Lipoteichoic Acid)"]
        Peptidoglycan     [label="Peptidoglycan"]
        PAMP              [label="PAMP\n(Pathogen-Associated\nMolecular Patterns)"]
        DAMP              [label="DAMP\n(Damage-Associated\nMolecular Patterns)"]
        HMGB1_release     [label="HMGB1\n(Early Release)"]
        Bacteremia        [label="Bacteremia /\nFungemia"]
        Fungemia          [label="Fungal PAMPs\n(β-glucan, Mannan)"]
        Viral_RNA         [label="Viral RNA /\nCpG DNA"]
    }

    // =========================================================
    // CLUSTER 2 — INNATE IMMUNE SIGNALING
    // =========================================================
    subgraph cluster_innate {
        label     = "Innate Immune Signaling (TLR / NF-κB Pathway)"
        style     = "filled,rounded"
        fillcolor = "#1a1a00"
        color     = "#aaaa00"
        fontcolor = "#ffffcc"
        fontsize  = 13
        fontname  = "Helvetica-Bold"
        penwidth  = 2.0

        node [fillcolor="#556b2f" fontcolor=white color="#aaaa44"]

        TLR4              [label="TLR4\n(LPS Receptor)"]
        TLR2              [label="TLR2\n(LTA/PGN Receptor)"]
        TLR9              [label="TLR9\n(CpG DNA Receptor)"]
        MD2_complex       [label="MD-2 / CD14\nCo-receptor Complex"]
        MyD88             [label="MyD88\n(Adaptor Protein)"]
        IRAK1             [label="IRAK1\n(Kinase)"]
        IRAK4             [label="IRAK4\n(Kinase)"]
        TRAF6             [label="TRAF6\n(E3 Ubiquitin Ligase)"]
        IKK_complex       [label="IKK Complex\n(IKKα/β/γ)"]
        IkB               [label="IκB\n(Phosphorylated)"]
        NF_kB_inactive    [label="NF-κB\n(Inactive / Cytoplasm)"]
        NF_kB_active      [label="NF-κB\n(Active)"]
        NF_kB_nucleus     [label="NF-κB\n(Nucleus — Transcription)"]
        Neutrophil_recruit [label="Neutrophil\nRecruitment & Activation"]
        Macrophage_activation [label="Macrophage /\nMonocyte Activation"]
    }

    // =========================================================
    // CLUSTER 3 — CYTOKINES & CHEMOKINES
    // =========================================================
    subgraph cluster_cytokines {
        label     = "Cytokines & Chemokines"
        style     = "filled,rounded"
        fillcolor = "#000033"
        color     = "#6666ff"
        fontcolor = "#ccccff"
        fontsize  = 13
        fontname  = "Helvetica-Bold"
        penwidth  = 2.0

        node [fillcolor="#00008b" fontcolor=white color="#6666ff"]

        TNF_alpha   [label="TNF-α"]
        IL1_beta    [label="IL-1β"]
        IL6         [label="IL-6"]
        IL8_CXCL8   [label="IL-8 / CXCL8"]
        IL12        [label="IL-12\n(Th1 Polarisation)"]
        IL18        [label="IL-18\n(IFN-γ inducer)"]
        IL10        [label="IL-10\n(Anti-inflammatory)"]
        IL4         [label="IL-4\n(Anti-inflammatory)"]
        TGF_beta1   [label="TGF-β1\n(Immunosuppression)"]
        IFN_gamma   [label="IFN-γ\n(Macrophage priming)"]
        MIP1a       [label="MIP-1α / CCL3\n(Chemokine)"]
        MCP1        [label="MCP-1 / CCL2\n(Monocyte chemoattractant)"]
        HMGB1_late  [label="HMGB1\n(Late Mediator)"]
        IL17        [label="IL-17\n(Neutrophil mobiliser)"]
        G_CSF       [label="G-CSF\n(Neutrophil growth factor)"]
    }

    // =========================================================
    // CLUSTER 4 — COAGULATION CASCADE
    // =========================================================
    subgraph cluster_coag {
        label     = "Coagulation Cascade & DIC"
        style     = "filled,rounded"
        fillcolor = "#2d1b00"
        color     = "#cc8833"
        fontcolor = "#ffd59a"
        fontsize  = 13
        fontname  = "Helvetica-Bold"
        penwidth  = 2.0

        node [fillcolor="#8b4513" fontcolor=white color="#cc8833"]

        TF_expression   [label="Tissue Factor\n(TF) Expression"]
        FVIIa           [label="FVIIa\n(Extrinsic Pathway)"]
        FXa_complex     [label="FXa / Prothrombinase\nComplex"]
        FVa             [label="FVa\n(Cofactor)"]
        Prothrombin     [label="Prothrombin\n(Factor II)"]
        Thrombin        [label="Thrombin\n(Factor IIa)"]
        Fibrinogen      [label="Fibrinogen\n(Factor I)"]
        Fibrin          [label="Fibrin\n(Cross-linked)"]
        PAI1            [label="PAI-1\n(Plasminogen Activator\nInhibitor-1)"]
        tPA             [label="tPA\n(Tissue Plasminogen\nActivator)"]
        Plasmin         [label="Plasmin\n(Fibrinolysis)"]
        D_dimer         [label="D-Dimer\n(Fibrin degradation\nproduct)"]
        Antithrombin    [label="Antithrombin III\n(AT-III)"]
        Protein_C       [label="Protein C\n(Anticoagulant)"]
        TFPI            [label="TFPI\n(Tissue Factor Pathway\nInhibitor)"]
    }

    // =========================================================
    // CLUSTER 5 — COMPLEMENT SYSTEM
    // =========================================================
    subgraph cluster_complement {
        label     = "Complement System"
        style     = "filled,rounded"
        fillcolor = "#001a00"
        color     = "#44cc44"
        fontcolor = "#ccffcc"
        fontsize  = 13
        fontname  = "Helvetica-Bold"
        penwidth  = 2.0

        node [fillcolor="#006400" fontcolor=white color="#44cc44"]

        C1q_C1r_C1s  [label="C1q-C1r-C1s\n(Classical Pathway)"]
        C3_activation [label="C3 Activation\n(C3 Convertase)"]
        C3a           [label="C3a\n(Anaphylatoxin)"]
        C3b           [label="C3b\n(Opsonin)"]
        C5_activation [label="C5 Activation\n(C5 Convertase)"]
        C5a           [label="C5a\n(Potent Anaphylatoxin)"]
        C5b_MAC       [label="C5b-9\n(Membrane Attack Complex)"]
        Factor_B      [label="Factor B\n(Alternative Pathway)"]
        Properdin     [label="Properdin\n(Stabiliser)"]
        MBL_MASP      [label="MBL-MASP\n(Lectin Pathway)"]
    }

    // =========================================================
    // CLUSTER 6 — VASCULAR / ENDOTHELIAL DYSFUNCTION
    // =========================================================
    subgraph cluster_vascular {
        label     = "Vascular & Endothelial Dysfunction"
        style     = "filled,rounded"
        fillcolor = "#00001a"
        color     = "#4444cc"
        fontcolor = "#ccccff"
        fontsize  = 13
        fontname  = "Helvetica-Bold"
        penwidth  = 2.0

        node [fillcolor="#191970" fontcolor=white color="#4444cc"]

        iNOS_upregulation   [label="iNOS Up-regulation"]
        NO_production       [label="NO\n(Nitric Oxide\nOver-production)"]
        sGC_cGMP            [label="sGC / cGMP\n(Smooth Muscle\nRelaxation)"]
        Vasodilation        [label="Systemic\nVasodilation"]
        Glycocalyx_shedding [label="Glycocalyx\nShedding"]
        Angiopoietin_2      [label="Angiopoietin-2\n(Vascular Destabiliser)"]
        VE_cadherin_disruption [label="VE-Cadherin\nDisruption"]
        VCAM1_ICAM1         [label="VCAM-1 / ICAM-1\n(Adhesion Molecules)"]
        Capillary_leak      [label="Capillary Leak /\nVascular Permeability↑"]
        Interstitial_edema  [label="Interstitial\nEdema"]
        MAP_decrease        [label="MAP Decrease\n(Hypotension)"]
        SVR_decrease        [label="SVR Decrease\n(Distributive Shock)"]
    }

    // =========================================================
    // CLUSTER 7 — HPA AXIS (Neuroendocrine)
    // =========================================================
    subgraph cluster_hpa {
        label     = "HPA Axis & Neuroendocrine Response"
        style     = "filled,rounded"
        fillcolor = "#1a001a"
        color     = "#aa44aa"
        fontcolor = "#ffccff"
        fontsize  = 13
        fontname  = "Helvetica-Bold"
        penwidth  = 2.0

        node [fillcolor="#4b0082" fontcolor=white color="#aa44aa"]

        CRH_hypothalamus  [label="CRH\n(Hypothalamus)"]
        ACTH_pituitary    [label="ACTH\n(Anterior Pituitary)"]
        Cortisol_synthesis [label="Cortisol Synthesis\n(Adrenal Cortex)"]
        GR_activation     [label="GR Activation\n(Glucocorticoid\nReceptor)"]
        Anti_inflam_genes [label="Anti-inflammatory\nGene Expression"]
        Adrenal_cortex    [label="Adrenal Cortex\n(Zona Fasciculata)"]
        Relative_AI_syndrome [label="Relative Adrenal\nInsufficiency (CIRCI)"]
        Vasopressin_ADH   [label="Vasopressin /\nADH (Posterior Pit.)"]
    }

    // =========================================================
    // CLUSTER 8 — ORGAN DYSFUNCTION / MODS
    // =========================================================
    subgraph cluster_organ {
        label     = "Organ Dysfunction (MODS)"
        style     = "filled,rounded"
        fillcolor = "#1a0000"
        color     = "#cc3333"
        fontcolor = "#ffbbbb"
        fontsize  = 13
        fontname  = "Helvetica-Bold"
        penwidth  = 2.0

        node [fillcolor="#800000" fontcolor=white color="#cc3333"]

        Cardiac_depression       [label="Cardiac Depression\n(Myocardial Dysfunction)"]
        Renal_AKI                [label="AKI\n(Acute Kidney Injury)"]
        Hepatic_dysfunction      [label="Hepatic\nDysfunction"]
        Pulmonary_ARDS           [label="ARDS\n(Acute Resp. Distress)"]
        Brain_encephalopathy     [label="Septic\nEncephalopathy"]
        Gut_barrier_fail         [label="Gut Barrier\nFailure (Leaky Gut)"]
        Adrenal_dysfunction      [label="Adrenal\nDysfunction"]
        DIC_organ_failure        [label="DIC → Organ\nMicrothrombosis"]
        Mitochondrial_dysfunction [label="Mitochondrial\nDysfunction"]
        MODS_score               [label="MODS Score\n(Multiple Organ\nDysfunction Score)"]
    }

    // =========================================================
    // CLUSTER 9 — PK / DRUG COMPARTMENTS
    // =========================================================
    subgraph cluster_pk_drugs {
        label     = "PK Drug Compartments"
        style     = "filled,rounded"
        fillcolor = "#001a1a"
        color     = "#00cccc"
        fontcolor = "#ccffff"
        fontsize  = 13
        fontname  = "Helvetica-Bold"
        penwidth  = 2.0

        node [fillcolor="#008b8b" fontcolor=white color="#00cccc" shape=diamond]

        Pip_Tazo_IV        [label="Pip/Tazo\nIV Dose (Input)"]
        PipTazo_Central    [label="Pip/Tazo\nCentral Compartment\n(Cp)"]
        PipTazo_Peripheral [label="Pip/Tazo\nPeripheral Compartment\n(Ct)"]
        Vancomycin_IV      [label="Vancomycin\nIV Dose (Input)"]
        Vancomycin_Central [label="Vancomycin\nCentral Compartment\n(Cp)"]
        NE_infusion        [label="Norepinephrine\nInfusion Rate"]
        NE_plasma          [label="Norepinephrine\nPlasma Conc."]
        HC_infusion        [label="Hydrocortisone\nInfusion Rate"]
        Cortisol_total     [label="Total Cortisol\n(Endogenous + HC)"]
        Vasopressin_infusion [label="Vasopressin\nInfusion Rate"]
        VP_plasma          [label="Vasopressin\nPlasma Conc."]
        Insulin_infusion   [label="Insulin Infusion\n(Glucose Control)"]
    }

    // =========================================================
    // CLUSTER 10 — CLINICAL ENDPOINTS / BIOMARKERS
    // =========================================================
    subgraph cluster_clinical {
        label     = "Clinical Endpoints & Biomarkers"
        style     = "filled,rounded"
        fillcolor = "#0d0d0d"
        color     = "#888888"
        fontcolor = "#dddddd"
        fontsize  = 13
        fontname  = "Helvetica-Bold"
        penwidth  = 2.0

        node [fillcolor="#2f4f4f" fontcolor=white color="#888888" shape=ellipse]

        SOFA_score      [label="SOFA Score"]
        qSOFA           [label="qSOFA"]
        Lactate_serum   [label="Serum Lactate\n(mmol/L)"]
        Procalcitonin   [label="Procalcitonin\n(PCT)"]
        CRP             [label="C-Reactive Protein\n(CRP)"]
        WBC_count       [label="WBC Count\n(×10³/μL)"]
        Platelet_count  [label="Platelet Count\n(×10³/μL)"]
        INR_PT          [label="INR / PT\n(Coagulation)"]
        Creatinine_serum [label="Serum Creatinine\n(mg/dL)"]
        Bilirubin       [label="Total Bilirubin\n(mg/dL)"]
        PaO2_FiO2       [label="PaO₂/FiO₂\n(P/F Ratio)"]
        Septic_Shock    [label="Septic Shock\n(Diagnosis)"]
    }

    // =========================================================
    // EDGES
    // =========================================================
    // Edge style defaults are overridden per category:
    //   Activation  → color="#00ff88"  arrowhead=normal
    //   Inhibition  → color="#ff4444"  arrowhead=tee style=dashed
    //   Drug effect → color="#00bfff"  arrowhead=normal style=dashed

    // --- Infection → PAMPs / DAMPs ---
    Bacteria        -> LPS             [color="#00ff88" arrowhead=normal label="releases"]
    Bacteria        -> LTA             [color="#00ff88" arrowhead=normal]
    Bacteria        -> Peptidoglycan   [color="#00ff88" arrowhead=normal]
    Bacteria        -> PAMP            [color="#00ff88" arrowhead=normal]
    Bacteria        -> Bacteremia      [color="#00ff88" arrowhead=normal label="systemic spread"]
    Fungemia        -> PAMP            [color="#00ff88" arrowhead=normal]
    Viral_RNA       -> PAMP            [color="#00ff88" arrowhead=normal]
    DAMP            -> HMGB1_release   [color="#00ff88" arrowhead=normal label="cell damage"]
    Bacteremia      -> DAMP            [color="#00ff88" arrowhead=normal]

    // --- PAMPs → TLR receptors ---
    LPS             -> MD2_complex     [color="#00ff88" arrowhead=normal]
    MD2_complex     -> TLR4            [color="#00ff88" arrowhead=normal label="LPS→TLR4\nvia MD-2/CD14"]
    LTA             -> TLR2            [color="#00ff88" arrowhead=normal]
    Peptidoglycan   -> TLR2            [color="#00ff88" arrowhead=normal]
    Viral_RNA       -> TLR9            [color="#00ff88" arrowhead=normal]
    PAMP            -> TLR4            [color="#00ff88" arrowhead=normal]

    // --- TLR → NF-kB signaling cascade ---
    TLR4            -> MyD88           [color="#00ff88" arrowhead=normal label="recruits"]
    TLR2            -> MyD88           [color="#00ff88" arrowhead=normal]
    TLR9            -> MyD88           [color="#00ff88" arrowhead=normal]
    MyD88           -> IRAK4           [color="#00ff88" arrowhead=normal label="activates"]
    IRAK4           -> IRAK1           [color="#00ff88" arrowhead=normal label="phosphorylates"]
    IRAK1           -> TRAF6           [color="#00ff88" arrowhead=normal]
    TRAF6           -> IKK_complex     [color="#00ff88" arrowhead=normal label="K63-Ub"]
    IKK_complex     -> IkB             [color="#00ff88" arrowhead=normal label="phosphorylates\n& ubiquitinates"]
    IkB             -> NF_kB_inactive  [color="#ff4444" arrowhead=tee style=dashed label="releases\nNF-κB"]
    NF_kB_inactive  -> NF_kB_active    [color="#00ff88" arrowhead=normal label="IκB degraded"]
    NF_kB_active    -> NF_kB_nucleus   [color="#00ff88" arrowhead=normal label="nuclear\ntranslocation"]

    // --- NF-kB nucleus → gene targets ---
    NF_kB_nucleus   -> TNF_alpha       [color="#00ff88" arrowhead=normal label="transcription"]
    NF_kB_nucleus   -> IL1_beta        [color="#00ff88" arrowhead=normal]
    NF_kB_nucleus   -> IL6             [color="#00ff88" arrowhead=normal]
    NF_kB_nucleus   -> IL8_CXCL8      [color="#00ff88" arrowhead=normal]
    NF_kB_nucleus   -> IL12            [color="#00ff88" arrowhead=normal]
    NF_kB_nucleus   -> iNOS_upregulation [color="#00ff88" arrowhead=normal]
    NF_kB_nucleus   -> TF_expression   [color="#00ff88" arrowhead=normal]
    NF_kB_nucleus   -> VCAM1_ICAM1    [color="#00ff88" arrowhead=normal]

    // --- Cytokine downstream signaling ---
    TNF_alpha       -> Macrophage_activation [color="#00ff88" arrowhead=normal]
    TNF_alpha       -> Neutrophil_recruit    [color="#00ff88" arrowhead=normal]
    IL1_beta        -> Macrophage_activation [color="#00ff88" arrowhead=normal]
    IL1_beta        -> Neutrophil_recruit    [color="#00ff88" arrowhead=normal]
    IL8_CXCL8       -> Neutrophil_recruit    [color="#00ff88" arrowhead=normal label="chemotaxis"]
    Macrophage_activation -> TNF_alpha       [color="#00ff88" arrowhead=normal label="amplifies"]
    Macrophage_activation -> IL1_beta        [color="#00ff88" arrowhead=normal]
    Macrophage_activation -> IL6             [color="#00ff88" arrowhead=normal]
    Macrophage_activation -> IL12            [color="#00ff88" arrowhead=normal]
    Macrophage_activation -> IL18            [color="#00ff88" arrowhead=normal]
    Macrophage_activation -> MIP1a           [color="#00ff88" arrowhead=normal]
    Macrophage_activation -> MCP1            [color="#00ff88" arrowhead=normal]
    Macrophage_activation -> HMGB1_late      [color="#00ff88" arrowhead=normal label="late secretion\n(8–32 h)"]
    IL12            -> IFN_gamma             [color="#00ff88" arrowhead=normal]
    IL18            -> IFN_gamma             [color="#00ff88" arrowhead=normal]
    IFN_gamma       -> Macrophage_activation [color="#00ff88" arrowhead=normal label="primes\nM1 phenotype"]
    IL6             -> G_CSF                 [color="#00ff88" arrowhead=normal]
    G_CSF           -> Neutrophil_recruit    [color="#00ff88" arrowhead=normal]
    IL17            -> G_CSF                 [color="#00ff88" arrowhead=normal]

    // --- Anti-inflammatory negative feedback ---
    TNF_alpha       -> IL10             [color="#00ff88" arrowhead=normal label="induces\n(feedback)"]
    IL6             -> IL10             [color="#00ff88" arrowhead=normal]
    IL1_beta        -> IL10             [color="#00ff88" arrowhead=normal]
    IL10            -> TNF_alpha        [color="#ff4444" arrowhead=tee style=dashed label="suppresses"]
    IL10            -> IL1_beta         [color="#ff4444" arrowhead=tee style=dashed]
    IL10            -> NF_kB_active     [color="#ff4444" arrowhead=tee style=dashed]
    IL4             -> NF_kB_active     [color="#ff4444" arrowhead=tee style=dashed]
    TGF_beta1       -> NF_kB_active     [color="#ff4444" arrowhead=tee style=dashed]

    // --- Procalcitonin & CRP induction ---
    IL6             -> Procalcitonin    [color="#00ff88" arrowhead=normal label="induces"]
    TNF_alpha       -> Procalcitonin    [color="#00ff88" arrowhead=normal]
    IL1_beta        -> Procalcitonin    [color="#00ff88" arrowhead=normal]
    IL6             -> CRP              [color="#00ff88" arrowhead=normal label="liver\nsynthesis"]

    // --- Coagulation cascade ---
    TF_expression   -> FVIIa            [color="#00ff88" arrowhead=normal label="forms TF:VIIa\ncomplex"]
    FVIIa           -> FXa_complex      [color="#00ff88" arrowhead=normal label="activates FX"]
    FVa             -> FXa_complex      [color="#00ff88" arrowhead=normal label="cofactor"]
    Thrombin        -> FVa              [color="#00ff88" arrowhead=normal label="activates"]
    FXa_complex     -> Prothrombin      [color="#00ff88" arrowhead=normal label="cleaves"]
    Prothrombin     -> Thrombin         [color="#00ff88" arrowhead=normal label="→ Thrombin"]
    Thrombin        -> Fibrinogen       [color="#00ff88" arrowhead=normal label="cleaves"]
    Fibrinogen      -> Fibrin           [color="#00ff88" arrowhead=normal label="→ Fibrin\n(polymerisation)"]
    Fibrin          -> D_dimer          [color="#00ff88" arrowhead=normal label="fibrinolysis\nproduct"]
    Thrombin        -> PAI1             [color="#00ff88" arrowhead=normal label="upregulates"]
    PAI1            -> tPA              [color="#ff4444" arrowhead=tee style=dashed label="inhibits"]
    tPA             -> Plasmin          [color="#00ff88" arrowhead=normal label="activates"]
    Plasmin         -> Fibrin           [color="#ff4444" arrowhead=tee style=dashed label="degrades"]
    Antithrombin    -> Thrombin         [color="#ff4444" arrowhead=tee style=dashed label="neutralises"]
    Protein_C       -> FVa              [color="#ff4444" arrowhead=tee style=dashed label="inactivates"]
    TFPI            -> FVIIa            [color="#ff4444" arrowhead=tee style=dashed label="inhibits\nTF:VIIa"]
    Thrombin        -> Protein_C        [color="#00ff88" arrowhead=normal label="activates\n(via TM)"]
    TNF_alpha       -> TF_expression    [color="#00ff88" arrowhead=normal label="induces"]
    IL1_beta        -> TF_expression    [color="#00ff88" arrowhead=normal]
    TNF_alpha       -> PAI1             [color="#00ff88" arrowhead=normal label="upregulates"]
    Fibrin          -> DIC_organ_failure [color="#00ff88" arrowhead=normal label="microvascular\nthrombi"]
    D_dimer         -> INR_PT           [color="#00ff88" arrowhead=normal label="DIC marker"]
    Platelet_count  -> DIC_organ_failure [color="#ff4444" arrowhead=tee style=dashed label="consumed\nin DIC"]

    // --- Complement system ---
    LPS             -> C3_activation    [color="#00ff88" arrowhead=normal label="activates\nclassical/alternative"]
    Bacteria        -> C1q_C1r_C1s     [color="#00ff88" arrowhead=normal label="classical\npathway"]
    C1q_C1r_C1s    -> C3_activation    [color="#00ff88" arrowhead=normal]
    MBL_MASP        -> C3_activation   [color="#00ff88" arrowhead=normal label="lectin\npathway"]
    Factor_B        -> C3_activation   [color="#00ff88" arrowhead=normal label="alternative\npathway"]
    Properdin       -> Factor_B        [color="#00ff88" arrowhead=normal label="stabilises\nalternative C3bBb"]
    C3_activation   -> C3a             [color="#00ff88" arrowhead=normal]
    C3_activation   -> C3b             [color="#00ff88" arrowhead=normal]
    C3b             -> C5_activation   [color="#00ff88" arrowhead=normal label="C5 convertase\nformation"]
    C5_activation   -> C5a             [color="#00ff88" arrowhead=normal]
    C5_activation   -> C5b_MAC        [color="#00ff88" arrowhead=normal]
    C5a             -> Neutrophil_recruit     [color="#00ff88" arrowhead=normal label="potent\nchemoattractant"]
    C5a             -> Macrophage_activation  [color="#00ff88" arrowhead=normal]
    C5b_MAC         -> Bacteria              [color="#ff4444" arrowhead=tee style=dashed label="bactericidal\nlysis"]
    C3a             -> Macrophage_activation  [color="#00ff88" arrowhead=normal label="degranulation"]

    // --- Vascular / endothelial dysfunction ---
    iNOS_upregulation -> NO_production  [color="#00ff88" arrowhead=normal label="catalyses"]
    NO_production   -> sGC_cGMP         [color="#00ff88" arrowhead=normal label="activates sGC"]
    sGC_cGMP        -> Vasodilation     [color="#00ff88" arrowhead=normal label="VSMC\nrelaxation"]
    Vasodilation    -> SVR_decrease     [color="#00ff88" arrowhead=normal]
    SVR_decrease    -> MAP_decrease     [color="#00ff88" arrowhead=normal]
    Angiopoietin_2  -> VE_cadherin_disruption [color="#00ff88" arrowhead=normal label="destabilises\nTie-2"]
    VE_cadherin_disruption -> Glycocalyx_shedding [color="#00ff88" arrowhead=normal]
    Glycocalyx_shedding -> Capillary_leak [color="#00ff88" arrowhead=normal]
    Capillary_leak  -> Interstitial_edema [color="#00ff88" arrowhead=normal]
    VCAM1_ICAM1     -> Neutrophil_recruit [color="#00ff88" arrowhead=normal label="adhesion &\nrolling"]
    TNF_alpha       -> Angiopoietin_2   [color="#00ff88" arrowhead=normal label="upregulates"]
    IL1_beta        -> Angiopoietin_2   [color="#00ff88" arrowhead=normal]
    MAP_decrease    -> Lactate_serum    [color="#00ff88" arrowhead=normal label="tissue\nhypoperfusion"]
    Interstitial_edema -> Pulmonary_ARDS [color="#00ff88" arrowhead=normal label="alveolar\nflooding"]
    Capillary_leak  -> Renal_AKI       [color="#00ff88" arrowhead=normal label="renal\nhypoperfusion"]

    // --- HPA axis ---
    TNF_alpha       -> CRH_hypothalamus [color="#00ff88" arrowhead=normal label="stress\nresponse"]
    IL1_beta        -> CRH_hypothalamus [color="#00ff88" arrowhead=normal]
    IL6             -> CRH_hypothalamus [color="#00ff88" arrowhead=normal]
    CRH_hypothalamus -> ACTH_pituitary  [color="#00ff88" arrowhead=normal]
    ACTH_pituitary  -> Adrenal_cortex   [color="#00ff88" arrowhead=normal label="stimulates"]
    Adrenal_cortex  -> Cortisol_synthesis [color="#00ff88" arrowhead=normal]
    Cortisol_synthesis -> GR_activation [color="#00ff88" arrowhead=normal label="ligand\nbinding"]
    GR_activation   -> Anti_inflam_genes [color="#00ff88" arrowhead=normal label="transactivation\ntransrepression"]
    Anti_inflam_genes -> TNF_alpha      [color="#ff4444" arrowhead=tee style=dashed label="suppresses"]
    Anti_inflam_genes -> IL1_beta       [color="#ff4444" arrowhead=tee style=dashed]
    Anti_inflam_genes -> IL6            [color="#ff4444" arrowhead=tee style=dashed]
    Anti_inflam_genes -> NF_kB_active   [color="#ff4444" arrowhead=tee style=dashed label="nuclear\nexclusion"]
    Relative_AI_syndrome -> Cortisol_synthesis [color="#ff4444" arrowhead=tee style=dashed label="impairs"]
    MAP_decrease    -> Relative_AI_syndrome [color="#00ff88" arrowhead=normal label="adrenal\nischemia"]
    Vasopressin_ADH -> MAP_decrease     [color="#ff4444" arrowhead=tee style=dashed label="vasopressor\neffect"]
    Cortisol_synthesis -> Vasopressin_ADH [color="#00ff88" arrowhead=normal label="upregulates\nV1 receptor"]

    // --- Organ dysfunction ---
    TNF_alpha       -> Cardiac_depression   [color="#00ff88" arrowhead=normal label="myocardial\ndepression"]
    IL1_beta        -> Cardiac_depression   [color="#00ff88" arrowhead=normal]
    IL6             -> Cardiac_depression   [color="#00ff88" arrowhead=normal]
    NO_production   -> Cardiac_depression   [color="#00ff88" arrowhead=normal label="cGMP↑ in\ncardiomyocytes"]
    MAP_decrease    -> Renal_AKI            [color="#00ff88" arrowhead=normal label="glomerular\nhypoperfusion"]
    TNF_alpha       -> Renal_AKI            [color="#00ff88" arrowhead=normal label="tubular\ninjury"]
    MAP_decrease    -> Hepatic_dysfunction  [color="#00ff88" arrowhead=normal label="hepatic\nhypoperfusion"]
    TNF_alpha       -> Hepatic_dysfunction  [color="#00ff88" arrowhead=normal]
    IL6             -> Hepatic_dysfunction  [color="#00ff88" arrowhead=normal label="acute-phase\nresponse"]
    TNF_alpha       -> Brain_encephalopathy [color="#00ff88" arrowhead=normal label="BBB\ndisruption"]
    IL1_beta        -> Brain_encephalopathy [color="#00ff88" arrowhead=normal]
    Capillary_leak  -> Gut_barrier_fail     [color="#00ff88" arrowhead=normal]
    TNF_alpha       -> Gut_barrier_fail     [color="#00ff88" arrowhead=normal label="tight junction\ndisruption"]
    MAP_decrease    -> Adrenal_dysfunction  [color="#00ff88" arrowhead=normal]
    Mitochondrial_dysfunction -> MODS_score [color="#00ff88" arrowhead=normal label="bioenergetic\nfailure"]
    DIC_organ_failure -> MODS_score        [color="#00ff88" arrowhead=normal]
    Cardiac_depression -> MODS_score       [color="#00ff88" arrowhead=normal]
    Renal_AKI       -> MODS_score          [color="#00ff88" arrowhead=normal]
    Pulmonary_ARDS  -> MODS_score          [color="#00ff88" arrowhead=normal]
    Hepatic_dysfunction -> MODS_score      [color="#00ff88" arrowhead=normal]
    Brain_encephalopathy -> MODS_score     [color="#00ff88" arrowhead=normal]
    TNF_alpha       -> Mitochondrial_dysfunction [color="#00ff88" arrowhead=normal label="oxidative\nstress"]
    IL1_beta        -> Mitochondrial_dysfunction [color="#00ff88" arrowhead=normal]
    HMGB1_late      -> Gut_barrier_fail    [color="#00ff88" arrowhead=normal label="late-phase\ntoxicity"]

    // --- Clinical biomarker outputs ---
    Renal_AKI       -> Creatinine_serum    [color="#00ff88" arrowhead=normal label="↑ creatinine"]
    Pulmonary_ARDS  -> PaO2_FiO2           [color="#ff4444" arrowhead=tee style=dashed label="↓ P/F ratio"]
    Hepatic_dysfunction -> Bilirubin       [color="#00ff88" arrowhead=normal label="↑ bilirubin"]
    Cardiac_depression -> SOFA_score       [color="#00ff88" arrowhead=normal]
    Renal_AKI       -> SOFA_score          [color="#00ff88" arrowhead=normal]
    Pulmonary_ARDS  -> SOFA_score          [color="#00ff88" arrowhead=normal]
    Hepatic_dysfunction -> SOFA_score      [color="#00ff88" arrowhead=normal]
    Brain_encephalopathy -> SOFA_score     [color="#00ff88" arrowhead=normal]
    Platelet_count  -> SOFA_score          [color="#ff4444" arrowhead=tee style=dashed label="thrombocytopenia\n↓ platelets"]
    MAP_decrease    -> SOFA_score          [color="#00ff88" arrowhead=normal]
    Lactate_serum   -> SOFA_score          [color="#00ff88" arrowhead=normal]
    DIC_organ_failure -> INR_PT            [color="#00ff88" arrowhead=normal label="↑ INR"]
    DIC_organ_failure -> Platelet_count    [color="#ff4444" arrowhead=tee style=dashed label="consumption\ncoagulopathy"]
    Creatinine_serum -> SOFA_score         [color="#00ff88" arrowhead=normal]
    Bilirubin       -> SOFA_score          [color="#00ff88" arrowhead=normal]
    PaO2_FiO2       -> SOFA_score          [color="#ff4444" arrowhead=tee style=dashed label="low P/F\nworsens SOFA"]
    Neutrophil_recruit -> WBC_count        [color="#00ff88" arrowhead=normal label="leukocytosis"]
    SOFA_score      -> Septic_Shock        [color="#00ff88" arrowhead=normal label="SOFA ≥ 2\n+ MAP < 65"]
    Lactate_serum   -> Septic_Shock        [color="#00ff88" arrowhead=normal label="Lactate > 2\nmmol/L"]
    MAP_decrease    -> Septic_Shock        [color="#00ff88" arrowhead=normal label="vasopressor\nrequirement"]
    SOFA_score      -> qSOFA               [color="#00ff88" arrowhead=normal label="simplified\nbedside score"]

    // --- Drug PK chains ---
    Pip_Tazo_IV     -> PipTazo_Central     [color="#00bfff" arrowhead=normal style=dashed label="IV bolus /\ncontinuous inf."]
    PipTazo_Central -> PipTazo_Peripheral  [color="#00bfff" arrowhead=normal style=dashed label="distribution\n(k12)"]
    PipTazo_Peripheral -> PipTazo_Central  [color="#00bfff" arrowhead=normal style=dashed label="redistribution\n(k21)"]
    Vancomycin_IV   -> Vancomycin_Central  [color="#00bfff" arrowhead=normal style=dashed label="IV infusion"]
    NE_infusion     -> NE_plasma           [color="#00bfff" arrowhead=normal style=dashed label="clearance\n(CL_NE)"]
    HC_infusion     -> Cortisol_total      [color="#00bfff" arrowhead=normal style=dashed label="adds to\nendogenous"]
    Cortisol_synthesis -> Cortisol_total   [color="#00bfff" arrowhead=normal style=dashed label="endogenous\ncortisol"]
    Vasopressin_infusion -> VP_plasma      [color="#00bfff" arrowhead=normal style=dashed label="clearance\n(CL_VP)"]
    Cortisol_total  -> Anti_inflam_genes   [color="#00bfff" arrowhead=normal style=dashed label="GR-mediated\nanti-inflam"]
    Cortisol_total  -> GR_activation       [color="#00bfff" arrowhead=normal style=dashed label="HC + cortisol\n→ GR"]

    // --- Drug PD effects ---
    PipTazo_Central -> Bacteria            [color="#00bfff" arrowhead=normal style=dashed label="bactericidal\n(T > MIC)"]
    Vancomycin_Central -> Bacteria         [color="#00bfff" arrowhead=normal style=dashed label="bactericidal\n(AUC/MIC)"]
    NE_plasma       -> MAP_decrease        [color="#ff4444" arrowhead=tee style=dashed label="vasopressor\n(α1-adrenergic)\nreverses ↓MAP"]
    NE_plasma       -> SVR_decrease        [color="#ff4444" arrowhead=tee style=dashed label="increases\nSVR"]
    VP_plasma       -> MAP_decrease        [color="#ff4444" arrowhead=tee style=dashed label="V1R-mediated\nvasoconstriction"]
    VP_plasma       -> SVR_decrease        [color="#ff4444" arrowhead=tee style=dashed]
    Insulin_infusion -> Lactate_serum      [color="#ff4444" arrowhead=tee style=dashed label="glucose control\nreduces lactate"]
    HC_infusion     -> Relative_AI_syndrome [color="#ff4444" arrowhead=tee style=dashed label="replacement\ntherapy"]

    // --- Cross-cluster edges (MODS ↔ clinical) ---
    MODS_score      -> SOFA_score          [color="#00ff88" arrowhead=normal]
    Gut_barrier_fail -> Bacteremia         [color="#00ff88" arrowhead=normal label="bacterial\ntranslocation"]

    // =========================================================
    // LEGEND
    // =========================================================
    subgraph cluster_legend {
        label     = "Legend"
        style     = "filled,rounded"
        fillcolor = "#0a0a1a"
        color     = "#aaaaaa"
        fontcolor = "#cccccc"
        fontsize  = 12
        fontname  = "Helvetica-Bold"
        penwidth  = 1.5
        rank      = sink

        Legend_Act   [label="Activation / Induction" shape=box fillcolor="#1a3a1a" fontcolor="#00ff88" color="#00ff88"]
        Legend_Inh   [label="Inhibition / Suppression" shape=box fillcolor="#3a1a1a" fontcolor="#ff4444" color="#ff4444"]
        Legend_Drug  [label="Drug PK/PD Effect"        shape=box fillcolor="#1a2a3a" fontcolor="#00bfff" color="#00bfff"]
        Legend_Node_Drug [label="Drug Compartment\n(Diamond)" shape=diamond fillcolor="#008b8b" fontcolor=white color="#00cccc"]
        Legend_Biomarker [label="Clinical Biomarker\n(Ellipse)"  shape=ellipse fillcolor="#2f4f4f" fontcolor=white color="#888888"]

        Legend_Act   -> Legend_Inh   [color="#00ff88" arrowhead=normal label="→ activation"]
        Legend_Inh   -> Legend_Drug  [color="#ff4444" arrowhead=tee style=dashed label="⊣ inhibition"]
        Legend_Drug  -> Legend_Node_Drug [color="#00bfff" arrowhead=normal style=dashed label="-- drug effect"]
    }

}
