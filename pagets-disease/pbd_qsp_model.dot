digraph PBD_QSP_Model {
    // Global graph settings
    graph [
        label="Paget's Disease of Bone (PBD) — Quantitative Systems Pharmacology Model\nMechanistic Map: Etiology · RANKL Signaling · Osteoclast Biology · Bone Resorption · Osteoblast Biology\nBone Formation · Biomarkers · Clinical Endpoints · Drug PK/PD (Bisphosphonates · Calcitonin · Denosumab) · Systemic Effects"
        fontname="Helvetica"
        fontsize=18
        labelloc=t
        rankdir=TB
        splines=ortho
        nodesep=0.5
        ranksep=0.7
        bgcolor=white
        compound=true
    ]
    node [fontname="Helvetica" fontsize=10 style=filled shape=box]
    edge [fontname="Helvetica" fontsize=8]

    // ==========================================================================
    // CLUSTER 1: ETIOLOGY — Genetic & Environmental Triggers
    // ==========================================================================
    subgraph cluster_etiology {
        label="Etiology: Genetic & Environmental Risk Factors"
        style=filled
        fillcolor="#FFF0F0"
        color=red
        fontsize=13
        fontname="Helvetica-Bold"

        SQSTM1_mut [label="SQSTM1 Mutation\n(p62/Sequestosome-1)" fillcolor=lightcoral]
        VCP_mut [label="VCP Mutation\n(Valosin-Containing Protein)" fillcolor=lightcoral]
        RANK_mut [label="RANK Mutation\n(TNFRSF11A gain-of-fn)" fillcolor=lightcoral]
        ZNF687_mut [label="ZNF687 Mutation\n(Zinc Finger Protein 687)" fillcolor=lightcoral]
        CSF1_mut [label="CSF1 Mutation\n(Colony Stimulating Factor 1)" fillcolor=lightcoral]
        Paramyxovirus_hyp [label="Paramyxovirus Hypothesis\n(Measles/RSV/CDV)" fillcolor=lightcoral]
        Measles_NP_protein [label="Measles Nucleocapsid Protein\n(NP — viral inclusion bodies)" fillcolor=lightcoral]
        Oxidative_stress [label="Oxidative Stress\n(ROS accumulation)" fillcolor=lightcoral]
        Aging [label="Aging\n(Age-related OC dysregulation)" fillcolor=lightcoral]
        CDT2_deficiency [label="CDT2 Deficiency\n(CRL4-CDT2 E3 ligase)" fillcolor=lightcoral]
        mitophagy_impair [label="Mitophagy Impairment\n(Abnormal mitochondria clearance)" fillcolor=lightcoral]
        Autophagy_defect [label="Autophagy Defect\n(p62 aggregate accumulation)" fillcolor=lightcoral]
    }

    // ==========================================================================
    // CLUSTER 2: RANKL / OPG SIGNALING PATHWAY
    // ==========================================================================
    subgraph cluster_rankl_signaling {
        label="RANKL / OPG Signaling Axis"
        style=filled
        fillcolor="#FFFFF0"
        color=goldenrod
        fontsize=13
        fontname="Helvetica-Bold"

        RANKL [label="RANKL\n(TNFSF11; osteoblast/stromal)" fillcolor=lightyellow]
        OPG [label="OPG\n(Osteoprotegerin; decoy receptor)" fillcolor=lightyellow]
        RANK_receptor [label="RANK Receptor\n(TNFRSF11A; OC surface)" fillcolor=lightyellow]
        MCSF [label="M-CSF\n(Macrophage Colony-Stim Factor)" fillcolor=lightyellow]
        cFms [label="c-Fms (CSF1R)\n(M-CSF receptor on OC precursors)" fillcolor=lightyellow]
        TRAF6 [label="TRAF6\n(TNF Receptor-Associated Factor 6)" fillcolor=lightyellow]
        IKK_complex [label="IKK Complex\n(IKKα/IKKβ/NEMO)" fillcolor=lightyellow]
        IkBa [label="IκBα\n(NF-κB inhibitor — degraded)" fillcolor=lightyellow]
        NFkB_pathway [label="NF-κB Pathway\n(p50/p65 nuclear translocation)" fillcolor=lightyellow]
        NFATc1 [label="NFATc1\n(Master OC transcription factor)" fillcolor=lightyellow]
        AP1 [label="AP-1 Complex\n(c-Fos/c-Jun heterodimer)" fillcolor=lightyellow]
        cFos [label="c-Fos\n(proto-oncogene, OC gene activation)" fillcolor=lightyellow]
        cJun [label="c-Jun\n(AP-1 component)" fillcolor=lightyellow]
        ERK [label="ERK1/2\n(Extracellular Signal-Regulated Kinase)" fillcolor=lightyellow]
        p38_MAPK [label="p38 MAPK\n(Stress-activated kinase)" fillcolor=lightyellow]
        JNK [label="JNK\n(c-Jun N-terminal Kinase)" fillcolor=lightyellow]
        PI3K_Akt [label="PI3K/Akt\n(Survival signaling)" fillcolor=lightyellow]
        RhoA_Rock [label="RhoA/ROCK\n(Cytoskeletal organization)" fillcolor=lightyellow]
    }

    // ==========================================================================
    // CLUSTER 3: OSTEOCLAST BIOLOGY
    // ==========================================================================
    subgraph cluster_osteoclast {
        label="Osteoclast Biology — Differentiation & Activation"
        style=filled
        fillcolor="#FFF3EE"
        color=darkorange
        fontsize=13
        fontname="Helvetica-Bold"

        Monocyte_prec [label="Monocyte Precursors\n(CD14+ bone marrow origin)" fillcolor=lightsalmon]
        OCpre_committed [label="Committed OC Precursor\n(RANK+/TRAP+ pre-OC)" fillcolor=lightsalmon]
        Multinucleated_OC [label="Multinucleated Osteoclast\n(Pagetic — giant, hypernucleated)" fillcolor=lightsalmon]
        CathepsinK [label="Cathepsin K\n(Cysteine protease; bone collagen)" fillcolor=lightsalmon]
        MMP9 [label="MMP-9\n(Matrix Metalloproteinase 9)" fillcolor=lightsalmon]
        Src_kinase [label="Src Kinase\n(Cytoskeletal signaling in OC)" fillcolor=lightsalmon]
        Integrin_avb3 [label="Integrin αvβ3\n(OC attachment to bone)" fillcolor=lightsalmon]
        DCSTAMP [label="DC-STAMP\n(Dendritic Cell-Specific TM Prot)" fillcolor=lightsalmon]
        TRAP [label="TRAP\n(Tartrate-Resistant Acid Phosphatase)" fillcolor=lightsalmon]
        vATPase [label="V-ATPase\n(Vacuolar proton pump — acidification)" fillcolor=lightsalmon]
        Carbonic_anhydrase2 [label="Carbonic Anhydrase II\n(CA2; H+ generation)" fillcolor=lightsalmon]
        Chloride_channel [label="Chloride Channel\n(ClC-7; HCl secretion)" fillcolor=lightsalmon]
        Ezrin_Radixin_Moesin [label="Ezrin/Radixin/Moesin\n(ERM; ruffled border organization)" fillcolor=lightsalmon]
        Podosome_belt [label="Podosome Belt\n(Sealing zone precursor structure)" fillcolor=lightsalmon]
        OC_number_pagetic [label="Pagetic OC Number\n(Markedly increased vs normal)" fillcolor=lightsalmon]
    }

    // ==========================================================================
    // CLUSTER 4: BONE RESORPTION
    // ==========================================================================
    subgraph cluster_resorption {
        label="Bone Resorption — Mechanism & Markers"
        style=filled
        fillcolor="#FFF0F5"
        color=deeppink
        fontsize=13
        fontname="Helvetica-Bold"

        Ruffled_border [label="Ruffled Border\n(OC secretory membrane domain)" fillcolor=lightpink]
        Sealing_zone [label="Sealing Zone\n(Tight OC-bone attachment)" fillcolor=lightpink]
        Resorption_lacuna [label="Resorption Lacuna\n(Howship's lacuna — low pH ~4.5)" fillcolor=lightpink]
        H_secretion [label="H+ Secretion\n(Acidification of lacuna)" fillcolor=lightpink]
        Cl_secretion [label="Cl- Secretion\n(Electroneutrality maintenance)" fillcolor=lightpink]
        Collagen_degradation [label="Collagen I Degradation\n(CathK + MMP9 proteolysis)" fillcolor=lightpink]
        DPD_release [label="DPD Release\n(Deoxypyridinoline crosslinks)" fillcolor=lightpink]
        NTX_urine [label="Urinary NTX\n(N-Telopeptide — resorption marker)" fillcolor=lightpink]
        CTX_serum [label="Serum CTX\n(C-Telopeptide — β-CrossLaps)" fillcolor=lightpink]
        Hydroxyproline [label="Hydroxyproline\n(Urinary collagen degradation product)" fillcolor=lightpink]
        TGFb1_release [label="TGF-β1 Release\n(Bone matrix — coupling signal)" fillcolor=lightpink]
        IGF1_release [label="IGF-1 Release\n(Bone matrix — OB stimulation)" fillcolor=lightpink]
        Resorption_rate_PBD [label="Pagetic Resorption Rate\n(Up to 20× normal)" fillcolor=lightpink]
    }

    // ==========================================================================
    // CLUSTER 5: OSTEOBLAST BIOLOGY
    // ==========================================================================
    subgraph cluster_osteoblast {
        label="Osteoblast Biology — Differentiation & Regulation"
        style=filled
        fillcolor="#F0F0FF"
        color=mediumblue
        fontsize=13
        fontname="Helvetica-Bold"

        MSC_bone_marrow [label="Bone Marrow MSC\n(Mesenchymal Stem Cell)" fillcolor=lightblue]
        OBpre_committed [label="Committed OB Precursor\n(Pre-osteoblast)" fillcolor=lightblue]
        OB_mature [label="Mature Osteoblast\n(Cuboidal; active matrix synthesis)" fillcolor=lightblue]
        Osteocyte [label="Osteocyte\n(Embedded; mechanosensing)" fillcolor=lightblue]
        Runx2_Cbfa1 [label="RUNX2/Cbfa1\n(Master OB transcription factor)" fillcolor=lightblue]
        Osterix [label="Osterix (SP7)\n(Downstream of RUNX2)" fillcolor=lightblue]
        Wnt_ligand [label="Wnt Ligands\n(Wnt3a, Wnt10b — OB stimulation)" fillcolor=lightblue]
        Frizzled_LRP56 [label="Frizzled/LRP5/6\n(Wnt co-receptor complex)" fillcolor=lightblue]
        Bcatenin_nucl [label="β-Catenin (Nuclear)\n(Wnt target gene activation)" fillcolor=lightblue]
        BMP2 [label="BMP-2\n(Bone Morphogenetic Protein 2)" fillcolor=lightblue]
        BMP4 [label="BMP-4\n(Bone Morphogenetic Protein 4)" fillcolor=lightblue]
        BMP7 [label="BMP-7 (OP-1)\n(Osteogenic Protein 1)" fillcolor=lightblue]
        Smad158 [label="SMAD 1/5/8\n(BMP signal transducers)" fillcolor=lightblue]
        Sclerostin [label="Sclerostin (SOST)\n(Osteocyte-derived Wnt inhibitor)" fillcolor=lightblue]
        DKK1 [label="DKK-1\n(Dickkopf-1; Wnt antagonist)" fillcolor=lightblue]
        Activin_A [label="Activin A\n(TGF-β superfamily; OB inhibitor)" fillcolor=lightblue]
        OB_number_pagetic [label="Pagetic OB Number\n(Reactive increase; coupling)" fillcolor=lightblue]
    }

    // ==========================================================================
    // CLUSTER 6: BONE FORMATION
    // ==========================================================================
    subgraph cluster_formation {
        label="Bone Formation — Matrix Synthesis & Mineralization"
        style=filled
        fillcolor="#F0FFFF"
        color=teal
        fontsize=13
        fontname="Helvetica-Bold"

        CollagenI_synthesis [label="Collagen Type I Synthesis\n(COL1A1/COL1A2; bone matrix)" fillcolor=lightcyan]
        Osteocalcin [label="Osteocalcin (BGP)\n(Gla-protein; bone formation marker)" fillcolor=lightcyan]
        Osteopontin [label="Osteopontin (OPN)\n(SIBLING protein; bone adhesion)" fillcolor=lightcyan]
        Bone_sialoprotein [label="Bone Sialoprotein (BSP)\n(Nucleates hydroxyapatite)" fillcolor=lightcyan]
        bsALP_enzyme [label="Bone-Specific ALP\n(Enzyme; matrix vesicle-derived)" fillcolor=lightcyan]
        Mineralization [label="Hydroxyapatite Mineralization\n(Ca10(PO4)6(OH)2 deposition)" fillcolor=lightcyan]
        Woven_bone_PBD [label="Woven Bone (Pagetic)\n(Disorganized; hypervascular)" fillcolor=lightcyan]
        Lamellar_bone_normal [label="Lamellar Bone\n(Organized; load-bearing)" fillcolor=lightcyan]
        Mosaic_bone_pattern [label="Mosaic Bone Pattern\n(Pathognomonic PBD histology)" fillcolor=lightcyan]
        Cement_lines [label="Cement Lines\n(Irregular reversal lines — PBD hallmark)" fillcolor=lightcyan]
        Formation_rate_PBD [label="Pagetic Formation Rate\n(Coupled to resorption; disordered)" fillcolor=lightcyan]
        PICP_serum [label="Serum PICP\n(Procollagen I C-terminal propeptide)" fillcolor=lightcyan]
    }

    // ==========================================================================
    // CLUSTER 7: BIOMARKERS
    // ==========================================================================
    subgraph cluster_biomarkers {
        label="Biochemical Biomarkers — PBD Activity Monitoring"
        style=filled
        fillcolor="#F5F5F5"
        color=grey40
        fontsize=13
        fontname="Helvetica-Bold"

        bsALP_serum [label="Serum bsALP\n(Bone-Specific Alkaline Phosphatase)" fillcolor=lightgrey]
        TotalALP_serum [label="Total Serum ALP\n(Primary clinical marker for PBD)" fillcolor=lightgrey]
        NTX_measure [label="Urinary NTX\n(Collagen crosslink resorption)" fillcolor=lightgrey]
        CTX_measure [label="Serum β-CTX\n(β-CrossLaps resorption marker)" fillcolor=lightgrey]
        P1NP_serum [label="Serum P1NP\n(Procollagen I N-terminal propeptide)" fillcolor=lightgrey]
        Osteocalcin_serum [label="Serum Osteocalcin\n(Bone formation marker)" fillcolor=lightgrey]
        Serum_Ca [label="Serum Calcium\n(Usually normal; hypercalcemia if immobile)" fillcolor=lightgrey]
        Serum_Pi [label="Serum Phosphate\n(Usually normal in PBD)" fillcolor=lightgrey]
        PTH_serum [label="Serum PTH\n(Usually suppressed if hypercalcemic)" fillcolor=lightgrey]
        Vit_D_125OH2D3 [label="1,25(OH)2D3\n(Calcitriol; Ca absorption regulator)" fillcolor=lightgrey]
        CRP_inflammation [label="CRP\n(Inflammatory marker; elevated in PBD)" fillcolor=lightgrey]
        Uric_acid [label="Uric Acid\n(Elevated due to cell turnover)" fillcolor=lightgrey]
    }

    // ==========================================================================
    // CLUSTER 8: CLINICAL OUTCOMES
    // ==========================================================================
    subgraph cluster_clinical {
        label="Clinical Manifestations & Complications"
        style=filled
        fillcolor="#F8F0FF"
        color=purple
        fontsize=13
        fontname="Helvetica-Bold"

        Bone_pain_VAS [label="Bone Pain (VAS)\n(Primary symptom; local + referred)" fillcolor=lavender]
        Bone_deformity [label="Bone Deformity\n(Progressive; weight-bearing bones)" fillcolor=lavender]
        Bowing_tibia [label="Bowing of Tibia\n('Saber shin'; lateral bowing)" fillcolor=lavender]
        Skull_enlargement [label="Skull Enlargement\n(Hat size increase; thickened calvaria)" fillcolor=lavender]
        Pathological_fracture [label="Pathological Fracture\n(Chalk-stick; incomplete fissure)" fillcolor=lavender]
        Hearing_loss_CN8 [label="Hearing Loss (CN VIII)\n(Cochlear/ossicle involvement)" fillcolor=lavender]
        Spinal_stenosis [label="Spinal Stenosis\n(Vertebral expansion; cord compress)" fillcolor=lavender]
        High_output_cardiac [label="High-Output Cardiac\n(Pagetic bone hypervascularity)" fillcolor=lavender]
        Osteosarcoma_risk [label="Osteosarcoma Risk\n(<1%; poor prognosis)" fillcolor=lavender]
        Cranial_nerve_compress [label="Cranial Nerve Compression\n(Platybasia; basilar invagination)" fillcolor=lavender]
        Vertebral_collapse [label="Vertebral Collapse\n(Ivory vertebra → compression)" fillcolor=lavender]
        Osteoarthritis_secondary [label="Secondary Osteoarthritis\n(Adjacent joint involvement)" fillcolor=lavender]
    }

    // ==========================================================================
    // CLUSTER 9: BISPHOSPHONATE PK/PD
    // ==========================================================================
    subgraph cluster_pk_bp {
        label="Bisphosphonate PK/PD (Zoledronic Acid · Alendronate)"
        style=filled
        fillcolor="#F0FFF0"
        color=darkgreen
        fontsize=13
        fontname="Helvetica-Bold"

        ZA_IV_admin [label="Zoledronic Acid IV\n(5 mg once; standard of care)" fillcolor=lightgreen]
        ZA_central_cmt [label="ZA Central Compartment\n(Plasma distribution; t½α ~0.23h)" fillcolor=lightgreen]
        ZA_peripheral_cmt [label="ZA Peripheral Compartment\n(Tissue distribution)" fillcolor=lightgreen]
        ZA_bone_bound [label="ZA Bone-Bound\n(High affinity HAP binding; depot)" fillcolor=lightgreen]
        Alendronate_oral [label="Alendronate Oral\n(40 mg/day for PBD; 3-month course)" fillcolor=lightgreen]
        Alendronate_absorb [label="Alendronate Absorbed\n(~0.7% bioavailability; GI limited)" fillcolor=lightgreen]
        Alendronate_bone [label="Alendronate Bone-Bound\n(HAP affinity; long retention)" fillcolor=lightgreen]
        FPPS_enzyme [label="FPPS\n(Farnesyl Pyrophosphate Synthase)" fillcolor=lightgreen]
        Mevalonate_pathway [label="Mevalonate Pathway\n(Cholesterol biosynthesis cascade)" fillcolor=lightgreen]
        Geranyl_PP [label="Geranyl Pyrophosphate\n(Intermediate; BP blocks here)" fillcolor=lightgreen]
        Farnesyl_PP [label="Farnesyl Pyrophosphate\n(FPPS product; BP inhibits synthesis)" fillcolor=lightgreen]
        Prenylation_block [label="Protein Prenylation Block\n(Farnesyl/Geranylgeranyl transfer)" fillcolor=lightgreen]
        Rab_GTPase_inhib [label="Rab GTPase Inhibition\n(Vesicular trafficking disruption)" fillcolor=lightgreen]
        OC_apoptosis_BP [label="OC Apoptosis (BP)\n(Caspase activation → OC death)" fillcolor=lightgreen]
        Risedronate_oral [label="Risedronate Oral\n(30 mg/day × 2 months; alternative)" fillcolor=lightgreen]
        Pamidronate_IV [label="Pamidronate IV\n(60–90 mg; older agent)" fillcolor=lightgreen]
    }

    // ==========================================================================
    // CLUSTER 10: CALCITONIN PK/PD
    // ==========================================================================
    subgraph cluster_pk_ctn {
        label="Calcitonin PK/PD (Salmon Calcitonin)"
        style=filled
        fillcolor="#F0FFF4"
        color=forestgreen
        fontsize=13
        fontname="Helvetica-Bold"

        Calcitonin_SC [label="Salmon Calcitonin SC/IM\n(100 IU/day; historical use)" fillcolor=palegreen]
        CTN_plasma [label="Calcitonin Plasma\n(Peak ~15 min; t½ ~1h)" fillcolor=palegreen]
        CALCR_receptor [label="Calcitonin Receptor (CALCR)\n(GPCR; OC membrane)" fillcolor=palegreen]
        Gs_protein [label="Gs Protein\n(Receptor-coupled G-protein)" fillcolor=palegreen]
        cAMP_PKA [label="cAMP/PKA Signaling\n(OC cytoskeletal disruption)" fillcolor=palegreen]
        CALCR_downreg [label="CALCR Downregulation\n(Desensitization; escape phenomenon)" fillcolor=palegreen]
        OC_inhibition_CTN [label="OC Inhibition (Calcitonin)\n(Rapid but transient; quiescent OC)" fillcolor=palegreen]
        CTN_renal_effect [label="Renal Calcitonin Effect\n(Ca/P reabsorption reduction)" fillcolor=palegreen]
    }

    // ==========================================================================
    // CLUSTER 11: DENOSUMAB PK/PD
    // ==========================================================================
    subgraph cluster_pk_dmb {
        label="Denosumab PK/PD (Anti-RANKL mAb)"
        style=filled
        fillcolor="#F0F8FF"
        color=steelblue
        fontsize=13
        fontname="Helvetica-Bold"

        Denosumab_SC [label="Denosumab SC\n(60 mg q6m or 120 mg; off-label PBD)" fillcolor=lightskyblue]
        DMB_central_cmt [label="Denosumab Central Cmt\n(Plasma; t½ ~28 days)" fillcolor=lightskyblue]
        DMB_peripheral_cmt [label="Denosumab Peripheral Cmt\n(Tissue distribution)" fillcolor=lightskyblue]
        FcRn_recycling [label="FcRn Recycling\n(Neonatal Fc receptor; mAb t½ ext)" fillcolor=lightskyblue]
        RANKL_binding [label="RANKL Binding\n(Kd ~3 pM; high affinity)" fillcolor=lightskyblue]
        RANKL_neutralization [label="RANKL Neutralization\n(Prevents RANK engagement)" fillcolor=lightskyblue]
        OC_formation_block [label="OC Formation Block\n(Differentiation arrest)" fillcolor=lightskyblue]
        Rebound_effect_DMB [label="Rebound Effect\n(OC burst after cessation)" fillcolor=lightskyblue]
    }

    // ==========================================================================
    // CLUSTER 12: SYSTEMIC EFFECTS
    // ==========================================================================
    subgraph cluster_systemic {
        label="Systemic & Vascular Complications"
        style=filled
        fillcolor="#F5F0FF"
        color=darkviolet
        fontsize=13
        fontname="Helvetica-Bold"

        VEGF_pagetic [label="VEGF (Pagetic Bone)\n(Vascular Endothelial Growth Factor)" fillcolor=plum]
        AV_shunting [label="Arteriovenous Shunting\n(Pagetic bone hypervascularity)" fillcolor=plum]
        Cardiac_output_incr [label="Cardiac Output Increase\n(High-output state; warm pagetic bone)" fillcolor=plum]
        HO_cardiac_failure [label="High-Output Cardiac Failure\n(Severe/extensive PBD)" fillcolor=plum]
        Neurological_complic [label="Neurological Complications\n(Steal syndrome; cord compress)" fillcolor=plum]
        Bone_marrow_fibrosis [label="Bone Marrow Fibrosis\n(Peritrabecular fibrosis in PBD)" fillcolor=plum]
        Focal_hyperemia [label="Focal Hyperemia\n(Increased local blood flow; warmth)" fillcolor=plum]
        Hypercalcemia_immob [label="Immobilization Hypercalcemia\n(If extensive PBD + bed rest)" fillcolor=plum]
        IL6_pagetic [label="IL-6 (Pagetic)\n(Osteoclastogenic cytokine — elevated)" fillcolor=plum]
        IL1b_pagetic [label="IL-1β (Pagetic)\n(Pro-inflammatory; OC activator)" fillcolor=plum]
        TNFa_pagetic [label="TNF-α (Pagetic)\n(NF-κB activator; OC stimulation)" fillcolor=plum]
    }

    // ==========================================================================
    // EDGES: ETIOLOGY → RANKL/OC SIGNALING
    // ==========================================================================
    SQSTM1_mut -> Autophagy_defect [label="p62 aggregation\nimpairs ubiquitin-\nproteasome" color=red]
    SQSTM1_mut -> NFkB_pathway [label="p62 scaffold\nactivates NF-κB" color=red]
    SQSTM1_mut -> TRAF6 [label="p62-TRAF6\ninteraction\n(scaffold)" color=red]
    VCP_mut -> Autophagy_defect [label="VCP/p97 regulates\nautophagosome\nmaturation" color=red]
    VCP_mut -> Multinucleated_OC [label="VCP mutation →\nabnormal OC\nfusion" color=red]
    RANK_mut -> RANK_receptor [label="Gain-of-function\n→ constitutive\nRANK activation" color=red]
    ZNF687_mut -> NFATc1 [label="ZNF687 regulates\nNFATc1\ntranscription" color=red]
    CSF1_mut -> MCSF [label="CSF1 mutation\nalters M-CSF\nproduction" color=red]
    Paramyxovirus_hyp -> Measles_NP_protein [label="Viral NP protein\ndetected in pagetic\nOC nuclei" color=red]
    Measles_NP_protein -> RANK_receptor [label="Viral NP sensitizes\nOC to RANKL\nsignaling" color=red]
    Measles_NP_protein -> NFkB_pathway [label="Viral NP activates\nNF-κB in OC" color=red]
    Oxidative_stress -> SQSTM1_mut [label="ROS promotes\nSQSTM1 mutation\nexpression" color=red]
    Oxidative_stress -> mitophagy_impair [label="ROS disrupts\nmitochondrial\nclearance" color=red]
    Aging -> Oxidative_stress [label="Age-related ROS\naccumulation" color=red]
    Aging -> SQSTM1_mut [label="Aging increases\nSQSTM1 dysfunction\npenetrance" color=red]
    CDT2_deficiency -> Autophagy_defect [label="CDT2 loss impairs\nSQSTM1 degradation" color=red]
    mitophagy_impair -> Oxidative_stress [label="Impaired mitophagy\n→ ROS accumulation" color=red]
    Autophagy_defect -> NFkB_pathway [label="p62 aggregate\nconstitutively\nactivates NF-κB" color=red]

    // ==========================================================================
    // EDGES: RANKL SIGNALING CASCADE
    // ==========================================================================
    RANKL -> RANK_receptor [label="RANKL binds RANK\n(trimeric interaction)" color=goldenrod style=bold]
    OPG -> RANKL [label="OPG sequesters\nRANKL (decoy\nreceptor)" color=blue style=dashed arrowhead=tee]
    MCSF -> cFms [label="M-CSF binds c-Fms\n(survival + proliferation)" color=goldenrod]
    RANK_receptor -> TRAF6 [label="RANK cytoplasmic\ntail recruits TRAF6" color=goldenrod]
    TRAF6 -> IKK_complex [label="TRAF6 ubiquitin\nligase activates IKK" color=goldenrod]
    IKK_complex -> IkBa [label="IKK phosphorylates\nIκBα → ubiquitination" color=goldenrod]
    IkBa -> NFkB_pathway [label="IκBα degradation\nreleases NF-κB" color=goldenrod]
    NFkB_pathway -> NFATc1 [label="NF-κB induces\nNFATc1 transcription\n(key OC gene)" color=goldenrod style=bold]
    TRAF6 -> ERK [label="TRAF6 activates\nMAPK cascade" color=goldenrod]
    TRAF6 -> p38_MAPK [label="TRAF6 → ASK1\n→ p38 activation" color=goldenrod]
    TRAF6 -> JNK [label="TRAF6 → MEKK1\n→ JNK activation" color=goldenrod]
    ERK -> cFos [label="ERK phosphorylates\nc-Fos → stabilization" color=goldenrod]
    cFos -> AP1 [label="c-Fos + c-Jun\nform AP-1 complex" color=goldenrod]
    cJun -> AP1 [label="c-Jun heterodimerizes\nwith c-Fos → AP-1" color=goldenrod]
    AP1 -> NFATc1 [label="AP-1 cooperates with\nNFATc1 at OC\ngene promoters" color=goldenrod]
    RANK_receptor -> PI3K_Akt [label="RANK → PI3K\n→ Akt survival" color=goldenrod]
    PI3K_Akt -> NFATc1 [label="Akt stabilizes\nNFATc1 (GSK3β\ninhibition)" color=goldenrod]
    RANK_receptor -> RhoA_Rock [label="RANK → RhoA\n→ actin ring\nformation" color=goldenrod]
    RhoA_Rock -> Podosome_belt [label="ROCK phosphorylates\nmyosin → podosome\norganization" color=goldenrod]
    cFms -> PI3K_Akt [label="M-CSF/c-Fms\nactivates PI3K" color=goldenrod]

    // ==========================================================================
    // EDGES: OC DIFFERENTIATION
    // ==========================================================================
    NFATc1 -> Monocyte_prec [label="NFATc1 commits\nmonocytes to OC\nlineage" color=darkorange]
    Monocyte_prec -> OCpre_committed [label="M-CSF + RANKL\ndrive OC precursor\ncommitment" color=darkorange]
    MCSF -> Monocyte_prec [label="M-CSF supports\nprecursor survival\n+ proliferation" color=darkorange]
    OCpre_committed -> Multinucleated_OC [label="DCSTAMP-mediated\ncell fusion (RANKL\ndependent)" color=darkorange style=bold]
    NFATc1 -> DCSTAMP [label="NFATc1 drives\nDC-STAMP expression\n(fusion gene)" color=darkorange]
    NFATc1 -> CathepsinK [label="NFATc1 → CathK\ngene activation\n(resorption)" color=darkorange]
    NFATc1 -> TRAP [label="NFATc1 activates\nTRAP gene\n(OC marker)" color=darkorange]
    Multinucleated_OC -> OC_number_pagetic [label="Pagetic OC: 100+\nnuclei vs 3-5\nnormal" color=darkorange]
    Multinucleated_OC -> Integrin_avb3 [label="αvβ3 integrin\nattaches OC to\nRGD motifs" color=darkorange]
    Integrin_avb3 -> Src_kinase [label="Integrin → Src\nkinase activation\n(outside-in)" color=darkorange]
    Src_kinase -> RhoA_Rock [label="Src → RhoA\nactin cytoskeleton\nreorganization" color=darkorange]
    Multinucleated_OC -> Podosome_belt [label="Podosomes coalesce\ninto sealing zone\nring" color=darkorange]
    Multinucleated_OC -> Ezrin_Radixin_Moesin [label="ERM proteins\norganize ruffled\nborder" color=darkorange]

    // ==========================================================================
    // EDGES: RESORPTION MECHANISM
    // ==========================================================================
    Podosome_belt -> Sealing_zone [label="Belt matures\ninto tight sealing\nzone" color=deeppink]
    Sealing_zone -> Ruffled_border [label="Membrane domain\nwithin sealing zone" color=deeppink]
    Ruffled_border -> Resorption_lacuna [label="Creates acidic\ncompartment\n(pH ~4.5)" color=deeppink]
    vATPase -> H_secretion [label="V-ATPase pumps\nH+ into lacuna\n(ATP-dependent)" color=deeppink]
    Carbonic_anhydrase2 -> H_secretion [label="CA2: CO2+H2O →\nH2CO3 → H+ + HCO3-" color=deeppink]
    Chloride_channel -> Cl_secretion [label="ClC-7 secretes Cl-\n(HCl formed in\nlacuna)" color=deeppink]
    H_secretion -> Resorption_lacuna [label="Acidification\ndissolves HAP\nmineral" color=deeppink]
    Cl_secretion -> Resorption_lacuna [label="Cl- maintains\nelectroneutrality\nin lacuna" color=deeppink]
    CathepsinK -> Collagen_degradation [label="CathK degrades\ncollagen I at\nlow pH" color=deeppink style=bold]
    MMP9 -> Collagen_degradation [label="MMP9 degrades\ngelatin + collagen\n(neutral pH)" color=deeppink]
    Collagen_degradation -> DPD_release [label="Crosslink release\nfrom mature\ncollagen" color=deeppink]
    Collagen_degradation -> NTX_urine [label="N-telopeptide\nreleased → urine\nexcretion" color=deeppink]
    Collagen_degradation -> CTX_serum [label="C-telopeptide\nreleased → serum\nmeasurement" color=deeppink]
    Collagen_degradation -> Hydroxyproline [label="Hydroxyproline\nreleased → urinary\nexcretion" color=deeppink]
    Resorption_lacuna -> TGFb1_release [label="TGF-β1 liberated\nfrom bone matrix\n(acidic pH)" color=deeppink]
    Resorption_lacuna -> IGF1_release [label="IGF-1 liberated\nfrom bone matrix\n(coupling signal)" color=deeppink]
    OC_number_pagetic -> Resorption_rate_PBD [label="Increased OC #\n→ massively increased\nresorption rate" color=deeppink style=bold]
    Multinucleated_OC -> vATPase [label="OC expresses V-ATPase\n(a3 subunit; OC-specific)" color=deeppink]
    Multinucleated_OC -> Carbonic_anhydrase2 [label="CA2 expressed\nin mature OC" color=deeppink]
    Multinucleated_OC -> Chloride_channel [label="ClC-7 co-localizes\nwith V-ATPase" color=deeppink]
    Multinucleated_OC -> CathepsinK [label="CathK secreted\ninto ruffled\nborder" color=deeppink]
    Multinucleated_OC -> MMP9 [label="MMP9 secreted\nby pagetic OC" color=deeppink]

    // ==========================================================================
    // EDGES: COUPLING (RESORPTION → FORMATION)
    // ==========================================================================
    TGFb1_release -> OBpre_committed [label="TGF-β1 recruits\nOB precursors\n(chemotaxis)" color=teal]
    IGF1_release -> OB_mature [label="IGF-1 stimulates\nOB proliferation\n+ function" color=teal]
    TGFb1_release -> MSC_bone_marrow [label="TGF-β1 promotes\nMSC migration\nto resorption site" color=teal]

    // ==========================================================================
    // EDGES: OSTEOBLAST DIFFERENTIATION
    // ==========================================================================
    MSC_bone_marrow -> OBpre_committed [label="BMP/Wnt signals\ndirect MSC to\nOB lineage" color=mediumblue]
    OBpre_committed -> OB_mature [label="Runx2/Osterix\ndrive terminal\nOB differentiation" color=mediumblue]
    OB_mature -> Osteocyte [label="OB entombed\nin matrix →\nosteocyte" color=mediumblue]
    BMP2 -> Smad158 [label="BMP2 → BMPRI/II\n→ SMAD1/5/8\nactivation" color=mediumblue]
    BMP4 -> Smad158 [label="BMP4 activates\nSMAD pathway" color=mediumblue]
    BMP7 -> Smad158 [label="BMP7 → SMAD1/5/8\nphosphorylation" color=mediumblue]
    Smad158 -> Runx2_Cbfa1 [label="SMAD1/5/8 activate\nRunx2 transcription" color=mediumblue]
    Runx2_Cbfa1 -> Osterix [label="Runx2 activates\nOsterix (SP7)\ngene" color=mediumblue]
    Wnt_ligand -> Frizzled_LRP56 [label="Wnt binds Frizzled\n+ LRP5/6 coreceptor" color=mediumblue]
    Frizzled_LRP56 -> Bcatenin_nucl [label="Dishevelled →\nGSK3β inhibition\n→ β-cat stabilized" color=mediumblue]
    Bcatenin_nucl -> Runx2_Cbfa1 [label="β-catenin/TCF\ndrives Runx2\nexpression" color=mediumblue]
    Sclerostin -> Frizzled_LRP56 [label="Sclerostin blocks\nWnt/LRP5/6\nbinding" color=blue style=dashed arrowhead=tee]
    DKK1 -> Frizzled_LRP56 [label="DKK1 sequesters\nLRP5/6 (Wnt\nantagonist)" color=blue style=dashed arrowhead=tee]
    Activin_A -> Smad158 [label="Activin A/ACVR\n→ SMAD2/3 (OB\ninhibitory)" color=blue style=dashed arrowhead=tee]
    Osteocyte -> Sclerostin [label="Osteocyte secretes\nsclerostin (SOST\ngene)" color=mediumblue]
    Osterix -> OB_mature [label="Osterix essential\nfor mature OB\ndifferentiation" color=mediumblue]
    OB_mature -> RANKL [label="OB/stromal cells\npresent RANKL\nto OC" color=mediumblue]
    OB_mature -> OPG [label="OB secretes OPG\n(decoy receptor\nfor RANKL)" color=mediumblue]
    OB_mature -> MCSF [label="OB/stromal cells\nsecrete M-CSF\nfor OC support" color=mediumblue]
    OB_number_pagetic -> Formation_rate_PBD [label="Increased pagetic\nOB → high\nformation rate" color=teal]

    // ==========================================================================
    // EDGES: BONE FORMATION & MATRIX
    // ==========================================================================
    OB_mature -> CollagenI_synthesis [label="OB secretes\nCollagen I\n(osteoid matrix)" color=teal]
    OB_mature -> Osteocalcin [label="OB secretes\nosteocalcin\n(Gla protein)" color=teal]
    OB_mature -> Osteopontin [label="OB secretes\nosteopontin\n(OB/OC binding)" color=teal]
    OB_mature -> Bone_sialoprotein [label="OB secretes BSP\n(HAP nucleation)" color=teal]
    OB_mature -> bsALP_enzyme [label="OB expresses\nbone-specific\nALP enzyme" color=teal]
    bsALP_enzyme -> Mineralization [label="ALP cleaves PPi\n(inhibitor) → Pi\navailable for HAP" color=teal]
    CollagenI_synthesis -> Mineralization [label="Osteoid matrix\ncollagen scaffold\nfor mineralization" color=teal]
    Bone_sialoprotein -> Mineralization [label="BSP nucleates\nhydroxyapatite\ncrystals" color=teal]
    Mineralization -> Woven_bone_PBD [label="Disordered rapid\nmineralization →\nwoven bone" color=teal]
    Mineralization -> Lamellar_bone_normal [label="Organized slow\nmineralization →\nlamellar bone" color=teal]
    Woven_bone_PBD -> Mosaic_bone_pattern [label="Alternating woven\n+ lamellar:\nPBD hallmark" color=teal style=bold]
    Mosaic_bone_pattern -> Cement_lines [label="Irregular reversal\nlines = cement\nlines in PBD" color=teal]
    Formation_rate_PBD -> PICP_serum [label="High collagen\nsynthesis → elevated\nPICP marker" color=teal]
    OB_number_pagetic -> bsALP_serum [label="Abundant OB\n→ high serum\nbsALP output" color=teal]

    // ==========================================================================
    // EDGES: BIOMARKERS ← BIOLOGICAL PROCESSES
    // ==========================================================================
    bsALP_enzyme -> bsALP_serum [label="Bone ALP released\ninto circulation" color=grey40]
    bsALP_serum -> TotalALP_serum [label="bsALP comprises\n~95% of total\nALP in PBD" color=grey40]
    NTX_urine -> NTX_measure [label="Urinary NTX\n(clinical assay)" color=grey40]
    CTX_serum -> CTX_measure [label="Serum β-CTX\n(Roche Elecsys)" color=grey40]
    Osteocalcin -> Osteocalcin_serum [label="Serum osteocalcin\n(formation marker)" color=grey40]
    CollagenI_synthesis -> P1NP_serum [label="P1NP released\nfrom procollagen\nprocessing" color=grey40]
    PICP_serum -> P1NP_serum [label="Propeptide markers\nof bone collagen\nsynthesis" color=grey40]
    Serum_Ca -> PTH_serum [label="Ca2+ regulates\nPTH secretion\n(negative feedback)" color=grey40 style=dashed]
    PTH_serum -> Vit_D_125OH2D3 [label="PTH stimulates\n1α-hydroxylase\n→ calcitriol" color=grey40]
    IL6_pagetic -> CRP_inflammation [label="IL-6 drives\nhepatic CRP\nproduction" color=grey40]
    Resorption_lacuna -> Serum_Ca [label="Massive resorption\n→ Ca release\n(hypercalcemia risk)" color=grey40]

    // ==========================================================================
    // EDGES: CLINICAL MANIFESTATIONS
    // ==========================================================================
    Woven_bone_PBD -> Bone_pain_VAS [label="Pagetic bone:\nperiostal stretch,\nvascularity → pain" color=purple]
    Mosaic_bone_pattern -> Bone_deformity [label="Abnormal bone\narchitecture →\ndeformity" color=purple]
    Bone_deformity -> Bowing_tibia [label="Tibia affected:\nlateral bowing\n(weight bearing)" color=purple]
    Woven_bone_PBD -> Skull_enlargement [label="Skull (calvaria)\npagetic expansion\n→ hat size ↑" color=purple]
    Mosaic_bone_pattern -> Pathological_fracture [label="Chalk-stick fracture:\nlateral tibia/femur" color=purple]
    Skull_enlargement -> Hearing_loss_CN8 [label="Cochlear/ossicle\npagetic involvement\n→ CN VIII compress" color=purple]
    Woven_bone_PBD -> Spinal_stenosis [label="Vertebral pagetic\nexpansion → canal\nnarrowing" color=purple]
    AV_shunting -> High_output_cardiac [label="Extensive AV\nshunts → cardiac\noutput ↑" color=purple]
    High_output_cardiac -> HO_cardiac_failure [label="Severe AV shunting\n→ cardiac\ndecompensation" color=purple]
    Mosaic_bone_pattern -> Osteosarcoma_risk [label="Malignant transform\n(<1% of PBD;\npoor prognosis)" color=purple style=bold]
    Skull_enlargement -> Cranial_nerve_compress [label="Foraminal stenosis\n→ CN compression\n(II,V,VII,VIII)" color=purple]
    Spinal_stenosis -> Vertebral_collapse [label="Ivory vertebra\n→ compression\nfracture" color=purple]
    Woven_bone_PBD -> Osteoarthritis_secondary [label="Altered biomechanics\n→ adjacent joint\nOA" color=purple]
    Bone_marrow_fibrosis -> Bone_pain_VAS [label="Peritrabecular\nfibrosis contributes\nto pain" color=purple]

    // ==========================================================================
    // EDGES: SYSTEMIC/VASCULAR
    // ==========================================================================
    Woven_bone_PBD -> VEGF_pagetic [label="Pagetic bone\nsecretes VEGF\n(hypervascular)" color=darkviolet]
    VEGF_pagetic -> AV_shunting [label="VEGF promotes\nAV anastomosis\nin pagetic bone" color=darkviolet]
    AV_shunting -> Focal_hyperemia [label="Local blood flow\nmarkedly increased\n→ warmth" color=darkviolet]
    AV_shunting -> Cardiac_output_incr [label="Systemic AV shunt\n→ ↑ preload\n→ ↑ CO" color=darkviolet]
    Cardiac_output_incr -> HO_cardiac_failure [label="Sustained high CO\n→ cardiac failure\nin severe PBD" color=darkviolet]
    Resorption_lacuna -> Hypercalcemia_immob [label="Immobilization:\nresorption without\nformation → hypercalc" color=darkviolet]
    IL6_pagetic -> RANKL [label="IL-6 upregulates\nRANKL on\nstromal cells" color=darkviolet]
    IL1b_pagetic -> NFkB_pathway [label="IL-1β activates\nNF-κB in OC\nprecursors" color=darkviolet]
    TNFa_pagetic -> NFkB_pathway [label="TNF-α activates\nNF-κB independently\nof RANKL" color=darkviolet]
    Woven_bone_PBD -> Bone_marrow_fibrosis [label="Pagetic turnover\n→ peritrabecular\nfibrosis" color=darkviolet]
    Focal_hyperemia -> Neurological_complic [label="Vascular steal\n→ cord ischemia\nin PBD" color=darkviolet]

    // ==========================================================================
    // EDGES: BISPHOSPHONATE PK/PD
    // ==========================================================================
    ZA_IV_admin -> ZA_central_cmt [label="Rapid IV infusion\n(15 min); 5 mg\nonce" color=darkgreen]
    ZA_central_cmt -> ZA_peripheral_cmt [label="Distributive t½α\n~0.23h (2-cmt\nPK model)" color=darkgreen]
    ZA_central_cmt -> ZA_bone_bound [label="~50% of dose\nbinds to HAP\n(high affinity)" color=darkgreen style=bold]
    ZA_bone_bound -> FPPS_enzyme [label="ZA released during\nresorption → FPPS\ninhibition" color=darkgreen]
    Alendronate_oral -> Alendronate_absorb [label="~0.7% GI absorption\n(take fasting;\nwater only)" color=darkgreen]
    Alendronate_absorb -> Alendronate_bone [label="~50% of absorbed\ndose to bone;\nremainder excreted" color=darkgreen]
    Alendronate_bone -> FPPS_enzyme [label="Alendronate\ninhibits FPPS\n(N-BP class)" color=darkgreen]
    Risedronate_oral -> Alendronate_bone [label="Similar mechanism\nto alendronate;\nalternative BP" color=darkgreen style=dashed]
    Pamidronate_IV -> ZA_bone_bound [label="Older N-BP;\nsimilar bone\nbinding mechanism" color=darkgreen style=dashed]
    FPPS_enzyme -> Farnesyl_PP [label="FPPS catalyzes\nIPP+GPP → FPP\n(inhibited by N-BP)" color=darkgreen]
    FPPS_enzyme -> Geranyl_PP [label="FPPS uses GPP\nas substrate" color=darkgreen]
    Mevalonate_pathway -> Geranyl_PP [label="MVA pathway:\nHMG-CoA →\nGPP" color=darkgreen]
    Geranyl_PP -> Farnesyl_PP [label="GPP → FPP:\nFPPS-catalyzed\n(BP target step)" color=darkgreen]
    Farnesyl_PP -> Prenylation_block [label="N-BP depletes\nFPP → blocks\nprenylation" color=darkgreen]
    Prenylation_block -> Rab_GTPase_inhib [label="Rab proteins not\ngeranylgeranylated\n→ inactive" color=darkgreen]
    Rab_GTPase_inhib -> OC_apoptosis_BP [label="Disrupted vesicular\ntrafficking → OC\napoptosis" color=darkgreen style=bold]
    OC_apoptosis_BP -> OC_number_pagetic [label="BP-induced OC\napoptosis reduces\npagetic OC #" color=darkgreen style=bold arrowhead=tee]
    OC_apoptosis_BP -> Resorption_rate_PBD [label="Fewer OC →\ndramatically reduced\nresorption rate" color=darkgreen style=bold arrowhead=tee]

    // ==========================================================================
    // EDGES: CALCITONIN PK/PD
    // ==========================================================================
    Calcitonin_SC -> CTN_plasma [label="SC/IM injection;\nt½ ~1h; rapid\npeak then decline" color=forestgreen]
    CTN_plasma -> CALCR_receptor [label="Calcitonin binds\nCALCR on OC\nmembrane" color=forestgreen]
    CALCR_receptor -> Gs_protein [label="CALCR-Gs coupling\n(class B GPCR)" color=forestgreen]
    Gs_protein -> cAMP_PKA [label="Gs → adenylyl\ncyclase → cAMP\n→ PKA" color=forestgreen]
    cAMP_PKA -> OC_inhibition_CTN [label="PKA disrupts OC\ncytoskeleton;\nrapid quiescence" color=forestgreen]
    CALCR_receptor -> CALCR_downreg [label="Prolonged stimulation\n→ receptor\ninternalization" color=forestgreen]
    CALCR_downreg -> OC_inhibition_CTN [label="Receptor downreg\n→ escape phenomenon\n(days-weeks)" color=forestgreen style=dashed arrowhead=tee]
    OC_inhibition_CTN -> Resorption_rate_PBD [label="Calcitonin transiently\nreduces resorption\n(escape limits efficacy)" color=forestgreen arrowhead=tee]
    CTN_plasma -> CTN_renal_effect [label="Calcitonin reduces\nrenal Ca/P\nreabsorption" color=forestgreen]
    CTN_renal_effect -> Serum_Ca [label="Renal effect lowers\nserum calcium\n(minor contribution)" color=forestgreen arrowhead=tee]

    // ==========================================================================
    // EDGES: DENOSUMAB PK/PD
    // ==========================================================================
    Denosumab_SC -> DMB_central_cmt [label="SC injection;\nbioavailability ~62%;\nt½ ~28 days" color=steelblue]
    DMB_central_cmt -> DMB_peripheral_cmt [label="2-compartment\ndistribution;\nslow equilibrium" color=steelblue]
    DMB_central_cmt -> FcRn_recycling [label="IgG2 mAb; FcRn\nrecycling extends\nhalf-life" color=steelblue]
    DMB_central_cmt -> RANKL_binding [label="Denosumab binds\nRANKL (Kd ~3 pM;\nvery high affinity)" color=steelblue style=bold]
    RANKL_binding -> RANKL_neutralization [label="Full RANKL\nneutralization at\ntherapeutic dose" color=steelblue]
    RANKL_neutralization -> RANK_receptor [label="No free RANKL\n→ RANK not\nactivated" color=steelblue arrowhead=tee]
    RANKL_neutralization -> OC_formation_block [label="OC differentiation\narrested without\nRANKL signal" color=steelblue style=bold]
    OC_formation_block -> OC_number_pagetic [label="Denosumab prevents\nnew OC →\nOC # declines" color=steelblue arrowhead=tee]
    OC_formation_block -> Resorption_rate_PBD [label="Fewer OC →\nmarked resorption\nreduction" color=steelblue arrowhead=tee]
    Rebound_effect_DMB -> RANKL [label="After cessation:\nRANKL surge →\nrebound OC burst" color=steelblue style=dashed]

    // ==========================================================================
    // EDGES: TREATMENT EFFECTS ON BIOMARKERS
    // ==========================================================================
    OC_apoptosis_BP -> TotalALP_serum [label="BP Rx: ALP falls\n50-90% within\n3-6 months" color=darkgreen arrowhead=tee style=bold]
    OC_apoptosis_BP -> NTX_measure [label="BP Rx: NTX falls\nrapidly (within\nweeks)" color=darkgreen arrowhead=tee]
    OC_apoptosis_BP -> CTX_measure [label="BP Rx: CTX\nnormalizes within\n3 months" color=darkgreen arrowhead=tee]
    OC_inhibition_CTN -> TotalALP_serum [label="CTN Rx: ALP falls\nmodestly (20-50%;\nescape limits)" color=forestgreen arrowhead=tee style=dashed]
    OC_formation_block -> TotalALP_serum [label="Denosumab: ALP\nfalls significantly\n(>50%)" color=steelblue arrowhead=tee]

    // ==========================================================================
    // EDGES: BIOMARKERS → CLINICAL
    // ==========================================================================
    TotalALP_serum -> Bone_pain_VAS [label="High ALP correlates\nwith disease\nactivity/pain" color=grey40 style=dashed]
    TotalALP_serum -> Osteosarcoma_risk [label="Very high ALP\nmay signal\nmalignant transform" color=grey40 style=dashed]
    CTX_measure -> Resorption_rate_PBD [label="CTX reflects\nresorption rate\n(monitoring)" color=grey40 style=dashed]

    // ==========================================================================
    // ADDITIONAL CROSS-PATHWAY EDGES
    // ==========================================================================
    IL6_pagetic -> OBpre_committed [label="IL-6 activates\nSTAT3 in OB\n(paradoxical stim)" color=darkviolet style=dashed]
    TNFa_pagetic -> RANKL [label="TNF-α upregulates\nRANKL on OB/\nstromal cells" color=darkviolet]
    Hypercalcemia_immob -> PTH_serum [label="Hypercalcemia\nsuppresses PTH\n(negative feedback)" color=darkviolet arrowhead=tee]
    Vit_D_125OH2D3 -> Serum_Ca [label="Calcitriol increases\nintestinal Ca\nabsorption" color=grey40]
    Vit_D_125OH2D3 -> OB_mature [label="1,25-D3 supports\nOB differentiation\n(VDR)" color=grey40]
    Osteocyte -> DKK1 [label="Osteocyte-derived\nDKK1 regulates\nWnt signaling" color=mediumblue]
    ZA_IV_admin -> Osteosarcoma_risk [label="Zoledronic acid\ndoes NOT reduce\nosteosarcoma risk" color=darkgreen style=dashed arrowhead=none]
    Pathological_fracture -> Bone_pain_VAS [label="Fracture: acute\npain exacerbation" color=purple]
    Bowing_tibia -> Osteoarthritis_secondary [label="Bowing alters\nknee biomechanics\n→ OA" color=purple]
}
