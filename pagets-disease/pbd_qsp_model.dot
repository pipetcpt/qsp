digraph PagetsBoneDisease_QSP {

    graph [
        label="Paget's Disease of Bone — QSP Mechanistic Map\n파젯병 정량적 시스템 약리학 기계론적 지도",
        labelloc=t, labeljust=c,
        fontsize=22, fontname="Helvetica-Bold",
        bgcolor="#F8F9FA",
        rankdir=TB,
        splines=ortho,
        compound=true,
        nodesep=0.35,
        ranksep=0.55,
        pad=0.5
    ];
    node [shape=box, style="filled,rounded", fontsize=9, fontname="Helvetica", margin="0.08,0.04"];
    edge [fontsize=8, fontname="Helvetica", arrowsize=0.7];

    /* ================================================================
       CLUSTER 1: VIRAL & GENETIC TRIGGERS
    ================================================================ */
    subgraph cluster_triggers {
        label="Viral & Genetic Triggers\n바이러스 및 유전적 유발 요인";
        style=filled; fillcolor="#FFF0E6"; color="#D4570A"; penwidth=2.0;
        fontname="Helvetica-Bold"; fontsize=11;

        MeaslesVirus   [label="Measles Virus\n홍역 바이러스", fillcolor="#FF7043", fontcolor=white];
        CDV            [label="Canine Distemper\nVirus (CDV)", fillcolor="#FF7043", fontcolor=white];
        RSV            [label="Respiratory Syncytial\nVirus (RSV)", fillcolor="#FF7043", fontcolor=white];
        NucleocapsidProtein [label="Paramyxovirus\nNucleocapsid Protein", fillcolor="#FFAB40"];
        InclusionBodies [label="Nuclear Inclusion\nBodies in OC", fillcolor="#FFAB40"];
        SQSTM1         [label="SQSTM1/p62\nMutation", fillcolor="#FFA726"];
        VCP            [label="VCP/p97\nMutation", fillcolor="#FFA726"];
        RANK_gene      [label="TNFRSF11A\n(RANK gene) Mutation", fillcolor="#FFA726"];
        OPG_gene       [label="TNFRSF11B\n(OPG gene) Mutation", fillcolor="#FFA726"];
        CSF1R_gene     [label="CSF1R\nPolymorphism", fillcolor="#FFA726"];
        FamPDB         [label="Familial PDB\n(autosomal dominant)", fillcolor="#FFD180"];
        SporadicPDB    [label="Sporadic PDB\n(>85% of cases)", fillcolor="#FFD180"];
        EpigeneticMod  [label="Epigenetic\nModification", fillcolor="#FFD180"];
        EnvFactors     [label="Environmental\nFactors", fillcolor="#FFD180"];
    }

    /* ================================================================
       CLUSTER 2: BONE MARROW MICROENVIRONMENT
    ================================================================ */
    subgraph cluster_microenvironment {
        label="Bone Marrow Microenvironment\n골수 미세환경";
        style=filled; fillcolor="#E8F5E9"; color="#2E7D32"; penwidth=2.0;
        fontname="Helvetica-Bold"; fontsize=11;

        BoneMarrow     [label="Bone Marrow\n골수", fillcolor="#66BB6A", fontcolor=white];
        Stroma         [label="Stromal Cells\n기질세포", fillcolor="#81C784"];
        MSC            [label="Mesenchymal Stem\nCells (MSC)", fillcolor="#81C784"];
        Monocyte       [label="Monocyte /\nMacrophage", fillcolor="#A5D6A7"];
        OCP            [label="Osteoclast\nPrecursor (OCP)", fillcolor="#A5D6A7"];
        Tcell          [label="T Lymphocytes\n(activated)", fillcolor="#A5D6A7"];
        MCSF           [label="M-CSF\n(CSF1)", fillcolor="#C8E6C9"];
        cFms           [label="c-Fms\n(CSF1R) receptor", fillcolor="#C8E6C9"];
        VEGF           [label="VEGF\nVascularity↑", fillcolor="#C8E6C9"];
        PageticVascularity [label="Pagetic Lesion\nHypervascularization", fillcolor="#E8F5E9"];
    }

    /* ================================================================
       CLUSTER 3: RANKL / OPG / RANK AXIS
    ================================================================ */
    subgraph cluster_rankl_axis {
        label="RANKL / OPG / RANK Signaling Axis\nRANKL-OPG-RANK 신호 축";
        style=filled; fillcolor="#FFF3E0"; color="#E65100"; penwidth=2.0;
        fontname="Helvetica-Bold"; fontsize=11;

        RANKL_memb     [label="Membrane-bound\nRANKL (TNFSF11)", fillcolor="#FF6F00", fontcolor=white];
        RANKL_sol      [label="Soluble RANKL\n(sRANKL)", fillcolor="#FF8F00", fontcolor=white];
        OPG            [label="Osteoprotegerin\n(OPG, TNFRSF11B)", fillcolor="#1565C0", fontcolor=white];
        RANK_receptor  [label="RANK Receptor\n(TNFRSF11A)", fillcolor="#FF6F00", fontcolor=white];
        RANKL_OPG_ratio [label="RANKL / OPG\nRatio ↑↑ in PBD", fillcolor="#FF8F00"];
        OB_RANKL       [label="Osteoblast-derived\nRANKL", fillcolor="#FFA000"];
        TC_RANKL       [label="T cell-derived\nRANKL", fillcolor="#FFA000"];
        PTH_eff        [label="PTH / PTHrP\n→ RANKL↑, OPG↓", fillcolor="#FFA000"];
        IL6_RANKL      [label="IL-6 →\nRANKL↑", fillcolor="#FFA000"];
        TNFa_RANKL     [label="TNF-α →\nRANKL↑", fillcolor="#FFA000"];
        RANK_RANKL_cpx [label="RANK–RANKL\nComplex", fillcolor="#FF8F00"];
    }

    /* ================================================================
       CLUSTER 4: OSTEOCLAST INTRACELLULAR SIGNALING
    ================================================================ */
    subgraph cluster_oc_signaling {
        label="Osteoclast Intracellular Signaling\n파골세포 세포내 신호전달";
        style=filled; fillcolor="#FCE4EC"; color="#880E4F"; penwidth=2.0;
        fontname="Helvetica-Bold"; fontsize=11;

        TRAF6          [label="TRAF6\nadapter protein", fillcolor="#AD1457", fontcolor=white];
        IKK_complex    [label="IKK Complex\n(IKKα/β/γ)", fillcolor="#C2185B", fontcolor=white];
        IkBa           [label="IκBα\nDegradation", fillcolor="#D81B60", fontcolor=white];
        NFkB_nuclear   [label="NF-κB\n(Nuclear activation)", fillcolor="#E91E63", fontcolor=white];
        NFATc1         [label="NFATc1\n(Master OC regulator)", fillcolor="#E91E63", fontcolor=white];
        cFos           [label="c-Fos\ntranscription factor", fillcolor="#F06292"];
        AP1            [label="AP-1\n(c-Fos/c-Jun)", fillcolor="#F06292"];
        MAPK_ERK       [label="MAPK / ERK\npathway", fillcolor="#F48FB1"];
        PI3K_Akt       [label="PI3K / Akt\nsurvival pathway", fillcolor="#F48FB1"];
        PLCg           [label="PLCγ → IP3/DAG\nCa²⁺ mobilization", fillcolor="#F48FB1"];
        CaN_NFAT       [label="Calcineurin /\nNFAT dephosphorylation", fillcolor="#F48FB1"];
        p62_NF         [label="p62/SQSTM1\nNF-κB scaffold (mutant)", fillcolor="#F8BBD9"];
        DC_STAMP       [label="DC-STAMP\ncell fusion", fillcolor="#F8BBD9"];
        OC_STAMP       [label="OC-STAMP\ncell fusion", fillcolor="#F8BBD9"];
    }

    /* ================================================================
       CLUSTER 5: OSTEOCLAST BIOLOGY
    ================================================================ */
    subgraph cluster_osteoclasts {
        label="Osteoclast Biology\n파골세포 생물학";
        style=filled; fillcolor="#EDE7F6"; color="#4527A0"; penwidth=2.0;
        fontname="Helvetica-Bold"; fontsize=11;

        PreOC          [label="Pre-Osteoclast\n파골세포 전구체", fillcolor="#7B1FA2", fontcolor=white];
        MatureOC       [label="Mature Osteoclast\n성숙 파골세포", fillcolor="#6A1B9A", fontcolor=white];
        GiantOC        [label="Giant Osteoclast\n(Pagetic, 100+ nuclei)", fillcolor="#4A148C", fontcolor=white];
        ActiveOC       [label="Actively Resorbing\nOsteoclast", fillcolor="#7E57C2", fontcolor=white];
        OC_Apoptosis   [label="Osteoclast\nApoptosis", fillcolor="#9575CD"];
        IntegrinAvb3   [label="Integrin αvβ3\nBone attachment", fillcolor="#B39DDB"];
        ActinRing      [label="Actin Ring /\nSealing Zone", fillcolor="#B39DDB"];
        RhoA           [label="RhoA GTPase\nCytoskeleton", fillcolor="#B39DDB"];
        Rac1           [label="Rac1 GTPase\nlamellipodia", fillcolor="#B39DDB"];
    }

    /* ================================================================
       CLUSTER 6: BONE RESORPTION
    ================================================================ */
    subgraph cluster_resorption {
        label="Bone Resorption Machinery\n골흡수 기전";
        style=filled; fillcolor="#FFF8E1"; color="#F57F17"; penwidth=2.0;
        fontname="Helvetica-Bold"; fontsize=11;

        CathepsinK     [label="Cathepsin K\nCollagen degradation", fillcolor="#F9A825", fontcolor=white];
        MMP9           [label="MMP-9\nMatrix metalloproteinase", fillcolor="#F9A825", fontcolor=white];
        TRAP           [label="TRAP (TRAcP 5b)\nTartrate-Resistant AcP", fillcolor="#F57F17", fontcolor=white];
        HCl_secretion  [label="H⁺-ATPase\nAcid secretion (pH<4)", fillcolor="#FF8F00", fontcolor=white];
        ResorpLacuna   [label="Resorption\nLacuna", fillcolor="#FFB300"];
        HydroxyAP_resorp [label="Hydroxyapatite\nDissolution", fillcolor="#FFB300"];
        CollagenDegr   [label="Type I Collagen\nDegradation (PICP,PINP)", fillcolor="#FFB300"];
        CTx_release    [label="CTx (CrossLaps)\nC-terminal telopeptide", fillcolor="#FFC107"];
        NTx_release    [label="NTx (Osteomark)\nN-terminal telopeptide", fillcolor="#FFC107"];
        DPD_release    [label="DPD\n(Deoxypyridinoline)", fillcolor="#FFC107"];
        TRAP5b_serum   [label="TRAP5b\n(serum)", fillcolor="#FFCA28"];
    }

    /* ================================================================
       CLUSTER 7: COUPLING SIGNALS
    ================================================================ */
    subgraph cluster_coupling {
        label="OC→OB Coupling Signals\n파골-조골세포 연결 신호";
        style=filled; fillcolor="#E3F2FD"; color="#0D47A1"; penwidth=2.0;
        fontname="Helvetica-Bold"; fontsize=11;

        TGFb1_rel      [label="TGF-β1\n(from bone matrix)", fillcolor="#1565C0", fontcolor=white];
        IGF1_rel       [label="IGF-1 / IGF-2\n(from bone matrix)", fillcolor="#1565C0", fontcolor=white];
        BMP2_4         [label="BMP-2 / BMP-4\nOsteogenic factor", fillcolor="#1976D2", fontcolor=white];
        EphrinB2       [label="Ephrin-B2 / EphB4\nOC→OB contact", fillcolor="#1976D2", fontcolor=white];
        Wnt_coupling   [label="Wnt Ligands\n(OC-derived)", fillcolor="#1E88E5"];
        S1P_coupling   [label="Sphingosine-1-P\n(S1P) signaling", fillcolor="#42A5F5"];
        FGF23          [label="FGF-23 / FGF\nFibroblast GF", fillcolor="#42A5F5"];
        PDGF           [label="PDGF\nPlatelet-derived GF", fillcolor="#90CAF9"];
    }

    /* ================================================================
       CLUSTER 8: OSTEOBLAST SIGNALING (WNT / BMP)
    ================================================================ */
    subgraph cluster_ob_signaling {
        label="Osteoblast Signaling — Wnt / BMP\n조골세포 신호전달 경로";
        style=filled; fillcolor="#E8EAF6"; color="#283593"; penwidth=2.0;
        fontname="Helvetica-Bold"; fontsize=11;

        Wnt3a          [label="Wnt-3a / Wnt-10b\ncanonical ligand", fillcolor="#303F9F", fontcolor=white];
        Frizzled       [label="Frizzled / LRP5/6\nWnt receptor complex", fillcolor="#3949AB", fontcolor=white];
        BetaCatenin    [label="β-catenin\nnuclear signaling", fillcolor="#3F51B5", fontcolor=white];
        GSK3b          [label="GSK-3β\nβ-catenin phosphorylation", fillcolor="#5C6BC0"];
        Sclerostin     [label="Sclerostin (SOST)\nWnt inhibitor ↓ in PBD", fillcolor="#7986CB"];
        DKK1           [label="DKK-1\nWnt antagonist", fillcolor="#7986CB"];
        Axin2          [label="Axin2\ndestruction complex", fillcolor="#9FA8DA"];
        BMP_recept     [label="BMPR-I / BMPR-II\nBMP receptor", fillcolor="#303F9F", fontcolor=white];
        Smad1_5_8      [label="Smad 1/5/8\nBMP effectors", fillcolor="#3949AB", fontcolor=white];
        Runx2          [label="Runx2\n(master OB TF)", fillcolor="#3F51B5", fontcolor=white];
        Osterix        [label="Osterix (SP7)\nosteoblast commitment", fillcolor="#5C6BC0"];
        ATF4           [label="ATF4\nOsteocalcin regulation", fillcolor="#7986CB"];
    }

    /* ================================================================
       CLUSTER 9: OSTEOBLAST BIOLOGY & BONE FORMATION
    ================================================================ */
    subgraph cluster_osteoblasts {
        label="Osteoblast Biology & Bone Formation\n조골세포 및 골형성";
        style=filled; fillcolor="#E0F7FA"; color="#006064"; penwidth=2.0;
        fontname="Helvetica-Bold"; fontsize=11;

        OBP            [label="Osteoblast\nPrecursor (OBP)", fillcolor="#00838F", fontcolor=white];
        PreOB          [label="Pre-Osteoblast\n조골세포 전구체", fillcolor="#00838F", fontcolor=white];
        ActiveOB       [label="Active Osteoblast\n활성 조골세포", fillcolor="#00695C", fontcolor=white];
        LiningCell     [label="Bone Lining\nCell", fillcolor="#00897B", fontcolor=white];
        Osteocyte      [label="Osteocyte\n골세포", fillcolor="#00796B", fontcolor=white];
        OB_Apoptosis   [label="Osteoblast\nApoptosis", fillcolor="#4DB6AC"];
        Mineralization [label="Matrix\nMineralization", fillcolor="#4DD0E1"];
        BALP_prod      [label="Bone ALP\n(BALP) production", fillcolor="#80DEEA"];
        P1NP_prod      [label="P1NP\n(procollagen)", fillcolor="#80DEEA"];
        Osteocalcin_pr [label="Osteocalcin\n(OCN/BGP)", fillcolor="#80DEEA"];
        CollagenI_form [label="Type I Collagen\nSynthesis", fillcolor="#B2EBF2"];
    }

    /* ================================================================
       CLUSTER 10: BONE QUALITY & LESION
    ================================================================ */
    subgraph cluster_bone_quality {
        label="Bone Quality & Pagetic Lesion\n골 품질 및 파젯 병변";
        style=filled; fillcolor="#F1F8E9"; color="#33691E"; penwidth=2.0;
        fontname="Helvetica-Bold"; fontsize=11;

        PageticLesion  [label="Pagetic Lesion\n파젯 병변", fillcolor="#558B2F", fontcolor=white];
        WovenBone      [label="Woven Bone\n(disorganized)", fillcolor="#689F38", fontcolor=white];
        LamellarBone   [label="Lamellar Bone\n(normal structure)", fillcolor="#7CB342"];
        MosaicPattern  [label="Mosaic (Cement Line)\nPattern", fillcolor="#8BC34A"];
        BoneVolume     [label="Bone Volume\n(pagetic site ↑)", fillcolor="#9CCC65"];
        BMD_pagetic    [label="BMD — Pagetic\nSite", fillcolor="#AED581"];
        CorticalThick  [label="Cortical Thickness\n(cortical thickening)", fillcolor="#C5E1A5"];
        BoneTurnoverAll [label="Overall Bone\nTurnover Rate", fillcolor="#DCEDC8"];
        BoneStiffness  [label="Bone Mechanical\nStiffness", fillcolor="#DCEDC8"];
    }

    /* ================================================================
       CLUSTER 11: DRUG PK — BISPHOSPHONATES & DENOSUMAB
    ================================================================ */
    subgraph cluster_drug_pk {
        label="Drug PK — Bisphosphonates & Denosumab\n약물 약동학";
        style=filled; fillcolor="#F3E5F5"; color="#6A1B9A"; penwidth=2.0;
        fontname="Helvetica-Bold"; fontsize=11;

        Zoledronate    [label="Zoledronate\n(IV 5 mg/yr)\nHigh bone affinity", fillcolor="#7B1FA2", fontcolor=white];
        Pamidronate    [label="Pamidronate\n(IV 60-90 mg)\nModerate affinity", fillcolor="#7B1FA2", fontcolor=white];
        Alendronate    [label="Alendronate\n(PO 70 mg/wk)\nF~0.6%", fillcolor="#7B1FA2", fontcolor=white];
        Risedronate    [label="Risedronate\n(PO 30 mg/d×2mo)", fillcolor="#8E24AA"];
        Denosumab      [label="Denosumab\n(SC 60 mg Q6M)\nAnti-RANKL mAb", fillcolor="#AB47BC"];
        DrugPlasma     [label="Drug Plasma\nConcentration (C1)", fillcolor="#BA68C8"];
        DrugPeripheral [label="Drug Peripheral\nCompartment (C2)", fillcolor="#CE93D8"];
        DrugBoneBound  [label="Drug Bone-Bound\n(Hydroxyapatite)", fillcolor="#BA68C8"];
        OralAbsorption [label="Oral Absorption\n(Ka, F~0.006)", fillcolor="#E1BEE7"];
        IVInfusion     [label="IV Infusion\n(rate: mg/h)", fillcolor="#E1BEE7"];
        DrugReleaseOC  [label="Drug Release\n(OC resorption)", fillcolor="#CE93D8"];
        DenAbsorption  [label="Denosumab SC\nAbsorption depot", fillcolor="#E1BEE7"];
        DenPlasma      [label="Denosumab\nPlasma (Ab)", fillcolor="#BA68C8"];
        DenRANKL_cpx   [label="Den–RANKL\nComplex", fillcolor="#CE93D8"];
    }

    /* ================================================================
       CLUSTER 12: DRUG PD — MECHANISMS
    ================================================================ */
    subgraph cluster_drug_pd {
        label="Drug PD — Mechanisms of Action\n약물 약력학 기전";
        style=filled; fillcolor="#FFF9C4"; color="#F57F17"; penwidth=2.0;
        fontname="Helvetica-Bold"; fontsize=11;

        MevalonateP    [label="Mevalonate\nPathway (HMG-CoA)", fillcolor="#F9A825", fontcolor=white];
        FPP_synth      [label="FPP Synthase\n(Bisphosphonate target)", fillcolor="#F57F17", fontcolor=white];
        Farnesyl_PP    [label="Farnesyl-PP\n(FPP)", fillcolor="#FF8F00"];
        GGPP_synth     [label="GGPP Synthase\n→ geranylgeranyl-PP", fillcolor="#FF8F00"];
        RabGTPase_pren [label="Rab GTPase\nPrenylation (impaired)", fillcolor="#FFA000"];
        RhoA_pren      [label="RhoA / Rac\nPrenylation (impaired)", fillcolor="#FFA000"];
        Cytoskel_disrupt [label="Cytoskeletal\nDisruption → OC↓", fillcolor="#FFC107"];
        OC_Apoptosis2  [label="Enhanced OC\nApoptosis (BPs)", fillcolor="#FFD54F"];
        RANKL_neutral  [label="RANKL Neutralization\n(Denosumab)", fillcolor="#FFECB3"];
        OC_Suppress    [label="Osteoclast\nSuppression", fillcolor="#FFE082"];
        BoneMarkerNorm [label="Bone Marker\nNormalization (ALP↓)", fillcolor="#FFEE58"];
    }

    /* ================================================================
       CLUSTER 13: BIOMARKERS
    ================================================================ */
    subgraph cluster_biomarkers {
        label="Biomarkers — Serum & Urine\n혈중·요중 바이오마커";
        style=filled; fillcolor="#E8F4FD"; color="#1565C0"; penwidth=2.0;
        fontname="Helvetica-Bold"; fontsize=11;

        sALP           [label="Serum Total ALP\n(↑↑ most sensitive)", fillcolor="#1565C0", fontcolor=white];
        BALP           [label="Bone ALP (BALP)\n(more specific)", fillcolor="#1976D2", fontcolor=white];
        sP1NP          [label="Serum P1NP\n(formation marker)", fillcolor="#1E88E5"];
        sCTx           [label="Serum CTx\n(resorption marker)", fillcolor="#1E88E5"];
        uNTx           [label="Urinary NTx\n(resorption marker)", fillcolor="#42A5F5"];
        uDPD           [label="Urinary DPD\n(crosslinks)", fillcolor="#42A5F5"];
        sTRAP5b        [label="Serum TRAP5b\n(OC activity)", fillcolor="#64B5F6"];
        sOsteocalcin   [label="Serum Osteocalcin\n(formation)", fillcolor="#64B5F6"];
        sCa_Phosphate  [label="Serum Ca / PO₄\n(usually normal in PBD)", fillcolor="#90CAF9"];
        sPTH           [label="Serum PTH\n(elevated if hypoCa)", fillcolor="#90CAF9"];
        sIL6           [label="Serum IL-6\n(disease activity)", fillcolor="#BBDEFB"];
    }

    /* ================================================================
       CLUSTER 14: CLINICAL ENDPOINTS
    ================================================================ */
    subgraph cluster_clinical {
        label="Clinical Endpoints & Complications\n임상 평가 변수 및 합병증";
        style=filled; fillcolor="#FFEBEE"; color="#B71C1C"; penwidth=2.0;
        fontname="Helvetica-Bold"; fontsize=11;

        BonePain       [label="Bone Pain\n(VAS score)", fillcolor="#C62828", fontcolor=white];
        BoneDeformity  [label="Bone Deformity\n(bowing, skull↑)", fillcolor="#C62828", fontcolor=white];
        PathFracture   [label="Pathologic\nFracture", fillcolor="#D32F2F", fontcolor=white];
        NerveCompress  [label="Nerve Compression\n(hearing loss, radiculopathy)", fillcolor="#D32F2F", fontcolor=white];
        HearingLoss    [label="Sensorineural\nHearing Loss", fillcolor="#E53935"];
        HighOutputHF   [label="High-Output\nHeart Failure", fillcolor="#E53935"];
        SecondaryOA    [label="Secondary\nOsteoarthritis", fillcolor="#EF5350"];
        OsteosarcomaRisk [label="Osteosarcoma\nRisk (<1% of PBD)", fillcolor="#EF5350"];
        GiantCellTumor [label="Giant Cell\nTumor (rare)", fillcolor="#E57373"];
        QoL            [label="Quality of Life\n(SF-36, WOMAC)", fillcolor="#EF9A9A"];
        RadiographicScore [label="Radiographic\nProgression Score", fillcolor="#FFCDD2"];
    }

    /* ================================================================
       CLUSTER 15: SYSTEMIC EFFECTS
    ================================================================ */
    subgraph cluster_systemic {
        label="Systemic & Metabolic Effects\n전신 및 대사 영향";
        style=filled; fillcolor="#F0F4C3"; color="#827717"; penwidth=2.0;
        fontname="Helvetica-Bold"; fontsize=11;

        Hypercalcemia  [label="Hypercalcemia\n(immobilization)", fillcolor="#9E9D24", fontcolor=white];
        Hypercalciuria [label="Hypercalciuria\nKidney stones risk", fillcolor="#A5A80E"];
        Hyperphosphate [label="Hyperphosphatemia\n(rare)", fillcolor="#AFB42B"];
        CardiacOutput  [label="↑ Cardiac Output\n(high flow lesion)", fillcolor="#C0CA33"];
        VitD_Ca_metab  [label="Vitamin D / Ca\nMetabolism", fillcolor="#CDDC39"];
        BoneTurnLow    [label="Normal/Low Bone\nTurnover (remission)", fillcolor="#D4E157"];
        Remission      [label="Biochemical\nRemission (ALP norm)", fillcolor="#DCE775"];
    }

    /* ================================================================
       EDGES — VIRAL / GENETIC → OSTEOCLAST
    ================================================================ */
    MeaslesVirus -> NucleocapsidProtein [color="#D4570A"];
    CDV -> NucleocapsidProtein [color="#D4570A"];
    RSV -> NucleocapsidProtein [color="#D4570A"];
    NucleocapsidProtein -> InclusionBodies [color="#D4570A"];
    InclusionBodies -> GiantOC [color="#D4570A", label="abnormal OC"];
    SQSTM1 -> p62_NF [color="#D4570A", label="scaffold mut"];
    VCP -> NFkB_nuclear [color="#D4570A", label="VCP mut"];
    RANK_gene -> RANK_receptor [color="#D4570A", label="gain-of-fxn"];
    OPG_gene -> OPG [color="#D4570A", label="loss-of-fxn"];
    FamPDB -> SQSTM1 [color="#888"];
    SporadicPDB -> EnvFactors [color="#888"];
    EpigeneticMod -> RANKL_sol [color="#888", style=dashed];
    EnvFactors -> InclusionBodies [color="#888", style=dashed];

    /* ================================================================
       EDGES — MICROENVIRONMENT → RANKL AXIS
    ================================================================ */
    BoneMarrow -> OCP [color="#2E7D32"];
    BoneMarrow -> Monocyte [color="#2E7D32"];
    Monocyte -> OCP [color="#2E7D32"];
    Stroma -> MCSF [color="#2E7D32"];
    MSC -> OBP [color="#2E7D32", lhead=cluster_osteoblasts];
    MSC -> RANKL_memb [color="#2E7D32"];
    MCSF -> cFms [color="#2E7D32"];
    cFms -> OCP [color="#2E7D32", label="proliferation"];
    VEGF -> PageticVascularity [color="#2E7D32"];
    PageticVascularity -> BoneTurnoverAll [color="#2E7D32", style=dashed];
    Tcell -> TC_RANKL [color="#2E7D32"];
    IL6_RANKL -> Stroma [color="#888", dir=back, style=dashed];

    /* ================================================================
       EDGES — RANKL AXIS → OSTEOCLAST SIGNALING
    ================================================================ */
    RANKL_memb -> RANK_RANKL_cpx [color="#E65100"];
    RANKL_sol -> RANK_RANKL_cpx [color="#E65100"];
    RANK_receptor -> RANK_RANKL_cpx [color="#E65100"];
    OPG -> RANKL_sol [color="#1565C0", label="decoy\nneutralizes", style=dashed];
