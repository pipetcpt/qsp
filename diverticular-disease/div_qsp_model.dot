digraph DIV_QSP {
  graph [
    rankdir=LR,
    bgcolor="#1a1a2e",
    fontname="Helvetica",
    splines=curved,
    nodesep=0.35,
    ranksep=0.9,
    label="Diverticular Disease (게실병) QSP Model\nPathophysiology · Inflammation · Drug PK/PD\nDiverticulosis → Diverticulitis → Complications",
    labelloc=t,
    fontcolor="white",
    fontsize=20
  ];
  node [fontname="Helvetica", fontsize=9, style=filled, shape=box, color="#444466"];
  edge [color="#aaaaaa", fontsize=7, fontname="Helvetica"];

  // ========================================
  // CLUSTER 1: Diet & Lifestyle Risk Factors
  // ========================================
  subgraph cluster_diet {
    label="Diet & Lifestyle Risk Factors\n(식이 및 생활습관 위험인자)";
    color="#e74c3c"; fontcolor="white"; style=filled; fillcolor="#2d1212";

    low_fiber       [label="Low Dietary\nFiber Intake\n(<15 g/day)", fillcolor="#e74c3c", fontcolor="white"];
    high_fat        [label="High-Fat /\nHigh-Processed\nFood Diet",   fillcolor="#c0392b", fontcolor="white"];
    obesity         [label="Obesity\n(BMI >30 kg/m²)",                fillcolor="#e74c3c", fontcolor="white"];
    physical_inact  [label="Physical\nInactivity",                     fillcolor="#c0392b", fontcolor="white"];
    NSAID_use       [label="NSAID / Aspirin\nChronic Use",             fillcolor="#e74c3c", fontcolor="white"];
    alcohol         [label="Alcohol\nConsumption\n(>2 drinks/day)",    fillcolor="#c0392b", fontcolor="white"];
    smoking         [label="Smoking",                                   fillcolor="#e74c3c", fontcolor="white"];
    red_meat        [label="Red Meat\nConsumption\n(>85 g/day)",       fillcolor="#c0392b", fontcolor="white"];
    aging           [label="Aging\n(>50 yrs)",                         fillcolor="#e74c3c", fontcolor="white"];
    fiber_diet      [label="Adequate Dietary\nFiber (≥25 g/day)\n[Protective]", fillcolor="#27ae60", fontcolor="white"];
    hydration       [label="Hydration\nStatus",                        fillcolor="#27ae60", fontcolor="white"];
    connective_dis  [label="Connective Tissue\nDisorders (EDS, Marfan)",fillcolor="#c0392b", fontcolor="white"];
  }

  // ========================================
  // CLUSTER 2: Colonic Biomechanics
  // ========================================
  subgraph cluster_biomech {
    label="Colonic Biomechanics & Motility\n(대장 생역학)";
    color="#3498db"; fontcolor="white"; style=filled; fillcolor="#0e1f3a";

    intralum_press  [label="Intraluminal\nColonic Pressure\n(cmH₂O) ↑",   fillcolor="#2980b9", fontcolor="white", shape=ellipse];
    seg_contract    [label="Segmentation\nContractions",                    fillcolor="#3498db", fontcolor="white"];
    haustral        [label="Haustral\nContractions",                        fillcolor="#2980b9", fontcolor="white"];
    transit_time    [label="Colonic Transit\nTime (h) ↑",                  fillcolor="#3498db", fontcolor="white"];
    stool_bulk      [label="Stool Bulk /\nVolume ↓",                       fillcolor="#2980b9", fontcolor="white"];
    stool_consist   [label="Stool\nConsistency\n(Hard / BSS 1-2)",         fillcolor="#3498db", fontcolor="white"];
    myenteric_plx   [label="Myenteric Plexus\n(Auerbach's plexus)",        fillcolor="#1a78c2", fontcolor="white"];
    ICC             [label="Interstitial Cells\nof Cajal (ICC)",            fillcolor="#3498db", fontcolor="white"];
    serotonin       [label="5-HT (Serotonin)\n5-HT3/5-HT4 Receptors",     fillcolor="#2980b9", fontcolor="white"];
    motilin         [label="Motilin / Ghrelin\n(Phase III MMC)",           fillcolor="#3498db", fontcolor="white"];
    VIP             [label="VIP\n(Relaxatory\nneuropeptide)",               fillcolor="#2980b9", fontcolor="white"];
    substance_P     [label="Substance P /\nNKA (Excitatory)",              fillcolor="#3498db", fontcolor="white"];
    wall_tension    [label="Colonic Wall\nTension\n(La Place: T=P·r/2h)", fillcolor="#1a5f8a", fontcolor="white", shape=ellipse];
    teniae_coli     [label="Teniae Coli\n(Longitudinal\nMuscle) ↓ tone", fillcolor="#2980b9", fontcolor="white"];
    circ_muscle     [label="Circular Muscle\nLayer Integrity",             fillcolor="#3498db", fontcolor="white"];
    intra_abdom_p   [label="Intra-Abdominal\nPressure (Valsalva)",        fillcolor="#2980b9", fontcolor="white"];
  }

  // ========================================
  // CLUSTER 3: Mucosal Barrier
  // ========================================
  subgraph cluster_mucosal {
    label="Mucosal Barrier & Permeability\n(점막 방어 및 투과성)";
    color="#9b59b6"; fontcolor="white"; style=filled; fillcolor="#1e0e38";

    colonocyte      [label="Colonocyte\nIntegrity",                         fillcolor="#8e44ad", fontcolor="white"];
    goblet_cell     [label="Goblet Cells\n(Mucin Secretion)",               fillcolor="#9b59b6", fontcolor="white"];
    mucin_MUC2      [label="Mucin Layer\n(MUC2 / MUC5AC)",                  fillcolor="#8e44ad", fontcolor="white"];
    ZO1             [label="ZO-1 / ZO-2\nTight Junction",                   fillcolor="#9b59b6", fontcolor="white"];
    occludin        [label="Occludin /\nClaudin-2/4",                       fillcolor="#8e44ad", fontcolor="white"];
    sIgA            [label="Secretory IgA\n(sIgA)",                         fillcolor="#9b59b6", fontcolor="white"];
    defensins       [label="Defensins /\nAMPs (alpha/beta)",                fillcolor="#8e44ad", fontcolor="white"];
    permeability    [label="Gut Barrier\nPermeability ↑\n(Leaky Gut)",     fillcolor="#6c3483", fontcolor="white", shape=ellipse];
    bact_transloc   [label="Bacterial\nTranslocation ↑",                   fillcolor="#9b59b6", fontcolor="white"];
    NSAID_injury    [label="NSAID-Induced\nMucosal Injury\n(PG depletion)", fillcolor="#8e44ad", fontcolor="white"];
    butyrate_fuel   [label="Butyrate\nColonotrophy\n(Energy source)",      fillcolor="#27ae60", fontcolor="white"];
  }

  // ========================================
  // CLUSTER 4: Gut Microbiome
  // ========================================
  subgraph cluster_microbiome {
    label="Gut Microbiome & Dysbiosis\n(장내 미생물 및 생태계 교란)";
    color="#27ae60"; fontcolor="white"; style=filled; fillcolor="#0e2010";

    Bacteroidetes   [label="Bacteroidetes\n(Protective) ↓",                fillcolor="#27ae60", fontcolor="white"];
    Firmicutes      [label="Firmicutes\n(Balanced) ↓",                     fillcolor="#2ecc71", fontcolor="white"];
    Faecalib        [label="Faecalibacterium\nprausnitzii ↓",              fillcolor="#27ae60", fontcolor="white"];
    Bifido          [label="Bifidobacterium\nspp. ↓",                      fillcolor="#2ecc71", fontcolor="white"];
    E_coli_path     [label="E. coli /\nKlebsiella ↑\n(Pathogenic)",        fillcolor="#c0392b", fontcolor="white"];
    Fusobacterium   [label="Fusobacterium\nnucleatum ↑",                   fillcolor="#e74c3c", fontcolor="white"];
    Prevotella      [label="Prevotella /\nRuminococcaceae ↓",              fillcolor="#27ae60", fontcolor="white"];
    butyrate        [label="Butyrate\n(SCFA) ↓",                          fillcolor="#27ae60", fontcolor="white"];
    propionate      [label="Propionate ↓\n(SCFA)",                         fillcolor="#2ecc71", fontcolor="white"];
    LPS             [label="LPS / Endotoxin ↑\n(TLR4 Ligand)",            fillcolor="#e74c3c", fontcolor="white", shape=ellipse];
    microbio_div    [label="Microbiome\nAlpha Diversity ↓\n(Shannon index)",fillcolor="#27ae60", fontcolor="white"];
    dysbiosis_idx   [label="Dysbiosis\nIndex ↑",                           fillcolor="#e74c3c", fontcolor="white", shape=diamond];
    H2S             [label="Hydrogen Sulfide\n(H₂S) ↑",                    fillcolor="#c0392b", fontcolor="white"];
    bile_acids_2nd  [label="Secondary\nBile Acids\n(Deoxycholic acid)",     fillcolor="#27ae60", fontcolor="white"];
    trimethylamine  [label="TMA → TMAO\n(↑ inflammation)",                 fillcolor="#c0392b", fontcolor="white"];
  }

  // ========================================
  // CLUSTER 5: Diverticula Formation
  // ========================================
  subgraph cluster_divert_form {
    label="Diverticula Formation & Structural Remodeling\n(게실 형성 및 구조 리모델링)";
    color="#e67e22"; fontcolor="white"; style=filled; fillcolor="#2a1800";

    collagen_I      [label="Collagen Type I\n(Tensile strength)",           fillcolor="#e67e22", fontcolor="white"];
    collagen_III    [label="Collagen Type III\n(Compliance)",               fillcolor="#f39c12", fontcolor="white"];
    elastin         [label="Elastin Fiber\nContent ↓",                     fillcolor="#e67e22", fontcolor="white"];
    MMP1            [label="MMP-1\n(Collagenase) ↑",                       fillcolor="#d35400", fontcolor="white"];
    MMP9            [label="MMP-9\n(Gelatinase B) ↑",                      fillcolor="#e67e22", fontcolor="white"];
    MMP13           [label="MMP-13\n(Collagenase 3)",                      fillcolor="#d35400", fontcolor="white"];
    TIMP1           [label="TIMP-1\n(MMP Inhibitor) ↓",                    fillcolor="#f39c12", fontcolor="white"];
    fibroblast      [label="Fibroblast /\nSMC Activation",                  fillcolor="#e67e22", fontcolor="white"];
    ECM_remodel     [label="ECM\nRemodeling\n↓ Integrity",                 fillcolor="#f39c12", fontcolor="white", shape=ellipse];
    mucosal_hern    [label="Mucosal Herniation\n→ Diverticulum\nFormation", fillcolor="#d35400", fontcolor="white", shape=ellipse];
    divert_N        [label="Diverticula Count\n(N, cumulative)",            fillcolor="#e67e22", fontcolor="white", shape=ellipse];
    divert_size     [label="Diverticula Diameter\n(mm, mean)",              fillcolor="#f39c12", fontcolor="white"];
    vasa_recta      [label="Vasa Recta\n(at diverticulum neck)",            fillcolor="#e67e22", fontcolor="white"];
    circ_defect     [label="Circular Muscle\nDefect / Weak Zone",           fillcolor="#d35400", fontcolor="white"];
    divert_location [label="Left Colon\n(Sigmoid) >> Right\n(Asian variant)",fillcolor="#f39c12", fontcolor="white"];
  }

  // ========================================
  // CLUSTER 6: Acute Diverticulitis
  // ========================================
  subgraph cluster_acute {
    label="Acute Diverticulitis – Inflammatory Cascade\n(급성 게실염 - 염증 폭포)";
    color="#e74c3c"; fontcolor="white"; style=filled; fillcolor="#2e0a0a";

    fecalith        [label="Fecalith\nObstruction",                        fillcolor="#e74c3c", fontcolor="white"];
    micro_perf      [label="Micro-Perforation\n(Diverticular\nrupture)",   fillcolor="#c0392b", fontcolor="white", shape=diamond];
    TLR4_activ      [label="TLR4 / TLR2 / TLR9\nActivation (PAMP/DAMP)", fillcolor="#e74c3c", fontcolor="white"];
    NF_kB           [label="NF-κB Activation\n(p65/p50)",                  fillcolor="#c0392b", fontcolor="white", shape=ellipse];
    NLRP3           [label="NLRP3\nInflammasome",                           fillcolor="#e74c3c", fontcolor="white"];
    TNF_a           [label="TNF-α ↑\n(pg/mL)",                             fillcolor="#c0392b", fontcolor="white"];
    IL6             [label="IL-6 ↑\n(pg/mL)",                              fillcolor="#e74c3c", fontcolor="white"];
    IL1b            [label="IL-1β ↑\n(pg/mL)",                             fillcolor="#c0392b", fontcolor="white"];
    IL8             [label="IL-8 / CXCL8 ↑\n(Neutrophil chemoattractant)", fillcolor="#e74c3c", fontcolor="white"];
    IL17            [label="IL-17A ↑",                                      fillcolor="#c0392b", fontcolor="white"];
    IL10            [label="IL-10 ↑\n(Anti-inflammatory)",                  fillcolor="#27ae60", fontcolor="white"];
    COX2            [label="COX-2\nInduction",                              fillcolor="#e74c3c", fontcolor="white"];
    PGE2            [label="Prostaglandin\nE2 (PGE2) ↑",                   fillcolor="#c0392b", fontcolor="white"];
    neutrophil      [label="Neutrophil\nInfiltration ↑",                   fillcolor="#e74c3c", fontcolor="white"];
    elastase        [label="Neutrophil\nElastase ↑",                        fillcolor="#c0392b", fontcolor="white"];
    ROS             [label="ROS / Oxidative\nStress ↑",                    fillcolor="#e74c3c", fontcolor="white"];
    MPO             [label="Myeloperoxidase\n(MPO) ↑",                     fillcolor="#c0392b", fontcolor="white"];
    CRP_marker      [label="CRP ↑\n(Acute Phase Protein)",                  fillcolor="#e74c3c", fontcolor="white", shape=ellipse];
    WBC_marker      [label="WBC ↑\n(Leukocytosis >10k)",                  fillcolor="#c0392b", fontcolor="white"];
    complement      [label="Complement\nActivation\n(C3a / C5a)",          fillcolor="#e74c3c", fontcolor="white"];
    macrophage_M1   [label="Macrophage M1\n(Pro-inflammatory)",            fillcolor="#c0392b", fontcolor="white"];
    pericolic_fat   [label="Pericolic Fat\nStranding\n(CT finding)",        fillcolor="#e74c3c", fontcolor="white"];
    fever_sign      [label="Fever\n(T > 38.5°C)",                          fillcolor="#c0392b", fontcolor="white"];
    pain_acute      [label="LLQ Pain ↑\n(Acute Onset)",                   fillcolor="#e74c3c", fontcolor="white"];
  }

  // ========================================
  // CLUSTER 7: Chronic Inflammation & Fibrosis
  // ========================================
  subgraph cluster_chronic {
    label="Chronic Diverticular Disease – Fibrosis & SUDD\n(만성 게실질환 - 섬유화)";
    color="#f39c12"; fontcolor="white"; style=filled; fillcolor="#2a1a00";

    macrophage_M2   [label="Macrophage M2\n(Pro-fibrotic)",                fillcolor="#d68910", fontcolor="white"];
    TGF_b           [label="TGF-β1\n(Fibrosis driver)",                    fillcolor="#f39c12", fontcolor="white"];
    SMAD23          [label="SMAD2/3\nSignaling",                            fillcolor="#d68910", fontcolor="white"];
    myofibroblast   [label="Myofibroblast\nActivation (αSMA+)",            fillcolor="#f39c12", fontcolor="white"];
    col_deposit     [label="Collagen\nDeposition ↑",                       fillcolor="#d68910", fontcolor="white"];
    stricture       [label="Colonic\nStricture\n(Luminal narrowing)",       fillcolor="#f39c12", fontcolor="white", shape=ellipse];
    chron_infl      [label="Chronic Inflammation\nScore (SUDD)",            fillcolor="#d68910", fontcolor="white", shape=ellipse];
    mast_cell       [label="Mast Cell\nActivation ↑",                      fillcolor="#f39c12", fontcolor="white"];
    visceral_hyp    [label="Visceral\nHypersensitivity ↑",                 fillcolor="#d68910", fontcolor="white"];
    submucosal_fib  [label="Submucosal\nFibrosis",                         fillcolor="#f39c12", fontcolor="white"];
    nerve_remodel   [label="Enteric Nerve\nRemodeling",                    fillcolor="#d68910", fontcolor="white"];
    SUDD            [label="SUDD\n(Symptomatic\nUncomplicated\nDD)",        fillcolor="#e67e22", fontcolor="white", shape=ellipse];
  }

  // ========================================
  // CLUSTER 8: Complications
  // ========================================
  subgraph cluster_complic {
    label="Clinical Complications (Hinchey Classification)\n(임상 합병증)";
    color="#7f8c8d"; fontcolor="white"; style=filled; fillcolor="#141414";

    abscess_peric   [label="Pericolic\nAbscess",                           fillcolor="#7f8c8d", fontcolor="white"];
    abscess_pelv    [label="Pelvic / Distant\nAbscess",                    fillcolor="#95a5a6", fontcolor="white"];
    macro_perf      [label="Frank\nPerforation",                            fillcolor="#5d6d7e", fontcolor="white"];
    peritonitis     [label="Peritonitis\n(Purulent/Fecal)",                 fillcolor="#7f8c8d", fontcolor="white"];
    fistula         [label="Fistula Formation\n(Colovesical /\nColovaginal)", fillcolor="#95a5a6", fontcolor="white"];
    obstruction     [label="Bowel\nObstruction",                            fillcolor="#5d6d7e", fontcolor="white"];
    LGIB            [label="Lower GI\nBleeding (LGIB)",                   fillcolor="#7f8c8d", fontcolor="white"];
    vasc_erosion    [label="Vasa Recta\nErosion\n(Pulsatile bleeding)",    fillcolor="#95a5a6", fontcolor="white"];
    Hinchey_I       [label="Hinchey I\nPericolic Abscess",                 fillcolor="#27ae60", fontcolor="white"];
    Hinchey_II      [label="Hinchey II\nPelvic Abscess",                   fillcolor="#f39c12", fontcolor="white"];
    Hinchey_III     [label="Hinchey III\nPurulent Peritonitis",            fillcolor="#e74c3c", fontcolor="white"];
    Hinchey_IV      [label="Hinchey IV\nFecal Peritonitis",                fillcolor="#c0392b", fontcolor="white"];
    recurrence      [label="Recurrence\n(25-30% after\n1st episode)",       fillcolor="#7f8c8d", fontcolor="white", shape=ellipse];
    sepsis          [label="Sepsis /\nSeptic Shock",                        fillcolor="#5d6d7e", fontcolor="white"];
  }

  // ========================================
  // CLUSTER 9: Drug PK/PD
  // ========================================
  subgraph cluster_drugs {
    label="Pharmacological Interventions – PK/PD\n(약물 PK/PD)";
    color="#1abc9c"; fontcolor="white"; style=filled; fillcolor="#061e18";

    rifax_dose      [label="Rifaximin\n400mg TID × 7d\n(Cyclic, monthly)",  fillcolor="#16a085", fontcolor="white", shape=hexagon];
    rifax_GI        [label="Rifaximin GI\nConc. (mg/L)\nF < 0.4%",         fillcolor="#1abc9c", fontcolor="white"];
    rifax_eff       [label="Rifaximin → ↓\nDysbiosis / ↓ LPS\n/ ↑ Diversity", fillcolor="#16a085", fontcolor="white"];
    mesa_dose       [label="Mesalamine\n(5-ASA) 1.6g/day\nMaintenance",    fillcolor="#1abc9c", fontcolor="white", shape=hexagon];
    mesa_GI         [label="5-ASA Colonic\nConcentration",                  fillcolor="#16a085", fontcolor="white"];
    mesa_eff        [label="5-ASA → ↓ NF-κB\n/ ↓ TNF-α / ↓\nPGE2 / ↓ IL-6", fillcolor="#1abc9c", fontcolor="white"];
    cipro_dose      [label="Ciprofloxacin\n500mg BID\n(Acute 7-10d)",       fillcolor="#148f77", fontcolor="white", shape=hexagon];
    cipro_plasma    [label="Ciprofloxacin\nPlasma Conc.\n(mg/L)",           fillcolor="#16a085", fontcolor="white"];
    metro_dose      [label="Metronidazole\n500mg TID\n(Acute 7-10d)",       fillcolor="#1abc9c", fontcolor="white", shape=hexagon];
    metro_plasma    [label="Metronidazole\nPlasma Conc.\n(mg/L)",           fillcolor="#148f77", fontcolor="white"];
    antibio_eff     [label="Antibiotic Effect\n→ ↓ Pathogenic\nBacteria",   fillcolor="#16a085", fontcolor="white"];
    fiber_supp      [label="Psyllium / Inulin\nFiber Supplement\n(15g/day)", fillcolor="#27ae60", fontcolor="white", shape=hexagon];
    fiber_eff       [label="Fiber → ↑ Butyrate\n/ ↑ Stool Bulk\n/ ↓ Pressure", fillcolor="#2ecc71", fontcolor="white"];
    probiotic_dose  [label="Probiotic\n(Lactobacillus /\nBifidobacterium)",  fillcolor="#27ae60", fontcolor="white", shape=hexagon];
    probi_eff       [label="Probiotic → ↑\nMicrobiome Diversity\n/ ↓ Dysbiosis", fillcolor="#2ecc71", fontcolor="white"];
    eluxadoline     [label="Eluxadoline\n100mg BID\n(Post-DD IBS)",         fillcolor="#16a085", fontcolor="white", shape=hexagon];
    amox_clav       [label="Amoxicillin-\nClavulanate\n875/125 mg BID",     fillcolor="#148f77", fontcolor="white", shape=hexagon];
    amox_plasma     [label="Amoxicillin\nPlasma Conc.",                     fillcolor="#16a085", fontcolor="white"];
  }

  // ========================================
  // CLUSTER 10: Clinical Endpoints
  // ========================================
  subgraph cluster_endpoints {
    label="Clinical Endpoints & Outcomes\n(임상 결과)";
    color="#ecf0f1"; fontcolor="#2c3e50"; style=filled; fillcolor="#101820";

    pain_VAS        [label="Abdominal Pain\nScore (VAS 0-10)",              fillcolor="#bdc3c7", fontcolor="#2c3e50", shape=ellipse];
    CRP_end         [label="CRP\n(mg/L) ↓",                                 fillcolor="#95a5a6", fontcolor="white"];
    WBC_end         [label="WBC Count\n(×10³/µL) ↓",                        fillcolor="#bdc3c7", fontcolor="#2c3e50"];
    CT_severity     [label="CT Severity Score\n(Modified Hinchey)",         fillcolor="#95a5a6", fontcolor="white"];
    recurrence_rate [label="Recurrence Rate\n(% per year) ↓",              fillcolor="#bdc3c7", fontcolor="#2c3e50", shape=ellipse];
    hospitaliz      [label="Hospitalization\nRate ↓",                       fillcolor="#95a5a6", fontcolor="white", shape=ellipse];
    surgery_rate    [label="Surgery Rate\n(Hartmann / LAR) ↓",             fillcolor="#bdc3c7", fontcolor="#2c3e50", shape=ellipse];
    QoL             [label="Quality of Life\n(SF-36 / EQ-5D) ↑",           fillcolor="#95a5a6", fontcolor="white", shape=ellipse];
    bleeding_ep     [label="LGIB Episodes\n(per year) ↓",                  fillcolor="#bdc3c7", fontcolor="#2c3e50"];
    resolution_t    [label="Clinical Resolution\nTime (days) ↓",           fillcolor="#95a5a6", fontcolor="white"];
    bowel_habit     [label="Bowel Habit\nNormalization",                    fillcolor="#bdc3c7", fontcolor="#2c3e50"];
    microbiome_res  [label="Microbiome\nRestoration Index",                 fillcolor="#27ae60", fontcolor="white"];
  }

  // ============================
  // EDGES: Diet → Biomechanics
  // ============================
  low_fiber      -> stool_bulk      [label="↓ bulk"];
  low_fiber      -> transit_time    [label="↑ slow transit"];
  low_fiber      -> butyrate        [label="↓ fermentation"];
  high_fat       -> intralum_press  [label="↑ press"];
  high_fat       -> E_coli_path     [label="feeds pathogens"];
  obesity        -> intralum_press  [label="↑ intra-abdom\npress"];
  obesity        -> LPS             [label="↑ LPS\n(fatty meal)"];
  physical_inact -> transit_time    [label="↑ transit"];
  aging          -> teniae_coli     [label="↓ muscle tone"];
  aging          -> collagen_I      [label="↓ quality"];
  aging          -> MMP1            [label="↑ MMP-1"];
  aging          -> elastin         [label="↓ elastin"];
  fiber_diet     -> stool_bulk      [label="↑ bulk"];
  fiber_diet     -> transit_time    [label="↓ transit"];
  fiber_diet     -> butyrate        [label="↑ fermentation"];
  hydration      -> stool_consist   [label="softens stool"];
  connective_dis -> ECM_remodel     [label="↑ ECM\nvulnerability"];
  red_meat       -> H2S             [label="sulfur\nfermentation"];
  alcohol        -> permeability    [label="↑ leaky gut"];
  smoking        -> MMP9            [label="↑ MMP-9"];

  // Biomechanics → Pressure/Tension
  stool_bulk     -> intralum_press  [label="fills lumen\n→ ↓ press"];
  seg_contract   -> intralum_press  [label="↑ closed\nsegment press"];
  haustral       -> wall_tension    [label="↑ tension"];
  intralum_press -> wall_tension    [label="La Place Law\nT=P·r/2h"];
  myenteric_plx  -> serotonin       [label="releases 5-HT"];
  serotonin      -> seg_contract    [label="↑ contractions"];
  myenteric_plx  -> VIP             [label="inhibitory\nneuron"];
  VIP            -> seg_contract    [label="inhibits"];
  substance_P    -> seg_contract    [label="excites"];
  ICC            -> haustral        [label="pacemaker\nactivity"];
  motilin        -> haustral        [label="↑ MMC III\nmotility"];
  intra_abdom_p  -> intralum_press  [label="↑ transmural\npress"];
  obesity        -> intra_abdom_p   [label="↑ IAP"];
  NSAID_use      -> serotonin       [label="alters 5-HT\nmetabolism"];

  // Mucosal Barrier
  butyrate_fuel  -> colonocyte      [label="energy\nsource"];
  butyrate       -> butyrate_fuel   [label="provides"];
  butyrate       -> goblet_cell     [label="stimulates\nmucin"];
  goblet_cell    -> mucin_MUC2      [label="secretes MUC2"];
  mucin_MUC2     -> permeability    [label="↓ permeability"];
  ZO1            -> permeability    [label="seals TJ"];
  occludin       -> permeability    [label="seals TJ"];
  defensins      -> E_coli_path     [label="kills"];
  sIgA           -> E_coli_path     [label="opsonizes"];
  NSAID_use      -> NSAID_injury    [label="PG depletion"];
  NSAID_injury   -> permeability    [label="↑ permeability"];
  permeability   -> bact_transloc   [label="allows\ntranslocation"];
  bact_transloc  -> TLR4_activ      [label="PAMP\nexposure"];
  H2S            -> colonocyte      [label="↑ mitochondrial\ntoxicity"];

  // Microbiome edges
  fiber_diet     -> Faecalib        [label="feeds FP"];
  fiber_diet     -> Bifido          [label="prebiotic"];
  fiber_diet     -> Bacteroidetes   [label="↑ abundance"];
  Faecalib       -> butyrate        [label="produces"];
  Bifido         -> propionate      [label="produces"];
  Bacteroidetes  -> butyrate        [label="cross-feeds"];
  E_coli_path    -> LPS             [label="sheds LPS"];
  Fusobacterium  -> LPS             [label="produces\nFadA toxin"];
  LPS            -> TLR4_activ      [label="binds MD-2\n/TLR4"];
  microbio_div   -> dysbiosis_idx   [label="↓ diversity\n→ ↑ dysbiosis"];
  dysbiosis_idx  -> LPS             [label="↑ dysbiosis\n→ ↑ LPS"];
  dysbiosis_idx  -> bact_transloc   [label="↑ permeability"];
  red_meat       -> trimethylamine  [label="TMA\nproduction"];
  trimethylamine -> LPS             [label="co-promotes\ninflammation"];

  // Diverticula formation
  wall_tension   -> circ_defect     [label="↑ stress →\nfatigue"];
  circ_defect    -> mucosal_hern    [label="allows herniation"];
  intralum_press -> mucosal_hern    [label="driving force"];
  MMP1           -> collagen_I      [label="degrades"];
  MMP9           -> collagen_III    [label="degrades"];
  MMP13          -> collagen_I      [label="degrades"];
  TIMP1          -> MMP1            [label="inhibits"];
  TIMP1          -> MMP9            [label="inhibits"];
  aging          -> TIMP1           [label="↓ TIMP-1"];
  TNF_a          -> MMP1            [label="induces\nMMP-1"];
  IL1b           -> MMP9            [label="induces\nMMP-9"];
  collagen_I     -> ECM_remodel     [label="structural\nsupport"];
  collagen_III   -> ECM_remodel     [label="compliance"];
  elastin        -> ECM_remodel     [label="recoil"];
  ECM_remodel    -> mucosal_hern    [label="weakened ECM\n→ herniation"];
  mucosal_hern   -> divert_N        [label="count ↑"];
  mucosal_hern   -> divert_size     [label="size ↑"];
  vasa_recta     -> divert_N        [label="at neck\nvulnerable"];
  fibroblast     -> collagen_I      [label="synthesizes"];
  fibroblast     -> collagen_III    [label="synthesizes"];
  divert_location-> divert_N        [label="sigmoid\npredominant"];

  // Acute Diverticulitis
  fecalith       -> micro_perf      [label="obstructs\n→ rupture"];
  divert_N       -> micro_perf      [label="↑ risk"];
  divert_size    -> micro_perf      [label="↑ risk"];
  micro_perf     -> pericolic_fat   [label="spreads to\npericolic fat"];
  micro_perf     -> TLR4_activ      [label="bacterial\nPAMPs/DAMPs"];
  bact_transloc  -> TLR4_activ      [label="↑ PAMP load"];
  TLR4_activ     -> NF_kB           [label="IKKβ→IκB\ndegradation"];
  NF_kB          -> TNF_a           [label="transcribes"];
  NF_kB          -> IL6             [label="transcribes"];
  NF_kB          -> IL1b            [label="transcribes"];
  NF_kB          -> IL8             [label="transcribes"];
  NF_kB          -> COX2            [label="transcribes"];
  NLRP3          -> IL1b            [label="caspase-1\ncleavage"];
  LPS            -> NLRP3           [label="primes"];
  ROS            -> NLRP3           [label="signal 2\nactivates"];
  COX2           -> PGE2            [label="synthesizes"];
  PGE2           -> pain_acute      [label="sensitizes\nnociceptors"];
  IL8            -> neutrophil      [label="recruits"];
  neutrophil     -> elastase        [label="releases"];
  neutrophil     -> ROS             [label="NADPH\noxidase"];
  neutrophil     -> MPO             [label="degranulates"];
  MPO            -> ROS             [label="→ HOCl"];
  IL6            -> CRP_marker      [label="hepatic\nCRP synthesis"];
  WBC_marker     -> neutrophil      [label="neutrophilia"];
  TNF_a          -> NF_kB           [label="amplifies"];
  IL1b           -> NF_kB           [label="amplifies"];
  complement     -> neutrophil      [label="C5a\nchemoattract"];
  macrophage_M1  -> TNF_a           [label="secretes"];
  macrophage_M1  -> IL6             [label="secretes"];
  macrophage_M1  -> IL1b            [label="secretes"];
  pericolic_fat  -> macrophage_M1   [label="resident\nmacrophages"];
  IL17           -> NF_kB           [label="synergy"];
  IL10           -> NF_kB           [label="↓ negative\nfeedback"];
  fever_sign     -> CRP_marker      [label="acute phase"];
  NF_kB          -> IL17            [label="amplifies"];

  // Chronic Inflammation/Fibrosis
  macrophage_M1  -> macrophage_M2   [label="M1→M2\nresolution"];
  macrophage_M2  -> TGF_b           [label="secretes\nTGF-β1"];
  TGF_b          -> SMAD23          [label="R-SMAD\nphosphorylation"];
  SMAD23         -> myofibroblast   [label="activates\nαSMA+cells"];
  myofibroblast  -> col_deposit     [label="secretes\ncollagen"];
  col_deposit    -> stricture       [label="→ stricture\nformation"];
  col_deposit    -> submucosal_fib  [label="fibrosis"];
  mast_cell      -> visceral_hyp    [label="histamine /\ntryptase"];
  mast_cell      -> IL1b            [label="releases"];
  chron_infl     -> recurrence      [label="↑ recurrence\nrisk"];
  TGF_b          -> fibroblast      [label="activates\nfibroblast"];
  nerve_remodel  -> visceral_hyp    [label="sensitization"];
  visceral_hyp   -> pain_VAS        [label="↑ pain\nperception"];
  SUDD           -> chron_infl      [label="chronic\nsymptoms"];
  SUDD           -> pain_VAS        [label="chronic\nLLQ pain"];

  // Complications
  micro_perf     -> abscess_peric   [label="→ Hinchey I\ncontained"];
  abscess_peric  -> Hinchey_I;
  abscess_peric  -> abscess_pelv    [label="extends"];
  abscess_pelv   -> Hinchey_II;
  micro_perf     -> macro_perf      [label="progression"];
  macro_perf     -> peritonitis     [label="free\nperforation"];
  peritonitis    -> Hinchey_III;
  peritonitis    -> Hinchey_IV;
  peritonitis    -> sepsis          [label="systemic\nspread"];
  stricture      -> obstruction     [label="luminal\nnarrowing"];
  divert_N       -> fistula         [label="chronic\npressure"];
  vasa_recta     -> vasc_erosion    [label="arterial\nerosion"];
  vasc_erosion   -> LGIB            [label="painless\nbleeding"];
  LGIB           -> bleeding_ep;
  Hinchey_I      -> CT_severity;
  Hinchey_II     -> CT_severity;
  Hinchey_III    -> CT_severity;
  Hinchey_IV     -> CT_severity;
  chron_infl     -> recurrence;

  // Drug PK/PD
  rifax_dose     -> rifax_GI        [label="F<0.4%\nlocal action"];
  rifax_GI       -> rifax_eff       [label="↑ GI conc\n→ antimicrobial"];
  rifax_eff      -> dysbiosis_idx   [label="↓ dysbiosis"];
  rifax_eff      -> LPS             [label="↓ LPS"];
  rifax_eff      -> microbio_div    [label="↑ diversity"];
  rifax_eff      -> Faecalib        [label="spares FP"];
  mesa_dose      -> mesa_GI         [label="pH-release\n/MMX"];
  mesa_GI        -> mesa_eff        [label="colonic\nconcentration"];
  mesa_eff       -> NF_kB           [label="↓ NF-κB\nactivation"];
  mesa_eff       -> PGE2            [label="↓ via COX-2\ninhibition"];
  mesa_eff       -> TNF_a           [label="↓ TNF-α"];
  mesa_eff       -> IL6             [label="↓ IL-6"];
  cipro_dose     -> cipro_plasma    [label="F=0.70\nt½=4-6h"];
  cipro_plasma   -> antibio_eff     [label="bactericidal\n(gram-neg)"];
  metro_dose     -> metro_plasma    [label="F=0.99\nt½=6-8h"];
  metro_plasma   -> antibio_eff     [label="bactericidal\n(anaerobes)"];
  amox_clav      -> amox_plasma     [label="F=0.93\nt½=1-2h"];
  amox_plasma    -> antibio_eff     [label="beta-lactam\nbroad-spectrum"];
  antibio_eff    -> E_coli_path     [label="↓ kills"];
  antibio_eff    -> Fusobacterium   [label="↓ kills"];
  antibio_eff    -> TLR4_activ      [label="↓ PAMP\nburden"];
  fiber_supp     -> fiber_eff;
  fiber_eff      -> butyrate        [label="↑ butyrate"];
  fiber_eff      -> stool_bulk      [label="↑ bulk"];
  fiber_eff      -> intralum_press  [label="↓ pressure"];
  probiotic_dose -> probi_eff;
  probi_eff      -> microbio_div    [label="↑ diversity"];
  probi_eff      -> Bifido          [label="↑ engraftment"];
  probi_eff      -> dysbiosis_idx   [label="↓ dysbiosis"];
  eluxadoline    -> serotonin       [label="μ/κ agonist\nδ antag\n(↓ motility)"];

  // Clinical Endpoints
  pain_acute     -> pain_VAS;
  fever_sign     -> CRP_end;
  IL6            -> CRP_end         [label="induces"];
  neutrophil     -> WBC_end;
  CRP_marker     -> CRP_end;
  WBC_marker     -> WBC_end;
  pericolic_fat  -> CT_severity     [label="fat stranding\nCT sign"];
  recurrence     -> recurrence_rate;
  chron_infl     -> recurrence_rate [label="driver"];
  CT_severity    -> hospitaliz      [label="severe → admit"];
  CT_severity    -> surgery_rate    [label="Hinchey 3/4\n→ surgery"];
  recurrence_rate-> hospitaliz      [label="drives admit"];
  recurrence_rate-> surgery_rate    [label="repeated\nepisodes"];
  pain_VAS       -> QoL             [label="↓ QoL"];
  pain_VAS       -> resolution_t    [label="resolution"];
  chron_infl     -> QoL             [label="↓ QoL"];
  visceral_hyp   -> QoL             [label="↓ QoL"];
  stricture      -> surgery_rate    [label="elective\nsurgery"];
  peritonitis    -> surgery_rate    [label="emergency\nHartmann"];
  obstruction    -> surgery_rate    [label="surgery\nindicated"];
  microbiome_res -> QoL             [label="↑ QoL"];
  rifax_eff      -> microbiome_res  [label="restores"];
  probi_eff      -> microbiome_res  [label="restores"];
  bowel_habit    -> QoL             [label="↑ QoL"];
  fiber_eff      -> bowel_habit     [label="normalizes"];
  mesa_eff       -> chron_infl      [label="↓ chron\ninflammation"];
  antibio_eff    -> fever_sign      [label="→ resolves\nfever"];
  antibio_eff    -> pain_acute      [label="→ ↓ pain"];
}
