digraph HFrEF_QSP {
  graph [
    layout    = fdp
    overlap   = false
    splines   = true
    sep       = "+8"
    K         = 1.8
    bgcolor   = "#0d1117"
    fontname  = "Helvetica"
    fontsize  = 11
    fontcolor = white
    label     = "Heart Failure with Reduced Ejection Fraction (HFrEF)\nComprehensive QSP Mechanistic Map — 126 nodes, 9 subgraphs"
    labelloc  = t
    labeljust = c
  ]
  node [
    fontname  = "Helvetica"
    fontsize  = 9
    fontcolor = white
    style     = "filled,rounded"
    shape     = box
    margin    = "0.12,0.06"
  ]
  edge [
    fontname  = "Helvetica"
    fontsize  = 7
    fontcolor = "#aaaaaa"
    color     = "#666688"
    arrowsize = 0.7
  ]

  // ─────────────────────────────────────────────────────────────
  // CLUSTER 1 — RENIN-ANGIOTENSIN-ALDOSTERONE SYSTEM (RAAS)
  // ─────────────────────────────────────────────────────────────
  subgraph cluster_raas {
    label     = "RAAS (Renin-Angiotensin-Aldosterone System)"
    style     = filled
    fillcolor = "#1a0a2e"
    color     = "#9b59b6"
    penwidth  = 2

    AGT        [label="Angiotensinogen\n(AGT)",          fillcolor="#6c3483"]
    Renin      [label="Renin\n(Kidney JGA)",             fillcolor="#7d3c98"]
    AngI       [label="Angiotensin I\n(AngI)",           fillcolor="#884ea0"]
    ACE        [label="ACE\n(Lung/Vascular)",            fillcolor="#9b59b6"]
    ACE2       [label="ACE2\n(Heart/Lung)",              fillcolor="#27ae60" fontcolor=white]
    AngII      [label="Angiotensin II\n(AngII)",         fillcolor="#c0392b"]
    Ang17      [label="Angiotensin 1-7\n(Ang1-7)",       fillcolor="#27ae60" fontcolor=white]
    AT1R       [label="AT1 Receptor\n(AT1R)",            fillcolor="#922b21"]
    AT2R       [label="AT2 Receptor\n(AT2R)",            fillcolor="#27ae60" fontcolor=white]
    MasR       [label="Mas Receptor\n(MasR)",            fillcolor="#1e8449" fontcolor=white]
    AT1R_sig   [label="AT1R Signaling\n(Vasoconstriction/\nNa-retention/\nHypertrophy)",  fillcolor="#c0392b"]
    Aldo       [label="Aldosterone\n(Zona glomerulosa)", fillcolor="#e74c3c"]
    MR         [label="Mineralocorticoid\nReceptor (MR)", fillcolor="#cb4335"]
    NEP        [label="Neprilysin (NEP)\n(Neutral endopeptidase)", fillcolor="#8e44ad"]
    BK         [label="Bradykinin\n(BK)",                fillcolor="#2980b9"]
    BK2R       [label="BK B2 Receptor\n(BK2R→NO/PGI₂)", fillcolor="#2471a3" fontcolor=white]
    Na_ret     [label="Na⁺ Reabsorption\n+ H₂O Retention", fillcolor="#e74c3c"]
    K_exc      [label="K⁺ Excretion\n(Hypokalemia risk)", fillcolor="#e67e22"]
    RAAS_act   [label="RAAS Activation\n(Triggers: Low BP\nLow Na / SNS)",  fillcolor="#922b21" shape=diamond]
    PRR        [label="(Pro)renin Receptor\n(PRR)",      fillcolor="#7d3c98"]
  }

  // ─────────────────────────────────────────────────────────────
  // CLUSTER 2 — SYMPATHETIC NERVOUS SYSTEM (SNS)
  // ─────────────────────────────────────────────────────────────
  subgraph cluster_sns {
    label     = "Sympathetic Nervous System (SNS)"
    style     = filled
    fillcolor = "#1a1000"
    color     = "#e67e22"
    penwidth  = 2

    CNS_act    [label="CNS Activation\n(Paraventricular\nnucleus)",       fillcolor="#d35400"]
    SNA        [label="Sympathetic Nerve\nActivity (SNA)",                fillcolor="#e67e22"]
    NE_plasma  [label="Plasma NE\n(Norepinephrine)\n[pg/mL]",             fillcolor="#e74c3c"]
    Epi        [label="Epinephrine\n(Adrenal medulla)",                   fillcolor="#e67e22"]
    B1AR       [label="β1-Adrenergic\nReceptor (β1AR)\n[Heart]",         fillcolor="#f39c12"]
    B2AR       [label="β2-Adrenergic\nReceptor (β2AR)\n[Vessel/Lung]",   fillcolor="#f0b27a"]
    A1AR       [label="α1-Adrenergic\nReceptor (α1AR)\n[Vessel]",        fillcolor="#e67e22"]
    Gs_cAMP    [label="Gs→cAMP→PKA\nSignaling",                          fillcolor="#f8c471"]
    PKA        [label="Protein Kinase A\n(PKA)",                         fillcolor="#f8c471"]
    HR_SNS     [label="Heart Rate↑\n(Tachycardia)",                      fillcolor="#e74c3c"]
    Contr_SNS  [label="Contractility↑\n(Short-term benefit)",            fillcolor="#f39c12"]
    RenStim    [label="Renin Release↑\n(JGA β1AR)",                      fillcolor="#e67e22"]
    Vasocon_S  [label="Vasoconstriction\n(α1AR → SVR↑)",                 fillcolor="#c0392b"]
    Baro       [label="Baroreceptor Reflex\n(Blunted in HFrEF)",         fillcolor="#e67e22"]
    NE_spill   [label="Cardiac NE Spillover\n(Marker: ↑plasma NE)",      fillcolor="#e74c3c"]
  }

  // ─────────────────────────────────────────────────────────────
  // CLUSTER 3 — NATRIURETIC PEPTIDE SYSTEM (NPS)
  // ─────────────────────────────────────────────────────────────
  subgraph cluster_nps {
    label     = "Natriuretic Peptide System (NPS)"
    style     = filled
    fillcolor = "#001a10"
    color     = "#27ae60"
    penwidth  = 2

    WallStress [label="LV Wall Stress↑\n(Pressure/Volume\nOverload)",   fillcolor="#16a085"]
    ANP        [label="ANP\n(Atrial NP)\n[pg/mL]",                       fillcolor="#1abc9c"]
    BNP_syn    [label="BNP Gene Expression\n(myocardial stretch)",       fillcolor="#27ae60"]
    BNP        [label="BNP Plasma\n[pg/mL]\n★ Biomarker",               fillcolor="#27ae60" shape=diamond]
    NTproBNP   [label="NT-proBNP\n[pg/mL]\n★ Biomarker",               fillcolor="#1e8449" shape=diamond]
    CNP        [label="CNP (C-type NP)\n(Vascular endothelium)",         fillcolor="#17a589"]
    NPRA       [label="NPR-A Receptor\n(ANP/BNP target)",                fillcolor="#148f77"]
    NPRB       [label="NPR-B Receptor\n(CNP target)",                    fillcolor="#0e6655"]
    cGMP_NPS   [label="cGMP↑\n(intracellular)",                          fillcolor="#1abc9c"]
    PKG        [label="Protein Kinase G\n(PKG)",                         fillcolor="#1abc9c"]
    PDE5_enz   [label="PDE5\n(cGMP degradation)",                        fillcolor="#e74c3c"]
    Vasodil_N  [label="Vasodilation\n+ Natriuresis\n(cardioprotective)", fillcolor="#27ae60"]
  }

  // ─────────────────────────────────────────────────────────────
  // CLUSTER 4 — CARDIAC REMODELING
  // ─────────────────────────────────────────────────────────────
  subgraph cluster_remod {
    label     = "Cardiac Remodeling"
    style     = filled
    fillcolor = "#1a0000"
    color     = "#e74c3c"
    penwidth  = 2

    CM         [label="Cardiomyocyte\n(Contractile unit)",               fillcolor="#922b21"]
    CM_hyp     [label="CM Hypertrophy\n(NFAT / MEK-ERK /\nPI3K-Akt)",   fillcolor="#c0392b"]
    CM_apo     [label="CM Apoptosis\n(Caspase-3/Cytochrome c)",          fillcolor="#e74c3c"]
    CM_nec     [label="CM Necrosis\n(Mitochondrial\npermeability pore)", fillcolor="#e74c3c"]
    FB         [label="Cardiac Fibroblast\n(resting)",                   fillcolor="#7f8c8d"]
    MFB        [label="Myofibroblast\n(α-SMA⁺, activated)",             fillcolor="#e67e22"]
    TGFb1      [label="TGF-β1↑\n(pro-fibrotic\nmediator)",              fillcolor="#c0392b"]
    ColI       [label="Collagen Type I↑\n(scar formation)",              fillcolor="#e74c3c"]
    ColIII     [label="Collagen Type III↑\n(early fibrosis)",            fillcolor="#e74c3c"]
    MMP_enz    [label="MMP-2/9\n(matrix degradation)",                   fillcolor="#e67e22"]
    TIMP_prot  [label="TIMP-1/2\n(MMP inhibitor↑ in HF)",               fillcolor="#e67e22"]
    ECM_rem    [label="ECM Remodeling\n(net excess collagen)",           fillcolor="#922b21"]
    LV_dil     [label="LV Dilation\n(↑LVEDV, wall thinning)",           fillcolor="#c0392b"]
    LVEF_dec   [label="LVEF Decline\n(systolic dysfunction)",            fillcolor="#e74c3c" shape=diamond]
    DD         [label="Diastolic Dysfunction\n(filling pressure↑)",      fillcolor="#922b21"]
  }

  // ─────────────────────────────────────────────────────────────
  // CLUSTER 5 — INFLAMMATION & OXIDATIVE STRESS
  // ─────────────────────────────────────────────────────────────
  subgraph cluster_inflam {
    label     = "Inflammation & Oxidative Stress"
    style     = filled
    fillcolor = "#1a0510"
    color     = "#e91e63"
    penwidth  = 2

    TNFa       [label="TNF-α↑\n(cardiodepressant)",                     fillcolor="#ad1457"]
    IL6        [label="IL-6↑\n(→CRP, STAT3\nsignaling)",               fillcolor="#c2185b"]
    IL1b       [label="IL-1β↑\n(NLRP3 inflammasome)",                   fillcolor="#d81b60"]
    NFkB       [label="NF-κB\n(master\ninflammation TF)",               fillcolor="#880e4f" fontcolor=white]
    NOX2       [label="NADPH Oxidase 2\n(NOX2)",                         fillcolor="#6a1b9a"]
    ROS        [label="Reactive Oxygen\nSpecies (ROS↑)",                 fillcolor="#e91e63"]
    Mito_dys   [label="Mitochondrial\nDysfunction\n(ETC leak, ΔΨm↓)",  fillcolor="#880e4f" fontcolor=white]
    iNOS       [label="iNOS→Peroxynitrite\n(NO-ROS coupling)",          fillcolor="#c62828"]
    NLRP3      [label="NLRP3 Inflammasome\n(caspase-1 → IL-1β/18)",    fillcolor="#ad1457"]
    Inflamm_a  [label="Inflammasome\nActivation",                        fillcolor="#880e4f" fontcolor=white]
    CRP        [label="CRP↑\n(Systemic marker)",                        fillcolor="#c2185b" shape=diamond]
    Mono_infil [label="Monocyte/Macrophage\nInfiltration\n(M1→injury)", fillcolor="#d81b60"]
  }

  // ─────────────────────────────────────────────────────────────
  // CLUSTER 6 — HEMODYNAMICS
  // ─────────────────────────────────────────────────────────────
  subgraph cluster_hemo {
    label     = "Hemodynamics"
    style     = filled
    fillcolor = "#001520"
    color     = "#3498db"
    penwidth  = 2

    LVEDV      [label="LVEDV↑\n(Preload / EDV)\n[mL]",                  fillcolor="#1565c0" fontcolor=white]
    LVESV      [label="LVESV↑\n(End-systolic vol)\n[mL]",               fillcolor="#0d47a1" fontcolor=white]
    CO         [label="Cardiac Output\n(CO = HR × SV)\n[L/min]",        fillcolor="#1976d2" fontcolor=white]
    SV         [label="Stroke Volume\n(SV)\n[mL]",                       fillcolor="#1976d2" fontcolor=white]
    LVEF_hem   [label="LVEF\n(= SV/LVEDV)\n★ Primary endpoint",        fillcolor="#1e88e5" fontcolor=white shape=diamond]
    SVR        [label="Systemic Vascular\nResistance (SVR)\n[dynes·s/cm⁵]", fillcolor="#1565c0" fontcolor=white]
    MAP_h      [label="MAP↓\n(Mean Arterial Pressure)",                  fillcolor="#1976d2" fontcolor=white]
    PCWP       [label="PCWP↑\n(Pulmonary Wedge\nPressure) ≥18 mmHg",   fillcolor="#0288d1" fontcolor=white]
    PAP        [label="PAP↑\n(Pulmonary Artery\nPressure)",             fillcolor="#0277bd" fontcolor=white]
    CVP        [label="CVP↑\n(Central Venous\nPressure)",               fillcolor="#01579b" fontcolor=white]
    HR_h       [label="Heart Rate\n(HR) [bpm]",                          fillcolor="#1565c0" fontcolor=white]
    Cong       [label="Congestion\n(Dyspnea, Edema,\nOrthopnea)",       fillcolor="#e74c3c"]
  }

  // ─────────────────────────────────────────────────────────────
  // CLUSTER 7 — PHARMACOLOGY (PK/PD)
  // ─────────────────────────────────────────────────────────────
  subgraph cluster_drugs {
    label     = "Drug Pharmacology (PK/PD)"
    style     = filled
    fillcolor = "#001a1a"
    color     = "#00bcd4"
    penwidth  = 2

    // ARNI
    Sacubitril [label="Sacubitril\n(pro-drug)",                          fillcolor="#006064" fontcolor=white]
    LBQ657     [label="LBQ657\n(active NEPi\nmetabolite)",               fillcolor="#00838f" fontcolor=white]
    Valsar_A   [label="Valsartan\n(ARB component)",                      fillcolor="#006064" fontcolor=white]
    NEP_inhib  [label="Neprilysin Inhibition\n(↓BNP degradation\n→BNP plasma↑,\nAng1-7↑)", fillcolor="#0097a7" fontcolor=white]

    // ACEi
    Enalapril  [label="Enalapril\n(ACE Inhibitor)",                      fillcolor="#0277bd" fontcolor=white]
    ACEi_eff   [label="ACEi Effect\n(↓AngII, ↑BK,\n↑Ang1-7)",         fillcolor="#0288d1" fontcolor=white]

    // β-blockers
    Metoprolol [label="Metoprolol\n(β1-selective)",                      fillcolor="#37474f" fontcolor=white]
    Carvedilol [label="Carvedilol\n(β1/β2/α1-blocker)",                  fillcolor="#37474f" fontcolor=white]
    BB_eff     [label="β-Blocker Effect\n(↓HR, ↓Renin,\n↓cAMP/PKA,\nreverse remodeling)", fillcolor="#546e7a" fontcolor=white]

    // MRA
    Spirono    [label="Spironolactone\n(non-selective MRA)",             fillcolor="#4a148c" fontcolor=white]
    Eplerenone [label="Eplerenone\n(selective MRA)",                     fillcolor="#4a148c" fontcolor=white]
    Finerenone [label="Finerenone\n(non-steroidal MRA)",                 fillcolor="#6a1b9a" fontcolor=white]
    MRA_eff    [label="MRA Effect\n(↓Aldosterone signaling\n↓Na-ret, ↓Fibrosis,\n↑K⁺)", fillcolor="#7b1fa2" fontcolor=white]

    // SGLT2i
    Dapagli    [label="Dapagliflozin\n(SGLT2i)",                        fillcolor="#1b5e20" fontcolor=white]
    Empagli    [label="Empagliflozin\n(SGLT2i)",                        fillcolor="#1b5e20" fontcolor=white]
    SGLT2_eff  [label="SGLT2i Effect\n(Osmotic diuresis,\nHematocrit↑,\nAutophagy↑,\nNa⁺/H⁺ exchanger↓)", fillcolor="#2e7d32" fontcolor=white]
    Cardiac_DM [label="Direct Cardiac\nEffect (SGLT2i)\n(NHE1↓→Ca²⁺ overload↓\nmitochondrial benefit)", fillcolor="#388e3c" fontcolor=white]

    // Ivabradine
    Ivabradine [label="Ivabradine\n(HCN channel If-blocker)",           fillcolor="#e65100" fontcolor=white]
    If_block   [label="HCN/If Channel Block\n(↓HR at rest+exercise\nno negative inotropy)", fillcolor="#ef6c00" fontcolor=white]

    // Diuretics
    Furosemide [label="Furosemide\n(Loop diuretic)",                    fillcolor="#4e342e" fontcolor=white]
    Loop_eff   [label="Loop Diuretic Effect\n(↓Preload/LVEDV,\n↓Congestion,\nSymptom relief)", fillcolor="#5d4037" fontcolor=white]

    // Digoxin
    Digoxin    [label="Digoxin\n(Na/K-ATPase inhibitor)",               fillcolor="#263238" fontcolor=white]
    Dig_eff    [label="Digoxin Effect\n(↑[Na]i→↑[Ca]i→\n↑Contractility,\n↓HR via vagal↑)", fillcolor="#37474f" fontcolor=white]
  }

  // ─────────────────────────────────────────────────────────────
  // CLUSTER 8 — CLINICAL ENDPOINTS
  // ─────────────────────────────────────────────────────────────
  subgraph cluster_endpoints {
    label     = "Clinical Endpoints & Biomarkers"
    style     = filled
    fillcolor = "#0a0a1a"
    color     = "#9c27b0"
    penwidth  = 2

    NYHA       [label="NYHA Class\n(I–IV)\n★ Symptom endpoint",         fillcolor="#6a1b9a" fontcolor=white shape=diamond]
    HF_hosp    [label="HF Hospitalization\n(Rate/10,000 p-y)\n★ Morbidity endpoint", fillcolor="#7b1fa2" fontcolor=white shape=diamond]
    CV_death   [label="CV Death\n(★ Primary endpoint)",                 fillcolor="#4a148c" fontcolor=white shape=diamond]
    AllCause   [label="All-Cause Mortality\n★ Endpoint",                fillcolor="#4a148c" fontcolor=white shape=diamond]
    SixMWT     [label="6-Minute Walk Test\n(6MWT, meters)",              fillcolor="#6a1b9a" fontcolor=white shape=diamond]
    KCCQ       [label="KCCQ Score\n(QoL instrument\n0–100)",             fillcolor="#7b1fa2" fontcolor=white shape=diamond]
    EF_resp    [label="EF Response\n(≥10% absolute ↑\n= reverse remodeling)", fillcolor="#8e24aa" fontcolor=white shape=diamond]
    BNP_resp   [label="BNP/NT-proBNP\nReduction ≥30%\n★ Surrogate endpoint", fillcolor="#9c27b0" fontcolor=white shape=diamond]
    Rev_rem    [label="Reverse Remodeling\n(↓LVEDV, ↓LVESV,\n↑LVEF)",  fillcolor="#6a1b9a" fontcolor=white shape=diamond]
    MACE       [label="MACE\n(CV death + MI\n+ Stroke + HF-hosp)",      fillcolor="#4a148c" fontcolor=white shape=diamond]
  }

  // ─────────────────────────────────────────────────────────────
  // CLUSTER 9 — COMORBIDITIES
  // ─────────────────────────────────────────────────────────────
  subgraph cluster_comorbid {
    label     = "Comorbidities & Aggravating Factors"
    style     = filled
    fillcolor = "#1a1a00"
    color     = "#f9a825"
    penwidth  = 2

    HTN        [label="Hypertension\n(↑Afterload → concentric\nhypertrophy → HFpEF→HFrEF)", fillcolor="#f57f17" fontcolor=white]
    T2DM_co    [label="Type 2 Diabetes\n(↑AGEs, PKC, ROS\n→ cardiomyopathy)",              fillcolor="#e65100" fontcolor=white]
    CKD_co     [label="Chronic Kidney Disease\n(↓Drug clearance,\nRAAS ↑, Diuretic resist.)", fillcolor="#bf360c" fontcolor=white]
    AFib_co    [label="Atrial Fibrillation\n(↓CO, ↑PCWP,\ntachycardia-induced CM)",        fillcolor="#f57f17" fontcolor=white]
    Anemia_co  [label="Iron Deficiency Anemia\n(↑CO demand,\nFerric carboxymaltose)",       fillcolor="#ff8f00" fontcolor=white]
    OSA_co     [label="Obstructive Sleep Apnea\n(Intermittent hypoxia,\n↑SNS, ↑BP)",       fillcolor="#f9a825" fontcolor=white]
    Obesity_co [label="Obesity\n(Adipokines, ↑Preload,\nSleep apnea risk)",                fillcolor="#ffa000" fontcolor=white]
    Etiology   [label="Etiology\n(CAD/MI, Dilated CM\nHypertensive, Valvular\nAlcohol/Toxic/Viral)", fillcolor="#e65100" fontcolor=white shape=diamond]
  }

  // ═══════════════════════════════════════════════════════════
  // EDGES — RAAS
  // ═══════════════════════════════════════════════════════════
  RAAS_act -> Renin       [label="stimulates"]
  AGT      -> AngI        [label="Renin cleaves"]
  Renin    -> AngI        [label="↑"]
  PRR      -> Renin       [label="activates"]
  AngI     -> AngII       [label="ACE converts"]
  ACE      -> AngII       [label="catalyzes"]
  AngI     -> Ang17       [label="ACE2 converts"]
  ACE2     -> Ang17       [label="catalyzes"]
  AngII    -> AT1R        [label="binds"]
  AngII    -> AT2R        [label="binds (minority)"]
  Ang17    -> MasR        [label="binds"]
  AT1R     -> AT1R_sig    [label="activates"]
  AT1R_sig -> Aldo        [label="→Adrenal stimulation"]
  AT1R_sig -> Na_ret      [label="→Kidney"]
  AT1R_sig -> K_exc       [label="secondary"]
  AT1R_sig -> TGFb1       [label="→Fibrosis"]
  AT1R_sig -> CM_hyp      [label="→MAPK/NFAT"]
  AT1R_sig -> Vasocon_S   [label="→SVR↑"]
  AT2R     -> Vasodil_N   [label="counter-regulatory"]
  MasR     -> Vasodil_N   [label="NO↑/anti-fibrotic"]
  Aldo     -> MR          [label="activates"]
  MR       -> Na_ret      [label="ENaC/Na-K-ATPase↑"]
  MR       -> TGFb1       [label="→Fibrosis↑"]
  MR       -> K_exc       [label="urinary K+ loss"]
  BK       -> BK2R        [label="binds"]
  BK2R     -> Vasodil_N   [label="eNOS→NO↑"]
  NEP      -> BK          [label="degrades"]
  NEP      -> ANP         [label="degrades"]
  NEP      -> BNP         [label="degrades (NEPi→↑BNP)"]
  NEP      -> Ang17       [label="degrades"]

  // ═══════════════════════════════════════════════════════════
  // EDGES — SNS
  // ═══════════════════════════════════════════════════════════
  CNS_act  -> SNA         [label="↑efferent output"]
  SNA      -> NE_plasma   [label="↑spillover"]
  SNA      -> NE_spill    [label="cardiac NE↑"]
  NE_plasma -> B1AR       [label="binds"]
  NE_plasma -> A1AR       [label="binds"]
  Epi      -> B2AR        [label="adrenal→vessels"]
  B1AR     -> Gs_cAMP     [label="Gαs activation"]
  Gs_cAMP  -> PKA         [label="→PKA"]
  PKA      -> HR_SNS      [label="Phospholam-\nban/SERCA"]
  PKA      -> Contr_SNS   [label="Troponin I /\nRyR2 phosph"]
  B1AR     -> RenStim     [label="JGA renin↑"]
  RenStim  -> RAAS_act    [label="→"]
  A1AR     -> Vasocon_S   [label="IP3→Ca2+→\nvasoconstriction"]
  Baro     -> CNS_act     [label="blunted reflex\ninhibition"]
  NE_spill -> CM_apo      [label="chronic toxicity\n(β1-AR downreg)"]
  NE_spill -> ROS         [label="oxidative stress"]

  // ═══════════════════════════════════════════════════════════
  // EDGES — NPS
  // ═══════════════════════════════════════════════════════════
  WallStress -> ANP       [label="atrial stretch"]
  WallStress -> BNP_syn   [label="ventricular stretch"]
  BNP_syn    -> BNP       [label="co-released with\nNT-proBNP"]
  BNP_syn    -> NTproBNP  [label="N-terminal cleavage"]
  BNP        -> NPRA      [label="binds"]
  ANP        -> NPRA      [label="binds"]
  CNP        -> NPRB      [label="binds"]
  NPRA       -> cGMP_NPS  [label="guanylyl cyclase"]
  NPRB       -> cGMP_NPS  [label="guanylyl cyclase"]
  cGMP_NPS   -> PKG       [label="activates"]
  PKG        -> Vasodil_N [label="↓Ca2+→smooth\nmuscle relax"]
  PKG        -> ECM_rem   [label="anti-fibrotic"]
  PDE5_enz   -> cGMP_NPS  [label="degrades (↓)"]

  // ═══════════════════════════════════════════════════════════
  // EDGES — CARDIAC REMODELING
  // ═══════════════════════════════════════════════════════════
  WallStress -> CM_hyp    [label="mechanical stretch\n→MAPK/Akt/mTOR"]
  TGFb1      -> FB        [label="activates"]
  FB         -> MFB       [label="transdifferentiation"]
  MFB        -> ColI      [label="secretes"]
  MFB        -> ColIII    [label="secretes"]
  MFB        -> TIMP_prot [label="secretes"]
  ColI       -> ECM_rem   [label="accumulates"]
  ColIII     -> ECM_rem   [label="accumulates"]
  MMP_enz    -> ECM_rem   [label="degrades ECM\n(net ↓in HF)"]
  TIMP_prot  -> MMP_enz   [label="inhibits"]
  ECM_rem    -> LV_dil    [label="→eccentric\nhypertrophy"]
  LV_dil     -> LVEDV     [label="↑"]
  LV_dil     -> WallStress [label="Laplace: T=Pr/2h"]
  CM_hyp     -> LVEF_dec  [label="maladaptive\nhypertrophy"]
  CM_apo     -> LVEF_dec  [label="↓contractile units"]
  CM_nec     -> LVEF_dec  [label="↓contractile mass"]
  LVEF_dec   -> LVEF_hem  [label="≡"]
  ROS        -> CM_apo    [label="oxidative cell death"]
  ROS        -> Mito_dys  [label="ETC damage"]
  Mito_dys   -> CM_nec    [label="ATP↓, mPTP open"]
  TNFa       -> CM_apo    [label="caspase cascade"]
  IL1b       -> TGFb1     [label="cross-talk↑"]

  // ═══════════════════════════════════════════════════════════
  // EDGES — INFLAMMATION
  // ═══════════════════════════════════════════════════════════
  AT1R_sig  -> NFkB       [label="IKK activation"]
  NFkB      -> TNFa       [label="transcription↑"]
  NFkB      -> IL6        [label="transcription↑"]
  NFkB      -> IL1b       [label="transcription↑"]
  NOX2      -> ROS        [label="superoxide O₂⁻"]
  NE_plasma -> NOX2       [label="adrenergic→NOX2"]
  IL1b      -> NLRP3      [label="primes"]
  NLRP3     -> Inflamm_a  [label="assembles"]
  Inflamm_a -> IL1b       [label="auto-amplification"]
  IL6       -> CRP        [label="hepatic synthesis"]
  Mono_infil -> TNFa      [label="secretes"]
  ROS       -> iNOS       [label="→peroxynitrite\nNO scavenging"]
  AngII     -> NOX2       [label="AT1R→PKC→\nNOX2 assembly"]

  // ═══════════════════════════════════════════════════════════
  // EDGES — HEMODYNAMICS
  // ═══════════════════════════════════════════════════════════
  LVEDV    -> SV          [label="Frank-Starling\n(↑EDV→↑SV up\nto limit)"]
  LVESV    -> SV          [label="SV = EDV−ESV"]
  SV       -> CO          [label="CO = HR × SV"]
  HR_h     -> CO          [label=""]
  CO       -> MAP_h       [label="MAP = CO × SVR"]
  SVR      -> MAP_h       [label=""]
  PCWP     -> Cong        [label="↑pulmonary\npressure → dyspnea"]
  PAP      -> Cong        [label="↑RV afterload"]
  CVP      -> Cong        [label="↑venous pressure\n→peripheral edema"]
  CO       -> Baro        [label="low CO→blunted\nreflex → SNS↑"]
  MAP_h    -> RAAS_act    [label="↓MAP→ renin↑"]
  SVR      -> LV_dil      [label="↑afterload →\neccentric hypertrophy"]
  LVEF_hem -> SV          [label="EF = SV/LVEDV"]
  Cong     -> NYHA        [label="→symptom\nseverity"]
  Cong     -> HF_hosp     [label="decompensation"]

  // ═══════════════════════════════════════════════════════════
  // EDGES — DRUGS
  // ═══════════════════════════════════════════════════════════
  // ARNI
  Sacubitril -> LBQ657    [label="esterases\n(prodrug→active)"]
  LBQ657     -> NEP_inhib [label="competitive\nNEP inhibition"]
  NEP_inhib  -> BNP       [label="↑BNP plasma\n(less degradation)"]
  NEP_inhib  -> Ang17     [label="↑Ang1-7"]
  Valsar_A   -> AT1R      [label="ARB: blocks\nAngII binding"]
  Valsar_A   -> AT1R_sig  [label="↓downstream\nsignaling"]

  // ACEi
  Enalapril  -> ACEi_eff  [label="active enalaprilat"]
  ACEi_eff   -> ACE       [label="inhibits (competitive)"]
  ACEi_eff   -> AngII     [label="↓production"]
  ACEi_eff   -> BK        [label="↑bradykinin\n(ACE degrades BK)"]

  // β-blockers
  Metoprolol -> BB_eff    [label="β1-selective block"]
  Carvedilol -> BB_eff    [label="β1/β2/α1 block\n+ antioxidant"]
  BB_eff     -> B1AR      [label="competitive\nantagonist"]
  BB_eff     -> HR_h      [label="↓HR (chronotropy)"]
  BB_eff     -> Contr_SNS [label="↓inotropy (acute)\n↑EF (chronic)"]
  BB_eff     -> RenStim   [label="↓renin release"]
  BB_eff     -> CM_apo    [label="↓(chronic BB\nreduces apoptosis)"]

  // MRA
  Spirono    -> MRA_eff   [label="steroidal MRA"]
  Eplerenone -> MRA_eff   [label="selective MRA"]
  Finerenone -> MRA_eff   [label="non-steroidal\n(HF+CKD/T2DM)"]
  MRA_eff    -> MR        [label="competitive block"]
  MRA_eff    -> Na_ret    [label="↓Na reabsorption"]
  MRA_eff    -> TGFb1     [label="↓fibrotic signaling"]
  MRA_eff    -> ColI      [label="↓collagen deposition"]
  MRA_eff    -> K_exc     [label="↓K+ excretion\n(hyperkalemia risk)"]

  // SGLT2i
  Dapagli    -> SGLT2_eff [label="SGLT2 inhibition\n(kidney tubule)"]
  Empagli    -> SGLT2_eff [label="SGLT2 inhibition"]
  SGLT2_eff  -> Na_ret    [label="↓Na-glucose\ncotransport → diuresis"]
  SGLT2_eff  -> LVEDV     [label="↓Preload (diuresis)"]
  SGLT2_eff  -> Cardiac_DM [label="direct\ncardiac effects"]
  Cardiac_DM -> Mito_dys  [label="↓(improved\nmitochondrial fxn)"]
  Cardiac_DM -> ROS       [label="↓oxidative stress"]
  Cardiac_DM -> CM_apo    [label="↓apoptosis (NHE1↓)"]

  // Ivabradine
  Ivabradine -> If_block  [label="HCN current\nblock"]
  If_block   -> HR_h      [label="↓HR selectively\n(no inotropy effect)"]

  // Furosemide
  Furosemide -> Loop_eff  [label="Na-K-2Cl block\n(loop of Henle)"]
  Loop_eff   -> LVEDV     [label="↓preload"]
  Loop_eff   -> Cong      [label="↓congestion\n(symptom relief)"]
  Loop_eff   -> K_exc     [label="hypokalemia risk"]

  // Digoxin
  Digoxin    -> Dig_eff   [label="Na/K-ATPase\ninhibition"]
  Dig_eff    -> Contr_SNS [label="↑inotropy\n(modest)"]
  Dig_eff    -> HR_h      [label="↓HR\n(vagal↑)"]
  Dig_eff    -> HF_hosp   [label="↓hospitalizations\n(PROVED/RADIANCE)"]

  // ═══════════════════════════════════════════════════════════
  // EDGES — TO CLINICAL ENDPOINTS
  // ═══════════════════════════════════════════════════════════
  LVEF_hem   -> EF_resp   [label="≥50% = normalized"]
  LVEDV      -> Rev_rem   [label="↓LVEDV\n= reverse remod"]
  CO         -> NYHA      [label="↓CO→exertional\nsymptoms"]
  Cong       -> NYHA      [label="↑NYHA class"]
  BNP        -> BNP_resp  [label="primary\nbiomarker"]
  NTproBNP   -> BNP_resp  [label="more stable\nbiomarker"]
  HF_hosp    -> CV_death  [label="hospitalization\n→risk↑"]
  MACE       -> AllCause  [label="component of MACE"]
  CV_death   -> AllCause  [label="component"]
  NYHA       -> SixMWT    [label="functional capacity"]
  NYHA       -> KCCQ      [label="QoL correlation"]
  Rev_rem    -> EF_resp   [label="favorable remodeling"]
  Rev_rem    -> LVEF_hem  [label="↑EF"]
  Rev_rem    -> CV_death  [label="↓mortality"]

  // ═══════════════════════════════════════════════════════════
  // EDGES — COMORBIDITIES
  // ═══════════════════════════════════════════════════════════
  HTN        -> SVR       [label="↑afterload"]
  HTN        -> LV_dil    [label="chronic\npressure overload"]
  T2DM_co    -> ROS       [label="glucotoxicity\n→oxidative stress"]
  T2DM_co    -> TGFb1     [label="AGE-RAGE\naxis"]
  CKD_co     -> RAAS_act  [label="↑renin\n(reduced nephrons)"]
  CKD_co     -> K_exc     [label="↓K excretion\n(hyperkalemia risk)"]
  AFib_co    -> HR_h      [label="tachycardia"]
  AFib_co    -> SV        [label="↓SV (loss\nof atrial kick)"]
  Anemia_co  -> CO        [label="↑CO demand\n→volume overload"]
  OSA_co     -> SNA       [label="intermittent hypoxia\n→↑SNS"]
  OSA_co     -> ROS       [label="hypoxia-reoxygenation\n→ROS"]
  Obesity_co -> LVEDV     [label="↑blood volume\n→↑preload"]
  Etiology   -> CM_nec    [label="MI → scar\n→loss of CM"]
  Etiology   -> LV_dil    [label="DCM, ischemia"]
}
