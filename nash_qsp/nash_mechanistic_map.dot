/* ============================================================
   QSP Mechanistic Map: Non-Alcoholic Steatohepatitis (NASH)
   Disease: 비알코올성 지방간질환 (NAFLD/NASH)
   Version: 1.0  |  Date: 2026-06-16
   Nodes: 130+   |  Edges: 150+
   ============================================================ */

digraph NASH_QSP {

  /* ---- Global graph styling ---- */
  graph [
    fontname   = "Helvetica"
    fontsize   = 11
    splines    = "curved"
    overlap    = "prism"
    K          = 1.2
    label      = "NASH / NAFLD  —  Quantitative Systems Pharmacology Map\n(비알코올성 지방간질환 QSP 기전 지도)"
    labelloc   = "t"
    labeljust  = "c"
    bgcolor    = "#FAFAFA"
  ]
  node [fontname="Helvetica" fontsize=9 style="filled,rounded" shape=box margin="0.12,0.06"]
  edge [fontname="Helvetica" fontsize=8 arrowsize=0.7]

  /* ============================================================
     SUBGRAPH 1: ADIPOSE / SYSTEMIC METABOLIC INPUTS
     ============================================================ */
  subgraph cluster_adipose {
    label     = "Adipose Tissue & Systemic Metabolism"
    style     = "filled,rounded"
    fillcolor = "#FFF3E0"
    fontcolor = "#E65100"
    fontsize  = 10

    FFA_plasma   [label="FFA\n(Plasma)" fillcolor="#FFCC80"]
    TG_adipose   [label="TG\n(Adipose)" fillcolor="#FFCC80"]
    Adiponectin  [label="Adiponectin" fillcolor="#A5D6A7" shape=ellipse]
    Leptin       [label="Leptin" fillcolor="#EF9A9A" shape=ellipse]
    Resistin     [label="Resistin" fillcolor="#EF9A9A" shape=ellipse]
    TNFa_adipose [label="TNF-α\n(Adipose)" fillcolor="#EF5350" fontcolor=white]
    IL6_adipose  [label="IL-6\n(Adipose)" fillcolor="#EF5350" fontcolor=white]
    Obesity      [label="Obesity /\nCaloric Excess" fillcolor="#FFAB40" shape=diamond]
    IR_systemic  [label="Insulin Resistance\n(Systemic)" fillcolor="#FF7043" fontcolor=white]
  }

  /* ============================================================
     SUBGRAPH 2: PANCREAS / GLUCOSE-INSULIN AXIS
     ============================================================ */
  subgraph cluster_pancreas {
    label     = "Pancreas / GI — Glucose-Insulin Axis"
    style     = "filled,rounded"
    fillcolor = "#E8F5E9"
    fontcolor = "#1B5E20"
    fontsize  = 10

    Glucose_plasma  [label="Glucose\n(Plasma)" fillcolor="#C8E6C9"]
    Insulin_plasma  [label="Insulin\n(Plasma)" fillcolor="#66BB6A"]
    Glucagon        [label="Glucagon" fillcolor="#A5D6A7"]
    GLP1            [label="GLP-1" fillcolor="#81C784"]
    GIP             [label="GIP" fillcolor="#81C784"]
    Beta_cell       [label="Pancreatic\nβ-cell" fillcolor="#2E7D32" fontcolor=white]
    Insulin_secret  [label="Insulin\nSecretion" fillcolor="#4CAF50"]
    Insulin_clear   [label="Insulin\nClearance" fillcolor="#EF9A9A"]
  }

  /* ============================================================
     SUBGRAPH 3: HEPATOCYTE — LIPID METABOLISM
     ============================================================ */
  subgraph cluster_hepatocyte_lipid {
    label     = "Hepatocyte — Lipid Metabolism"
    style     = "filled,rounded"
    fillcolor = "#E3F2FD"
    fontcolor = "#0D47A1"
    fontsize  = 10

    FFA_liver      [label="FFA\n(Liver)" fillcolor="#90CAF9"]
    TG_liver       [label="TG\n(Liver)" fillcolor="#42A5F5"]
    VLDL_secretion [label="VLDL\nSecretion" fillcolor="#1E88E5" fontcolor=white]
    Steatosis      [label="Hepatic\nSteatosis" fillcolor="#1565C0" fontcolor=white]
    DNL            [label="De Novo\nLipogenesis (DNL)" fillcolor="#64B5F6"]
    FASN           [label="FAS / ACC1\n(Lipogenic Enzymes)" fillcolor="#90CAF9"]
    SREBP1c        [label="SREBP-1c" fillcolor="#42A5F5"]
    ChREBP         [label="ChREBP" fillcolor="#42A5F5"]
    CPT1a          [label="CPT1α\n(Mito. Import)" fillcolor="#29B6F6"]
    FAO            [label="β-Oxidation\n(Mitochondrial)" fillcolor="#0288D1" fontcolor=white]
    Acetyl_CoA     [label="Acetyl-CoA" fillcolor="#B3E5FC"]
    MalonylCoA     [label="Malonyl-CoA" fillcolor="#B3E5FC"]
    Ketogenesis    [label="Ketogenesis" fillcolor="#81D4FA"]
    AMPK           [label="AMPK" fillcolor="#0277BD" fontcolor=white shape=ellipse]
    IR_insulin_sig [label="Insulin Receptor\nSignaling (IRS1/Akt)" fillcolor="#1976D2" fontcolor=white]
    FOXO1          [label="FOXO1" fillcolor="#5C6BC0"]
    HGO            [label="Hepatic Glucose\nOutput (HGO)" fillcolor="#9FA8DA"]
    Gluconeogen    [label="Gluconeogenesis\n(PEPCK, G6Pase)" fillcolor="#7986CB"]
    Glycogenolysis [label="Glycogenolysis" fillcolor="#7986CB"]
  }

  /* ============================================================
     SUBGRAPH 4: OXIDATIVE STRESS & ER STRESS
     ============================================================ */
  subgraph cluster_oxstress {
    label     = "Oxidative Stress / ER Stress / Mitochondria"
    style     = "filled,rounded"
    fillcolor = "#FCE4EC"
    fontcolor = "#880E4F"
    fontsize  = 10

    ROS          [label="ROS\n(Reactive O₂ Species)" fillcolor="#F48FB1"]
    Mito_dysfunc [label="Mitochondrial\nDysfunction" fillcolor="#E91E63" fontcolor=white]
    Nrf2         [label="Nrf2" fillcolor="#F06292" shape=ellipse]
    NQO1         [label="NQO1 / HO-1\n(Antioxidant enzymes)" fillcolor="#F8BBD0"]
    GSH          [label="Glutathione\n(GSH)" fillcolor="#A5D6A7"]
    LipidPerox   [label="Lipid Peroxidation\n(4-HNE, MDA)" fillcolor="#E91E63" fontcolor=white]
    ER_stress    [label="ER Stress" fillcolor="#C2185B" fontcolor=white]
    PERK_path    [label="PERK / eIF2α\nPathway" fillcolor="#F06292"]
    IRE1a        [label="IRE1α / XBP1s" fillcolor="#F06292"]
    ATF6         [label="ATF6" fillcolor="#F06292"]
    CHOP         [label="CHOP\n(Pro-apoptotic)" fillcolor="#AD1457" fontcolor=white]
    JNK12        [label="JNK1/2\nActivation" fillcolor="#D81B60" fontcolor=white]
    Apoptosis    [label="Hepatocyte\nApoptosis" fillcolor="#880E4F" fontcolor=white shape=diamond]
    Casp37       [label="Caspase 3/7" fillcolor="#C62828" fontcolor=white]
    Ballooning   [label="Hepatocellular\nBallooning" fillcolor="#B71C1C" fontcolor=white]
    ASK1         [label="ASK1\n(MAP3K5)" fillcolor="#E53935" fontcolor=white shape=ellipse]
  }

  /* ============================================================
     SUBGRAPH 5: INNATE IMMUNITY — KUPFFER CELLS / INFLAMMATION
     ============================================================ */
  subgraph cluster_kupffer {
    label     = "Kupffer Cell — Innate Immunity & Inflammation"
    style     = "filled,rounded"
    fillcolor = "#FFF8E1"
    fontcolor = "#E65100"
    fontsize  = 10

    Kupffer      [label="Kupffer Cell\n(Activation)" fillcolor="#FFD54F" shape=ellipse]
    TLR4         [label="TLR4 Signaling" fillcolor="#FFB300"]
    LPS          [label="LPS\n(Portal Vein)" fillcolor="#FF8F00"]
    MyD88        [label="MyD88 / TRIF" fillcolor="#FFCA28"]
    NFkB         [label="NF-κB" fillcolor="#F57F17" fontcolor=white]
    TNFa_liver   [label="TNF-α\n(Liver)" fillcolor="#E53935" fontcolor=white]
    IL1b         [label="IL-1β" fillcolor="#E53935" fontcolor=white]
    IL6_liver    [label="IL-6\n(Liver)" fillcolor="#EF5350" fontcolor=white]
    IL8          [label="IL-8 / CXCL8" fillcolor="#EF9A9A"]
    MCP1         [label="MCP-1 / CCL2" fillcolor="#EF9A9A"]
    CCR2         [label="CCR2\n(MCP-1 Receptor)" fillcolor="#FFCC02" shape=ellipse]
    CCR5         [label="CCR5\n(on HSC/Monocyte)" fillcolor="#FFCC02" shape=ellipse]
    NLRP3        [label="NLRP3\nInflammasome" fillcolor="#FF6F00"]
    Casp1        [label="Caspase-1" fillcolor="#FF8F00"]
    IL18         [label="IL-18" fillcolor="#EF9A9A"]
    Pyroptosis   [label="Pyroptosis" fillcolor="#BF360C" fontcolor=white shape=diamond]
    Lob_inflam   [label="Lobular\nInflammation" fillcolor="#BF360C" fontcolor=white]
  }

  /* ============================================================
     SUBGRAPH 6: HEPATIC STELLATE CELLS — FIBROSIS
     ============================================================ */
  subgraph cluster_fibrosis {
    label     = "Hepatic Stellate Cell — Fibrosis Pathway"
    style     = "filled,rounded"
    fillcolor = "#EDE7F6"
    fontcolor = "#311B92"
    fontsize  = 10

    HSC_quiesc  [label="HSC\n(Quiescent)" fillcolor="#CE93D8" shape=ellipse]
    HSC_active  [label="HSC\n(Activated)" fillcolor="#7B1FA2" fontcolor=white shape=ellipse]
    TGFb1       [label="TGF-β1" fillcolor="#9C27B0" fontcolor=white]
    Smad23      [label="Smad2/3\n(Canonical)" fillcolor="#AB47BC"]
    Smad7       [label="Smad7\n(Inhibitory)" fillcolor="#CE93D8"]
    alphaSMA    [label="α-SMA\n(Myofibroblast marker)" fillcolor="#7B1FA2" fontcolor=white]
    Col1_Col3   [label="Collagen I / III\nDeposition" fillcolor="#6A1B9A" fontcolor=white]
    MMP_fib     [label="MMP-1/9/13\n(Matrix degradation)" fillcolor="#BA68C8"]
    TIMP1       [label="TIMP-1\n(MMP inhibitor)" fillcolor="#9C27B0" fontcolor=white]
    PDGF        [label="PDGF-BB\n(HSC Proliferation)" fillcolor="#E040FB"]
    CTGF        [label="CTGF / CCN2" fillcolor="#AB47BC"]
    Fibrosis    [label="Fibrosis Stage\n(F0 → F4)" fillcolor="#4A148C" fontcolor=white shape=diamond]
    PROC3       [label="PRO-C3\n(Fibrosis Biomarker)" fillcolor="#CE93D8"]
    ELF_score   [label="ELF Score\n(HA+TIMP1+PIIINP)" fillcolor="#B39DDB"]
  }

  /* ============================================================
     SUBGRAPH 7: GUT-LIVER AXIS
     ============================================================ */
  subgraph cluster_gut {
    label     = "Gut–Liver Axis"
    style     = "filled,rounded"
    fillcolor = "#E0F7FA"
    fontcolor = "#006064"
    fontsize  = 10

    Microbiota   [label="Gut Microbiota\n(Dysbiosis)" fillcolor="#80DEEA"]
    SCFAs        [label="Short-Chain\nFatty Acids (SCFAs)" fillcolor="#26C6DA"]
    Intestinal_P [label="Intestinal\nPermeability (↑)" fillcolor="#EF9A9A"]
    Tight_junc   [label="Tight Junctions\n(ZO-1, Occludin)" fillcolor="#80DEEA"]
    Portal_LPS   [label="Portal Vein\nLPS Flux" fillcolor="#FF7043"]
    BA_gut       [label="Bile Acids\n(Intestinal pool)" fillcolor="#00ACC1" fontcolor=white]
    FXR_gut      [label="FXR\n(Intestinal)" fillcolor="#00838F" fontcolor=white shape=ellipse]
    FGF15_19     [label="FGF15/19\n(Ileal → Portal)" fillcolor="#006064" fontcolor=white]
  }

  /* ============================================================
     SUBGRAPH 8: NUCLEAR RECEPTORS / BILE ACID SIGNALING
     ============================================================ */
  subgraph cluster_nuclearR {
    label     = "Nuclear Receptors / Bile Acid & Lipid Sensing"
    style     = "filled,rounded"
    fillcolor = "#F1F8E9"
    fontcolor = "#33691E"
    fontsize  = 10

    FXR_liver    [label="FXR\n(Hepatic)" fillcolor="#8BC34A" fontcolor=white shape=ellipse]
    BA_liver     [label="Bile Acids\n(Hepatic pool)" fillcolor="#558B2F" fontcolor=white]
    CYP7A1       [label="CYP7A1\n(BA synthesis)" fillcolor="#7CB342"]
    CYP27A1      [label="CYP27A1" fillcolor="#9CCC65"]
    NTCP         [label="NTCP\n(BA uptake)" fillcolor="#AED581"]
    BSEP         [label="BSEP\n(BA efflux)" fillcolor="#AED581"]
    SHP          [label="SHP\n(Represses CYP7A1)" fillcolor="#33691E" fontcolor=white]
    PPARa        [label="PPARα\n(FA oxidation)" fillcolor="#66BB6A" shape=ellipse]
    PPARg        [label="PPARγ\n(Adipogenesis)" fillcolor="#43A047" shape=ellipse]
    PPARd        [label="PPARδ\n(FA oxidation)" fillcolor="#2E7D32" fontcolor=white shape=ellipse]
    LXR          [label="LXR\n(Cholesterol)" fillcolor="#C5E1A5" shape=ellipse]
    FGF21        [label="FGF-21\n(Hepatokine)" fillcolor="#1B5E20" fontcolor=white]
    FGFR4        [label="FGFR4\n(FGF19 receptor)" fillcolor="#558B2F" fontcolor=white]
    THR_beta     [label="THRβ\n(Thyroid receptor β)" fillcolor="#33691E" fontcolor=white shape=ellipse]
  }

  /* ============================================================
     SUBGRAPH 9: DRUG PK/PD COMPARTMENTS
     ============================================================ */
  subgraph cluster_drugs {
    label     = "Drug PK/PD — Therapeutic Interventions"
    style     = "filled,rounded"
    fillcolor = "#E8EAF6"
    fontcolor = "#1A237E"
    fontsize  = 10

    /* ---- FXR Agonists ---- */
    OCA         [label="Obeticholic Acid\n(OCA / INT-747)\nFXR Agonist" fillcolor="#3F51B5" fontcolor=white]
    Cilofexor   [label="Cilofexor\n(Non-bile acid FXR Ag.)" fillcolor="#5C6BC0" fontcolor=white]

    /* ---- PPAR Agonists ---- */
    Lanifibranor [label="Lanifibranor\n(pan-PPARα/γ/δ Ag.)" fillcolor="#7986CB" fontcolor=white]
    Pemafibrate  [label="Pemafibrate\n(Selective PPARα)" fillcolor="#9FA8DA"]
    Pioglitazone [label="Pioglitazone\n(PPARγ Ag.)" fillcolor="#9FA8DA"]

    /* ---- ACC Inhibitor ---- */
    Firsocostat  [label="Firsocostat (ND-630)\nACC1/2 Inhibitor" fillcolor="#303F9F" fontcolor=white]

    /* ---- ASK1 Inhibitor ---- */
    Selonsertib  [label="Selonsertib (GS-4997)\nASK1 Inhibitor" fillcolor="#283593" fontcolor=white]

    /* ---- CCR Antagonist ---- */
    Cenicriviroc [label="Cenicriviroc\nCCR2/5 Antagonist" fillcolor="#3949AB" fontcolor=white]

    /* ---- GLP-1 RA ---- */
    Semaglutide  [label="Semaglutide\nGLP-1 RA" fillcolor="#1565C0" fontcolor=white]

    /* ---- THRβ Agonist ---- */
    Resmetirom   [label="Resmetirom (MGL-3196)\nTHRβ Agonist" fillcolor="#0D47A1" fontcolor=white]

    /* ---- SGLT2 Inhibitor ---- */
    Empagliflozin [label="Empagliflozin\nSGLT2 Inhibitor" fillcolor="#1E88E5" fontcolor=white]

    /* ---- SCD1 / FASN Inhibitor ---- */
    TVB2640      [label="TVB-2640\nFASN Inhibitor" fillcolor="#42A5F5"]
  }

  /* ============================================================
     SUBGRAPH 10: CLINICAL ENDPOINTS & BIOMARKERS
     ============================================================ */
  subgraph cluster_endpoints {
    label     = "Clinical Endpoints & Biomarkers"
    style     = "filled,rounded"
    fillcolor = "#FAFAFA"
    fontcolor = "#212121"
    fontsize  = 10

    NAS_score    [label="NAS Score\n(0–8)\nSteatosis+Inflammation+Ballooning" fillcolor="#37474F" fontcolor=white shape=diamond]
    Fibrosis_stg [label="Fibrosis Stage\n(Ishak / METAVIR)" fillcolor="#455A64" fontcolor=white shape=diamond]
    ALT          [label="ALT / AST\n(Hepatocyte Injury)" fillcolor="#78909C"]
    LStiffness   [label="Liver Stiffness\n(FibroScan / MRE)" fillcolor="#90A4AE"]
    MRI_PDFF     [label="MRI-PDFF\n(Steatosis %)" fillcolor="#90A4AE"]
    CK18         [label="CK-18 Fragments\n(Apoptosis marker)" fillcolor="#B0BEC5"]
    CXCL10_bm    [label="CXCL10\n(Inflammatory biomarker)" fillcolor="#CFD8DC"]
    Adiponect_bm [label="Adiponectin\n(Serum)" fillcolor="#A5D6A7"]
    FIB4         [label="FIB-4 Index\n(Non-invasive)" fillcolor="#B0BEC5"]
    BodyWeight   [label="Body Weight / BMI" fillcolor="#ECEFF1"]
    Dyslipidemia [label="Dyslipidemia\n(LDL-C, TG, HDL-C)" fillcolor="#CFD8DC"]
    HbA1c        [label="HbA1c\n(Glycemic Control)" fillcolor="#CFD8DC"]
  }

  /* ============================================================
     EDGES — Metabolic Inputs → Liver
     ============================================================ */

  /* Obesity feeds systemic insulin resistance */
  Obesity        -> IR_systemic [label="promotes" color="#E65100" style=bold]
  Obesity        -> FFA_plasma  [label="↑ lipolysis" color="#E65100"]
  Obesity        -> TNFa_adipose [label="adipokine" color="#E65100"]
  Obesity        -> IL6_adipose  [label="adipokine" color="#E65100"]
  Obesity        -> Leptin       [label="↑" color="#E65100"]
  Obesity        -> Adiponectin  [label="↓" color="#EF5350" arrowhead=tee]
  IR_systemic    -> IR_insulin_sig [label="impairs" color="#FF7043" style=dashed]
  IR_systemic    -> FFA_plasma    [label="↑ lipolysis" color="#FF7043"]

  /* Adipokine signaling */
  Adiponectin    -> AMPK      [label="activates" color="#43A047"]
  Adiponectin    -> PPARa     [label="↑ expression" color="#43A047"]
  Leptin         -> NFkB      [label="activates" color="#E53935"]
  Resistin       -> IR_systemic [label="promotes" color="#E53935"]
  TNFa_adipose   -> IR_systemic [label="Ser307 IRS1\nphosphorylation" color="#E53935"]

  /* FFA flux to liver */
  FFA_plasma -> FFA_liver [label="uptake\n(CD36/FATP)" color="#1565C0" style=bold]
  TG_adipose -> FFA_plasma [label="HSL lipolysis" color="#E65100"]

  /* Glucose-Insulin axis */
  Glucose_plasma -> Beta_cell    [label="stimulates" color="#2E7D32"]
  Beta_cell      -> Insulin_secret [label="" color="#2E7D32"]
  Insulin_secret -> Insulin_plasma [label="" color="#2E7D32"]
  GLP1           -> Beta_cell    [label="potentiates" color="#43A047"]
  GIP            -> Beta_cell    [label="potentiates" color="#43A047"]
  Insulin_plasma -> Insulin_clear [label="hepatic\nclearance" color="#9E9E9E"]
  Insulin_plasma -> IR_insulin_sig [label="binds\nIR/IRS1" color="#2E7D32" style=bold]
  Glucagon       -> HGO          [label="stimulates" color="#F57F17"]
  IR_insulin_sig -> FOXO1        [label="phospho/\nexclusion" color="#1976D2" arrowhead=tee]
  FOXO1          -> Gluconeogen  [label="transcription" color="#5C6BC0"]
  IR_insulin_sig -> SREBP1c     [label="activates" color="#1976D2"]

  /* De Novo Lipogenesis */
  SREBP1c        -> DNL   [label="transcription\n(FASN,ACC1)" color="#1565C0" style=bold]
  ChREBP         -> DNL   [label="glucose-driven" color="#1976D2"]
  Glucose_plasma -> ChREBP [label="activates" color="#2E7D32"]
  DNL            -> FASN  [label="" color="#1565C0"]
  FASN           -> FFA_liver [label="synthesizes" color="#1565C0"]
  FFA_liver      -> TG_liver  [label="esterification" color="#1565C0" style=bold]
  TG_liver       -> Steatosis  [label="accumulation" color="#0D47A1" style=bold]
  TG_liver       -> VLDL_secretion [label="export" color="#1E88E5"]
  VLDL_secretion -> Dyslipidemia   [label="↑TG, ↓HDL" color="#9E9E9E"]

  /* ACC1 / Malonyl-CoA */
  FASN           -> MalonylCoA  [label="ACC1 product" color="#64B5F6"]
  MalonylCoA     -> CPT1a       [label="inhibits" color="#EF5350" arrowhead=tee]
  CPT1a          -> FAO         [label="enables" color="#0288D1" style=bold]
  FAO            -> Acetyl_CoA  [label="generates" color="#0288D1"]
  Acetyl_CoA     -> Ketogenesis [label="overflow" color="#81D4FA"]
  AMPK           -> FASN        [label="phospho-inhibit" color="#0277BD" arrowhead=tee]

  /* PPARα drives FAO */
  PPARa          -> CPT1a    [label="transcription" color="#43A047"]
  PPARa          -> FAO      [label="↑ genes" color="#43A047"]

  /* Oxidative Stress cascade */
  FFA_liver      -> Mito_dysfunc [label="β-oxidation\noverload" color="#E91E63"]
  Mito_dysfunc   -> ROS        [label="generates" color="#E91E63" style=bold]
  FAO            -> ROS        [label="excess flux" color="#F48FB1"]
  TG_liver       -> ROS        [label="lipotoxicity" color="#E91E63"]
  ROS            -> LipidPerox  [label="peroxidation" color="#C2185B" style=bold]
  ROS            -> ASK1        [label="activates" color="#C2185B"]
  ROS            -> ER_stress   [label="triggers" color="#C2185B"]
  ROS            -> JNK12       [label="activates" color="#C2185B"]
  LipidPerox     -> Apoptosis   [label="hepatotoxic" color="#880E4F" style=bold]
  LipidPerox     -> NFkB        [label="activates" color="#BF360C"]
  ASK1           -> JNK12       [label="phosphorylates" color="#E53935" style=bold]
  JNK12          -> Apoptosis   [label="activates\nBim/Bax" color="#880E4F" style=bold]
  JNK12          -> IR_insulin_sig [label="Ser307-IRS1\n(worsens IR)" color="#E53935" arrowhead=tee]
  CHOP           -> Apoptosis   [label="pro-apoptotic\ngene Txn" color="#AD1457" style=bold]
  ER_stress      -> PERK_path   [label="" color="#C2185B"]
  ER_stress      -> IRE1a       [label="" color="#C2185B"]
  ER_stress      -> ATF6        [label="" color="#C2185B"]
  PERK_path      -> CHOP        [label="→ CHOP" color="#AD1457"]
  IRE1a          -> JNK12       [label="→ JNK" color="#D81B60"]
  Apoptosis      -> Casp37      [label="executes" color="#880E4F"]
  Casp37         -> Ballooning  [label="keratin\ncleavage" color="#B71C1C"]
  Casp37         -> CK18        [label="releases\nM30/M65" color="#B71C1C"]
  Nrf2           -> NQO1        [label="transcription" color="#43A047"]
  Nrf2           -> GSH         [label="↑ synthesis" color="#43A047"]
  NQO1           -> ROS         [label="scavenges" color="#43A047" arrowhead=tee]
  GSH            -> ROS         [label="neutralises" color="#43A047" arrowhead=tee]
  ROS            -> Nrf2        [label="activates\n(Keap1 release)" color="#43A047"]

  /* Gut-Liver Axis */
  Obesity        -> Microbiota   [label="dysbiosis" color="#006064"]
  Microbiota     -> SCFAs        [label="fermentation" color="#26C6DA"]
  Microbiota     -> Intestinal_P [label="↑ permeability" color="#EF9A9A"]
  Intestinal_P   -> Tight_junc   [label="disrupts" color="#EF9A9A" arrowhead=tee]
  Intestinal_P   -> Portal_LPS   [label="translocation" color="#FF7043" style=bold]
  Portal_LPS     -> LPS          [label="" color="#FF7043" style=bold]
  LPS            -> TLR4         [label="binds" color="#FF8F00" style=bold]
  SCFAs          -> GPR41_43     [label="receptor\nactivation" color="#26C6DA"]
  FXR_gut        -> FGF15_19     [label="induces" color="#006064"]
  BA_gut         -> FXR_gut      [label="activates" color="#00838F" style=bold]
  FGF15_19       -> FGFR4        [label="liver signal" color="#006064"]
  FGFR4          -> CYP7A1       [label="suppresses" color="#558B2F" arrowhead=tee]

  /* Kupffer Cell Activation */
  TLR4           -> MyD88    [label="" color="#FFB300" style=bold]
  MyD88          -> NFkB     [label="IKK complex" color="#FFB300" style=bold]
  NFkB           -> TNFa_liver [label="transcription" color="#E53935" style=bold]
  NFkB           -> IL1b       [label="transcription" color="#E53935" style=bold]
  NFkB           -> IL6_liver  [label="transcription" color="#EF5350"]
  NFkB           -> IL8        [label="transcription" color="#EF9A9A"]
  NFkB           -> MCP1       [label="transcription" color="#EF9A9A"]
  LipidPerox     -> NLRP3     [label="priming" color="#FF6F00"]
  ROS            -> NLRP3     [label="activates" color="#FF6F00"]
  NLRP3          -> Casp1     [label="cleaves" color="#FF8F00"]
  Casp1          -> IL1b      [label="matures" color="#E53935"]
  Casp1          -> IL18      [label="matures" color="#EF9A9A"]
  Casp1          -> Pyroptosis [label="" color="#BF360C"]
  TNFa_liver     -> IR_insulin_sig [label="Ser307-IRS1" color="#E53935" arrowhead=tee]
  TNFa_liver     -> Apoptosis   [label="TRAIL/FasL" color="#880E4F"]
  IL1b           -> NFkB        [label="amplifies" color="#E53935"]
  IL6_liver      -> STAT3       [label="JAK/STAT3" color="#EF5350"]
  MCP1           -> CCR2        [label="binds" color="#FFCA28"]
  CCR2           -> Kupffer     [label="recruitment" color="#FFD54F"]
  CCR5           -> HSC_active  [label="promotes\nactivation" color="#7B1FA2"]
  Lob_inflam     -> NAS_score   [label="component" color="#455A64"]

  /* Fibrosis cascade */
  TNFa_liver     -> HSC_active  [label="activates" color="#7B1FA2"]
  IL1b           -> HSC_active  [label="activates" color="#7B1FA2"]
  TGFb1          -> Smad23      [label="phosphorylates" color="#9C27B0" style=bold]
  TGFb1          -> HSC_active  [label="activates/\nmaintains" color="#7B1FA2" style=bold]
  PDGF           -> HSC_active  [label="proliferation" color="#AB47BC"]
  HSC_quiesc     -> HSC_active  [label="activation" color="#7B1FA2" style=bold]
  HSC_active     -> TGFb1       [label="autocrine" color="#9C27B0"]
  HSC_active     -> alphaSMA    [label="expresses" color="#7B1FA2"]
  HSC_active     -> CTGF        [label="secretes" color="#AB47BC"]
  Smad23         -> Col1_Col3   [label="transcription" color="#6A1B9A" style=bold]
  Smad23         -> TIMP1       [label="induces" color="#9C27B0"]
  Smad7          -> Smad23      [label="inhibits" color="#CE93D8" arrowhead=tee]
  TIMP1          -> MMP_fib     [label="inhibits" color="#9C27B0" arrowhead=tee]
  Col1_Col3      -> Fibrosis    [label="accumulation" color="#4A148C" style=bold]
  MMP_fib        -> Col1_Col3   [label="degrades" color="#BA68C8" arrowhead=tee]
  Apoptosis      -> TGFb1       [label="DAMPs\nrelease" color="#9C27B0"]
  ROS            -> TGFb1       [label="activates\nlatent pool" color="#9C27B0"]
  Fibrosis       -> PROC3       [label="reflects" color="#CE93D8"]
  Fibrosis       -> ELF_score   [label="reflects" color="#B39DDB"]
  Fibrosis       -> LStiffness  [label="↑ stiffness" color="#9E9E9E"]
  Fibrosis       -> Fibrosis_stg [label="" color="#4A148C" style=bold]

  /* Nuclear Receptor / Bile Acid Axis */
  BA_liver       -> FXR_liver   [label="activates" color="#558B2F" style=bold]
  FXR_liver      -> SHP         [label="induces" color="#558B2F"]
  SHP            -> CYP7A1      [label="represses" color="#558B2F" arrowhead=tee]
  FXR_liver      -> BSEP        [label="induces" color="#8BC34A"]
  FXR_liver      -> TNFa_liver  [label="represses" color="#43A047" arrowhead=tee style=dashed]
  FXR_liver      -> TGFb1       [label="represses" color="#43A047" arrowhead=tee style=dashed]
  FXR_liver      -> IL1b        [label="represses\n(NFkB)" color="#43A047" arrowhead=tee style=dashed]
  FXR_liver      -> SREBP1c     [label="represses" color="#43A047" arrowhead=tee]
  LXR            -> SREBP1c     [label="activates" color="#C5E1A5"]
  THR_beta       -> CYP7A1      [label="induces\n(BA synthesis)" color="#1B5E20"]
  THR_beta       -> FAO         [label="↑ expression" color="#33691E"]
  FGF21          -> PPARa       [label="coregulator" color="#1B5E20"]
  PPARa          -> FGF21       [label="induces" color="#558B2F"]
  PPARg          -> TGFb1       [label="suppresses" color="#43A047" arrowhead=tee style=dashed]
  PPARd          -> FAO         [label="↑ expression" color="#2E7D32"]

  /* ============================================================
     DRUG → TARGET edges
     ============================================================ */

  /* OCA */
  OCA         -> FXR_liver [label="EC50=0.099 µM\nagonist" color="#3F51B5" style=bold penwidth=2]
  OCA         -> FXR_gut   [label="agonist" color="#3F51B5" style=bold penwidth=2]
  OCA         -> Dyslipidemia [label="↑LDL-C\n(side-effect)" color="#EF9A9A" style=dashed]

  /* Cilofexor */
  Cilofexor   -> FXR_liver [label="agonist" color="#5C6BC0" penwidth=1.5]

  /* Lanifibranor */
  Lanifibranor -> PPARa   [label="pan-PPAR Ag.\nIC50~0.25 µM" color="#7986CB" style=bold penwidth=2]
  Lanifibranor -> PPARg   [label="agonist" color="#7986CB" style=bold penwidth=2]
  Lanifibranor -> PPARd   [label="agonist" color="#7986CB" style=bold penwidth=2]

  /* Pemafibrate */
  Pemafibrate  -> PPARa   [label="selective Ag." color="#9FA8DA"]

  /* Pioglitazone */
  Pioglitazone -> PPARg   [label="agonist" color="#9FA8DA"]

  /* Firsocostat */
  Firsocostat  -> FASN    [label="ACC1/2 Inh.\nIC50=15 nM" color="#303F9F" style=bold penwidth=2 arrowhead=tee]
  Firsocostat  -> MalonylCoA [label="↓ malonyl-CoA\n→ ↑ FAO" color="#303F9F" arrowhead=tee]

  /* Selonsertib */
  Selonsertib  -> ASK1    [label="Inh.\nIC50=3 nM" color="#283593" style=bold penwidth=2 arrowhead=tee]

  /* Cenicriviroc */
  Cenicriviroc -> CCR2    [label="antagonist" color="#3949AB" style=bold arrowhead=tee]
  Cenicriviroc -> CCR5    [label="antagonist" color="#3949AB" style=bold arrowhead=tee]

  /* Semaglutide */
  Semaglutide  -> GLP1    [label="GLP-1 RA\nmimics" color="#1565C0" style=bold penwidth=2]
  Semaglutide  -> Obesity [label="↓ food intake\n↓ body weight" color="#1565C0" arrowhead=tee]
  Semaglutide  -> IR_systemic [label="improves" color="#1565C0" arrowhead=tee]

  /* Resmetirom */
  Resmetirom   -> THR_beta  [label="THRβ Ag.\nKi=28 nM" color="#0D47A1" style=bold penwidth=2]

  /* Empagliflozin */
  Empagliflozin -> Glucose_plasma [label="SGLT2 Inh.\n↑ glucosuria" color="#1E88E5" arrowhead=tee]
  Empagliflozin -> BodyWeight     [label="↓ weight\n(caloric loss)" color="#1E88E5" arrowhead=tee]

  /* TVB-2640 (FASN Inh.) */
  TVB2640      -> FASN    [label="FASN Inh." color="#42A5F5" arrowhead=tee]
  TVB2640      -> DNL     [label="↓ DNL" color="#42A5F5" arrowhead=tee]

  /* ============================================================
     CLINICAL ENDPOINTS
     ============================================================ */
  Steatosis      -> NAS_score  [label="component\n(0–3)" color="#37474F"]
  Ballooning     -> NAS_score  [label="component\n(0–2)" color="#37474F"]
  Lob_inflam     -> NAS_score  [label="component\n(0–3)" color="#37474F"]
  Steatosis      -> MRI_PDFF   [label="quantified by" color="#90A4AE"]
  Apoptosis      -> ALT        [label="hepatocyte\nlysis → ALT↑" color="#78909C"]
  Ballooning     -> ALT        [label="" color="#78909C"]
  NAS_score      -> Fibrosis_stg [label="drives\nprogression" color="#455A64" style=dashed]
  IR_systemic    -> HbA1c      [label="hyperglycemia" color="#9E9E9E"]
  Dyslipidemia   -> BodyWeight  [label="associated" color="#CFD8DC" style=dashed]
  VLDL_secretion -> Dyslipidemia [label="" color="#9E9E9E"]

  /* STAT3 node */
  STAT3 [label="STAT3\n(Hepatic)" fillcolor="#EF9A9A" style="filled,rounded" shape=ellipse fontsize=9]
  STAT3 -> SREBP1c [label="↑ lipogenesis" color="#EF5350"]
  STAT3 -> Fibrosis [label="promotes" color="#7B1FA2"]

  /* GPR41_43 node */
  GPR41_43 [label="GPR41/43\n(SCFA receptors)" fillcolor="#80DEEA" style="filled,rounded" fontsize=9]
  GPR41_43 -> GLP1 [label="induces" color="#43A047"]
  GPR41_43 -> Insulin_secret [label="↑ secretion" color="#43A047"]

  /* HGO → glucose plasma */
  HGO -> Glucose_plasma [label="" color="#F57F17"]
  Gluconeogen -> HGO [label="" color="#5C6BC0"]
  Glycogenolysis -> HGO [label="" color="#5C6BC0"]

  /* FFA_liver → NLRP3 priming */
  FFA_liver -> NLRP3 [label="saturated FA\npriming" color="#FF6F00" style=dashed]
  FFA_liver -> ER_stress [label="lipotoxicity" color="#C2185B"]

  /* Adiponectin direct hepatic effect */
  Adiponectin -> TGFb1 [label="suppresses" color="#43A047" arrowhead=tee style=dashed]
  Adiponectin -> NFkB  [label="suppresses" color="#43A047" arrowhead=tee style=dashed]
  Adiponectin -> FAO   [label="↑ via PPARα" color="#43A047"]

  /* BA → liver steatosis negative feedback */
  FXR_liver -> FGF21 [label="induces" color="#1B5E20"]
  FGF21 -> FAO [label="↑ expression\n(FGF21 target)" color="#1B5E20"]

}
