    style=rounded

    Antithrombin_AT         [label="Antithrombin (AT)",        fillcolor="#023e8a", fontcolor=white]
    AT_thrombin_complex     [label="AT–Thrombin Complex",      fillcolor="#023e8a", fontcolor=white]
    AT_FXa_complex          [label="AT–FXa Complex",           fillcolor="#023e8a", fontcolor=white]
    Heparin_cofactor        [label="Heparin Cofactor",         fillcolor="#023e8a", fontcolor=white]
    Thrombomodulin_TM       [label="Thrombomodulin (TM)",      fillcolor="#023e8a", fontcolor=white]
    Protein_C               [label="Protein C",                fillcolor="#023e8a", fontcolor=white]
    Activated_Protein_C_APC [label="Activated Protein C\n(APC)", fillcolor="#6a0572", fontcolor=white]
    Protein_S               [label="Protein S",                fillcolor="#023e8a", fontcolor=white]
    EPCR                    [label="EPCR",                     fillcolor="#023e8a", fontcolor=white]
    APC_FVa_cleavage        [label="APC: FVa Cleavage",        fillcolor="#6a0572", fontcolor=white]
    APC_FVIIIa_cleavage     [label="APC: FVIIIa Cleavage",     fillcolor="#6a0572", fontcolor=white]
    Prostacyclin_PGI2       [label="Prostacyclin (PGI2)",      fillcolor="#023e8a", fontcolor=white]
    tPA_fibrinolysis        [label="tPA (Fibrinolysis)",       fillcolor="#023e8a", fontcolor=white]
    Plasminogen             [label="Plasminogen",              fillcolor="#023e8a", fontcolor=white]
    Plasmin                 [label="Plasmin",                  fillcolor="#023e8a", fontcolor=white]
    Alpha2AP                [label="Alpha-2-Antiplasmin",      fillcolor="#023e8a", fontcolor=white]

    Antithrombin_AT         -> AT_thrombin_complex
    Antithrombin_AT         -> AT_FXa_complex
    Heparin_cofactor        -> Antithrombin_AT [label="enhances"]
    Thrombomodulin_TM       -> Protein_C [label="activates\nThrombin–TM"]
    Thrombin_FIIa           -> Thrombomodulin_TM [label="binds"]
    EPCR                    -> Protein_C [label="presents"]
    Protein_C               -> Activated_Protein_C_APC
    Protein_S               -> Activated_Protein_C_APC [label="cofactor"]
    Activated_Protein_C_APC -> APC_FVa_cleavage
    Activated_Protein_C_APC -> APC_FVIIIa_cleavage
    APC_FVa_cleavage        -> FVa [label="inactivates" color=red style=dashed]
    tPA_fibrinolysis        -> Plasminogen [label="activates"]
    Plasminogen             -> Plasmin
    Plasmin                 -> Fibrin_crosslinked [label="degrades" color=red style=dashed]
    Alpha2AP                -> Plasmin [label="inhibits" color=red style=dashed]
    Prostacyclin_PGI2       -> Platelet_Activation [label="inhibits" color=red style=dashed]
}

