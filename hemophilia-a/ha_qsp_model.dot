// ─── CLUSTER 8: Hemophilic Arthropathy ──────────────────────────────────────
subgraph cluster_8 {
    label="Hemophilic Arthropathy"
    color="#8338ec"
    fontcolor="#8338ec"
    fontsize=12
    style=rounded

    Synovial_membrane_iron     [label="Synovial Membrane\nIron Deposition",   fillcolor="#6a0572", fontcolor=white]
    Hemosiderin_deposition     [label="Hemosiderin Deposition",               fillcolor="#6a0572", fontcolor=white]
    ROS_reactive_oxygen        [label="ROS (Reactive\nOxygen Species)",       fillcolor="#6a0572", fontcolor=white]
    Synoviocyte_inflammation   [label="Synoviocyte\nInflammation",            fillcolor="#6a0572", fontcolor=white]
    TNFalpha_IL1beta_IL6       [label="TNF-α / IL-1β / IL-6",                 fillcolor="#6a0572", fontcolor=white]
    MMP_matrix_metalloprotease [label="MMP\n(Matrix Metalloprotease)",        fillcolor="#6a0572", fontcolor=white]
    Chondrocyte_apoptosis      [label="Chondrocyte Apoptosis",                fillcolor="#6a0572", fontcolor=white]
    Cartilage_degradation      [label="Cartilage Degradation",                fillcolor="#6a0572", fontcolor=white]
    Subchondral_bone_erosion   [label="Subchondral Bone\nErosion",            fillcolor="#6a0572", fontcolor=white]
    Osteoclast_activation      [label="Osteoclast Activation",                fillcolor="#6a0572", fontcolor=white]
    Joint_space_narrowing      [label="Joint Space\nNarrowing",               fillcolor="#6a0572", fontcolor=white]
    Arnold_Hilgartner_score    [label="Arnold-Hilgartner\nScore",             fillcolor="#1b4332", fontcolor=white]
    Pettersson_score           [label="Pettersson Score",                     fillcolor="#1b4332", fontcolor=white]
    Haemophilia_Joint_Health_Score [label="Haemophilia Joint\nHealth Score",  fillcolor="#1b4332", fontcolor=white]

    Synovial_membrane_iron     -> Hemosiderin_deposition
    Hemosiderin_deposition     -> ROS_reactive_oxygen
    ROS_reactive_oxygen        -> Synoviocyte_inflammation
    Synoviocyte_inflammation   -> TNFalpha_IL1beta_IL6
    TNFalpha_IL1beta_IL6       -> MMP_matrix_metalloprotease
    MMP_matrix_metalloprotease -> Cartilage_degradation
    ROS_reactive_oxygen        -> Chondrocyte_apoptosis
    Chondrocyte_apoptosis      -> Cartilage_degradation
    Cartilage_degradation      -> Joint_space_narrowing
    TNFalpha_IL1beta_IL6       -> Osteoclast_activation
    Osteoclast_activation      -> Subchondral_bone_erosion
    Subchondral_bone_erosion   -> Joint_space_narrowing
    Joint_space_narrowing      -> Arnold_Hilgartner_score
    Joint_space_narrowing      -> Pettersson_score
    Joint_space_narrowing      -> Haemophilia_Joint_Health_Score
}

// ─── CLUSTER 9: Clinical Endpoints & QoL ────────────────────────────────────
subgraph cluster_9 {
    label="Clinical Endpoints & QoL"
    color="#fb5607"
    fontcolor="#fb5607"
    fontsize=12
    style=rounded

    FVIII_trough_level_target  [label="FVIII Trough Level\nTarget",         fillcolor="#1b4332", fontcolor=white]
    FVIII_1IU_dL_severe        [label="FVIII <1 IU/dL\n(Severe)",          fillcolor="#370617", fontcolor=white]
    FVIII_trough_15_optimal    [label="FVIII Trough ≥15%\n(Optimal)",      fillcolor="#1b4332", fontcolor=white]
    Prophylaxis_primary        [label="Primary Prophylaxis",               fillcolor="#1b4332", fontcolor=white]
    Prophylaxis_secondary      [label="Secondary Prophylaxis",             fillcolor="#1b4332", fontcolor=white]
    On_demand_therapy          [label="On-Demand Therapy",                 fillcolor="#1b4332", fontcolor=white]
    Zero_bleed_phenotype       [label="Zero Bleed Phenotype",              fillcolor="#1b4332", fontcolor=white]
    ABR_annual                 [label="ABR (Annual)",                      fillcolor="#1b4332", fontcolor=white]
    QoL_EQ5D                   [label="QoL: EQ-5D",                        fillcolor="#1b4332", fontcolor=white]
    HaemoQoL_score             [label="HaemoQoL Score",                    fillcolor="#1b4332", fontcolor=white]
    Physical_activity_score    [label="Physical Activity\nScore",          fillcolor="#1b4332", fontcolor=white]
    Joint_score_outcome        [label="Joint Score\nOutcome",              fillcolor="#1b4332", fontcolor=white]
    PROBE_study_outcome        [label="PROBE Study\nOutcome",              fillcolor="#1b4332", fontcolor=white]
    SF36_score                 [label="SF-36 Score",                       fillcolor="#1b4332", fontcolor=white]

    FVIII_trough_level_target  -> FVIII_trough_15_optimal
    FVIII_1IU_dL_severe        -> FVIII_trough_level_target [label="defines\nneed"]
    Prophylaxis_primary        -> FVIII_trough_level_target
    Prophylaxis_secondary      -> FVIII_trough_level_target
    On_demand_therapy          -> ABR_annual [label="higher ABR"]
    Prophylaxis_primary        -> Zero_bleed_phenotype [label="goal"]
    Zero_bleed_phenotype       -> QoL_EQ5D [label="improves"]
    Zero_bleed_phenotype       -> Physical_activity_score [label="enables"]
    ABR_annual                 -> QoL_EQ5D
    ABR_annual                 -> HaemoQoL_score
    Joint_score_outcome        -> QoL_EQ5D
    Joint_score_outcome        -> HaemoQoL_score
    Joint_score_outcome        -> SF36_score
    PROBE_study_outcome        -> QoL_EQ5D
    PROBE_study_outcome        -> ABR_annual
}

// ═══════════════════════════════════════════════════════════════════════════════
// INTER-CLUSTER EDGES
// ═══════════════════════════════════════════════════════════════════════════════

// Cluster 0 → Cluster 1
Vascular_Injury -> TF_FVIIa_complex [label="triggers"]

// Cluster 1 → Cluster 2
TF_FVIIa_complex -> FIX_activation_extrinsic
TF_FVIIa_complex -> FX_activation_extrinsic

// Cluster 0 → Cluster 3
Phospholipid_Surface -> Prothrombinase_complex [label="anchors"]
Phospholipid_Surface -> FIXa_FVIIIa_Xase_complex [label="anchors"]

// Cluster 2 → Cluster 2 (intrinsic Xase)
FIXa -> FIXa_FVIIIa_Xase_complex
FVIIIa_activated -> FIXa_FVIIIa_Xase_complex

// Cluster 2 → Cluster 3
FIXa_FVIIIa_Xase_complex -> FXa_common [label="generates"]

// Cluster 2 → Cluster 2 (FVIII activation chain)
FVIII_VWF_complex -> FVIII_release_from_VWF
FVIII_release_from_VWF -> FVIIIa_activated [label="Thrombin\nactivation"]

// Cluster 3 internal and into fibrin
FXa_common -> Prothrombinase_complex
FVa -> Prothrombinase_complex
Prothrombinase_complex -> Thrombin_FIIa
Thrombin_FIIa -> Fibrinogen_FI [label="cleaves"]
Fibrinogen_FI -> Fibrin_monomer
Fibrin_monomer -> Fibrin_polymer
FXIIIa_transglutaminase -> Fibrin_crosslinked

// Cluster 4 → Cluster 3 (inhibitory)
Antithrombin_AT -> Thrombin_FIIa [label="inhibits" style=dashed color=red]
Antithrombin_AT -> FXa_common   [label="inhibits" style=dashed color=red]

// Cluster 4 → Cluster 2 (APC → FVIIIa)
APC_FVIIIa_cleavage -> FVIIIa_inactivation [color=red]

// Cluster 5 → Cluster 6 (inhibitor neutralizes FVIII)
Anti_FVIII_IgG -> FVIII_central_comp [label="neutralizes" style=dashed color=red]

// Cluster 6 → Cluster 6 / Cluster 2 (FVIII replacement PK)
FVIII_Concentrate_SHL -> FVIII_central_comp
EHL_FVIII_Fc_fusion -> FVIII_central_comp
FVIII_central_comp -> FVIII_peripheral_comp
FVIII_central_comp -> FVIIIa_activated [label="replenishes"]

// Emicizumab PK/PD
EMIC_SC_depot -> Emicizumab_central
Emicizumab_central -> Emicizumab_FIXa_bridge
Emicizumab_central -> Emicizumab_FX_bridge
Emicizumab_tenase_mimicry -> FXa_common [label="bypasses\nFVIII"]

// Fitusiran PK/PD
Fitusiran_SC_depot -> Fitusiran_central
Fitusiran_central -> Fitusiran_RISC_complex
Fitusiran_RISC_complex -> AT_mRNA_knockdown
AT_mRNA_knockdown -> AT_protein_reduction
AT_protein_reduction -> Antithrombin_AT [style=dashed color=orange label="reduces"]

// Marstacimab
Marstacimab_anti_TFPI -> TFPI_inhibition [style=dashed color=orange label="blocks"]

// Cluster 7 → Cluster 8 (bleed → arthropathy)
Hemarthrosis_knee -> Synovial_membrane_iron [label="repeated\nbleeds"]
Synovial_membrane_iron -> Hemosiderin_deposition
Hemosiderin_deposition -> ROS_reactive_oxygen
ROS_reactive_oxygen -> Chondrocyte_apoptosis
Chondrocyte_apoptosis -> Cartilage_degradation
Cartilage_degradation -> Joint_space_narrowing

// Cluster 9 → Cluster 7 (ABR)
ABR_annual -> Hemarthrosis_knee [label="drives"]
Annualized_Bleed_Rate_ABR -> ABR_annual

// Cluster 9 → Cluster 9 (trough → zero bleed)
FVIII_trough_level_target -> Zero_bleed_phenotype [label="enables"]

// Cluster 8 → Cluster 9 (arthropathy → QoL)
Joint_space_narrowing -> Pettersson_score
Pettersson_score -> QoL_EQ5D [label="impacts"]

// Additional cross-cluster connections for completeness
FVIII_severity_levels -> Spontaneous_bleed [label="severe→\nfrequent"]
FVIII_1IU_dL_severe -> FVIII_severity_levels
FX_activation_extrinsic -> FXa_common [label="contributes"]
FXa_intrinsic -> FXa_common [label="merges"]
vWF_Release -> VWF_carrier [label="circulates"]
VWF_carrier -> FVIII_VWF_complex
vWF_FVIII_release_endothelial -> FVIII_VWF_complex [label="boosts vWF"]
FVIII_antigen_presentation -> FVIII_protein_inactive [label="processed\nfrom"]
Thrombin_FIIa -> FVIII_release_from_VWF [label="cleaves\nFVIII–VWF"]
Haemophilia_Joint_Health_Score -> Joint_score_outcome [label="informs"]
Arnold_Hilgartner_score -> Joint_score_outcome [label="grades"]

}
