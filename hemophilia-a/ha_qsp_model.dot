    FXa_common              -> Prothrombinase_complex
    FVa                     -> Prothrombinase_complex
    Prothrombin_FII         -> Thrombin_FIIa [label="cleaved by\nProthrombinase"]
    Prothrombinase_complex  -> Thrombin_FIIa
    Thrombin_FIIa           -> Thrombin_burst
    Thrombin_FIIa           -> Thrombin_amplification
    Thrombin_FIIa           -> FVa [label="activates"]
    Thrombin_FIIa           -> FXIII_zymogen [label="activates"]
