digraph HemophiliaA_QSP {

graph [rankdir=LR, bgcolor="#1a1a2e", fontcolor=white, fontsize=14, labelloc=t,
       label="Hemophilia A — Comprehensive QSP Mechanistic Map\n(FVIII Deficiency · Coagulation Cascade · Emicizumab · Fitusiran · Marstacimab · Arthropathy · Clinical Endpoints)",
       fontname="Helvetica-Bold", pad=0.5, nodesep=0.3, ranksep=0.8]
node [shape=box, style="filled,rounded", fontname="Helvetica", fontsize=9, margin="0.1,0.05"]
edge [fontname="Helvetica", fontsize=8, color="#aaaaaa"]

// ─── CLUSTER 0: Vascular Injury & Platelet Activation ───────────────────────
subgraph cluster_0 {
    label="Vascular Injury & Platelet Activation"
    color=crimson
    fontcolor=crimson
    fontsize=12
    style=rounded

    Vascular_Injury         [label="Vascular Injury",          fillcolor="#6a0572", fontcolor=white]
    Subendothelium_Exposure [label="Subendothelium Exposure",  fillcolor="#6a0572", fontcolor=white]
    Collagen_Exposure       [label="Collagen Exposure",        fillcolor="#023e8a", fontcolor=white]
    vWF_Release             [label="vWF Release",              fillcolor="#023e8a", fontcolor=white]
    Platelet_Adhesion       [label="Platelet Adhesion",        fillcolor="#023e8a", fontcolor=white]
    Platelet_Activation     [label="Platelet Activation",      fillcolor="#023e8a", fontcolor=white]
    Platelet_Aggregation    [label="Platelet Aggregation",     fillcolor="#023e8a", fontcolor=white]
    GPIB_vWF_binding        [label="GPIb–vWF Binding",         fillcolor="#023e8a", fontcolor=white]
    GPIIbIIIa_activation    [label="GPIIb/IIIa Activation",    fillcolor="#023e8a", fontcolor=white]
    Phospholipid_Surface    [label="Phospholipid Surface",     fillcolor="#6a0572", fontcolor=white]
    TXA2_Release            [label="TXA2 Release",             fillcolor="#023e8a", fontcolor=white]
    ADP_Release             [label="ADP Release",              fillcolor="#023e8a", fontcolor=white]
    GP1b_IX_V               [label="GP1b-IX-V Complex",        fillcolor="#023e8a", fontcolor=white]

    Vascular_Injury         -> Subendothelium_Exposure
    Subendothelium_Exposure -> Collagen_Exposure
    Subendothelium_Exposure -> vWF_Release
    Collagen_Exposure       -> Platelet_Adhesion
    vWF_Release             -> GPIB_vWF_binding
    GPIB_vWF_binding        -> Platelet_Adhesion
    GP1b_IX_V               -> GPIB_vWF_binding
    Platelet_Adhesion       -> Platelet_Activation
    Platelet_Activation     -> Platelet_Aggregation
    Platelet_Activation     -> TXA2_Release
    Platelet_Activation     -> ADP_Release
    Platelet_Activation     -> GPIIbIIIa_activation
    Platelet_Aggregation    -> Phospholipid_Surface
}

