    TF_FVIIa_complex        -> FIX_activation_extrinsic
    TF_FVIIa_complex        -> FX_activation_extrinsic
    FX_activation_extrinsic -> FXa_TFPI_complex
    TFPI_alpha              -> TFPI_inhibition
    TFPI_beta               -> TFPI_inhibition
    TFPI_inhibition         -> FXa_TFPI_complex
    Kunitz_domain           -> TFPI_inhibition
    Protease_Nexin2         -> TFPI_inhibition
}

