/*
  Microscopic Colitis (MC) — Comprehensive QSP Mechanistic Map
  Subtypes: Lymphocytic Colitis (LC) and Collagenous Colitis (CC)
  Clusters: triggers, genetics, microbiome, barrier, mucosal immunity,
            collagen deposition, bile-acid malabsorption, water/electrolyte
            transport, clinical phenotype, drug PK, drug PD targets,
            comorbidities & outcomes.
*/
digraph MC_QSP {
  graph [layout=dot, rankdir=LR, splines=true, overlap=false,
         fontname="Helvetica", fontsize=11, nodesep=0.32, ranksep=0.7,
         bgcolor="white", labelloc="t",
         label="Microscopic Colitis (LC + CC) — QSP Mechanistic Map\n(Triggers · Mucosa · Immunity · Collagen Band · Bile Acid · Transport · Drugs · Endpoints)"];
  node  [shape=box, style="rounded,filled", fontname="Helvetica",
         fontsize=10, color="#34495e", fillcolor="#ecf0f1", penwidth=1.1];
  edge  [fontname="Helvetica", fontsize=8, color="#7f8c8d",
         arrowsize=0.7, penwidth=0.9];

  /* =================================================================== */
  /* 1. Triggers and Risk Factors                                        */
  /* =================================================================== */
  subgraph cluster_trig {
    label="① Triggers & Risk Factors"; style="rounded,filled"; fillcolor="#fdecea"; color="#c0392b";
    NSAID    [label="NSAID exposure", fillcolor="#fadbd8"];
    PPI      [label="Proton-pump inhibitor", fillcolor="#fadbd8"];
    SSRI     [label="SSRI / SNRI", fillcolor="#fadbd8"];
    STATIN   [label="Statin (rare)", fillcolor="#fadbd8"];
    ARANS    [label="Acarbose / Ranitidine", fillcolor="#fadbd8"];
    SMOKE    [label="Active smoking", fillcolor="#fadbd8"];
    AGE      [label="Age > 60 y", fillcolor="#fadbd8"];
    FEMALE   [label="Female sex", fillcolor="#fadbd8"];
    BILE_TRG [label="Cholecystectomy /\nbile acid load", fillcolor="#fadbd8"];
    INFECT   [label="Prior enteric infection\n(C. jejuni, C. difficile)", fillcolor="#fadbd8"];
  }

  /* =================================================================== */
  /* 2. Genetics & HLA                                                   */
  /* =================================================================== */
  subgraph cluster_gen {
    label="② Genetics / HLA"; style="rounded,filled"; fillcolor="#f4ecf7"; color="#7d3c98";
    HLA_DQ   [label="HLA-DQ2.5\n(celiac shared risk)", fillcolor="#e8daef"];
    MMP9_g   [label="MMP-9 polymorphism", fillcolor="#e8daef"];
    IL6_g    [label="IL-6 -174 G/C", fillcolor="#e8daef"];
    NOD2_g   [label="NOD2 variants (rare)", fillcolor="#e8daef"];
    CELIAC_g [label="Celiac-overlap polygenic risk", fillcolor="#e8daef"];
  }

  /* =================================================================== */
  /* 3. Microbiome & Luminal Factors                                     */
  /* =================================================================== */
  subgraph cluster_micro {
    label="③ Microbiome & Luminal"; style="rounded,filled"; fillcolor="#fef9e7"; color="#b7950b";
    DYSBIO   [label="Mucosa-associated\ndysbiosis", fillcolor="#fcf3cf"];
    F_PRAUS  [label="↓ F. prausnitzii", fillcolor="#fcf3cf"];
    AKKER    [label="↓ Akkermansia", fillcolor="#fcf3cf"];
    LACHN    [label="↓ Lachnospiraceae", fillcolor="#fcf3cf"];
    PROTEO   [label="↑ Proteobacteria", fillcolor="#fcf3cf"];
    SCFA     [label="↓ Butyrate / SCFA", fillcolor="#fcf3cf"];
    BILE_LUM [label="↑ Luminal bile acids\n(secondary BAs)", fillcolor="#fcf3cf"];
    LPS_LUM  [label="↑ LPS / PAMPs", fillcolor="#fcf3cf"];
  }

  /* =================================================================== */
  /* 4. Epithelial Barrier                                               */
  /* =================================================================== */
  subgraph cluster_bar {
    label="④ Epithelial Barrier"; style="rounded,filled"; fillcolor="#eafaf1"; color="#1e8449";
    EPI_DMG  [label="Surface epithelial\ndamage", fillcolor="#d4efdf"];
    CLAUDIN  [label="↓ Claudin-1/3/4\ntight-junction loss", fillcolor="#d4efdf"];
    ZO1      [label="↓ ZO-1, Occludin", fillcolor="#d4efdf"];
    MUC2     [label="↓ MUC2 mucin", fillcolor="#d4efdf"];
    PERMEAB  [label="↑ Paracellular\npermeability", fillcolor="#d4efdf"];
    APOPT    [label="↑ Epithelial apoptosis", fillcolor="#d4efdf"];
    GOBLET   [label="↓ Goblet-cell density", fillcolor="#d4efdf"];
    PANETH   [label="Paneth-cell defensin\n(α-defensin) shift", fillcolor="#d4efdf"];
  }

  /* =================================================================== */
  /* 5. Mucosal Immunity                                                 */
  /* =================================================================== */
  subgraph cluster_imm {
    label="⑤ Mucosal Immunity"; style="rounded,filled"; fillcolor="#eaf2f8"; color="#1f618d";
    APC      [label="Mucosal DC / APC\n(CD11c+)", fillcolor="#d4e6f1"];
    CD8_IEL  [label="↑ CD8+ Intraepithelial\nLymphocytes (>20/100 EC)", fillcolor="#d4e6f1"];
    CD4_LP   [label="CD4+ lamina propria\nT cells", fillcolor="#d4e6f1"];
    TREG     [label="↓ Foxp3+ Treg\nfunction", fillcolor="#d4e6f1"];
    TH1      [label="Th1 polarization\n(IFN-γ, T-bet)", fillcolor="#d4e6f1"];
    TH17     [label="Th17 / IL-17A/IL-22", fillcolor="#d4e6f1"];
    BREG     [label="↑ Plasma cells\n(IgG, IgM)", fillcolor="#d4e6f1"];
    MAST     [label="Mast cell hyperplasia\n(CC subtype)", fillcolor="#d4e6f1"];
    EOSIN    [label="Eosinophil infiltration", fillcolor="#d4e6f1"];
    NEUTRO   [label="Neutrophil (mild)", fillcolor="#d4e6f1"];
    NK       [label="iNK / iNKT activation", fillcolor="#d4e6f1"];
  }

  /* =================================================================== */
  /* 6. Cytokines & Chemokines                                           */
  /* =================================================================== */
  subgraph cluster_cyto {
    label="⑥ Cytokines & Chemokines"; style="rounded,filled"; fillcolor="#fdedec"; color="#922b21";
    IFNG     [label="IFN-γ ↑↑", fillcolor="#f5b7b1"];
    TNFA     [label="TNF-α ↑", fillcolor="#f5b7b1"];
    IL15     [label="IL-15 ↑\n(epithelial)", fillcolor="#f5b7b1"];
    IL17     [label="IL-17A ↑", fillcolor="#f5b7b1"];
    IL22     [label="IL-22", fillcolor="#f5b7b1"];
    IL23     [label="IL-23 ↑", fillcolor="#f5b7b1"];
    IL6      [label="IL-6 ↑", fillcolor="#f5b7b1"];
    IL1B     [label="IL-1β", fillcolor="#f5b7b1"];
    TGFB     [label="TGF-β ↑↑\n(CC fibrogenic)", fillcolor="#f5b7b1"];
    CXCL10   [label="CXCL10 / IP-10", fillcolor="#f5b7b1"];
    CCL5     [label="CCL5 / RANTES", fillcolor="#f5b7b1"];
    GMCSF    [label="GM-CSF", fillcolor="#f5b7b1"];
  }

  /* =================================================================== */
  /* 7. Subepithelial Collagen Band (CC subtype-defining)                */
  /* =================================================================== */
  subgraph cluster_col {
    label="⑦ Subepithelial Collagen Band (CC)"; style="rounded,filled"; fillcolor="#f6ddcc"; color="#a04000";
    PERICYTE [label="Pericryptal\nmyofibroblasts ↑", fillcolor="#fae5d3"];
    SMA      [label="α-SMA expression", fillcolor="#fae5d3"];
    COLI     [label="Type I / III / VI\ncollagen deposition", fillcolor="#fae5d3"];
    TENA     [label="Tenascin-C ↑", fillcolor="#fae5d3"];
    MMP9     [label="MMP-9 / TIMP-1\nimbalance", fillcolor="#fae5d3"];
    BANDTHK  [label="Collagen band\n>10 μm (CC dx)", fillcolor="#fae5d3"];
    VEGF     [label="VEGF (angiogenesis)", fillcolor="#fae5d3"];
  }

  /* =================================================================== */
  /* 8. Bile Acid Malabsorption                                          */
  /* =================================================================== */
  subgraph cluster_bam {
    label="⑧ Bile Acid Malabsorption (BAM)"; style="rounded,filled"; fillcolor="#fef5e7"; color="#9a7d0a";
    BAM      [label="Ileal BA malabsorption\n(SeHCAT < 10%)", fillcolor="#fdebd0"];
    FGF19    [label="↓ FGF19 (ileal)", fillcolor="#fdebd0"];
    CYP7A1   [label="↑ Hepatic CYP7A1\n(BA synthesis)", fillcolor="#fdebd0"];
    ASBT     [label="ASBT (ileal Na+/BA\ntransporter)", fillcolor="#fdebd0"];
    TGR5     [label="TGR5 / FXR signalling", fillcolor="#fdebd0"];
    COL_DCA  [label="↑ Colonic DCA / LCA", fillcolor="#fdebd0"];
    SECR_BAM [label="Colonic secretory\ndiarrhoea (BA)", fillcolor="#fdebd0"];
  }

  /* =================================================================== */
  /* 9. Water & Electrolyte Transport                                    */
  /* =================================================================== */
  subgraph cluster_trans {
    label="⑨ Water & Electrolyte Transport"; style="rounded,filled"; fillcolor="#e8f8f5"; color="#117a65";
    NHE3     [label="↓ NHE3 (apical Na+/H+)", fillcolor="#d1f2eb"];
    NKCC1    [label="↑ NKCC1 secretion", fillcolor="#d1f2eb"];
    CFTR     [label="CFTR Cl- channel\n(BA / cAMP)", fillcolor="#d1f2eb"];
    NA_KATP  [label="Basolateral Na+/K+-ATPase", fillcolor="#d1f2eb"];
    AQP4     [label="Aquaporin-4 mucosal", fillcolor="#d1f2eb"];
    NETFLX   [label="Net Na+/water flux:\nabsorption → secretion", fillcolor="#d1f2eb"];
    HYPOK    [label="Hypokalemia /\nbicarb loss (severe)", fillcolor="#d1f2eb"];
  }

  /* =================================================================== */
  /* 10. Clinical Phenotype                                              */
  /* =================================================================== */
  subgraph cluster_clin {
    label="⑩ Clinical Phenotype"; style="rounded,filled"; fillcolor="#fef9e7"; color="#7d6608";
    DIARR    [label="Chronic watery\nnon-bloody diarrhea\n(>3 stools/day)", fillcolor="#fdebd0"];
    STOOL_W  [label="Stool weight\n>300 g/day", fillcolor="#fdebd0"];
    NOCT     [label="Nocturnal stools", fillcolor="#fdebd0"];
    URGENCY  [label="Fecal urgency /\nincontinence", fillcolor="#fdebd0"];
    ABD_P    [label="Abdominal pain /\ncramping", fillcolor="#fdebd0"];
    WEIGHT   [label="Weight loss /\ndehydration", fillcolor="#fdebd0"];
    HJORTS   [label="Hjortswang\nclinical remission\n(<3 stools, <1 watery)", fillcolor="#fdebd0"];
    QOL      [label="HRQoL\n(SF-36, IBDQ)", fillcolor="#fdebd0"];
    FATIGUE  [label="Fatigue / depression\n(50% of patients)", fillcolor="#fdebd0"];
  }

  /* =================================================================== */
  /* 11. Drug PK Compartments                                            */
  /* =================================================================== */
  subgraph cluster_pk {
    label="⑪ Drug PK"; style="rounded,filled"; fillcolor="#e8f6f3"; color="#0e6655";
    BUD_PO   [label="Budesonide MMX 9 mg PO\n(pH/time-release)", fillcolor="#d0ece7"];
    BUD_GUT  [label="Budesonide gut lumen\n(local mucosal AUC)", fillcolor="#d0ece7"];
    BUD_CEN  [label="Budesonide plasma\n(CL ≈ 1.4 L/h/kg, 90% FPE)", fillcolor="#d0ece7"];
    CHOL_PO  [label="Cholestyramine 4–16 g PO\n(non-absorbed)", fillcolor="#d0ece7"];
    MESAL_PO [label="Mesalamine 2.4–4.8 g PO", fillcolor="#d0ece7"];
    BIS_PO   [label="Bismuth subsalicylate", fillcolor="#d0ece7"];
    LOP_PO   [label="Loperamide PO", fillcolor="#d0ece7"];
    AZA_PO   [label="Azathioprine 2 mg/kg PO\n(→ 6-TGN)", fillcolor="#d0ece7"];
    IFX_IV   [label="Infliximab IV\n(anti-TNF)", fillcolor="#d0ece7"];
    VDZ_IV   [label="Vedolizumab IV\n(anti-α4β7)", fillcolor="#d0ece7"];
    ADA_SC   [label="Adalimumab SC", fillcolor="#d0ece7"];
  }

  /* =================================================================== */
  /* 12. Drug PD targets                                                 */
  /* =================================================================== */
  subgraph cluster_pd {
    label="⑫ Drug PD Mechanisms"; style="rounded,filled"; fillcolor="#f5eef8"; color="#5b2c6f";
    GR_NUC   [label="GR nuclear translocation\n(budesonide)", fillcolor="#e8daef"];
    NFKB_X   [label="NF-κB transrepression", fillcolor="#e8daef"];
    BA_BIND  [label="BA chelation\n(cholestyramine, colesevelam)", fillcolor="#e8daef"];
    PPAR     [label="5-ASA: PPAR-γ activation", fillcolor="#e8daef"];
    PG_INH   [label="Bismuth: anti-secretory\n+ PG modulation", fillcolor="#e8daef"];
    MOR      [label="Loperamide: μ-opioid\nperistaltic inhibition", fillcolor="#e8daef"];
    TPMT     [label="AZA → 6-TGN\n(TPMT-dependent)", fillcolor="#e8daef"];
    TNF_NEU  [label="TNF neutralization", fillcolor="#e8daef"];
    A4B7     [label="α4β7 / MAdCAM-1\nblockade (gut homing)", fillcolor="#e8daef"];
  }

  /* =================================================================== */
  /* 13. Comorbidities & Long-term Outcomes                              */
  /* =================================================================== */
  subgraph cluster_com {
    label="⑬ Comorbidities & Outcomes"; style="rounded,filled"; fillcolor="#fdf2e9"; color="#a04000";
    CELIAC   [label="Celiac disease (10–20%)", fillcolor="#fae5d3"];
    THYROID  [label="Autoimmune thyroiditis", fillcolor="#fae5d3"];
    RA_OV    [label="Rheumatoid arthritis /\nSjogren overlap", fillcolor="#fae5d3"];
    OSTEOP   [label="GC-induced bone loss\n(BMD ↓)", fillcolor="#fae5d3"];
    HPA_AX   [label="HPA axis suppression\n(systemic GC)", fillcolor="#fae5d3"];
    INFECT_R [label="Opportunistic infection\n(AZA/biologics)", fillcolor="#fae5d3"];
    RELAPSE  [label="Relapse on withdrawal\n(60–80%)", fillcolor="#fae5d3"];
    CRC_NO   [label="No ↑ colorectal\ncancer risk", fillcolor="#fae5d3"];
    QALY     [label="QALY / cost-effectiveness", fillcolor="#fae5d3"];
  }

  /* =================================================================== */
  /* Inter-cluster edges                                                 */
  /* =================================================================== */
  NSAID    -> EPI_DMG     [label="COX inh /\nbarrier"];
  NSAID    -> PROTEO;
  PPI      -> DYSBIO      [label="gastric acid ↓"];
  PPI      -> BILE_LUM    [label="bile pool"];
  SSRI     -> MAST        [label="5-HT signaling"];
  SSRI     -> SECR_BAM    [label="enteric 5-HT"];
  STATIN   -> EPI_DMG;
  ARANS    -> EPI_DMG;
  SMOKE    -> CD8_IEL     [label="immune skew"];
  SMOKE    -> COLI;
  AGE      -> CD8_IEL;
  FEMALE   -> TREG;
  BILE_TRG -> BAM;
  INFECT   -> EPI_DMG;
  INFECT   -> DYSBIO;

  HLA_DQ   -> CD8_IEL;
  HLA_DQ   -> CELIAC;
  CELIAC_g -> CD8_IEL;
  MMP9_g   -> MMP9;
  IL6_g    -> IL6;
  NOD2_g   -> EPI_DMG;

  DYSBIO   -> F_PRAUS     [dir=back];
  DYSBIO   -> AKKER       [dir=back];
  DYSBIO   -> LACHN       [dir=back];
  DYSBIO   -> PROTEO;
  F_PRAUS  -> SCFA        [label="butyrate"];
  SCFA     -> EPI_DMG     [label="protects"];
  BILE_LUM -> COL_DCA;
  PROTEO   -> LPS_LUM;
  LPS_LUM  -> APC         [label="TLR4"];

  EPI_DMG  -> PERMEAB;
  CLAUDIN  -> PERMEAB;
  ZO1      -> PERMEAB;
  EPI_DMG  -> APOPT;
  MUC2     -> EPI_DMG     [label="loss"];
  GOBLET   -> MUC2;
  PERMEAB  -> APC         [label="Ag delivery"];

  APC      -> CD4_LP;
  APC      -> CD8_IEL;
  CD4_LP   -> TH1;
  CD4_LP   -> TH17;
  TH1      -> IFNG;
  TH17     -> IL17;
  TH17     -> IL22;
  APC      -> IL23;
  IL23     -> TH17;
  CD8_IEL  -> IFNG;
  CD8_IEL  -> APOPT       [label="cytotoxic"];
  IL15     -> CD8_IEL     [label="survival"];
  EPI_DMG  -> IL15;
  IL6_g    -> IL6;
  IL6      -> TH17;
  TREG     -> TH1         [label="↓ suppresses"];
  TREG     -> TH17        [label="↓ suppresses"];
  BREG     -> IL6;
  MAST     -> TGFB;
  MAST     -> COLI;
  EOSIN    -> TGFB;
  NK       -> IFNG;

  IFNG     -> EPI_DMG;
  IFNG     -> CLAUDIN     [label="↓"];
  IFNG     -> NHE3        [label="↓"];
  TNFA     -> EPI_DMG;
  TNFA     -> APOPT;
  TNFA     -> CLAUDIN     [label="↓"];
  IL17     -> NEUTRO;
  IL17     -> CXCL10;
  IL1B     -> NEUTRO;
  GMCSF    -> APC;
  CXCL10   -> CD8_IEL;
  CCL5     -> CD4_LP;

  TGFB     -> PERICYTE;
  PERICYTE -> SMA;
  PERICYTE -> COLI;
  COLI     -> BANDTHK;
  TENA     -> COLI;
  MMP9     -> COLI        [label="↓ degrade"];
  VEGF     -> COLI;
  BANDTHK  -> NETFLX      [label="↓ absorption"];
  BANDTHK  -> NHE3        [label="diffusion barrier"];

  BAM      -> COL_DCA;
  BAM      -> FGF19       [label="↓"];
  FGF19    -> CYP7A1      [label="↓ inh"];
  CYP7A1   -> BAM         [label="more BA"];
  ASBT     -> BAM;
  COL_DCA  -> SECR_BAM;
  COL_DCA  -> CFTR;
  COL_DCA  -> EPI_DMG;
  TGR5     -> COL_DCA;
  SECR_BAM -> DIARR;

  NHE3     -> NETFLX      [label="↓"];
  NKCC1    -> NETFLX      [label="↑ secrete"];
  CFTR     -> NETFLX;
  NA_KATP  -> NETFLX;
  AQP4     -> NETFLX;
  NETFLX   -> DIARR;
  NETFLX   -> STOOL_W;
  NETFLX   -> HYPOK;
  DIARR    -> URGENCY;
  DIARR    -> NOCT;
  DIARR    -> ABD_P;
  DIARR    -> WEIGHT;
  DIARR    -> QOL          [label="↓"];
  DIARR    -> FATIGUE;
  STOOL_W  -> HJORTS       [label="defines"];
  NOCT     -> QOL          [label="↓↓"];

  /* PK -> tissue / PD edges */
  BUD_PO   -> BUD_GUT     [label="release Tlag ~3h"];
  BUD_GUT  -> GR_NUC      [label="local"];
  BUD_GUT  -> BUD_CEN     [label="ka, F~10%"];
  BUD_CEN  -> HPA_AX      [label="systemic"];
  BUD_CEN  -> OSTEOP;
  GR_NUC   -> NFKB_X;
  NFKB_X   -> TNFA        [label="↓"];
  NFKB_X   -> IFNG        [label="↓"];
  NFKB_X   -> IL6         [label="↓"];
  NFKB_X   -> IL17        [label="↓"];
  GR_NUC   -> CD8_IEL     [label="↓ apoptosis"];
  GR_NUC   -> TGFB        [label="↓"];
  GR_NUC   -> COLI        [label="↓ deposition"];
  GR_NUC   -> NHE3        [label="↑ restore"];

  CHOL_PO  -> BA_BIND;
  BA_BIND  -> COL_DCA     [label="↓"];
  BA_BIND  -> SECR_BAM    [label="↓"];

  MESAL_PO -> PPAR;
  PPAR     -> NFKB_X;
  MESAL_PO -> COX2        [style=invis];

  BIS_PO   -> PG_INH;
  PG_INH   -> NETFLX      [label="↓ secrete"];
  BIS_PO   -> H_PYL       [style=invis];

  LOP_PO   -> MOR;
  MOR      -> NETFLX      [label="↓ motility +\n↓ secretion"];
  MOR      -> URGENCY;

  AZA_PO   -> TPMT;
  TPMT     -> CD4_LP      [label="↓ proliferation"];
  TPMT     -> CD8_IEL     [label="↓"];

  IFX_IV   -> TNF_NEU;
  ADA_SC   -> TNF_NEU;
  TNF_NEU  -> TNFA        [label="↓ free"];
  TNF_NEU  -> EPI_DMG     [label="↓"];

  VDZ_IV   -> A4B7;
  A4B7     -> CD4_LP      [label="↓ gut homing"];
  A4B7     -> CD8_IEL     [label="↓ recruit"];

  /* Comorbidities */
  CD8_IEL  -> CELIAC      [label="overlap"];
  HLA_DQ   -> CELIAC;
  TH1      -> THYROID;
  TREG     -> RA_OV       [label="↓ suppress"];
  BUD_CEN  -> OSTEOP      [label="systemic GC"];
  IFX_IV   -> INFECT_R;
  AZA_PO   -> INFECT_R;
  RELAPSE  -> HJORTS      [label="loss"];
  HJORTS   -> QALY;
  QOL      -> QALY;

  /* Latent invisible nodes used as anchors */
  COX2 [style=invis]; H_PYL [style=invis];

  /* Rank hints */
  { rank=same; NSAID; PPI; SSRI; SMOKE; }
  { rank=same; DIARR; STOOL_W; HJORTS; QOL; }
  { rank=same; BUD_PO; CHOL_PO; MESAL_PO; BIS_PO; LOP_PO; AZA_PO; IFX_IV; VDZ_IV; ADA_SC; }
}
