// ============================================================
// Rheumatoid Arthritis - Quantitative Systems Pharmacology Map
// Version 1.0 | 2026-06-16
// Covers: Immune activation, cytokine networks, JAK-STAT/NF-kB signaling,
//         synovial pathology, bone/cartilage destruction, pain signaling,
//         Drug PK/PD (cDMARDs + biologics + JAKi), biomarkers, clinical endpoints
// ============================================================
digraph RA_QSP {

    graph [
        label="Rheumatoid Arthritis — QSP Mechanistic Map\nPathophysiology · Drug PK/PD · Clinical Endpoints",
        labelloc=t, labeljust=c,
        fontsize=22, fontname="Helvetica-Bold",
        bgcolor="#F5F5F5",
        pad=1.2, nodesep=0.35, ranksep=0.75,
        splines=curved,
        overlap=false
    ]
    node [fontname="Helvetica", fontsize=9, style="filled,rounded", margin="0.12,0.06", shape=box]
    edge [fontname="Helvetica", fontsize=7, arrowsize=0.55, penwidth=0.9]

    // ============================================================
    // CLUSTER 1 – Immune Cell Populations
    // ============================================================
    subgraph cluster_immune {
        label="Immune Cell Populations"
        style=filled fillcolor="#FFF3E0" color="#E65100" penwidth=2.5 fontsize=13 fontname="Helvetica-Bold"
        node [fillcolor="#FFE0B2"]

        Antigen        [label="Foreign/Self\nAntigen",       shape=diamond, fillcolor="#FFCCBC"]
        DC             [label="Dendritic Cell\n(DC)",                       fillcolor="#FFCC80"]
        Macrophage_M0  [label="Macrophage\n(Resting M0)"]
        Macrophage_M1  [label="Macrophage\n(Activated M1)", fillcolor="#FF8A65"]
        CD4_naive      [label="CD4⁺ T Cell\n(Naïve)"]
        Th1            [label="Th1 Cell",                   fillcolor="#FFB74D"]
        Th17           [label="Th17 Cell",                  fillcolor="#FFA726"]
        Treg           [label="Treg Cell",                  fillcolor="#A5D6A7"]
        CD8_T          [label="CD8⁺ T Cell\n(Cytotoxic)"]
        NK_cell        [label="NK Cell"]
        B_naive        [label="B Cell\n(Naïve)"]
        B_activated    [label="B Cell\n(Activated)",        fillcolor="#FFB74D"]
        Plasmablast    [label="Plasmablast"]
        Plasma_cell    [label="Plasma Cell",                fillcolor="#FF8A65"]
        Neutrophil     [label="Neutrophil",                 fillcolor="#FFCC80"]
        Mast_cell      [label="Mast Cell"]
        NET_formation  [label="NETosis /\nNET Formation"]
        Tfh_cell       [label="Tfh Cell\n(Follicular Helper)"]
        GC_B_cell      [label="Germinal Center\nB Cell"]
    }

    // ============================================================
    // CLUSTER 2 – Autoantibody & Immune Complex Formation
    // ============================================================
    subgraph cluster_autoab {
        label="Autoantibody & Immune Complex Formation"
        style=filled fillcolor="#FCE4EC" color="#880E4F" penwidth=2.5 fontsize=13 fontname="Helvetica-Bold"
        node [fillcolor="#F8BBD9"]

        PAD4              [label="PAD4/PAD2\nEnzyme (citrullination)"]
        Citrullinated_prot[label="Citrullinated\nProteins (fibrinogen,\nvimentin, α-enolase)"]
        ACPA              [label="ACPA / Anti-CCP\nAutoantibody",  fillcolor="#F48FB1"]
        RF                [label="Rheumatoid\nFactor (RF)",        fillcolor="#F48FB1"]
        IgG_Fc            [label="IgG Fc\nRegion"]
        Immune_complex    [label="Immune Complex\n(IC)",           fillcolor="#EC407A"]
        Complement_C1q    [label="Complement\nC1q Binding"]
        Complement_C3     [label="C3/C5\nActivation (C5a, MAC)"]
        FcgRIII           [label="FcγRIII\n(on Macrophage/NK)"]
        BLyS_BAFF         [label="BLyS / BAFF\n(B cell survival)"]
        APRIL             [label="APRIL\n(Ig class switch)"]
    }

    // ============================================================
    // CLUSTER 3 – Cytokine Network
    // ============================================================
    subgraph cluster_cytokines {
        label="Cytokine Network"
        style=filled fillcolor="#E3F2FD" color="#0D47A1" penwidth=2.5 fontsize=13 fontname="Helvetica-Bold"
        node [fillcolor="#BBDEFB"]

        TNFa   [label="TNF-α",            fillcolor="#EF9A9A"]
        IL1b   [label="IL-1β",            fillcolor="#EF9A9A"]
        IL2    [label="IL-2"]
        IL4    [label="IL-4",             fillcolor="#C8E6C9"]
        IL6    [label="IL-6",             fillcolor="#EF9A9A"]
        IL7    [label="IL-7\n(T/B survival)"]
        IL8    [label="IL-8 / CXCL8"]
        IL10   [label="IL-10\n(Anti-inflam)",fillcolor="#C8E6C9"]
        IL12   [label="IL-12\n(p40/p35)"]
        IL13   [label="IL-13",            fillcolor="#C8E6C9"]
        IL15   [label="IL-15"]
        IL17A  [label="IL-17A",           fillcolor="#FFCC80"]
        IL17F  [label="IL-17F"]
        IL18   [label="IL-18"]
        IL21   [label="IL-21\n(B cell class switch)"]
        IL22   [label="IL-22"]
        IL23   [label="IL-23\n(p19/p40)",  fillcolor="#FFCC80"]
        IL33   [label="IL-33\n(alarmin)"]
        IL34   [label="IL-34\n(CSF1R ligand)"]
        IFNg   [label="IFN-γ",            fillcolor="#BBDEFB"]
        GM_CSF [label="GM-CSF\n(CSF2)"]
        M_CSF  [label="M-CSF\n(CSF1)"]
        VEGF   [label="VEGF-A",           fillcolor="#B3E5FC"]
        TGFb   [label="TGF-β",            fillcolor="#C8E6C9"]
        CXCL13 [label="CXCL13\n(B-cell chemoattractant)"]
        CCL2   [label="CCL2 / MCP-1\n(Macrophage recruit)"]
        CCL5   [label="CCL5 / RANTES\n(T-cell recruit)"]
        CXCL10 [label="CXCL10 / IP-10\n(Th1 recruit)"]
        Oncostatin_M [label="Oncostatin M\n(OSM, IL-6 family)"]
    }

    // ============================================================
    // CLUSTER 4 – Intracellular Signaling
    // ============================================================
    subgraph cluster_signaling {
        label="Intracellular Signaling Pathways"
        style=filled fillcolor="#F3E5F5" color="#4A148C" penwidth=2.5 fontsize=13 fontname="Helvetica-Bold"
        node [fillcolor="#E1BEE7"]

        JAK1          [label="JAK1"]
        JAK2          [label="JAK2"]
        JAK3          [label="JAK3"]
        TYK2          [label="TYK2"]
        STAT1         [label="STAT1"]
        STAT3         [label="STAT3",          fillcolor="#CE93D8"]
        STAT4         [label="STAT4"]
        STAT5         [label="STAT5"]
        STAT6         [label="STAT6"]
        STAT3_nuclear [label="STAT3 Nuclear\nTranslocation",fillcolor="#AB47BC"]
        NFkB_inactive [label="NF-κB (Inactive)\nIκBα-bound"]
        NFkB_active   [label="NF-κB (Active)\np50/p65",     fillcolor="#AB47BC"]
        IkBa          [label="IκBα\n(NF-κB inhibitor)",fillcolor="#C8E6C9"]
        IKK_complex   [label="IKK Complex\n(IKKα/β/γ)"]
        MAPK_p38      [label="p38 MAPK",       fillcolor="#CE93D8"]
        ERK1_2        [label="ERK1/2\n(MAPK cascade)"]
        JNK           [label="JNK\n(stress kinase)"]
        PI3K          [label="PI3K\n(p85/p110)"]
        Akt           [label="Akt / PKB"]
        mTOR          [label="mTOR\n(mTORC1)"]
        AP1           [label="AP-1\n(c-Fos/c-Jun)"]
        HIF1a         [label="HIF-1α\n(hypoxia transcription)"]
        Notch1        [label="Notch1\n(FLS invasiveness)"]
        TRAF6         [label="TRAF6\n(RANK adapter)"]
        NFAT_c1       [label="NFATc1\n(osteoclast master TF)"]
        Wnt_bcatenin  [label="Wnt / β-catenin\nSignaling",fillcolor="#C8E6C9"]
        DKK1          [label="DKK-1\n(Wnt antagonist)"]
        Sclerostin    [label="Sclerostin / SOST\n(Wnt antagonist)"]
    }

    // ============================================================
    // CLUSTER 5 – Synovial Joint Pathology
    // ============================================================
    subgraph cluster_synovium {
        label="Synovial Joint Pathology"
        style=filled fillcolor="#FFF8E1" color="#F57F17" penwidth=2.5 fontsize=13 fontname="Helvetica-Bold"
        node [fillcolor="#FFECB3"]

        Synovial_lining   [label="Synovial\nLining (Intima)"]
        FLS_quiescent     [label="FLS (Quiescent)\nFibroblast-like\nSynoviocyte"]
        FLS_activated     [label="FLS (Activated)\n\"Tumor-like\"\nPhenotype",fillcolor="#FFD54F"]
        Synovial_mac      [label="Synovial\nMacrophage"]
        Pannus            [label="Pannus\nTissue",fillcolor="#FF8F00"]
        COX2              [label="COX-2\n(Cyclooxygenase-2)"]
        cPLA2             [label="cPLA2\n(Arachidonic acid\nrelease)"]
        PGE2              [label="PGE2\n(Prostaglandin E2)"]
        LTB4              [label="LTB4\n(Leukotriene B4)"]
        MMP1              [label="MMP-1\n(Interstitial\nCollagenase)"]
        MMP2              [label="MMP-2\n(Gelatinase A)"]
        MMP3              [label="MMP-3\n(Stromelysin-1)"]
        MMP9              [label="MMP-9\n(Gelatinase B)"]
        MMP13             [label="MMP-13\n(Collagenase-3)"]
        ADAMTS4           [label="ADAMTS-4\n(Aggrecanase-1)"]
        ADAMTS5           [label="ADAMTS-5\n(Aggrecanase-2)"]
        TIMP1             [label="TIMP-1\n(MMP inhibitor)",fillcolor="#C8E6C9"]
        TIMP2             [label="TIMP-2\n(MMP inhibitor)",fillcolor="#C8E6C9"]
        Synovial_fluid_vol[label="Synovial Fluid\nVolume (effusion)"]
        Arachidonate      [label="Arachidonic\nAcid (AA)"]
    }

    // ============================================================
    // CLUSTER 6 – Synovial Vasculature
    // ============================================================
    subgraph cluster_vasculature {
        label="Synovial Vasculature & Endothelium"
        style=filled fillcolor="#E8F5E9" color="#1B5E20" penwidth=2.5 fontsize=13 fontname="Helvetica-Bold"
        node [fillcolor="#C8E6C9"]

        Endothelial_cell [label="Endothelial\nCell (EC)"]
        ICAM1            [label="ICAM-1\n(adhesion)"]
        VCAM1            [label="VCAM-1\n(adhesion)"]
        Selectin_E       [label="E-Selectin\n(adhesion)"]
        Neoangiogenesis  [label="Neo-\nAngiogenesis"]
        Hypoxia          [label="Synovial\nHypoxia (↓O₂)"]
        eNOS_NO          [label="eNOS/NO\n(vasodilation)",fillcolor="#A5D6A7"]
        PDGF             [label="PDGF\n(fibroblast growth)"]
        Ang1_2           [label="Angiopoietin-1/2\n(vessel stability)"]
        Pericyte         [label="Pericyte\n(vessel coverage)"]
    }

    // ============================================================
    // CLUSTER 7 – Bone & Cartilage Destruction
    // ============================================================
    subgraph cluster_bone {
        label="Bone & Cartilage Destruction"
        style=filled fillcolor="#EFEBE9" color="#3E2723" penwidth=2.5 fontsize=13 fontname="Helvetica-Bold"
        node [fillcolor="#D7CCC8"]

        OPG          [label="OPG\n(Osteoprotegerin\ndecoy receptor)",fillcolor="#A5D6A7"]
        RANKL        [label="RANKL\n(TNFSF11)",fillcolor="#BCAAA4"]
        RANK         [label="RANK\n(Osteoclast receptor)"]
        OC_precursor [label="Osteoclast\nPrecursor (monocyte)"]
        Osteoclast   [label="Osteoclast\n(Activated)",fillcolor="#A1887F"]
        Osteoblast   [label="Osteoblast",fillcolor="#A5D6A7"]
        Bone_erosion [label="Periarticular\nBone Erosion",fillcolor="#8D6E63",shape=diamond]
        Bone_formation[label="Bone\nFormation",fillcolor="#A5D6A7"]
        BMD          [label="BMD\n(Bone Mineral Density)"]
        Cartilage_ECM[label="Cartilage\nExtracellular Matrix"]
        Type_II_coll [label="Type II\nCollagen"]
        Aggrecan     [label="Aggrecan\n(Proteoglycan)"]
        Chondrocyte  [label="Chondrocyte"]
        Chondrocyte_apop[label="Chondrocyte\nApoptosis",fillcolor="#8D6E63"]
        Cartilage_damage[label="Cartilage\nDamage / JSN",fillcolor="#8D6E63",shape=diamond]
        Cathepsin_K  [label="Cathepsin K\n(acid protease)"]
        Tartrate_AcPh[label="TRAP\n(Osteoclast marker)"]
    }

    // ============================================================
    // CLUSTER 8 – Pain Signaling
    // ============================================================
    subgraph cluster_pain {
        label="Pain Signaling Pathways"
        style=filled fillcolor="#FCE4EC" color="#B71C1C" penwidth=2.5 fontsize=13 fontname="Helvetica-Bold"
        node [fillcolor="#FFCDD2"]

        Nociceptor       [label="Nociceptor\n(C-fiber / Aδ-fiber)"]
        SubstanceP       [label="Substance P\n(NK1 receptor)"]
        CGRP_pain        [label="CGRP\n(vasodilatory neuropeptide)"]
        Bradykinin       [label="Bradykinin\n(B2→B1 receptor)"]
        NGF              [label="NGF\n(Nerve Growth Factor)"]
        TrkA             [label="TrkA / p75NTR\n(NGF receptor)"]
        TRPV1            [label="TRPV1\n(heat/capsaicin channel)"]
        Nav1_7           [label="Nav1.7 / Nav1.8\n(voltage-gated Na⁺ channel)"]
        Peripheral_sens  [label="Peripheral\nSensitization",fillcolor="#EF9A9A"]
        Spinal_dorsal    [label="Dorsal Horn\nNeuron (spinal cord)"]
        NMDA_rec         [label="NMDA Receptor\n(central synapse)"]
        Substance_P_spinal[label="Substance P\nSpinal Release"]
        Central_sens     [label="Central\nSensitization",fillcolor="#EF9A9A"]
        PainVAS          [label="Pain VAS\nScore (0–100)",fillcolor="#EF5350",shape=oval]
        Fatigue_score    [label="Fatigue\n(NRS/FACIT)"]
    }

    // ============================================================
    // CLUSTER 9 – Drug PK Compartments
    // ============================================================
    subgraph cluster_pk {
        label="Drug Pharmacokinetics"
        style=filled fillcolor="#E8EAF6" color="#1A237E" penwidth=2.5 fontsize=13 fontname="Helvetica-Bold"
        node [fillcolor="#C5CAE9"]

        Dose_oral       [label="Oral Dose\n(cDMARD)",          shape=cylinder]
        Dose_SC         [label="SC Dose\n(Biologic/JAKi)",     shape=cylinder]
        Dose_IV         [label="IV Infusion\n(Biologic)",      shape=cylinder]
        GI_absorb       [label="GI Absorption\n(F_oral, ka)"]
        SC_depot        [label="SC Depot\n(F_SC, ka_SC)"]
        C1_cDMARD       [label="Plasma\ncDMARD (C₁)",         fillcolor="#9FA8DA"]
        C2_cDMARD       [label="Tissue\ncDMARD (C₂)"]
        C_synovium_cD   [label="Synovial\ncDMARD (Ceff)"]
        C1_biologic     [label="Plasma\nBiologic (C₁)",       fillcolor="#9FA8DA"]
        C2_biologic     [label="Peripheral\nBiologic (C₂)"]
        C_synovium_biol [label="Synovial\nBiologic (Ceff)"]
        Renal_CL        [label="Renal\nClearance"]
        Hepatic_CL      [label="Hepatic\nClearance / CYP"]
        FcRn_recycling  [label="FcRn\nRecycling (IgG)",       fillcolor="#A5D6A7"]
        ADA_biologic    [label="Anti-Drug\nAntibody (ADA)",   fillcolor="#FFCCBC"]
        TMDD_complex    [label="Drug-Target\nComplex (TMDD)"]
        Protein_binding [label="Plasma Protein\nBinding (α₁-AGP)"]
    }

    // ============================================================
    // CLUSTER 10 – Drug Mechanisms of Action
    // ============================================================
    subgraph cluster_drugs {
        label="Drug Mechanisms of Action"
        style=filled fillcolor="#E0F7FA" color="#006064" penwidth=2.5 fontsize=13 fontname="Helvetica-Bold"
        node [fillcolor="#B2EBF2", shape=hexagon]

        // conventional DMARDs
        MTX          [label="Methotrexate\n(MTX)",              fillcolor="#80DEEA"]
        MTX_DHFR     [label="DHFR\nInhibition",                 shape=box, fillcolor="#B2EBF2"]
        MTX_AICAR    [label="AICAR →\nAdenosine Release",       shape=box]
        MTX_folate   [label="Folate\nDepletion",                shape=box]
        LEF          [label="Leflunomide\n(LEF/A771726)",       fillcolor="#80DEEA"]
        LEF_DHODH    [label="DHODH\nInhibition",                shape=box]
        LEF_pyrimid  [label="Pyrimidine\nDepletion",            shape=box]
        HCQ          [label="Hydroxychloroquine\n(HCQ)",        fillcolor="#80DEEA"]
        HCQ_lysosm   [label="Lysosomal pH↑\nTLR7/9 Inhibition",shape=box]
        SSZ          [label="Sulfasalazine\n(SSZ)",             fillcolor="#80DEEA"]
        SSZ_NF       [label="NF-κB &\nPG Inhibition",          shape=box]

        // NSAIDs
        NSAID        [label="NSAIDs\n(Naproxen/\nCelecoxib)",   fillcolor="#80DEEA"]
        NSAID_COX    [label="COX-1/2\nBlockade",                shape=box]

        // Glucocorticoids
        GC           [label="Glucocorticoids\n(Prednisone)",    fillcolor="#80DEEA"]
        GC_GR        [label="GR\nActivation",                   shape=box]
        GC_NFkB_supp [label="NF-κB\nTransrepression",           shape=box]
        GC_AP1_supp  [label="AP-1\nTransrepression",            shape=box]

        // TNF inhibitors
        Etanercept   [label="Etanercept\n(TNFR-Fc)",           fillcolor="#4DD0E1"]
        Infliximab   [label="Infliximab\n(anti-TNF chimeric)",  fillcolor="#4DD0E1"]
        Adalimumab   [label="Adalimumab\n(anti-TNF fully human)",fillcolor="#4DD0E1"]
        Certolizumab [label="Certolizumab\nPegol (PEGylated Fab')",fillcolor="#4DD0E1"]
        Golimumab    [label="Golimumab\n(anti-TNF human)",      fillcolor="#4DD0E1"]

        // IL-6 pathway inhibitors
        Tocilizumab  [label="Tocilizumab\n(anti-IL6Rα mAb)",   fillcolor="#4DD0E1"]
        Sarilumab    [label="Sarilumab\n(anti-IL6Rα mAb)",     fillcolor="#4DD0E1"]
        Satralizumab [label="Satralizumab\n(anti-IL6Rα SC)",   fillcolor="#4DD0E1"]
        Siltuximab   [label="Siltuximab\n(anti-IL6 mAb)",      fillcolor="#4DD0E1"]

        // Co-stimulation / B-cell
        Abatacept    [label="Abatacept\n(CTLA4-Ig)",           fillcolor="#4DD0E1"]
        Rituximab    [label="Rituximab\n(anti-CD20)",           fillcolor="#4DD0E1"]
        Obinutuzumab [label="Obinutuzumab\n(anti-CD20 GIII)",   fillcolor="#4DD0E1"]

        // Bone-targeted
        Denosumab    [label="Denosumab\n(anti-RANKL)",          fillcolor="#4DD0E1"]
        Zoledronate  [label="Bisphosphonate\n(Zoledronate)",    fillcolor="#80DEEA"]

        // JAK inhibitors
        Baricitinib  [label="Baricitinib\n(JAK1/2i)",          fillcolor="#26C6DA"]
        Tofacitinib  [label="Tofacitinib\n(JAK1/3i pan-JAKi)", fillcolor="#26C6DA"]
        Upadacitinib [label="Upadacitinib\n(selective JAK1i)", fillcolor="#26C6DA"]
        Filgotinib   [label="Filgotinib\n(selective JAK1i)",   fillcolor="#26C6DA"]
    }

    // ============================================================
    // CLUSTER 11 – Biomarkers & Laboratory Values
    // ============================================================
    subgraph cluster_biomarkers {
        label="Biomarkers & Laboratory Values"
        style=filled fillcolor="#F1F8E9" color="#33691E" penwidth=2.5 fontsize=13 fontname="Helvetica-Bold"
        node [fillcolor="#DCEDC8"]

        CRP_serum       [label="Serum CRP\n(mg/L)",          fillcolor="#A5D6A7"]
        ESR_serum       [label="ESR\n(mm/hr)",               fillcolor="#A5D6A7"]
        IL6_serum       [label="Serum IL-6\n(pg/mL)"]
        TNF_serum       [label="Serum TNF-α\n(pg/mL)"]
        MMP3_serum      [label="Serum MMP-3\n(ng/mL)"]
        RF_titer        [label="RF Titer\n(IU/mL)"]
        AntiCCP_titer   [label="Anti-CCP\n(U/mL)"]
        Fibrinogen_serum[label="Fibrinogen\n(g/L, acute phase)"]
        SAA_serum       [label="Serum Amyloid A\n(SAA, mg/L)"]
        sIL6R_serum     [label="Soluble IL-6R\n(sIL6Rα, ng/mL)"]
        Hepcidin_serum  [label="Hepcidin\n(µg/L)"]
        Hb_level        [label="Hemoglobin\n(g/dL ↓ in CID)"]
        WBC_count       [label="WBC Count\n(×10³/µL)"]
        PLT_count       [label="Platelet Count\n(×10³/µL)"]
        RANKL_serum     [label="Serum RANKL\n(pmol/L)"]
        OPG_serum       [label="Serum OPG\n(pmol/L)"]
    }

    // ============================================================
    // CLUSTER 12 – Clinical Endpoints
    // ============================================================
    subgraph cluster_endpoints {
        label="Clinical Endpoints"
        style=filled fillcolor="#E8F5E9" color="#2E7D32" penwidth=2.5 fontsize=13 fontname="Helvetica-Bold"
        node [fillcolor="#A5D6A7", shape=oval]

        SJC28           [label="SJC-28\n(Swollen Joint Count)"]
        TJC28           [label="TJC-28\n(Tender Joint Count)"]
        PatientGlobal   [label="Patient Global\nAssessment (PtGA)"]
        PhysicianGlobal [label="Physician Global\n(EGA)"]
        DAS28_CRP       [label="DAS28-CRP\nScore",           fillcolor="#43A047",fontcolor=white]
        DAS28_ESR       [label="DAS28-ESR\nScore",           fillcolor="#43A047",fontcolor=white]
        ACR20           [label="ACR20\nResponse",            fillcolor="#2E7D32",fontcolor=white]
        ACR50           [label="ACR50\nResponse",            fillcolor="#2E7D32",fontcolor=white]
        ACR70           [label="ACR70\nResponse",            fillcolor="#2E7D32",fontcolor=white]
        CDAI            [label="CDAI\n(Clinical DAI)"]
        SDAI            [label="SDAI\n(Simplified DAI)"]
        HAQ_DI          [label="HAQ-DI\n(Disability Index)"]
        Sharp_score     [label="Sharp/vdH Score\n(X-ray erosion+JSN)"]
        MRI_RAMRIS      [label="RAMRIS\n(MRI synovitis)"]
        ACR_EULAR_rem   [label="ACR/EULAR\nRemission",      fillcolor="#1B5E20",fontcolor=white]
        MBDA_score      [label="MBDA Score\n(multi-biomarker DA)"]
    }

    // ============================================================
    // CLUSTER 13 – Systemic Complications
    // ============================================================
    subgraph cluster_systemic {
        label="Systemic Complications & Comorbidities"
        style=filled fillcolor="#FFEBEE" color="#B71C1C" penwidth=2.5 fontsize=13 fontname="Helvetica-Bold"
        node [fillcolor="#FFCDD2"]

        CV_risk      [label="↑ CV Risk\n(MI, Stroke, HF)"]
        Atheroscler  [label="Accelerated\nAtherosclerosis"]
        BMD_loss     [label="↓ BMD\n(Secondary\nOsteoporosis)"]
        ILD          [label="Interstitial\nLung Disease\n(RA-ILD)"]
        Lymphoma_risk[label="↑ Lymphoma\nRisk"]
        Infect_risk  [label="↑ Infection\nRisk (DMARD)"]
        VTE_risk     [label="↑ VTE Risk\n(JAKi class effect)"]
        Depression   [label="Depression /\nAnxiety"]
        Anemia_CID   [label="Anemia of\nChronic Inflammation"]
        Thrombocytos [label="Reactive\nThrombocytosis"]
        Amyloidosis  [label="Secondary AA\nAmyloidosis"]
        Sicca        [label="Secondary Sjögren\n(Sicca features)"]
        GI_toxicity  [label="GI Toxicity\n(NSAID/MTX)"]
        Hepatotox    [label="Hepatotoxicity\n(MTX/LEF)"]
        Bone_fracture[label="Fragility\nFracture Risk"]
    }

    // ==============================================================
    // EDGES
    // ==============================================================

    // --- Immune Cell Activation ---
    Antigen -> DC             [label="uptake &\npresentation"]
    Antigen -> Macrophage_M0  [label="phagocytosis"]
    DC -> CD4_naive           [label="MHC-II/TCR\npeptide complex"]
    DC -> IL12                [label="secretes"]
    DC -> IL23                [label="secretes"]
    DC -> IL6                 [label="secretes"]
