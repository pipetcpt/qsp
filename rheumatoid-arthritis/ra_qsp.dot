    Rituximab -> Plasmablast    [label="depletes\nCD20+ plasmablasts", color="#B71C1C"]
    Rituximab -> RF             [label="reduces\nRF titer", color="#B71C1C"]
    Rituximab -> ACPA           [label="reduces\nACPA titer", color="#B71C1C"]
    Obinutuzumab -> B_naive     [label="glycoengineered\nanti-CD20 (stronger ADCC)", color="#B71C1C"]

    Denosumab -> RANKL          [label="anti-RANKL mAb\nbinds with high affinity", color="#B71C1C"]
    Denosumab -> Osteoclast     [label="prevents\ndifferentiation", color="#B71C1C"]
    Denosumab -> Bone_erosion   [label="reduces\nradiographic progression", color="#B71C1C"]
    Zoledronate -> Osteoclast   [label="FPP synthase inhibition\n→ apoptosis", color="#B71C1C"]
    Zoledronate -> BMD          [label="antiresorptive\n→ BMD ↑", color="#2E7D32"]

    // --- Drug Mechanisms: JAK inhibitors ---
    Baricitinib -> JAK1         [label="JAK1 Ki<0.5nM\nJAK1/2 selective", color="#B71C1C"]
    Baricitinib -> JAK2         [label="JAK2 Ki~6nM", color="#B71C1C"]
    Tofacitinib -> JAK1         [label="JAK1 Ki~1nM\npan-JAKi", color="#B71C1C"]
    Tofacitinib -> JAK3         [label="JAK3 Ki~20nM", color="#B71C1C"]
    Upadacitinib -> JAK1        [label="JAK1 Ki~0.05nM\n>60× selectivity", color="#B71C1C"]
    Filgotinib -> JAK1          [label="JAK1 Ki~0.1nM\n>100× selectivity", color="#B71C1C"]
    Baricitinib -> STAT3        [label="blocks multiple\ncytokine STATs", color="#B71C1C"]
    Baricitinib -> STAT1        [label="IFNγ pathway\nblocked", color="#B71C1C"]
    Baricitinib -> STAT5        [label="IL-2/15 pathway\nblocked", color="#B71C1C"]
    Tofacitinib -> STAT3        [label="blocks IL-6\nSTAT3 signaling", color="#B71C1C"]
    Upadacitinib -> STAT3       [label="JAK1 selective\nSTAT3 block", color="#B71C1C"]
    Baricitinib -> VTE_risk     [label="class effect\n(↑ VTE observed)", color="#E65100"]
    Tofacitinib -> VTE_risk     [label="class effect\n(higher dose risk)", color="#E65100"]

    // --- Biomarkers ←→ Pathology ---
    IL6 -> IL6_serum            [label="systemic\ncirculation"]
    TNFa -> TNF_serum           [label="systemic\nspillover"]
    FLS_activated -> MMP3_serum [label="serum MMP-3\nbiomarker"]
    STAT3_nuclear -> CRP_serum  [label="hepatocyte\nCRP synthesis"]
    IL6 -> ESR_serum            [label="fibrinogen↑\n→ ESR↑"]
    Fibrinogen_serum -> ESR_serum [label="fibrinogen\ndetermines ESR"]
    Plasma_cell -> RF_titer     [label="RF production"]
    Plasma_cell -> AntiCCP_titer [label="ACPA\nproduction"]
    TNFa -> Anemia_CID          [label="hepcidin↑\niron sequestration"]
    IL6 -> Anemia_CID           [label="hepcidin↑\n→ ↓ Hb"]
    Hepcidin_serum -> Hb_level  [label="↓ iron\navailability", color="#B71C1C"]
    SAA_serum -> Amyloidosis    [label="AA amyloid\ndeposition\n(chronic high SAA)"]
    Tartrate_AcPh -> Bone_erosion [label="TRAP reflects\nosteoclast activity"]
    RANKL -> RANKL_serum        [label="reflects\nRANKL levels"]
    OPG -> OPG_serum            [label="reflects\nOPG production"]
    MMP3_serum -> MBDA_score    [label="component\nof MBDA"]
    CRP_serum -> MBDA_score     [label="component"]
    IL6_serum -> MBDA_score     [label="component"]

    // --- Clinical Endpoints ←→ Biomarkers/Pathology ---
    TNFa -> SJC28               [label="drives\nsynovial swelling"]
    IL6 -> SJC28                [label="drives\nsynovitis"]
    IL17A -> SJC28              [label="neutrophil-driven\nsynovitis"]
    PGE2 -> TJC28               [label="sensitizes\njoint tenderness"]
    PainVAS -> TJC28            [label="pain drives\ntender joint count"]
    PainVAS -> PatientGlobal    [label="pain is key\npatient-reported outcome"]
    Synovial_fluid_vol -> SJC28 [label="effusion drives\nswollen joint count"]
    SJC28 -> DAS28_CRP          [label="0.28×√SJC28\ncomponent"]
    TJC28 -> DAS28_CRP          [label="0.56×√TJC28\ncomponent"]
    CRP_serum -> DAS28_CRP      [label="0.36×ln(CRP+1)\ncomponent"]
    PatientGlobal -> DAS28_CRP  [label="0.014×PtGA\ncomponent"]
    SJC28 -> DAS28_ESR          [label="component"]
    TJC28 -> DAS28_ESR          [label="component"]
    ESR_serum -> DAS28_ESR      [label="0.70×√ESR\ncomponent"]
    PatientGlobal -> DAS28_ESR  [label="component"]
    DAS28_CRP -> ACR20          [label="≥20% improvement\nin 7 ACR criteria"]
    DAS28_CRP -> ACR50          [label="≥50% improvement"]
    DAS28_CRP -> ACR70          [label="≥70% improvement"]
    DAS28_CRP -> HAQ_DI         [label="disease activity\n→ disability"]
    DAS28_CRP -> CDAI           [label="without\nlab values version"]
    SJC28 -> CDAI               [label="component"]
    TJC28 -> CDAI               [label="component"]
    PatientGlobal -> CDAI       [label="component"]
    PhysicianGlobal -> CDAI     [label="component"]
    CDAI -> SDAI                [label="SDAI = CDAI\n+ serum CRP"]
    CRP_serum -> SDAI           [label="+ CRP (mg/dL)\nadded"]
    Pannus -> MRI_RAMRIS        [label="RAMRIS synovitis\nscore (0–21)"]
    Bone_erosion -> MRI_RAMRIS  [label="RAMRIS erosion\nscore"]
    DAS28_CRP -> ACR_EULAR_rem  [label="DAS28 <2.6\n= remission"]
    SDAI -> ACR_EULAR_rem       [label="SDAI ≤3.3\n= remission"]
    SJC28 -> ACR_EULAR_rem      [label="SJC≤1 criterion\n(EULAR Boolean)"]
    TJC28 -> ACR_EULAR_rem      [label="TJC≤1 criterion"]
    CRP_serum -> ACR_EULAR_rem  [label="CRP≤1 mg/dL\n(Boolean criterion)"]

    // --- Systemic Complications ---
    TNFa -> CV_risk             [label="endothelial\ndysfunction → atherosclerosis"]
    IL6 -> Atheroscler          [label="lipid dysregulation\nCRP-driven plaque"]
    TNFa -> Atheroscler         [label="accelerates\nplaque formation"]
    Atheroscler -> CV_risk      [label="plaque → MI/\nstroke/HF"]
    BMD_loss -> Bone_fracture   [label="fragility\nfracture ↑"]
    GC_GR -> BMD_loss           [label="GC-induced\nosteoporosis"]
    TNFa -> BMD_loss            [label="RANKL-mediated\nbone loss"]
    IL6 -> ILD                  [label="TGF-β/IL-6\nfibroblast activation"]
    TGFb -> ILD                 [label="myofibroblast\nactivation → fibrosis"]
    IL6 -> Depression           [label="HPA axis\ndysregulation (CNS)"]
    TNFa -> Depression          [label="neuroinflammation\nCNS sickness behavior"]
    Infect_risk -> Rituximab    [label="serious infections\nrisk monitoring"]
    Lymphoma_risk -> MTX        [label="long-term MTX\n↑ lymphoma caution"]
    MTX -> GI_toxicity          [label="GI mucositis\nnausea/vomiting"]
    NSAID -> GI_toxicity        [label="PGE2↓ → mucosal\nprotection loss"]
    MTX -> Hepatotox            [label="hepatic fibrosis\nwith long-term use"]
    LEF -> Hepatotox            [label="hepatotoxic\nmonitoring required"]
    Anemia_CID -> Hb_level      [label="CID mechanism\n→ ↓ Hb"]
    PLT_count -> Thrombocytos   [label="reactive\nthrombocytosis in RA"]
    IL6 -> Thrombocytos         [label="IL-6 stimulates\nTPO-like effect"]
    Baricitinib -> VTE_risk     [label="JAK1/2 inhibition\n→ platelet effects"]

    // Histamine node (separate)
    Histamine [label="Histamine\n(Mast cell / Basophil)", fillcolor="#FFCDD2", style="filled,rounded"]
    Mast_cell -> Histamine      [label="releases on\nIgE/SP activation"]
    Histamine -> Nociceptor     [label="H1R: direct\npain fiber sensitization"]
    Histamine -> Endothelial_cell [label="vasodilation\n→ joint swelling"]
}
