digraph RA_QSP {
    graph [
        rankdir=TB
        compound=true
        splines=curved
        fontname="Helvetica"
        fontsize=11
        pad=0.5
        nodesep=0.4
        ranksep=0.6
        label="Rheumatoid Arthritis — Quantitative Systems Pharmacology Map\nMechanistic Network: Genetics · Innate & Adaptive Immunity · Cytokines · FLS · Bone/Cartilage · Drug PK/PD"
        labelloc=t
        labeljust=c
    ]
    node [shape=box style=filled fontname="Helvetica" fontsize=10 margin="0.12,0.06"]
    edge [fontname="Helvetica" fontsize=9]

    // =========================================================
    // CLUSTER 1: Genetic & Environmental Factors
    // =========================================================
    subgraph cluster_genetic {
        label="유전·환경 (Genetic & Environmental Risk)"
        style=filled
        fillcolor="#E8F4FD"
        color="#2E86C1"
        fontcolor="#2E86C1"
        fontsize=12
        fontname="Helvetica-Bold"

        HLA_DRB1    [label="HLA-DRB1\n(SE alleles)" fillcolor="#AED6F1"]
        PTPN22      [label="PTPN22\nvariant" fillcolor="#AED6F1"]
        STAT4_poly  [label="STAT4\npolymorphism" fillcolor="#AED6F1"]
        CTLA4_gene  [label="CTLA4\npolymorphism" fillcolor="#AED6F1"]
        smoking     [label="Smoking" shape=ellipse fillcolor="#D6EAF8"]
        microbiome  [label="Gut\nMicrobiome" shape=ellipse fillcolor="#D6EAF8"]
        oral_bacteria [label="Oral Bacteria\n(P. gingivalis)" shape=ellipse fillcolor="#D6EAF8"]
        periodontal [label="Periodontal\nDisease" fillcolor="#AED6F1"]
        citrullination [label="Protein\nCitrullination" fillcolor="#AED6F1"]
        PAD4        [label="PAD4\nEnzyme" fillcolor="#AED6F1"]
        genetic_risk [label="Polygenic\nRisk Score" fillcolor="#85C1E9"]
        epigenetics [label="DNA Methylation /\nHistone Modification" fillcolor="#AED6F1"]
    }

    // =========================================================
    // CLUSTER 2: Innate Immunity
    // =========================================================
    subgraph cluster_innate {
        label="선천면역 (Innate Immunity)"
        style=filled
        fillcolor="#FEF9E7"
        color="#D4AC0D"
        fontcolor="#B7950B"
        fontsize=12
        fontname="Helvetica-Bold"

        DC          [label="Dendritic\nCell (DC)" fillcolor="#FAD7A0"]
        pDC         [label="Plasmacytoid\nDC (pDC)" fillcolor="#FAD7A0"]
        macrophage_M1 [label="Macrophage M1\n(pro-inflam)" fillcolor="#F0B27A"]
        macrophage_M2 [label="Macrophage M2\n(anti-inflam)" fillcolor="#FAD7A0"]
        neutrophil  [label="Neutrophil\n(NET)" fillcolor="#FAD7A0"]
        mast_cell   [label="Mast Cell" fillcolor="#FAD7A0"]
        NK_cell     [label="NK Cell" fillcolor="#FAD7A0"]
        NLRP3       [label="NLRP3\nInflammasome" fillcolor="#F0B27A"]
        TLR_signal  [label="TLR\nSignaling\n(TLR2/4/9)" fillcolor="#F0B27A"]
        FcgR        [label="FcγR\n(immune complex)" fillcolor="#FAD7A0"]
        complement_C1q [label="Complement\nC1q" fillcolor="#FAD7A0"]
        complement_C3a [label="Complement\nC3a/C5a" fillcolor="#FAD7A0"]
        ROS         [label="Reactive Oxygen\nSpecies (ROS)" fillcolor="#E59866"]
        type1_IFN   [label="Type I IFN\n(IFN-α/β)" fillcolor="#FAD7A0"]
    }

    // =========================================================
    // CLUSTER 3: T Cell Responses
    // =========================================================
    subgraph cluster_tcell {
        label="T세포 반응 (T Cell Responses)"
        style=filled
        fillcolor="#F4ECF7"
        color="#8E44AD"
        fontcolor="#7D3C98"
        fontsize=12
        fontname="Helvetica-Bold"

        naive_T     [label="Naive T Cell\n(CD4+)" fillcolor="#D7BDE2"]
        Th1         [label="Th1 Cell\n(IFN-γ+)" fillcolor="#C39BD3"]
        Th17        [label="Th17 Cell\n(IL-17A+)" fillcolor="#BB8FCE"]
        Treg        [label="Regulatory T\n(Foxp3+ Treg)" fillcolor="#D7BDE2"]
        Tfh         [label="T Follicular\nHelper (Tfh)" fillcolor="#D7BDE2"]
        CD8_T       [label="CD8+ T Cell\n(cytotoxic)" fillcolor="#D7BDE2"]
        T_activation [label="TCR\nActivation" fillcolor="#BB8FCE"]
        CD28_cosig  [label="CD28\nCo-stimulation" fillcolor="#C39BD3"]
        CTLA4_brk   [label="CTLA-4\n(immune brake)" fillcolor="#D7BDE2"]
        PD1_sig     [label="PD-1/PD-L1\nCheckpoint" fillcolor="#D7BDE2"]
        OX40_sig    [label="OX40/OX40L\nSignaling" fillcolor="#D7BDE2"]
        T_migration [label="T Cell\nMigration\n(CXCR3/CCR6)" fillcolor="#D7BDE2"]
        ICOS_sig    [label="ICOS/ICOSL\nSignaling" fillcolor="#D7BDE2"]
    }

    // =========================================================
    // CLUSTER 4: B Cell Responses
    // =========================================================
    subgraph cluster_bcell {
        label="B세포 반응 (B Cell Responses)"
        style=filled
        fillcolor="#EAFAF1"
        color="#1E8449"
        fontcolor="#1A5632"
        fontsize=12
        fontname="Helvetica-Bold"

        naive_B     [label="Naive B Cell" fillcolor="#A9DFBF"]
        GC_B        [label="Germinal Center\nB Cell" fillcolor="#7DCEA0"]
        memory_B    [label="Memory B Cell" fillcolor="#A9DFBF"]
        plasma_cell [label="Plasma Cell\n(ASC)" fillcolor="#58D68D"]
        Breg        [label="Regulatory B\n(Breg, IL-10+)" fillcolor="#A9DFBF"]
        RF          [label="Rheumatoid\nFactor (RF)" fillcolor="#7DCEA0"]
        anti_CCP    [label="Anti-CCP\nAntibody (ACPA)" fillcolor="#52BE80"]
        IgG_IC      [label="IgG Immune\nComplexes" fillcolor="#7DCEA0"]
        BAFF_R      [label="BAFF Receptor\n(B survival)" fillcolor="#A9DFBF"]
        CD20        [label="CD20\n(B cell marker)" fillcolor="#A9DFBF"]
        B_activation [label="BCR Activation\n+ TLR9" fillcolor="#7DCEA0"]
        FcRn        [label="FcRn\n(IgG recycling)" fillcolor="#A9DFBF"]
    }

    // =========================================================
    // CLUSTER 5: Cytokines & Signaling
    // =========================================================
    subgraph cluster_cytokine {
        label="사이토카인 & 신호전달 (Cytokines & Intracellular Signaling)"
        style=filled
        fillcolor="#FEF0E7"
        color="#CA6F1E"
        fontcolor="#A04000"
        fontsize=12
        fontname="Helvetica-Bold"

        TNF_a       [label="TNF-α" fillcolor="#F0B27A" fontsize=11]
        IL6         [label="IL-6" fillcolor="#F0B27A" fontsize=11]
        IL1b        [label="IL-1β" fillcolor="#F0B27A" fontsize=11]
        IL17A       [label="IL-17A" fillcolor="#FAD7A0"]
        IL17F       [label="IL-17F" fillcolor="#FAD7A0"]
        IL21        [label="IL-21" fillcolor="#FAD7A0"]
        IL23        [label="IL-23" fillcolor="#FAD7A0"]
        IL12        [label="IL-12" fillcolor="#FAD7A0"]
        IFN_g       [label="IFN-γ" fillcolor="#F0B27A"]
        GM_CSF      [label="GM-CSF\n(CSF2)" fillcolor="#FAD7A0"]
        BAFF        [label="BAFF\n(BLyS)" fillcolor="#FAD7A0"]
        APRIL       [label="APRIL\n(B survival)" fillcolor="#FAD7A0"]
        VEGF        [label="VEGF\n(angiogenesis)" fillcolor="#FAD7A0"]
        TGF_b       [label="TGF-β" fillcolor="#FAD7A0"]
        IL10        [label="IL-10\n(anti-inflam)" fillcolor="#D5F5E3"]
        IL4         [label="IL-4\n(anti-inflam)" fillcolor="#D5F5E3"]
        IL33        [label="IL-33\n(alarmin)" fillcolor="#FAD7A0"]
        CCL2        [label="CCL2\n(MCP-1)" fillcolor="#FAD7A0"]
        CXCL13      [label="CXCL13\n(B cell chemo)" fillcolor="#FAD7A0"]
        CXCL10      [label="CXCL10\n(T cell chemo)" fillcolor="#FAD7A0"]
        JAK1        [label="JAK1\n(kinase)" fillcolor="#E59866" fontsize=11]
        JAK2        [label="JAK2\n(kinase)" fillcolor="#E59866" fontsize=11]
        JAK3        [label="JAK3\n(kinase)" fillcolor="#E59866" fontsize=11]
        TYK2        [label="TYK2\n(kinase)" fillcolor="#E59866"]
        STAT1       [label="STAT1\n(pSTAT1)" fillcolor="#F0B27A"]
        STAT3       [label="STAT3\n(pSTAT3)" fillcolor="#F0B27A"]
        STAT6       [label="STAT6\n(pSTAT6)" fillcolor="#FAD7A0"]
        NFkB        [label="NF-κB\n(transcription)" fillcolor="#E59866" fontsize=11]
        MAPK        [label="MAPK/ERK\nPathway" fillcolor="#FAD7A0"]
    }

    // =========================================================
    // CLUSTER 6: Fibroblast-like Synoviocytes (FLS)
    // =========================================================
    subgraph cluster_FLS {
        label="활막섬유아세포 (Fibroblast-like Synoviocytes — FLS)"
        style=filled
        fillcolor="#FDFEFE"
        color="#717D7E"
        fontcolor="#4D5656"
        fontsize=12
        fontname="Helvetica-Bold"

        FLS         [label="FLS\n(resting)" fillcolor="#EAECEE"]
        FLS_prolif  [label="FLS\nProliferation" fillcolor="#D5D8DC"]
        FLS_invasive [label="Invasive FLS\n(aggressive)" fillcolor="#ABB2B9"]
        PDPN        [label="Podoplanin\n(PDPN)" fillcolor="#EAECEE"]
        cadherin11  [label="Cadherin-11\n(cell adhesion)" fillcolor="#EAECEE"]
        COX2        [label="COX-2\n(PTGS2)" fillcolor="#D5D8DC"]
        PGE2        [label="PGE2\n(prostaglandin)" fillcolor="#EAECEE"]
        MMP1        [label="MMP-1\n(collagenase)" fillcolor="#ABB2B9"]
        MMP3        [label="MMP-3\n(stromelysin)" fillcolor="#ABB2B9"]
        MMP9        [label="MMP-9\n(gelatinase B)" fillcolor="#ABB2B9"]
        MMP13       [label="MMP-13\n(collagenase 3)" fillcolor="#ABB2B9"]
        VEGFR       [label="VEGFR\n(endothelium)" fillcolor="#EAECEE"]
        pannus      [label="Pannus\nFormation" fillcolor="#717D7E" fontcolor=white]
        HIF1a       [label="HIF-1α\n(hypoxia)" fillcolor="#D5D8DC"]
        synovial_hyper [label="Synovial\nHyperplasia" fillcolor="#ABB2B9"]
    }

    // =========================================================
    // CLUSTER 7: Bone & Cartilage
    // =========================================================
    subgraph cluster_bone {
        label="뼈·연골 파괴 (Bone & Cartilage Destruction)"
        style=filled
        fillcolor="#FDEDEC"
        color="#C0392B"
        fontcolor="#922B21"
        fontsize=12
        fontname="Helvetica-Bold"

        OC_precursor [label="Osteoclast\nPrecursor" fillcolor="#F1948A"]
        OC_mature   [label="Mature\nOsteoclast" fillcolor="#EC7063"]
        OB          [label="Osteoblast\n(bone formation)" fillcolor="#F1948A"]
        RANKL       [label="RANKL\n(TNFSF11)" fillcolor="#EC7063" fontsize=11]
        RANK        [label="RANK\n(receptor)" fillcolor="#F1948A"]
        OPG         [label="OPG\n(decoy receptor)" fillcolor="#F1948A"]
        M_CSF       [label="M-CSF\n(CSF1)" fillcolor="#F1948A"]
        cathK       [label="Cathepsin K\n(bone resorption)" fillcolor="#E74C3C" fontcolor=white]
        DKK1        [label="DKK1\n(Wnt inhibitor)" fillcolor="#F1948A"]
        Wnt_sig     [label="Wnt Signaling\n(β-catenin)" fillcolor="#F1948A"]
        sclerostin  [label="Sclerostin\n(SOST)" fillcolor="#F1948A"]
        bone_erosion [label="Bone Erosion\n(Sharp/vdH score)" fillcolor="#C0392B" fontcolor=white]
        chondrocyte [label="Chondrocyte\n(cartilage cell)" fillcolor="#F1948A"]
        ADAMTS4     [label="ADAMTS-4\n(aggrecanase)" fillcolor="#EC7063"]
        ADAMTS5     [label="ADAMTS-5\n(aggrecanase)" fillcolor="#EC7063"]
        cartilage_loss [label="Cartilage Loss\n(JSN score)" fillcolor="#C0392B" fontcolor=white]
    }

    // =========================================================
    // CLUSTER 8: Drug PK (Pharmacokinetics)
    // =========================================================
    subgraph cluster_PK {
        label="약물 PK (Pharmacokinetics)"
        style=filled
        fillcolor="#EBF5FB"
        color="#1A5276"
        fontcolor="#1A5276"
        fontsize=12
        fontname="Helvetica-Bold"

        DEPOT_drug  [label="SC Depot\n(injection site)" fillcolor="#AED6F1"]
        CENT_drug   [label="Central\nCompartment\n(plasma)" fillcolor="#5DADE2"]
        PERI_drug   [label="Peripheral\nCompartment\n(tissue)" fillcolor="#AED6F1"]
        MTX_gut     [label="MTX Gut\nAbsorption" fillcolor="#AED6F1"]
        MTX_polyglut [label="MTX\nPolyglutamates\n(active)" fillcolor="#5DADE2"]
        folate_pathway [label="Folate\nPathway\n(DHFR inhibition)" fillcolor="#AED6F1"]
        target_tissue [label="Target Tissue\n(synovium)" fillcolor="#AED6F1"]
        drug_clearance [label="Drug\nClearance\n(renal/hepatic)" fillcolor="#AED6F1"]
    }

    // =========================================================
    // CLUSTER 9: Drugs (PD agents)
    // =========================================================
    subgraph cluster_PD {
        label="약물 (Therapeutic Agents — PD)"
        style=filled
        fillcolor="#F0FFF0"
        color="#1E8449"
        fontcolor="#1A5632"
        fontsize=12
        fontname="Helvetica-Bold"

        MTX         [label="Methotrexate\n(MTX)" fillcolor="#1A5276" fontcolor=white]
        TCZ         [label="Tocilizumab\n(IL-6R mAb)" fillcolor="#154360" fontcolor=white]
        adalimumab  [label="Adalimumab\n(anti-TNF)" fillcolor="#6E2F4F" fontcolor=white]
        etanercept  [label="Etanercept\n(TNF-Fc fusion)" fillcolor="#6E2F4F" fontcolor=white]
        abatacept   [label="Abatacept\n(CTLA4-Ig)" fillcolor="#4A235A" fontcolor=white]
        rituximab   [label="Rituximab\n(anti-CD20)" fillcolor="#0B4F0B" fontcolor=white]
        baricitinib [label="Baricitinib\n(JAK1/2i)" fillcolor="#784212" fontcolor=white]
        tofacitinib [label="Tofacitinib\n(JAK1/3i)" fillcolor="#784212" fontcolor=white]
        upadacitinib [label="Upadacitinib\n(JAK1i)" fillcolor="#784212" fontcolor=white]
        sarilumab   [label="Sarilumab\n(IL-6R mAb)" fillcolor="#154360" fontcolor=white]
        secukinumab [label="Secukinumab\n(anti-IL-17A)" fillcolor="#1B4F72" fontcolor=white]
        NSAIDs      [label="NSAIDs\n(COX inhibitor)" fillcolor="#515A5A" fontcolor=white]
        GC          [label="Glucocorticoids\n(GC)" fillcolor="#515A5A" fontcolor=white]
        HCQ         [label="Hydroxychloroquine\n(HCQ)" fillcolor="#515A5A" fontcolor=white]
        sulfasalazine [label="Sulfasalazine\n(SSZ)" fillcolor="#515A5A" fontcolor=white]
    }

    // =========================================================
    // CLUSTER 10: Biomarkers (diamond shape)
    // =========================================================
    subgraph cluster_biomarkers {
        label="바이오마커 (Biomarkers)"
        style=filled
        fillcolor="#F4F6F7"
        color="#717D7E"
        fontcolor="#4D5656"
        fontsize=12
        fontname="Helvetica-Bold"

        CRP_bm      [label="CRP\n(serum)" shape=diamond fillcolor="#D5D8DC"]
        ESR_bm      [label="ESR\n(sed. rate)" shape=diamond fillcolor="#D5D8DC"]
        RF_bm       [label="RF\n(serum)" shape=diamond fillcolor="#D5D8DC"]
        anti_CCP_bm [label="Anti-CCP\n(ACPA titer)" shape=diamond fillcolor="#D5D8DC"]
        IL6_serum   [label="IL-6\n(serum)" shape=diamond fillcolor="#D5D8DC"]
        TNF_serum   [label="TNF-α\n(serum)" shape=diamond fillcolor="#D5D8DC"]
        synovial_bx [label="Synovial\nBiopsy Score" shape=diamond fillcolor="#D5D8DC"]
        DAS28_score [label="DAS28-CRP\nComposite" shape=diamond fillcolor="#ABB2B9"]
        SDAI        [label="SDAI\nIndex" shape=diamond fillcolor="#D5D8DC"]
        CDAI        [label="CDAI\nIndex" shape=diamond fillcolor="#D5D8DC"]
        anti_MCV    [label="Anti-MCV\n(mutated CCP)" shape=diamond fillcolor="#D5D8DC"]
    }

    // =========================================================
    // CLUSTER 11: Clinical Endpoints (hexagon shape)
    // =========================================================
    subgraph cluster_endpoints {
        label="임상 엔드포인트 (Clinical Endpoints)"
        style=filled
        fillcolor="#F9EBEA"
        color="#922B21"
        fontcolor="#922B21"
        fontsize=12
        fontname="Helvetica-Bold"

        ACR20       [label="ACR20\nResponse" shape=hexagon fillcolor="#F1948A"]
        ACR50       [label="ACR50\nResponse" shape=hexagon fillcolor="#EC7063"]
        ACR70       [label="ACR70\nResponse" shape=hexagon fillcolor="#E74C3C" fontcolor=white]
        DAS28_rem   [label="DAS28\nRemission\n(<2.6)" shape=hexagon fillcolor="#E74C3C" fontcolor=white]
        MDA         [label="Minimal\nDisease Activity\n(MDA)" shape=hexagon fillcolor="#F1948A"]
        HAQ_DI      [label="HAQ-DI\n(function)" shape=hexagon fillcolor="#F1948A"]
        VAS_pain    [label="VAS Pain\nScore" shape=hexagon fillcolor="#F1948A"]
        TJC_SJC     [label="TJC / SJC\n(joint counts)" shape=hexagon fillcolor="#F1948A"]
        sharp_score [label="Sharp/vdH\nScore\n(X-ray)" shape=hexagon fillcolor="#EC7063"]
        CV_risk     [label="CV Risk\n(Framingham)" shape=hexagon fillcolor="#F1948A"]
        mortality   [label="All-cause\nMortality" shape=hexagon fillcolor="#922B21" fontcolor=white]
    }

    // =========================================================
    // EDGES
    // =========================================================

    // --- Genetic/Environmental → Innate/T cell ---
    HLA_DRB1    -> T_activation   [label="MHC-II\npresentation" color="#2E86C1"]
    PTPN22      -> T_activation   [label="↓ TCR\nthreshold" color="#2E86C1"]
    STAT4_poly  -> Th1             [label="↑ Th1\nbias"]
    CTLA4_gene  -> CTLA4_brk      [label="SNP\naffects"]
    smoking     -> citrullination  [label="induces" color="#E74C3C"]
    smoking     -> ROS             [label="generates" color="#E74C3C"]
    oral_bacteria -> periodontal   [label="causes"]
    oral_bacteria -> citrullination [label="P. gingivalis\nPAD" color="#E74C3C"]
    microbiome  -> TLR_signal      [label="MAMPs\nactivate" color="#D4AC0D"]
    periodontal -> citrullination  [label="local"]
    citrullination -> PAD4         [label="substrate"]
    PAD4        -> anti_CCP        [label="generates\nACPA antigen" color="#E74C3C"]
    genetic_risk -> HLA_DRB1       [label="includes"]
    genetic_risk -> PTPN22         [label="includes"]
    epigenetics -> FLS_invasive    [label="epigenetic\nreprogramming"]
    epigenetics -> Th17            [label="demethylation"]

    // --- Innate Immune Signaling ---
    TLR_signal  -> macrophage_M1   [label="activates"]
    TLR_signal  -> DC              [label="matures"]
    TLR_signal  -> NLRP3           [label="primes"]
    NLRP3       -> IL1b            [label="cleaves\npro-IL-1β" color="#E74C3C" style=bold]
    macrophage_M1 -> TNF_a         [label="secretes" color="#E74C3C" style=bold]
    macrophage_M1 -> IL6           [label="secretes" color="#E74C3C" style=bold]
    macrophage_M1 -> IL1b          [label="secretes" color="#E74C3C" style=bold]
    macrophage_M1 -> GM_CSF        [label="secretes"]
    macrophage_M1 -> ROS           [label="generates"]
    macrophage_M2 -> IL10          [label="secretes\n(resolution)"]
    macrophage_M2 -> TGF_b         [label="secretes"]
    DC          -> Th1             [label="IL-12\npolarize"]
    DC          -> Th17            [label="IL-23\npolarize"]
    pDC         -> type1_IFN       [label="secretes"]
    type1_IFN   -> DC              [label="matures\nactivates"]
    neutrophil  -> IL1b            [label="NET-driven"]
    neutrophil  -> ROS             [label="burst"]
    neutrophil  -> citrullination  [label="NET citr."]
    mast_cell   -> TNF_a           [label="degranulates"]
    mast_cell   -> IL33            [label="secretes"]
    NK_cell     -> IFN_g           [label="secretes"]
    FcgR        -> macrophage_M1   [label="IC activates"]
    complement_C1q -> FcgR         [label="IgG binding"]
    complement_C3a -> macrophage_M1 [label="activates"]
    IgG_IC      -> complement_C1q  [label="activates"]
    IgG_IC      -> FcgR            [label="cross-links"]

    // --- T Cell Differentiation ---
    T_activation -> naive_T        [label="signal 1\n(TCR)"]
    CD28_cosig  -> naive_T         [label="signal 2\n(costim.)" color="#8E44AD"]
    naive_T     -> Th1             [label="IL-12\ndrive"]
    naive_T     -> Th17            [label="IL-6+TGF-β\ndrive"]
    naive_T     -> Treg            [label="TGF-β\nhigh dose"]
    naive_T     -> Tfh             [label="ICOS\ndrive"]
    Th1         -> IFN_g           [label="secretes" color="#8E44AD"]
    Th1         -> TNF_a           [label="secretes" color="#8E44AD"]
    Th17        -> IL17A           [label="secretes" color="#8E44AD" style=bold]
    Th17        -> IL17F           [label="secretes"]
    Th17        -> IL21            [label="secretes"]
    Treg        -> IL10            [label="secretes\n(suppresses)"]
    Treg        -> TGF_b           [label="secretes"]
    Tfh         -> CXCL13         [label="responds to"]
    Tfh         -> GC_B            [label="helps\nGC reaction"]
    CD8_T       -> IFN_g           [label="secretes"]
    CTLA4_brk   -> CD28_cosig      [label="competes\n(inhibits)" color="#E74C3C" arrowhead=tee style=bold]
    PD1_sig     -> T_activation    [label="inhibits" color="#E74C3C" arrowhead=tee style=bold]
    OX40_sig    -> Th1             [label="amplifies"]
    OX40_sig    -> Th17            [label="amplifies"]
    ICOS_sig    -> Tfh             [label="drives"]
    T_migration -> Th1             [label="synovial\ninfiltration"]
    T_migration -> Th17            [label="synovial\ninfiltration"]

    // --- B Cell Biology ---
    naive_B     -> B_activation    [label="BCR signal"]
    B_activation -> GC_B           [label="GC entry"]
    GC_B        -> memory_B        [label="memory\ndiff."]
    GC_B        -> plasma_cell     [label="plasma\ncell diff."]
    plasma_cell -> RF              [label="secretes" color="#1E8449" style=bold]
    plasma_cell -> anti_CCP        [label="secretes" color="#1E8449" style=bold]
    plasma_cell -> IgG_IC          [label="forms\ncomplexes"]
    BAFF        -> BAFF_R          [label="binds\nsurvival"]
    BAFF_R      -> naive_B         [label="survival\nsignal" color="#1E8449"]
    CD20        -> naive_B         [label="marker\non surface"]
    Breg        -> T_activation    [label="IL-10\nsuppresses" color="#1E8449" arrowhead=tee]
    FcRn        -> IgG_IC          [label="prolongs\nhalf-life"]
    Tfh         -> GC_B            [label="IL-21\nhelp"]
    IL21        -> GC_B            [label="GC support"]
    CXCL13      -> GC_B            [label="chemoattract"]

    // --- Cytokine → Intracellular Signaling ---
    IL6         -> JAK1            [label="gp130\nsignal" color="#CA6F1E" style=bold]
    IL6         -> STAT3           [label="via JAK1\n→ pSTAT3" color="#CA6F1E" style=bold]
    IFN_g       -> JAK1            [label="IFNGR\nsignal"]
    IFN_g       -> JAK2            [label="IFNGR\nsignal"]
    IFN_g       -> STAT1           [label="pSTAT1\nactivation"]
    TNF_a       -> NFkB            [label="TNFR1\nsignal" color="#E74C3C" style=bold]
    TNF_a       -> MAPK            [label="TNFR1\nMAPK"]
    IL1b        -> NFkB            [label="IL-1R\nsignal" color="#E74C3C"]
    IL1b        -> MAPK            [label="IL-1R\nMAPK"]
    IL17A       -> NFkB            [label="IL-17RA\nsignal"]
    IL17A       -> MAPK            [label="IL-17RA"]
    IL4         -> JAK1            [label="IL-4Rα"]
    IL4         -> STAT6           [label="via JAK1"]
    GM_CSF      -> JAK2            [label="βc receptor"]
    JAK1        -> STAT3           [label="phospho-\nylates"]
    JAK2        -> STAT1           [label="phospho-\nylates"]
    JAK3        -> STAT6           [label="γc chain"]
    TYK2        -> STAT1           [label="IFN-α\nresponse"]
    STAT3       -> IL6             [label="positive\nfeedback" color="#CA6F1E"]
    STAT3       -> VEGF            [label="transcribes"]
    NFkB        -> TNF_a           [label="transcribes"]
    NFkB        -> IL6             [label="transcribes"]
    NFkB        -> IL1b            [label="transcribes"]
    NFkB        -> VEGF            [label="transcribes"]
    NFkB        -> RANKL           [label="transcribes"]

    // --- Cytokine cross-regulation ---
    IL23        -> Th17            [label="stabilizes"]
    IL12        -> Th1             [label="drives"]
    IL10        -> macrophage_M1   [label="suppresses" arrowhead=tee color="#27AE60"]
    IL10        -> NFkB            [label="inhibits" arrowhead=tee color="#27AE60"]
    TGF_b       -> Treg            [label="expands"]
    IL33        -> mast_cell       [label="activates\nST2"]
    CCL2        -> macrophage_M1   [label="recruits"]
    CCL2        -> T_migration     [label="guides"]
    CXCL10      -> T_migration     [label="guides\nCXCR3"]
    BAFF        -> plasma_cell     [label="survival"]
    APRIL       -> plasma_cell     [label="long-lived\nPC survival"]
    VEGF        -> VEGFR           [label="neoangio-\ngenesis"]

    // --- FLS Activation ---
    TNF_a       -> FLS             [label="activates" color="#E74C3C" style=bold]
    IL6         -> FLS             [label="activates" color="#CA6F1E"]
    IL17A       -> FLS             [label="activates\nsynergy"]
    IL1b        -> FLS             [label="activates"]
    FLS         -> FLS_prolif      [label="PDGF\nstimulus"]
    FLS         -> FLS_invasive    [label="cytokine\nreprogramming"]
    FLS_prolif  -> synovial_hyper  [label="overgrowth"]
    FLS_invasive -> MMP1           [label="secretes"]
    FLS_invasive -> MMP3           [label="secretes"]
    FLS_invasive -> MMP9           [label="secretes"]
    FLS_invasive -> MMP13          [label="secretes"]
    FLS_invasive -> VEGF           [label="secretes"]
    FLS_invasive -> RANKL          [label="secretes"]
    FLS_invasive -> pannus         [label="forms"]
    FLS         -> COX2            [label="↑ COX-2\nexpression"]
    COX2        -> PGE2            [label="converts\nAA→PGE2"]
    HIF1a       -> VEGF            [label="transcribes"]
    HIF1a       -> FLS_invasive    [label="hypoxia\ndrives"]
    pannus      -> bone_erosion    [label="invades\njoint" color="#C0392B" style=bold]
    pannus      -> cartilage_loss  [label="erodes\ncartilage" color="#C0392B" style=bold]
    synovial_hyper -> HIF1a        [label="hypoxic\nniche"]
    PDPN        -> FLS_invasive    [label="promotes\nchemotaxis"]
    cadherin11  -> FLS             [label="cell-cell\nadhesion"]

    // --- Bone & Cartilage Destruction ---
    RANKL       -> RANK            [label="binds\nosteoclast" color="#C0392B" style=bold]
    RANK        -> OC_precursor    [label="activates\nNF-κB"]
    OC_precursor -> OC_mature      [label="differentiates\n(M-CSF+RANKL)"]
    OPG         -> RANKL           [label="decoy\nbinds" arrowhead=tee color="#27AE60"]
    M_CSF       -> OC_precursor    [label="co-stim\nsurvival"]
    OC_mature   -> cathK           [label="secretes"]
    cathK       -> bone_erosion    [label="resorbs\nbone" color="#C0392B" style=bold]
    OC_mature   -> bone_erosion    [label="resorbs" color="#C0392B"]
    DKK1        -> Wnt_sig         [label="inhibits" arrowhead=tee]
    sclerostin  -> Wnt_sig         [label="inhibits" arrowhead=tee]
    Wnt_sig     -> OB              [label="drives\nformation"]
    OB          -> OPG             [label="secretes"]
    OB          -> DKK1            [label="secretes"]
    TNF_a       -> DKK1            [label="induces"]
    TNF_a       -> sclerostin      [label="induces"]
    MMP13       -> chondrocyte     [label="degrades\nECM"]
    ADAMTS4     -> chondrocyte     [label="degrades\naggrecan"]
    ADAMTS5     -> chondrocyte     [label="degrades\naggrecan"]
    chondrocyte -> ADAMTS4         [label="induces"]
    chondrocyte -> ADAMTS5         [label="induces"]
    IL17A       -> chondrocyte     [label="damages"]
    MMP13       -> cartilage_loss  [label="collagen\nIV loss" color="#C0392B"]
    ADAMTS4     -> cartilage_loss  [label="aggrecan\nloss" color="#C0392B"]
    ADAMTS5     -> cartilage_loss  [label="aggrecan\nloss" color="#C0392B"]

    // --- Drug PK Flow ---
    DEPOT_drug  -> CENT_drug       [label="KA (SC abs.)" color="#1A5276" style=bold]
    CENT_drug   -> PERI_drug       [label="distribution\nQ" color="#1A5276"]
    PERI_drug   -> CENT_drug       [label="redistrib.\nQ" color="#1A5276"]
    CENT_drug   -> drug_clearance  [label="CL\n(renal/hepatic)"]
    CENT_drug   -> target_tissue   [label="distributes\nto synovium"]
    MTX_gut     -> CENT_drug       [label="oral\nabsorption"]
    MTX_polyglut -> folate_pathway [label="inhibits\nDHFR" color="#1A5276" style=bold]
    CENT_drug   -> MTX_polyglut    [label="polyglut.\nformation"]

    // --- Drug PD Inhibitory Edges (bold, colored, tee arrowhead) ---
    TCZ         -> IL6             [label="anti-IL-6R\nblocks" color="#154360" style=bold arrowhead=tee fontcolor="#154360"]
    sarilumab   -> IL6             [label="anti-IL-6R\nblocks" color="#154360" style=bold arrowhead=tee fontcolor="#154360"]
    adalimumab  -> TNF_a           [label="anti-TNF\nneutralizes" color="#6E2F4F" style=bold arrowhead=tee fontcolor="#6E2F4F"]
    etanercept  -> TNF_a           [label="TNF trap\nneutralizes" color="#6E2F4F" style=bold arrowhead=tee fontcolor="#6E2F4F"]
    abatacept   -> CD28_cosig      [label="blocks\nCD80/86" color="#4A235A" style=bold arrowhead=tee fontcolor="#4A235A"]
    rituximab   -> CD20            [label="depletes\nB cells" color="#0B4F0B" style=bold arrowhead=tee fontcolor="#0B4F0B"]
    baricitinib -> JAK1            [label="inhibits" color="#784212" style=bold arrowhead=tee fontcolor="#784212"]
    baricitinib -> JAK2            [label="inhibits" color="#784212" style=bold arrowhead=tee fontcolor="#784212"]
    tofacitinib -> JAK1            [label="inhibits" color="#784212" style=bold arrowhead=tee fontcolor="#784212"]
    tofacitinib -> JAK3            [label="inhibits" color="#784212" style=bold arrowhead=tee fontcolor="#784212"]
    upadacitinib -> JAK1           [label="selective\ninhibits" color="#784212" style=bold arrowhead=tee fontcolor="#784212"]
    MTX         -> folate_pathway  [label="DHFR inhibition\n↓ adenosine" color="#1A5276" style=bold arrowhead=tee fontcolor="#1A5276"]
    MTX         -> NFkB            [label="indirect\nanti-inflam" color="#1A5276" arrowhead=tee]
    NSAIDs      -> COX2            [label="inhibits\nCOX-2" color="#515A5A" style=bold arrowhead=tee fontcolor="#515A5A"]
    GC          -> NFkB            [label="suppresses\ntranscription" color="#515A5A" style=bold arrowhead=tee fontcolor="#515A5A"]
    GC          -> IL6             [label="reduces\nsynthesis" color="#515A5A" arrowhead=tee]
    GC          -> RANKL           [label="↑ RANKL\n(side effect)" color="#E74C3C"]
    secukinumab -> IL17A           [label="anti-IL-17A\nneutralizes" color="#1B4F72" style=bold arrowhead=tee fontcolor="#1B4F72"]
    HCQ         -> TLR_signal      [label="blocks\nendosomal TLR" color="#515A5A" arrowhead=tee]
    sulfasalazine -> NFkB          [label="inhibits" color="#515A5A" arrowhead=tee]

    // --- Drug PK → PD linkage ---
    CENT_drug   -> TCZ             [label="PK drives\nexposure"]
    DEPOT_drug  -> adalimumab      [label="SC injection"]
    DEPOT_drug  -> abatacept       [label="SC injection"]
    MTX_gut     -> MTX             [label="oral dose"]

    // --- Biomarker connections ---
    IL6         -> IL6_serum       [label="reflects\nserum"]
    IL6         -> CRP_bm          [label="via STAT3\nhepatic" color="#CA6F1E"]
    IL6         -> ESR_bm          [label="↑ fibrinogen"]
    TNF_a       -> TNF_serum       [label="reflects\nserum"]
    RF          -> RF_bm           [label="measured"]
    anti_CCP    -> anti_CCP_bm     [label="measured"]
    anti_CCP    -> anti_MCV        [label="related\nACPA"]
    synovial_hyper -> synovial_bx  [label="biopsy\nscore"]
    pannus      -> synovial_bx     [label="pannus\nscore"]
    CRP_bm      -> DAS28_score     [label="component"]
    TJC_SJC     -> DAS28_score     [label="component"]
    VAS_pain    -> DAS28_score     [label="component"]
    DAS28_score -> SDAI            [label="component"]
    DAS28_score -> CDAI            [label="component"]

    // --- Clinical Endpoints ---
    DAS28_score -> ACR20           [label="≥20%\nimprove" color="#922B21"]
    DAS28_score -> ACR50           [label="≥50%\nimprove" color="#922B21"]
    DAS28_score -> ACR70           [label="≥70%\nimprove" color="#922B21"]
    DAS28_score -> DAS28_rem       [label="<2.6\nremission" color="#922B21"]
    DAS28_score -> MDA             [label="minimal\nactivity"]
    VAS_pain    -> HAQ_DI          [label="correlates"]
    TJC_SJC     -> HAQ_DI          [label="drives\ndisability"]
    bone_erosion -> sharp_score    [label="X-ray\nreads"]
    cartilage_loss -> sharp_score  [label="JSN\ncomponent"]
    sharp_score -> HAQ_DI          [label="structural\ndamage"]
    HAQ_DI      -> CV_risk         [label="inactivity\nrisk" color="#922B21"]
    DAS28_score -> CV_risk         [label="inflam.\nCV risk"]
    CV_risk     -> mortality       [label="major MACE" color="#922B21" style=bold]
    HAQ_DI      -> mortality       [label="disability\nmortality" color="#922B21"]
    sharp_score -> mortality       [label="severe\ndamage"]
}
