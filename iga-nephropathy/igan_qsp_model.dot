digraph IgAN_QSP {
    graph [
        label="IgA Nephropathy (IgAN)\nComprehensive QSP Mechanistic Map\n(Four-Hit Hypothesis + Drug PK/PD)"
        labelloc=t
        fontname="Helvetica-Bold"
        fontsize=20
        fontcolor="#1a1a2e"
        rankdir=TB
        splines=ortho
        overlap=false
        nodesep=0.35
        ranksep=0.55
        bgcolor="#F8F9FA"
        pad=0.5
    ]

    node [fontname="Helvetica" fontsize=9 style="filled,rounded" penwidth=1.5]
    edge [fontname="Helvetica" fontsize=7.5 penwidth=1.2 arrowsize=0.75]

    // ==========================================================
    // CLUSTER 0: GENETIC & ENVIRONMENTAL RISK FACTORS
    // ==========================================================
    subgraph cluster_genetic {
        label="Genetic & Environmental Risk Factors"
        style="filled,rounded"
        bgcolor="#E8F4F8"
        color="#2196F3"
        fontname="Helvetica-Bold"
        fontsize=13
        fontcolor="#1565C0"

        node [fillcolor="#BBDEFB" color="#1565C0"]

        HLA_DQ        [label="HLA-DQB1\nRisk Alleles" shape=diamond]
        TNFSF13_gene  [label="TNFSF13\n(APRIL gene)" shape=ellipse]
        TNFSF13B_gene [label="TNFSF13B\n(BAFF gene)" shape=ellipse]
        DEFA          [label="DEFA1A3\nα-defensin gene" shape=ellipse]
        C1GALT1_gene  [label="C1GALT1\nmutation/variant" shape=ellipse]
        COSMC_gene    [label="C1GALT1C1 (Cosmc)\nchaperone defect" shape=ellipse]
        ST6GalNAc2_gene [label="ST6GalNAc-II\ngene variant" shape=ellipse]
        Gut_micro     [label="Gut Dysbiosis\n(microbial translocation)" shape=rect]
        Mucosal_inf   [label="Mucosal Infection\n(URI, GI, tonsillitis)" shape=rect]
        Env_trigger   [label="Environmental\nTrigger" shape=rect]
    }

    // ==========================================================
    // CLUSTER 1: MUCOSAL IMMUNITY & IgA PRODUCTION
    // ==========================================================
    subgraph cluster_mucosal {
        label="Mucosal Immunity & IgA1 Production (MALT)"
        style="filled,rounded"
        bgcolor="#E8F5E9"
        color="#4CAF50"
        fontname="Helvetica-Bold"
        fontsize=13
        fontcolor="#1B5E20"

        node [fillcolor="#C8E6C9" color="#2E7D32"]

        Naive_B       [label="Naive B Cell\n(mucosal)" shape=ellipse]
        PP_GC         [label="Peyer's Patch\nGerminal Center" shape=rect]
        Tonsillar_B   [label="Tonsillar B Cell\n(tonsil MALT)" shape=ellipse]
        IgA1_PC       [label="IgA1 Plasma Cell\n(bone marrow/MALT)" shape=ellipse]
        pIgR          [label="pIgR\n(polymeric Ig receptor)" shape=ellipse]
        sIgA          [label="Secretory IgA1\n(sIgA)" shape=ellipse]
        Tfh_mus       [label="Tfh Cell\n(follicular T helper)" shape=ellipse]
        IL21_mus      [label="IL-21\n(Tfh cytokine)" shape=ellipse]
        IL10_mus      [label="IL-10\n(regulatory)" shape=ellipse]
        IL6_mus       [label="IL-6\n(B cell differentiation)" shape=ellipse]
        IL4_mus       [label="IL-4\n(Th2 class-switch)" shape=ellipse]
        TGFb_sw       [label="TGF-β1\n(class switch to IgA)" shape=ellipse]
        APRIL         [label="APRIL\n(TNFSF13)" shape=diamond fillcolor="#66BB6A"]
        BAFF          [label="BAFF / BLyS\n(TNFSF13B)" shape=diamond fillcolor="#66BB6A"]
        AID           [label="AID\n(class-switch enzyme)" shape=ellipse]
    }

    // ==========================================================
    // CLUSTER 2: HIT 1 – Gd-IgA1 OVERPRODUCTION
    // ==========================================================
    subgraph cluster_hit1 {
        label="HIT 1: Gd-IgA1 Overproduction (aberrant O-glycosylation)"
        style="filled,rounded"
        bgcolor="#FFF3E0"
        color="#FF9800"
        fontname="Helvetica-Bold"
        fontsize=13
        fontcolor="#E65100"

        node [fillcolor="#FFE0B2" color="#E65100"]

        IgA1_hinge    [label="IgA1 Hinge Region\nO-glycan sites (Ser/Thr)" shape=rect]
        C1GalT1       [label="C1GalT1\n(β1,3-galactosyltransferase)" shape=ellipse]
        Cosmc         [label="Cosmc Chaperone\n(C1GALT1C1)" shape=ellipse]
        ST6GalNAc2    [label="ST6GalNAc-II\n(GalNAc sialylation)" shape=ellipse]
        GalNAc_exp    [label="Exposed GalNAc\n(truncated O-glycan)" shape=rect fillcolor="#FFCC02"]
        Gd_IgA1       [label="Gd-IgA1\n(galactose-deficient IgA1)" shape=diamond fillcolor="#FF6F00" fontcolor="white"]
        Normal_IgA1   [label="Normal IgA1\n(fully galactosylated)" shape=ellipse]
        IgA1_serum    [label="Circulatory IgA1\n(serum pool)" shape=rect]
        GdIgA1_serum  [label="Serum Gd-IgA1\n(↑↑ in IgAN patients)" shape=rect fillcolor="#FF6F00" fontcolor="white"]
        FcaRI_mes     [label="FcαRI (CD89)\nMesangial IgA Receptor" shape=rect]
        TfR1          [label="TfR1 / CD71\n(Alternative IgA-R)" shape=ellipse]
        ASGPR         [label="ASGPR\n(Hepatic clearance)" shape=ellipse]
    }

    // ==========================================================
    // CLUSTER 3: HIT 2 – ANTI-Gd-IgA1 AUTOANTIBODIES
    // ==========================================================
    subgraph cluster_hit2 {
        label="HIT 2: Anti-Gd-IgA1 Autoantibody Formation"
        style="filled,rounded"
        bgcolor="#FCE4EC"
        color="#E91E63"
        fontname="Helvetica-Bold"
        fontsize=13
        fontcolor="#880E4F"

        node [fillcolor="#F8BBD0" color="#880E4F"]

        BCR_GalNAc    [label="BCR Recognizing\nGalNAc Epitope" shape=ellipse]
        GC_auto       [label="Germinal Center\nReaction (auto)" shape=rect]
        SHM           [label="Somatic\nHypermutation" shape=ellipse]
        Anti_IgG      [label="Anti-Gd-IgA1 IgG\n(autoantibody, ↑ disease activity)" shape=diamond fillcolor="#EC407A" fontcolor="white"]
        Anti_IgA      [label="Anti-Gd-IgA1 IgA\n(autoantibody class)" shape=diamond]
        CD4_Tfh_auto  [label="CD4+ Tfh\n(autoreactive)" shape=ellipse]
        IL21_auto     [label="IL-21\n(GC support)" shape=ellipse]
        Class_sw_IgG  [label="Class Switch\nRecombination → IgG" shape=ellipse]
        PC_auto       [label="Autoantibody\nPlasma Cell" shape=ellipse]
        IL17A         [label="IL-17A\n(Th17 – mucosal inflam)" shape=ellipse]
    }

    // ==========================================================
    // CLUSTER 4: HIT 3+4 – IC FORMATION & DEPOSITION
    // ==========================================================
    subgraph cluster_hit34 {
        label="HIT 3+4: IC Formation & Mesangial Deposition"
        style="filled,rounded"
        bgcolor="#F3E5F5"
        color="#9C27B0"
        fontname="Helvetica-Bold"
        fontsize=13
        fontcolor="#4A148C"

        node [fillcolor="#E1BEE7" color="#6A1B9A"]

        IC_complex    [label="Gd-IgA1 – IgG\nImmune Complex" shape=diamond fillcolor="#7B1FA2" fontcolor="white"]
        IC_large      [label="Large Macromolecular\nIC (deposit-prone)" shape=rect]
        IC_small      [label="Small IC\n(hepatic clearance)" shape=rect]
        IC_hex        [label="IC Hexamerization\n(C1q binding)" shape=ellipse]
        EC_IC         [label="Endothelial IC\nCapture / Transcytosis" shape=ellipse]
        Mes_dep       [label="Mesangial IgA\nDeposition (↑↑↑)" shape=rect fillcolor="#7B1FA2" fontcolor="white"]
        GFB_IC        [label="IC Glomerular\nFiltration Barrier" shape=ellipse]
    }

    // ==========================================================
    // CLUSTER 5: COMPLEMENT ACTIVATION (LP + AP amplification)
    // ==========================================================
    subgraph cluster_complement {
        label="Complement System Activation (Lectin + Alternative Pathway)"
        style="filled,rounded"
        bgcolor="#E3F2FD"
        color="#1976D2"
        fontname="Helvetica-Bold"
        fontsize=13
        fontcolor="#0D47A1"

        node [fillcolor="#BBDEFB" color="#1565C0"]

        MBL           [label="MBL\n(mannose-binding lectin)" shape=ellipse]
        FCN           [label="Ficolins\n(LP pattern recog.)" shape=ellipse]
        MASP12        [label="MASP-1/MASP-2\n(serine proteases)" shape=ellipse]
        C1q           [label="C1q\n(classical pathway)" shape=ellipse]
        C4b           [label="C4 → C4b\n(cleavage)" shape=ellipse]
        C3conv_CP     [label="C3 Convertase CP\n(C4b2a)" shape=rect]
        Factor_B      [label="Factor B\n(alternative pathway)" shape=ellipse fillcolor="#64B5F6"]
        Factor_D      [label="Factor D\n(serine protease)" shape=ellipse]
        Properdin     [label="Properdin (P)\n(C3bBb stabilizer)" shape=ellipse]
        C3conv_AP     [label="C3 Convertase AP\n(C3bBb)" shape=rect fillcolor="#64B5F6"]
        C3_cleave     [label="C3 Cleavage\n(central amplification)" shape=rect fillcolor="#1976D2" fontcolor="white"]
        C3b           [label="C3b\n(opsonin)" shape=ellipse]
        C3a           [label="C3a\n(anaphylatoxin)" shape=ellipse fillcolor="#FFCDD2" color="#C62828"]
        C5_conv       [label="C5 Convertase\n(C4b2a3b/C3bBbP)" shape=rect]
        C5a           [label="C5a\n(potent anaphylatoxin)" shape=ellipse fillcolor="#EF9A9A" color="#C62828"]
        MAC_C5b9      [label="MAC (C5b-9)\nMembrane Attack Complex" shape=rect fillcolor="#B71C1C" fontcolor="white"]
        CD46_CD55     [label="CD46/CD55/CD59\n(complement regulators)" shape=ellipse]
    }

    // ==========================================================
    // CLUSTER 6: MESANGIAL CELL SIGNALING
    // ==========================================================
    subgraph cluster_mesangial {
        label="Mesangial Cell Activation & Signaling"
        style="filled,rounded"
        bgcolor="#FFF8E1"
        color="#FFC107"
        fontname="Helvetica-Bold"
        fontsize=13
        fontcolor="#FF6F00"

        node [fillcolor="#FFF9C4" color="#F57F17"]

        MC_quiet      [label="Mesangial Cell\n(quiescent)" shape=ellipse]
        MC_act        [label="Mesangial Cell\n(activated)" shape=ellipse fillcolor="#FFD600"]
        NF_kB_MC      [label="NF-κB\n(mesangial)" shape=ellipse]
        ERK_MC        [label="ERK1/2 MAPK\n(mesangial)" shape=ellipse]
        PI3K_AKT_MC   [label="PI3K/AKT/mTOR\n(mesangial)" shape=ellipse]
        PDGFR_B       [label="PDGFR-β\n(mesangial)" shape=ellipse]
        PDGF_BB       [label="PDGF-BB\n(proliferation signal)" shape=ellipse]
        TGFb_MC       [label="TGF-β1\n(fibrotic master regulator)" shape=ellipse fillcolor="#FFB300"]
        Smad23        [label="SMAD2/3\n(TGF-β canonical)" shape=ellipse]
        CTGF          [label="CTGF/CCN2\n(matrix production)" shape=ellipse]
        IL6_MC        [label="IL-6\n(mesangial secretion)" shape=ellipse]
        TNFa_MC       [label="TNF-α\n(inflammatory)" shape=ellipse]
        MCP1_MC       [label="MCP-1 / CCL2\n(monocyte recruit)" shape=ellipse]
        MC_prolif     [label="MC Proliferation\n(M-score↑)" shape=rect fillcolor="#F57F17" fontcolor="white"]
        Matrix_exp    [label="Mesangial Matrix\nExpansion (S-score↑)" shape=rect fillcolor="#F57F17" fontcolor="white"]
        ROS_MC        [label="ROS / NOX4\nOxidative Stress" shape=ellipse]
        HIF1a_MC      [label="HIF-1α\n(hypoxia response)" shape=ellipse]
    }

    // ==========================================================
    // CLUSTER 7: GLOMERULAR INJURY (PODOCYTE + GBM)
    // ==========================================================
    subgraph cluster_glom {
        label="Glomerular Injury – Podocyte & GBM"
        style="filled,rounded"
        bgcolor="#FFEBEE"
        color="#F44336"
        fontname="Helvetica-Bold"
        fontsize=13
        fontcolor="#B71C1C"

        node [fillcolor="#FFCDD2" color="#C62828"]

        Podocyte      [label="Podocyte\n(healthy)" shape=ellipse]
        Pod_inj       [label="Podocyte\n(injured/depleted)" shape=ellipse fillcolor="#EF9A9A"]
        Nephrin       [label="Nephrin\n(NPHS1, slit diaphragm)" shape=ellipse]
        Podocin       [label="Podocin\n(NPHS2)" shape=ellipse]
        Synapto       [label="Synaptopodin\n(actin stabilizer)" shape=ellipse]
        TRPC6         [label="TRPC6 Channel\n(Ca²⁺ overload)" shape=ellipse]
        FP_eff        [label="Foot Process\nEffacement" shape=rect fillcolor="#EF5350" fontcolor="white"]
        GBM_inj       [label="GBM Thickening\n& Breach" shape=rect fillcolor="#EF5350" fontcolor="white"]
        Glom_perm     [label="↑ Glomerular\nPermeability" shape=rect]
        Proteinuria   [label="PROTEINURIA\n(albumin, IgG leak)" shape=hexagon fillcolor="#B71C1C" fontcolor="white"]
        Hematuria     [label="HEMATURIA\n(dysmorphic RBC, casts)" shape=hexagon fillcolor="#B71C1C" fontcolor="white"]
        Crescents     [label="Cellular/Fibrous\nCrescents (C-score)" shape=rect]
        VEGF_glom     [label="VEGF\n(glomerular)" shape=ellipse]
        Ang2_glom     [label="Angiopoietin-2\n(endothelial destab.)" shape=ellipse]
        WT1           [label="WT1\n(podocyte marker)" shape=ellipse]
    }

    // ==========================================================
    // CLUSTER 8: TUBULAR & INTERSTITIAL INJURY
    // ==========================================================
    subgraph cluster_tif {
        label="Tubular & Interstitial Injury / Fibrosis"
        style="filled,rounded"
        bgcolor="#E8EAF6"
        color="#3F51B5"
        fontname="Helvetica-Bold"
        fontsize=13
        fontcolor="#1A237E"

        node [fillcolor="#C5CAE9" color="#283593"]

        PTC_norm      [label="Proximal Tubular Cell\n(PTC, normal)" shape=ellipse]
        Prot_ovrload  [label="Protein Overload\nNephropathy (tube cast)" shape=rect]
        TEC_EMT       [label="TEC → EMT\n(→ myofibroblast)" shape=ellipse]
        Int_mac       [label="Interstitial\nMacrophage (M1)" shape=ellipse]
        Int_T         [label="Interstitial T Cell\n(CD4+/CD8+)" shape=ellipse]
        TGFb_TIF      [label="TGF-β1\n(tubulointerstitial)" shape=ellipse]
        MyoFB         [label="Myofibroblast\n(activated)" shape=ellipse fillcolor="#7986CB"]
        Col_I_III     [label="Collagen I/III\n(ECM deposition)" shape=rect]
        TIF           [label="Tubulointerstitial\nFibrosis (T-score↑)" shape=rect fillcolor="#283593" fontcolor="white"]
        Tub_atrophy   [label="Tubular Atrophy\n(Oxford T-score)" shape=rect fillcolor="#283593" fontcolor="white"]
        MMP_2_9       [label="MMP-2/9\n(matrix remodelling)" shape=ellipse]
        TIMP_1        [label="TIMP-1/2\n(MMP inhibitor)" shape=ellipse]
    }

    // ==========================================================
    // CLUSTER 9: RAAS SYSTEM
    // ==========================================================
    subgraph cluster_raas {
        label="RAAS & Intraglomerular Hemodynamics"
        style="filled,rounded"
        bgcolor="#E0F2F1"
        color="#009688"
        fontname="Helvetica-Bold"
        fontsize=13
        fontcolor="#004D40"

        node [fillcolor="#B2DFDB" color="#00695C"]

        Renin         [label="Renin\n(juxtaglomerular cells)" shape=ellipse]
        AGT           [label="Angiotensinogen\n(liver)" shape=ellipse]
        AngI          [label="Angiotensin I\n(inactive)" shape=ellipse]
        ACE           [label="ACE\n(pulmonary/renal EC)" shape=ellipse]
        AngII         [label="Angiotensin II\n(vasoactive effector)" shape=diamond fillcolor="#00897B" fontcolor="white"]
        AT1R          [label="AT1R\n(mesangial / VSMC)" shape=ellipse]
        AT2R          [label="AT2R\n(counter-regulatory)" shape=ellipse]
        Aldosterone   [label="Aldosterone\n(adrenal cortex)" shape=ellipse]
        Na_retain     [label="Na⁺/H₂O\nRetention" shape=rect]
        IntraGlom_P   [label="Intraglomerular\nHypertension" shape=rect fillcolor="#00695C" fontcolor="white"]
        SNS_act       [label="Sympathetic\nActivation" shape=ellipse]
        ET1           [label="ET-1\n(endothelin-1)" shape=ellipse]
        ACE2          [label="ACE2\n(counter-regulatory EC)" shape=ellipse]
        Ang1_7        [label="Ang(1-7)\n(MasR → vasoprotective)" shape=ellipse]
    }

    // ==========================================================
    // CLUSTER 10: DRUG PK/PD
    // ==========================================================
    subgraph cluster_drugs {
        label="Drug PK/PD Mechanisms"
        style="filled,rounded"
        bgcolor="#F1F8E9"
        color="#8BC34A"
        fontname="Helvetica-Bold"
        fontsize=13
        fontcolor="#33691E"

        node [fillcolor="#DCEDC8" color="#558B2F"]

        ACEi          [label="ACE Inhibitor\n(enalapril/ramipril)\nACE blockade" shape=rect fillcolor="#AED581"]
        ARB           [label="ARB\n(losartan/irbesartan)\nAT1R blockade" shape=rect fillcolor="#AED581"]
        Sparsentan    [label="Sparsentan\n(dual AT1R + ETB)\n↓ proteinuria ↓↓" shape=rect fillcolor="#8BC34A" fontcolor="white"]
        Budesonide_TRF [label="Budesonide TRF\n(Nefecon 16mg/d)\n↓ mucosal APRIL/IgA" shape=rect fillcolor="#8BC34A" fontcolor="white"]
        Iptacopan     [label="Iptacopan\n(Factor B inhibitor)\n↓ AP complement" shape=rect fillcolor="#8BC34A" fontcolor="white"]
        Sibeprenlimab [label="Sibeprenlimab\n(anti-APRIL mAb)\n↓ Gd-IgA1 production" shape=rect fillcolor="#8BC34A" fontcolor="white"]
        Zigakibart    [label="Zigakibart\n(anti-C5 mAb)\n↓ MAC/C5a" shape=rect fillcolor="#8BC34A" fontcolor="white"]
        SGLT2i        [label="SGLT2i\n(dapagliflozin 10mg)\nhemodynamic+anti-inflam" shape=rect fillcolor="#AED581"]
        Prednisolone  [label="Prednisolone\n(oral steroids)\nimmunosuppression" shape=rect fillcolor="#AED581"]
        MMF           [label="Mycophenolate\n(MMF)\nanti-proliferative" shape=rect fillcolor="#AED581"]
        Atrasentan    [label="Atrasentan\n(ETA inhibitor)\n↓ efferent arteriole" shape=rect fillcolor="#AED581"]
        Belimumab     [label="Belimumab\n(anti-BAFF mAb)\n↓ B cell survival" shape=rect fillcolor="#AED581"]
    }

    // ==========================================================
    // CLUSTER 11: CLINICAL ENDPOINTS & BIOMARKERS
    // ==========================================================
    subgraph cluster_endpoints {
        label="Clinical Endpoints & Biomarkers"
        style="filled,rounded"
        bgcolor="#FAFAFA"
        color="#607D8B"
        fontname="Helvetica-Bold"
        fontsize=13
        fontcolor="#263238"

        node [fillcolor="#ECEFF1" color="#455A64"]

        eGFR_ep       [label="eGFR\n(mL/min/1.73m²)" shape=hexagon fillcolor="#455A64" fontcolor="white"]
        UPCR_ep       [label="UPCR\n(mg protein/mg creatinine)" shape=hexagon fillcolor="#455A64" fontcolor="white"]
        Prot24h       [label="24-h Proteinuria\n(g/day)" shape=hexagon]
        IgA_ser       [label="Serum IgA\n(g/L)" shape=hexagon]
        GdIgA1_ep     [label="Serum Gd-IgA1\n(disease biomarker)" shape=hexagon]
        C3_ser        [label="Serum C3\n(↓ in active disease)" shape=hexagon]
        Creat_ser     [label="Serum Creatinine\n(mg/dL)" shape=hexagon]
        BP_ep         [label="Blood Pressure\n(systolic mmHg)" shape=hexagon]
        MEST_C        [label="Oxford MEST-C\nHistology Score" shape=rect]
        ESKD          [label="ESKD\n(end-stage kidney disease)" shape=hexagon fillcolor="#B71C1C" fontcolor="white"]
        CR50          [label="CR50 Endpoint\n(≥50% UPCR reduction)" shape=hexagon]
        GFR_slope     [label="eGFR Slope\n(mL/min/yr)" shape=hexagon]
        Remission     [label="Complete Remission\n(UPCR <0.3 g/g)" shape=hexagon]
    }

    // ===========================================================
    // EDGES
    // ===========================================================

    // --- Genetics → downstream ---
    TNFSF13_gene  -> APRIL          [label="encodes" style=dashed]
    TNFSF13B_gene -> BAFF           [label="encodes" style=dashed]
    C1GALT1_gene  -> C1GalT1        [label="↓ expression" style=dashed color="#E65100"]
    COSMC_gene    -> Cosmc          [label="↓ function" style=dashed color="#E65100"]
    ST6GalNAc2_gene -> ST6GalNAc2  [label="variant" style=dashed]
    HLA_DQ        -> Tfh_mus        [label="antigen pres."]
    HLA_DQ        -> CD4_Tfh_auto   [label="risk allele"]
    Gut_micro     -> APRIL          [label="upregulates" color="#388E3C"]
    Gut_micro     -> BAFF           [label="upregulates" color="#388E3C"]
    Mucosal_inf   -> APRIL          [label="stimulates" color="#388E3C"]
    Mucosal_inf   -> IL6_mus        [label="induces" color="#388E3C"]
    Env_trigger   -> Mucosal_inf    [label="predisposes"]
    DEFA          -> Gut_micro      [label="shapes microbiome"]

    // --- Mucosal immunity → IgA1 production ---
    Mucosal_inf   -> Naive_B        [label="activates"]
    Naive_B       -> PP_GC          [label="migrates to"]
    Naive_B       -> Tonsillar_B    [label="or tonsil MALT"]
    APRIL         -> IgA1_PC        [label="survival/diff↑" color="#2E7D32" penwidth=2]
    BAFF          -> IgA1_PC        [label="survival↑" color="#2E7D32" penwidth=2]
    APRIL         -> Naive_B        [label="activates" color="#2E7D32"]
    BAFF          -> Naive_B        [label="survival"]
    PP_GC         -> AID            [label="induces"]
    AID           -> TGFb_sw        [label="cooperates"]
    TGFb_sw       -> IgA1_PC        [label="IgA class switch"]
    IL21_mus      -> PP_GC          [label="GC support↑"]
    IL21_mus      -> AID            [label="upregulates"]
    IL4_mus       -> AID            [label="class switch" color="#1B5E20"]
    IL6_mus       -> IgA1_PC        [label="differentiation"]
    IL10_mus      -> IgA1_PC        [label="survival/prolif"]
    Tfh_mus       -> IL21_mus       [label="secretes"]
    Tfh_mus       -> PP_GC          [label="T-B interaction"]
    Tonsillar_B   -> IgA1_PC        [label="differentiates"]
    IgA1_PC       -> pIgR           [label="IgA secreted"]
    pIgR          -> sIgA           [label="transport to mucosa"]

    // --- Hit 1: Gd-IgA1 ---
    IgA1_PC       -> IgA1_hinge     [label="produces IgA1"]
    C1GalT1       -> IgA1_hinge     [label="galactosylates"]
    Cosmc         -> C1GalT1        [label="chaperone enables↑"]
    ST6GalNAc2    -> IgA1_hinge     [label="sialylates GalNAc\n(competes with C1GalT1)"]
    IgA1_hinge    -> Normal_IgA1    [label="fully glycosylated"]
    IgA1_hinge    -> GalNAc_exp     [label="C1GalT1↓ → truncated"]
    GalNAc_exp    -> Gd_IgA1        [label="forms Gd-IgA1"]
    Gd_IgA1       -> GdIgA1_serum   [label="secreted↑↑" penwidth=2.5 color="#E65100"]
    Normal_IgA1   -> IgA1_serum     [label="normal secretion"]
    GdIgA1_serum  -> FcaRI_mes      [label="binds"]
    GdIgA1_serum  -> ASGPR          [label="partial clearance"]
    Gd_IgA1       -> TfR1           [label="alternative bind"]

    // --- Hit 2: autoantibody ---
    Gd_IgA1       -> BCR_GalNAc     [label="GalNAc epitope"]
    BCR_GalNAc    -> GC_auto        [label="B cell → GC"]
    CD4_Tfh_auto  -> GC_auto        [label="T-cell help"]
    CD4_Tfh_auto  -> IL21_auto      [label="secretes"]
    IL21_auto     -> GC_auto        [label="promotes"]
    GC_auto       -> SHM            [label="induces"]
    SHM           -> Class_sw_IgG   [label="IgG switch"]
    GC_auto       -> PC_auto        [label="differentiates"]
    Class_sw_IgG  -> Anti_IgG       [label="produces"]
    PC_auto       -> Anti_IgG       [label="secretes" penwidth=2 color="#880E4F"]
    PC_auto       -> Anti_IgA       [label="secretes"]
    IL17A         -> IL6_mus        [label="amplifies"]
    CD4_Tfh_auto  -> IL17A          [label="Th17 subset"]

    // --- Hit 3: IC formation ---
    GdIgA1_serum  -> IC_complex     [label="+ autoantibody"]
    Anti_IgG      -> IC_complex     [label="binds Gd-IgA1" penwidth=2 color="#7B1FA2"]
    Anti_IgA      -> IC_complex     [label="binds"]
    IC_complex    -> IC_large       [label="polymerize"]
    IC_complex    -> IC_small       [label="small fraction"]
    IC_large      -> IC_hex         [label="hexamerize"]
    IC_hex        -> C1q            [label="C1q binding"]

    // --- Hit 4: deposition ---
    IC_large      -> Mes_dep        [label="deposit↑↑↑" penwidth=2.5 color="#6A1B9A"]
    IC_large      -> FcaRI_mes      [label="FcαRI binding"]
    IC_large      -> EC_IC          [label="endothelial"]
    FcaRI_mes     -> MC_act         [label="activates MC" penwidth=2]
    TfR1          -> MC_act         [label="activates MC"]
    Mes_dep       -> C3conv_CP      [label="CP/LP trigger"]
    IC_small      -> ASGPR          [label="cleared"]

    // --- Complement cascade ---
    C1q           -> C4b            [label="activates C1r/C1s"]
    Mes_dep       -> MBL            [label="MBL binding"]
    Mes_dep       -> FCN            [label="ficolin binding"]
    MBL           -> MASP12         [label="activates"]
    FCN           -> MASP12         [label="activates"]
    MASP12        -> C4b            [label="cleaves C4"]
    C4b           -> C3conv_CP      [label="C4b + C2a"]
    C3conv_CP     -> C3_cleave      [label="cleaves C3" penwidth=2]
    C3conv_AP     -> C3_cleave      [label="amplification↑↑" penwidth=2]
    Factor_B      -> C3conv_AP      [label="assembly: C3b+Bb"]
    Factor_D      -> Factor_B       [label="cleaves Bb"]
    Properdin     -> C3conv_AP      [label="stabilizes"]
    C3_cleave     -> C3b            [label="→ C3b opsonin"]
    C3_cleave     -> C3a            [label="+ C3a"]
    C3b           -> C3conv_AP      [label="AP amplification loop" penwidth=2]
    C3b           -> C5_conv        [label="joins C3conv → C5conv"]
    C5_conv       -> C5a            [label="cleaves C5"]
    C5_conv       -> MAC_C5b9       [label="initiates C5b-9"]
    C5a           -> Int_mac        [label="chemotaxis↑" color="#C62828"]
    C5a           -> MC_act         [label="activates MC" color="#C62828"]
    MAC_C5b9      -> Pod_inj        [label="podocyte lysis" penwidth=2 color="#B71C1C"]
    MAC_C5b9      -> MC_act         [label="activates MC" penwidth=1.5]
    C3a           -> MC_act         [label="activates"]
    CD46_CD55     -> C3conv_AP      [label="inhibits (deficient↓)" style=dashed]

    // --- Mesangial signaling ---
    MC_quiet      -> MC_act         [label="activated by IC/MAC"]
    MC_act        -> NF_kB_MC       [label="activates"]
    MC_act        -> ERK_MC         [label="activates"]
    MC_act        -> PI3K_AKT_MC    [label="activates"]
    PDGFR_B       -> ERK_MC         [label="PDGF signal"]
    PDGF_BB       -> PDGFR_B        [label="ligand"]
    MC_act        -> PDGF_BB        [label="autocrine loop"]
    MC_act        -> TGFb_MC        [label="secretes" penwidth=2 color="#F57F17"]
    TGFb_MC       -> Smad23         [label="canonical signal"]
    Smad23        -> CTGF           [label="transcribes CTGF"]
    CTGF          -> Matrix_exp     [label="ECM production" penwidth=2]
    TGFb_MC       -> Matrix_exp     [label="↑ collagen/FN" penwidth=2]
    NF_kB_MC      -> IL6_MC         [label="transcribes"]
    NF_kB_MC      -> TNFa_MC        [label="transcribes"]
    NF_kB_MC      -> MCP1_MC        [label="transcribes"]
    ERK_MC        -> MC_prolif      [label="proliferation↑" penwidth=2]
    PI3K_AKT_MC   -> MC_prolif      [label="proliferation↑"]
    TGFb_MC       -> ROS_MC         [label="NOX4 induction"]
    ROS_MC        -> NF_kB_MC       [label="redox activation"]
    ROS_MC        -> HIF1a_MC       [label="stabilizes"]
    HIF1a_MC      -> VEGF_glom      [label="induces VEGF"]
    MCP1_MC       -> Int_mac        [label="recruits macrophages"]
    IL6_MC        -> Pod_inj        [label="indirect injury"]
    TNFa_MC       -> Pod_inj        [label="indirect injury"]
    MCP1_MC       -> Int_T          [label="recruits T cells"]

    // --- Glomerular injury ---
    Podocyte      -> Nephrin        [label="expresses"]
    Podocyte      -> Podocin        [label="expresses"]
    Podocyte      -> Synapto        [label="expresses"]
    Podocyte      -> WT1            [label="expresses"]
    MAC_C5b9      -> FP_eff         [label="disrupts SD/cytoskel"]
    TNFa_MC       -> TRPC6          [label="upregulates"]
    TRPC6         -> FP_eff         [label="Ca²⁺ overload → actin rearr."]
    FP_eff        -> Pod_inj        [label="→ depleted" penwidth=2 color="#C62828"]
    Pod_inj       -> GBM_inj        [label="GBM exposed" penwidth=2]
    GBM_inj       -> Glom_perm      [label="↑ permeability" penwidth=2]
    Glom_perm     -> Proteinuria    [label="albumin leak" penwidth=2.5 color="#B71C1C"]
    MC_prolif     -> Crescents      [label="severe disease"]
    Matrix_exp    -> GBM_inj        [label="mesangial expansion"]
    VEGF_glom     -> Glom_perm      [label="↑ permeability"]
    Ang2_glom     -> VEGF_glom      [label="induces"]
    Pod_inj       -> Ang2_glom      [label="VEGF↓→ instability" style=dashed]
    Matrix_exp    -> Hematuria      [label="capillary compression"]
    GBM_inj       -> Hematuria      [label="RBC passage"]
    IL6_MC        -> Crescents      [label="promotes"]

    // --- Tubular injury ---
    Proteinuria   -> Prot_ovrload   [label="filtered protein"]
    Prot_ovrload  -> PTC_norm       [label="toxic reabsorption"]
    PTC_norm      -> TEC_EMT        [label="EMT transition"]
    TEC_EMT       -> MyoFB          [label="→ myoFB" penwidth=2]
    TGFb_MC       -> TGFb_TIF       [label="spillover to interstitium"]
    TGFb_TIF      -> TEC_EMT        [label="induces EMT"]
    TGFb_TIF      -> MyoFB          [label="activates"]
    MyoFB         -> Col_I_III      [label="deposits ECM"]
    Col_I_III     -> TIF            [label="accumulates" penwidth=2]
    TIMP_1        -> MMP_2_9        [label="inhibits"]
    TIF           -> Tub_atrophy    [label="advanced TIF" penwidth=2 color="#283593"]
    Int_mac       -> TGFb_TIF       [label="secretes TGF-β"]
    Int_T         -> TGFb_TIF       [label="secretes TGF-β"]
    Int_mac       -> TNFa_MC        [label="secretes TNF-α"]
    MMP_2_9       -> Col_I_III      [label="degrades (limited)"]

    // --- RAAS ---
    SNS_act       -> Renin          [label="β1-stimulates"]
    Renin         -> AngI           [label="AGT → AngI"]
    AGT           -> AngI           [label="substrate"]
    AngI          -> AngII          [label="ACE converts"]
    ACE           -> AngII          [label="catalyzes"]
    AngII         -> AT1R           [label="binds" penwidth=2]
    AngII         -> AT2R           [label="binds (minor)"]
    AT1R          -> IntraGlom_P    [label="efferent vasoconstriction" penwidth=2]
    AT1R          -> Aldosterone    [label="adrenal stimulation"]
    Aldosterone   -> Na_retain      [label="Na⁺/K⁺ exchange"]
    AT1R          -> TGFb_MC        [label="↑ TGF-β" penwidth=1.5]
    AT1R          -> NF_kB_MC       [label="activates" penwidth=1.5]
    IntraGlom_P   -> Proteinuria    [label="↑ filtration pressure" penwidth=1.5]
    IntraGlom_P   -> Pod_inj        [label="mechanical stress"]
    ACE2          -> Ang1_7         [label="ACE2 converts AngII"]
    AngII         -> ACE2           [label="substrate (partial)"]
    Ang1_7        -> AT1R           [label="counters via MasR" style=dashed color="#009688"]
    ET1           -> IntraGlom_P    [label="ETA vasoconstriction"]
    ET1           -> NF_kB_MC       [label="activates"]
    Na_retain     -> BP_ep          [label="↑ BP"]
    AngII         -> BP_ep          [label="↑ BP"]
    Na_retain     -> IntraGlom_P    [label="↑ filtration"]

    // --- Clinical Endpoints ---
    GdIgA1_serum  -> GdIgA1_ep     [label="measured directly"]
    IgA1_PC       -> IgA_ser        [label="serum IgA↑"]
    C3_cleave     -> C3_ser         [label="C3 ↓ consumed"]
    Proteinuria   -> UPCR_ep        [label="→ UPCR ratio"]
    Proteinuria   -> Prot24h        [label="→ 24h collection"]
    Proteinuria   -> CR50           [label="≥50% ↓ = CR50"]
    Proteinuria   -> Remission      [label="<0.3 g/g = remission"]
    TIF           -> eGFR_ep        [label="→ eGFR↓" penwidth=2 color="#455A64"]
    Tub_atrophy   -> eGFR_ep        [label="→ eGFR↓" penwidth=2]
    Matrix_exp    -> eGFR_ep        [label="glomerulosclerosis"]
    eGFR_ep       -> GFR_slope      [label="slope over yrs"]
    GFR_slope     -> ESKD           [label="progression→ESKD" penwidth=2.5 color="#B71C1C"]
    TIF           -> MEST_C         [label="T-score"]
    MC_prolif     -> MEST_C         [label="M-score"]
    Matrix_exp    -> MEST_C         [label="S-score"]
    Crescents     -> MEST_C         [label="C-score"]
    eGFR_ep       -> Creat_ser      [label="inverse relation"]
    Hematuria     -> MEST_C         [label="gross hematuria"]

    // ===========================================================
    // DRUG EFFECTS (dashed inhibitory/stimulatory edges)
    // ===========================================================

    ACEi          -> ACE            [label="inhibits ⊣" color="#558B2F" style=dashed arrowhead=tee]
    ACEi          -> AngII          [label="↓ AngII ⊣" color="#558B2F" style=dashed arrowhead=tee]
    ARB           -> AT1R           [label="blocks ⊣" color="#558B2F" style=dashed arrowhead=tee]
    ARB           -> IntraGlom_P    [label="↓ pressure ⊣" color="#558B2F" style=dashed arrowhead=tee]

    Sparsentan    -> AT1R           [label="dual block ⊣" color="#33691E" style=dashed arrowhead=tee penwidth=2]
    Sparsentan    -> ET1            [label="ETB block ⊣" color="#33691E" style=dashed arrowhead=tee penwidth=2]
    Sparsentan    -> IntraGlom_P    [label="↓↓ pressure ⊣" color="#33691E" style=dashed arrowhead=tee penwidth=2]

    Budesonide_TRF -> APRIL         [label="↓ mucosal APRIL ⊣" color="#33691E" style=dashed arrowhead=tee penwidth=2]
    Budesonide_TRF -> Gd_IgA1       [label="↓ Gd-IgA1 ⊣" color="#33691E" style=dashed arrowhead=tee penwidth=2]
    Budesonide_TRF -> IgA1_PC       [label="↓ IgA prod ⊣" color="#33691E" style=dashed arrowhead=tee]

    Iptacopan     -> Factor_B       [label="inhibits ⊣" color="#33691E" style=dashed arrowhead=tee penwidth=2]
    Iptacopan     -> C3conv_AP      [label="↓ AP ⊣" color="#33691E" style=dashed arrowhead=tee penwidth=2]

    Sibeprenlimab -> APRIL          [label="anti-APRIL ⊣" color="#33691E" style=dashed arrowhead=tee penwidth=2]

    Zigakibart    -> C5_conv        [label="anti-C5 ⊣" color="#33691E" style=dashed arrowhead=tee penwidth=2]
    Zigakibart    -> MAC_C5b9       [label="↓ MAC ⊣" color="#33691E" style=dashed arrowhead=tee]
    Zigakibart    -> C5a            [label="↓ C5a ⊣" color="#33691E" style=dashed arrowhead=tee]

    SGLT2i        -> IntraGlom_P    [label="↓ afferent tone ⊣" color="#558B2F" style=dashed arrowhead=tee penwidth=1.5]
    SGLT2i        -> ROS_MC         [label="anti-oxidant ⊣" color="#558B2F" style=dashed arrowhead=tee]
    SGLT2i        -> NF_kB_MC       [label="anti-inflam ⊣" color="#558B2F" style=dashed arrowhead=tee]

    Prednisolone  -> NF_kB_MC       [label="GR-mediated ⊣" color="#558B2F" style=dashed arrowhead=tee]
    Prednisolone  -> IL6_MC         [label="↓ cytokines ⊣" color="#558B2F" style=dashed arrowhead=tee]
    Prednisolone  -> Gd_IgA1        [label="↓ B cell act ⊣" color="#558B2F" style=dashed arrowhead=tee]

    MMF           -> IgA1_PC        [label="antiproliferative ⊣" color="#558B2F" style=dashed arrowhead=tee]
    MMF           -> GC_auto        [label="↓ GC response ⊣" color="#558B2F" style=dashed arrowhead=tee]

    Atrasentan    -> ET1            [label="ETA block ⊣" color="#558B2F" style=dashed arrowhead=tee]
    Atrasentan    -> IntraGlom_P    [label="↓ pressure ⊣" color="#558B2F" style=dashed arrowhead=tee]

    Belimumab     -> BAFF           [label="anti-BAFF ⊣" color="#558B2F" style=dashed arrowhead=tee]
}
