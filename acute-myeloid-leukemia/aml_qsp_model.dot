digraph AML_QSP {
    rankdir=TB;
    graph [fontname="Helvetica", fontsize=11, bgcolor="#f8f9fa", compound=true, nodesep=0.4, ranksep=0.6, label="Acute Myeloid Leukemia (AML)\nQuantitative Systems Pharmacology Model", labelloc=t, labeljust=c, fontsize=16];
    node [fontname="Helvetica", fontsize=9, style="filled,rounded", shape=box];
    edge [fontname="Helvetica", fontsize=8, arrowsize=0.7];

    // =====================================================================
    // CLUSTER 1: Normal Hematopoiesis
    // =====================================================================
    subgraph cluster_hematopoiesis {
        label="Normal Hematopoiesis";
        style=filled;
        color="#dde8f8";
        fontsize=12;
        fontname="Helvetica-Bold";

        HSC [label="HSC\nHematopoietic Stem Cell", fillcolor="#4477cc", fontcolor="white"];
        LSC [label="LSC\nLeukemic Stem Cell", fillcolor="#ff4444", fontcolor="white"];
        CMP [label="CMP\nCommon Myeloid Progenitor", fillcolor="#4477cc", fontcolor="white"];
        GMP [label="GMP\nGranulocyte-Monocyte Progenitor", fillcolor="#4477cc", fontcolor="white"];
        MEP [label="MEP\nMegakaryocyte-Erythroid Progenitor", fillcolor="#4477cc", fontcolor="white"];
        Myeloblast [label="Myeloblast", fillcolor="#4477cc", fontcolor="white"];
        Promyelocyte [label="Promyelocyte", fillcolor="#4477cc", fontcolor="white"];
        Myelocyte [label="Myelocyte", fillcolor="#4477cc", fontcolor="white"];
        Granulocyte [label="Granulocyte\n(Neutrophil)", fillcolor="#4477cc", fontcolor="white"];
        Monocyte [label="Monocyte", fillcolor="#4477cc", fontcolor="white"];
        Erythroblast [label="Erythroblast", fillcolor="#4477cc", fontcolor="white"];
        Erythrocyte [label="Erythrocyte\n(RBC)", fillcolor="#4477cc", fontcolor="white"];
        Megakaryocyte [label="Megakaryocyte", fillcolor="#4477cc", fontcolor="white"];
        Platelet [label="Platelet\n(Thrombocyte)", fillcolor="#4477cc", fontcolor="white"];
        SCF [label="SCF\nStem Cell Factor", fillcolor="#44bb44", fontcolor="white"];
        TPO [label="TPO\nThrombopoietin", fillcolor="#44bb44", fontcolor="white"];
        EPO [label="EPO\nErythropoietin", fillcolor="#44bb44", fontcolor="white"];
        G_CSF [label="G-CSF", fillcolor="#44bb44", fontcolor="white"];
        GM_CSF [label="GM-CSF", fillcolor="#44bb44", fontcolor="white"];
        M_CSF [label="M-CSF", fillcolor="#44bb44", fontcolor="white"];
        IL3 [label="IL-3\nInterleukin-3", fillcolor="#44bb44", fontcolor="white"];
        IL6 [label="IL-6\nInterleukin-6", fillcolor="#44bb44", fontcolor="white"];
    }

    // =====================================================================
    // CLUSTER 2: AML Molecular Pathogenesis
    // =====================================================================
    subgraph cluster_molecular {
        label="AML Molecular Pathogenesis";
        style=filled;
        color="#ffe0e0";
        fontsize=12;
        fontname="Helvetica-Bold";

        FLT3_ITD [label="FLT3-ITD\nInternal Tandem Dup.", fillcolor="#ff4444", fontcolor="white"];
        RAS [label="RAS GTPase", fillcolor="#ff4444", fontcolor="white"];
        RAF [label="RAF Kinase", fillcolor="#ff4444", fontcolor="white"];
        MEK [label="MEK1/2", fillcolor="#ff4444", fontcolor="white"];
        ERK [label="ERK1/2", fillcolor="#ff4444", fontcolor="white"];
        NPM1_mut [label="NPM1 Mutation\n(Nucleophosmin)", fillcolor="#ff4444", fontcolor="white"];
        DNMT3A_mut [label="DNMT3A Mutation", fillcolor="#ff4444", fontcolor="white"];
        TET2_mut [label="TET2 Mutation", fillcolor="#ff4444", fontcolor="white"];
        IDH1_mut [label="IDH1 Mutation\n(R132H/C/S)", fillcolor="#ff4444", fontcolor="white"];
        IDH2_mut [label="IDH2 Mutation\n(R140Q/R172K)", fillcolor="#ff4444", fontcolor="white"];
        CEBPA_mut [label="CEBPA bZIP\nMutation", fillcolor="#ff4444", fontcolor="white"];
        RUNX1_RUNX1T1 [label="RUNX1-RUNX1T1\nt(8;21)", fillcolor="#ff4444", fontcolor="white"];
        PML_RARA [label="PML-RARA\nt(15;17) APL", fillcolor="#ff4444", fontcolor="white"];
        CBFB_MYH11 [label="CBFB-MYH11\ninv(16)", fillcolor="#ff4444", fontcolor="white"];
        TP53_mut [label="TP53 Mutation\nLoss of Function", fillcolor="#ff4444", fontcolor="white"];
        WT1_mut [label="WT1 Mutation", fillcolor="#ff4444", fontcolor="white"];
        ASXL1_mut [label="ASXL1 Mutation", fillcolor="#ff4444", fontcolor="white"];
        SF3B1_mut [label="SF3B1 Splicing\nMutation", fillcolor="#ff4444", fontcolor="white"];
        U2AF1_mut [label="U2AF1 Splicing\nMutation", fillcolor="#ff4444", fontcolor="white"];
        NRAS_mut [label="NRAS Mutation\n(G12/G13/Q61)", fillcolor="#ff4444", fontcolor="white"];
        KRAS_mut [label="KRAS Mutation", fillcolor="#ff4444", fontcolor="white"];
        FLT3_TKD [label="FLT3-TKD\nTyrosine Kinase Domain", fillcolor="#ff4444", fontcolor="white"];
        PI3K [label="PI3K\np110α/δ", fillcolor="#ff4444", fontcolor="white"];
        AKT [label="AKT/PKB", fillcolor="#ff4444", fontcolor="white"];
        mTOR [label="mTORC1/2", fillcolor="#ff4444", fontcolor="white"];
    }

    // =====================================================================
    // CLUSTER 3: Signaling Pathways
    // =====================================================================
    subgraph cluster_signaling {
        label="Oncogenic Signaling Pathways";
        style=filled;
        color="#fff0d0";
        fontsize=12;
        fontname="Helvetica-Bold";

        JAK_STAT5 [label="JAK2/STAT5\nSignaling", fillcolor="#ff8844", fontcolor="white"];
        FOXO [label="FOXO1/3a\nTranscription Factor", fillcolor="#44bb44", fontcolor="white"];
        MYC_oncogene [label="c-MYC\nOncogene", fillcolor="#ff4444", fontcolor="white"];
        NFkB [label="NF-κB\nSignaling", fillcolor="#ff4444", fontcolor="white"];
        WNT_pathway [label="WNT Pathway", fillcolor="#ff8844", fontcolor="white"];
        Beta_catenin [label="β-Catenin\nTCF/LEF Target", fillcolor="#ff4444", fontcolor="white"];
        Hedgehog_pathway [label="Hedgehog\nPathway", fillcolor="#ff8844", fontcolor="white"];
        Gli [label="GLI1/2\nTranscription", fillcolor="#ff4444", fontcolor="white"];
        Notch_pathway [label="NOTCH1/2\nSignaling", fillcolor="#ff8844", fontcolor="white"];
        Hes1 [label="HES1\nNotch Target", fillcolor="#ff4444", fontcolor="white"];
        HIF1a [label="HIF-1α\nHypoxia Response", fillcolor="#ff8844", fontcolor="white"];
        Glycolysis [label="Warburg Effect\nAerobic Glycolysis", fillcolor="#ff8844", fontcolor="white"];
    }

    // =====================================================================
    // CLUSTER 4: Apoptosis & Cell Death
    // =====================================================================
    subgraph cluster_apoptosis {
        label="Apoptosis & Cell Death Regulation";
        style=filled;
        color="#e8f8e8";
        fontsize=12;
        fontname="Helvetica-Bold";

        BCL2 [label="BCL-2\nAnti-apoptotic", fillcolor="#ff4444", fontcolor="white"];
        BCLxL [label="BCL-xL\nAnti-apoptotic", fillcolor="#ff4444", fontcolor="white"];
        MCL1 [label="MCL-1\nAnti-apoptotic", fillcolor="#ff4444", fontcolor="white"];
        BAX [label="BAX\nPro-apoptotic", fillcolor="#44bb44", fontcolor="white"];
        BAK [label="BAK\nPro-apoptotic", fillcolor="#44bb44", fontcolor="white"];
        BIM [label="BIM (BCL2L11)\nBH3-only Protein", fillcolor="#44bb44", fontcolor="white"];
        PUMA_protein [label="PUMA (BBC3)\nBH3-only Protein", fillcolor="#44bb44", fontcolor="white"];
        NOXA [label="NOXA (PMAIP1)\nBH3-only Protein", fillcolor="#44bb44", fontcolor="white"];
        BAD [label="BAD\nBH3-only Protein", fillcolor="#44bb44", fontcolor="white"];
        HRK [label="HRK (DP5)\nBH3-only Protein", fillcolor="#44bb44", fontcolor="white"];
        Cytochrome_c [label="Cytochrome c\nMitochondrial Release", fillcolor="#44bb44", fontcolor="white"];
        Apaf1 [label="APAF-1\nApoptosome", fillcolor="#44bb44", fontcolor="white"];
        Caspase9 [label="Caspase-9\nInitiator", fillcolor="#44bb44", fontcolor="white"];
        Caspase3 [label="Caspase-3/7\nExecutioner", fillcolor="#44bb44", fontcolor="white"];
        Apoptosis [label="APOPTOSIS\nCell Death", fillcolor="#228822", fontcolor="white", shape=doubleoctagon];
        p53_protein [label="p53 Protein\nTumor Suppressor", fillcolor="#44bb44", fontcolor="white"];
        XIAP [label="XIAP\nCaspase Inhibitor", fillcolor="#ff4444", fontcolor="white"];
        Survivin [label="Survivin (BIRC5)\nIAP Family", fillcolor="#ff4444", fontcolor="white"];
    }

    // =====================================================================
    // CLUSTER 5: Epigenetic Dysregulation
    // =====================================================================
    subgraph cluster_epigenetics {
        label="Epigenetic Dysregulation";
        style=filled;
        color="#f5e8ff";
        fontsize=12;
        fontname="Helvetica-Bold";

        TwoHG [label="2-Hydroxyglutarate\n(Oncometabolite)", fillcolor="#ff4444", fontcolor="white"];
        TET2_enzyme [label="TET2 Enzyme\n5mC→5hmC", fillcolor="#44bb44", fontcolor="white"];
        DNA_methylation [label="DNA Methylation\nCpG Islands", fillcolor="#ff4444", fontcolor="white"];
        EZH2 [label="EZH2\nHistone Methyltransferase", fillcolor="#ff4444", fontcolor="white"];
        PRC2 [label="PRC2 Complex\nPolycomb Repressive", fillcolor="#ff4444", fontcolor="white"];
        H3K27me3 [label="H3K27me3\nRepressive Mark", fillcolor="#ff4444", fontcolor="white"];
        HDAC [label="HDAC1/2/3\nHistone Deacetylase", fillcolor="#ff4444", fontcolor="white"];
        BRD4 [label="BRD4\nBromodomain Protein", fillcolor="#ff4444", fontcolor="white"];
        DOT1L [label="DOT1L\nHistone Methyltransferase", fillcolor="#ff4444", fontcolor="white"];
        H3K79me [label="H3K79me2/3\nDOT1L Mark (MLL-r)", fillcolor="#ff4444", fontcolor="white"];
    }

    // =====================================================================
    // CLUSTER 6: Bone Marrow Microenvironment
    // =====================================================================
    subgraph cluster_microenvironment {
        label="Bone Marrow Microenvironment";
        style=filled;
        color="#f0e8ff";
        fontsize=12;
        fontname="Helvetica-Bold";

        Osteoblast [label="Osteoblast\nNiche Cell", fillcolor="#9966cc", fontcolor="white"];
        Adipocyte [label="Adipocyte\nLipid Supply", fillcolor="#9966cc", fontcolor="white"];
        MSC [label="MSC\nMesenchymal Stem Cell", fillcolor="#9966cc", fontcolor="white"];
        CXCL12 [label="CXCL12/SDF-1α\nChemokine", fillcolor="#9966cc", fontcolor="white"];
        CXCR4 [label="CXCR4\nSDF-1 Receptor", fillcolor="#ff4444", fontcolor="white"];
        VLA4 [label="VLA-4\n(α4β1 Integrin)", fillcolor="#ff4444", fontcolor="white"];
        Fibronectin [label="Fibronectin\nECM Protein", fillcolor="#9966cc", fontcolor="white"];
        Endothelial_cell [label="Endothelial Cell\nAngiogenesis", fillcolor="#9966cc", fontcolor="white"];
        VEGF [label="VEGF-A\nAngiogenic Factor", fillcolor="#ff4444", fontcolor="white"];
        VEGFR [label="VEGFR2\nKDR", fillcolor="#ff4444", fontcolor="white"];
        ROS [label="Reactive Oxygen\nSpecies (ROS)", fillcolor="#ff8844", fontcolor="white"];
        M2_Macrophage [label="M2 Macrophage\nPro-tumoral", fillcolor="#ff8844", fontcolor="white"];
        TGFb [label="TGF-β\nImmunosuppressive", fillcolor="#ff4444", fontcolor="white"];
        IL10 [label="IL-10\nAnti-inflammatory", fillcolor="#ff8844", fontcolor="white"];
        Treg [label="T-regulatory Cell\nImmunosuppression", fillcolor="#ff8844", fontcolor="white"];
        NK_cell [label="NK Cell\nCytotoxic", fillcolor="#44bb44", fontcolor="white"];
        ADCC [label="ADCC\nAntibody-Dep. Cell Cytotoxicity", fillcolor="#44bb44", fontcolor="white"];
    }

    // =====================================================================
    // CLUSTER 7: Drug Mechanisms
    // =====================================================================
    subgraph cluster_drugs {
        label="Drug Mechanisms of Action";
        style=filled;
        color="#fff0e8";
        fontsize=12;
        fontname="Helvetica-Bold";

        Venetoclax [label="Venetoclax\nBCL-2 Inhibitor", fillcolor="#ff6b35", fontcolor="white"];
        Azacitidine [label="Azacitidine\nDNMT Inhibitor", fillcolor="#ff6b35", fontcolor="white"];
        Decitabine [label="Decitabine\nDNMT Inhibitor", fillcolor="#ff6b35", fontcolor="white"];
        Cytarabine [label="Cytarabine (Ara-C)\nNucleoside Analog", fillcolor="#ff6b35", fontcolor="white"];
        Daunorubicin [label="Daunorubicin\nAnthracycline", fillcolor="#ff6b35", fontcolor="white"];
        Idarubicin [label="Idarubicin\nAnthracycline", fillcolor="#ff6b35", fontcolor="white"];
        Midostaurin [label="Midostaurin\nFLT3/PKC Inhibitor", fillcolor="#ff6b35", fontcolor="white"];
        Quizartinib [label="Quizartinib\nFLT3 Inhibitor (II)", fillcolor="#ff6b35", fontcolor="white"];
        Gilteritinib [label="Gilteritinib\nFLT3/AXL Inhibitor", fillcolor="#ff6b35", fontcolor="white"];
        Enasidenib [label="Enasidenib\nIDH2 Inhibitor", fillcolor="#ff6b35", fontcolor="white"];
        Ivosidenib [label="Ivosidenib\nIDH1 Inhibitor", fillcolor="#ff6b35", fontcolor="white"];
        Glasdegib [label="Glasdegib\nSMO Inhibitor", fillcolor="#ff6b35", fontcolor="white"];
        Gemtuzumab_Ozo [label="Gemtuzumab Ozogamicin\nAnti-CD33 ADC", fillcolor="#ff6b35", fontcolor="white"];
        ATRA [label="ATRA\nAll-trans Retinoic Acid", fillcolor="#ff6b35", fontcolor="white"];
        Arsenic_Trioxide [label="Arsenic Trioxide\n(ATO)", fillcolor="#ff6b35", fontcolor="white"];
        CD33 [label="CD33 (Siglec-3)\nMyeloid Antigen", fillcolor="#ff4444", fontcolor="white"];
        CD33_ADC_complex [label="CD33-ADC\nInternalized Complex", fillcolor="#ff6b35", fontcolor="white"];
        RARA_receptor [label="RAR-α Receptor\nRetinoid Receptor", fillcolor="#44bb44", fontcolor="white"];
        DNMT_trapped [label="DNMT-DNA\nCovalent Trap", fillcolor="#44bb44", fontcolor="white"];
        TopoisomeraseII [label="Topoisomerase IIα\nAnthracycline Target", fillcolor="#ff4444", fontcolor="white"];
        FLT3_receptor [label="FLT3 Receptor\n(CD135)", fillcolor="#ff4444", fontcolor="white"];
    }

    // =====================================================================
    // CLUSTER 8: Drug Resistance
    // =====================================================================
    subgraph cluster_resistance {
        label="Drug Resistance Mechanisms";
        style=filled;
        color="#ffe8e8";
        fontsize=12;
        fontname="Helvetica-Bold";

        FLT3_F691L [label="FLT3-F691L\nGatekeeper Mutation", fillcolor="#ff4444", fontcolor="white"];
        BCL2_D103V [label="BCL-2 D103V\nVenetoclax Resistance", fillcolor="#ff4444", fontcolor="white"];
        MCL1_upregulation [label="MCL-1 Upregulation\nBCL-2 Independence", fillcolor="#ff4444", fontcolor="white"];
        NRAS_secondary [label="NRAS Secondary\nMutation (RAS escape)", fillcolor="#ff4444", fontcolor="white"];
        IDH_reversion [label="IDH Isoform\nReversion/Switch", fillcolor="#ff4444", fontcolor="white"];
        MDR1_Pgp [label="MDR1/P-gp\nDrug Efflux Pump", fillcolor="#ff4444", fontcolor="white"];
        CD33_loss [label="CD33 Antigen\nLoss/Downregulation", fillcolor="#ff4444", fontcolor="white"];
        CAMDR [label="CAM-DR\nCell Adhesion-Mediated\nDrug Resistance", fillcolor="#ff4444", fontcolor="white"];
    }

    // =====================================================================
    // CLUSTER 9: Immune Evasion & Immunotherapy
    // =====================================================================
    subgraph cluster_immune {
        label="Immune Evasion & Immunotherapy";
        style=filled;
        color="#e8f0ff";
        fontsize=12;
        fontname="Helvetica-Bold";

        CD47 [label="CD47\n'Don't Eat Me' Signal", fillcolor="#ff4444", fontcolor="white"];
        SIRPa [label="SIRPα\nMacrophage Receptor", fillcolor="#9966cc", fontcolor="white"];
        PDL1 [label="PD-L1 (CD274)\nCheckpoint Ligand", fillcolor="#ff4444", fontcolor="white"];
        PD1 [label="PD-1 (CD279)\nCheckpoint Receptor", fillcolor="#ff8844", fontcolor="white"];
        T_cell_exhaustion [label="T Cell Exhaustion\nTOX/LAG3/TIM3", fillcolor="#ff4444", fontcolor="white"];
        CD70 [label="CD70\nCostimulatory Ligand", fillcolor="#ff4444", fontcolor="white"];
        CD27 [label="CD27\nTNF Receptor", fillcolor="#44bb44", fontcolor="white"];
        CAR_T_CD33 [label="CAR-T (CD33)\nAdoptive Therapy", fillcolor="#44bb44", fontcolor="white"];
        CAR_T_CD123 [label="CAR-T (CD123)\nAdoptive Therapy", fillcolor="#44bb44", fontcolor="white"];
        BiTE_CD3CD33 [label="BiTE CD3xCD33\n(AMG 330)", fillcolor="#44bb44", fontcolor="white"];
        Magrolimab [label="Magrolimab\nAnti-CD47 mAb", fillcolor="#44bb44", fontcolor="white"];
    }

    // =====================================================================
    // CLUSTER 10: Clinical Endpoints
    // =====================================================================
    subgraph cluster_endpoints {
        label="Clinical Endpoints & Toxicities";
        style=filled;
        color="#e8ffe8";
        fontsize=12;
        fontname="Helvetica-Bold";

        Complete_Remission [label="Complete Remission\n(CR: blasts <5%)", fillcolor="#228822", fontcolor="white", shape=doubleoctagon];
        MLFS [label="MLFS\nMorphologic Leukemia-\nFree State", fillcolor="#44bb44", fontcolor="white"];
        MRD_status [label="MRD Status\n(Flow/PCR/NGS)", fillcolor="#44bb44", fontcolor="white"];
        OS [label="Overall Survival\n(OS)", fillcolor="#228822", fontcolor="white", shape=doubleoctagon];
        EFS [label="Event-Free Survival\n(EFS)", fillcolor="#44bb44", fontcolor="white"];
        Relapse [label="Relapse\nDrug Resistance", fillcolor="#ff4444", fontcolor="white", shape=doubleoctagon];
        ANC_nadir [label="ANC Nadir\nNeutropenia Tox.", fillcolor="#ff8844", fontcolor="white"];
        Thrombocytopenia [label="Thrombocytopenia\nPlatelet Nadir", fillcolor="#ff8844", fontcolor="white"];
        Anemia [label="Anemia\nHemoglobin Drop", fillcolor="#ff8844", fontcolor="white"];
        TLS_risk [label="Tumor Lysis\nSyndrome Risk", fillcolor="#ff8844", fontcolor="white"];
        Differentiation_Syndrome [label="Differentiation\nSyndrome (APL)", fillcolor="#ff8844", fontcolor="white"];
    }

    // =====================================================================
    // EDGES: Normal Hematopoiesis
    // =====================================================================
    SCF -> HSC [label="c-KIT", color="#44bb44"];
    IL3 -> HSC [color="#44bb44"];
    IL3 -> CMP [color="#44bb44"];
    HSC -> CMP [label="differentiation", color="#4477cc"];
    HSC -> LSC [label="transformation", color="#ff4444", style=dashed, penwidth=2];
    CMP -> GMP [color="#4477cc"];
    CMP -> MEP [color="#4477cc"];
    GMP -> Myeloblast [color="#4477cc"];
    Myeloblast -> Promyelocyte [color="#4477cc"];
    Promyelocyte -> Myelocyte [color="#4477cc"];
    Myelocyte -> Granulocyte [color="#4477cc"];
    G_CSF -> Granulocyte [label="stimulation", color="#44bb44"];
    GM_CSF -> Myelocyte [color="#44bb44"];
    GMP -> Monocyte [color="#4477cc"];
    M_CSF -> Monocyte [label="CSF1R", color="#44bb44"];
    MEP -> Erythroblast [color="#4477cc"];
    EPO -> Erythroblast [label="EPOR", color="#44bb44"];
    Erythroblast -> Erythrocyte [color="#4477cc"];
    MEP -> Megakaryocyte [color="#4477cc"];
    TPO -> Megakaryocyte [label="MPL/TPOR", color="#44bb44"];
    Megakaryocyte -> Platelet [color="#4477cc"];
    IL6 -> HSC [color="#44bb44"];
    IL6 -> CMP [color="#44bb44"];

    // =====================================================================
    // EDGES: Molecular Pathogenesis
    // =====================================================================
    FLT3_ITD -> JAK_STAT5 [label="constitutive\nactivation", color="#ff4444", penwidth=2];
    FLT3_ITD -> PI3K [color="#ff4444"];
    FLT3_ITD -> RAS [color="#ff4444"];
    FLT3_TKD -> RAS [color="#ff4444"];
    RAS -> RAF [color="#ff4444"];
    RAF -> MEK [color="#ff4444"];
    MEK -> ERK [color="#ff4444"];
    ERK -> MYC_oncogene [label="proliferation", color="#ff4444"];
    NRAS_mut -> RAS [color="#ff4444", style=dashed];
    KRAS_mut -> RAS [color="#ff4444", style=dashed];
    PI3K -> AKT [color="#ff4444"];
    AKT -> mTOR [color="#ff4444"];
    AKT -> FOXO [label="phospho-\ninhibition", color="#ff4444", arrowhead=tee];
    mTOR -> MYC_oncogene [color="#ff4444"];
    IDH1_mut -> TwoHG [label="neomorphic\nactivity", color="#ff4444", penwidth=2];
    IDH2_mut -> TwoHG [label="neomorphic\nactivity", color="#ff4444", penwidth=2];
    NPM1_mut -> MYC_oncogene [color="#ff4444"];
    TP53_mut -> p53_protein [label="LOF", color="#ff4444", arrowhead=tee];
    DNMT3A_mut -> DNA_methylation [label="impaired", color="#ff4444", arrowhead=tee];
    TET2_mut -> TET2_enzyme [label="LOF", color="#ff4444", arrowhead=tee];
    ASXL1_mut -> PRC2 [label="derepression", color="#ff4444"];
    SF3B1_mut -> NFkB [label="mis-splicing", color="#ff4444", style=dashed];
    U2AF1_mut -> NFkB [label="mis-splicing", color="#ff4444", style=dashed];
    RUNX1_RUNX1T1 -> HDAC [label="corepressor\nrecruitment", color="#ff4444"];
    PML_RARA -> RARA_receptor [label="fusion\nprotein", color="#ff4444"];
    CBFB_MYH11 -> HDAC [label="corepressor", color="#ff4444"];

    // =====================================================================
    // EDGES: Signaling → Downstream
    // =====================================================================
    JAK_STAT5 -> MYC_oncogene [color="#ff8844"];
    JAK_STAT5 -> BCL2 [label="transcription", color="#ff8844"];
    JAK_STAT5 -> MCL1 [color="#ff8844"];
    FOXO -> PUMA_protein [label="transcription", color="#44bb44"];
    FOXO -> BIM [color="#44bb44"];
    MYC_oncogene -> Glycolysis [color="#ff4444"];
    MYC_oncogene -> BCL2 [color="#ff4444"];
    NFkB -> BCL2 [color="#ff4444"];
    NFkB -> Survivin [color="#ff4444"];
    NFkB -> XIAP [color="#ff4444"];
    WNT_pathway -> Beta_catenin [color="#ff8844"];
    Beta_catenin -> MYC_oncogene [color="#ff4444"];
    Beta_catenin -> Survivin [color="#ff4444"];
    Hedgehog_pathway -> Gli [color="#ff8844"];
    Gli -> BCL2 [color="#ff4444"];
    Gli -> MCL1 [color="#ff4444"];
    Notch_pathway -> Hes1 [color="#ff8844"];
    Hes1 -> MYC_oncogene [color="#ff4444"];
    HIF1a -> VEGF [color="#ff8844"];
    HIF1a -> Glycolysis [color="#ff8844"];
    HIF1a -> BCL2 [color="#ff8844"];
    Glasdegib -> Hedgehog_pathway [label="SMO\ninhibition", color="#ff6b35", arrowhead=tee, penwidth=2];

    // =====================================================================
    // EDGES: Apoptosis Cascade
    // =====================================================================
    BCL2 -> BAX [label="sequester", color="#ff4444", arrowhead=tee];
    BCL2 -> BAK [label="sequester", color="#ff4444", arrowhead=tee];
    BCL2 -> BIM [arrowhead=tee, color="#ff4444"];
    BCL2 -> PUMA_protein [arrowhead=tee, color="#ff4444"];
    BCLxL -> BAX [arrowhead=tee, color="#ff4444"];
    MCL1 -> BAK [arrowhead=tee, color="#ff4444"];
    MCL1 -> NOXA [arrowhead=tee, color="#ff4444"];
    BIM -> BCL2 [color="#44bb44"];
    NOXA -> MCL1 [color="#44bb44", arrowhead=tee];
    BAD -> BCL2 [color="#44bb44", arrowhead=tee];
    BAD -> BCLxL [color="#44bb44", arrowhead=tee];
    HRK -> BCLxL [color="#44bb44", arrowhead=tee];
    BAX -> Cytochrome_c [label="MOMP", color="#44bb44", penwidth=2];
    BAK -> Cytochrome_c [label="MOMP", color="#44bb44", penwidth=2];
    Cytochrome_c -> Apaf1 [color="#44bb44"];
    Apaf1 -> Caspase9 [label="apoptosome", color="#44bb44"];
    Caspase9 -> Caspase3 [color="#44bb44"];
    XIAP -> Caspase9 [arrowhead=tee, color="#ff4444"];
    XIAP -> Caspase3 [arrowhead=tee, color="#ff4444"];
    Survivin -> Caspase3 [arrowhead=tee, color="#ff4444"];
    Caspase3 -> Apoptosis [penwidth=2, color="#228822"];
    p53_protein -> PUMA_protein [label="transcription", color="#44bb44"];
    p53_protein -> BAX [color="#44bb44"];
