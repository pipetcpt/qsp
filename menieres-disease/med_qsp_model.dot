digraph MED_QSP {
  graph [rankdir=LR, fontname="Helvetica", fontsize=11, labelloc=t,
         label="Ménière's Disease (메니에르병) — Integrated QSP Mechanistic Map\nEndolymphatic Sac Dysfunction → Endolymphatic Hydrops → Hair-Cell Injury → Episodic Vertigo, Fluctuating SNHL, Tinnitus, Aural Fullness\nBetahistine · Diuretics (HCTZ/Triamterene, Acetazolamide) · Intratympanic Dexamethasone · Intratympanic Gentamicin · Vestibular Suppressants · Endolymphatic Sac/Neurectomy/Labyrinthectomy",
         splines=spline, overlap=false, nodesep=0.28, ranksep=0.55,
         bgcolor="#fbfbfd"];
  node  [shape=box, style="rounded,filled", fontname="Helvetica", fontsize=10,
         fillcolor="#ffffff", color="#7d8590"];
  edge  [fontname="Helvetica", fontsize=9, color="#6e7681", arrowsize=0.7];

  /* ───────────────────────── 1. Etiology & Susceptibility ─────────────────── */
  subgraph cluster_etiology {
    label="1. Etiology, Genetic & Autoimmune Susceptibility";
    style="filled,rounded"; color="#5c6370"; fillcolor="#f3f0ff"; fontsize=12;
    GeneticRisk     [label="Familial clustering /\nDTNA, FAM136A, POU4F3\ncandidate loci"];
    MigraineAssoc   [label="Vestibular migraine\ncomorbidity/overlap"];
    ViralTrigger    [label="Viral labyrinthitis\ntrigger (HSV reactivation\nhypothesis)"];
    AutoimmuneHyp   [label="Autoimmune inner-ear\ndisease hypothesis"];
    AntiInnerEarAb  [label="Anti-inner-ear\nantibodies (anti-Hsp70,\nanti-CoCh5B2)"];
    VascularTheory  [label="Vascular theory\n(labyrinthine ischemia/\nvasospasm)"];
    AllergyHyp      [label="Allergic/immune-complex\nhypothesis"];
    SystemicAutoimm [label="Systemic autoimmune\ndisease association\n(Cogan syndrome, SLE)"];
    Idiopathic      [label="Idiopathic (majority\nof sporadic cases)"];
    GeneticRisk -> EndoSacDysfunction [style=dashed, label="predisposes"];
    MigraineAssoc -> VascularTheory [style=dashed, label="shared\nvasoreactivity"];
    ViralTrigger -> AutoimmuneHyp [style=dashed, label="molecular\nmimicry"];
    AutoimmuneHyp -> AntiInnerEarAb;
    AntiInnerEarAb -> EndoSacDysfunction [style=dashed, label="immune injury"];
    SystemicAutoimm -> AutoimmuneHyp;
    AllergyHyp -> AntiInnerEarAb [style=dashed];
    VascularTheory -> EndoSacDysfunction [style=dashed, label="microcirculatory\ncompromise"];
    Idiopathic -> EndoSacDysfunction [style=dashed, label="unknown\ntrigger"];
  }

  /* ───────────────────────── 2. Endolymphatic Sac / Fluid Homeostasis ─────── */
  subgraph cluster_sac {
    label="2. Endolymphatic Sac Dysfunction & Fluid Homeostasis";
    style="filled,rounded"; color="#5c6370"; fillcolor="#fff4e6"; fontsize=12;
    EndoSacDysfunction [label="Endolymphatic sac\nabsorptive dysfunction"];
    LongitFlowBlock  [label="Longitudinal endolymph\nflow obstruction"];
    EndoOverprod     [label="Endolymph\noverproduction\n(stria/dark cells)"];
    EndoUnderabs     [label="Endolymph\nunderabsorption (sac)"];
    AQP2             [label="Aquaporin-2 (AQP2)\nsac epithelium"];
    AQP3             [label="Aquaporin-3 (AQP3)\nsac epithelium"];
    CochlearAQP      [label="Cochlear aquaporin\nwater channels\n(AQP1/AQP4/AQP6)"];
    VasopressinSyst  [label="Systemic vasopressin\n(ADH) elevation"];
    V2Receptor       [label="V2 receptor\n(sac epithelium, renal\ncollecting duct)"];
    cAMPsac          [label="cAMP-PKA signaling\n(V2-Gs, sac)"];
    NaKATPaseSac     [label="Na+/K+-ATPase\n(sac epithelium)"];
    EndoSacDysfunction -> EndoUnderabs;
    LongitFlowBlock -> EndoUnderabs [style=dashed, label="mechanical\nobstruction"];
    VasopressinSyst -> V2Receptor -> cAMPsac -> AQP2;
    cAMPsac -> AQP3;
    AQP2 -> EndoUnderabs [label="↑ water\nreabsorption\nimpairment"];
    AQP3 -> EndoUnderabs;
    NaKATPaseSac -> EndoUnderabs [style=dashed, label="ion transport\nfailure"];
    CochlearAQP -> EndoOverprod [style=dashed, label="dysregulated\nwater flux"];
  }

  /* ───────────────────────── 3. Stria Vascularis Ion Transport ────────────── */
  subgraph cluster_stria {
    label="3. Stria Vascularis Ion Transport & Endolymph Composition";
    style="filled,rounded"; color="#5c6370"; fillcolor="#e6f7ff"; fontsize=12;
    StriaVascularis  [label="Stria vascularis\n(marginal/intermediate/\nbasal cells)"];
    NaKATPaseStria   [label="Na+/K+-ATPase\n(marginal cell,\nbasolateral)"];
    NKCC1            [label="Na+-K+-2Cl-\ncotransporter (NKCC1)"];
    KCNQ1KCNE1       [label="KCNQ1/KCNE1\nK+ channel (apical)"];
    ConnexinGapJx    [label="Connexin 26/30\ngap junctions\n(K+ recycling)"];
    EndoK            [label="Endolymph [K+]\n(~150 mM normal)"];
    EndoNa           [label="Endolymph [Na+]\n(~1 mM normal)"];
    EndocochlearPot  [label="Endocochlear\npotential (+80 mV)"];
    IonHomeostasis   [label="Endolymph ionic\nhomeostasis"];
    StriaVascularis -> NaKATPaseStria -> IonHomeostasis;
    StriaVascularis -> NKCC1 -> IonHomeostasis;
    KCNQ1KCNE1 -> EndoK;
    ConnexinGapJx -> EndoK [label="K+ recycling\nsupport"];
    IonHomeostasis -> EndoK; IonHomeostasis -> EndoNa;
    EndoK -> EndocochlearPot; EndoNa -> EndocochlearPot [style=dashed];
    EndoSacDysfunction -> IonHomeostasis [style=dashed, label="disrupts\nreabsorption balance"];
  }

  /* ───────────────────────── 4. Endolymphatic Hydrops ─────────────────────── */
  subgraph cluster_hydrops {
    label="4. Endolymphatic Hydrops Formation";
    style="filled,rounded"; color="#5c6370"; fillcolor="#e8f5e9"; fontsize=12;
    HydropsIndex     [label="Endolymphatic hydrops\nindex (HYDROPS, volumetric)"];
    CochlearDuctDist [label="Cochlear duct\n(scala media) distension"];
    SacculeDist      [label="Saccule distension"];
    UtricleDist      [label="Utricle distension\n(less prominent)"];
    ReissnerBulge    [label="Reissner's membrane\nbulging"];
    ReissnerRupture  [label="Reissner's membrane\nmicro-rupture(s)"];
    PerilymphKmix    [label="K+-rich endolymph\nleaks into perilymph"];
    KIntoxication    [label="Perilymph K+\nintoxication of\nhair cells/afferents"];
    MRIhydrops       [label="Gadolinium-enhanced\nMRI hydrops grading\n(Nakashima)"];
    EndoOverprod -> HydropsIndex; EndoUnderabs -> HydropsIndex;
    HydropsIndex -> CochlearDuctDist; HydropsIndex -> SacculeDist; HydropsIndex -> UtricleDist [style=dashed];
    CochlearDuctDist -> ReissnerBulge -> ReissnerRupture [label="acute pressure\nspike"];
    ReissnerRupture -> PerilymphKmix -> KIntoxication;
    HydropsIndex -> MRIhydrops [style=dashed, label="imaging\nbiomarker"];
  }

  /* ───────────────────────── 5. Cochlear Hair Cell & Neural Injury ────────── */
  subgraph cluster_cochlear {
    label="5. Cochlear Hair Cell & Auditory Neural Injury";
    style="filled,rounded"; color="#5c6370"; fillcolor="#fff0f6"; fontsize=12;
    OHCviability     [label="Outer hair cell (OHC)\nviability (COCHOHC)"];
    IHCviability     [label="Inner hair cell (IHC)\nviability (COCHIHC)"];
    StereociliaDmg   [label="Stereocilia bundle\ndamage / fusion"];
    SGNviability     [label="Spiral ganglion neuron\n(SGN) survival"];
    OxidativeStress  [label="Oxidative stress /\nROS accumulation"];
    ApoptosisPathway [label="Caspase-mediated\nhair-cell apoptosis"];
    LowFreqDamage    [label="Low-frequency\n(apical turn) damage\n(early, hydrops-prone)"];
    AllFreqDamage    [label="Pan-frequency\n(basal+apical) damage\n(late-stage)"];
    KIntoxication -> OHCviability [label="ionic injury", color="#c0392b", fontcolor="#c0392b"];
    KIntoxication -> IHCviability [label="ionic injury", color="#c0392b", fontcolor="#c0392b"];
    CochlearDuctDist -> StereociliaDmg [label="mechanical\ndistortion"];
    StereociliaDmg -> OHCviability; StereociliaDmg -> IHCviability;
    OxidativeStress -> ApoptosisPathway; KIntoxication -> OxidativeStress;
    ApoptosisPathway -> OHCviability [label="reduces"]; ApoptosisPathway -> SGNviability [label="reduces"];
    IHCviability -> SGNviability [style=dashed, label="trophic\nsupport loss"];
    LowFreqDamage -> OHCviability [style=dashed]; AllFreqDamage -> OHCviability [style=dashed];
    HydropsIndex -> LowFreqDamage [label="apical-turn\ndistension first"];
  }

  /* ───────────────────────── 6. Vestibular End-Organ Dysfunction ──────────── */
  subgraph cluster_vestibular {
    label="6. Vestibular Hair Cell & End-Organ Dysfunction";
    style="filled,rounded"; color="#5c6370"; fillcolor="#fff9e6"; fontsize=12;
    VestHairCellViab [label="Vestibular hair cell\nviability (type I/II)"];
    SCCFunction      [label="Semicircular canal\n(cupula) function"];
    OtolithFunction  [label="Otolith organ\n(saccule/utricle)\nfunction"];
    VestAfferentDisch[label="Vestibular afferent\ndischarge irregularity"];
    VORIntegrity     [label="Vestibulo-ocular\nreflex (VOR) integrity"];
    Nystagmus        [label="Spontaneous/positional\nnystagmus"];
    CaloricAsymmetry [label="Caloric test\ncanal paresis"];
    vHIT             [label="Video head-impulse\ntest (vHIT) gain\nabnormality"];
    SacculeDist -> VestHairCellViab [label="mechanical/\nionic injury", color="#c0392b", fontcolor="#c0392b"];
    UtricleDist -> VestHairCellViab [style=dashed];
    KIntoxication -> VestHairCellViab [label="ionic injury", color="#c0392b", fontcolor="#c0392b"];
    VestHairCellViab -> SCCFunction; VestHairCellViab -> OtolithFunction;
    SCCFunction -> VestAfferentDisch; OtolithFunction -> VestAfferentDisch;
    VestAfferentDisch -> VORIntegrity [label="disrupts"];
    VORIntegrity -> Nystagmus;
    SCCFunction -> CaloricAsymmetry [style=dashed];
    SCCFunction -> vHIT [style=dashed];
  }

  /* ───────────────────────── 7. Acute Attack Pathophysiology ──────────────── */
  subgraph cluster_attack {
    label="7. Acute Vertigo Attack Pathophysiology";
    style="filled,rounded"; color="#5c6370"; fillcolor="#f0f4ff"; fontsize=12;
    AcutePressureSpike [label="Acute endolymphatic\npressure spike"];
    MembraneRuptureCyc [label="Rupture-repair cycle\n(Reissner's membrane)"];
    AcuteVertigoOnset  [label="Acute rotational\nvertigo onset"];
    VertigoDuration    [label="Attack duration\n(20 min - 12 h,\nAAO-HNS criterion)"];
    AutonomicSx        [label="Autonomic symptoms\n(nausea, vomiting,\ndiaphoresis)"];
    TumarkinDropAttack [label="Tumarkin otolithic\ncrisis (drop attack)"];
    PostAttackFatigue  [label="Post-ictal fatigue/\nimbalance"];
    FallRisk           [label="Fall / injury risk"];
    AcutePressureSpike -> MembraneRuptureCyc; ReissnerRupture -> MembraneRuptureCyc;
    MembraneRuptureCyc -> AcuteVertigoOnset;
    VestAfferentDisch -> AcuteVertigoOnset [label="sudden asymmetric\ndischarge"];
    AcuteVertigoOnset -> VertigoDuration; AcuteVertigoOnset -> AutonomicSx;
    OtolithFunction -> TumarkinDropAttack [label="sudden utricular/\nsaccular dysfunction\n(Minor 1998)", color="#c0392b", fontcolor="#c0392b"];
    TumarkinDropAttack -> FallRisk;
    AcuteVertigoOnset -> PostAttackFatigue;
    VertigoDuration -> FallRisk [style=dashed];
  }

  /* ───────────────────────── 8. Clinical Manifestations & Staging ─────────── */
  subgraph cluster_clinical {
    label="8. Clinical Manifestations, Diagnostic Criteria & Staging";
    style="filled,rounded"; color="#5c6370"; fillcolor="#f5f0ff"; fontsize=12;
    EpisodicVertigo   [label="Episodic vertigo\n(≥2 spells, AAO-HNS 1995/2020 Barany)"];
    FluctuatingSNHL   [label="Fluctuating\nsensorineural hearing\nloss (documented ≥1x)"];
    PTA               [label="Pure-tone average\n(PTA) threshold, dB"];
    LowFreqSNHLPattern[label="Low-frequency-\npredominant SNHL\n(early)"];
    Tinnitus          [label="Tinnitus (roaring/\nlow-pitched, fluctuating)"];
    AuralFullness     [label="Aural fullness /\npressure sensation"];
    AAOHNS1995        [label="AAO-HNS 1995\ndiagnostic criteria\n(certain/definite/probable/possible)"];
    DiseaseStageIIV   [label="AAO-HNS stage I-IV\n(by 4-tone PTA average)"];
    FLS               [label="Functional Level\nScale (FLS 1-6)"];
    BurnoutPhase      [label="'Burned-out' phase\n(attacks cease, fixed\ndeficits remain)"];
    BilateralProgress [label="Bilateral progression\n(~15-50% over years)"];
    OHCviability -> FluctuatingSNHL [label="reduces\n(reversible early)", color="#c0392b", fontcolor="#c0392b"];
    IHCviability -> FluctuatingSNHL [style=dashed];
    FluctuatingSNHL -> PTA; PTA -> LowFreqSNHLPattern [style=dashed];
    PTA -> DiseaseStageIIV;
    OHCviability -> Tinnitus [label="reduces", color="#c0392b", fontcolor="#c0392b"];
    HydropsIndex -> AuralFullness [label="pressure\nsensation"];
    AcuteVertigoOnset -> EpisodicVertigo [label="accumulates"];
    EpisodicVertigo -> AAOHNS1995; FluctuatingSNHL -> AAOHNS1995;
    Tinnitus -> AAOHNS1995 [style=dashed]; AuralFullness -> AAOHNS1995 [style=dashed];
    EpisodicVertigo -> FLS; SGNviability -> BurnoutPhase [style=dashed, label="depletion\nquiets attacks"];
    HydropsIndex -> BurnoutPhase [style=dashed];
    BurnoutPhase -> BilateralProgress [style=dashed];
  }

  /* ───────────────────────── 9. Patient-Reported & Composite Endpoints ────── */
  subgraph cluster_pro {
    label="9. Patient-Reported Outcomes & Composite Endpoints";
    style="filled,rounded"; color="#5c6370"; fillcolor="#eaf7f0"; fontsize=12;
    DHI              [label="Dizziness Handicap\nInventory (DHI, 0-100)"];
    THI              [label="Tinnitus Handicap\nInventory (THI)"];
    QoLGeneric       [label="Health-related\nquality of life (SF-36)"];
    AnxietyDepr      [label="Anxiety / depression\n(unpredictable vertigo)"];
    VertigoFreqMo    [label="Definitive vertigo\nspells per month"];
    ECoGSPAP         [label="Electrocochleography\n(ECoG) SP/AP ratio"];
    GlycerolTest     [label="Glycerol dehydration\ntest (historical)"];
    VEMP             [label="Vestibular evoked\nmyogenic potential\n(cVEMP/oVEMP)"];
    EpisodicVertigo -> VertigoFreqMo;
    VertigoFreqMo -> DHI [label="drives handicap"]; FallRisk -> DHI [style=dashed];
    Tinnitus -> THI;
    HydropsIndex -> ECoGSPAP [label="↑ SP/AP ratio\n(biomarker)"];
    HydropsIndex -> GlycerolTest [style=dashed];
    VestHairCellViab -> VEMP [style=dashed, label="amplitude/\nthreshold change"];
    VertigoFreqMo -> AnxietyDepr [label="unpredictability"];
    DHI -> QoLGeneric; THI -> QoLGeneric [style=dashed]; AnxietyDepr -> QoLGeneric;
    DiseaseStageIIV -> QoLGeneric [style=dashed];
  }

  /* ───────────────────────── 10. Drug PK/PD — Betahistine ─────────────────── */
  subgraph cluster_pk_beta {
    label="10. Drug PK/PD — Betahistine";
    style="filled,rounded"; color="#5c6370"; fillcolor="#e6fff2"; fontsize=12;
    BetahistineOral  [label="Betahistine oral\ndose (16-48mg TID,\nBEMED up to 48mg TID)"];
    BetahistineGut   [label="Betahistine gut\ndepot"];
    BetahistinePlasma[label="Betahistine plasma\nconcentration (rapid\nfirst-pass to metabolite)"];
    AminoethylPyr    [label="Aminoethylpyridine\n(active metabolite)"];
    H1AgonistEffect  [label="Histamine H1\nreceptor agonism\n(vasodilation)"];
    H3AntagEffect    [label="Histamine H3\nautoreceptor antagonism\n(↑ histamine release)"];
    CochlearBF       [label="Cochlear/labyrinthine\nblood flow ↑"];
    VestCompensation [label="Central vestibular\ncompensation (promotes)"];
    BetahistineOral -> BetahistineGut -> BetahistinePlasma -> AminoethylPyr;
    BetahistinePlasma -> H1AgonistEffect; AminoethylPyr -> H3AntagEffect;
    H1AgonistEffect -> CochlearBF [label="microvascular\nvasodilation", color="#c0392b", fontcolor="#c0392b"];
    H3AntagEffect -> VestCompensation [label="↑ histaminergic\ntone in vestibular\nnuclei", color="#c0392b", fontcolor="#c0392b"];
    CochlearBF -> EndoOverprod [style=dashed, label="may reduce\n(perfusion-mediated)", color="#c0392b", fontcolor="#c0392b"];
    VestCompensation -> VertigoFreqMo [label="reduces\n(BEMED high-dose)", color="#c0392b", fontcolor="#c0392b"];
  }

  /* ───────────────────────── 11. Drug PK/PD — Diuretics ───────────────────── */
  subgraph cluster_pk_diur {
    label="11. Drug PK/PD — Diuretics (HCTZ/Triamterene, Acetazolamide)";
    style="filled,rounded"; color="#5c6370"; fillcolor="#fef6e0"; fontsize=12;
    HCTZoral         [label="Hydrochlorothiazide\noral dose (25-50mg/d)"];
    TriamtereneOral  [label="Triamterene oral\ndose (37.5-50mg/d)"];
    AcetazolamideOral[label="Acetazolamide oral\ndose (250-500mg/d)"];
    HCTZplasma       [label="HCTZ plasma\nconcentration"];
    TriamtPlasma     [label="Triamterene plasma\nconcentration"];
    AcetazPlasma     [label="Acetazolamide plasma\nconcentration"];
    NCCblock         [label="Na+/Cl- cotransporter\n(NCC) blockade,\ndistal tubule"];
    ENaCblock        [label="ENaC blockade\n(triamterene,\nK-sparing)"];
    CAinhibition     [label="Carbonic anhydrase\ninhibition (systemic\n+ stria vascularis)"];
    RenalNaLoss      [label="Renal Na+/water\nexcretion ↑"];
    SystemicVolContr [label="Mild systemic\nvolume contraction"];
    StriaCAeffect    [label="Stria vascularis\ncarbonic anhydrase\ninhibition (local)"];
    HCTZoral -> HCTZplasma -> NCCblock -> RenalNaLoss;
    TriamtereneOral -> TriamtPlasma -> ENaCblock; ENaCblock -> RenalNaLoss [style=dashed];
    AcetazolamideOral -> AcetazPlasma -> CAinhibition;
    CAinhibition -> RenalNaLoss [style=dashed]; CAinhibition -> StriaCAeffect;
    RenalNaLoss -> SystemicVolContr;
    SystemicVolContr -> EndoOverprod [label="↓ systemic fluid →\n↓ endolymph production\n(hypothesized)", color="#c0392b", fontcolor="#c0392b"];
    StriaCAeffect -> NaKATPaseStria [label="reduces ion-transport-\ndriven fluid secretion", color="#c0392b", fontcolor="#c0392b"];
  }

  /* ───────────────────────── 12. Drug PK/PD — Intratympanic Dexamethasone ─── */
  subgraph cluster_pk_itds {
    label="12. Drug PK/PD — Intratympanic Dexamethasone";
    style="filled,rounded"; color="#5c6370"; fillcolor="#e6f0ff"; fontsize=12;
    ITDexInjection   [label="Intratympanic\ndexamethasone injection\n(series, weekly x3-4)"];
    MiddleEarDepot   [label="Middle-ear fluid\ndepot"];
    RWMPermeation    [label="Round-window\nmembrane permeation"];
    PerilymphDex     [label="Perilymph\ndexamethasone\nconcentration"];
    GRcomplexInner   [label="Glucocorticoid\nreceptor (GR) complex,\ninner-ear tissue"];
    LocalAntiInflam  [label="Local anti-\ninflammatory /\nanti-edema effect"];
    NaKATPaseUpreg   [label="Na+/K+-ATPase &\nENaC upregulation\n(fluid resorption)"];
    ITDexInjection -> MiddleEarDepot -> RWMPermeation -> PerilymphDex;
    PerilymphDex -> GRcomplexInner -> LocalAntiInflam;
    GRcomplexInner -> NaKATPaseUpreg [label="genomic\nupregulation", color="#c0392b", fontcolor="#c0392b"];
    LocalAntiInflam -> AntiInnerEarAb [style=dashed, label="dampens immune\ninjury", color="#c0392b", fontcolor="#c0392b"];
    NaKATPaseUpreg -> EndoUnderabs [label="improves sac/stria\nfluid resorption", color="#c0392b", fontcolor="#c0392b"];
    LocalAntiInflam -> VestHairCellViab [label="protective", color="#c0392b", fontcolor="#c0392b"];
  }

  /* ───────────────────────── 13. Drug PK/PD — Intratympanic Gentamicin ────── */
  subgraph cluster_pk_itgm {
    label="13. Drug PK/PD — Intratympanic Gentamicin (Chemical Labyrinthectomy)";
    style="filled,rounded"; color="#5c6370"; fillcolor="#ffecec"; fontsize=12;
    ITGentInjection  [label="Intratympanic gentamicin\ninjection (low-dose\ntitration vs fixed high-dose)"];
    GentMiddleEar    [label="Middle-ear gentamicin\ndepot"];
    GentRWMPerm      [label="Round-window\nmembrane permeation"];
    PerilymphGent    [label="Perilymph gentamicin\nconcentration"];
    HairCellUptake   [label="Aminoglycoside uptake\nby vestibular hair\ncells (mechanotransduction\nchannel entry)"];
    MitochondrialTox [label="Mitochondrial /\noxidative ototoxicity"];
    VestAblation     [label="Selective vestibular\nhair-cell ablation\n('chemical labyrinthectomy')"];
    CochleoToxRisk   [label="Cochlear hair-cell\nco-toxicity risk\n(dose-dependent)"];
    TitrationProtocol[label="Low-dose titration\nprotocol (symptom/vHIT-\nguided, monthly)"];
    FixedHighDoseProt[label="Fixed high-dose\nprotocol (multiple\ninjections, destructive)"];
    ITGentInjection -> GentMiddleEar -> GentRWMPerm -> PerilymphGent;
    PerilymphGent -> HairCellUptake -> MitochondrialTox -> VestAblation;
    VestAblation -> VestHairCellViab [label="ablates\n(therapeutic)", color="#c0392b", fontcolor="#c0392b"];
    VestAblation -> VertigoFreqMo [label="abolishes\nattacks", color="#c0392b", fontcolor="#c0392b"];
    PerilymphGent -> CochleoToxRisk [style=dashed];
    CochleoToxRisk -> OHCviability [label="risk of hearing\nloss", color="#c0392b", fontcolor="#c0392b"];
    TitrationProtocol -> ITGentInjection [style=dashed, label="lower cumulative\ndose"];
    FixedHighDoseProt -> ITGentInjection [style=dashed, label="higher cumulative\ndose"];
  }

  /* ───────────────────────── 14. Acute Symptomatic Pharmacotherapy ────────── */
  subgraph cluster_pk_acute {
    label="14. Acute Symptomatic Pharmacotherapy (Vestibular Suppressants/Antiemetics)";
    style="filled,rounded"; color="#5c6370"; fillcolor="#f2f2f2"; fontsize=12;
    MeclizineDose    [label="Meclizine oral\ndose (12.5-25mg)"];
    DiazepamDose     [label="Diazepam/benzodiazepine\ndose (2-5mg)"];
    GABAAeffect      [label="GABA-A receptor\npotentiation (vestibular\nnuclei suppression)"];
    H1blockCentral   [label="Central H1/muscarinic\nblockade (meclizine)"];
    ProchlorperazDose[label="Prochlorperazine\ndose (5-10mg)"];
    OndansetronDose  [label="Ondansetron\ndose (4-8mg)"];
    D2block          [label="Dopamine D2\nreceptor blockade\n(CTZ)"];
    FiveHT3block     [label="5-HT3 receptor\nblockade (CTZ/vagal\nafferents)"];
    MeclizineDose -> H1blockCentral -> VestAfferentDisch [label="suppresses\nacute signal", color="#c0392b", fontcolor="#c0392b"];
    DiazepamDose -> GABAAeffect -> VestAfferentDisch [label="suppresses\nacute signal", color="#c0392b", fontcolor="#c0392b"];
    ProchlorperazDose -> D2block -> AutonomicSx [label="antiemetic", color="#c0392b", fontcolor="#c0392b"];
    OndansetronDose -> FiveHT3block -> AutonomicSx [label="antiemetic", color="#c0392b", fontcolor="#c0392b"];
    GABAAeffect -> VestCompensation [style=dashed, label="chronic use\nimpairs compensation\n(caution)", color="#c0392b", fontcolor="#c0392b"];
  }

  /* ───────────────────────── 15. Surgical / Procedural Therapy ────────────── */
  subgraph cluster_surgical {
    label="15. Surgical & Procedural Therapy";
    style="filled,rounded"; color="#5c6370"; fillcolor="#fff4f0"; fontsize=12;
    EndoSacDecompr   [label="Endolymphatic sac\ndecompression surgery"];
    EndoSacShunt     [label="Endolymphatic\nmastoid shunt"];
    VestNeurectomy   [label="Vestibular nerve\nsection (neurectomy)"];
    Labyrinthectomy  [label="Surgical labyrinthectomy\n(destructive, hearing-\nsacrificing)"];
    MeniettDevice    [label="Meniett low-pressure\npulse device"];
    EndoSacDecompr -> EndoSacDysfunction [label="relieves\nobstruction\n(controversial efficacy)", color="#c0392b", fontcolor="#c0392b"];
    EndoSacShunt -> HydropsIndex [label="diverts\nendolymph", color="#c0392b", fontcolor="#c0392b"];
    VestNeurectomy -> VestAfferentDisch [label="ablates afferent\ninput (hearing-\npreserving)", color="#c0392b", fontcolor="#c0392b"];
    Labyrinthectomy -> VestHairCellViab [label="destroys\n(hearing-sacrificing)", color="#c0392b", fontcolor="#c0392b"];
    Labyrinthectomy -> OHCviability [label="destroys\ncochlea", color="#c0392b", fontcolor="#c0392b"];
    MeniettDevice -> HydropsIndex [style=dashed, label="pressure pulse,\nlow-quality evidence", color="#c0392b", fontcolor="#c0392b"];
  }

  /* ───────────────────────── 16. Investigational Therapy ──────────────────── */
  subgraph cluster_invest {
    label="16. Investigational & Emerging Therapy";
    style="filled,rounded"; color="#5c6370"; fillcolor="#f0eaff"; fontsize=12;
    V2RA             [label="Vasopressin V2-receptor\nantagonist (investigational,\ne.g. tolvaptan-class/PE0139)"];
    V2RABind         [label="V2 receptor\nblockade (sac)"];
    IntratympanicIGF [label="Intratympanic IGF-1\n(investigational,\nhearing preservation)"];
    GeneTherapyHC    [label="Hair-cell regeneration/\ngene therapy\n(preclinical)"];
    AntiHspTherapy   [label="Anti-Hsp70 targeted\nimmunotherapy\n(exploratory)"];
    V2RA -> V2RABind; V2RABind -> V2Receptor [label="competitive\nantagonism", color="#c0392b", fontcolor="#c0392b"];
    V2RABind -> cAMPsac [label="blocks", color="#c0392b", fontcolor="#c0392b"];
    IntratympanicIGF -> OHCviability [style=dashed, label="investigational\nprotection", color="#c0392b", fontcolor="#c0392b"];
    GeneTherapyHC -> OHCviability [style=dashed, label="preclinical\nregeneration", color="#c0392b", fontcolor="#c0392b"];
    AntiHspTherapy -> AntiInnerEarAb [style=dashed, label="targets\nautoimmunity", color="#c0392b", fontcolor="#c0392b"];
  }

  /* ───────────────────────── 17. Systemic & Renal Effects of Therapy ──────── */
  subgraph cluster_systemic {
    label="17. Systemic/Renal Effects & Central Adaptation";
    style="filled,rounded"; color="#5c6370"; fillcolor="#f7f7e8"; fontsize=12;
    RenalKLoss       [label="Renal K+ wasting\n(HCTZ)"];
    Hypokalemia      [label="Hypokalemia risk"];
    RenalKSparing    [label="K+-sparing effect\n(triamterene)"];
    MetabolicAcidosis[label="Metabolic acidosis\n(acetazolamide, CA\ninhibition)"];
    Paresthesia      [label="Paresthesia /\ntaste disturbance\n(acetazolamide)"];
    CentralAdaptation[label="Central vestibular\nadaptation/plasticity\n(cerebellum, vestibular\nnuclei)"];
    PsychComorbidity [label="Psychological\ncomorbidity burden"];
    RenalNaLoss -> RenalKLoss [style=dashed]; RenalKLoss -> Hypokalemia;
    ENaCblock -> RenalKSparing [style=dashed]; RenalKSparing -> Hypokalemia [style=dashed, label="offsets", color="#2e7d32", fontcolor="#2e7d32"];
    CAinhibition -> MetabolicAcidosis; CAinhibition -> Paresthesia [style=dashed];
    VestCompensation -> CentralAdaptation;
    CentralAdaptation -> PostAttackFatigue [style=dashed, label="mitigates\nover time", color="#2e7d32", fontcolor="#2e7d32"];
    AnxietyDepr -> PsychComorbidity; VertigoFreqMo -> PsychComorbidity [style=dashed];
  }

  /* ───────────────────────── 18. Adverse Effects & Safety Monitoring ──────── */
  subgraph cluster_ae {
    label="18. Adverse Effects & Safety Monitoring";
    style="filled,rounded"; color="#5c6370"; fillcolor="#ffe0e0"; fontsize=12;
    GentCumDose      [label="Cumulative\nintratympanic gentamicin\nexposure"];
    IatrogenicHL     [label="Iatrogenic\nsensorineural hearing\nloss (gentamicin AE)"];
    BilateralVestLoss[label="Bilateral vestibular\nloss risk (systemic\naminoglycoside; rare\nIT)"];
    OscillopsiaRisk  [label="Oscillopsia\n(bilateral vestibulopathy)"];
    TympanicPerf     [label="Tympanic membrane\nperforation (injection\nAE)"];
    SteroidLocalAE   [label="Local steroid AE\n(transient vertigo\npost-injection)"];
    SurgicalAE       [label="Surgical complications\n(CSF leak, facial nerve\nrisk - neurectomy)"];
    GentCumDose -> IatrogenicHL [label="dose-dependent", color="#c0392b", fontcolor="#c0392b"];
    GentCumDose -> BilateralVestLoss [style=dashed];
    BilateralVestLoss -> OscillopsiaRisk;
    ITGentInjection -> TympanicPerf [style=dashed];
    ITDexInjection -> SteroidLocalAE [style=dashed];
    VestNeurectomy -> SurgicalAE [style=dashed]; Labyrinthectomy -> SurgicalAE [style=dashed];
    PerilymphGent -> GentCumDose;
  }

  /* ───────────────────────── Cross-cluster master cascade ─────────────────── */
  HydropsIndex -> EpisodicVertigo [label="mechanical/ionic\ndestabilization"];
  HydropsIndex -> AcutePressureSpike;
  VestCompensation -> DHI [label="reduces\nhandicap over time", color="#2e7d32", fontcolor="#2e7d32"];
  OHCviability -> DiseaseStageIIV [style=dashed];
  DiseaseStageIIV -> FLS [style=dashed];
  BetahistineOral -> VertigoFreqMo [style=dashed, label="modest overall\nRCT effect\n(Adrion 2016 BMJ)", color="#c0392b", fontcolor="#c0392b"];
  ECoGSPAP -> AAOHNS1995 [style=dashed, label="supportive\nbiomarker"];
  KIntoxication -> AcuteVertigoOnset [label="acute\ndepolarization block"];
}
