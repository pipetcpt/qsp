digraph UterineLeiomyomaQSP {
    graph [
        label="Uterine Leiomyoma (Fibroid) QSP Model\n자궁근종 정량적 시스템 약리학 모델\nHPG Axis · Steroidogenesis · Fibroid Biology · Drug PK/PD",
        labelloc=t,
        fontsize=22,
        fontname="Helvetica-Bold",
        bgcolor="#FAFAFA",
        splines=ortho,
        nodesep=0.4,
        ranksep=0.7,
        rankdir=TB,
        size="30,22"
    ]
    node [fontname="Helvetica", fontsize=10, style=filled, shape=box, width=1.6, height=0.5]
    edge [fontname="Helvetica", fontsize=9, arrowsize=0.7]

    // =========================================================
    // SUBGRAPH 1: Hypothalamic-Pituitary Axis (HPG)
    // =========================================================
    subgraph cluster_HPG {
        label="Hypothalamic-Pituitary-Gonadal Axis\n시상하부-뇌하수체-생식선 축"
        style=filled
        fillcolor="#E8F4FD"
        color="#2980B9"
        fontcolor="#1A5276"
        fontsize=14
        fontname="Helvetica-Bold"

        Hypothalamus [label="Hypothalamus\n시상하부", fillcolor="#AED6F1", shape=ellipse]
        KNDy_neurons [label="KNDy Neurons\n(Kisspeptin/NKB/\nDynorphin)", fillcolor="#D6EAF8"]
        GnRH_pulse [label="GnRH Pulse Generator\nGnRH 펄스 발생기", fillcolor="#AED6F1"]
        GnRH [label="GnRH\n(Gonadotropin-Releasing\nHormone)", fillcolor="#5DADE2", fontcolor=white]
        GnRH_R [label="GnRH Receptor\n(Pituitary)\nGnRHR", fillcolor="#2E86C1", fontcolor=white]
        Pituitary [label="Anterior Pituitary\n뇌하수체 전엽", fillcolor="#A9CCE3", shape=ellipse]
        LH [label="LH\n(Luteinizing Hormone)", fillcolor="#5DADE2", fontcolor=white]
        FSH [label="FSH\n(Follicle-Stimulating\nHormone)", fillcolor="#5DADE2", fontcolor=white]
        LH_surge [label="LH Surge\n(Ovulation Trigger)\nLH 급증", fillcolor="#85C1E9"]
        pituitary_desensitization [label="Pituitary\nDesensitization\n수용체 하향조절", fillcolor="#D6EAF8"]

        KNDy_neurons -> GnRH_pulse [label="kisspeptin\nstimulation"]
        GnRH_pulse -> GnRH [label="pulsatile\nsecretion"]
        Hypothalamus -> KNDy_neurons [label="neural\ncontrol"]
        GnRH -> GnRH_R [label="binds"]
        GnRH_R -> Pituitary [label="activates"]
        Pituitary -> LH [label="secretes"]
        Pituitary -> FSH [label="secretes"]
        LH -> LH_surge [label="positive\nfeedback\n(preovulatory)"]
        GnRH -> pituitary_desensitization [label="continuous\nexposure →\ndownregulation", style=dashed, color=red]
    }

    // =========================================================
    // SUBGRAPH 2: Ovarian Folliculogenesis & Steroidogenesis
    // =========================================================
    subgraph cluster_Ovary {
        label="Ovarian Biology · 난소 스테로이드 생성"
        style=filled
        fillcolor="#FEF9E7"
        color="#D4AC0D"
        fontcolor="#7D6608"
        fontsize=14
        fontname="Helvetica-Bold"

        Ovary [label="Ovary\n난소", fillcolor="#F9E79F", shape=ellipse]
        Theca_cells [label="Theca Cells\n협막 세포", fillcolor="#F7DC6F"]
        Granulosa_cells [label="Granulosa Cells\n과립막 세포", fillcolor="#F7DC6F"]
        Follicle [label="Antral Follicle\n동난포", fillcolor="#FCF3CF"]
        Corpus_luteum [label="Corpus Luteum\n황체", fillcolor="#F0B27A"]
        Cholesterol [label="Cholesterol\n콜레스테롤", fillcolor="#FAD7A0"]
        Pregnenolone [label="Pregnenolone\n프레그네놀론", fillcolor="#EDBB99"]
        Progesterone [label="Progesterone (P4)\n프로게스테론", fillcolor="#E59866", fontcolor=white]
        Androstenedione [label="Androstenedione\n안드로스텐디온", fillcolor="#EDBB99"]
        Testosterone [label="Testosterone\n테스토스테론", fillcolor="#E59866", fontcolor=white]
        Estradiol [label="Estradiol (E2)\n에스트라디올", fillcolor="#E74C3C", fontcolor=white]
        Estrone [label="Estrone (E1)\n에스트론", fillcolor="#E8DAEF"]
        SHBG [label="SHBG\n성호르몬결합글로불린", fillcolor="#FAD7A0"]
        inhibin_B [label="Inhibin B\n인히빈 B", fillcolor="#FDEBD0"]
        inhibin_A [label="Inhibin A\n인히빈 A", fillcolor="#FDEBD0"]
        AMH [label="AMH\n(Anti-Müllerian\nHormone)", fillcolor="#FCF3CF"]

        LH -> Theca_cells [label="LH-R\nstimulation"]
        FSH -> Granulosa_cells [label="FSH-R\nstimulation"]
        Theca_cells -> Cholesterol [label="uptake\n& mobilization"]
        Cholesterol -> Pregnenolone [label="StAR/CYP11A1"]
        Pregnenolone -> Progesterone [label="3β-HSD"]
        Pregnenolone -> Androstenedione [label="CYP17A1"]
        Progesterone -> Androstenedione [label="CYP17A1\n17α-hydroxylase"]
        Androstenedione -> Testosterone [label="17β-HSD"]
        Testosterone -> Estradiol [label="CYP19A1\n(Aromatase)"]
        Androstenedione -> Estrone [label="CYP19A1\n(Aromatase)"]
        Estrone -> Estradiol [label="17β-HSD"]
        Estradiol -> SHBG [label="binding\n(~60%)"]
        Granulosa_cells -> inhibin_B [label="secretes"]
        Corpus_luteum -> inhibin_A [label="secretes"]
        Granulosa_cells -> AMH [label="secretes"]
        Follicle -> Granulosa_cells [label="contains"]
        Follicle -> Theca_cells [label="contains"]
        LH_surge -> Corpus_luteum [label="triggers\novulation &\nluteogenesis"]
        Corpus_luteum -> Progesterone [label="main source\n(luteal phase)"]
        Corpus_luteum -> Estradiol [label="secretes"]
        Ovary -> Follicle [label="contains"]
    }

    // =========================================================
    // SUBGRAPH 3: Feedback Loops
    // =========================================================
    subgraph cluster_Feedback {
        label="Hormonal Feedback · 호르몬 피드백"
        style=filled
        fillcolor="#E8F8F5"
        color="#1E8449"
        fontcolor="#145A32"
        fontsize=14
        fontname="Helvetica-Bold"

        neg_E2_LH [label="E2 Negative\nFeedback on LH\n(Follicular Phase)", fillcolor="#ABEBC6"]
        pos_E2_LH [label="E2 Positive\nFeedback on LH\n(Preovulatory Surge)", fillcolor="#58D68D"]
        P4_neg_GnRH [label="P4 Negative\nFeedback on GnRH\n(Luteal Phase)", fillcolor="#ABEBC6"]
        inhibin_neg_FSH [label="Inhibin Negative\nFeedback on FSH", fillcolor="#D5F5E3"]

        Estradiol -> neg_E2_LH [label="low E2\nsuppresses"]
        Estradiol -> pos_E2_LH [label="high E2\nstimulates"]
        neg_E2_LH -> LH [label="↓LH pulse\namplitude"]
        pos_E2_LH -> LH_surge [label="↑LH surge"]
        Progesterone -> P4_neg_GnRH [label="suppresses"]
        P4_neg_GnRH -> GnRH_pulse [label="↓pulse\nfrequency"]
        inhibin_A -> inhibin_neg_FSH [label="selective\nFSH suppression"]
        inhibin_B -> inhibin_neg_FSH [label="selective\nFSH suppression"]
        inhibin_neg_FSH -> FSH [label="↓FSH\nsecretion"]
    }

    // =========================================================
    // SUBGRAPH 4: Uterine Biology
    // =========================================================
    subgraph cluster_Uterus {
        label="Uterine Biology · 자궁 생물학"
        style=filled
        fillcolor="#F9F0FF"
        color="#7D3C98"
        fontcolor="#4A235A"
        fontsize=14
        fontname="Helvetica-Bold"

        Uterus [label="Uterus\n자궁", fillcolor="#D7BDE2", shape=ellipse]
        Myometrium [label="Myometrium\n자궁근층", fillcolor="#C39BD3"]
        Endometrium [label="Endometrium\n자궁내막", fillcolor="#C39BD3"]
        Uterine_artery [label="Uterine Artery\n자궁동맥", fillcolor="#D2B4DE"]
        ER_alpha [label="ERα\n(Estrogen Receptor α)\n자궁 내 ER알파", fillcolor="#A569BD", fontcolor=white]
        ER_beta [label="ERβ\n(Estrogen Receptor β)", fillcolor="#9B59B6", fontcolor=white]
        PR_A [label="PR-A\n(Progesterone\nReceptor A)", fillcolor="#A569BD", fontcolor=white]
        PR_B [label="PR-B\n(Progesterone\nReceptor B)", fillcolor="#9B59B6", fontcolor=white]
        VEGF_uterus [label="VEGF\n(Angiogenesis)", fillcolor="#D2B4DE"]
        uterine_contraction [label="Uterine\nContraction\n자궁 수축", fillcolor="#C39BD3"]
        menstruation [label="Menstruation\n월경", fillcolor="#E8DAEF"]
        MBL [label="Menstrual Blood Loss\n(MBL) 월경혈량", fillcolor="#E8DAEF"]

        Uterus -> Myometrium [label="contains"]
        Uterus -> Endometrium [label="contains"]
        Uterus -> Uterine_artery [label="vascularized by"]
        Estradiol -> ER_alpha [label="binds\n(high affinity)"]
        Estradiol -> ER_beta [label="binds"]
        Progesterone -> PR_A [label="binds"]
        Progesterone -> PR_B [label="binds"]
        ER_alpha -> Myometrium [label="proliferative\nsignaling"]
        ER_alpha -> Endometrium [label="proliferative\nsignaling"]
        VEGF_uterus -> Uterine_artery [label="angiogenesis"]
        Estradiol -> VEGF_uterus [label="upregulates"]
        Myometrium -> uterine_contraction [label="smooth\nmuscle"]
        uterine_contraction -> menstruation [label="expulsion of\nendometrium"]
        menstruation -> MBL [label="quantified as"]
    }

    // =========================================================
    // SUBGRAPH 5: Leiomyoma Pathogenesis
    // =========================================================
    subgraph cluster_Fibroid {
        label="Leiomyoma Pathogenesis · 자궁근종 발병기전"
        style=filled
        fillcolor="#FDEDEC"
        color="#C0392B"
        fontcolor="#7B241C"
        fontsize=14
        fontname="Helvetica-Bold"

        Fibroid [label="Uterine Fibroid\n(Leiomyoma)\n자궁근종", fillcolor="#E74C3C", fontcolor=white, shape=ellipse]
        fibroid_volume [label="Fibroid Volume\n근종 용적 (cm³)", fillcolor="#F1948A"]
        HMGA2 [label="HMGA2\n(Oncofetal Protein)\nChromosome 12q15", fillcolor="#F1948A"]
        MED12 [label="MED12 Mutation\n(70% of fibroids)", fillcolor="#F1948A"]
        fibroid_ER [label="ERα Overexpression\n근종 내 ER알파 과발현", fillcolor="#E74C3C", fontcolor=white]
        fibroid_PR [label="PR Overexpression\n근종 내 PR 과발현", fillcolor="#E74C3C", fontcolor=white]
        fibroid_aromatase [label="Aromatase (CYP19A1)\n근종 내 아로마타제\n(local E2 production)", fillcolor="#F1948A"]
        fibroid_proliferation [label="Myofibroblast\nProliferation\n근종 세포 증식", fillcolor="#F1948A"]
        fibroid_apoptosis [label="Reduced\nApoptosis\n세포사멸 감소", fillcolor="#E74C3C", fontcolor=white]
        ECM_fibroid [label="ECM Accumulation\n(Collagen I/III/IV)\n세포외기질 축적", fillcolor="#F1948A"]
        fibroid_IGF [label="IGF-1/IGF-2\n인슐린 유사성장인자", fillcolor="#FADBD8"]
        fibroid_EGF [label="EGF/TGF-α\n표피성장인자", fillcolor="#FADBD8"]
        fibroid_TGFb [label="TGF-β1/β3\n섬유화 촉진 인자", fillcolor="#E8DAEF"]
        fibroid_bFGF [label="bFGF (FGF2)\n기본 섬유아세포\n성장인자", fillcolor="#FADBD8"]
        fibroid_VEGF [label="VEGF\n(Neovascularization\nin Fibroid)", fillcolor="#FADBD8"]
        fibroid_compression [label="Myometrium\nCompression\n자궁근층 압박", fillcolor="#FDFEFE"]

        Fibroid -> fibroid_volume [label="measurable\nendpoint"]
        Fibroid -> fibroid_ER [label="overexpresses"]
        Fibroid -> fibroid_PR [label="overexpresses"]
        Fibroid -> fibroid_aromatase [label="local\naromatase"]
        Estradiol -> fibroid_ER [label="binds →\nproliferation"]
        fibroid_aromatase -> Estradiol [label="local E2\nproduction"]
        Progesterone -> fibroid_PR [label="binds →\nECM & growth"]
        fibroid_ER -> fibroid_proliferation [label="↑cell cycle\nG0→G1→S"]
        fibroid_PR -> ECM_fibroid [label="↑collagen\ndeposition"]
        fibroid_PR -> fibroid_IGF [label="upregulates"]
        HMGA2 -> fibroid_proliferation [label="chromatin\nremodeling"]
        MED12 -> fibroid_proliferation [label="transcription\ncoactivation"]
        fibroid_IGF -> fibroid_proliferation [label="mitogenic\nsignaling"]
        fibroid_EGF -> fibroid_proliferation [label="mitogenic\nsignaling"]
        fibroid_TGFb -> ECM_fibroid [label="↑fibrosis"]
        fibroid_bFGF -> fibroid_VEGF [label="upregulates"]
        fibroid_VEGF -> Fibroid [label="neovascularization\nsupports growth"]
        fibroid_proliferation -> Fibroid [label="net growth"]
        fibroid_apoptosis -> Fibroid [label="reduced\ncell death"]
        ECM_fibroid -> Fibroid [label="stiffens &\nenlages"]
        Fibroid -> fibroid_compression [label="mechanical\neffect"]
        fibroid_compression -> MBL [label="↑uterine\nbleeding\n(AUB)"]
        fibroid_volume -> fibroid_compression [label="size\ncorrelates"]
    }

    // =========================================================
    // SUBGRAPH 6: Intracellular Signaling Pathways
    // =========================================================
    subgraph cluster_Signaling {
        label="Intracellular Signaling · 세포 내 신호전달"
        style=filled
        fillcolor="#EBF5FB"
        color="#1F618D"
        fontcolor="#154360"
        fontsize=14
        fontname="Helvetica-Bold"

        MAPK_ERK [label="MAPK/ERK Pathway\n세포 증식 조절", fillcolor="#AED6F1"]
        PI3K_AKT [label="PI3K/AKT/mTOR\n세포 생존 경로", fillcolor="#AED6F1"]
        Wnt_beta_cat [label="Wnt/β-catenin\nPathway", fillcolor="#AED6F1"]
        JAK_STAT [label="JAK-STAT3\n(IL-6 signaling)", fillcolor="#AED6F1"]
        NF_kB [label="NF-κB\n(Inflammatory\nSignaling)", fillcolor="#85C1E9"]
        Cyclin_D1 [label="Cyclin D1\n(G1/S checkpoint)", fillcolor="#D6EAF8"]
        p53 [label="p53\n(Tumor Suppressor)", fillcolor="#D6EAF8"]
        Bcl2 [label="Bcl-2\n(Anti-apoptotic)", fillcolor="#D6EAF8"]
        caspase [label="Caspase-3/7\n(Pro-apoptotic)", fillcolor="#D6EAF8"]
        ER_genomic [label="ERα Genomic\nSignaling (ERE\ntranscription)", fillcolor="#AED6F1"]
        ER_nongenomic [label="ERα Non-genomic\nSignaling (EGFR\ntransactivation)", fillcolor="#AED6F1"]
        mTOR_S6K [label="mTOR/S6K1\n(Translation &\nGrowth)", fillcolor="#D6EAF8"]

        fibroid_ER -> ER_genomic [label="nuclear\ntranslocation"]
        fibroid_ER -> ER_nongenomic [label="membrane\nER"]
        ER_genomic -> Cyclin_D1 [label="transcribes"]
        ER_genomic -> Bcl2 [label="upregulates"]
        ER_nongenomic -> MAPK_ERK [label="activates"]
        MAPK_ERK -> Cyclin_D1 [label="promotes"]
        PI3K_AKT -> mTOR_S6K [label="activates"]
        mTOR_S6K -> fibroid_proliferation [label="↑protein\nsynthesis"]
        fibroid_IGF -> PI3K_AKT [label="IGF-1R\nactivation"]
        fibroid_EGF -> MAPK_ERK [label="EGFR\nactivation"]
        Wnt_beta_cat -> Cyclin_D1 [label="TCF/LEF\ntranscription"]
        NF_kB -> fibroid_TGFb [label="upregulates\nvia IL-1/TNF"]
        JAK_STAT -> fibroid_proliferation [label="STAT3\nactivation"]
        Bcl2 -> fibroid_apoptosis [label="inhibits\napoptosis"]
        Bcl2 -> caspase [label="inhibits"]
        p53 -> caspase [label="activates"]
        Cyclin_D1 -> fibroid_proliferation [label="cell cycle\nprogression"]
    }

    // =========================================================
    // SUBGRAPH 7: ECM Remodeling & Fibrosis
    // =========================================================
    subgraph cluster_ECM {
        label="ECM Remodeling & Fibrosis · 세포외기질 재형성"
        style=filled
        fillcolor="#F0FFF0"
        color="#27AE60"
        fontcolor="#1D6A39"
        fontsize=14
        fontname="Helvetica-Bold"

        Collagen_I [label="Collagen Type I\n제1형 콜라겐\n(Structural)", fillcolor="#A9DFBF"]
        Collagen_III [label="Collagen Type III\n제3형 콜라겐", fillcolor="#A9DFBF"]
        Fibronectin [label="Fibronectin\n피브로넥틴", fillcolor="#ABEBC6"]
        MMP_1 [label="MMP-1\n(Collagenase)\n기질금속단백분해효소", fillcolor="#82E0AA"]
        MMP_2 [label="MMP-2\n(Gelatinase A)", fillcolor="#82E0AA"]
        MMP_9 [label="MMP-9\n(Gelatinase B)", fillcolor="#82E0AA"]
        TIMP_1 [label="TIMP-1\n(Tissue Inhibitor\nof MMP)", fillcolor="#D5F5E3"]
        TIMP_2 [label="TIMP-2\n(Tissue Inhibitor\nof MMP)", fillcolor="#D5F5E3"]
        fibroid_stiffness [label="Fibroid Tissue\nStiffness\n근종 조직 경도", fillcolor="#ABEBC6"]
        LOX [label="Lysyl Oxidase\n(LOX)\n콜라겐 가교결합", fillcolor="#A9DFBF"]
        Hyaluronan [label="Hyaluronan\n히알루론산", fillcolor="#D5F5E3"]

        ECM_fibroid -> Collagen_I [label="main\ncomponent"]
        ECM_fibroid -> Collagen_III [label="component"]
        ECM_fibroid -> Fibronectin [label="component"]
        fibroid_TGFb -> Collagen_I [label="↑synthesis"]
        fibroid_TGFb -> TIMP_1 [label="↑expression"]
        fibroid_TGFb -> TIMP_2 [label="↑expression"]
        TIMP_1 -> MMP_1 [label="inhibits\ndegradation"]
        TIMP_2 -> MMP_2 [label="inhibits\ndegradation"]
        MMP_1 -> Collagen_I [label="degrades"]
        MMP_2 -> Collagen_III [label="degrades"]
        MMP_9 -> Fibronectin [label="degrades"]
        LOX -> Collagen_I [label="crosslinks\n→ stiffness"]
        Collagen_I -> fibroid_stiffness [label="major\ncontributor"]
        Hyaluronan -> ECM_fibroid [label="hydration\n& signaling"]
        fibroid_stiffness -> fibroid_volume [label="mechanical\nenlargement"]
    }

    // =========================================================
    // SUBGRAPH 8: Inflammation & Immune Microenvironment
    // =========================================================
    subgraph cluster_Inflammation {
        label="Inflammation & Immune Microenvironment · 염증 및 면역 미세환경"
        style=filled
        fillcolor="#FFF5E4"
        color="#E67E22"
        fontcolor="#784212"
        fontsize=14
        fontname="Helvetica-Bold"

        macrophages_fibroid [label="Tumor-Associated\nMacrophages (M2)\n섬유종 내 대식세포", fillcolor="#FAD7A0"]
        mast_cells [label="Mast Cells\n비만 세포", fillcolor="#FAD7A0"]
        IL_1_beta [label="IL-1β\n인터루킨-1β", fillcolor="#F0B27A"]
        IL_6 [label="IL-6\n인터루킨-6", fillcolor="#F0B27A"]
        IL_8 [label="IL-8 (CXCL8)\n인터루킨-8", fillcolor="#F0B27A"]
        IL_13 [label="IL-13\n인터루킨-13\n(M2 polarization)", fillcolor="#F0B27A"]
        TNF_alpha [label="TNF-α\n종양괴사인자", fillcolor="#E59866"]
        PGE2 [label="PGE2\n프로스타글란딘E2", fillcolor="#FAD7A0"]
        COX2 [label="COX-2\n(Prostaglandin\nSynthase)", fillcolor="#E59866"]
        LTB4 [label="LTB4\n(Leukotriene B4)", fillcolor="#FDEBD0"]
        fibroid_pain [label="Pelvic Pain\n골반통", fillcolor="#FAD7A0"]
        platelet_agg [label="Platelet Aggregation\n혈소판 응집 (AUB)", fillcolor="#FDEBD0"]

        macrophages_fibroid -> IL_13 [label="secretes"]
        macrophages_fibroid -> TGF_label [label="M2 → TGFβ\nsecretion"]
        mast_cells -> IL_1_beta [label="releases"]
        mast_cells -> LTB4 [label="releases"]
        IL_1_beta -> COX2 [label="induces"]
        TNF_alpha -> COX2 [label="induces"]
        TNF_alpha -> NF_kB [label="activates"]
        COX2 -> PGE2 [label="synthesizes"]
        PGE2 -> fibroid_aromatase [label="↑aromatase\nexpression\n(positive loop)"]
        PGE2 -> fibroid_pain [label="sensitizes\nnociceptors"]
        PGE2 -> platelet_agg [label="inhibits\n→ prolonged\nbleeding"]
        IL_6 -> JAK_STAT [label="activates"]
        IL_8 -> fibroid_VEGF [label="co-stimulates\nangiogenesis"]
        fibroid_compression -> fibroid_pain [label="mechanical\nnociception"]
        MBL -> platelet_agg [label="excessive\nbleeding"]
    }
    TGF_label [label="TGF-β\n섬유화 주요 인자", fillcolor="#F0B27A"]

    // =========================================================
    // SUBGRAPH 9: Drug PK — GnRH Agonists
    // =========================================================
    subgraph cluster_GnRHAg_PK {
        label="Drug PK: GnRH Agonists · GnRH 작용제 약동학"
        style=filled
        fillcolor="#E8DAEF"
        color="#6C3483"
        fontcolor="#4A235A"
        fontsize=14
        fontname="Helvetica-Bold"

        Leuprolide_depot [label="Leuprolide Acetate\n(Depot 3.75/11.25mg)\n류프로라이드 데포", fillcolor="#C39BD3"]
        Nafarelin_nasal [label="Nafarelin\n(Intranasal)\n나파렐린 비강 스프레이", fillcolor="#D2B4DE"]
        GnRHAg_Cmax [label="GnRH Agonist\nCmax (plasma)\n최고 혈중 농도", fillcolor="#BB8FCE"]
        GnRHAg_trough [label="GnRH Agonist\nTrough Level\n최저 농도", fillcolor="#BB8FCE"]
        GnRHAg_flare [label="Initial Flare Effect\n(1-2 weeks)\n초기 자극 효과", fillcolor="#A569BD", fontcolor=white]
