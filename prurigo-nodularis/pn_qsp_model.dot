digraph PN_QSP_Model {

    graph [
        label="Prurigo Nodularis (PN) QSP Mechanistic Map\nNeuroimmune Pathophysiology · Type 2 Inflammation · Drug PK/PD",
        fontsize=20,
        fontname="Helvetica",
        rankdir=TB,
        splines=true,
        nodesep=0.35,
        ranksep=0.8,
        bgcolor="#fafafa",
        compound=true
    ]

    node [
        fontname="Helvetica",
        fontsize=9,
        style=filled,
        shape=box,
        margin="0.07,0.03"
    ]

    edge [
        fontname="Helvetica",
        fontsize=8,
        arrowsize=0.55
    ]

    // ====================================================================
    // CLUSTER 1: Environmental Triggers & Skin Barrier
    // ====================================================================
    subgraph cluster_barrier {
        label="Skin Barrier & Environmental Triggers"
        style=filled
        fillcolor="#fff7ed"
        color="#c2410c"
        fontsize=13
        fontcolor="#c2410c"

        mechanical_scratch [label="Mechanical Scratch\n(Itch-scratch cycle)", fillcolor="#fed7aa"]
        barrier_defect     [label="Skin Barrier Defect\n(FLG mutation, TEWL↑)", fillcolor="#fdba74"]
        allergen           [label="Allergen / Irritant\nExposure", fillcolor="#fb923c"]
        pathogen           [label="Microbial Colonization\n(S.aureus, biofilm)", fillcolor="#f97316"]
        UV_stimulus        [label="UV Radiation\n(Koebner in PN)", fillcolor="#ea580c"]
        trauma             [label="Trauma / Neurogenic\nSensitization", fillcolor="#c2410c", fontcolor="white"]
        epidermal_disruption [label="Epidermal Disruption\n& Inflammation", fillcolor="#fbbf24"]
        TSLP               [label="TSLP\n(barrier-derived)", fillcolor="#fde68a"]
        IL33_epi           [label="IL-33\n(alarmin)", fillcolor="#fde68a"]
        IL25_epi           [label="IL-25 (IL-17E)\n(alarmin)", fillcolor="#fde68a"]
    }

    // ====================================================================
    // CLUSTER 2: Innate Immune Cells (Mast Cells, ILC2, Eosinophils)
    // ====================================================================
    subgraph cluster_innate {
        label="Innate Immune Response"
        style=filled
        fillcolor="#fef3c7"
        color="#d97706"
        fontsize=13
        fontcolor="#d97706"

        mast_cell      [label="Mast Cell\n(activated)", fillcolor="#fcd34d"]
        mast_deg       [label="Mast Cell\nDegranulation", fillcolor="#fbbf24"]
        histamine      [label="Histamine\n(H1R itch)", fillcolor="#f59e0b"]
        tryptase       [label="Tryptase\n(PAR-2 activation)", fillcolor="#d97706"]
        IL4_mc         [label="IL-4 (mast cell)", fillcolor="#fde68a"]
        IL13_mc        [label="IL-13 (mast cell)", fillcolor="#fde68a"]
        SCF            [label="SCF / c-Kit\n(mast cell survival)", fillcolor="#fcd34d"]

        ILC2           [label="ILC2\n(type 2 innate lymphoid)", fillcolor="#fcd34d"]
        IL5_ilc2       [label="IL-5 (ILC2)\nEosinophil driver", fillcolor="#fde68a"]
        IL13_ilc2      [label="IL-13 (ILC2)", fillcolor="#fde68a"]
        amphiregulin   [label="Amphiregulin\n(ILC2, tissue repair)", fillcolor="#fcd34d"]

        eosinophil     [label="Eosinophil\n(tissue-resident)", fillcolor="#fbbf24"]
        ECP            [label="Eosinophil Cationic\nProtein (ECP)", fillcolor="#f59e0b"]
        MBP_eo         [label="Major Basic Protein\n(MBP, neurotoxic)", fillcolor="#d97706"]
        IL5_eo         [label="IL-5\n(eosinophil survival)", fillcolor="#fde68a"]

        NK_innate      [label="NK Cell\n(IFN-γ producer)", fillcolor="#fcd34d"]
        neutrophil     [label="Neutrophil\n(early response)", fillcolor="#fbbf24"]
        basophil       [label="Basophil\n(IL-4 early source)", fillcolor="#fcd34d"]
    }

    // ====================================================================
    // CLUSTER 3: Adaptive Immune Response (T cells, B cells, IgE)
    // ====================================================================
    subgraph cluster_adaptive {
        label="Adaptive Immune Response (Type 2 Dominant)"
        style=filled
        fillcolor="#fce7f3"
        color="#9d174d"
        fontsize=13
        fontcolor="#9d174d"

        naive_Tcell    [label="Naive CD4+ T Cell", fillcolor="#fbcfe8"]
        APC_DC         [label="Dendritic Cell (DC)\nAPC", fillcolor="#f9a8d4"]
        Th2            [label="Th2 Cell\n(IL-4, IL-13, IL-5)", fillcolor="#f472b6", fontcolor="white"]
        Th1_cell       [label="Th1 Cell\n(IFN-γ, TNF)\n(minority)", fillcolor="#e879f9"]
        Th22           [label="Th22 Cell\n(IL-22 producer)", fillcolor="#f472b6", fontcolor="white"]
        Th17_cell      [label="Th17 Cell\n(IL-17A)\n(subset)", fillcolor="#d946ef", fontcolor="white"]
        Treg_PN        [label="Treg\n(FoxP3+, dysfunct.)", fillcolor="#c4b5fd"]
        CD8_TC         [label="CD8+ T Cell\n(cytotoxic)", fillcolor="#a78bfa"]

        Bcell_PN       [label="B Cell\n(naive)", fillcolor="#c4b5fd"]
        plasma_IgE     [label="IgE-Producing\nPlasma Cell", fillcolor="#8b5cf6", fontcolor="white"]
        IgE_total      [label="Total IgE\n(serum, often >2000 kIU/L)", fillcolor="#7c3aed", fontcolor="white"]
        FcεRI          [label="FcεRI\n(high-affinity IgE receptor)", fillcolor="#6d28d9", fontcolor="white", shape=diamond]
        IgE_specific   [label="Allergen-Specific\nIgE", fillcolor="#5b21b6", fontcolor="white"]

        IL4_T2         [label="IL-4 (Th2)\nClass switch to IgE", fillcolor="#fde68a"]
        IL13_T2        [label="IL-13 (Th2)\nBarrier dysreg.", fillcolor="#fde68a"]
        IL5_T2         [label="IL-5 (Th2)\nEosinophil survival", fillcolor="#fde68a"]
        IL31_T2        [label="IL-31 (Th2)\nMAJOR ITCH mediator", fillcolor="#f97316"]
        IL22_T2        [label="IL-22 (Th22)\nAcanthosis", fillcolor="#fde68a"]
        IL17_T2        [label="IL-17A (Th17)\nNeutrophil recruit.", fillcolor="#fde68a"]
        TSLP_T2        [label="TSLP (Th2 promoter)\n→ ILC2 activation", fillcolor="#fde68a"]
        OX40L          [label="OX40L/OX40\n(T cell costimul.)", fillcolor="#fbcfe8", shape=diamond]
        CRTH2          [label="CRTH2 (PGD2R)\n(Th2/ILC2 receptor)", fillcolor="#fbcfe8", shape=diamond]
    }

    // ====================================================================
    // CLUSTER 4: Keratinocytes & Epidermis
    // ====================================================================
    subgraph cluster_kera {
        label="Keratinocytes & Epidermal Remodeling"
        style=filled
        fillcolor="#f0fdf4"
        color="#14532d"
        fontsize=13
        fontcolor="#14532d"

        keratinocyte   [label="Keratinocyte\n(basal/suprabasal)", fillcolor="#bbf7d0"]
        epidermal_hyp  [label="Epidermal Hyperplasia\n(acanthosis, rete ridges)", fillcolor="#86efac"]
        hyperkeratosis [label="Hyperkeratosis /\nParakeratosis", fillcolor="#4ade80"]
        filaggrin      [label="Filaggrin (FLG)\nDeficiency", fillcolor="#fca5a5"]
        Cx26_43        [label="Connexin 26/43\n(gap junctions, itch propag.)", fillcolor="#6ee7b7", shape=diamond]
        CCL17          [label="CCL17 / TARC\n(T cell chemoattractant)", fillcolor="#bbf7d0"]
        CCL22          [label="CCL22\n(Th2 recruitment)", fillcolor="#bbf7d0"]
        CXCL10         [label="CXCL10 / IP-10\n(Th1 minor)", fillcolor="#6ee7b7"]
        TSLP_kera      [label="TSLP (keratinocyte)\nSkin-derived", fillcolor="#fde68a"]
        IL33_kera      [label="IL-33 (keratinocyte)\nAlarmin", fillcolor="#fde68a"]
        CCL11_eotaxin  [label="CCL11 / Eotaxin-1\n(eosinophil chemoattr.)", fillcolor="#bbf7d0"]
        MMP1_kera      [label="MMP-1 / Collagenase\n(ECM remodeling)", fillcolor="#fca5a5"]
        Sema3A_kera    [label="Semaphorin 3A\n(axon guidance keratinocyte)", fillcolor="#fca5a5"]
        NGF_kera       [label="NGF\n(nerve growth factor)\nKeratinocyte-derived", fillcolor="#bbf7d0"]
    }

    // ====================================================================
    // CLUSTER 5: Sensory Neurons & Itch Pathways
    // ====================================================================
    subgraph cluster_neuron {
        label="Sensory Neuron & Itch (Pruritus) Pathways"
        style=filled
        fillcolor="#eff6ff"
        color="#1e40af"
        fontsize=13
        fontcolor="#1e40af"

        sensory_neuron [label="C-Fiber / Aδ\nSensory Neuron", fillcolor="#bfdbfe"]
        DRG            [label="Dorsal Root\nGanglion (DRG)", fillcolor="#93c5fd"]
        spinal_cord_PN [label="Spinal Cord\nDorsal Horn", fillcolor="#60a5fa"]
        supraspinal    [label="Supraspinal\nItch Processing\n(thalamus, cortex)", fillcolor="#3b82f6", fontcolor="white"]

        IL31RA         [label="IL-31RA / OSMR\n(sensory neuron receptor)", fillcolor="#93c5fd", shape=diamond]
        TrkA           [label="TrkA\n(NGF receptor)", fillcolor="#93c5fd", shape=diamond]
        PAR2           [label="PAR-2\n(tryptase/kallikrein)", fillcolor="#93c5fd", shape=diamond]
        TRPV1          [label="TRPV1\n(capsaicin/heat)", fillcolor="#60a5fa", shape=diamond]
        TRPA1          [label="TRPA1\n(reactive compounds)", fillcolor="#60a5fa", shape=diamond]
        H1R_neuron     [label="H1 Receptor\n(histamine)", fillcolor="#93c5fd", shape=diamond]

        SP             [label="Substance P (SP)\nNeuropeptide", fillcolor="#bfdbfe"]
        CGRP           [label="CGRP\nNeuropeptide", fillcolor="#bfdbfe"]
        Pruritogen     [label="Pruritogen Signaling\nGARP / GRP", fillcolor="#93c5fd"]
        nerve_sprout   [label="Nerve Fiber\nSprouting ↑ (PN)", fillcolor="#60a5fa"]
        neurogenic_inf [label="Neurogenic\nInflammation", fillcolor="#3b82f6", fontcolor="white"]
        central_sens   [label="Central Sensitization\n(wind-up)", fillcolor="#1d4ed8", fontcolor="white"]
        mu_opioid      [label="μ-Opioid Receptor\n(analgesia/itch modulation)", fillcolor="#bfdbfe", shape=diamond]
        kappa_opioid   [label="κ-Opioid Receptor\n(anti-itch)", fillcolor="#bfdbfe", shape=diamond]
        JAK1_neuron    [label="JAK1 Signaling\n(neuronal IL-31 signal)", fillcolor="#60a5fa", shape=diamond]
    }

    // ====================================================================
    // CLUSTER 6: Dermal Remodeling & Fibrosis
    // ====================================================================
    subgraph cluster_dermal {
        label="Dermal Remodeling, Fibrosis & Nodule Formation"
        style=filled
        fillcolor="#f5f3ff"
        color="#4c1d95"
        fontsize=13
        fontcolor="#4c1d95"

        fibroblast     [label="Dermal Fibroblast\n(activated)", fillcolor="#ede9fe"]
        fibro_act      [label="Fibroblast Activation\n(TGF-β, IL-13 driven)", fillcolor="#ddd6fe"]
        TGFb1          [label="TGF-β1\n(fibrosis driver)", fillcolor="#c4b5fd"]
        collagen_1_3   [label="Collagen I & III\n(ECM↑, nodule fibrosis)", fillcolor="#a78bfa"]
        myo_fibro      [label="Myofibroblast\n(α-SMA+)", fillcolor="#8b5cf6", fontcolor="white"]
        ECM_remodel    [label="ECM Remodeling\n(MMP/TIMP imbalance)", fillcolor="#7c3aed", fontcolor="white"]
        nodule_form    [label="Nodule Formation\n(hallmark of PN)", fillcolor="#6d28d9", fontcolor="white"]
        dermal_macro   [label="Dermal Macrophage\n(M2 phenotype)", fillcolor="#c4b5fd"]
        M2_macro       [label="M2 Macrophage\n(TGF-β, IL-10)", fillcolor="#a78bfa"]
        PDGF           [label="PDGF\n(fibroblast mitogen)", fillcolor="#ede9fe"]
        periostin      [label="Periostin\n(ECM glycoprotein, PN marker)", fillcolor="#ddd6fe"]
    }

    // ====================================================================
    // CLUSTER 7: Drug PK
    // ====================================================================
    subgraph cluster_drug_pk {
        label="Drug Pharmacokinetics"
        style=filled
        fillcolor="#ecfdf5"
        color="#065f46"
        fontsize=13
        fontcolor="#065f46"

        // Dupilumab
        dup_dose  [label="Dupilumab\n300mg SC q2w/q4w\n(anti-IL-4Rα)", fillcolor="#86efac", shape=parallelogram]
        dup_C1    [label="Dupilumab Cp\n(t1/2~18-21d)", fillcolor="#4ade80"]
        dup_TMDD  [label="IL-4Rα:Dupilumab\nComplex (TMDD)", fillcolor="#16a34a", fontcolor="white"]

        // Nemolizumab
        nem_dose  [label="Nemolizumab\n60mg SC q4w\n(anti-IL-31RA)", fillcolor="#86efac", shape=parallelogram]
        nem_C1    [label="Nemolizumab Cp\n(t1/2~18-21d)", fillcolor="#4ade80"]
        nem_TMDD  [label="IL-31RA:Nemolizumab\nComplex (TMDD)", fillcolor="#16a34a", fontcolor="white"]

        // Tralokinumab
        tral_dose [label="Tralokinumab\n300mg SC q2w\n(anti-IL-13)", fillcolor="#86efac", shape=parallelogram]
        tral_C1   [label="Tralokinumab Cp\n(t1/2~21d)", fillcolor="#4ade80"]

        // Topical corticosteroid
        TCS_dose  [label="Topical Corticosteroid\n(TCS, clobetasol)\nOD-BID", fillcolor="#86efac", shape=parallelogram]
        TCS_local [label="TCS Skin\nConcentration", fillcolor="#34d399"]

        // Systemic immunosuppressant
        cyclo_dose [label="Cyclosporine\n3-5 mg/kg/d PO\n(bridge)", fillcolor="#86efac", shape=parallelogram]
        cyclo_C1   [label="Cyclosporine Cp\n(t1/2~6-30h)", fillcolor="#10b981"]

        // Antihistamine
        antih_dose [label="Cetirizine / Loratadine\n10mg PO qd\n(H1-antihistamine)", fillcolor="#86efac", shape=parallelogram]
        antih_C1   [label="Antihistamine Cp", fillcolor="#34d399"]

        // Opioid modulator
        nalbuto_dose [label="Nalbuphine ER\n(κ-opioid agonist/\nμ-antagonist)", fillcolor="#86efac", shape=parallelogram]
        nalbuto_C1   [label="Nalbuphine Cp\n(t1/2~5h)", fillcolor="#4ade80"]
    }

    // ====================================================================
    // CLUSTER 8: Drug PD Mechanisms
    // ====================================================================
    subgraph cluster_drug_pd {
        label="Drug Pharmacodynamic Mechanisms"
        style=filled
        fillcolor="#fff1f2"
        color="#9f1239"
        fontsize=13
        fontcolor="#9f1239"

        IL4Ra_block  [label="IL-4Rα Blockade\n(Dupilumab)\nBlocks IL-4 & IL-13", fillcolor="#fda4af"]
        JAK1_inh     [label="JAK1/JAK2 Inhibition\n(Upadacitinib, Abrocitinib)", fillcolor="#fb7185"]
        IL13_block   [label="IL-13 Neutralization\n(Tralokinumab)", fillcolor="#fda4af"]
        IL31Ra_block [label="IL-31RA Blockade\n(Nemolizumab)\nDirect anti-itch", fillcolor="#f43f5e", fontcolor="white"]
        H1_block     [label="H1 Receptor Block\n(Antihistamines)\nModest PN effect", fillcolor="#fda4af"]
        calcineurin_inh [label="Calcineurin Inhibition\n(Cyclosporine → IL-2↓)", fillcolor="#fb7185"]
        GR_nuclear   [label="Glucocorticoid\nReceptor (GR) Activation\n(TCS → NF-κB↓)", fillcolor="#fda4af", shape=diamond]
        kappa_ag     [label="κ-Opioid Agonism\n(Nalbuphine, Difelikefalin)\nSpinal anti-itch", fillcolor="#f43f5e", fontcolor="white"]
        mu_antag     [label="μ-Opioid Antagonism\n(Nalbuphine)\nReduced opioid-driven itch", fillcolor="#fb7185"]
        Th2_suppress [label="Th2 Suppression\n(Dupilumab / JAKi effect)", fillcolor="#fda4af"]
        eosin_reduce [label="Eosinophil Reduction\n(Type 2 cytokine block)", fillcolor="#fecdd3"]
        NF_kB_inh    [label="NF-κB Inhibition\n(TCS/Cyclosporine)", fillcolor="#fb7185"]
    }

    // ====================================================================
    // CLUSTER 9: Biomarkers
    // ====================================================================
    subgraph cluster_bio {
        label="Biomarkers & Disease Monitoring"
        style=filled
        fillcolor="#e0f2fe"
        color="#0369a1"
        fontsize=13
        fontcolor="#0369a1"

        IgE_serum  [label="Total IgE\n(serum, kIU/L)", fillcolor="#bae6fd"]
        TARC_serum [label="TARC / CCL17\n(serum, pg/mL) — PN marker", fillcolor="#7dd3fc"]
        ECP_serum  [label="ECP\n(serum eosinophil act.)", fillcolor="#38bdf8"]
        eos_blood  [label="Blood Eosinophil\nCount (cells/µL)", fillcolor="#0ea5e9"]
        periostin_s[label="Serum Periostin\n(fibrosis/Th2 marker)", fillcolor="#0284c7", fontcolor="white"]
        TEWL_meas  [label="TEWL\n(trans-epidermal water loss)", fillcolor="#bae6fd"]
        IL31_serum [label="Serum IL-31\n(itch marker)", fillcolor="#7dd3fc"]
        skin_biopsy[label="Skin Biopsy\n(eosinophils, nerve density)", fillcolor="#0369a1", fontcolor="white"]
        nerve_density [label="Intraepidermal Nerve\nFiber Density (IENFD)", fillcolor="#0284c7", fontcolor="white"]
        thymus_LD  [label="TSLP\n(serum)", fillcolor="#38bdf8"]
    }

    // ====================================================================
    // CLUSTER 10: Clinical Endpoints
    // ====================================================================
    subgraph cluster_clinical {
        label="Clinical Endpoints"
        style=filled
        fillcolor="#f0fdf4"
        color="#14532d"
        fontsize=13
        fontcolor="#14532d"

        itch_VAS   [label="Itch NRS/VAS\n(worst itch 0-10)", fillcolor="#bbf7d0"]
        WI_NRS     [label="WI-NRS 0\n(Weekly Worst Itch ≤0/10)", fillcolor="#86efac"]
        IGA_score  [label="IGA Score\n(0-4 nodule count/severity)", fillcolor="#4ade80"]
        IGA0_1     [label="IGA 0/1\n(Clear/Almost Clear)", fillcolor="#22c55e", fontcolor="white"]
        DLQI       [label="DLQI\n(dermatology QoL, 0-30)", fillcolor="#16a34a", fontcolor="white"]
        POEM_score [label="POEM\n(atopic derm. measure, adapted)", fillcolor="#bbf7d0"]
        sleep_PN   [label="Sleep Disturbance\n(PSQ, ISI)", fillcolor="#86efac"]
        scratch_beh[label="Scratch Behavior\n(actigraphy)", fillcolor="#4ade80"]
        lesion_cnt [label="Lesion Count\n(nodule number)", fillcolor="#22c55e", fontcolor="white"]
        pain_PN    [label="Pain NRS\n(nodule tenderness)", fillcolor="#bbf7d0"]
        NRSS_itch  [label="NRSS Itch Responder\n(≥4pt reduction from baseline)", fillcolor="#16a34a", fontcolor="white"]
        QoL_resp   [label="QoL Responder\n(DLQI 0-1)", fillcolor="#14532d", fontcolor="white"]
    }

    // ====================================================================
    // EDGES — Triggers & Alarmin Release
    // ====================================================================
    barrier_defect  -> TSLP         [label="alarmin\nrelease"]
    barrier_defect  -> IL33_epi
    barrier_defect  -> IL25_epi
    mechanical_scratch -> epidermal_disruption [label="trauma"]
    allergen        -> APC_DC       [label="sensitization"]
    pathogen        -> TLR_signal_innate [label="PAMPs" ]
    UV_stimulus     -> TSLP         [label="stress"]
    trauma          -> nerve_sprout  [label="nerve\ndamage"]
    epidermal_disruption -> TSLP_kera
    epidermal_disruption -> keratinocyte [label="wound response"]

    // Internal alarmin nodes
    TLR_signal_innate [label="TLR Signaling\n(skin innate)", fillcolor="#fbbf24"]

    // ====================================================================
    // EDGES — Innate Immune Activation
    // ====================================================================
    TSLP            -> ILC2         [label="ILC2 activation"]
    TSLP            -> mast_cell    [label="activation"]
    IL33_epi        -> mast_cell    [label="ST2 signaling"]
    IL33_epi        -> ILC2         [label="ST2 signaling"]
    IL25_epi        -> ILC2         [label="IL-25R"]
    mast_cell       -> mast_deg     [label="FcεRI crosslink\nor TSLP"]
    mast_deg        -> histamine    [label="granule release"]
    mast_deg        -> tryptase     [label="granule release"]
    mast_deg        -> IL4_mc       [label="cytokine synthesis"]
    mast_deg        -> IL13_mc
    ILC2            -> IL5_ilc2     [label="produces"]
    ILC2            -> IL13_ilc2    [label="produces"]
    ILC2            -> amphiregulin [label="produces"]
    IL5_ilc2        -> eosinophil   [label="survival\n+ BM mobilization"]
    IL5_T2          -> eosinophil   [label="survival"]
    eosinophil      -> ECP          [label="degranulation"]
    eosinophil      -> MBP_eo       [label="degranulation"]
    MBP_eo          -> sensory_neuron [label="direct\nactivation"]
    ECP             -> sensory_neuron [label="sensitization"]
    TLR_signal_innate -> mast_cell  [label="PAMP"]
    SCF             -> mast_cell    [label="survival"]
    basophil        -> IL4_T2       [label="early IL-4"]
    NK_innate       -> Th1_cell     [label="IFN-γ signal"]

    // ====================================================================
    // EDGES — Adaptive Immune / Th2 Axis
    // ====================================================================
    TSLP            -> APC_DC       [label="DC activation\n→ Th2 bias"]
    IL4_mc          -> Th2          [label="Th2 polarization"]
    IL13_ilc2       -> Th2          [label="supports"]
    APC_DC          -> Th2          [label="OX40L/CRTH2\ndriven"]
    APC_DC          -> Th17_cell    [label="IL-23 drive"]
    Th2             -> IL4_T2       [label="produces"]
    Th2             -> IL13_T2      [label="produces"]
    Th2             -> IL5_T2       [label="produces"]
    Th2             -> IL31_T2      [label="produces (KEY ITCH)"]
    Th22            -> IL22_T2      [label="produces"]
    Th17_cell       -> IL17_T2      [label="produces"]
    OX40L           -> Th2          [label="costimulation"]
    CRTH2           -> ILC2         [label="PGD2→CRTH2"]
    IL4_T2          -> Bcell_PN     [label="class switch\nto IgE"]
    IL13_T2         -> Bcell_PN     [label="class switch"]
    Bcell_PN        -> plasma_IgE   [label="differentiation"]
    plasma_IgE      -> IgE_total    [label="secretes"]
    IgE_total       -> FcεRI        [label="binds FcεRI\non mast cell"]
    FcεRI           -> mast_deg     [label="crosslinking\n→ degranulation"]
    Treg_PN         -> Th2          [label="insufficient\nsuppress", style=dashed, color=red, arrowhead=tee]

    // ====================================================================
    // EDGES — Keratinocyte Responses
    // ====================================================================
    IL4_T2          -> filaggrin    [label="FLG↓", color=red, arrowhead=tee]
    IL13_T2         -> filaggrin    [label="FLG↓", color=red, arrowhead=tee]
    IL4_T2          -> CCL17        [label="Th2 chemoattr."]
    IL13_T2         -> CCL17
    IL22_T2         -> epidermal_hyp [label="acanthosis"]
    IL22_T2         -> keratinocyte [label="hyperproliferation"]
    IL17_T2         -> keratinocyte [label="inflammation"]
    NGF_kera        -> TrkA         [label="binds"]
    TSLP_kera       -> APC_DC       [label="OX40L induction"]
    IL33_kera       -> mast_cell    [label="ST2"]
    CCL11_eotaxin   -> eosinophil   [label="chemotaxis"]
    Sema3A_kera     -> nerve_sprout [label="repels normal\nnerves → dysfunct.", style=dashed, color=red]
    keratinocyte    -> TSLP_kera    [label="IL-4, IL-13 ↑"]
    keratinocyte    -> NGF_kera     [label="produces"]
    keratinocyte    -> CCL11_eotaxin

    // ====================================================================
    // EDGES — Neuronal / Itch
    // ====================================================================
    IL31_T2         -> IL31RA       [label="binds IL-31RA/OSMR"]
    IL31RA          -> JAK1_neuron  [label="JAK1/STAT3/5"]
    JAK1_neuron     -> sensory_neuron [label="itch signal"]
    histamine       -> H1R_neuron   [label="direct itch"]
    H1R_neuron      -> sensory_neuron
    tryptase        -> PAR2         [label="cleavage\nactivation"]
    PAR2            -> sensory_neuron [label="Ca2+ influx\nitch"]
    TRPV1           -> sensory_neuron [label="heat/capsaicin"]
    TRPA1           -> sensory_neuron [label="reactive molec."]
    TrkA            -> sensory_neuron [label="NGF sensitization"]
    SP              -> sensory_neuron [label="bidirectional"]
    CGRP            -> sensory_neuron [label="bidirectional"]
    sensory_neuron  -> SP           [label="releases"]
    sensory_neuron  -> CGRP         [label="releases"]
    sensory_neuron  -> DRG          [label="central relay"]
    DRG             -> spinal_cord_PN [label="GRPR/TRPV1"]
    spinal_cord_PN  -> supraspinal  [label="spinothalamic\ntract"]
    supraspinal     -> itch_VAS     [label="perceived itch"]
    SP              -> mast_cell    [label="neurogenic\ndegranulation"]
    CGRP            -> mast_cell    [label="neurogenic\nactivation"]
    SP              -> neurogenic_inf [label="drives"]
    nerve_sprout    -> itch_VAS     [label="amplified\nitch signal"]
    central_sens    -> itch_VAS     [label="chronic\nitch↑"]
    spinal_cord_PN  -> central_sens [label="wind-up"]
    mu_opioid       -> itch_VAS     [label="paradox itch\n(peripheral)", color=orange]
    kappa_opioid    -> itch_VAS     [label="anti-itch", color=blue, arrowhead=tee]
    mechanical_scratch -> scratch_beh [label="behavior"]
    itch_VAS        -> mechanical_scratch [label="itch-scratch\ncycle"]

    // ====================================================================
    // EDGES — Dermal Remodeling
    // ====================================================================
    IL13_T2         -> fibroblast   [label="TGF-β ↑\ncollagen ↑"]
    TGFb1           -> myo_fibro    [label="activation"]
    TGFb1           -> collagen_1_3 [label="synthesis↑"]
    myo_fibro       -> collagen_1_3 [label="deposits"]
    collagen_1_3    -> nodule_form  [label="tissue\nfibrous core"]
    epidermal_hyp   -> nodule_form  [label="thickened\nepidermis"]
    M2_macro        -> TGFb1        [label="secretes"]
    M2_macro        -> PDGF         [label="secretes"]
    PDGF            -> fibroblast   [label="mitogen"]
    dermal_macro    -> M2_macro     [label="IL-4/IL-13\npolarization"]
    IL4_T2          -> dermal_macro [label="M2 polariz."]
    periostin       -> nodule_form  [label="ECM signal"]
    IL13_T2         -> periostin    [label="induces"]

    // ====================================================================
    // EDGES — Drug PK
    // ====================================================================
    dup_dose  -> dup_C1    [label="SC abs\nka~0.007/h"]
    dup_C1    -> dup_TMDD  [label="IL-4Rα binding"]
    nem_dose  -> nem_C1    [label="SC abs\nka~0.006/h"]
    nem_C1    -> nem_TMDD  [label="IL-31RA binding"]
    tral_dose -> tral_C1   [label="SC abs"]
    TCS_dose  -> TCS_local [label="topical penetration\n(vehicle dependent)"]
    cyclo_dose -> cyclo_C1 [label="oral abs F~30%"]
    antih_dose -> antih_C1 [label="oral abs F~73%"]
    nalbuto_dose -> nalbuto_C1 [label="ER oral\nka~0.1/h"]

    // ====================================================================
    // EDGES — Drug PD
    // ====================================================================
    dup_TMDD   -> IL4Ra_block   [label="saturates\nIL-4Rα"]
    IL4Ra_block -> Th2_suppress [label="Th2 cytokine\nproduction↓"]
    IL4Ra_block -> IL4_T2       [label="blocks IL-4\nsignaling", color=blue, style=dashed, arrowhead=tee]
    IL4Ra_block -> IL13_T2      [label="blocks IL-13\nsignaling", color=blue, style=dashed, arrowhead=tee]
    IL4Ra_block -> IgE_total    [label="IgE class\nswitch↓", color=blue, style=dashed, arrowhead=tee]
    Th2_suppress -> IL31_T2     [label="IL-31↓", color=blue, style=dashed, arrowhead=tee]
    Th2_suppress -> eosin_reduce [label="IL-5↓\nEosinophil↓"]

    nem_TMDD   -> IL31Ra_block  [label="blocks IL-31\nsignaling"]
    IL31Ra_block -> JAK1_neuron [label="JAK1↓ in\nneurons", color=blue, style=dashed, arrowhead=tee]
    IL31Ra_block -> itch_VAS    [label="direct itch↓\n(fast ~1-2wk)", color=blue, style=dashed, arrowhead=tee]

    tral_C1    -> IL13_block    [label="neutralizes\nIL-13"]
    IL13_block -> IL13_T2       [label="IL-13↓", color=blue, style=dashed, arrowhead=tee]
    IL13_block -> fibroblast    [label="fibrosis↓", color=blue, style=dashed, arrowhead=tee]

    antih_C1   -> H1_block      [label="H1 antagonism"]
    H1_block   -> H1R_neuron    [label="blocks\nhistamine itch", color=blue, style=dashed, arrowhead=tee]

    cyclo_C1   -> calcineurin_inh [label="calcineurin↓"]
    calcineurin_inh -> Th2       [label="T cell prolif↓", color=blue, style=dashed, arrowhead=tee]
    calcineurin_inh -> IL4_T2    [label="IL-4↓", color=blue, style=dashed, arrowhead=tee]

    TCS_local  -> GR_nuclear    [label="GR activation"]
    GR_nuclear -> NF_kB_inh     [label="NF-κB↓"]
    NF_kB_inh  -> keratinocyte  [label="inflam.\ncytokines↓", color=blue, style=dashed, arrowhead=tee]
    NF_kB_inh  -> mast_cell     [label="activation↓", color=blue, style=dashed, arrowhead=tee]

    nalbuto_C1 -> kappa_ag      [label="κ-agonism"]
    nalbuto_C1 -> mu_antag      [label="μ-antagonism"]
    kappa_ag   -> kappa_opioid  [label="activates"]
    mu_antag   -> mu_opioid     [label="blocks", color=blue, arrowhead=tee]

    // ====================================================================
    // EDGES — Biomarkers
    // ====================================================================
    IgE_total   -> IgE_serum    [label="measured in\nblood"]
    CCL17       -> TARC_serum   [label="serum TARC"]
    ECP         -> ECP_serum    [label="serum ECP"]
    eosinophil  -> eos_blood    [label="peripheral count"]
    periostin   -> periostin_s  [label="serum"]
    barrier_defect -> TEWL_meas [label="skin barrier\nloss"]
    IL31_T2     -> IL31_serum   [label="serum IL-31"]
    nerve_sprout -> nerve_density [label="biopsy measure"]
    skin_biopsy -> nerve_density
    skin_biopsy -> eos_blood    [label="tissue eos."]

    // ====================================================================
    // EDGES — Clinical Endpoints
    // ====================================================================
    itch_VAS    -> WI_NRS       [label="weekly worst\nitch score"]
    nodule_form -> IGA_score    [label="lesion\nassessment"]
    IGA_score   -> IGA0_1       [label="clear/almost\nclear"]
    itch_VAS    -> DLQI         [label="quality of life"]
    nodule_form -> DLQI         [label="skin appear."]
    itch_VAS    -> sleep_PN     [label="nocturnal itch"]
    itch_VAS    -> scratch_beh  [label="itch drives\nscratch"]
    nodule_form -> lesion_cnt   [label="count lesions"]
    nodule_form -> pain_PN      [label="tenderness"]
    itch_VAS    -> NRSS_itch    [label="≥4pt NRS\nresponse"]
    DLQI        -> QoL_resp     [label="DLQI 0-1"]

    // Drug effects on endpoints
    IL31Ra_block -> WI_NRS      [label="rapid itch↓\n(~1wk)", color=blue, style=dashed]
    IL4Ra_block  -> IGA_score   [label="lesion↓\n(PRIME trial)", color=blue, style=dashed]
    IL4Ra_block  -> itch_VAS    [label="itch↓\n(gradual ~4-8wk)", color=blue, style=dashed]
    Th2_suppress -> IGA_score   [label="type 2 inflam↓\n→ nodule↓", color=blue, style=dashed]
    NF_kB_inh   -> IGA_score    [label="local inflam↓", color=blue, style=dashed]
    kappa_ag    -> NRSS_itch    [label="itch↓\n(difelikefalin)", color=blue, style=dashed]
}
