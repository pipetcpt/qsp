digraph PrurigoNodularis_QSP {
  graph [rankdir=LR, splines=true, overlap=false, fontname="Helvetica", fontsize=11, nodesep=0.32, ranksep=0.55, bgcolor="white", label="Prurigo Nodularis (PN) QSP Model — Neuroimmune Itch-Scratch Cycle → Nodule Fibrosis\nType-2/Th17 Cytokine-Nerve Crosstalk · IL-31/IL-31RA · Opioid Imbalance · Dupilumab · Nemolizumab · Gabapentinoids · Nalbuphine ER", labelloc=t, fontsize=14];
  node  [shape=box, style="rounded,filled", fontname="Helvetica", fontsize=10, color="#333333"];
  edge  [color="#555555", arrowsize=0.7, fontname="Helvetica", fontsize=9];

  // ============================================================
  // CLUSTER 1 — ETIOLOGY & PREDISPOSING FACTORS
  // ============================================================
  subgraph cluster_etiology {
    label="① Etiology & Predisposing Factors";
    style="rounded,filled"; fillcolor="#FFF1E6"; color="#E67E22";
    eti_atopic       [label="Atopic diathesis\npersonal/family AD·asthma·AR", fillcolor="#FCD9B6"];
    eti_ckd          [label="Chronic kidney disease\nCKD-associated pruritus (CKD-aP)", fillcolor="#FCD9B6"];
    eti_liver        [label="Cholestatic liver disease\nbile acid·LPA·autotaxin", fillcolor="#FCD9B6"];
    eti_psych        [label="Psychiatric comorbidity\ndepression·anxiety·OCD", fillcolor="#FCD9B6"];
    eti_genetic      [label="Genetic susceptibility\nfilaggrin variants·atopy genes", fillcolor="#FCD9B6"];
    eti_female       [label="Female + older age\npredominance (50–65y)", fillcolor="#FCD9B6"];
    eti_black_race   [label="Black race\ndisparity — incidence 3.4×", fillcolor="#FCD9B6"];
    eti_uremic       [label="Uremic toxin\naccumulation (CKD-aP specific)", fillcolor="#FCD9B6"];
    eti_hepatic      [label="Hepatic pruritogen\naccumulation (cholestasis)", fillcolor="#FCD9B6"];
    eti_lymphoma     [label="Hematologic malignancy\nparaneoplastic pruritus", fillcolor="#FCD9B6"];
    eti_hiv          [label="HIV infection\nassociated PN", fillcolor="#FCD9B6"];
    eti_dm           [label="Diabetes mellitus\nmetabolic/neuropathic driver", fillcolor="#FCD9B6"];
    eti_neuropathic  [label="Neuropathic overlap\npost-herpetic·diabetic neuropathy", fillcolor="#FCD9B6"];
    eti_stress_trigger [label="Chronic psychological\nstress trigger", fillcolor="#FCD9B6"];
  }

  // ============================================================
  // CLUSTER 2 — EPIDERMAL BARRIER & KERATINOCYTE ALARMINS
  // ============================================================
  subgraph cluster_barrier {
    label="② Epidermal Barrier & Keratinocyte Alarmins";
    style="rounded,filled"; fillcolor="#FDEBD0"; color="#D68910";
    ker_basal          [label="Basal\nkeratinocyte", fillcolor="#FAD7A0"];
    ker_tewl           [label="↑ TEWL\nbarrier disruption", fillcolor="#FAD7A0"];
    ker_filaggrin      [label="↓ Filaggrin\n↓ loricrin", fillcolor="#FAD7A0"];
    ker_lipid          [label="Stratum corneum\nlipid lamellae disorder", fillcolor="#FAD7A0"];
    ker_microbiome     [label="S. aureus\ncolonization/dysbiosis", fillcolor="#FAD7A0"];
    ker_tslp           [label="TSLP\nalarmin release", fillcolor="#FAD7A0"];
    ker_il33           [label="IL-33\nalarmin release", fillcolor="#FAD7A0"];
    ker_il25           [label="IL-25\nalarmin release", fillcolor="#FAD7A0"];
    ker_hyperkeratosis [label="Hyperkeratosis", fillcolor="#FAD7A0"];
    ker_acanthosis     [label="Acanthosis\nepidermal hyperplasia", fillcolor="#FAD7A0"];
    ker_ngf            [label="Nerve growth\nfactor (NGF) ↑", fillcolor="#FAD7A0"];
    ker_semaphorin     [label="Semaphorin 3A ↓\naxon-repellent loss", fillcolor="#FAD7A0"];
    ker_pgd            [label="Prostaglandin D2/E2\nrelease", fillcolor="#FAD7A0"];
  }

  // ============================================================
  // CLUSTER 3 — PERIPHERAL SENSORY NERVE & ITCH TRANSDUCTION
  // ============================================================
  subgraph cluster_nerve {
    label="③ Peripheral Sensory Nerve & Itch Transduction";
    style="rounded,filled"; fillcolor="#FDF2E3"; color="#B9770E";
    nerve_cfiber      [label="Unmyelinated\nC-fiber pruriceptor", fillcolor="#F8E1B0"];
    nerve_trpv1       [label="TRPV1\nchannel", fillcolor="#F8E1B0"];
    nerve_trpa1       [label="TRPA1\nchannel", fillcolor="#F8E1B0"];
    nerve_il31ra      [label="IL-31RA/OSMRβ\nheterodimer receptor", fillcolor="#F8E1B0"];
    nerve_h1r         [label="Histamine H1\nreceptor (minor)", fillcolor="#F8E1B0"];
    nerve_mrgprx      [label="MRGPRX2/4\nnon-histaminergic itch", fillcolor="#F8E1B0"];
    nerve_par2        [label="PAR-2\nprotease-activated receptor", fillcolor="#F8E1B0"];
    nerve_ienfd_early [label="Early: IENFD ↑\nnerve sprouting", fillcolor="#F8E1B0"];
    nerve_ienfd_late  [label="Late: IENFD ↓\ndenervation in nodule core", fillcolor="#F8E1B0"];
    nerve_sp          [label="Substance P\nrelease", fillcolor="#F8E1B0"];
    nerve_cgrp        [label="CGRP\nrelease", fillcolor="#F8E1B0"];
    nerve_mast        [label="Mast cell\nactivation (SP/CGRP)", fillcolor="#F8E1B0"];
    nerve_drg         [label="Dorsal root ganglion\npruriceptive neuron soma", fillcolor="#F8E1B0"];
    nerve_alloknesis  [label="Peripheral\nsensitization/alloknesis", fillcolor="#F8E1B0"];
  }

  // ============================================================
  // CLUSTER 4 — TYPE 2 (Th2) IMMUNE AXIS
  // ============================================================
  subgraph cluster_th2 {
    label="④ Type-2 (Th2) Immune Axis";
    style="rounded,filled"; fillcolor="#EAF2F8"; color="#2E86C1";
    th2_naive     [label="Naive\nCD4+ T cell", fillcolor="#AED6F1"];
    th2_diff      [label="Th2 differentiation\nGATA3+", fillcolor="#AED6F1"];
    th2_il4       [label="IL-4", fillcolor="#AED6F1"];
    th2_il13      [label="IL-13", fillcolor="#AED6F1"];
    th2_il5       [label="IL-5", fillcolor="#AED6F1"];
    th2_il31      [label="IL-31\n(key pruritogenic cytokine)", fillcolor="#5DADE2", fontcolor=white];
    th2_ilc2      [label="ILC2\n(innate lymphoid cell)", fillcolor="#AED6F1"];
    th2_eos       [label="Eosinophil\nrecruitment/activation", fillcolor="#AED6F1"];
    th2_mastige   [label="Mast cell\nIgE-mediated activation", fillcolor="#AED6F1"];
    th2_il4ra     [label="IL-4Rα\nshared receptor subunit", fillcolor="#AED6F1"];
    th2_stat6     [label="STAT6\nsignaling", fillcolor="#AED6F1"];
  }

  // ============================================================
  // CLUSTER 5 — Th17/Th22 AXIS & EPIDERMAL HYPERPLASIA
  // ============================================================
  subgraph cluster_th17 {
    label="⑤ Th17/Th22 Axis & Epidermal Hyperplasia";
    style="rounded,filled"; fillcolor="#EBF5EE"; color="#229954";
    th17_diff        [label="Th17/Th22\ndifferentiation", fillcolor="#A9DFBF"];
    th17_il17        [label="IL-17A", fillcolor="#A9DFBF"];
    th17_il22        [label="IL-22", fillcolor="#A9DFBF"];
    th17_ifng        [label="IFN-γ\n(mixed Th1 contribution)", fillcolor="#A9DFBF"];
    th17_neutrophil  [label="Neutrophil\nrecruitment (excoriated lesion)", fillcolor="#A9DFBF"];
    th17_keratinocyte_prolif [label="Keratinocyte\nproliferation drive", fillcolor="#A9DFBF"];
    th17_amp         [label="Antimicrobial peptide\nβ-defensin·S100", fillcolor="#A9DFBF"];
  }

  // ============================================================
  // CLUSTER 6 — CENTRAL SENSITIZATION & CNS ITCH PROCESSING
  // ============================================================
  subgraph cluster_cns {
    label="⑥ Central Sensitization & CNS Itch Processing";
    style="rounded,filled"; fillcolor="#F4ECF7"; color="#7D3C98";
    cns_grpr       [label="Spinal dorsal horn\nGRPR+ neuron", fillcolor="#D2B4DE"];
    cns_nppb       [label="Spinal Nppb\ninterneuron", fillcolor="#D2B4DE"];
    cns_gastrin    [label="Gastrin-releasing\npeptide (GRP)", fillcolor="#D2B4DE"];
    cns_sensitization [label="Central\nsensitization state", fillcolor="#D2B4DE"];
    cns_thalamus   [label="Thalamic\nrelay", fillcolor="#D2B4DE"];
    cns_cortex     [label="Somatosensory/insular\ncortex — itch percept", fillcolor="#D2B4DE"];
    cns_reward     [label="Reward/habit circuit\nnucleus accumbens", fillcolor="#D2B4DE"];
    cns_stress     [label="HPA-axis/cortisol\nstress amplification", fillcolor="#D2B4DE"];
    cns_stigma     [label="Psychosocial\nstigma feedback", fillcolor="#D2B4DE"];
  }

  // ============================================================
  // CLUSTER 7 — OPIOID RECEPTOR BALANCE
  // ============================================================
  subgraph cluster_opioid {
    label="⑦ Opioid Receptor Balance";
    style="rounded,filled"; fillcolor="#FEF9E7"; color="#B7950B";
    opioid_mor      [label="μ-opioid receptor\n(pruritogenic tone)", fillcolor="#F9E79F"];
    opioid_kor      [label="κ-opioid receptor\n(antipruritic tone)", fillcolor="#F9E79F"];
    opioid_endog    [label="Endogenous opioid\nβ-endorphin/dynorphin imbalance", fillcolor="#F9E79F"];
    opioid_mkratio  [label="MOR:KOR\nfunctional ratio ↑ in PN", fillcolor="#F9E79F"];
    opioid_difeli_target [label="Difelikefalin\nKOR-agonist target node", fillcolor="#F9E79F"];
  }

  // ============================================================
  // CLUSTER 8 — ITCH-SCRATCH CYCLE & NODULE FIBROSIS
  // ============================================================
  subgraph cluster_cycle {
    label="⑧ Itch-Scratch Cycle & Nodule Fibrosis";
    style="rounded,filled"; fillcolor="#FDEDEC"; color="#C0392B";
    cycle_percept     [label="Conscious itch\nperception (WI-NRS)", fillcolor="#F5B7B1"];
    cycle_scratch     [label="Scratch/rub\nbehavior", fillcolor="#F5B7B1"];
    cycle_trauma      [label="Mechanical\nepidermal trauma", fillcolor="#F5B7B1"];
    cycle_alloknesis  [label="Mechanical\nalloknesis (light-touch itch)", fillcolor="#F5B7B1"];
    cycle_pain        [label="Co-existing\nburning/pain sensation", fillcolor="#F5B7B1"];
    cycle_fibroblast  [label="Dermal fibroblast\nactivation", fillcolor="#F5B7B1"];
    cycle_tgfb        [label="TGF-β\nrelease", fillcolor="#F5B7B1"];
    cycle_collagen    [label="Collagen/ECM\ndeposition", fillcolor="#F5B7B1"];
    cycle_nodule      [label="Fibrotic nodule\nformation", fillcolor="#EC7063", fontcolor=white];
    cycle_lichen      [label="Lichenification", fillcolor="#F5B7B1"];
    cycle_infection   [label="Secondary bacterial\ninfection (excoriation)", fillcolor="#F5B7B1"];
    cycle_barrier_fb  [label="Feedback to\nbarrier disruption", fillcolor="#F5B7B1"];
  }

  // ============================================================
  // CLUSTER 9 — DRUG PK/PD: BIOLOGICS
  // ============================================================
  subgraph cluster_biologics {
    label="⑨ Drug PK/PD — Biologics (SC mAb)";
    style="rounded,filled"; fillcolor="#EBF5FB"; color="#1A5276";
    drug_dupi_pk    [label="Dupilumab SC\nPK (TMDD, q2w)", fillcolor="#AED6F1"];
    drug_dupi_moa   [label="Dupilumab blocks\nIL-4Rα (IL-4 & IL-13)", fillcolor="#AED6F1"];
    drug_dupi_ada   [label="Anti-drug antibody\n(immunogenicity)", fillcolor="#AED6F1"];
    drug_nemo_pk    [label="Nemolizumab SC\nPK (TMDD, q4w)", fillcolor="#AED6F1"];
    drug_nemo_moa   [label="Nemolizumab blocks\nIL-31RA (OSMRβ)", fillcolor="#AED6F1"];
    drug_nemo_ada   [label="Nemolizumab\nADA/immunogenicity", fillcolor="#AED6F1"];
    drug_vixa_pk    [label="Vixarelimab SC PK\n(anti-OSMRβ, investigational)", fillcolor="#AED6F1"];
  }

  // ============================================================
  // CLUSTER 10 — DRUG PK/PD: SMALL MOLECULES & SYMPTOMATIC
  // ============================================================
  subgraph cluster_smallmol {
    label="⑩ Drug PK/PD — Small Molecules & Symptomatic Therapy";
    style="rounded,filled"; fillcolor="#F5EEF8"; color="#6C3483";
    drug_gaba_pk     [label="Gabapentin/pregabalin\noral PK (α2δ ligand)", fillcolor="#D7BDE2"];
    drug_gaba_moa    [label="Ca²⁺-channel α2δ\nblockade → ↓ central sensitization", fillcolor="#D7BDE2"];
    drug_jaki_pk     [label="Oral JAK1 inhibitor\n(abrocitinib) PK", fillcolor="#D7BDE2"];
    drug_jaki_moa    [label="JAK1 inhibition blocks\nIL-4/13/31 signal transduction", fillcolor="#D7BDE2"];
    drug_tcs         [label="Topical\ncorticosteroid", fillcolor="#D7BDE2"];
    drug_tcni        [label="Topical calcineurin\ninhibitor", fillcolor="#D7BDE2"];
    drug_antihist    [label="Sedating\nantihistamine (H1)", fillcolor="#D7BDE2"];
    drug_thalidomide [label="Thalidomide/\nlenalidomide (TNF-α↓)", fillcolor="#D7BDE2"];
    drug_naltrexone  [label="Oral naltrexone\n(MOR antagonist)", fillcolor="#D7BDE2"];
    drug_nal_pk      [label="Nalbuphine ER\noral PK (2-cpt)", fillcolor="#D7BDE2"];
    drug_nal_moa     [label="Nalbuphine: MOR\nantagonist + KOR agonist", fillcolor="#D7BDE2"];
    drug_ssri        [label="SSRI (paroxetine)\nserotonergic itch modulation", fillcolor="#D7BDE2"];
  }

  // ============================================================
  // CLUSTER 11 — CLINICAL ENDPOINTS & QUALITY OF LIFE
  // ============================================================
  subgraph cluster_clin {
    label="⑪ Clinical Endpoints & Quality of Life";
    style="rounded,filled"; fillcolor="#FBEEE6"; color="#A04000";
    clin_winrs     [label="Worst-Itch NRS\n(0–10)", fillcolor="#F0B27A"];
    clin_iga       [label="PN-IGA\n(0–4, success = 0/1)", fillcolor="#F0B27A"];
    clin_nodule_ct [label="Nodule count\n(active lesions)", fillcolor="#F0B27A"];
    clin_sleep     [label="Sleep disturbance\n(ISI/ItchySleep)", fillcolor="#F0B27A"];
    clin_dlqi      [label="DLQI\nquality of life", fillcolor="#F0B27A"];
    clin_hads      [label="HADS anxiety/\ndepression score", fillcolor="#F0B27A"];
    clin_response  [label="Composite responder\n(IGA success + WI-NRS ≥4-pt ↓)", fillcolor="#F0B27A"];
    clin_biomarker [label="Serum biomarker\nIL-31 · TARC/CCL17", fillcolor="#F0B27A"];
    clin_flare     [label="Flare/relapse\nrate", fillcolor="#F0B27A"];
  }

  // ============================================================
  // CROSS-CLUSTER MECHANISTIC EDGES
  // ============================================================
  // Etiology -> barrier / immune priming
  eti_atopic -> ker_filaggrin;
  eti_genetic -> ker_filaggrin;
  eti_female -> eti_stress_trigger;
  eti_black_race -> th2_il31;
  eti_ckd -> eti_uremic;
  eti_uremic -> opioid_mkratio;
  eti_liver -> eti_hepatic;
  eti_hepatic -> nerve_cfiber;
  eti_lymphoma -> th2_diff;
  eti_hiv -> th2_diff;
  eti_dm -> nerve_ienfd_late;
  eti_neuropathic -> nerve_alloknesis;
  eti_psych -> cns_stress;
  eti_stress_trigger -> cns_stress;

  // Barrier -> alarmins -> immune
  ker_basal -> ker_tewl;
  ker_tewl -> ker_filaggrin;
  ker_filaggrin -> ker_lipid;
  ker_lipid -> ker_microbiome;
  ker_microbiome -> ker_tslp;
  ker_tewl -> ker_tslp;
  ker_tewl -> ker_il33;
  ker_tewl -> ker_il25;
  ker_tslp -> th2_ilc2;
  ker_tslp -> th2_diff;
  ker_il33 -> th2_ilc2;
  ker_il25 -> th2_ilc2;
  ker_basal -> ker_ngf;
  ker_ngf -> nerve_cfiber;
  ker_basal -> ker_semaphorin;
  ker_semaphorin -> nerve_ienfd_early [label="↓ repulsion", style=dashed];
  ker_basal -> ker_pgd;
  ker_pgd -> nerve_cfiber;
  ker_basal -> ker_hyperkeratosis;
  ker_basal -> ker_acanthosis;
  th17_keratinocyte_prolif -> ker_acanthosis;

  // Th2 axis
  th2_naive -> th2_diff;
  th2_diff -> th2_il4;
  th2_diff -> th2_il13;
  th2_diff -> th2_il5;
  th2_diff -> th2_il31;
  th2_ilc2 -> th2_il5;
  th2_ilc2 -> th2_il13;
  th2_il5 -> th2_eos;
  th2_il4 -> th2_mastige;
  th2_il4 -> th2_il4ra;
  th2_il13 -> th2_il4ra;
  th2_il4ra -> th2_stat6;
  th2_stat6 -> ker_tewl [label="barrier↓ feedback", style=dashed, constraint=false];
  th2_stat6 -> th2_il31;
  th2_il31 -> nerve_il31ra;
  nerve_il31ra -> nerve_cfiber;
  th2_eos -> cycle_infection [style=dashed, label="tissue damage"];
  th2_mastige -> nerve_sp [style=dashed];

  // Th17/22 axis
  th2_diff -> th17_diff [style=dashed, label="mixed polarization"];
  th17_diff -> th17_il17;
  th17_diff -> th17_il22;
  th17_diff -> th17_ifng;
  th17_il22 -> th17_keratinocyte_prolif;
  th17_il17 -> th17_neutrophil;
  th17_il17 -> th17_amp;
  cycle_infection -> th17_neutrophil;

  // Nerve transduction
  nerve_cfiber -> nerve_trpv1;
  nerve_cfiber -> nerve_trpa1;
  nerve_cfiber -> nerve_h1r;
  nerve_cfiber -> nerve_mrgprx;
  nerve_cfiber -> nerve_par2;
  nerve_trpv1 -> nerve_alloknesis;
  nerve_trpa1 -> nerve_alloknesis;
  nerve_par2 -> nerve_mast;
  nerve_cfiber -> nerve_sp;
  nerve_cfiber -> nerve_cgrp;
  nerve_sp -> nerve_mast;
  nerve_cgrp -> nerve_mast;
  nerve_mast -> ker_tslp [style=dashed, label="amplify"];
  nerve_cfiber -> nerve_ienfd_early;
  cycle_nodule -> nerve_ienfd_late [label="chronic denervation"];
  nerve_ienfd_late -> nerve_alloknesis [style=dashed, label="paradoxical hypersensitivity", constraint=false];
  nerve_cfiber -> nerve_drg;
  nerve_drg -> cns_grpr [label="ascending signal"];

  // Central processing
  cns_grpr -> cns_gastrin;
  cns_gastrin -> cns_nppb;
  cns_nppb -> cns_sensitization;
  nerve_alloknesis -> cns_sensitization;
  cns_sensitization -> cns_thalamus;
  cns_thalamus -> cns_cortex;
  cns_cortex -> cycle_percept;
  cns_stress -> cns_sensitization [label="stress-itch amplification"];
  cycle_percept -> cns_reward [style=dashed];
  cns_reward -> cycle_scratch [label="reinforcement", constraint=false];
  cns_stigma -> cns_stress [style=dashed, constraint=false];
  clin_dlqi -> cns_stigma [style=dashed];

  // Opioid modulation of itch gain
  opioid_endog -> opioid_mor;
  opioid_endog -> opioid_kor;
  opioid_mor -> cns_sensitization [label="↑ itch gain"];
  opioid_kor -> cns_sensitization [label="↓ itch gain", arrowhead=tee, color="#B7950B"];
  opioid_mkratio -> opioid_mor;
  opioid_mkratio -> opioid_kor [arrowhead=tee];
  opioid_difeli_target -> opioid_kor;

  // Itch-scratch-fibrosis cycle
  cycle_percept -> cycle_scratch;
  cycle_scratch -> cycle_trauma;
  cycle_trauma -> cycle_pain;
  cycle_trauma -> cycle_barrier_fb;
  cycle_barrier_fb -> ker_tewl [label="vicious cycle", color="#C0392B", constraint=false];
  cycle_trauma -> ker_ngf [label="re-injury → NGF↑"];
  cycle_trauma -> cycle_fibroblast;
  cycle_fibroblast -> cycle_tgfb;
  cycle_tgfb -> cycle_collagen;
  cycle_collagen -> cycle_nodule;
  cycle_nodule -> cycle_lichen;
  cycle_trauma -> cycle_infection;
  cycle_nodule -> clin_nodule_ct;
  cycle_lichen -> clin_iga;
  cycle_percept -> clin_winrs;
  clin_winrs -> clin_sleep;
  clin_sleep -> clin_hads;
  clin_hads -> cns_stress [style=dashed, label="bidirectional", constraint=false];
  clin_winrs -> clin_dlqi;
  clin_iga -> clin_dlqi;
  clin_nodule_ct -> clin_iga;
  th2_il31 -> clin_biomarker;
  clin_winrs -> clin_response;
  clin_iga -> clin_response;
  clin_response -> clin_flare [style=dashed, label="durability"];

  // ---------------- DRUG PK/PD EDGES ----------------
  drug_dupi_pk -> drug_dupi_moa;
  drug_dupi_moa -> th2_il4ra [arrowhead=tee, color="#1A5276", label="blocks"];
  drug_dupi_pk -> drug_dupi_ada [style=dashed];
  drug_dupi_ada -> drug_dupi_pk [style=dashed, label="↑ clearance", constraint=false];

  drug_nemo_pk -> drug_nemo_moa;
  drug_nemo_moa -> nerve_il31ra [arrowhead=tee, color="#1A5276", label="blocks"];
  drug_nemo_pk -> drug_nemo_ada [style=dashed];
  drug_nemo_ada -> drug_nemo_pk [style=dashed, label="↑ clearance", constraint=false];

  drug_vixa_pk -> nerve_il31ra [arrowhead=tee, color="#1A5276", label="blocks OSMRβ"];

  drug_gaba_pk -> drug_gaba_moa;
  drug_gaba_moa -> cns_sensitization [arrowhead=tee, color="#6C3483"];

  drug_jaki_pk -> drug_jaki_moa;
  drug_jaki_moa -> th2_stat6 [arrowhead=tee, color="#6C3483"];
  drug_jaki_moa -> nerve_il31ra [arrowhead=tee, color="#6C3483", style=dashed];

  drug_tcs -> ker_acanthosis [arrowhead=tee, color="#6C3483"];
  drug_tcs -> th17_il17 [arrowhead=tee, color="#6C3483", style=dashed];
  drug_tcni -> th2_stat6 [arrowhead=tee, color="#6C3483", style=dashed];
  drug_antihist -> nerve_h1r [arrowhead=tee, color="#6C3483"];
  drug_antihist -> cycle_percept [style=dashed, label="sedation, minor direct effect"];
  drug_thalidomide -> th2_diff [arrowhead=tee, color="#6C3483", style=dashed, label="TNF-α↓/immunomod"];

  drug_naltrexone -> opioid_mor [arrowhead=tee, color="#6C3483"];
  drug_nal_pk -> drug_nal_moa;
  drug_nal_moa -> opioid_mor [arrowhead=tee, color="#6C3483"];
  drug_nal_moa -> opioid_kor [color="#6C3483", label="agonist"];
  drug_ssri -> cns_sensitization [arrowhead=tee, color="#6C3483", style=dashed];
}
