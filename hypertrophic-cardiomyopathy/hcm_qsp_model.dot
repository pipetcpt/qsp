digraph HCM_QSP_Model {
  graph [layout=fdp, fontname="Helvetica", fontsize=10,
         label="Hypertrophic Cardiomyopathy (HCM)\nQuantitative Systems Pharmacology Model\nSarcomere Genetics · Calcium Handling · Cardiac Mechanics · Drug Pharmacology · Clinical Outcomes",
         labelloc=t, labeljust=c, bgcolor="#F8F9FA", pad=0.6,
         K=0.8, maxiter=1000, splines=curved, overlap=prism, compound=true];

  node [fontname="Helvetica", fontsize=8, style="filled,rounded", shape=box, margin="0.08,0.04", height=0.3];
  edge [fontname="Helvetica", fontsize=7, arrowsize=0.6];

  // =====================================================================
  // CLUSTER 1: GENETIC & MOLECULAR FOUNDATION
  // =====================================================================
  subgraph cluster_genetics {
    style=filled; color="#C5CAE9"; fillcolor="#E8EAF6";
    label="Genetic & Molecular Foundation"; fontsize=10; fontcolor="#1A237E"; fontname="Helvetica-Bold";

    node [fillcolor="#C5CAE9", color="#3F51B5"];

    MYH7         [label="MYH7\n(β-MHC Heavy Chain)"];
    MYBPC3       [label="MYBPC3\n(cMyBP-C)"];
    TNNT2        [label="TNNT2\n(Troponin T)"];
    TNNI3        [label="TNNI3\n(Troponin I)"];
    TPM1         [label="TPM1\n(α-Tropomyosin)"];
    MYL2         [label="MYL2\n(Regulatory Light Chain)"];
    MYL3         [label="MYL3\n(Essential Light Chain)"];
    ACTC1        [label="ACTC1\n(Cardiac Actin)"];
    CSRP3        [label="CSRP3\n(MLP / Muscle LIM)"];
    TTN          [label="TTN\n(Titin — elastic spring)"];
    mutation_burden  [label="Pathogenic Variant\nBurden / Penetrance", shape=oval, fillcolor="#9FA8DA"];
    allelic_imbal    [label="Allelic Imbalance /\nHaploinsufficiency"];
    sarcomere_prot   [label="Abnormal Sarcomere\nProtein Structure", shape=oval, fillcolor="#9FA8DA"];
    compound_het     [label="Compound\nHeterozygosity"];
  }

  // =====================================================================
  // CLUSTER 2: SARCOMERE MECHANICS & CROSS-BRIDGE CYCLING
  // =====================================================================
  subgraph cluster_sarcomere {
    style=filled; color="#A5D6A7"; fillcolor="#E8F5E9";
    label="Sarcomere Mechanics & Cross-Bridge Cycling"; fontsize=10; fontcolor="#1B5E20"; fontname="Helvetica-Bold";

    node [fillcolor="#C8E6C9", color="#388E3C"];

    myosin_head    [label="Myosin Head\n(S1 Domain)"];
    actin_fil      [label="Actin Filament\n(F-Actin)"];
    tropomyosin_cx [label="Tropomyosin–\nTroponin Complex"];
    titin_spring   [label="Titin\n(Passive Stiffness)"];
    nebulin        [label="Nebulin\n(Thin Filament Ruler)"];
    cross_bridge   [label="Actomyosin\nCross-Bridge"];
    SRX_state      [label="SRX State\n(Super-Relaxed,\nsequestered)", fillcolor="#FFCC80", color="#E65100"];
    DRX_state      [label="DRX State\n(Disordered-Relaxed,\navailable)"];
    power_stroke   [label="Power Stroke\n(Force-Generating)"];
    duty_ratio     [label="Duty Ratio\n(Fraction in\nPower-Stroke)", shape=oval, fillcolor="#A5D6A7"];
    ATP_hydrolysis [label="Myosin ATPase\n(ATP Hydrolysis Rate)"];
    energy_demand  [label="Myocardial Energy\nDemand (MVO₂)", shape=oval, fillcolor="#A5D6A7"];
    force_gen      [label="Active Force\nGeneration (Tension)", shape=oval, fillcolor="#A5D6A7"];
    hypercontract  [label="Hypercontractility\n(Hallmark of HCM)", shape=oval, fillcolor="#EF9A9A", color="#C62828"];
    sarcomere_len  [label="Sarcomere Length\n(μm)"];
    Frank_Star     [label="Frank-Starling\nMechanism"];
    Ca_sensitivity [label="Myofilament\nCa²⁺ Sensitivity\n(pCa50)"];
  }

  // =====================================================================
  // CLUSTER 3: CALCIUM HANDLING & EXCITATION-CONTRACTION COUPLING
  // =====================================================================
  subgraph cluster_calcium {
    style=filled; color="#FFE082"; fillcolor="#FFFDE7";
    label="Calcium Handling & E-C Coupling"; fontsize=10; fontcolor="#E65100"; fontname="Helvetica-Bold";

    node [fillcolor="#FFECB3", color="#F57F17"];

    LTCC         [label="L-Type Ca²⁺ Channel\n(Cav1.2 / DHPR)"];
    RyR2         [label="Ryanodine Receptor 2\n(RyR2 — SR release)"];
    SERCA2a      [label="SERCA2a\n(SR Ca²⁺ ATPase pump)"];
    NCX          [label="Na⁺/Ca²⁺ Exchanger\n(NCX1)"];
    PLB          [label="Phospholamban\n(PLB — SERCA inhibitor)"];
    Ca_cyt       [label="[Ca²⁺]cytosol\n(Free, nM)", shape=oval, fillcolor="#FFD54F"];
    Ca_SR        [label="[Ca²⁺]SR\n(Sarcoplasmic\nReticulum Store)", shape=oval, fillcolor="#FFD54F"];
    Ca_transient [label="Ca²⁺ Transient\nAmplitude & Duration"];
    CaM          [label="Calmodulin\n(CaM)"];
    CaMKII       [label="CaMKII\n(Ca²⁺/CaM Kinase II)"];
    CASQ2        [label="Calsequestrin 2\n(CASQ2 — SR buffer)"];
    FKBP12_6     [label="FKBP12.6\n(RyR2 channel\nstabilizer)"];
    Ca_leak      [label="Diastolic\nSR Ca²⁺ Leak"];
    PMCA         [label="Plasma Membrane\nCa²⁺ ATPase (PMCA)"];
    CALPAIN      [label="Calpain\n(Ca²⁺-activated\nprotease)"];
    IP3R         [label="IP₃ Receptor\n(Nuclear/ER)"];
  }

  // =====================================================================
  // CLUSTER 4: INTRACELLULAR SIGNALING CASCADES
  // =====================================================================
  subgraph cluster_signaling {
    style=filled; color="#F48FB1"; fillcolor="#FCE4EC";
    label="Intracellular Signaling Cascades"; fontsize=10; fontcolor="#880E4F"; fontname="Helvetica-Bold";

    node [fillcolor="#F8BBD9", color="#AD1457"];

    Calcineurin   [label="Calcineurin\n(PP2B / CaN)"];
    NFAT_c        [label="NFATc\n(Cytoplasmic, inactive)"];
    NFAT_n        [label="NFATc\n(Nuclear, active)"];
    HDAC4_5       [label="HDAC4/5\n(Class IIa Histone\nDeacetylase)"];
    MEF2          [label="MEF2\n(Myocyte Enhancer\nFactor 2)"];
    GATA4         [label="GATA4\n(Cardiac Transcription\nFactor)"];
    ERK1_2        [label="ERK1/2\n(p44/42 MAPK)"];
    p38_MAPK      [label="p38 MAPK"];
    JNK           [label="JNK\n(Stress MAPK)"];
    Ras_Raf       [label="Ras/Raf\n(MAPK upstream)"];
    PI3K          [label="PI3Kα/β\n(Class I)"];
    Akt_PKB       [label="Akt / PKB"];
    mTORC1        [label="mTORC1\n(Protein synthesis)"];
    S6K1_4EBP1    [label="S6K1 / 4E-BP1\n(Translation factors)"];
    GSK3b         [label="GSK-3β\n(Anti-hypertrophy\nkinase)"];
    FOXO3a        [label="FOXO3a\n(Autophagy / Atrophy)"];
    IGF1R_sig     [label="IGF-1R\n(Physiologic\nHypertrophy)"];
    Gq_prot       [label="Gq Protein\n(GPCR coupling)"];
    PLC_beta      [label="PLCβ\n(Phospholipase C)"];
    PKC_alpha     [label="PKCα\n(Protein Kinase C)"];
    IP3_sig       [label="IP₃\n(Inositol-1,4,5-P₃)"];
    DAG_sig       [label="DAG\n(Diacylglycerol)"];
    RhoA          [label="RhoA/ROCK\n(Cytoskeletal)"];
  }

  // =====================================================================
  // CLUSTER 5: CARDIAC HYPERTROPHY REMODELING
  // =====================================================================
  subgraph cluster_hypertrophy {
    style=filled; color="#CE93D8"; fillcolor="#F3E5F5";
    label="Cardiac Hypertrophy & Remodeling"; fontsize=10; fontcolor="#4A148C"; fontname="Helvetica-Bold";

    node [fillcolor="#E1BEE7", color="#7B1FA2"];

    prot_synth     [label="Protein Synthesis\nRate (Ribosomal)"];
    fetal_gene_pgm [label="Fetal Gene\nProgram Activation"];
    ANP_gene       [label="ANP (NPPA)\nGene Expression"];
    BNP_gene       [label="BNP (NPPB)\nGene Expression"];
    beta_MHC_expr  [label="β-MHC (MYH7)\nUpregulation"];
    alpha_MHC_expr [label="α-MHC (MYH6)\nDownregulation"];
    myocyte_size   [label="Cardiomyocyte\nHypertrophy (Size)", shape=oval, fillcolor="#CE93D8"];
    LV_mass        [label="LV Mass\n(g / g·m⁻²)", shape=oval, fillcolor="#CE93D8"];
    IVS_thick      [label="IVS Thickness\n(mm)", shape=oval, fillcolor="#CE93D8"];
    PW_thick       [label="Posterior Wall\nThickness (mm)"];
    asymm_hyp      [label="Asymmetric Septal\nHypertrophy (ASH)"];
    apical_hyp     [label="Apical HCM\nVariant"];
    midcav_obs     [label="Mid-Cavity\nObstruction"];
    myocyte_disarr [label="Myocyte Disarray\n(Histopathology)"];
    apoptosis_cm   [label="Cardiomyocyte\nApoptosis"];
    autophagy      [label="Autophagy\n(mTOR-regulated)"];
  }

  // =====================================================================
  // CLUSTER 6: MYOCARDIAL FIBROSIS
  // =====================================================================
  subgraph cluster_fibrosis {
    style=filled; color="#FFCC80"; fillcolor="#FFF8E1";
    label="Myocardial Fibrosis Pathway"; fontsize=10; fontcolor="#BF360C"; fontname="Helvetica-Bold";

    node [fillcolor="#FFE0B2", color="#E64A19"];

    TGFb1          [label="TGF-β1\n(Profibrotic Cytokine)", shape=oval, fillcolor="#FFCC80"];
    TGFb_R1_R2     [label="TGFβ-RI / RII\n(ALK5 / TGFBR2)"];
    SMAD2_3        [label="pSMAD2/3\n(Activated R-SMADs)"];
    SMAD4          [label="SMAD4\n(Co-SMAD)"];
    SMAD6_7        [label="SMAD6/7\n(Inhibitory I-SMADs)"];
    nonSMAD_TGFb   [label="Non-SMAD TGF-β\nPathways (PI3K, MAPK)"];
    cardiac_fibro  [label="Cardiac\nFibroblast (CF)"];
    myofibro       [label="Myofibroblast\n(αSMA⁺ activated)", fillcolor="#FFCC80"];
    collagen_I     [label="Collagen Type I\n(COL1A1/A2)"];
    collagen_III   [label="Collagen Type III\n(COL3A1)"];
    fibronectin    [label="Fibronectin\n(FN1)"];
    MMP1           [label="MMP-1\n(Interstitial\nCollagenase)"];
    MMP2           [label="MMP-2\n(Gelatinase A)"];
    MMP9           [label="MMP-9\n(Gelatinase B)"];
    TIMP1          [label="TIMP-1\n(MMP Inhibitor)"];
    TIMP2          [label="TIMP-2\n(MMP Inhibitor)"];
    ECM_remo       [label="ECM Remodeling\n& Crosslinking", shape=oval, fillcolor="#FFCC80"];
    LOX            [label="LOX/LOXL2\n(Collagen Crosslinker)"];
    interst_fibros [label="Interstitial Fibrosis\n(% area)", shape=oval, fillcolor="#FFA726"];
    replac_fibros  [label="Replacement Fibrosis\n(Scar / LGE)", shape=oval, fillcolor="#FFA726"];
    ECV_frac       [label="ECV Fraction\n(CMR, %)"];
    galectin3      [label="Galectin-3\n(Fibrosis Biomarker)"];
    ST2_prot       [label="sST2\n(IL-33 Decoy Receptor)"];
    CTGF           [label="CTGF / CCN2\n(Connective Tissue\nGrowth Factor)"];
    periostin      [label="Periostin\n(ECM Scaffold)"];
  }

  // =====================================================================
  // CLUSTER 7: LV MECHANICS & HEMODYNAMICS
  // =====================================================================
  subgraph cluster_mechanics {
    style=filled; color="#80DEEA"; fillcolor="#E0F7FA";
    label="LV Mechanics & Hemodynamics"; fontsize=10; fontcolor="#004D40"; fontname="Helvetica-Bold";

    node [fillcolor="#B2EBF2", color="#00695C"];

    LVOT_grad      [label="LVOT Gradient\n(mmHg resting/\nprovoked)", shape=oval, fillcolor="#4DB6AC"];
    SAM_MV         [label="Systolic Anterior\nMotion (SAM)"];
    Venturi_eff    [label="Venturi Effect\n(Flow Acceleration)"];
    mitral_regurg  [label="Dynamic Mitral\nRegurgitation"];
    LVEDP          [label="LVEDP\n(mmHg)", shape=oval, fillcolor="#4DB6AC"];
    LVEDV          [label="LVEDV\n(mL)"];
    LVESV          [label="LVESV\n(mL)"];
    LVEF           [label="LVEF\n(%)", shape=oval, fillcolor="#4DB6AC"];
    stroke_vol     [label="Stroke Volume\n(mL)"];
    cardiac_out    [label="Cardiac Output\n(L/min)", shape=oval, fillcolor="#4DB6AC"];
    heart_rate     [label="Heart Rate\n(bpm)"];
    sys_BP         [label="Systolic BP\n(mmHg)"];
    dia_BP         [label="Diastolic BP\n(mmHg)"];
    MAP            [label="Mean Arterial\nPressure (mmHg)"];
    LV_compliance  [label="LV Compliance\n(mL/mmHg)"];
    diastolic_fxn  [label="Diastolic Function\nGrade (I–IV)", shape=oval, fillcolor="#4DB6AC"];
    E_e_ratio      [label="E/e' Ratio\n(Filling Pressure)"];
    e_prime        [label="e' Velocity\n(Tissue Doppler)"];
    LA_vol_idx     [label="LA Volume Index\n(mL/m²)"];
    LA_pressure    [label="LA Pressure\n(mmHg)"];
    wall_stress    [label="LV Wall Stress\n(systolic / diastolic)"];
    myocard_isch   [label="Microvascular\nIschemia (MVD)", shape=oval, fillcolor="#FFCDD2", color="#C62828"];
    coronary_flow  [label="Coronary\nMicrovascular Flow"];
    PCWP           [label="PCWP\n(mmHg)"];
  }

  // =====================================================================
  // CLUSTER 8: ARRHYTHMIA & SCD RISK
  // =====================================================================
  subgraph cluster_arrhythmia {
    style=filled; color="#EF9A9A"; fillcolor="#FFEBEE";
    label="Arrhythmia & SCD Risk Pathways"; fontsize=10; fontcolor="#B71C1C"; fontname="Helvetica-Bold";

    node [fillcolor="#FFCDD2", color="#D32F2F"];

    AF_onset       [label="Atrial Fibrillation\n(AF)", shape=oval, fillcolor="#EF9A9A"];
    AF_burden      [label="AF Burden\n(% time in AF)"];
    atrial_elec_rem [label="Atrial Electrical\nRemodeling"];
    atrial_struct_rem [label="Atrial Structural\nRemodeling / Fibrosis"];
    NSVT           [label="Non-Sustained VT\n(NSVT on Holter)"];
    VT_sustained   [label="Sustained VT\n(≥30 s)", shape=oval, fillcolor="#EF9A9A"];
    VF             [label="Ventricular\nFibrillation (VF)", shape=oval, fillcolor="#EF9A9A"];
    SCD_risk_score [label="SCD Risk\n(HCM Risk-SCD,\n5-yr %)", shape=oval, fillcolor="#EF9A9A"];
    EAD            [label="Early After-\ndepolarizations (EAD)"];
    DAD            [label="Delayed After-\ndepolarizations (DAD)"];
    triggered_act  [label="Triggered Activity"];
    reentry_circ   [label="Reentrant Circuits\n(Scar-mediated)"];
    APD_prolong    [label="APD\nProlongation"];
    QTc_interval   [label="QTc Interval\n(ms)"];
    scar_substr    [label="Arrhythmic Scar\nSubstrate (LGE)"];
    LVOTO_syncope  [label="Hemodynamic\nSyncope (LVOTO)"];
    ICD_device     [label="ICD\n(Prophylactic)", shape=oval, fillcolor="#A5D6A7", color="#2E7D32"];
    thrombo_risk   [label="LA Thrombus /\nThromboembolism"];
  }

  // =====================================================================
  // CLUSTER 9: NEUROHORMONAL ACTIVATION
  // =====================================================================
  subgraph cluster_neuro {
    style=filled; color="#A5D6A7"; fillcolor="#E8F5E9";
    label="Neurohormonal Activation"; fontsize=10; fontcolor="#1B5E20"; fontname="Helvetica-Bold";

    node [fillcolor="#DCEDC8", color="#388E3C"];

    SNS_act        [label="Sympathetic\nNervous System (SNS)"];
    norepineph     [label="Norepinephrine\n(NE)"];
    epineph        [label="Epinephrine"];
    beta1AR        [label="β₁-Adrenergic\nReceptor (β₁AR)"];
    beta2AR        [label="β₂-Adrenergic\nReceptor (β₂AR)"];
    Gs_prot        [label="Gs Protein"];
    adenyl_cycl    [label="Adenylate\nCyclase (AC)"];
    cAMP_pool      [label="cAMP"];
    PKA_act        [label="PKA\n(Protein Kinase A)"];
    RAAS_sys       [label="RAAS System\nActivation", shape=oval, fillcolor="#A5D6A7"];
    Renin_sec      [label="Renin\n(JGA secretion)"];
    ACE_conv       [label="ACE\n(Angiotensin I → II)"];
    AngII_plasma   [label="Angiotensin II\n(AngII)"];
    AT1R_sig       [label="AT1 Receptor\n(AT1R)"];
    AT2R_sig       [label="AT2 Receptor\n(protective)"];
    Aldost         [label="Aldosterone"];
    MR_kidney      [label="Mineralocorticoid\nReceptor (MR)"];
    Na_water_ret   [label="Na⁺/H₂O Retention\n(Volume Overload)"];
    BNP_plasma     [label="BNP\n(Plasma, pg/mL)", shape=oval, fillcolor="#A5D6A7"];
    NT_proBNP_pl   [label="NT-proBNP\n(Plasma, pg/mL)", shape=oval, fillcolor="#A5D6A7"];
    ANP_plasma     [label="ANP\n(Atrial Natriuretic\nPeptide)"];
    vasopressin    [label="ADH / Vasopressin"];
    endothelin1    [label="Endothelin-1\n(ET-1)"];
  }

  // =====================================================================
  // CLUSTER 10: DRUG PHARMACOLOGY
  // =====================================================================
  subgraph cluster_drugs {
    style=filled; color="#90CAF9"; fillcolor="#E3F2FD";
    label="Drug Pharmacology"; fontsize=10; fontcolor="#0D47A1"; fontname="Helvetica-Bold";

    node [fillcolor="#BBDEFB", color="#1565C0"];

    // Mavacamten
    mava_dose      [label="Mavacamten\nDose (2.5–15 mg QD)", shape=parallelogram, fillcolor="#64B5F6"];
    mava_gut       [label="Mavacamten Gut\nCompartment (A_gut)"];
    mava_central   [label="Mavacamten\nCentral [C_c]\n(nM)", shape=oval, fillcolor="#42A5F5"];
    mava_periph    [label="Mavacamten\nPeripheral (A_p)"];
    CYP2C19        [label="CYP2C19\n(Major Metabolism\nPM/EM/UM)"];
    mava_inh_myosin [label="Cardiac Myosin\nATPase Inhibition\n(Competitive)"];
    mava_effect    [label="Mavacamten\nPD Effect (Duty↓)", shape=oval, fillcolor="#1E88E5"];

    // Aficamten
    aficam_dose    [label="Aficamten\n(Next-gen inhibitor)", shape=parallelogram, fillcolor="#64B5F6"];
    aficam_effect  [label="Aficamten PD\n(Duty↓, shorter t½)"];

    // Beta-blockers
    BB_dose        [label="Beta-Blocker\n(Metoprolol/Bisoprolol)", shape=parallelogram, fillcolor="#90CAF9"];
    BB_plasma      [label="Beta-Blocker\nPlasma Conc", shape=oval, fillcolor="#90CAF9"];
    BB_hr_effect   [label="HR Reduction\n(β₁ blockade)"];
    BB_inotropy    [label="Contractility ↓\n(Negative inotropy)"];

    // Calcium channel blockers
    CCB_verap      [label="Verapamil\n(Non-DHP CCB)", shape=parallelogram, fillcolor="#90CAF9"];
    CCB_plasma     [label="Verapamil\nPlasma Conc"];
    CCB_effect     [label="Cav1.2 Blockade\n(HR↓, contractility↓)"];

    // Disopyramide
    DIS_dose       [label="Disopyramide\n(100–300 mg TID)", shape=parallelogram, fillcolor="#90CAF9"];
    DIS_NaCh       [label="Na⁺ Channel\nBlockade (SAM↓)"];
    DIS_anticholinerg [label="Anticholinergic\nSide Effects"];

    // Diuretics
    diuretic_dose  [label="Diuretic\n(Furosemide/Torsemide)", shape=parallelogram, fillcolor="#90CAF9"];
    diuretic_eff   [label="Loop Diuretic Effect\n(Volume ↓)"];

    // Septal reduction therapy
    SRT_proc       [label="Septal Reduction\nTherapy (SRT)", shape=parallelogram, fillcolor="#FFB74D"];
    myect_effect   [label="Surgical Myectomy\n(LVOT ↓↓↓)"];
    ASA_effect     [label="Alcohol Septal\nAblation (ASA)"];

    // Anticoagulation
    NOAC_dose      [label="NOAC / Warfarin\n(AF Anticoagulation)", shape=parallelogram, fillcolor="#90CAF9"];
    AC_effect      [label="Stroke Prevention\n(Anticoagulation)"];

    // ICD implantation
    ICD_implant    [label="ICD Implantation\n(SCD Prevention)", shape=parallelogram, fillcolor="#FFCDD2", color="#C62828"];
  }

  // =====================================================================
  // CLUSTER 11: CLINICAL ENDPOINTS & OUTCOMES
  // =====================================================================
  subgraph cluster_outcomes {
    style=filled; color="#AED581"; fillcolor="#F1F8E9";
    label="Clinical Endpoints & Outcomes"; fontsize=10; fontcolor="#33691E"; fontname="Helvetica-Bold";

    node [fillcolor="#DCEDC8", color="#558B2F"];

    NYHA_class     [label="NYHA Functional\nClass (I–IV)", shape=oval, fillcolor="#AED581"];
    peak_VO2       [label="Peak VO₂\n(mL/kg/min, CPET)", shape=oval, fillcolor="#AED581"];
    six_MWT_dist   [label="6-Minute Walk\nTest (6MWT, m)", shape=oval, fillcolor="#AED581"];
    VE_VCO2        [label="VE/VCO₂ Slope\n(Ventilatory Eff.)"];
    dyspnea_sx     [label="Exertional\nDyspnea (NYHA)"];
    chest_pain_sx  [label="Chest Pain /\nExertional Angina"];
    palpitation_sx [label="Palpitations\n(AF / Ectopy)"];
    syncope_sx     [label="Syncope /\nPresyncope"];
    HF_hosp        [label="HF\nHospitalization"];
    stroke_event   [label="Cardioembolic\nStroke (AF)"];
    SCD_event      [label="Sudden Cardiac\nDeath (SCD)", shape=oval, fillcolor="#EF9A9A", color="#C62828"];
    transplant_ref [label="Heart Transplant\nReferral"];
    KCCQ_score     [label="KCCQ / EQ-5D\nQuality of Life", shape=oval, fillcolor="#AED581"];
    exer_capacity  [label="Functional Exercise\nCapacity"];
    HCM_composite  [label="HCM Composite\nEndpoint"];
  }

  // =====================================================================
  // CLUSTER 12: IMAGING & BIOMARKERS
  // =====================================================================
  subgraph cluster_biomarkers {
    style=filled; color="#B39DDB"; fillcolor="#EDE7F6";
    label="Imaging & Laboratory Biomarkers"; fontsize=10; fontcolor="#311B92"; fontname="Helvetica-Bold";

    node [fillcolor="#D1C4E9", color="#512DA8"];

    CMR_LGE        [label="CMR Late Gadolinium\nEnhancement (% LV)", shape=oval, fillcolor="#B39DDB"];
    CMR_ECV        [label="CMR ECV\n(Extracellular\nVolume %)", shape=oval, fillcolor="#B39DDB"];
    Echo_IVS       [label="Echo: IVS\n(mm)"];
    Echo_LVOT      [label="Echo: LVOT Gradient\n(mmHg, resting/Valsalva)"];
    Echo_LVEF      [label="Echo: LVEF (%)"];
    Echo_Ee        [label="Echo: E/e' Ratio"];
    Echo_SAM       [label="Echo: SAM\n(Present/Absent/Degree)"];
    Echo_LAVi      [label="Echo: LA Volume\nIndex (mL/m²)"];
    troponin_I_T   [label="Cardiac Troponin\nI / T (ng/L)", shape=oval, fillcolor="#B39DDB"];
    hs_CRP         [label="hs-CRP\n(Inflammation)"];
    galectin3_lab  [label="Galectin-3\n(ng/mL)", shape=oval, fillcolor="#B39DDB"];
    HCM_RSCD       [label="HCM Risk-SCD\n(5-year score %)", shape=oval, fillcolor="#B39DDB"];
    genetic_panel  [label="Genetic Panel\nResult (P/LP/VUS)"];
    family_hx_SCD  [label="Family History\nof SCD"];
    NSVT_Holter    [label="NSVT on\n24h Holter"];
    abnorm_BPR     [label="Abnormal BP\nResponse (Exercise)"];
    MRI_T1         [label="CMR T1 Mapping\n(Native T1, ms)"];
    CMR_strain     [label="CMR / Echo\nGlobal LS (%)"];
  }

  // =====================================================================
  // EDGES: GENETICS → SARCOMERE
  // =====================================================================
  MYH7        -> mutation_burden [label="P/LP variant"];
  MYBPC3      -> mutation_burden;
  TNNT2       -> mutation_burden;
