digraph OUD_QSP {
  graph [rankdir=LR, fontname="Helvetica", fontsize=11, labelloc=t,
         label="Opioid Use Disorder (OUD) — Integrated QSP Mechanistic Map\nMu/Kappa/Delta receptor pharmacology · Mesolimbic reward · Tolerance/withdrawal neuroadaptation · Respiratory-depression overdose cascade\nIllicit fentanyl/heroin · Methadone · Buprenorphine(±naloxone) · Naloxone · Naltrexone(XR) · Lofexidine · Craving/relapse & harm reduction",
         splines=spline, overlap=false, nodesep=0.30, ranksep=0.55,
         bgcolor="#fbfbfd"];
  node  [shape=box, style="rounded,filled", fontname="Helvetica", fontsize=10,
         fillcolor="#ffffff", color="#7d8590"];
  edge  [fontname="Helvetica", fontsize=9, color="#6e7681", arrowsize=0.7];

  /* ───────────────────────── 1. Etiology & Risk Factors ───────────────────── */
  subgraph cluster_etiology {
    label="1. Etiology & Risk Factors";
    style="filled,rounded"; color="#5c6370"; fillcolor="#f3f0ff"; fontsize=12;
    GeneticRiskOPRM1   [label="Genetic risk\n(OPRM1 A118G, heritability ~50%)"];
    AdverseChildhoodExp[label="Adverse childhood\nexperiences / trauma"];
    PsychiatricComorbid[label="Comorbid anxiety /\ndepression / PTSD"];
    ChronicPainCond    [label="Chronic pain\ncondition"];
    PrescriptionOpioidRx[label="Prescription opioid\nprescribing (acute/chronic pain)"];
    IatrogenicExposure [label="Iatrogenic long-term\nopioid exposure"];
    EarlyMisuseBehavior[label="Early nonmedical use /\ndose escalation"];
    SocialEnvironStress[label="Socioeconomic stress /\npeer environment"];
    IllicitMarketTransition[label="Transition to illicit\nopioid market (heroin/fentanyl)"];
    AdolescentNeurodevel[label="Adolescent brain\nreward-circuit vulnerability"];
    OUD_Onset          [label="Opioid Use Disorder\n(DSM-5 criteria met)"];
    GeneticRiskOPRM1 -> OUD_Onset [style=dashed, label="heritable\nsusceptibility"];
    AdverseChildhoodExp -> PsychiatricComorbid;
    PsychiatricComorbid -> EarlyMisuseBehavior;
    ChronicPainCond -> PrescriptionOpioidRx -> IatrogenicExposure -> EarlyMisuseBehavior;
    SocialEnvironStress -> EarlyMisuseBehavior;
    AdolescentNeurodevel -> EarlyMisuseBehavior;
    EarlyMisuseBehavior -> IllicitMarketTransition;
    IllicitMarketTransition -> OUD_Onset;
    EarlyMisuseBehavior -> OUD_Onset;
  }

  /* ───────────────────────── 2. Opioid Receptor Pharmacology & Signaling ──── */
  subgraph cluster_receptor {
    label="2. Opioid Receptor Pharmacology & Signaling";
    style="filled,rounded"; color="#5c6370"; fillcolor="#fff4e6"; fontsize=12;
    MOR                [label="Mu-opioid receptor\n(OPRM1, GPCR)"];
    KOR                [label="Kappa-opioid receptor\n(OPRK1)"];
    DOR                [label="Delta-opioid receptor\n(OPRD1)"];
    Gi_Go_Coupling     [label="Gi/Go protein\ncoupling"];
    AdenylylCyclaseInhib[label="Adenylyl cyclase\ninhibition"];
    cAMP_AcuteDecrease [label="Acute cAMP\ndecrease"];
    GIRK_Activation    [label="GIRK K+ channel\nactivation (hyperpolarization)"];
    VGCC_Inhibition    [label="Voltage-gated Ca2+\nchannel inhibition (presynaptic)"];
    NeurotransRelease_Inhib[label="Presynaptic neurotransmitter\nrelease inhibition"];
    BetaArrestin2_Recruit[label="β-arrestin-2\nrecruitment"];
    ReceptorInternalization[label="MOR internalization /\ndesensitization"];
    SpinalAnalgesia    [label="Spinal antinociception\n(dorsal horn)"];
    SupraspinalAnalgesia[label="Supraspinal analgesia\n(PAG/RVM)"];
    PeripheralGI_MOR   [label="Peripheral GI MOR\n(myenteric plexus)"];
    Miosis_EWNucleus   [label="Miosis\n(Edinger-Westphal nucleus)"];
    MOR -> Gi_Go_Coupling -> AdenylylCyclaseInhib -> cAMP_AcuteDecrease;
    Gi_Go_Coupling -> GIRK_Activation;
    Gi_Go_Coupling -> VGCC_Inhibition -> NeurotransRelease_Inhib;
    MOR -> BetaArrestin2_Recruit -> ReceptorInternalization;
    MOR -> SpinalAnalgesia;
    MOR -> SupraspinalAnalgesia;
    MOR -> PeripheralGI_MOR;
    MOR -> Miosis_EWNucleus;
  }

  /* ───────────────────────── 3. Mesolimbic Reward Pathway ─────────────────── */
  subgraph cluster_reward {
    label="3. Mesolimbic Reward Pathway";
    style="filled,rounded"; color="#5c6370"; fillcolor="#e6f7ff"; fontsize=12;
    VTA_GABA_Interneuron[label="VTA GABAergic\ninterneuron"];
    MOR_Disinhibition  [label="MOR agonism on GABA\ninterneuron → disinhibition"];
    VTA_DA_Neuron      [label="VTA dopaminergic\nneuron"];
    NAc_DA_Release     [label="Nucleus accumbens\ndopamine release"];
    NAc_ShellCircuit   [label="NAc shell\ncircuit"];
    PFC_ExecutiveControl[label="Prefrontal cortex\nexecutive control"];
    EuphoriaHigh       [label="Euphoria / \"high\""];
    IncentiveSalience  [label="Incentive salience\nattribution"];
    ConditionedCueAssoc[label="Conditioned drug-cue\nassociation"];
    DrugMemoryConsolid [label="Drug-memory consolidation\n(amygdala/hippocampus)"];
    MOR -> VTA_GABA_Interneuron [style=dashed, label="agonist\nbinding"];
    VTA_GABA_Interneuron -> MOR_Disinhibition -> VTA_DA_Neuron [label="disinhibits"];
    VTA_DA_Neuron -> NAc_DA_Release -> EuphoriaHigh;
    NAc_DA_Release -> NAc_ShellCircuit -> IncentiveSalience -> ConditionedCueAssoc -> DrugMemoryConsolid;
    PFC_ExecutiveControl -> NAc_ShellCircuit [style=dashed, label="top-down\nrestraint"];
  }

  /* ───────────────────────── 4. Neuroadaptation — Tolerance & Withdrawal ──── */
  subgraph cluster_neuroadapt {
    label="4. Neuroadaptation — Tolerance & Withdrawal Substrate";
    style="filled,rounded"; color="#5c6370"; fillcolor="#ffe6ec"; fontsize=12;
    ChronicMORAgonism  [label="Chronic MOR\nagonism (repeated dosing)"];
    cAMP_Superactivation[label="Homeostatic cAMP\nsuperactivation (rebound)"];
    PKA_Upregulation   [label="PKA\nupregulation"];
    CREB_Phosphorylation[label="CREB\nphosphorylation"];
    ReceptorDownreg_Tol[label="MOR downregulation /\npharmacodynamic tolerance"];
    OpioidHyperalgesia [label="Opioid-induced\nhyperalgesia"];
    LC_NE_Neuron       [label="Locus coeruleus (LC)\nnoradrenergic neuron"];
    LC_AcuteSuppress   [label="Acute LC firing\nsuppression (MOR-Gi)"];
    LC_ReboundHyperact [label="LC rebound\nhyperactivity (withdrawal)"];
    NE_Release_CtxHipp [label="NE release to cortex/\nhippocampus/hypothalamus"];
    DynorphinKOR_Upreg [label="Dynorphin/KOR\nsystem upregulation"];
    AntiRewardDysphoria[label="Anti-reward system /\ndysphoria state"];
    HPA_CRF_Activation [label="HPA axis / CRF\nactivation"];
    StressSystemSensit [label="Stress-system\nsensitization"];
    ChronicMORAgonism -> cAMP_Superactivation -> PKA_Upregulation -> CREB_Phosphorylation -> ReceptorDownreg_Tol;
    ReceptorDownreg_Tol -> OpioidHyperalgesia;
    ChronicMORAgonism -> LC_AcuteSuppress [style=dashed, label="tonic MOR-Gi\ninhibition"];
    LC_AcuteSuppress -> LC_NE_Neuron;
    cAMP_Superactivation -> LC_ReboundHyperact [label="unmasked on\nopioid withdrawal"];
    LC_ReboundHyperact -> NE_Release_CtxHipp;
    ChronicMORAgonism -> DynorphinKOR_Upreg -> AntiRewardDysphoria;
    AntiRewardDysphoria -> HPA_CRF_Activation -> StressSystemSensit;
    StressSystemSensit -> LC_ReboundHyperact [style=dashed];
  }

  /* ───────────────────────── 5. Withdrawal Clinical Syndrome ──────────────── */
  subgraph cluster_withdrawal {
    label="5. Withdrawal Clinical Syndrome";
    style="filled,rounded"; color="#5c6370"; fillcolor="#fff9e6"; fontsize=12;
    AutonomicHyperact  [label="Autonomic\nhyperactivity"];
    Mydriasis          [label="Mydriasis"];
    Piloerection       [label="Piloerection\n(\"cold turkey\")"];
    RhinorrheaLacrim   [label="Rhinorrhea /\nlacrimation"];
    Diaphoresis        [label="Diaphoresis"];
    GICramping_Diarrhea[label="GI cramping /\ndiarrhea / vomiting"];
    MyalgiaArthralgia  [label="Myalgia /\narthralgia"];
    YawningSneezing    [label="Yawning /\nsneezing"];
    AnxietyIrritability[label="Anxiety /\nirritability"];
    InsomniaWD         [label="Insomnia"];
    COWS_ScoreNode     [label="COWS composite\nwithdrawal score"];
    NE_Release_CtxHipp -> AutonomicHyperact;
    AutonomicHyperact -> Mydriasis;
    AutonomicHyperact -> Piloerection;
    AutonomicHyperact -> RhinorrheaLacrim;
    AutonomicHyperact -> Diaphoresis;
    AutonomicHyperact -> GICramping_Diarrhea;
    LC_ReboundHyperact -> MyalgiaArthralgia [style=dashed];
    LC_ReboundHyperact -> YawningSneezing [style=dashed];
    AntiRewardDysphoria -> AnxietyIrritability;
    AntiRewardDysphoria -> InsomniaWD;
    Mydriasis -> COWS_ScoreNode;
    GICramping_Diarrhea -> COWS_ScoreNode;
    MyalgiaArthralgia -> COWS_ScoreNode;
    AnxietyIrritability -> COWS_ScoreNode;
    InsomniaWD -> COWS_ScoreNode;
  }

  /* ───────────────────────── 6. Respiratory Depression / Overdose ─────────── */
  subgraph cluster_resp {
    label="6. Respiratory Depression & Overdose Cascade";
    style="filled,rounded"; color="#5c6370"; fillcolor="#ffe6e6"; fontsize=12;
    BrainstemMOR_Resp  [label="Brainstem MOR\n(respiratory centers)"];
    PreBotzingerComplex[label="Pre-Bötzinger complex\n(inspiratory rhythm generator)"];
    Hypoventilation    [label="Hypoventilation\n(↓ tidal volume/rate)"];
    HypoxiaHypercapnia [label="Hypoxia /\nhypercapnia"];
    Bradypnea          [label="Bradypnea"];
    ApneaCessation     [label="Apnea / cessation\nof breathing"];
    AnoxicCardiacArrest[label="Anoxic\ncardiac arrest"];
    FatalOverdoseDeath [label="Fatal opioid\noverdose"];
    ChestWallRigidity  [label="Chest-wall rigidity\n(rapid high-potency IV bolus)"];
    NaloxoneReversalNode[label="Naloxone competitive\ndisplacement (reversal)"];
    MOR -> BrainstemMOR_Resp [label="full-agonist\nsaturation"];
    BrainstemMOR_Resp -> PreBotzingerComplex -> Hypoventilation -> HypoxiaHypercapnia;
    Hypoventilation -> Bradypnea -> ApneaCessation -> AnoxicCardiacArrest -> FatalOverdoseDeath;
    ChestWallRigidity -> Hypoventilation [style=dashed, label="fentanyl\nrapid-bolus effect"];
    NaloxoneReversalNode -> BrainstemMOR_Resp [style=dashed, label="displaces agonist,\nrestores drive"];
  }

  /* ───────────────────────── 7. Illicit Fentanyl / Heroin PK/PD ───────────── */
  subgraph cluster_fentanyl {
    label="7. Drug PK/PD — Illicit Fentanyl / Heroin (Full Agonist)";
    style="filled,rounded"; color="#5c6370"; fillcolor="#e6f0ff"; fontsize=12;
    FentanylDose_IV_IN [label="Illicit fentanyl/heroin\ndose (IV/IN/smoked)"];
    FentanylCentralPlasma[label="Fentanyl central\nplasma"];
    FentanylPeripheralTissue[label="Fentanyl peripheral\n(lipophilic tissue) compartment"];
    FentanylMOR_HighPotency[label="High-potency\nMOR binding"];
    IllicitSupplyVariability[label="Illicit supply potency\nvariability / adulteration"];
    XylazineCoAdulterant[label="Xylazine\nco-adulterant"];
    CarfentanilAnalogRisk[label="Fentanyl-analog\n(carfentanil) risk"];
    FentanylDose_IV_IN -> FentanylCentralPlasma;
    FentanylCentralPlasma -> FentanylPeripheralTissue [dir=both, label="rapid\nredistribution"];
    FentanylCentralPlasma -> FentanylMOR_HighPotency -> MOR;
    IllicitSupplyVariability -> FentanylDose_IV_IN [style=dashed, label="unpredictable\npotency"];
    XylazineCoAdulterant -> Hypoventilation [style=dashed, label="non-opioid sedation,\nnaloxone-refractory"];
    CarfentanilAnalogRisk -> FentanylMOR_HighPotency [style=dashed, label="~100x fentanyl\npotency"];
  }

  /* ───────────────────────── 8. Methadone PK/PD ───────────────────────────── */
  subgraph cluster_methadone {
    label="8. Drug PK/PD — Methadone (Full Agonist, MMT)";
    style="filled,rounded"; color="#5c6370"; fillcolor="#e6fff2"; fontsize=12;
    MethadoneOralDose  [label="Oral methadone\ndose (MMT clinic)"];
    MethadoneGutAbsorp [label="Methadone gut\nabsorption"];
    MethadonePlasmaLongT12[label="Methadone plasma\n(long t1/2, 8-59h)"];
    CYP3A4_2B6_Metab   [label="CYP3A4/CYP2B6\nmetabolism (variable)"];
    MethadoneMOR_FullAg[label="Methadone MOR\nfull-agonist occupancy"];
    MethadonehERG_Block[label="Methadone hERG\nchannel block"];
    QTcProlongation    [label="QTc\nprolongation"];
    TorsadesRiskMeth   [label="Torsades de pointes\nrisk"];
    MethadoneNMDA_Antag[label="Methadone NMDA\nreceptor antagonism"];
    MethadoneOralDose -> MethadoneGutAbsorp -> MethadonePlasmaLongT12;
    CYP3A4_2B6_Metab -> MethadonePlasmaLongT12 [style=dashed, label="genetic/drug-interaction\nvariability"];
    MethadonePlasmaLongT12 -> MethadoneMOR_FullAg -> MOR;
    MethadonePlasmaLongT12 -> MethadonehERG_Block -> QTcProlongation -> TorsadesRiskMeth;
    MethadonePlasmaLongT12 -> MethadoneNMDA_Antag [style=dashed, label="anti-hyperalgesic,\nblunts tolerance"];
  }

  /* ───────────────────────── 9. Buprenorphine PK/PD ───────────────────────── */
  subgraph cluster_buprenorphine {
    label="9. Drug PK/PD — Buprenorphine (±Naloxone; Partial Agonist)";
    style="filled,rounded"; color="#5c6370"; fillcolor="#f2e6ff"; fontsize=12;
    BuprenorphineSLDose[label="Sublingual buprenorphine\n(±naloxone, Suboxone) dose"];
    BuprenorphinePlasma[label="Buprenorphine\nplasma"];
    BuprenorphineXRDepot[label="Extended-release\nSC depot (Sublocade, monthly)"];
    NaloxoneCoformulation[label="Naloxone co-formulation\n(abuse-deterrent)"];
    Bup_MOR_PartialAg  [label="High-affinity, low-\nintrinsic-activity MOR binding"];
    Bup_KOR_Antagonism [label="Buprenorphine KOR\nantagonism"];
    CeilingEffectResp  [label="Ceiling effect on\nrespiratory depression"];
    DisplacementFullAg [label="Competitive displacement\nof full agonist"];
    PrecipitatedWDRisk [label="Precipitated-withdrawal\nrisk (early induction)"];
    BuprenorphineSLDose -> BuprenorphinePlasma;
    BuprenorphineXRDepot -> BuprenorphinePlasma [label="sustained\nmonthly release"];
    NaloxoneCoformulation -> BuprenorphinePlasma [style=dashed, label="negligible SL\nabsorption, IV-abuse deterrent"];
    BuprenorphinePlasma -> Bup_MOR_PartialAg -> MOR [label="high affinity,\nlow intrinsic activity"];
    Bup_MOR_PartialAg -> CeilingEffectResp -> Hypoventilation [style=dashed, label="plateaus — safer\nthan full agonist"];
    Bup_MOR_PartialAg -> DisplacementFullAg -> FentanylMOR_HighPotency [style=dashed, label="competitive\ndisplacement"];
    DisplacementFullAg -> PrecipitatedWDRisk -> COWS_ScoreNode [style=dashed, label="if induced\nbefore adequate\nabstinence"];
    BuprenorphinePlasma -> Bup_KOR_Antagonism -> AntiRewardDysphoria [style=dashed, label="mood\nstabilization"];
  }

  /* ───────────────────────── 10. Naloxone & Naltrexone (Antagonists) ─────── */
  subgraph cluster_antagonist {
    label="10. Drug PK/PD — Naloxone (Acute) & Naltrexone (Sustained Blockade)";
    style="filled,rounded"; color="#5c6370"; fillcolor="#ffe6f0"; fontsize=12;
    NaloxoneDose_IN_IM [label="Naloxone dose\n(IN/IM/auto-injector)"];
    NaloxonePlasmaShortT12[label="Naloxone plasma\n(short t1/2, 30-90 min)"];
    Naloxone_MOR_CompAntag[label="Naloxone competitive\nMOR antagonism"];
    AcuteRespReversal  [label="Acute respiratory-drive\nreversal"];
    RenarcotizationRisk[label="Renarcotization risk\n(t1/2 shorter than agonist)"];
    NaltrexoneOralDaily[label="Oral naltrexone\n(daily)"];
    NaltrexoneXR_IM_Depot[label="Naltrexone XR-IM\ndepot (Vivitrol, monthly)"];
    Naltrexone_MOR_Sustained[label="Sustained MOR\nblockade"];
    OverdoseRiskLostTol[label="Overdose risk after\ntolerance loss (blockade lapse)"];
    NaloxoneDose_IN_IM -> NaloxonePlasmaShortT12 -> Naloxone_MOR_CompAntag -> MOR [label="rapid\ndisplacement"];
    Naloxone_MOR_CompAntag -> AcuteRespReversal -> BrainstemMOR_Resp [style=dashed, label="restores\nventilatory drive"];
    NaloxonePlasmaShortT12 -> RenarcotizationRisk [style=dashed, label="esp. vs long-acting\nfentanyl/methadone"];
    RenarcotizationRisk -> Hypoventilation [style=dashed];
    NaltrexoneOralDaily -> Naltrexone_MOR_Sustained;
    NaltrexoneXR_IM_Depot -> Naltrexone_MOR_Sustained [label="monthly\ndepot"];
    Naltrexone_MOR_Sustained -> MOR [label="near-complete\nblockade"];
    Naltrexone_MOR_Sustained -> OverdoseRiskLostTol [style=dashed, label="abstinence-driven\ntolerance loss"];
    OverdoseRiskLostTol -> FatalOverdoseDeath [style=dashed];
  }

  /* ───────────────────────── 11. Alpha-2 Agonist — Lofexidine/Clonidine ───── */
  subgraph cluster_alpha2 {
    label="11. Drug PK/PD — Lofexidine / Clonidine (α2-Agonist, Symptomatic Rx)";
    style="filled,rounded"; color="#5c6370"; fillcolor="#fff4d6"; fontsize=12;
    LofexidineOralDose [label="Oral lofexidine/\nclonidine dose"];
    LofexidinePlasma   [label="Lofexidine\nplasma"];
    Alpha2_PresynLC    [label="α2-adrenoceptor\n(presynaptic, LC)"];
    LC_NE_ReleaseInhib [label="LC noradrenergic\nrelease inhibition"];
    WithdrawalSympRelief[label="Autonomic withdrawal-\nsymptom relief"];
    HypotensionAE_Lofex[label="Hypotension /\nsedation (AE)"];
    LofexidineOralDose -> LofexidinePlasma -> Alpha2_PresynLC -> LC_NE_ReleaseInhib;
    LC_NE_ReleaseInhib -> LC_ReboundHyperact [style=dashed, label="dampens\nnoradrenergic surge"];
    LC_NE_ReleaseInhib -> WithdrawalSympRelief -> COWS_ScoreNode [style=dashed, label="↓ autonomic\nsymptoms"];
    Alpha2_PresynLC -> HypotensionAE_Lofex [style=dashed];
  }

  /* ───────────────────────── 12. Craving, Relapse & Behavioral Therapy ────── */
  subgraph cluster_craving {
    label="12. Craving, Relapse & Behavioral/Psychosocial Therapy";
    style="filled,rounded"; color="#5c6370"; fillcolor="#e6ffe9"; fontsize=12;
    CueReactivity      [label="Drug-cue\nreactivity"];
    StressInducedCraving[label="Stress-induced\ncraving"];
    PFC_ImpairedControl[label="Chronic-use impaired\nprefrontal control"];
    CravingVAS         [label="Craving VAS\nscore"];
    ReturnToUseRelapse [label="Return to use /\nrelapse"];
    TreatmentRetentionIdx[label="Treatment-retention\nindex"];
    ContingencyManagement[label="Contingency-management\nincentives"];
    CounselingPsychosocial[label="Counseling /\npsychosocial therapy"];
    DrugMemoryConsolid -> CueReactivity;
    HPA_CRF_Activation -> StressInducedCraving [style=dashed];
    PFC_ExecutiveControl -> PFC_ImpairedControl [style=dashed, label="chronic use\nimpairs"];
    CueReactivity -> CravingVAS;
    StressInducedCraving -> CravingVAS;
    PFC_ImpairedControl -> CravingVAS [style=dashed];
    CravingVAS -> ReturnToUseRelapse;
    ReturnToUseRelapse -> FatalOverdoseDeath [style=dashed, label="tolerance loss +\nreturn to use"];
    ContingencyManagement -> TreatmentRetentionIdx;
    CounselingPsychosocial -> TreatmentRetentionIdx;
    TreatmentRetentionIdx -> ReturnToUseRelapse [style=dashed, label="↓ risk"];
  }

  /* ───────────────────────── 13. Comorbidity, Harm Reduction & Biomarkers ─── */
  subgraph cluster_comorbid {
    label="13. Comorbidity, Harm Reduction & Biomarkers";
    style="filled,rounded"; color="#5c6370"; fillcolor="#fafafa"; fontsize=12;
    IVInjectionPractice[label="Injection drug\nuse practice"];
    HIVTransmissionRisk[label="HIV transmission\nrisk"];
    HCVTransmissionRisk[label="HCV transmission\nrisk"];
    InfectiveEndocarditisRisk[label="Infective endocarditis\nrisk"];
    NeedleExchangeHR   [label="Needle/syringe exchange\n(harm reduction)"];
    FentanylTestStrips [label="Fentanyl test\nstrips"];
    UrineDrugScreenBiomk[label="Urine drug screen\nbiomarker"];
    NaloxoneDistribProgram[label="Community naloxone\ndistribution program"];
    BenzodiazepineCoUse[label="Benzodiazepine\nco-use"];
    SynergisticCNSDepress[label="Synergistic CNS/\nrespiratory depression"];
    OUD_MortalityRate  [label="OUD-attributable\nmortality rate"];
    IVInjectionPractice -> HIVTransmissionRisk;
    IVInjectionPractice -> HCVTransmissionRisk;
    IVInjectionPractice -> InfectiveEndocarditisRisk;
    NeedleExchangeHR -> IVInjectionPractice [style=dashed, label="↓ transmission\nrisk"];
    FentanylTestStrips -> IllicitSupplyVariability [style=dashed, label="risk\nawareness"];
    NaloxoneDistribProgram -> NaloxoneDose_IN_IM [style=dashed, label="community\naccess/bystander use"];
    BenzodiazepineCoUse -> SynergisticCNSDepress -> Hypoventilation [style=dashed, label="additive\nrespiratory depression"];
    CravingVAS -> UrineDrugScreenBiomk [style=dashed];
    FatalOverdoseDeath -> OUD_MortalityRate;
    ReturnToUseRelapse -> OUD_MortalityRate [style=dashed];
  }
}
