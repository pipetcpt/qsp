digraph FSGS_QSP {
    graph [rankdir=TB, compound=true, nodesep=0.35, ranksep=0.55,
           fontname="Helvetica", fontsize=20,
           label="FSGS QSP Mechanistic Map\nFocal Segmental Glomerulosclerosis — Complete Pathophysiology & Pharmacology",
           labelloc=t, bgcolor="#FAFAFA"]
    node [fontname="Helvetica", fontsize=9, style=filled]
    edge [fontname="Helvetica", fontsize=7]

    // ─────────────────────────────────────────────────────────────────────
    // CLUSTER 1: Etiology & Pathogenesis Triggers
    // ─────────────────────────────────────────────────────────────────────
    subgraph cluster_etiology {
        label="① Etiology & Pathogenesis Triggers"
        style=filled; fillcolor="#FFF0F0"; color="#CC4444"; penwidth=2

        Primary     [label="Primary FSGS\n(Idiopathic)", shape=diamond, fillcolor="#FF8888"]
        Secondary   [label="Secondary FSGS\n(Adaptive)", shape=diamond, fillcolor="#FF8888"]
        Genetic     [label="Genetic FSGS\n(Monogenic)", shape=diamond, fillcolor="#FF8888"]

        CLCF1       [label="CLCF1\n(Cardiotrophin-Like\nCytokine Factor 1)", fillcolor="#FFAAAA"]
        AntiCD40    [label="Anti-CD40\nAutoAntibody", fillcolor="#FFAAAA"]
        sUPAR       [label="suPAR\n(Soluble uPAR)\n↑ integrin αvβ3", fillcolor="#FFAAAA"]
        PermFactor  [label="Circulating\nPermeability\nFactor (CPF)", fillcolor="#FF9999", shape=ellipse, penwidth=2]

        Hyperfiltration [label="Hyperfiltration\n(Obesity/CKD/DM)", fillcolor="#FFD0D0"]
        NephronLoss [label="Nephron Loss\n(Reduced Mass)", fillcolor="#FFD0D0"]
        Drug_Toxin  [label="Drug/Toxin\n(Heroin, IFN-α,\nBisphosphonates)", fillcolor="#FFD0D0"]
        HIV_FSGS    [label="HIV-Associated\nFSGS (HIVAN)", fillcolor="#FFCCCC"]
        Obesity_FSGS[label="Obesity-Related\nFSGS (ORG)", fillcolor="#FFCCCC"]
    }

    // ─────────────────────────────────────────────────────────────────────
    // CLUSTER 2: Genetic & Molecular Determinants
    // ─────────────────────────────────────────────────────────────────────
    subgraph cluster_genetic {
        label="② Genetic & Molecular Mechanisms"
        style=filled; fillcolor="#FFFAF0"; color="#886600"; penwidth=2

        NPHS1       [label="NPHS1 Mutation\n(Nephrin Gene)", fillcolor="#EEBB88", shape=hexagon]
        NPHS2       [label="NPHS2 Mutation\n(Podocin Gene)", fillcolor="#EEBB88", shape=hexagon]
        INF2        [label="INF2 Mutation\n(Inverted Formin 2)", fillcolor="#EEBB88", shape=hexagon]
        WT1         [label="WT1 Mutation\n(Transcription\nFactor)", fillcolor="#EEBB88", shape=hexagon]
        TRPC6       [label="TRPC6 Mutation\n(Ca²⁺ Channel)", fillcolor="#EEBB88", shape=hexagon]
        CD2AP_gene  [label="CD2AP Mutation\n(Adaptor Protein)", fillcolor="#EEBB88", shape=hexagon]
        APOL1_gene  [label="APOL1 G1/G2\nRisk Variants\n(West African)", fillcolor="#FFDD88", shape=hexagon]

        APOL1_pore  [label="APOL1 Protein\nToxic Oligomers\n(Pore Formation)", fillcolor="#DDAA66"]
        Lysosome_D  [label="Lysosomal\nDysfunction", fillcolor="#EEBB77"]
        miRNA193a   [label="miR-193a\n(WT1 Repressor)", fillcolor="#DDCCAA"]
        EpigenMod   [label="Epigenetic\nModifications\n(H3K27me3)", fillcolor="#DDCCBB"]
    }

    // ─────────────────────────────────────────────────────────────────────
    // CLUSTER 3: Podocyte Biology & Injury
    // ─────────────────────────────────────────────────────────────────────
    subgraph cluster_podocyte {
        label="③ Podocyte Biology & Injury"
        style=filled; fillcolor="#FFF5E6"; color="#CC7700"; penwidth=2

        Podocyte    [label="Podocyte\n(Terminally\nDifferentiated)", shape=ellipse, fillcolor="#FFD080", penwidth=3]
        Nephrin     [label="Nephrin\n(Slit Diaphragm\nStructure)", fillcolor="#FFE8AA"]
        Podocin     [label="Podocin\n(Lipid Raft\nScaffold)", fillcolor="#FFE8AA"]
        Synaptopodin[label="Synaptopodin\n(Actin Regulator)", fillcolor="#FFE8AA"]
        CD2AP       [label="CD2AP\n(Adaptor Protein)", fillcolor="#FFE8AA"]
        AlphaActinin[label="α-Actinin-4\n(Actin Crosslinker)", fillcolor="#FFDD99"]

        FPE         [label="Foot Process\nEffacement (FPE)", fillcolor="#FFCC66", shape=box, penwidth=3]
        ActinCyto   [label="Actin\nCytoskeleton\nRemodeling", fillcolor="#FFD080"]
        betaInt     [label="β3 Integrin\nActivation\n(CPF target)", fillcolor="#FFD0A0"]

        Pod_Apoptosis[label="Podocyte\nApoptosis\n(Caspase-3↑)", fillcolor="#FF9944"]
        Pod_Detach  [label="Podocyte\nDetachment\n(Matrix release)", fillcolor="#FF9944"]
        Pod_Loss    [label="Podocyte\nDepletion", fillcolor="#FF6600", shape=box, penwidth=3]
        Pod_Hyp     [label="Podocyte\nHypertrophy\n(Compensatory)", fillcolor="#FFD080"]
        PEC_Act     [label="PEC Activation\n(Parietal Epithelial\nCell)", fillcolor="#FFCC88"]
    }

    // ─────────────────────────────────────────────────────────────────────
    // CLUSTER 4: Glomerular Filtration Barrier
    // ─────────────────────────────────────────────────────────────────────
    subgraph cluster_barrier {
        label="④ Glomerular Filtration Barrier"
        style=filled; fillcolor="#F0FFF0"; color="#006600"; penwidth=2

        SlitDiaphragm[label="Slit Diaphragm\n(Size/Charge\nBarrier)", shape=ellipse, fillcolor="#88DD88", penwidth=3]
        GBM         [label="Glomerular\nBasement\nMembrane (GBM)", fillcolor="#AAFFAA"]
        GEndoth     [label="Glomerular\nEndothelium\n(Fenestrated)", fillcolor="#AAFFAA"]
        Glycocalyx  [label="Endothelial\nGlycocalyx\n(Heparan sulfate)", fillcolor="#CCFFCC"]

        Proteinuria [label="Proteinuria\n(g/day)", fillcolor="#FF8888", shape=box, penwidth=4]
        Nephrotic   [label="Nephrotic Syndrome\n(>3.5 g/day +\nHypoAlb + Edema)", fillcolor="#FF4444", shape=box, penwidth=2]
        AlbPlasma   [label="Plasma Albumin\n(Hypoalbuminemia)", fillcolor="#FFAAAA"]
        Edema       [label="Edema\n(Oncotic pressure↓)", fillcolor="#FFCCCC"]
        Hematuria   [label="Microscopic\nHematuria", fillcolor="#FFBBBB"]

        GFR         [label="eGFR\n(mL/min/1.73m²)", fillcolor="#FF7755", shape=box, penwidth=4]
        eGFR_Dec    [label="Progressive\neGFR Decline\n(8-15 mL/min/yr)", fillcolor="#FF5533"]
        ESRD        [label="ESRD\n(End-Stage\nRenal Disease)", fillcolor="#CC2222", shape=box, fontcolor=white, penwidth=4]
    }

    // ─────────────────────────────────────────────────────────────────────
    // CLUSTER 5: TGF-β & Fibrosis Pathway
    // ─────────────────────────────────────────────────────────────────────
    subgraph cluster_fibrosis {
        label="⑤ TGF-β / Fibrosis Pathway"
        style=filled; fillcolor="#F5F0FF"; color="#550088"; penwidth=2

        TGFb1       [label="TGF-β1\n(Master Fibrosis\nCytokine)", fillcolor="#CC88FF", penwidth=2]
        TGFbR       [label="TGFβR-I/II\n(ALK5 / TβRII)", fillcolor="#DDAAFF"]
        SMAD2_3     [label="SMAD2/3\nPhosphorylation", fillcolor="#DDAAFF"]
        SMAD4       [label="SMAD4\nNuclear Complex", fillcolor="#DDAAFF"]
        SMAD7       [label="SMAD7\n(Negative\nFeedback)", fillcolor="#EED0FF"]

        ECM_Prod    [label="ECM Production\n(Fibronectin,\nCollagen IV)", fillcolor="#BB77EE"]
        TIMP1       [label="TIMP-1 Upregulation\n(MMP Inhibition)", fillcolor="#BB77EE"]
        Collagen1   [label="Collagen I/III\n(Interstitial)", fillcolor="#CC99FF"]

        MesCells    [label="Activated\nMesangial Cells\n(Matrix Producing)", fillcolor="#BB88DD"]
        MesExpansion[label="Mesangial\nExpansion", fillcolor="#CCAAFF"]

        Sclerosis   [label="Glomerular\nSclerosis (%)\n(Near-Irreversible)", fillcolor="#884499", shape=box, fontcolor=white, penwidth=4]
        TubAtr      [label="Tubular Atrophy\n& IF/TA", fillcolor="#AA66CC"]
        CrescFib    [label="Fibrous Crescent\n(PEC-derived)", fillcolor="#BB77CC"]
    }

    // ─────────────────────────────────────────────────────────────────────
    // CLUSTER 6: Complement & Glomerular Inflammation
    // ─────────────────────────────────────────────────────────────────────
    subgraph cluster_complement {
        label="⑥ Complement & Glomerular Inflammation"
        style=filled; fillcolor="#FFF0F8"; color="#AA0055"; penwidth=2

        C3          [label="C3 Complement\n(Classical/\nAlternative)", fillcolor="#FF88CC"]
        C3b         [label="C3b\nDeposition\n(GBM)", fillcolor="#FFAADD"]
        C5a         [label="C5a\nAnaphylatoxin", fillcolor="#FF66BB"]
        C5b9_MAC    [label="C5b-9 (MAC)\nMembrane Attack\nComplex", fillcolor="#FF4499", penwidth=2]

        MCP1        [label="MCP-1/CCL2\n(Monocyte Chemoattractant)", fillcolor="#FFBBEE"]
        Macrophage  [label="Glomerular\nMacrophage\nInfiltration (M1/M2)", fillcolor="#FF88CC"]
        Neutrophil  [label="Neutrophil\nInfiltration", fillcolor="#FFBBEE"]

        IL6         [label="IL-6\n(Barrier Disruption)", fillcolor="#FF99DD"]
        TNFa        [label="TNF-α\n(NF-κB Activation)", fillcolor="#FF99DD"]
        IL1b        [label="IL-1β\n(Inflammasome\nNLRP3)", fillcolor="#FF99DD"]

        NFkB        [label="NF-κB\nActivation", fillcolor="#FF77CC", penwidth=2]
        ROS         [label="Reactive Oxygen\nSpecies (ROS)\nOxidative Stress", fillcolor="#FFAABB"]
        NLRP3       [label="NLRP3\nInflammasome", fillcolor="#FF88BB"]
    }

    // ─────────────────────────────────────────────────────────────────────
    // CLUSTER 7: mTOR / Autophagy / Mitochondria
    // ─────────────────────────────────────────────────────────────────────
    subgraph cluster_mtor {
        label="⑦ mTOR / Autophagy / Mitochondria"
        style=filled; fillcolor="#F0FFFF"; color="#006688"; penwidth=2

        mTORC1      [label="mTORC1\n(Nutrient/Growth\nSensor)", fillcolor="#66CCDD", penwidth=2]
        mTORC2      [label="mTORC2\n(Actin/AKT\nRegulator)", fillcolor="#88DDEE"]
        S6K1        [label="S6K1\nPhosphorylation\n(Protein Synthesis)", fillcolor="#AAEEFF"]
        FourEBP1    [label="4E-BP1\n(Translation\nInhibitor)", fillcolor="#AAEEFF"]

        Autophagy   [label="Podocyte Autophagy\n(Pro-Survival\nPathway)", fillcolor="#66BBCC"]
        Mitophagy   [label="Mitophagy\n(Damaged Mito.\nClearance)", fillcolor="#88CCDD"]
        Mitochond   [label="Mitochondrial\nDysfunction\n(ΔΨm↓)", fillcolor="#FFCCAA"]
        ATPdeficit  [label="ATP Deficit\n(Energy Failure)", fillcolor="#FFAA88"]

        AMPK        [label="AMPK\n(Energy Sensor\nActivation)", fillcolor="#AADDCC"]
        PI3K_AKT    [label="PI3K/AKT\nSignaling", fillcolor="#88CCAA"]
        PTEN        [label="PTEN\n(PI3K Suppressor)", fillcolor="#BBDDBB"]
        Nrf2        [label="Nrf2\n(Antioxidant\nResponse)", fillcolor="#66BBAA", penwidth=2]
    }

    // ─────────────────────────────────────────────────────────────────────
    // CLUSTER 8: RAAS & Glomerular Hemodynamics
    // ─────────────────────────────────────────────────────────────────────
    subgraph cluster_raas {
        label="⑧ RAAS & Glomerular Hemodynamics"
        style=filled; fillcolor="#FFFFF0"; color="#888800"; penwidth=2

        Renin       [label="Renin\n(JGA Release)", fillcolor="#EEEE88"]
        AngI        [label="Angiotensin I", fillcolor="#EEEEAA"]
        ACE_enz     [label="ACE\n(Pulmonary/Local)", fillcolor="#DDDD88"]
        AngII       [label="Angiotensin II\n(AT1R Agonist)", fillcolor="#CCCC55", penwidth=2]
        AT1R        [label="AT1R\n(Efferent Vasoconstriction\n+ Aldosterone)", fillcolor="#AAAA44"]
        Aldosterone [label="Aldosterone\n(Sodium Retention\nFibrosis)", fillcolor="#EEEE88"]

        GlomHTN     [label="Intraglomerular\nHypertension\n(↑ Pgc)", fillcolor="#DDDD66", penwidth=2]
        EfConst     [label="Efferent Arteriole\nConstriction", fillcolor="#CCCC77"]
        AfDil       [label="Afferent Arteriole\nDilation\n(Prostaglandin)", fillcolor="#CCCC77"]

        ET1         [label="Endothelin-1\n(ET-A/B Receptor)", fillcolor="#EECC55"]
        ET_A        [label="ET-A Receptor\n(Vasoconstriction\n+ Fibrosis)", fillcolor="#DDAA44"]

        VEGF_pod    [label="Podocyte VEGF-A\n(Endothelial\nSupport)", fillcolor="#CCFF88"]
        Prostaglandin[label="Prostaglandin E2\n(Afferent Dilation)", fillcolor="#EEFF99"]
    }

    // ─────────────────────────────────────────────────────────────────────
    // CLUSTER 9: Drug PK — First-Line (Steroids & CNI)
    // ─────────────────────────────────────────────────────────────────────
    subgraph cluster_pk1 {
        label="⑨ Drug PK — First-Line (Corticosteroids, CNI)"
        style=filled; fillcolor="#F0F8FF"; color="#003388"; penwidth=2

        PRED_dep    [label="Prednisolone\nDepot (Oral\nAbsorption)", fillcolor="#CCDDFF"]
        PRED1       [label="Prednisolone\nCentral C1\n(Vd=30L)", fillcolor="#88AAFF"]
        PRED2       [label="Prednisolone\nPeripheral C2\n(Vd=45L)", fillcolor="#AACCFF"]

        TAC_dep     [label="Tacrolimus\nDepot (Oral)", fillcolor="#BBCCFF"]
        TAC1        [label="Tacrolimus\nCentral C1\n(Vd=85L)", fillcolor="#6688FF"]
        TAC2        [label="Tacrolimus\nPeripheral C2\n(Vd=150L)", fillcolor="#88AAFF"]

        MMF_dep     [label="MMF/MPA Depot\n(Oral\nMycophenolate)", fillcolor="#AABBFF"]
        MMF1        [label="MPA Central\n(Immunosuppressant)", fillcolor="#99AAEE"]
    }

    // ─────────────────────────────────────────────────────────────────────
    // CLUSTER 10: Drug PK — Second-Line / Novel
    // ─────────────────────────────────────────────────────────────────────
    subgraph cluster_pk2 {
        label="⑩ Drug PK — Novel / Second-Line"
        style=filled; fillcolor="#F0FFF8"; color="#004422"; penwidth=2

        RTX1        [label="Rituximab\nCentral C1\n(Vd=3.1L)", fillcolor="#66CC99"]
        RTX2        [label="Rituximab\nPeripheral C2\n(Vd=1.7L)", fillcolor="#88DDAA"]

        SPARS_dep   [label="Sparsentan\nDepot (Oral 800mg\nQD FDA 2023)", fillcolor="#44BB88"]
        SPARS1      [label="Sparsentan\nCentral C1\n(AT1R+ETR Dual)", fillcolor="#44BB88", penwidth=2]
        SPARS2      [label="Sparsentan\nPeripheral C2", fillcolor="#66CC99"]

        VOCLO1      [label="Voclosporin\nCentral\n(Novel CNI)", fillcolor="#88CCBB"]
        ActharGel   [label="Acthar Gel\n(ACTH Analogue)\nDirect Podocyte", fillcolor="#66BBAA"]
    }

    // ─────────────────────────────────────────────────────────────────────
    // CLUSTER 11: Drug PD Mechanisms
    // ─────────────────────────────────────────────────────────────────────
    subgraph cluster_pd {
        label="⑪ Drug Pharmacodynamic Mechanisms"
        style=filled; fillcolor="#FFFBF0"; color="#884400"; penwidth=2

        GR_act      [label="GR\n(Glucocorticoid\nReceptor)", fillcolor="#FFCC88"]
        GR_pod_eff  [label="Direct Podocyte\nGR Effect\n(Actin Stabilization)", fillcolor="#FFBB77"]
        GRtransrep  [label="GR\nTransrepression\n(NF-κB↓, AP-1↓)", fillcolor="#FFAA66"]

        Calcineurin  [label="Calcineurin\nInhibition\n(CNI target)", fillcolor="#FFAA66"]
        NFAT         [label="NFAT\n(Nuclear Block\n→ Synap↑)", fillcolor="#FFBB88"]
        SynapStab    [label="Synaptopodin\nStabilization\n(Actin protection)", fillcolor="#FFCC99"]

        CD20_B      [label="CD20\n(B Cell Marker\nRTX target)", fillcolor="#88FFBB"]
        Bcell_depl  [label="B Cell Depletion\n→ CPF Reduction\n→ CLCF1↓, suPAR↓", fillcolor="#66DDAA"]

        AT1R_block  [label="AT1R Blockade\n(Sparsentan)\nAngII inhibition", fillcolor="#66BBAA"]
        ETR_block   [label="ET-A/B Blockade\n(Sparsentan)\nEndothelin inhib.", fillcolor="#66BBAA"]

        MC_receptor [label="Melanocortin\nMC1R/MC5R\n(Acthar target)", fillcolor="#FFDDAA"]
        Nrf2_drug   [label="Nrf2 Activation\n(Bardoxolone)\nAntioxidant pathway", fillcolor="#88CCAA"]
        mTOR_drug   [label="mTOR Inhibition\n(Sirolimus\nControversial)", fillcolor="#AADDFF"]
    }

    // ─────────────────────────────────────────────────────────────────────
    // CLUSTER 12: Clinical Endpoints & Biomarkers
    // ─────────────────────────────────────────────────────────────────────
    subgraph cluster_outcomes {
        label="⑫ Clinical Endpoints & Biomarkers"
        style=filled; fillcolor="#F8FFF0"; color="#446600"; penwidth=2

        UPCR        [label="UPCR\n(Urine Protein:\nCreatinine Ratio)", fillcolor="#AAFFAA", shape=box, penwidth=3]
        CR          [label="Complete Remission\nUPCR <0.3 g/g\n(≤0.3 g/day prot)", fillcolor="#55DD55", shape=box, penwidth=3]
        PR          [label="Partial Remission\n≥50% UPCR ↓\n& UPCR <3.5", fillcolor="#88EE88", shape=box, penwidth=2]

        SCreat      [label="Serum Creatinine\n(μmol/L)", fillcolor="#CCFF88"]
        CystC       [label="Cystatin C\n(Early GFR\nMarker)", fillcolor="#CCFF88"]

        suPAR_bio   [label="Serum suPAR\n(Biomarker &\nPathogenic)", fillcolor="#FFCCAA"]
        PodocalyxinU[label="Urine Podocalyxin\n(Podocyte Injury\nMarker)", fillcolor="#AAFFCC"]
        NephrinU    [label="Urine Nephrin\n(Slit Diaphragm\nDamage)", fillcolor="#AAFFCC"]
        WILMS1_U    [label="Urine WT1 mRNA\n(Podocyte\nDetachment)", fillcolor="#BBFFCC"]

        BiopsyFSGS  [label="Kidney Biopsy\nFSGS Lesion\n(Columbia Class.)", fillcolor="#DDFFAA"]
        KFRE        [label="KFRE\n(Kidney Failure\nRisk Equation)", fillcolor="#CCFF88"]
        Dialysis    [label="Dialysis /\nKidney Transplant", fillcolor="#FF8866"]
    }

    // ═══════════════════════════════════════════════════════════════════
    // EDGES
    // ═══════════════════════════════════════════════════════════════════

    // Etiology → Permeability factors
    Primary -> CLCF1 [label="produces"]
    Primary -> AntiCD40 [label="autoimmune"]
    Primary -> sUPAR [label="unknown source"]
    CLCF1 -> PermFactor [label="contributes"]
    AntiCD40 -> PermFactor
    sUPAR -> PermFactor

    // Secondary FSGS triggers
    Secondary -> Hyperfiltration [label="main driver"]
    Secondary -> NephronLoss
    Secondary -> Drug_Toxin
    Secondary -> HIV_FSGS
    Secondary -> Obesity_FSGS
    Hyperfiltration -> AfDil [label="prostaglandin↑"]
    NephronLoss -> Hyperfiltration [label="remaining\nnephrons compensate"]
    Obesity_FSGS -> Hyperfiltration [label="↑ cardiac output"]

    // Genetic triggers → molecular effects
    Genetic -> NPHS1
    Genetic -> NPHS2
    Genetic -> INF2
    Genetic -> WT1
    Genetic -> TRPC6
    Genetic -> CD2AP_gene
    Genetic -> APOL1_gene
    APOL1_gene -> APOL1_pore [label="oligomerization"]
    APOL1_pore -> Lysosome_D [label="disrupts"]
    APOL1_pore -> Podocyte [label="direct cytotoxicity"]
    NPHS1 -> Nephrin [label="encodes"]
    NPHS2 -> Podocin [label="encodes"]
    INF2 -> ActinCyto [label="actin\ndynamics disrupted"]
    TRPC6 -> Podocyte [label="Ca²⁺ overload"]
    CD2AP_gene -> CD2AP [label="encodes"]
    WT1 -> miRNA193a [label="regulates"]
    miRNA193a -> Podocyte [label="dedifferentiation"]
    EpigenMod -> Podocyte [label="epigenetic silencing"]

    // Circulating factors → podocyte
    PermFactor -> betaInt [label="activates αvβ3\nintegrin signaling"]
    betaInt -> ActinCyto [label="downstream\nkinase cascade"]
    sUPAR -> betaInt [label="direct binding"]

    // Podocyte components
    Nephrin -> SlitDiaphragm [label="structural"]
    Podocin -> SlitDiaphragm [label="structural"]
    Synaptopodin -> ActinCyto [label="stabilizes\nstress fibers"]
    CD2AP -> Nephrin [label="scaffolds"]
    AlphaActinin -> ActinCyto [label="crosslinks F-actin"]

    ActinCyto -> FPE [label="disruption →\neffacement"]
    FPE -> SlitDiaphragm [label="disrupts barrier", arrowhead=tee]

    Pod_Apoptosis -> Pod_Loss [label="programmed death"]
    Pod_Detach -> Pod_Loss [label="mechanical loss"]
    Podocyte -> Pod_Apoptosis [label="injury\ntriggers"]
    Podocyte -> Pod_Detach [label="matrix\ndetachment"]
    Pod_Loss -> Pod_Hyp [label="compensatory\nhypertrophy"]
    PEC_Act -> CrescFib [label="fibrous crescent\nformation"]
    PEC_Act -> Sclerosis [label="contributes"]

    // Filtration barrier → clinical manifestations
    SlitDiaphragm -> Proteinuria [label="loss →\nalbumin leak", arrowhead=tee]
    GBM -> Proteinuria [label="charge barrier\nloss", arrowhead=tee]
    Glycocalyx -> Proteinuria [label="breakdown", arrowhead=tee]
    Pod_Loss -> Proteinuria [label="denuded GBM", arrowhead=tee]

    Proteinuria -> Nephrotic [label="severe (>3.5g/d)"]
    Nephrotic -> AlbPlasma [label="hypoalbuminemia", arrowhead=tee]
    AlbPlasma -> Edema [label="oncotic pressure↓"]
    FPE -> Hematuria [label="barrier disruption"]

    Sclerosis -> GFR [label="nephron loss", arrowhead=tee]
    GFR -> eGFR_Dec [label="progressive"]
    eGFR_Dec -> ESRD [label="end-stage"]
    ESRD -> Dialysis [label="requires RRT"]

    // TGF-β fibrosis cascade
    TGFb1 -> TGFbR [label="binds receptor"]
    TGFbR -> SMAD2_3 [label="phosphorylation"]
    SMAD2_3 -> SMAD4 [label="heterocomplex"]
    SMAD4 -> ECM_Prod [label="transcription\nactivation"]
    SMAD4 -> TIMP1 [label="upregulates"]
    SMAD7 -> SMAD2_3 [label="negative feedback", arrowhead=tee]
    ECM_Prod -> Sclerosis [label="matrix\naccumulation"]
    TIMP1 -> Sclerosis [label="MMP inhibition\n→ matrix retention"]
    ECM_Prod -> Collagen1 [label="produces"]
    Collagen1 -> TubAtr [label="interstitial fibrosis"]
    MesCells -> ECM_Prod [label="activated\nproduces ECM"]
    MesExpansion -> Sclerosis [label="contributes"]
    Sclerosis -> TubAtr [label="tubular atrophy"]
    AngII -> TGFb1 [label="induces\n(AT1R→SMAD)", style=bold]

    // Complement & inflammation
    C3 -> C3b [label="convertase\ncleavage"]
    C3b -> C5b9_MAC [label="C5 activation →\nMAC assembly"]
    C3b -> C5a [label="anaphylatoxin\nreleased"]
    C5b9_MAC -> Podocyte [label="sublytic\ninjury"]
    C5b9_MAC -> FPE [label="cytoskeletal\ndisruption"]
    C5a -> Macrophage [label="recruitment"]
    Macrophage -> MCP1 [label="secretes"]
    Macrophage -> IL6 [label="secretes"]
    Macrophage -> TNFa [label="secretes"]
    Macrophage -> NFkB [label="activates"]
    NFkB -> IL1b [label="induces"]
    NFkB -> TGFb1 [label="induces", style=dashed]
    NFkB -> ROS [label="NOX activation"]
    NLRP3 -> IL1b [label="processes"]
    IL6 -> Proteinuria [label="barrier disruption\n(claudin downreg)", style=dashed]
    TNFa -> Podocyte [label="direct injury\n(apoptosis)", style=dashed]
    ROS -> Podocyte [label="oxidative\ndamage"]
    Neutrophil -> ROS [label="respiratory burst"]
    MCP1 -> Macrophage [label="amplifies\nrecruitment", constraint=false]

    // mTOR / autophagy
    PI3K_AKT -> mTORC1 [label="activates"]
    PTEN -> PI3K_AKT [label="inhibits", arrowhead=tee]
    AMPK -> mTORC1 [label="inhibits (energy)", arrowhead=tee]
    mTORC1 -> S6K1 [label="phosphorylates"]
    mTORC1 -> FourEBP1 [label="phosphorylates\n(hyperactivity harmful)"]
    mTORC1 -> Autophagy [label="inhibits\n(blocks\nsurvival)", arrowhead=tee]
    mTORC2 -> ActinCyto [label="actin\norganization"]
    Autophagy -> Pod_Apoptosis [label="prevents", arrowhead=tee]
    Autophagy -> Mitophagy [label="includes"]
    Mitochond -> ATPdeficit [label="energy failure"]
    ATPdeficit -> Pod_Apoptosis [label="bioenergetic\ndeath"]
    Nrf2 -> ROS [label="antioxidant\ngenes↑", arrowhead=tee]
    Lysosome_D -> Autophagy [label="blocks flux", arrowhead=tee]

    // RAAS & hemodynamics
    Renin -> AngI [label="cleaves\nangiotensinogen"]
    AngI -> AngII [label="ACE cleavage"]
    ACE_enz -> AngII [label="converts"]
    AngII -> AT1R [label="agonist\nbinding"]
    AT1R -> EfConst [label="vasoconstriction"]
    AT1R -> Aldosterone [label="stimulates"]
    EfConst -> GlomHTN [label="↑ hydrostatic\npressure"]
    AfDil -> GlomHTN [label="↑ perfusion\npressure"]
    GlomHTN -> GBM [label="mechanical\nstress"]
    GlomHTN -> Podocyte [label="shear stress\ninjury"]
    Aldosterone -> ROS [label="mineralocorticoid\neffect"]
    Aldosterone -> TGFb1 [label="promotes fibrosis", style=dashed]
    ET1 -> ET_A [label="activates"]
    ET_A -> EfConst [label="vasoconstriction"]
    ET_A -> TGFb1 [label="induces fibrosis"]
    VEGF_pod -> GEndoth [label="endothelial\nsurvival support"]
    GEndoth -> Glycocalyx [label="produces/maintains"]
    Prostaglandin -> AfDil [label="vasodilation"]

    // Drug PK flows
    PRED_dep -> PRED1 [label="ka=2/h\nF=0.82"]
    PRED1 -> PRED2 [label="distribution\nQ=8 L/h", dir=both, style=dashed]

    TAC_dep -> TAC1 [label="ka=0.4/h"]
    TAC1 -> TAC2 [label="distribution", dir=both, style=dashed]

    RTX1 -> RTX2 [label="distribution\nQ=0.012 L/h", dir=both, style=dashed]

    SPARS_dep -> SPARS1 [label="ka=1.2/h"]
    SPARS1 -> SPARS2 [label="distribution", dir=both, style=dashed]

    MMF_dep -> MMF1 [label="absorption"]

    // Drug PD mechanisms
    PRED1 -> GR_act [label="binds GR\n(Cmax→EC50)"]
    PRED1 -> GR_pod_eff [label="direct\npodocyte GR"]
    GR_act -> GRtransrep [label="nuclear\ntranslocation"]
    GRtransrep -> NFkB [label="transrepresses", arrowhead=tee]
    GRtransrep -> TGFb1 [label="suppresses", arrowhead=tee]
    GR_pod_eff -> ActinCyto [label="stabilizes\nstress fibers"]
    GR_pod_eff -> Synaptopodin [label="upregulates"]
    GR_pod_eff -> FPE [label="reverses", arrowhead=tee]

    TAC1 -> Calcineurin [label="inhibits\n(FKBP12\ncomplex)"]
    VOCLO1 -> Calcineurin [label="inhibits\n(similar to TAC)"]
    Calcineurin -> NFAT [label="blocks nuclear\nentry", arrowhead=tee]
    NFAT -> SynapStab [label="regulates\nexpression"]
    SynapStab -> ActinCyto [label="F-actin\nstabilization"]
    SynapStab -> FPE [label="reverses\neffacement", arrowhead=tee]

    RTX1 -> CD20_B [label="binds CD20\n(anti-CD20 mAb)"]
    CD20_B -> Bcell_depl [label="ADCC / CDC\napoptosis"]
    Bcell_depl -> PermFactor [label="CLCF1/AntiCD40↓\ncirculating factor↓", arrowhead=tee]

    SPARS1 -> AT1R_block [label="AT1R\nantagonism"]
    SPARS1 -> ETR_block [label="ET-A/B\nantagonism"]
    AT1R_block -> AT1R [label="competitive\nblock", arrowhead=tee]
    ETR_block -> ET_A [label="blocks", arrowhead=tee]
    AT1R_block -> GlomHTN [label="normalizes\nhemodynamics", arrowhead=tee]

    ActharGel -> MC_receptor [label="binds\nMC1R/MC5R"]
    MC_receptor -> Podocyte [label="direct\nprotection"]
    MC_receptor -> Nrf2 [label="activates\nantioxidant"]

    MMF1 -> Macrophage [label="proliferation↓\npurine synthesis↓", arrowhead=tee]

    Nrf2_drug -> Nrf2 [label="activates"]
    mTOR_drug -> mTORC1 [label="rapamycin-\nanalog blocks", arrowhead=tee]

    // Clinical outputs
    Proteinuria -> UPCR [label="measured as"]
    UPCR -> CR [label="if UPCR<0.3"]
    UPCR -> PR [label="if ≥50% ↓"]
    GFR -> SCreat [label="inverse\ncorrelation"]
    GFR -> CystC [label="reflected by"]
    Pod_Detach -> PodocalyxinU [label="shed podocyte\nmarker"]
    FPE -> NephrinU [label="slit diaphragm\ndamage→shed"]
    Pod_Detach -> WILMS1_U [label="urinary WT1 mRNA"]
    sUPAR -> suPAR_bio [label="serum\nmeasurement"]
    BiopsyFSGS -> Sclerosis [label="quantifies\n(Columbia Class.)"]
    GFR -> KFRE [label="input variable"]
    Proteinuria -> KFRE [label="input variable"]
    KFRE -> ESRD [label="risk prediction"]
    UPCR -> BiopsyFSGS [label="triggers biopsy"]
}
