digraph preeclampsia_qsp {
  graph [rankdir=LR, fontname="Helvetica", fontsize=11, bgcolor="#FAFAFA",
         label="Preeclampsia QSP Mechanistic Map\n(Placental Dysfunction · Angiogenic Imbalance · Endothelial Dysfunction · Multi-organ Involvement · Drug PK/PD)",
         labelloc=t, labelfontsize=14, pad=0.5, nodesep=0.4, ranksep=0.8]
  node [fontname="Helvetica", fontsize=8, style="filled,rounded", shape=box]
  edge [fontname="Helvetica", fontsize=7, arrowsize=0.7]

  // ─────────────────────────────────────────────────────────────────
  // CLUSTER 0: Maternal Risk Factors
  // ─────────────────────────────────────────────────────────────────
  subgraph cluster_risk {
    label="Maternal Risk Factors" style=filled fillcolor="#F0F0F0"
    fontname="Helvetica" fontsize=10 fontcolor="#333333"

    nulliparity    [label="Nulliparity" fillcolor="#E0E0E0"]
    obesity        [label="Obesity\n(BMI>30)" fillcolor="#E0E0E0"]
    advanced_age   [label="Advanced\nMaternal Age" fillcolor="#E0E0E0"]
    APS            [label="Antiphospholipid\nSyndrome (APS)" fillcolor="#E0E0E0"]
    prev_PE        [label="Previous\nPreeclampsia" fillcolor="#E0E0E0"]
    chronic_htn    [label="Chronic\nHypertension" fillcolor="#E0E0E0"]
    CKD_risk       [label="Pre-existing\nCKD" fillcolor="#E0E0E0"]
    DM_risk        [label="Pre-existing\nDiabetes" fillcolor="#E0E0E0"]
    thrombophilia  [label="Thrombophilia" fillcolor="#E0E0E0"]
    multip_preg    [label="Multiple\nPregnancy" fillcolor="#E0E0E0"]
  }

  // ─────────────────────────────────────────────────────────────────
  // CLUSTER 1: Placental Development & Dysfunction
  // ─────────────────────────────────────────────────────────────────
  subgraph cluster_placenta {
    label="Placental Compartment (1st–2nd Trimester)" style=filled fillcolor="#E3F2FD"
    fontname="Helvetica" fontsize=10 fontcolor="#0D47A1"

    trophoblast_invasion  [label="Extravillous\nTrophoblast (EVT)\nInvasion" fillcolor="#BBDEFB"]
    spiral_artery_remodul [label="Spiral Artery\nRemodeling" fillcolor="#BBDEFB"]
    dec_NK               [label="Decidual\nNK Cells" fillcolor="#BBDEFB"]
    KIR_receptor         [label="KIR Receptor /\nHLA-C Interaction" fillcolor="#90CAF9"]
    intervillous_space   [label="Intervillous\nSpace" fillcolor="#BBDEFB"]
    placental_perfusion  [label="Uteroplacental\nPerfusion" fillcolor="#BBDEFB"]
    uterine_blood_flow   [label="Uterine\nBlood Flow" fillcolor="#BBDEFB"]
    placental_O2         [label="Placental\nO₂ Tension" fillcolor="#90CAF9"]
    placental_hypoxia    [label="Placental\nIschemia/Hypoxia" fillcolor="#EF9A9A" shape=ellipse]
    HIF1a                [label="HIF-1α\nActivation" fillcolor="#EF9A9A"]
    placental_stress     [label="Placental\nOxidative Stress" fillcolor="#EF9A9A"]
    ER_stress            [label="ER Stress\n(ATF6/IRE1/PERK)" fillcolor="#FFCCBC"]
    syncytiotrophoblast  [label="Syncytiotrophoblast\nMicrovesicles" fillcolor="#FFCCBC"]
    placental_AT1_AA     [label="AT1 Receptor\nAutoantibody (AT1-AA)" fillcolor="#FFAB91"]
  }

  // ─────────────────────────────────────────────────────────────────
  // CLUSTER 2: Angiogenic Imbalance
  // ─────────────────────────────────────────────────────────────────
  subgraph cluster_angiogenic {
    label="Angiogenic Imbalance" style=filled fillcolor="#FFFDE7"
    fontname="Helvetica" fontsize=10 fontcolor="#F57F17"

    sFlt1_placenta [label="sFlt-1 Placental\nProduction" fillcolor="#FFF9C4"]
    sFlt1_plasma   [label="sFlt-1 Plasma\n(pg/mL)" fillcolor="#FFEE58" shape=diamond]
    PlGF_placenta  [label="PlGF Placental\nProduction" fillcolor="#FFF9C4"]
    PlGF_plasma    [label="PlGF Plasma\n(pg/mL)" fillcolor="#FFEE58" shape=diamond]
    sFlt1_PlGF_ratio [label="sFlt-1/PlGF\nRatio (>38)" fillcolor="#FF8F00" fontcolor="white" shape=diamond]
    VEGF_A         [label="VEGF-A\n(Free)" fillcolor="#FFF9C4"]
    VEGFR1         [label="VEGFR1 (Flt-1)\nCell-surface" fillcolor="#FFF176"]
    VEGFR2         [label="VEGFR2 (KDR)\nSignaling" fillcolor="#FFF176"]
    sEng_placenta  [label="Soluble Endoglin\nPlacental Source" fillcolor="#FFF9C4"]
    sEng_plasma    [label="Soluble Endoglin\nPlasma (ng/mL)" fillcolor="#FFEE58" shape=diamond]
    TGFbeta1       [label="TGF-β1\nSignaling" fillcolor="#FFF9C4"]
    TGFbeta_R      [label="TGF-β Receptor\n(ALK5/ENG)" fillcolor="#FFF176"]
    neuropilin1    [label="Neuropilin-1\nCo-receptor" fillcolor="#FFF176"]
    PIGF_VEGF_seq  [label="VEGF/PlGF\nSequestration\nby sFlt-1" fillcolor="#FFA000" fontcolor="white"]
  }

  // ─────────────────────────────────────────────────────────────────
  // CLUSTER 3: Endothelial Dysfunction
  // ─────────────────────────────────────────────────────────────────
  subgraph cluster_endothelial {
    label="Endothelial Dysfunction" style=filled fillcolor="#E8F5E9"
    fontname="Helvetica" fontsize=10 fontcolor="#1B5E20"

    eNOS           [label="eNOS Expression\n/ Activity" fillcolor="#C8E6C9"]
    NO_prod        [label="Nitric Oxide (NO)\nProduction" fillcolor="#A5D6A7"]
    NO_bioavail    [label="NO\nBioavailability↓" fillcolor="#EF9A9A" shape=ellipse]
    BH4            [label="BH4\n(eNOS Cofactor)" fillcolor="#C8E6C9"]
    ADMA           [label="ADMA\n(eNOS Inhibitor)" fillcolor="#FFCCBC"]
    PGI2_prod      [label="Prostacyclin (PGI2)\nProduction" fillcolor="#A5D6A7"]
    TXA2_prod      [label="Thromboxane A2\n(TXA2) Production" fillcolor="#EF9A9A"]
    PGI2_TXA2      [label="PGI2/TXA2\nBalance" fillcolor="#FFEE58" shape=diamond]
    ET1_prod       [label="Endothelin-1\n(ET-1) Production↑" fillcolor="#EF9A9A"]
    ET_A_receptor  [label="ETA Receptor\nVasoconstriction" fillcolor="#FFCCBC"]
    ET_B_receptor  [label="ETB Receptor\nVasodilation" fillcolor="#C8E6C9"]
    ROS_endothel   [label="Reactive Oxygen\nSpecies (ROS)↑" fillcolor="#EF9A9A"]
    NADPH_oxidase  [label="NADPH\nOxidase Activity" fillcolor="#FFCCBC"]
    superoxide     [label="Superoxide\nAnion (O₂⁻)" fillcolor="#FFCCBC"]
    peroxynitrite  [label="Peroxynitrite\n(ONOO⁻)" fillcolor="#FFCCBC"]
    endothel_apop  [label="Endothelial\nApoptosis" fillcolor="#EF9A9A"]
    ICAM1_VCAM1    [label="ICAM-1/VCAM-1\nExpression" fillcolor="#FFAB91"]
    leukocyte_adh  [label="Leukocyte\nAdhesion/Activation" fillcolor="#FFAB91"]
  }

  // ─────────────────────────────────────────────────────────────────
  // CLUSTER 4: Cardiovascular / Blood Pressure
  // ─────────────────────────────────────────────────────────────────
  subgraph cluster_cardiovascular {
    label="Cardiovascular & BP Regulation" style=filled fillcolor="#FCE4EC"
    fontname="Helvetica" fontsize=10 fontcolor="#880E4F"

    SVR            [label="Systemic Vascular\nResistance (SVR)↑" fillcolor="#F48FB1"]
    CO             [label="Cardiac Output" fillcolor="#F8BBD0"]
    HR             [label="Heart Rate" fillcolor="#F8BBD0"]
    SV             [label="Stroke Volume" fillcolor="#F8BBD0"]
    SBP            [label="Systolic BP\n(mmHg)" fillcolor="#F06292" fontcolor="white" shape=diamond]
    DBP            [label="Diastolic BP\n(mmHg)" fillcolor="#F06292" fontcolor="white" shape=diamond]
    MAP            [label="Mean Arterial\nPressure (MAP)" fillcolor="#EC407A" fontcolor="white" shape=diamond]
    RAAS_act       [label="RAAS\nActivation" fillcolor="#F48FB1"]
    AngII          [label="Angiotensin II\n(AngII)" fillcolor="#F48FB1"]
    aldosterone    [label="Aldosterone" fillcolor="#F8BBD0"]
    renin          [label="Renin Activity" fillcolor="#F8BBD0"]
    Na_retention   [label="Sodium\nRetention" fillcolor="#F8BBD0"]
    plasma_volume  [label="Plasma Volume\n(Relative ↓)" fillcolor="#F48FB1"]
    sympathetic    [label="Sympathetic\nNervous System" fillcolor="#F48FB1"]
    baroreflex     [label="Baroreflex\nSensitivity" fillcolor="#F8BBD0"]
  }

  // ─────────────────────────────────────────────────────────────────
  // CLUSTER 5: Renal Compartment
  // ─────────────────────────────────────────────────────────────────
  subgraph cluster_renal {
    label="Renal Compartment" style=filled fillcolor="#FFF3E0"
    fontname="Helvetica" fontsize=10 fontcolor="#E65100"

    GFR_val        [label="GFR\n(mL/min/1.73m²)" fillcolor="#FFE0B2" shape=diamond]
    proteinuria    [label="Proteinuria\n(mg/24h)" fillcolor="#FF8F00" fontcolor="white" shape=diamond]
    glom_endothel  [label="Glomerular\nEndotheliosis" fillcolor="#FFAB91"]
    podocyte_inj   [label="Podocyte\nInjury/Loss" fillcolor="#FFAB91"]
    nephrin        [label="Nephrin\nExpression↓" fillcolor="#FFCC80"]
    podocin        [label="Podocin\nExpression↓" fillcolor="#FFCC80"]
    slit_diaphragm [label="Slit Diaphragm\nDisruption" fillcolor="#FFCC80"]
    renal_BF       [label="Renal\nBlood Flow" fillcolor="#FFE0B2"]
    uric_acid      [label="Serum Uric Acid\n(Uricemia)" fillcolor="#FFAB91"]
    serum_creat    [label="Serum Creatinine\n(mg/dL)" fillcolor="#FFE0B2" shape=diamond]
    tubular_injury [label="Tubular\nInjury Markers" fillcolor="#FFCC80"]
  }

  // ─────────────────────────────────────────────────────────────────
  // CLUSTER 6: Coagulation & HELLP Syndrome
  // ─────────────────────────────────────────────────────────────────
  subgraph cluster_coagulation {
    label="Coagulation / HELLP Syndrome" style=filled fillcolor="#F3E5F5"
    fontname="Helvetica" fontsize=10 fontcolor="#4A148C"

    plt_count      [label="Platelet Count\n(×10³/µL)" fillcolor="#CE93D8" shape=diamond]
    plt_activation [label="Platelet\nActivation" fillcolor="#E1BEE7"]
    TXA2_plt       [label="TXA2-driven\nPlatelet Aggregation" fillcolor="#CE93D8"]
    vWF            [label="von Willebrand\nFactor (vWF)" fillcolor="#E1BEE7"]
    thrombin_gen   [label="Thrombin\nGeneration" fillcolor="#CE93D8"]
    fibrin_dep     [label="Fibrin\nDeposition" fillcolor="#CE93D8"]
    D_dimer        [label="D-dimer↑\n(µg/mL)" fillcolor="#BA68C8" shape=diamond]
    microthrombi   [label="Microthrombi\nFormation" fillcolor="#9C27B0" fontcolor="white"]
    hemolysis_mk   [label="Microangiopathic\nHemolytic Anemia" fillcolor="#9C27B0" fontcolor="white"]
    LDH_val        [label="LDH↑\n(IU/L)" fillcolor="#CE93D8" shape=diamond]
    schistocytes   [label="Schistocytes\non Smear" fillcolor="#E1BEE7"]
    HELLP          [label="HELLP Syndrome\n(Hemolyis+EL+LP)" fillcolor="#6A1B9A" fontcolor="white" shape=ellipse]
  }

  // ─────────────────────────────────────────────────────────────────
  // CLUSTER 7: Neurological Manifestations
  // ─────────────────────────────────────────────────────────────────
  subgraph cluster_neuro {
    label="Neurological Compartment" style=filled fillcolor="#EDE7F6"
    fontname="Helvetica" fontsize=10 fontcolor="#311B92"

    cerebral_BF    [label="Cerebral\nBlood Flow" fillcolor="#D1C4E9"]
    cerebral_auto  [label="Cerebral\nAutoregulation" fillcolor="#B39DDB"]
    BBB_integrity  [label="Blood-Brain\nBarrier (BBB)" fillcolor="#B39DDB"]
    cerebral_edema [label="Cerebral\nEdema/Vasospasm" fillcolor="#9575CD" fontcolor="white"]
    NMDA_receptor  [label="NMDA Receptor\nActivity" fillcolor="#B39DDB"]
    Mg_cerebral    [label="Cerebral Mg²⁺\nLevel (mmol/L)" fillcolor="#7E57C2" fontcolor="white" shape=diamond]
    seizure_thresh [label="Seizure\nThreshold" fillcolor="#9575CD" fontcolor="white"]
    eclampsia_risk [label="Eclampsia\nRisk" fillcolor="#4527A0" fontcolor="white" shape=ellipse]
    headache       [label="Headache /\nVisual Changes" fillcolor="#CE93D8"]
    hypertensive_enc [label="Hypertensive\nEncephalopathy" fillcolor="#7B1FA2" fontcolor="white"]
    PRES           [label="Posterior Reversible\nEncephalopathy Synd." fillcolor="#6A1B9A" fontcolor="white"]
  }

  // ─────────────────────────────────────────────────────────────────
  // CLUSTER 8: Hepatic Manifestations
  // ─────────────────────────────────────────────────────────────────
  subgraph cluster_hepatic {
    label="Hepatic Compartment" style=filled fillcolor="#FFF8E1"
    fontname="Helvetica" fontsize=10 fontcolor="#F57F17"

    hepatic_BF     [label="Hepatic\nBlood Flow" fillcolor="#FFF9C4"]
    hepatic_ischemf [label="Hepatic\nIschemia/Fibrin" fillcolor="#FFD54F"]
    AST_val        [label="AST↑ (IU/L)" fillcolor="#FFA000" fontcolor="white" shape=diamond]
    ALT_val        [label="ALT↑ (IU/L)" fillcolor="#FFA000" fontcolor="white" shape=diamond]
    bilirubin      [label="Bilirubin↑\n(mg/dL)" fillcolor="#FFD54F"]
    subcap_hem     [label="Subcapsular\nHematoma" fillcolor="#FF6F00" fontcolor="white" shape=ellipse]
    hepatic_rupture [label="Hepatic\nRupture Risk" fillcolor="#E65100" fontcolor="white" shape=ellipse]
  }

  // ─────────────────────────────────────────────────────────────────
  // CLUSTER 9: Complement Activation
  // ─────────────────────────────────────────────────────────────────
  subgraph cluster_complement {
    label="Complement Activation" style=filled fillcolor="#E8EAF6"
    fontname="Helvetica" fontsize=10 fontcolor="#1A237E"

    C3_act         [label="C3 Activation\n(AP/CP/LP)" fillcolor="#C5CAE9"]
    C4_act         [label="C4 Activation" fillcolor="#C5CAE9"]
    C3a            [label="C3a\nAnaphylatoxin" fillcolor="#9FA8DA"]
    C5_act         [label="C5 Activation" fillcolor="#9FA8DA"]
    C5a            [label="C5a\n(Inflammatory)" fillcolor="#7986CB" fontcolor="white"]
    C5b9_MAC       [label="C5b-9 MAC\n(Lysis)" fillcolor="#3949AB" fontcolor="white"]
    CFH            [label="Complement\nFactor H (CFH)" fillcolor="#C5CAE9"]
    CD46           [label="CD46\n(MCP)" fillcolor="#C5CAE9"]
    CD55           [label="CD55\n(DAF)" fillcolor="#C5CAE9"]
    CD59           [label="CD59\n(Protectin)" fillcolor="#C5CAE9"]
    C5a_plt        [label="C5a Receptor\non Platelets" fillcolor="#9FA8DA"]
  }

  // ─────────────────────────────────────────────────────────────────
  // CLUSTER 10: Fetal Compartment
  // ─────────────────────────────────────────────────────────────────
  subgraph cluster_fetal {
    label="Fetal / Neonatal Compartment" style=filled fillcolor="#E8F5E9"
    fontname="Helvetica" fontsize=10 fontcolor="#1B5E20"

    umbilical_BF   [label="Umbilical\nBlood Flow" fillcolor="#C8E6C9"]
    fetal_O2_del   [label="Fetal O₂\nDelivery" fillcolor="#A5D6A7"]
    fetal_wt       [label="Fetal Weight\n/ Growth" fillcolor="#A5D6A7"]
    IUGR           [label="IUGR\n(Fetal Growth Restriction)" fillcolor="#EF9A9A" shape=ellipse]
    preterm_del    [label="Preterm\nDelivery Risk" fillcolor="#EF9A9A" shape=ellipse]
    fetal_HR       [label="Fetal Heart Rate\n(CTG)" fillcolor="#C8E6C9"]
    BPP_score      [label="Biophysical\nProfile Score" fillcolor="#C8E6C9"]
    NICU_risk      [label="NICU\nAdmission Risk" fillcolor="#E57373"]
  }

  // ─────────────────────────────────────────────────────────────────
  // CLUSTER 11: Aspirin PK/PD
  // ─────────────────────────────────────────────────────────────────
  subgraph cluster_aspirin {
    label="Drug: Aspirin (Low-dose Prophylaxis)" style=filled fillcolor="#E3F2FD"
    fontname="Helvetica" fontsize=10 fontcolor="#0D47A1"

    aspirin_dose   [label="Aspirin\n75–150 mg/day PO" fillcolor="#B3E5FC" shape=box3d]
    aspirin_abs    [label="Aspirin\nAbsorption (ka)" fillcolor="#81D4FA"]
    aspirin_plasma [label="Aspirin Plasma\n(C_asp, mg/L)" fillcolor="#29B6F6" fontcolor="white" shape=diamond]
    aspirin_dist   [label="Distribution\n(Vd)" fillcolor="#81D4FA"]
    salicylate_pk  [label="Salicylate\nPlasma (mg/L)" fillcolor="#0288D1" fontcolor="white" shape=diamond]
    COX1_inhib     [label="COX-1\nIrreversible Inhibition" fillcolor="#01579B" fontcolor="white"]
    COX2_inhib     [label="COX-2\nPartial Inhibition" fillcolor="#0277BD" fontcolor="white"]
    TXA2_suppres   [label="TXA2\nSuppression (~95%)" fillcolor="#004D40" fontcolor="white"]
    PGI2_partial   [label="PGI2 Partial\nSuppression (<20%)" fillcolor="#00695C" fontcolor="white"]
    plt_func_inh   [label="Platelet Function\nInhibition" fillcolor="#81D4FA"]
    asp_bioavail   [label="Aspirin\nBioavailability\n(EC-coated: ~40%)" fillcolor="#81D4FA"]
  }

  // ─────────────────────────────────────────────────────────────────
  // CLUSTER 12: Labetalol PK/PD
  // ─────────────────────────────────────────────────────────────────
  subgraph cluster_labetalol {
    label="Drug: Labetalol (α1+β Blocker)" style=filled fillcolor="#FFF3E0"
    fontname="Helvetica" fontsize=10 fontcolor="#E65100"

    labetalol_dose [label="Labetalol\n200–800 mg/day PO\nor IV 20–80 mg" fillcolor="#FFECB3" shape=box3d]
    labetalol_pk   [label="Labetalol Plasma\n(ng/mL)" fillcolor="#FFB300" shape=diamond]
    labetalol_meta [label="Hepatic\nMetabolism (CYP)" fillcolor="#FFECB3"]
    alpha1_block   [label="α1 Adrenergic\nBlockade" fillcolor="#FF8F00" fontcolor="white"]
    beta1_block    [label="β1 Adrenergic\nBlockade" fillcolor="#FF8F00" fontcolor="white"]
    beta2_block    [label="β2 Adrenergic\nBlockade (partial)" fillcolor="#FFCC80"]
    SVR_red_lab    [label="SVR Reduction\n(α1 effect)" fillcolor="#E65100" fontcolor="white"]
    HR_red_lab     [label="HR Reduction\n(β1 effect)" fillcolor="#E65100" fontcolor="white"]
    BP_red_lab     [label="BP Reduction\n(Combined effect)" fillcolor="#BF360C" fontcolor="white"]
  }

  // ─────────────────────────────────────────────────────────────────
  // CLUSTER 13: Nifedipine PK/PD
  // ─────────────────────────────────────────────────────────────────
  subgraph cluster_nifedipine {
    label="Drug: Nifedipine (CCB)" style=filled fillcolor="#E8F5E9"
    fontname="Helvetica" fontsize=10 fontcolor="#1B5E20"

    nifedipine_dose [label="Nifedipine\n20–90 mg/day\n(MR formulation)" fillcolor="#C8E6C9" shape=box3d]
    nifedipine_pk   [label="Nifedipine Plasma\n(ng/mL)" fillcolor="#4CAF50" fontcolor="white" shape=diamond]
    nifedipine_meta [label="CYP3A4\nMetabolism" fillcolor="#A5D6A7"]
    CaV_block       [label="L-type Ca²⁺\nChannel (Cav1.2)\nBlockade" fillcolor="#2E7D32" fontcolor="white"]
    vascular_relax  [label="Vascular Smooth\nMuscle Relaxation" fillcolor="#388E3C" fontcolor="white"]
    SVR_red_nif     [label="SVR Reduction\n(Vasodilation)" fillcolor="#1B5E20" fontcolor="white"]
    BP_red_nif      [label="BP Reduction\n(10–20 mmHg)" fillcolor="#1B5E20" fontcolor="white"]
    reflex_tachy    [label="Reflex\nTachycardia (mild)" fillcolor="#FFAB91"]
  }

  // ─────────────────────────────────────────────────────────────────
  // CLUSTER 14: Magnesium Sulfate PK/PD
  // ─────────────────────────────────────────────────────────────────
  subgraph cluster_magnesium {
    label="Drug: Magnesium Sulfate (Seizure Prophylaxis)" style=filled fillcolor="#E0F7FA"
    fontname="Helvetica" fontsize=10 fontcolor="#006064"

    MgSO4_dose     [label="MgSO4\n4 g IV load +\n1–2 g/h maint." fillcolor="#B2EBF2" shape=box3d]
    Mg_plasma      [label="Plasma Mg²⁺\n(mmol/L)\nTherapeutic: 1.7–3.5" fillcolor="#00ACC1" fontcolor="white" shape=diamond]
    Mg_renal_excr  [label="Renal Mg²⁺\nExcretion (GFR-dep)" fillcolor="#B2EBF2"]
    NMDA_block     [label="NMDA Receptor\nAntagonism" fillcolor="#00838F" fontcolor="white"]
    Ca_channel_Mg  [label="Voltage-gated\nCa²⁺ Channel Block" fillcolor="#00838F" fontcolor="white"]
    vasodil_Mg     [label="Direct\nVasodilation" fillcolor="#4DD0E1"]
    neuromusc_block [label="Neuromuscular\nJunction Block\n(Mg >3.5 mmol/L)" fillcolor="#FFAB91"]
    resp_depress   [label="Respiratory\nDepression\n(Mg >5 mmol/L)" fillcolor="#EF9A9A"]
    Ca_gluconate   [label="Ca Gluconate\n(Antidote)" fillcolor="#E0F7FA"]
    Mg_cerebral_PD [label="Cerebral Mg²⁺\nNeuroprotection" fillcolor="#006064" fontcolor="white"]
  }

  // ─────────────────────────────────────────────────────────────────
  // CLUSTER 15: Clinical Endpoints & Outcomes
  // ─────────────────────────────────────────────────────────────────
  subgraph cluster_endpoints {
    label="Clinical Endpoints & Outcomes" style=filled fillcolor="#EFEBE9"
    fontname="Helvetica" fontsize=10 fontcolor="#3E2723"

    PE_diagnosis   [label="Preeclampsia\nDiagnosis\n(BP ≥140/90 +\nProteinuria/EO)" fillcolor="#8D6E63" fontcolor="white" shape=ellipse]
    severe_features [label="Severe Features\n(SBP≥160 or DBP≥110)" fillcolor="#6D4C41" fontcolor="white" shape=ellipse]
    early_PE       [label="Early-onset PE\n(<34 weeks)" fillcolor="#4E342E" fontcolor="white" shape=ellipse]
    late_PE        [label="Late-onset PE\n(≥34 weeks)" fillcolor="#795548" fontcolor="white" shape=ellipse]
    delivery_decision [label="Delivery\nDecision" fillcolor="#5D4037" fontcolor="white" shape=diamond]
    maternal_mort  [label="Maternal\nMortality Risk" fillcolor="#B71C1C" fontcolor="white" shape=ellipse]
    perinatal_mort [label="Perinatal\nMortality Risk" fillcolor="#B71C1C" fontcolor="white" shape=ellipse]
    stroke_risk    [label="Stroke Risk\n(Intracranial Hge)" fillcolor="#C62828" fontcolor="white" shape=ellipse]
    abruption      [label="Placental\nAbruption Risk" fillcolor="#D32F2F" fontcolor="white" shape=ellipse]
    long_term_CVD  [label="Long-term\nCVD Risk (mother)" fillcolor="#B71C1C" fontcolor="white"]
  }

  // =================================================================
  // EDGES: Risk Factors → Placenta
  // =================================================================
  nulliparity    -> trophoblast_invasion [label="impairs" color="#E57373"]
  obesity        -> sFlt1_placenta       [label="↑ production" color="#E57373"]
  APS            -> spiral_artery_remodul [label="impairs" color="#E57373"]
  prev_PE        -> trophoblast_invasion [label="predisposes" color="#E57373"]
  chronic_htn    -> SVR                  [label="↑ baseline" color="#E57373"]
  CKD_risk       -> GFR_val              [label="↓ baseline" color="#E57373"]
  DM_risk        -> placental_stress     [label="aggravates" color="#E57373"]
  thrombophilia  -> microthrombi         [label="promotes" color="#E57373"]
  multip_preg    -> sFlt1_placenta       [label="↑↑ production" color="#E57373"]
  advanced_age   -> eNOS                 [label="↓ activity" color="#E57373"]

  // =================================================================
  // EDGES: Placentation → Angiogenic Imbalance
  // =================================================================
  trophoblast_invasion -> spiral_artery_remodul [label="drives" color="#1565C0"]
  KIR_receptor    -> trophoblast_invasion  [label="regulates" color="#1565C0"]
  dec_NK          -> KIR_receptor          [label="expresses" color="#1565C0"]
  spiral_artery_remodul -> placental_perfusion [label="determines" color="#1565C0"]
  placental_perfusion -> placental_O2      [label="determines" color="#1565C0"]
  placental_O2    -> placental_hypoxia     [label="if↓" color="#C62828" style=dashed]
  placental_hypoxia -> HIF1a              [label="activates" color="#C62828"]
  HIF1a           -> sFlt1_placenta        [label="↑ transcription" color="#E65100"]
  HIF1a           -> PlGF_placenta         [label="↓ initially" color="#C62828" style=dashed]
  placental_stress -> ER_stress            [label="triggers" color="#E65100"]
  ER_stress       -> sFlt1_placenta        [label="↑" color="#E65100"]
  ER_stress       -> syncytiotrophoblast   [label="shed into\ncirculation" color="#E65100"]
  syncytiotrophoblast -> eNOS              [label="impairs" color="#C62828"]
  placental_hypoxia -> sEng_placenta      [label="↑" color="#E65100"]
  placental_AT1_AA -> RAAS_act            [label="activates\nAT1R" color="#E65100"]
  intervillous_space -> placental_O2      [label="O₂ exchange" color="#1565C0"]
  uterine_blood_flow -> intervillous_space [label="supplies" color="#1565C0"]

  // =================================================================
  // EDGES: Angiogenic Imbalance
  // =================================================================
  sFlt1_placenta -> sFlt1_plasma          [label="secreted\ninto circulation" color="#F57F17"]
  PlGF_placenta  -> PlGF_plasma           [label="secreted" color="#43A047"]
  sFlt1_plasma   -> PIGF_VEGF_seq         [label="binds/sequesters" color="#E65100"]
  PIGF_VEGF_seq  -> VEGFR2               [label="↓ signaling" color="#C62828"]
  PIGF_VEGF_seq  -> PlGF_plasma          [label="↓ free PlGF" color="#C62828"]
  sFlt1_plasma   -> sFlt1_PlGF_ratio     [label="numerator" color="#F57F17"]
  PlGF_plasma    -> sFlt1_PlGF_ratio     [label="denominator" color="#43A047"]
  VEGF_A         -> VEGFR2               [label="activates" color="#43A047"]
  VEGFR2         -> eNOS                 [label="↑ activity" color="#43A047"]
  VEGFR1         -> PIGF_VEGF_seq        [label="=sFlt1 shed\nfrom VEGFR1" color="#E65100"]
  sEng_placenta  -> sEng_plasma          [label="secreted" color="#E65100"]
  TGFbeta1       -> TGFbeta_R            [label="binds" color="#E65100"]
  sEng_plasma    -> TGFbeta_R            [label="blocks\nTGF-β binding" color="#C62828"]
  TGFbeta_R      -> eNOS                 [label="↓ via sEng" color="#C62828" style=dashed]
  neuropilin1    -> VEGFR2               [label="co-receptor" color="#43A047"]

  // =================================================================
  // EDGES: Endothelial Dysfunction
  // =================================================================
  sFlt1_plasma   -> eNOS                 [label="↓ VEGF-driven\neNOS" color="#C62828"]
  eNOS           -> NO_prod              [label="generates" color="#43A047"]
  BH4            -> eNOS                 [label="cofactor" color="#43A047"]
  ADMA           -> eNOS                 [label="inhibits" color="#C62828" style=dashed]
  ROS_endothel   -> BH4                  [label="oxidizes→\nBH2" color="#C62828"]
  NADPH_oxidase  -> superoxide           [label="generates" color="#E65100"]
  superoxide     -> NO_prod              [label="quenches\nNO→ONOO⁻" color="#C62828"]
  superoxide     -> peroxynitrite        [label="+ NO →" color="#E65100"]
  superoxide     -> ROS_endothel         [label="contributes" color="#E65100"]
  NO_prod        -> NO_bioavail          [label="if↓ ROS" color="#C62828" style=dashed]
  NO_bioavail    -> SVR                  [label="↑ if NO↓" color="#C62828"]
  ET1_prod       -> ET_A_receptor        [label="activates" color="#E65100"]
  ET_A_receptor  -> SVR                  [label="vasoconstriction" color="#C62828"]
  ET1_prod       -> ET_B_receptor        [label="activates (less)" color="#43A047"]
  ET_B_receptor  -> NO_prod             [label="stimulates" color="#43A047"]
  PGI2_prod      -> PGI2_TXA2           [label="numerator" color="#43A047"]
  TXA2_prod      -> PGI2_TXA2           [label="denominator" color="#C62828"]
  PGI2_TXA2      -> plt_activation      [label="if↓ ratio→\n↑ aggregation" color="#E65100"]
  PGI2_prod      -> SVR                 [label="vasodilates\n(if ↑)" color="#43A047" style=dashed]
  TXA2_prod      -> SVR                 [label="vasoconstricts" color="#C62828"]
  endothel_apop  -> ICAM1_VCAM1         [label="↑ on surviving\ncells" color="#E65100"]
  ICAM1_VCAM1    -> leukocyte_adh       [label="promotes" color="#E65100"]
  leukocyte_adh  -> ROS_endothel        [label="produces\nROS" color="#E65100"]
  leukocyte_adh  -> placental_stress    [label="aggravates" color="#E65100"]

  // =================================================================
  // EDGES: Cardiovascular
  // =================================================================
  SVR            -> SBP                  [label="main driver" color="#880E4F"]
  SVR            -> DBP                  [label="main driver" color="#880E4F"]
  CO             -> SBP                  [label="contributes" color="#880E4F"]
  HR             -> CO                   [label="×SV" color="#880E4F"]
  SV             -> CO                   [label="×HR" color="#880E4F"]
  SBP            -> MAP                  [label="SBP+2×DBP\n÷3" color="#880E4F"]
  DBP            -> MAP                  [label="" color="#880E4F"]
  RAAS_act       -> AngII               [label="generates" color="#880E4F"]
  AngII          -> SVR                  [label="AT1R → VC" color="#C62828"]
  AngII          -> aldosterone          [label="→ adrenal" color="#880E4F"]
  aldosterone    -> Na_retention         [label="↑ NaK-ATPase" color="#880E4F"]
  Na_retention   -> plasma_volume        [label="↑ (paradox)" color="#880E4F"]
  renin          -> RAAS_act             [label="angiotensinogen\n→ AngI" color="#880E4F"]
  MAP            -> baroreflex           [label="activates" color="#43A047"]
  baroreflex     -> sympathetic          [label="modulates" color="#880E4F"]
  sympathetic    -> HR                   [label="↑" color="#880E4F"]
  sympathetic    -> SVR                  [label="↑ (α1)" color="#C62828"]
  placental_AT1_AA -> AngII             [label="mimics/\npotentiates" color="#C62828"]

  // =================================================================
  // EDGES: Renal
  // =================================================================
  MAP            -> GFR_val             [label="drives" color="#E65100"]
  sFlt1_plasma   -> glom_endothel       [label="VEGF-loss\n→ endotheliosis" color="#C62828"]
  glom_endothel  -> slit_diaphragm      [label="disrupts" color="#C62828"]
  slit_diaphragm -> proteinuria         [label="loss →\n↑ protein leak" color="#C62828"]
  podocyte_inj   -> nephrin             [label="↓ expression" color="#C62828"]
  podocyte_inj   -> podocin             [label="↓ expression" color="#C62828"]
  nephrin        -> slit_diaphragm      [label="structural\ncomponent" color="#E65100"]
  podocin        -> slit_diaphragm      [label="structural\ncomponent" color="#E65100"]
  SVR            -> renal_BF            [label="↓ RBF if SVR↑" color="#C62828"]
  renal_BF       -> GFR_val             [label="determines" color="#E65100"]
  GFR_val        -> serum_creat         [label="↓GFR →\n↑creat" color="#C62828"]
  uric_acid      -> endothel_apop       [label="promotes" color="#C62828"]
  tubular_injury -> serum_creat         [label="contributes" color="#E65100"]

  // =================================================================
  // EDGES: Coagulation / HELLP
  // =================================================================
  TXA2_prod      -> TXA2_plt            [label="drives" color="#7B1FA2"]
  TXA2_plt       -> plt_activation      [label="↑ aggregation" color="#7B1FA2"]
  microthrombi   -> plt_count           [label="consumes\nplatelets" color="#C62828"]
  plt_activation -> vWF                 [label="releases" color="#7B1FA2"]
  vWF            -> plt_activation      [label="positive FB\n(GPIb)" color="#7B1FA2"]
  plt_activation -> thrombin_gen        [label="surface for\ntenase" color="#7B1FA2"]
  thrombin_gen   -> fibrin_dep          [label="fibrinogen →\nfibrin" color="#7B1FA2"]
  fibrin_dep     -> D_dimer             [label="fibrinolysis\nproduct" color="#7B1FA2"]
  fibrin_dep     -> microthrombi        [label="forms" color="#7B1FA2"]
  microthrombi   -> hemolysis_mk        [label="shear →\nRBC fragmentation" color="#7B1FA2"]
  hemolysis_mk   -> LDH_val             [label="↑ LDH" color="#7B1FA2"]
  hemolysis_mk   -> schistocytes        [label="schistocyte\nformation" color="#7B1FA2"]
  plt_count      -> HELLP               [label="if <100k\n(thrombocytopenia)" color="#C62828"]
  LDH_val        -> HELLP               [label="if ↑↑" color="#C62828"]
  AST_val        -> HELLP               [label="if ↑↑" color="#C62828"]
  HELLP          -> maternal_mort       [label="↑ risk" color="#B71C1C" style=bold]

  // =================================================================
  // EDGES: Neurological
  // =================================================================
  MAP            -> cerebral_BF         [label="drives" color="#311B92"]
  cerebral_BF    -> cerebral_auto       [label="regulated by" color="#311B92"]
  MAP            -> cerebral_auto       [label="exceeds\nautoregulation\nlimit" color="#C62828" style=dashed]
  cerebral_auto  -> cerebral_edema      [label="if overwhelmed" color="#C62828"]
  sFlt1_plasma   -> BBB_integrity       [label="disrupts (via\nVEGF loss)" color="#C62828"]
  ROS_endothel   -> BBB_integrity       [label="disrupts" color="#C62828"]
  BBB_integrity  -> cerebral_edema      [label="if breached" color="#C62828"]
  cerebral_edema -> headache            [label="causes" color="#C62828"]
  cerebral_edema -> hypertensive_enc    [label="→" color="#C62828"]
  hypertensive_enc -> PRES             [label="leads to" color="#C62828"]
  NMDA_receptor  -> seizure_thresh      [label="activation\n↓ threshold" color="#C62828"]
  Mg_cerebral    -> NMDA_block          [label="blocks if\nMg↑" color="#43A047"]
  NMDA_block     -> seizure_thresh      [label="↑ threshold\n(neuroprotection)" color="#43A047"]
  seizure_thresh -> eclampsia_risk      [label="if threshold\ncrossed" color="#C62828"]
  eclampsia_risk -> maternal_mort       [label="↑ risk" color="#B71C1C" style=bold]

  // =================================================================
  // EDGES: Hepatic
  // =================================================================
  microthrombi   -> hepatic_BF          [label="↓ microcirculation" color="#E65100"]
  hepatic_BF     -> hepatic_ischemf     [label="if↓" color="#E65100"]
  hepatic_ischemf -> AST_val            [label="hepatocyte\nlysis" color="#E65100"]
  hepatic_ischemf -> ALT_val            [label="hepatocyte\nlysis" color="#E65100"]
  hepatic_ischemf -> bilirubin          [label="↑" color="#E65100"]
  hepatic_ischemf -> subcap_hem         [label="stretches capsule" color="#C62828"]
  subcap_hem     -> hepatic_rupture     [label="progression" color="#C62828"]
  hepatic_rupture -> maternal_mort      [label="life-threatening" color="#B71C1C" style=bold]

  // =================================================================
  // EDGES: Complement
  // =================================================================
  sFlt1_plasma   -> C3_act              [label="indirect via\nendothelial damage" color="#3949AB" style=dashed]
  C3_act         -> C4_act              [label="classical/\nlectin pathway" color="#3949AB"]
  C3_act         -> C3a                 [label="generates" color="#3949AB"]
  C3_act         -> C5_act             [label="→ C5\nconvertase" color="#3949AB"]
  C5_act         -> C5a                 [label="generates" color="#3949AB"]
  C5_act         -> C5b9_MAC            [label="generates" color="#3949AB"]
  C5a            -> leukocyte_adh       [label="chemoattractant" color="#3949AB"]
  C5a            -> C5a_plt             [label="activates" color="#3949AB"]
  C5a_plt        -> plt_activation      [label="primes" color="#7B1FA2"]
  C5b9_MAC       -> endothel_apop       [label="lysis of\nendothelium" color="#C62828"]
  CFH            -> C3_act              [label="inhibits (if↓\nin PE)" color="#43A047" style=dashed]
  CD55           -> C3_act              [label="inhibits" color="#43A047" style=dashed]
  CD59           -> C5b9_MAC            [label="inhibits" color="#43A047" style=dashed]
  CD46           -> C3_act              [label="inhibits" color="#43A047" style=dashed]
  APS            -> C3_act              [label="↑ activation" color="#C62828"]

  // =================================================================
  // EDGES: Fetal
  // =================================================================
  placental_perfusion -> umbilical_BF   [label="determines" color="#1B5E20"]
  umbilical_BF   -> fetal_O2_del        [label="O₂ delivery" color="#1B5E20"]
  fetal_O2_del   -> fetal_wt            [label="supports\ngrowth" color="#43A047"]
  fetal_O2_del   -> IUGR                [label="if↓ → IUGR" color="#C62828" style=dashed]
  IUGR           -> preterm_del         [label="indicates need\nfor delivery" color="#C62828"]
  fetal_wt       -> BPP_score           [label="contributes" color="#1B5E20"]
  fetal_HR       -> BPP_score           [label="contributes" color="#1B5E20"]
  IUGR           -> NICU_risk           [label="↑" color="#C62828"]
  preterm_del    -> NICU_risk           [label="↑" color="#C62828"]
  IUGR           -> perinatal_mort      [label="↑ risk" color="#B71C1C"]

  // =================================================================
  // EDGES: Aspirin PK/PD
  // =================================================================
  aspirin_dose   -> aspirin_abs         [label="PO absorbed" color="#0288D1"]
  aspirin_abs    -> aspirin_plasma       [label="Cmax at 30min" color="#0288D1"]
  asp_bioavail   -> aspirin_plasma       [label="limits" color="#0288D1"]
  aspirin_plasma -> aspirin_dist         [label="Vd=0.14 L/kg" color="#0288D1"]
  aspirin_plasma -> salicylate_pk        [label="hydrolysis\n(esterase)" color="#0288D1"]
  aspirin_plasma -> COX1_inhib          [label="irreversible\nacetylation" color="#0288D1"]
  aspirin_plasma -> COX2_inhib          [label="partial\nacetylation" color="#0288D1"]
  COX1_inhib     -> TXA2_suppres        [label="blocks TXA2\nsynthesis" color="#004D40"]
  COX2_inhib     -> PGI2_partial        [label="partial ↓\n(endothelial)" color="#00695C"]
  TXA2_suppres   -> TXA2_prod           [label="inhibits" color="#43A047" style=bold]
  TXA2_suppres   -> plt_func_inh        [label="anti-platelet\neffect" color="#004D40"]
  PGI2_partial   -> PGI2_prod           [label="mild ↓\n(net benefit)" color="#E65100" style=dashed]
  plt_func_inh   -> plt_activation      [label="inhibits" color="#43A047"]

  // =================================================================
  // EDGES: Labetalol PK/PD
  // =================================================================
  labetalol_dose -> labetalol_pk        [label="PO: F=25%\nt½=6-8h" color="#E65100"]
  labetalol_pk   -> labetalol_meta      [label="CYP2D6\nconjugation" color="#E65100"]
  labetalol_pk   -> alpha1_block        [label="Kd~0.4 µM" color="#E65100"]
  labetalol_pk   -> beta1_block         [label="Kd~0.3 µM" color="#E65100"]
  labetalol_pk   -> beta2_block         [label="weaker\naffinity" color="#E65100"]
  alpha1_block   -> SVR_red_lab         [label="vasodilation" color="#E65100"]
  beta1_block    -> HR_red_lab          [label="chronotropy↓" color="#E65100"]
  SVR_red_lab    -> BP_red_lab          [label="contributes" color="#E65100"]
  HR_red_lab     -> BP_red_lab          [label="contributes" color="#E65100"]
  BP_red_lab     -> SBP                 [label="lowers" color="#43A047"]
  BP_red_lab     -> DBP                 [label="lowers" color="#43A047"]

  // =================================================================
  // EDGES: Nifedipine PK/PD
  // =================================================================
  nifedipine_dose -> nifedipine_pk      [label="MR: Cmax 2-4h\nt½=7-12h" color="#2E7D32"]
  nifedipine_pk  -> nifedipine_meta     [label="CYP3A4\nto inactive" color="#2E7D32"]
  nifedipine_pk  -> CaV_block           [label="IC50~1-3 nM" color="#2E7D32"]
  CaV_block      -> vascular_relax      [label="↓ [Ca²⁺]i\nSMC" color="#2E7D32"]
  vascular_relax -> SVR_red_nif         [label="arterial\nvasodilation" color="#2E7D32"]
  SVR_red_nif    -> BP_red_nif          [label="" color="#2E7D32"]
  BP_red_nif     -> SBP                 [label="lowers" color="#43A047"]
  BP_red_nif     -> DBP                 [label="lowers" color="#43A047"]
  BP_red_nif     -> reflex_tachy        [label="baroreceptor\nreflex" color="#E65100" style=dashed]
  reflex_tachy   -> HR                  [label="mild ↑HR" color="#E65100"]

  // =================================================================
  // EDGES: Magnesium Sulfate PK/PD
  // =================================================================
  MgSO4_dose     -> Mg_plasma           [label="IV: rapid\nredistribution" color="#006064"]
  Mg_plasma      -> Mg_renal_excr       [label="renal\nelimination\n(GFR-dependent)" color="#006064"]
  Mg_renal_excr  -> GFR_val             [label="monitor in\nrenal impairment" color="#E65100" style=dashed]
  Mg_plasma      -> NMDA_block          [label="blocks Mg²⁺\n(voltage-dep.)" color="#006064"]
  Mg_plasma      -> Ca_channel_Mg       [label="blocks\nL/T-type" color="#006064"]
  Mg_plasma      -> vasodil_Mg          [label="mild direct\nvasodilation" color="#006064"]
  NMDA_block     -> Mg_cerebral_PD      [label="neuroprotection\n(eclampsia prev.)" color="#006064"]
  Mg_cerebral_PD -> Mg_cerebral         [label="brain Mg" color="#006064"]
  Mg_cerebral    -> NMDA_receptor       [label="blocks at\ntherapeutic levels" color="#43A047"]
  Mg_plasma      -> neuromusc_block     [label="if Mg >3.5\ntoxic" color="#C62828" style=dashed]
  Mg_plasma      -> resp_depress        [label="if Mg >5\nlethal" color="#C62828" style=bold]
  Ca_gluconate   -> neuromusc_block     [label="reverses\ntoxicity" color="#43A047"]
  Ca_gluconate   -> resp_depress        [label="reverses" color="#43A047"]
  vasodil_Mg     -> SVR                 [label="mild ↓" color="#43A047" style=dashed]
  Ca_channel_Mg  -> SVR                 [label="vasodilation" color="#43A047"]

  // =================================================================
  // EDGES: Clinical Outcome
  // =================================================================
  SBP            -> PE_diagnosis        [label="if ≥140 after\n20 wk" color="#5D4037"]
  DBP            -> PE_diagnosis        [label="if ≥90 after\n20 wk" color="#5D4037"]
  proteinuria    -> PE_diagnosis        [label="if ≥300 mg/24h\n(or PCR>0.3)" color="#5D4037"]
  SBP            -> severe_features     [label="if ≥160" color="#B71C1C"]
  DBP            -> severe_features     [label="if ≥110" color="#B71C1C"]
  PE_diagnosis   -> early_PE            [label="<34 wk" color="#6D4C41"]
  PE_diagnosis   -> late_PE             [label="≥34 wk" color="#795548"]
  severe_features -> delivery_decision  [label="expedite\ndelivery" color="#B71C1C"]
  HELLP          -> delivery_decision   [label="urgent\ndelivery" color="#B71C1C"]
  eclampsia_risk -> delivery_decision   [label="urgent" color="#B71C1C"]
  early_PE       -> preterm_del         [label="iatrogenic" color="#C62828"]
  IUGR           -> delivery_decision   [label="guides timing" color="#C62828"]
  delivery_decision -> perinatal_mort   [label="timing\ncritical" color="#B71C1C"]
  PE_diagnosis   -> long_term_CVD       [label="5–10× ↑\nlifetime risk" color="#5D4037"]
  stroke_risk    -> maternal_mort       [label="major cause" color="#B71C1C" style=bold]
  SBP            -> stroke_risk         [label="if ≥160 →\ncerebral hge" color="#C62828"]
  abruption      -> maternal_mort       [label="↑ risk" color="#B71C1C"]
  microthrombi   -> abruption           [label="promotes" color="#C62828"]

  // sFlt-1/PlGF ratio as key biomarker
  sFlt1_PlGF_ratio -> PE_diagnosis      [label="ratio>38\npredictive" color="#F57F17" style=bold]
  sFlt1_PlGF_ratio -> severe_features   [label="ratio>85\nsevere PE" color="#F57F17" style=bold]

}
