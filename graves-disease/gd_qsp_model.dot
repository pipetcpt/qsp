digraph GravesDiseaseQSP {
  graph [rankdir=LR, fontname="Helvetica", fontsize=13, bgcolor="#f5f7fa",
         overlap=false, splines=ortho, nodesep=0.45, ranksep=0.9,
         label="Graves' Disease QSP Model\nHPT Axis · Autoimmune Pathogenesis · Thyroid Hormone Kinetics · Drug PK/PD · Target Organ Effects · Ophthalmopathy",
         labelloc=t, labeljust=c, fontsize=16]
  node [fontname="Helvetica", fontsize=10, style="filled,rounded", shape=box, penwidth=1.5]
  edge [fontname="Helvetica", fontsize=8, penwidth=1.2]

  // ─────────────────────────────────────────────
  // CLUSTER 1: Hypothalamus-Pituitary Axis
  // ─────────────────────────────────────────────
  subgraph cluster_hpt {
    label="1. HPT Axis (Neuroendocrine)" fontsize=13 style=filled fillcolor="#e8f4fd" color="#2980b9" penwidth=2
    node [fillcolor="#d6eaf8"]

    HYPO     [label="Hypothalamus\n(Paraventricular Nucleus)"]
    TRH      [label="TRH\n(Thyrotropin-Releasing Hormone)" shape=ellipse fillcolor="#aed6f1"]
    PITUIT   [label="Anterior Pituitary\n(Thyrotroph Cells)"]
    TSH      [label="TSH\n(Thyrotropin)" shape=ellipse fillcolor="#5dade2"]
    TSHRI    [label="TSHR on Thyroid\n(TSH Receptor)" shape=diamond fillcolor="#2e86c1" fontcolor=white]
    TSHPI    [label="TSHR on Pituitary\n(Negative Feedback)"]
    TRHpi    [label="TRH-R on Pituitary\n(TRH Receptor)" shape=diamond]
    TSHR_KD  [label="TSHR Desensitization\n(Downregulation)"]
    CYCLIC   [label="Circadian TRH\nPulsatility"]

    HYPO -> TRH [label="secretion" color="#2980b9"]
    TRH  -> TRHpi [color="#2980b9"]
    TRHpi -> PITUIT [label="stimulate TSH" color="#2980b9"]
    PITUIT -> TSH [label="secretion"]
    TSH -> TSHRI [label="binding"]
    TSH -> TSHPI [label="negative\nfeedback" style=dashed color="#e74c3c"]
    TSHPI -> PITUIT [label="suppresses TSH" color="#e74c3c" style=dashed]
    TSHR_KD -> TSHRI [label="receptor pool\nreduction" color="#e74c3c"]
    CYCLIC -> HYPO
  }

  // ─────────────────────────────────────────────
  // CLUSTER 2: Autoimmune Pathogenesis
  // ─────────────────────────────────────────────
  subgraph cluster_autoimmune {
    label="2. Autoimmune Pathogenesis" fontsize=13 style=filled fillcolor="#fdf2f8" color="#8e44ad" penwidth=2
    node [fillcolor="#f2d7ee"]

    APC      [label="Antigen-Presenting Cell\n(Dendritic Cell / Macrophage)" fillcolor="#d2b4de"]
    HLA_DR   [label="HLA-DR3/DR5\n(MHC Class II)" shape=diamond fillcolor="#a569bd"]
    TSHR_Ag  [label="TSHR Antigen\n(Self-Antigen Presentation)"]
    TPO_Ag   [label="TPO Antigen\n(Thyroid Peroxidase)"]
    TG_Ag    [label="Thyroglobulin Antigen"]
    CD4T     [label="CD4+ T Helper Cells\n(Naïve → Activated)"]
    TH1      [label="Th1 Cells\n(IFN-γ, TNF-α, IL-2)"]
    TH2      [label="Th2 Cells\n(IL-4, IL-5, IL-13)" fillcolor="#f8d7da"]
    TH17     [label="Th17 Cells\n(IL-17, IL-21, IL-22)"]
    TREG     [label="Regulatory T Cells\n(Tregs, Foxp3+)" fillcolor="#d5f5e3"]
    CD8T     [label="CD8+ Cytotoxic T Cells"]
    BCELL    [label="B Cells\n(TSHR-specific)"]
    PLASMA   [label="Plasma Cells\n(Antibody-secreting)"]
    TSAb     [label="TSAb\n(Thyroid-Stimulating Ab)" shape=ellipse fillcolor="#e74c3c" fontcolor=white]
    TBAb     [label="TBAb\n(Thyroid-Blocking Ab)" shape=ellipse fillcolor="#e67e22" fontcolor=white]
    TBII     [label="TBII / TRAb Total\n(Thyrotropin-Binding\nInhibitory Ig)" shape=ellipse fillcolor="#d35400" fontcolor=white]
    ANTI_TPO [label="Anti-TPO Ab" shape=ellipse]
    ANTI_TG  [label="Anti-Tg Ab" shape=ellipse]
    GERMCTR  [label="Germinal Center\nReaction"]
    MEMB     [label="Memory B Cells"]
    CXCL13   [label="CXCL13\n(B-cell chemoattractant)"]
    IL6      [label="IL-6\n(pro-inflammatory)"]
    IL10     [label="IL-10\n(anti-inflammatory)" fillcolor="#d5f5e3"]
    TGFB     [label="TGF-β\n(Treg maintenance)" fillcolor="#d5f5e3"]
    CTLA4    [label="CTLA-4 Polymorphism\n(Risk Factor)" shape=diamond]
    CD40     [label="CD40-CD40L\n(T-B costimulation)"]
    IL2_Sig  [label="IL-2 Signaling\n(T cell expansion)"]

    APC -> HLA_DR -> TSHR_Ag
    APC -> TPO_Ag
    APC -> TG_Ag
    TSHR_Ag -> CD4T [label="antigen\npresentation"]
    CD4T -> TH1 [label="Th1 polarization"]
    CD4T -> TH2 [label="Th2 polarization"]
    CD4T -> TH17
    CD4T -> TREG [label="IL-2+TGF-β"]
    TH2 -> BCELL [label="IL-4/IL-13\nhelp" color="#8e44ad"]
    CD40 -> BCELL [label="costimulation"]
    BCELL -> GERMCTR -> PLASMA
    GERMCTR -> MEMB
    PLASMA -> TSAb [label="secrete"]
    PLASMA -> TBAb [label="secrete"]
    PLASMA -> TBII [label="total TRAb"]
    PLASMA -> ANTI_TPO
    PLASMA -> ANTI_TG
    TREG -> TH1 [label="suppress" style=dashed color="#27ae60"]
    TREG -> TH2 [label="suppress" style=dashed color="#27ae60"]
    CTLA4 -> TREG [label="deficiency\nincreases risk" style=dashed color="#e74c3c"]
    TH1 -> IL6
    TH1 -> CD8T
    TH2 -> IL10
    IL2_Sig -> CD4T [label="proliferation"]
    CXCL13 -> BCELL [label="recruitment"]
    TGFB -> TREG
    CD4T -> IL2_Sig
  }

  // ─────────────────────────────────────────────
  // CLUSTER 3: Thyroid Follicular Cell
  // ─────────────────────────────────────────────
  subgraph cluster_thyroid {
    label="3. Thyroid Follicular Cell Mechanisms" fontsize=13 style=filled fillcolor="#eafaf1" color="#27ae60" penwidth=2
    node [fillcolor="#d5f5e3"]

    TSHR_FC  [label="TSHR\n(Follicular Cell)" shape=diamond fillcolor="#1e8449" fontcolor=white]
    GSALPHA  [label="Gs-α Protein\n(G-protein coupling)"]
    ADENYLC  [label="Adenylyl Cyclase\n(cAMP production)"]
    CAMP     [label="cAMP\n(2nd Messenger)" shape=ellipse fillcolor="#52be80"]
    PKA      [label="PKA\n(cAMP-dependent Protein Kinase)"]
    PI3K     [label="PI3K/Akt Pathway\n(TSHR secondary signaling)"]
    CREB     [label="CREB\n(Transcription Factor)"]
    NIS      [label="NIS\n(Na+/I- Symporter)\nIodide Uptake" fillcolor="#a9dfbf"]
    PENDRIN  [label="Pendrin\n(Iodide efflux\ninto lumen)"]
    IODIDE   [label="I⁻ (Iodide)\nIntracellular" shape=ellipse]
    DUOX2    [label="DUOX2\n(H₂O₂ generator)"]
    H2O2     [label="H₂O₂\n(Oxidant)" shape=ellipse fillcolor="#f9ebea"]
    TPO_ENZ  [label="TPO\n(Thyroid Peroxidase)" fillcolor="#a9dfbf"]
    ORGANIF  [label="Iodide Organification\n(I⁻ → I⁺ → protein-I)"]
    TG_SYNTH [label="Thyroglobulin (Tg)\nSynthesis/Secretion"]
    MIT      [label="MIT\n(Mono-iodotyrosine)"]
    DIT      [label="DIT\n(Di-iodotyrosine)"]
    T4_SYNTH [label="T4 Formation\n(DIT+DIT coupling)"]
    T3_SYNTH [label="T3 Formation\n(MIT+DIT coupling)"]
    COLLOID  [label="Colloid Storage\n(Tg-bound T4/T3)"]
    ENDOCYT  [label="Tg Endocytosis\n(via TSH stimulation)"]
    LYSOSOME [label="Lysosomal\nProteolysis"]
    T4_SEC   [label="T4 Secretion\n→ bloodstream" shape=ellipse fillcolor="#2ecc71"]
    T3_SEC   [label="T3 Secretion\n→ bloodstream" shape=ellipse fillcolor="#27ae60" fontcolor=white]
    WOLFF    [label="Wolff-Chaikoff Effect\n(High I⁻ → inhibit TPO)"]
    ESCAP    [label="Escape from\nWolff-Chaikoff"]
    THYROID_HYPER [label="Thyroid Hyperplasia\n& Hypertrophy (Goiter)"]
    VASCULR  [label="Thyroid Vascularity\n(increased blood flow)"]
    TG_POOL  [label="Tg Pool\n(intrafollicular store)"]

    TSHR_FC -> GSALPHA -> ADENYLC -> CAMP
    CAMP -> PKA
    PKA -> CREB [label="gene transcription"]
    PKA -> NIS [label="upregulate"]
    PKA -> TG_SYNTH [label="stimulate"]
    PKA -> TPO_ENZ [label="activate"]
    TSHR_FC -> PI3K [label="Gi coupling"]
    PI3K -> NIS [label="membrane\ntargeting"]
    NIS -> IODIDE [label="uptake I⁻"]
    IODIDE -> PENDRIN [label="efflux to colloid"]
    IODIDE -> DUOX2 -> H2O2
    H2O2 -> TPO_ENZ [label="oxidant substrate"]
    TPO_ENZ -> ORGANIF [label="iodide oxidation\n& organification"]
    ORGANIF -> MIT
    ORGANIF -> DIT
    TG_SYNTH -> TG_POOL
    MIT -> T3_SYNTH [label="+ DIT"]
    DIT -> T4_SYNTH [label="DIT + DIT"]
    T4_SYNTH -> COLLOID
    T3_SYNTH -> COLLOID
    COLLOID -> ENDOCYT [label="pinocytosis"]
    ENDOCYT -> LYSOSOME [label="Tg proteolysis"]
    LYSOSOME -> T4_SEC
    LYSOSOME -> T3_SEC
    IODIDE -> WOLFF [label="excess I⁻\n(>5 mg/day)"]
    WOLFF -> TPO_ENZ [label="transient\ninhibition" style=dashed color="#e74c3c"]
    WOLFF -> ESCAP [label="adaptation\n10-14 days"]
    CREB -> THYROID_HYPER [label="cell growth\ngenes"]
    PKA -> VASCULR [label="VEGF, bFGF\nupregulation"]
  }

  // ─────────────────────────────────────────────
  // CLUSTER 4: Thyroid Hormone PK / Peripheral Metabolism
  // ─────────────────────────────────────────────
  subgraph cluster_hormones {
    label="4. Thyroid Hormone PK & Peripheral Metabolism" fontsize=13 style=filled fillcolor="#fef9e7" color="#d4ac0d" penwidth=2
    node [fillcolor="#fcf3cf"]

    T4_CIRC  [label="Total T4 (Serum)\n~100 nmol/L" fillcolor="#f9e79f"]
    T3_CIRC  [label="Total T3 (Serum)\n~2 nmol/L" fillcolor="#f9e79f"]
    FT4      [label="Free T4 (fT4)\n~18 pmol/L" shape=ellipse fillcolor="#f4d03f"]
    FT3      [label="Free T3 (fT3)\n~6 pmol/L" shape=ellipse fillcolor="#f4d03f"]
    RT3      [label="Reverse T3 (rT3)\n(inactive)" shape=ellipse]
    TBG      [label="TBG\n(Thyroxine-Binding Globulin)\n~75% carrier" fillcolor="#fdebd0"]
    ALBUMIN  [label="Albumin\n(~10% carrier)"]
    TTR      [label="Transthyretin\n(Prealbumin, ~15%)"]
    D1       [label="Deiodinase Type 1\n(D1, liver/kidney)\nT4→T3, rT3→T2" fillcolor="#fad7a0"]
    D2       [label="Deiodinase Type 2\n(D2, brain/pituitary)\nT4→T3 (local)" fillcolor="#fad7a0"]
    D3       [label="Deiodinase Type 3\n(D3, placenta/brain)\nT4→rT3, T3→T2" fillcolor="#fad7a0"]
    TRA      [label="Thyroid Hormone Receptor\n(TR-α, TR-β)" shape=diamond fillcolor="#d4ac0d" fontcolor=white]
    TRE      [label="Thyroid Response Elements\n(TRE, gene regulation)" shape=parallelogram]
    RXR      [label="RXR (Retinoid X Receptor)\nTR:RXR Heterodimer" fillcolor="#fad7a0"]
    COACT    [label="Coactivators\n(SRC-1, GRIP1, CBP)"]
    COREP    [label="Corepressors\n(NCoR, SMRT)\n(suppress in hypothyroid)"]
    HEPATIC_CLEARANCE [label="Hepatic Clearance\nConjugation/\nGlucuronidation/Sulfation"]
    ENTEROHEPATC [label="Enterohepatic\nCirculation"]
    RENAL_CLEAR [label="Renal Clearance\n(minor)"]
    T2       [label="T2 (inactive\nmetabolite)"]
    HALF_T4  [label="T4 Half-life\n~7 days"]
    HALF_T3  [label="T3 Half-life\n~1 day"]

    T4_SEC -> T4_CIRC
    T3_SEC -> T3_CIRC
    T4_CIRC -> TBG [label="~75% bound"]
    T4_CIRC -> ALBUMIN [label="~10%"]
    T4_CIRC -> TTR [label="~15%"]
    TBG -> FT4 [label="dynamic\nequilibrium" style=dashed]
    T3_CIRC -> TBG [label="bound"]
    TBG -> FT3 [style=dashed]
    FT4 -> D1 [label="substrate"]
    FT4 -> D2 [label="substrate"]
    FT4 -> D3 [label="substrate"]
    D1 -> FT3 [label="~60% of\ncirculating T3"]
    D2 -> FT3 [label="local T3\n(brain)"]
    D3 -> RT3 [label="T4 inactivation"]
    FT3 -> D3 [label="T3→T2"]
    RT3 -> D1 [label="rT3→T2"]
    D1 -> T2
    D3 -> T2
    FT3 -> TRA [label="binds TR-β1/α1"]
    TRA -> RXR [label="heterodimerize"]
    RXR -> TRE [label="binds DNA"]
    TRE -> COACT [label="gene activation"]
    COREP -> TRA [label="basal repression\n(no T3)" style=dashed color="#e74c3c"]
    T4_CIRC -> HEPATIC_CLEARANCE
    T3_CIRC -> HEPATIC_CLEARANCE
    HEPATIC_CLEARANCE -> ENTEROHEPATC
    ENTEROHEPATC -> T4_CIRC [label="reabsorption\n~20%"]
    T4_CIRC -> RENAL_CLEAR
    T4_CIRC -> HALF_T4
    T3_CIRC -> HALF_T3
  }

  // ─────────────────────────────────────────────
  // CLUSTER 5: Drug Pharmacokinetics
  // ─────────────────────────────────────────────
  subgraph cluster_pkdrug {
    label="5. Drug Pharmacokinetics" fontsize=13 style=filled fillcolor="#f4ecf7" color="#6c3483" penwidth=2
    node [fillcolor="#e8daef"]

    // Methimazole
    MMI_DOSE [label="Methimazole (MMI)\n30–60 mg/day oral" shape=parallelogram fillcolor="#d2b4de"]
    MMI_GUT  [label="MMI GI Absorption\n(F ~93%, tmax ~1h)"]
    MMI_CENT [label="MMI Central\nCompartment" shape=ellipse fillcolor="#a569bd"]
    MMI_THYR [label="MMI Thyroid\nConcentration" fillcolor="#7d3c98" fontcolor=white]
    MMI_ELIM [label="MMI Elimination\n(t½ ~4-6h, renal)"]

    // PTU
    PTU_DOSE [label="Propylthiouracil (PTU)\n300–600 mg/day oral" shape=parallelogram fillcolor="#d2b4de"]
    PTU_GUT  [label="PTU GI Absorption\n(F ~75%, tmax ~1-2h)"]
    PTU_CENT [label="PTU Central\nCompartment" shape=ellipse fillcolor="#a569bd"]
    PTU_PROT [label="PTU Protein\nBinding ~75%"]
    PTU_ELIM [label="PTU Elimination\n(t½ ~1-2h, hepatic)"]

    // Radioiodine
    RAI_DOSE [label="Radioiodine ¹³¹I\n10-15 mCi oral" shape=parallelogram fillcolor="#f5cba7"]
    RAI_GUT  [label="¹³¹I GI Absorption\n(F ~100%, rapid)"]
    RAI_SERUM [label="¹³¹I Serum" shape=ellipse fillcolor="#eb984e"]
    RAI_THYR  [label="¹³¹I Thyroid Uptake\n(24h RAIU ~60-80%)" fillcolor="#d35400" fontcolor=white]
    RAI_ELIM  [label="¹³¹I Whole-body\nElimination (t½ ~8d)"]

    // Propranolol
    PROP_DOSE [label="Propranolol\n40-160 mg/day" shape=parallelogram fillcolor="#d6eaf8"]
    PROP_GUT  [label="Propranolol Absorption\n(F ~26%, first-pass)"]
    PROP_CENT [label="Propranolol Central\nCompartment" shape=ellipse fillcolor="#2980b9"]
    PROP_ELIM [label="Propranolol\nElimination (t½ ~4h)"]

    // Levothyroxine (replacement)
    LT4_DOSE [label="Levothyroxine (LT4)\n1.6 μg/kg/day" shape=parallelogram fillcolor="#d5f5e3"]
    LT4_GUT  [label="LT4 GI Absorption\n(F ~70-80%)"]
    LT4_CENT [label="LT4 Central\nCompartment" shape=ellipse fillcolor="#27ae60" fontcolor=white]

    // Rituximab (for GO)
    RTX_DOSE [label="Rituximab\n1000mg IV x2" shape=parallelogram fillcolor="#fdebd0"]
    RTX_CENT [label="Rituximab Central\nCompartment" shape=ellipse fillcolor="#e59866"]
    RTX_PERI [label="Rituximab\nPeripheral Compartment"]
    RTX_ELIM [label="Rituximab Elimination\n(t½ ~21d, tmdd)"]

    MMI_DOSE -> MMI_GUT -> MMI_CENT -> MMI_THYR [label="high thyroid\nconcentration"]
    MMI_CENT -> MMI_ELIM
    PTU_DOSE -> PTU_GUT -> PTU_CENT -> PTU_PROT
    PTU_CENT -> PTU_ELIM
    RAI_DOSE -> RAI_GUT -> RAI_SERUM -> RAI_THYR [label="NIS-mediated\nuptake"]
    RAI_THYR -> RAI_ELIM [label="β-radiation\ndecay"]
    PROP_DOSE -> PROP_GUT -> PROP_CENT -> PROP_ELIM
    LT4_DOSE -> LT4_GUT -> LT4_CENT -> T4_CIRC [label="exogenous T4"]
    RTX_DOSE -> RTX_CENT -> RTX_PERI
    RTX_CENT -> RTX_ELIM
  }

  // ─────────────────────────────────────────────
  // CLUSTER 6: Drug Pharmacodynamics
  // ─────────────────────────────────────────────
  subgraph cluster_pddrug {
    label="6. Drug Pharmacodynamics (Mechanisms of Action)" fontsize=13 style=filled fillcolor="#fdfefe" color="#566573" penwidth=2
    node [fillcolor="#eaecee"]

    // MMI PD
    MMI_INHIB [label="MMI → TPO Inhibition\n(Irreversible covalent\nbinding to TPO)" fillcolor="#a569bd"]
    MMI_IMMU  [label="MMI Immunosuppressive\nEffect (reduce TRAb)"]

    // PTU PD
    PTU_INHIB [label="PTU → TPO Inhibition\n(T4/T3 synthesis block)"]
    PTU_D1    [label="PTU → D1 Inhibition\n(T4→T3 conversion block)" fillcolor="#7d3c98" fontcolor=white]

    // RAI PD
    RAI_BETA  [label="¹³¹I β-Radiation\nThyroid Cell Death" fillcolor="#e74c3c" fontcolor=white]
    RAI_ATROPHY [label="Thyroid Atrophy\n(post-RAI)"]
    RAI_HYPOT [label="Hypothyroidism\n(post-RAI, 50-80%)"]

    // Propranolol PD
    PROP_B1   [label="β₁-Blocker\nHeart Rate Reduction"]
    PROP_B2   [label="β₂-Blocker\nTremor Reduction"]
    PROP_D1INH [label="Propranolol → D1 Inhibit\n(reduce T3 conversion)"]

    // Rituximab PD
    RTX_CD20  [label="Anti-CD20 → B Cell\nDepletion" fillcolor="#e59866"]
    RTX_TRAB  [label="RTX → TRAb\nReduction (delayed)"]

    // Cholestyramine
    CHOL_DOSE [label="Cholestyramine\n4g QID" shape=parallelogram]
    CHOL_EH   [label="Cholestyramine → Bile\nSequestration → ↓T4\nEnterohepatic Recirculation"]

    // Glucocorticoids
    GCS_DOSE  [label="Glucocorticoids\n(Prednisone, IV MP)" shape=parallelogram]
    GCS_IMMU  [label="GCS → Immunosuppression\n(↓TSAb, ↓orbital inflam)"]

    // KI (Potassium iodide, Lugol's)
    KI_DOSE   [label="Lugol's Iodide\n(pre-op 5–7 days)" shape=parallelogram]
    KI_WOLFF  [label="KI → Wolff-Chaikoff\n(block hormone synthesis)"]
    KI_BLOOD  [label="↓ Thyroid Vascularity\n(pre-op benefit)"]

    MMI_THYR -> MMI_INHIB -> TPO_ENZ [label="block" style=dashed color="#e74c3c"]
    MMI_INHIB -> MMI_IMMU -> TSAb [label="reduce\n(secondary)" style=dashed color="#27ae60"]
    PTU_CENT -> PTU_INHIB -> TPO_ENZ [label="block" style=dashed color="#e74c3c"]
    PTU_CENT -> PTU_D1 -> D1 [label="inhibit" style=dashed color="#e74c3c"]
    RAI_THYR -> RAI_BETA -> RAI_ATROPHY -> RAI_HYPOT
    PROP_CENT -> PROP_B1
    PROP_CENT -> PROP_B2
    PROP_CENT -> PROP_D1INH -> D1 [label="inhibit" style=dashed color="#e74c3c"]
    RTX_CENT -> RTX_CD20 -> BCELL [label="deplete" color="#e74c3c"]
    RTX_CD20 -> RTX_TRAB -> TSAb [label="reduce\n(3-6 months)" style=dashed]
    CHOL_DOSE -> CHOL_EH -> ENTEROHEPATC [label="interrupt" style=dashed color="#e74c3c"]
    GCS_DOSE -> GCS_IMMU -> TSAb [label="reduce" style=dashed color="#27ae60"]
    KI_DOSE -> KI_WOLFF -> ORGANIF [label="inhibit" style=dashed color="#e74c3c"]
    KI_DOSE -> KI_BLOOD
  }

  // ─────────────────────────────────────────────
  // CLUSTER 7: Graves' Ophthalmopathy (GO)
  // ─────────────────────────────────────────────
  subgraph cluster_go {
    label="7. Graves' Ophthalmopathy (GO)" fontsize=13 style=filled fillcolor="#fef5e7" color="#ca6f1e" penwidth=2
    node [fillcolor="#fdebd0"]

    TSHR_ORB  [label="TSHR on Orbital\nFibroblasts" shape=diamond fillcolor="#ca6f1e" fontcolor=white]
    IGFR1_ORB [label="IGF-1R on Orbital\nFibroblasts" shape=diamond]
    ORB_FIBRO [label="Orbital Fibroblast\nActivation" fillcolor="#e59866"]
    HA_SYNTH  [label="Hyaluronan (HA)\nSynthesis ↑\n(HAS1, HAS2)" fillcolor="#fad7a0"]
    FIBRO_ADIPOG [label="Orbital Fibroblast\nAdipogenesis\n(PPAR-γ → lipid accumulation)"]
    GO_INFLAM [label="Orbital Inflammation\n(Lymphocyte infiltration)"]
    GO_EDEMA  [label="Periorbital Edema\n(HA osmotic\nwater retention)"]
    EXOPH    [label="Proptosis/Exophthalmos\n(Hertel >20mm)" fillcolor="#e74c3c" fontcolor=white]
    DIPLO    [label="Diplopia\n(EOM fibrosis)"]
    EOM_FIBRO [label="Extraocular Muscle\nFibrosis & Enlargement"]
    CAS_SCORE [label="CAS Score\n(Clinical Activity Score\n0-7)" shape=parallelogram fillcolor="#e74c3c" fontcolor=white]
    NOCS     [label="Optic Nerve\nCompression\n(↓visual acuity)" fillcolor="#922b21" fontcolor=white]
    TNF_GO   [label="TNF-α, IL-6\n(orbital cytokines)"]
    TH1_GO   [label="Th1/Th2 orbital\ninfiltration"]
    TEPROTM  [label="Teprotumumab\n(IGF-1R inhibitor)" shape=parallelogram fillcolor="#aed6f1"]
    TEPROTM_PD [label="Teprotumumab PD:\nreduces proptosis &\norbital fibroblast activation"]

    TSAb -> TSHR_ORB [label="TRAb binds"]
    TSHR_ORB -> ORB_FIBRO [label="activate"]
    IGFR1_ORB -> ORB_FIBRO [label="synergize"]
    ORB_FIBRO -> HA_SYNTH
    ORB_FIBRO -> FIBRO_ADIPOG
    HA_SYNTH -> GO_EDEMA
    FIBRO_ADIPOG -> GO_INFLAM -> EOM_FIBRO
    GO_EDEMA -> EXOPH
    EOM_FIBRO -> EXOPH
    EOM_FIBRO -> DIPLO
    EXOPH -> CAS_SCORE
    DIPLO -> CAS_SCORE
    GO_INFLAM -> TNF_GO
    TH1_GO -> GO_INFLAM
    GO_INFLAM -> NOCS [label="severe GO"]
    TEPROTM -> TEPROTM_PD -> IGFR1_ORB [label="block" style=dashed color="#e74c3c"]
    GCS_IMMU -> GO_INFLAM [label="suppress" style=dashed color="#27ae60"]
  }

  // ─────────────────────────────────────────────
  // CLUSTER 8: Target Organ Effects
  // ─────────────────────────────────────────────
  subgraph cluster_organs {
    label="8. Target Organ Effects (Systemic Hyperthyroidism)" fontsize=13 style=filled fillcolor="#ebf5fb" color="#1a5276" penwidth=2
    node [fillcolor="#d6eaf8"]

    // Cardiovascular
    HEART    [label="Heart\n(Cardiovascular Effects)" fillcolor="#e74c3c" fontcolor=white]
    TACHYC   [label="Tachycardia\n(HR > 100 bpm)"]
    PALPITAT [label="Palpitations &\nHyperdynamic state"]
    AFIB_RISK [label="Atrial Fibrillation Risk\n(5-15% of patients)"]
    CARD_OUT [label="Cardiac Output ↑\n(increased stroke volume)"]
    VASC_RES [label="Peripheral Vascular\nResistance ↓"]
    HYPERT_SYMP [label="Systolic Hypertension\n(wide pulse pressure)"]

    // Bone
    BONE_META [label="Bone Metabolism" fillcolor="#fad7a0"]
    BONE_RESOR [label="Osteoclast Activity ↑\n(bone resorption)"]
    BONE_FORM  [label="Osteoblast Activity ↑\nbut net resorption"]
    BMD_LOSS  [label="BMD Loss\n(cortical > trabecular)" fillcolor="#e74c3c" fontcolor=white]
    FX_RISK   [label="Fracture Risk ↑\n(hip/wrist)"]
    HYPERCALC [label="Hypercalcemia\n(mild, rare)"]
    BONEREMOD [label="Accelerated Bone\nRemodeling Cycle"]

    // CNS
    CNS      [label="CNS / Neuromuscular" fillcolor="#d2b4de"]
    ANXIETY  [label="Anxiety &\nEmotional Lability"]
    TREMOR   [label="Fine Tremor\n(hands)"]
    INSOMNIA [label="Insomnia &\nHyperreactivity"]
    PROXMYOP [label="Proximal Myopathy\n(muscle weakness)"]
    HYPERREF [label="Hyperreflexia\n(DTR increase)"]

    // Metabolism
    METAB    [label="Metabolic Effects" fillcolor="#d5f5e3"]
    BMR_INC  [label="BMR ↑ 20-60%\n(increased O₂ consumption)"]
    WEIGHT_LOSS [label="Weight Loss\n(↑ protein catabolism)"]
    HEAT_INT [label="Heat Intolerance\n(sweating, warm skin)"]
    HYPERGLC [label="Glucose Intolerance\n(↑ hepatic glucose output)"]
    LIPOLYSIS [label="Enhanced Lipolysis\n(FFA mobilization)"]
    PROTEIN_CAT [label="Protein Catabolism\n(negative N balance)"]

    // GI
    GI_MOTI  [label="GI Motility ↑\n(diarrhea, frequent stools)"]
    MALABSORB [label="Malabsorption risk\n(rapid transit)"]

    // Skin / Dermopathy
    SKIN     [label="Dermopathy\n(pretibial myxedema)" fillcolor="#fad7a0"]
    ACROPACH [label="Thyroid Acropachy\n(subperiosteal\nbone formation)"]

    // Reproductive
    REPROD   [label="Reproductive Effects" fillcolor="#f2d7ee"]
    OLIGOMEN [label="Oligomenorrhea /\nIrregular cycles"]
    INFERTIL [label="Reduced Fertility\n(anovulation)"]
    PREG_RISK [label="Pregnancy\nComplications\n(PTL, preeclampsia)"]

    FT3 -> HEART [label="T3 → cardiac\nstimulation"]
    HEART -> TACHYC
    HEART -> PALPITAT
    HEART -> CARD_OUT
    HEART -> VASC_RES
    HEART -> AFIB_RISK
    CARD_OUT -> HYPERT_SYMP
    VASC_RES -> HYPERT_SYMP

    FT3 -> BONE_META [label="T3 → osteoclast\nupregulation"]
    BONE_META -> BONE_RESOR
    BONE_META -> BONE_FORM
    BONE_RESOR -> BONEREMOD
    BONE_FORM -> BONEREMOD
    BONE_RESOR -> BMD_LOSS
    BMD_LOSS -> FX_RISK
    BONE_RESOR -> HYPERCALC

    FT3 -> CNS [label="T3 → catecholamine\nsensitization"]
    CNS -> ANXIETY
    CNS -> TREMOR
    CNS -> INSOMNIA
    CNS -> PROXMYOP
    CNS -> HYPERREF

    FT3 -> METAB [label="T3 → metabolic\nrate"]
    METAB -> BMR_INC
    METAB -> WEIGHT_LOSS
    METAB -> HEAT_INT
    METAB -> HYPERGLC
    METAB -> LIPOLYSIS
    METAB -> PROTEIN_CAT
    METAB -> GI_MOTI -> MALABSORB

    TSAb -> SKIN [label="fibroblast\nstimulation"]
    TSAb -> ACROPACH

    FT3 -> REPROD [label="hypothalamic\ndysfunction"]
    REPROD -> OLIGOMEN
    REPROD -> INFERTIL
    REPROD -> PREG_RISK
  }

  // ─────────────────────────────────────────────
  // CLUSTER 9: Clinical Endpoints & Biomarkers
  // ─────────────────────────────────────────────
  subgraph cluster_clinical {
    label="9. Clinical Endpoints & Biomarkers" fontsize=13 style=filled fillcolor="#f9f9f9" color="#2c3e50" penwidth=2
    node [fillcolor="#ecf0f1"]

    // Lab markers
    LAB_TSH   [label="Serum TSH\n(suppressed <0.01 mIU/L)" shape=parallelogram fillcolor="#e74c3c" fontcolor=white]
    LAB_FT4   [label="Serum fT4 ↑\n(>22 pmol/L)" shape=parallelogram fillcolor="#e74c3c" fontcolor=white]
    LAB_FT3   [label="Serum fT3 ↑\n(>7 pmol/L)" shape=parallelogram fillcolor="#e74c3c" fontcolor=white]
    LAB_TRAB  [label="TRAb ↑\n(>1.75 IU/L, diagnostic)" shape=parallelogram fillcolor="#e74c3c" fontcolor=white]
    LAB_TPO   [label="Anti-TPO Ab ↑\n(present in 75%)" shape=parallelogram]
    LAB_RAIU  [label="RAIU ↑ >30%\n(24h uptake test)" shape=parallelogram]
    LAB_TC    [label="Total Cholesterol ↓\n(increased catabolism)" shape=parallelogram]
    LAB_SHBG  [label="SHBG ↑\n(hepatic T3 effect)" shape=parallelogram]
    LAB_FERRIT [label="Ferritin ↑\n(acute phase)" shape=parallelogram]
    LAB_ALP   [label="ALP ↑\n(bone isoform)" shape=parallelogram]
    LAB_GGT   [label="GGT / LFT mildly ↑" shape=parallelogram]
    LAB_NTX   [label="Urine NTX ↑\n(bone resorption marker)" shape=parallelogram]
    LAB_OSTE  [label="Osteocalcin ↑\n(bone turnover)" shape=parallelogram]

    // Clinical scores
    SCORE_GS  [label="Goiter Size\n(WHO grade 0-3)"]
    SCORE_HR  [label="Heart Rate\n(bpm)" shape=parallelogram]
    SCORE_BURCH [label="Burch-Wartofsky\nScore\n(thyroid storm risk)" fillcolor="#e74c3c" fontcolor=white]
    REMISSION [label="Remission\n(TRAb neg, euthyroid\n>1yr off meds)" fillcolor="#27ae60" fontcolor=white]
    RELAPSE   [label="Relapse\n(TRAb pos,\nfT4/fT3 ↑)" fillcolor="#e74c3c" fontcolor=white]
    CURE      [label="Cure\n(post-RAI/surgery)" fillcolor="#1a5276" fontcolor=white]
    THYRSTORM [label="Thyroid Storm\n(fever, delirium,\nCV collapse)" fillcolor="#922b21" fontcolor=white]

    // Treatment response
    EUTHYROID [label="Euthyroidism\n(TSH 0.5-4.5 mIU/L)" fillcolor="#27ae60" fontcolor=white]
    ESCAPE_MMI [label="MMI Dose\nEscalation Need"]
    AGRANULOCYT [label="Agranulocytosis\n(MMI ADR ~0.3%)"]
    HYPOTHYROID [label="Hypothyroidism\n(post-treatment\ncorrect with LT4)" fillcolor="#aed6f1"]

    TSH -> LAB_TSH
    FT4 -> LAB_FT4
    FT3 -> LAB_FT3
    TSAb -> LAB_TRAB
    ANTI_TPO -> LAB_TPO
    RAI_THYR -> LAB_RAIU
    BONE_RESOR -> LAB_NTX
    BONE_RESOR -> LAB_ALP
    BONE_META -> LAB_OSTE
    THYROID_HYPER -> SCORE_GS
    TACHYC -> SCORE_HR
    SCORE_HR -> SCORE_BURCH
    LAB_TSH -> EUTHYROID [label="normalization\ngoal"]
    LAB_TSH -> REMISSION [label="sustained\nnormalization"]
    LAB_TSH -> RELAPSE
    LAB_FT4 -> EUTHYROID
    RAI_HYPOT -> HYPOTHYROID -> LT4_DOSE [label="LT4\nreplacement"]
    MMI_INHIB -> EUTHYROID [label="drug effect"]
    MMI_INHIB -> AGRANULOCYT [label="ADR"]
    EUTHYROID -> REMISSION [label="18-24 months\nMMI therapy"]
    REMISSION -> RELAPSE [label="relapse rate\n50-60%"]
    THYRSTORM -> SCORE_BURCH
    RAI_ATROPHY -> CURE
    CURE -> HYPOTHYROID
  }

  // ─────────────────────────────────────────────
  // CROSS-CLUSTER CONNECTIONS
  // ─────────────────────────────────────────────

  // Autoimmune → Thyroid
  TSAb -> TSHR_FC [label="TRAb mimics\nTSH action" color="#8e44ad" penwidth=2]
  TBAb -> TSHR_FC [label="blocks (if\ndominant)" style=dashed color="#e67e22"]
  IL6 -> PITUIT [label="suppresses\nTSH" style=dashed color="#e74c3c"]

  // Thyroid → HPT feedback
  FT4 -> PITUIT [label="negative\nfeedback" style=dashed color="#e74c3c" penwidth=2]
  FT3 -> PITUIT [label="negative\nfeedback" style=dashed color="#e74c3c"]
  FT4 -> HYPO [label="long-loop\nfeedback" style=dashed color="#e74c3c"]
  FT3 -> HYPO [label="negative\nfeedback" style=dashed color="#e74c3c"]

  // TSAb suppresses TSH via direct competition
  TSAb -> TSHRI [label="direct TSHR\nstimulation\n(no TSH needed)" color="#e74c3c" penwidth=2.5]

  // NIS for RAI uptake
  NIS -> RAI_THYR [label="active\ntransport" color="#d35400"]

  // Immune → GO
  TH1_GO -> TH1 [style=dashed color="#8e44ad"]
  IL6 -> GO_INFLAM [color="#8e44ad"]
  TH2 -> TH1_GO [style=dashed]

  // Drug effects on autoimmunity
  RTX_CD20 -> BCELL [color="#ca6f1e"]
  PLASMA -> BCELL [style=dashed label="derive from"]

  // Organs feedback
  AFIB_RISK -> SCORE_BURCH [label="contributes"]
  THYRSTORM -> TACHYC [style=dashed label="extreme"]
}
