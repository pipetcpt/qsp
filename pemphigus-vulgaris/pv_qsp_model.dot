digraph PemphigusVulgaris_QSP {

  // ── Global layout ──────────────────────────────────────────
  rankdir=LR;
  compound=true;
  splines=ortho;
  fontname="Helvetica";
  fontsize=10;
  node [fontsize=9, style=filled, fontname="Helvetica"];
  edge [fontsize=8, fontname="Helvetica"];

  // ==========================================================
  // CLUSTER 1 : Genetic & Environmental Triggers
  // ==========================================================
  subgraph cluster_triggers {
    label="Genetic & Environmental Triggers";
    style=filled; fillcolor="#FFE8E8"; color="#CC0000"; fontsize=11;

    HLA_DRB10402  [label="HLA-DRB1*04:02\nRisk allele",  shape=diamond, fillcolor="#FF9999"];
    HLA_DQB10503  [label="HLA-DQB1*05:03\nRisk allele",  shape=diamond, fillcolor="#FF9999"];
    HLA_DRB10301  [label="HLA-DRB1*03:01\nProtective?",  shape=diamond, fillcolor="#FFBBBB"];
    UV_radiation  [label="UV Radiation\nEnvironmental",   shape=box,     fillcolor="#FFB3B3"];
    drug_trigger  [label="Drug Triggers\n(penicillamine,\ncaptopril)",   shape=box, fillcolor="#FFB3B3"];
    infection_trg [label="Viral/Bacterial\nInfection",    shape=box,     fillcolor="#FFB3B3"];
    thymoma       [label="Thymoma\nAssociation",          shape=box,     fillcolor="#FFB3B3"];
    genetic_stress[label="Oxidative Stress\n(ROS)",       shape=box,     fillcolor="#FFCCCC"];
    CTLA4_poly    [label="CTLA4\nPolymorphism",           shape=diamond, fillcolor="#FFBBBB"];
    PDCD1_poly    [label="PD-1/PD-L1\nPolymorphism",     shape=diamond, fillcolor="#FFBBBB"];
  }

  // ==========================================================
  // CLUSTER 2 : Antigen Processing & Presentation
  // ==========================================================
  subgraph cluster_antigen {
    label="Antigen Processing & Presentation";
    style=filled; fillcolor="#E8F4FF"; color="#003399"; fontsize=11;

    APC_DC        [label="Dendritic Cell\n(APC)",         shape=ellipse, fillcolor="#99CCFF"];
    APC_macro     [label="Macrophage\n(APC)",             shape=ellipse, fillcolor="#99CCFF"];
    Dsg3_peptide  [label="Dsg3 Peptides\n(EC1-EC2)",      shape=box,     fillcolor="#CCE5FF"];
    Dsg1_peptide  [label="Dsg1 Peptides\n(EC1-EC2)",      shape=box,     fillcolor="#CCE5FF"];
    MHC_II        [label="MHC Class II\nDQ5/DR4 complex", shape=ellipse, fillcolor="#99CCFF"];
    CD28_CTLA4    [label="CD28/CTLA4\nCostimulation",     shape=box,     fillcolor="#CCE5FF"];
    thymic_escape [label="Central Tolerance\nFailure",    shape=box,     fillcolor="#CCE5FF"];
    AIRE_loss     [label="AIRE Defect\n(Dsg expression)", shape=box,     fillcolor="#CCE5FF"];
  }

  // ==========================================================
  // CLUSTER 3 : T Cell Compartment
  // ==========================================================
  subgraph cluster_tcell {
    label="T Cell Compartment";
    style=filled; fillcolor="#EEFFEE"; color="#006600"; fontsize=11;

    naive_CD4     [label="Naive CD4+\nT Cell",             shape=ellipse, fillcolor="#99FF99"];
    Th0           [label="Th0 Precursor",                  shape=ellipse, fillcolor="#99FF99"];
    Th2           [label="Th2 Cell",                       shape=ellipse, fillcolor="#66CC66"];
    Tfh           [label="T Follicular\nHelper (Tfh)\nCXCR5+ PD-1+", shape=ellipse, fillcolor="#33AA33"];
    Treg          [label="FoxP3+ Treg\n(Suppressor)",      shape=ellipse, fillcolor="#99FF99"];
    Th17          [label="Th17 Cell",                      shape=ellipse, fillcolor="#99FF99"];
    Th1           [label="Th1 Cell\n(minor role)",         shape=ellipse, fillcolor="#CCFFCC"];

    IL4           [label="IL-4",                           shape=hexagon, fillcolor="#CCFFCC"];
    IL13          [label="IL-13",                          shape=hexagon, fillcolor="#CCFFCC"];
    IL21          [label="IL-21\n(Tfh→GC)",                shape=hexagon, fillcolor="#CCFFCC"];
    IL17          [label="IL-17",                          shape=hexagon, fillcolor="#CCFFCC"];
    IFNg          [label="IFN-γ",                          shape=hexagon, fillcolor="#CCFFCC"];
    IL10_treg     [label="IL-10\n(Treg)",                  shape=hexagon, fillcolor="#CCFFCC"];
    TGFb_treg     [label="TGF-β\n(Treg)",                  shape=hexagon, fillcolor="#CCFFCC"];
    ICOS_Tfh      [label="ICOS/ICOSL\nCostimulation",      shape=box,     fillcolor="#DDFFDD"];
    CD40L_help    [label="CD40L/CD40\nB-T interaction",    shape=box,     fillcolor="#DDFFDD"];
    PD1_exhaust   [label="PD-1\nExhaustion",               shape=box,     fillcolor="#DDFFDD"];
  }

  // ==========================================================
  // CLUSTER 4 : B Cell Compartment & Germinal Center
  // ==========================================================
  subgraph cluster_bcell {
    label="B Cell Compartment & Germinal Center";
    style=filled; fillcolor="#FFFFF0"; color="#888800"; fontsize=11;

    naive_B       [label="Naive B Cell\n(Dsg3-autoreactive)", shape=ellipse, fillcolor="#FFFF99"];
    GC_B          [label="Germinal Center\nB Cell",            shape=ellipse, fillcolor="#FFEE44"];
    memory_B      [label="Memory B Cell\n(CD27+IgG+)",         shape=ellipse, fillcolor="#FFDD00"];
    plasmablast   [label="Plasmablast",                        shape=ellipse, fillcolor="#FFDD00"];
    LLPC          [label="Long-lived\nPlasma Cell\n(CD138+ BCMA+)", shape=ellipse, fillcolor="#CC9900"];
    SLPC          [label="Short-lived\nPlasma Cell",           shape=ellipse, fillcolor="#FFBB00"];
    pre_B         [label="Pre-B Cell\n(Bone marrow)",          shape=ellipse, fillcolor="#FFFFCC"];

    BAFF          [label="BAFF/BLyS\n(B survival)",            shape=hexagon, fillcolor="#FFFFBB"];
    APRIL         [label="APRIL\n(BCMA ligand)",               shape=hexagon, fillcolor="#FFFFBB"];
    BCR_signal    [label="BCR Signaling\nBtk pathway",         shape=box,     fillcolor="#FFFFCC"];
    SHM_GC        [label="Somatic\nHypermutation\nAffinity maturation", shape=box, fillcolor="#FFFFCC"];
    CSR_IgG       [label="Class Switch\nIgM→IgG4→IgG1",       shape=box,     fillcolor="#FFFFCC"];
    CXCR5_homing  [label="CXCL13/CXCR5\nGC homing",           shape=box,     fillcolor="#FFFFCC"];
    PD1_L1_GC     [label="PD-1/PD-L1\nGC checkpoint",         shape=box,     fillcolor="#FFFFCC"];
    IGHV_usage    [label="IGHV3-23/3-30\nGene usage",          shape=box,     fillcolor="#FFFFCC"];
  }

  // ==========================================================
  // CLUSTER 5 : Autoantibodies
  // ==========================================================
  subgraph cluster_antibody {
    label="Autoantibodies & Effectors";
    style=filled; fillcolor="#FFF0E8"; color="#CC4400"; fontsize=11;

    AntiDsg3_IgG  [label="Anti-Dsg3 IgG\n(Mucosal PV)\n>20 U/mL pathogenic", shape=ellipse, fillcolor="#FF9966"];
    AntiDsg1_IgG  [label="Anti-Dsg1 IgG\n(Cutaneous PV)\nSuperficial split", shape=ellipse, fillcolor="#FF9966"];
    AntiDsg3_IgG4 [label="Anti-Dsg3 IgG4\n(Predominant\nsubclass)",           shape=ellipse, fillcolor="#FF6633"];
    AntiDsg1_IgG4 [label="Anti-Dsg1 IgG4\nsubclass",                          shape=ellipse, fillcolor="#FF6633"];
    AntiDsg3_IgG1 [label="Anti-Dsg3 IgG1\n(complement fix)",                  shape=ellipse, fillcolor="#FF8855"];
    anti_PERP     [label="Anti-PERP Ab\n(Apoptosis signal)",                   shape=ellipse, fillcolor="#FFAA88"];
    anti_a9AChR   [label="Anti-α9-AChR Ab\n(nicotinic receptor)",              shape=ellipse, fillcolor="#FFAA88"];
    FcRn_cycle    [label="Neonatal FcR\n(FcRn) Recycling\nt1/2 ~21 days",     shape=box,     fillcolor="#FFCCBB"];
    FcgR_effector [label="FcγRIII\n(ADCC effector)",                           shape=box,     fillcolor="#FFCCBB"];
    Ab_complex    [label="Immune Complex\nFormation",                          shape=box,     fillcolor="#FFCCBB"];
  }

  // ==========================================================
  // CLUSTER 6 : Skin/Epithelial Target
  // ==========================================================
  subgraph cluster_skin {
    label="Skin & Epithelial Target Structures";
    style=filled; fillcolor="#FFF8E0"; color="#AA7700"; fontsize=11;

    keratinocyte  [label="Keratinocyte\n(Suprabasal layer)",  shape=box, fillcolor="#FFE57A"];
    Dsg3_protein  [label="Desmoglein-3\n(Dsg3)\n150 kDa cadherin\noral + skin", shape=box, fillcolor="#FFD700"];
    Dsg1_protein  [label="Desmoglein-1\n(Dsg1)\nSuperficial skin\n(pemphigus foliaceus)", shape=box, fillcolor="#FFD700"];
    Dsg2_intact   [label="Desmoglein-2\n(Not targeted)",      shape=box, fillcolor="#FFE57A"];
    desmosome_cplx[label="Desmosome\nComplex",                shape=octagon, fillcolor="#FFE57A"];
    Dsg3_EC_domain[label="Dsg3 EC1-EC2\nAdhesion domain",    shape=box, fillcolor="#FFDD88"];
    plakophilin   [label="Plakophilin-1/2\n(PKP)",            shape=box, fillcolor="#FFE57A"];
    desmoplakin   [label="Desmoplakin\n(DP)",                 shape=box, fillcolor="#FFE57A"];
    desmocollin   [label="Desmocollin\n(Dsc1/2/3)",           shape=box, fillcolor="#FFE57A"];
    E_cadherin    [label="E-Cadherin\n(CDH1)",                shape=box, fillcolor="#FFE57A"];
    pemphaxin     [label="Pemphaxin\n(Annexin A1)",           shape=box, fillcolor="#FFE57A"];
    periplakin    [label="Periplakin/\nEnvoplakin",           shape=box, fillcolor="#FFE57A"];
    KF14_KF5     [label="Keratin 5/14\nIntermediate filament",shape=box, fillcolor="#FFE57A"];
    cornified_env [label="Cornified Envelope\n(loricrin, involucrin)", shape=box, fillcolor="#FFE57A"];
  }

  // ==========================================================
  // CLUSTER 7 : Acantholysis Signaling
  // ==========================================================
  subgraph cluster_signaling {
    label="Acantholysis Signaling Pathways";
    style=filled; fillcolor="#F0E8FF"; color="#6600CC"; fontsize=11;

    steric_block  [label="Steric Interference\n(EC1-EC2 trans-dimer)", shape=diamond, fillcolor="#CC99FF"];
    p38_MAPK      [label="p38 MAPK\nActivation",                       shape=box,     fillcolor="#CC99FF"];
    PKC_alpha     [label="PKCα\nActivation",                           shape=box,     fillcolor="#BB88FF"];
    EGFR_trans    [label="EGFR\nTransactivation",                      shape=box,     fillcolor="#CC99FF"];
    Src_kinase    [label="Src Kinase\nPhosphorylation",                shape=box,     fillcolor="#CC99FF"];
    STAT3_sig     [label="STAT3\nSignaling",                           shape=box,     fillcolor="#CC99FF"];
    RhoA_ROCK     [label="RhoA/ROCK\nActin stress fibers",             shape=box,     fillcolor="#CC99FF"];
    Akt_PI3K      [label="Akt/PI3K\nSurvival pathway",                 shape=box,     fillcolor="#BB88FF"];
    caspase_act   [label="Caspase 3/8\nApoptosis",                     shape=box,     fillcolor="#CC99FF"];
    FasL_pathway  [label="FasL/Fas\nApoptosis signal",                 shape=box,     fillcolor="#CC99FF"];
    mTOR_sig      [label="mTOR\nSignaling",                            shape=box,     fillcolor="#BB88FF"];
    Dsg3_internal [label="Dsg3\nInternalization\n& Lysosomal\nDegradation", shape=box, fillcolor="#9966EE"];
    cytokeratin_rt[label="Cytokeratin\nRetraction",                    shape=box,     fillcolor="#CC99FF"];
    PLC_pathway   [label="PLCγ/DAG/IP3\nCa2+ signaling",              shape=box,     fillcolor="#BB88FF"];
    actin_dysreg  [label="Actin\nDysregulation",                      shape=box,     fillcolor="#CC99FF"];
  }

  // ==========================================================
  // CLUSTER 8 : Complement & Innate Immunity
  // ==========================================================
  subgraph cluster_innate {
    label="Complement & Innate Immunity";
    style=filled; fillcolor="#FFE8F4"; color="#CC0066"; fontsize=11;

    C1q_bind      [label="C1q Binding\n(IgG1 > IgG4)",  shape=box,     fillcolor="#FF99BB"];
    C3b_opson     [label="C3b\nOpsonization",            shape=box,     fillcolor="#FF99BB"];
    MAC_form      [label="MAC (C5b-9)\nFormation",       shape=box,     fillcolor="#FF77AA"];
    C5a_anaphyl   [label="C5a\nAnaphylatoxin",           shape=hexagon, fillcolor="#FF99BB"];
    neutrophil_inf[label="Neutrophil\nInflux",           shape=ellipse, fillcolor="#FF99BB"];
    mast_cell_deg [label="Mast Cell\nDegranulation",     shape=ellipse, fillcolor="#FF99BB"];
    histamine_rel [label="Histamine\n& Proteases",       shape=hexagon, fillcolor="#FFBBCC"];
    TNFa_innate   [label="TNF-α",                        shape=hexagon, fillcolor="#FFBBCC"];
    IL6_innate    [label="IL-6",                         shape=hexagon, fillcolor="#FFBBCC"];
    IL1b_innate   [label="IL-1β",                        shape=hexagon, fillcolor="#FFBBCC"];
    IL8_CXCL8     [label="IL-8/CXCL8\nNeutrophil chemo", shape=hexagon, fillcolor="#FFBBCC"];
    uPA_plasmin   [label="uPA/Plasmin\nProteolysis",     shape=box,     fillcolor="#FFBBCC"];
    NETosis       [label="NET Formation\nNeutrophil trap",shape=box,    fillcolor="#FF99BB"];
    IgE_mast      [label="IgE cross-link\nMast cell",    shape=box,     fillcolor="#FFBBCC"];
  }

  // ==========================================================
  // CLUSTER 9 : Clinical Manifestations & Endpoints
  // ==========================================================
  subgraph cluster_clinical {
    label="Clinical Manifestations & Endpoints";
    style=filled; fillcolor="#FFFAE8"; color="#AA8800"; fontsize=11;

    acantholysis  [label="Acantholysis\n(Intraepidermal split\nsuprabasal)", shape=octagon, fillcolor="#FFCC00"];
    oral_blister  [label="Oral Mucosal\nBlisters/Erosions\n(First manifestation\n>90% patients)", shape=box, fillcolor="#FFDD88"];
    skin_blister  [label="Skin Blisters\n(Nikolsky sign +\nfragile bullae)",shape=box,    fillcolor="#FFDD88"];
    conjunctival  [label="Conjunctival\nInvolvement",                       shape=box,    fillcolor="#FFDD88"];
    genital_mucos [label="Genital Mucosal\nErosions",                       shape=box,    fillcolor="#FFDD88"];
    Tzanck_smear  [label="Tzanck Smear\n(Acantholytic cells)",              shape=box,    fillcolor="#FFE8AA"];
    DIF_test      [label="Direct\nImmunofluorescence\n(IgG intercellular)", shape=box,    fillcolor="#FFE8AA"];
    ELISA_Dsg     [label="ELISA\nAnti-Dsg titer",                           shape=box,    fillcolor="#FFE8AA"];
    PDAI_score    [label="PDAI Score\n(Pemphigus Disease\nActivity Index)",  shape=box,    fillcolor="#FF9900"];
    ABSIS_score   [label="ABSIS Score\n(Activity / Sequalae)",               shape=box,    fillcolor="#FF9900"];
    DQLI_score    [label="Quality of Life\n(DLQI / ABQOL)",                  shape=box,    fillcolor="#FFDD88"];
    complete_rem  [label="Complete Remission\noff Therapy\n(CR-off)",        shape=octagon,fillcolor="#FFBB00"];
    partial_rem   [label="Partial Remission\non minimal Rx\n(PR-min)",       shape=box,    fillcolor="#FFCC44"];
    relapse       [label="Relapse/Flare\n(PDAI increase ≥5)",                shape=box,    fillcolor="#FF8800"];
    secondary_inf [label="Secondary Infection\n(Sepsis risk)",               shape=box,    fillcolor="#FF7700"];
    mortality_end [label="Mortality\n(historic ~75%;\nnow <5%)",             shape=box,    fillcolor="#FF5500"];
    steroid_compl [label="Steroid\nComplications\n(DM, HTN, osteo, infect)", shape=box,   fillcolor="#FFAA00"];
  }

  // ==========================================================
  // CLUSTER 10 : Corticosteroid PK/PD
  // ==========================================================
  subgraph cluster_steroids {
    label="Corticosteroid PK/PD";
    style=filled; fillcolor="#E8FFE8"; color="#005500"; fontsize=11;

    PRED_dose     [label="Prednisone\nDose\n1-2 mg/kg/day",              shape=box,     fillcolor="#99FF99"];
    PRED_gut      [label="Prednisolone\nGut Absorption\n(F=0.82)",       shape=box,     fillcolor="#88EE88"];
    PRED_C1       [label="Prednisolone\nCentral (C1)\nVd=35 L",         shape=box,     fillcolor="#66CC66"];
    PRED_C2       [label="Prednisolone\nPeripheral (C2)\nVd=60 L",      shape=box,     fillcolor="#66CC66"];
    IVMP_pulse    [label="IV Pulse\nMethylprednisolone\n1g × 3 days",   shape=box,     fillcolor="#99FF99"];
    GR_alpha      [label="Glucocorticoid\nReceptor-α\n(GR-α)",          shape=ellipse, fillcolor="#CCFFCC"];
    GRE_transact  [label="GRE\nTransactivation\n(anti-inflam genes)",   shape=box,     fillcolor="#CCFFCC"];
    NFkB_inh      [label="NF-κB\nSuppression\n(tethering)",             shape=box,     fillcolor="#AAFFAA"];
    AP1_inh       [label="AP-1\nSuppression",                           shape=box,     fillcolor="#AAFFAA"];
    MKP1_induct   [label="MKP-1\nInduction\n(p38 MAPK off)",            shape=box,     fillcolor="#CCFFCC"];
    lipocortin1   [label="Lipocortin-1\n(Annexin A1)\nAnti-phospholipase", shape=box,  fillcolor="#CCFFCC"];
    pred_SE       [label="Steroid Side Effects\n(glucose, bone,\nBP, infection,\nadrenal suppression)", shape=box, fillcolor="#FFEECC"];
  }

  // ==========================================================
  // CLUSTER 11 : Rituximab PK/PD
  // ==========================================================
  subgraph cluster_rtx {
    label="Rituximab PK/PD";
    style=filled; fillcolor="#E8F0FF"; color="#003399"; fontsize=11;

    RTX_dose      [label="Rituximab Dose\n1000mg IV ×2 (wks 0,2)\nor 375mg/m² ×4\n(RITUX3 protocol)", shape=box,  fillcolor="#99CCFF"];
    RTX_C1        [label="Rituximab\nCentral (mg/L)\n2-compartment",   shape=box,     fillcolor="#6699FF"];
    RTX_C2        [label="Rituximab\nPeripheral\n(mg/L)",              shape=box,     fillcolor="#6699FF"];
    CD20_target   [label="CD20 Target\n(MS4A1)\nKd=5.3 nM",           shape=box,     fillcolor="#99CCFF"];
    RTX_ADCC      [label="ADCC\n(NK cell lysis\nFcγRIIIA-Val158)",    shape=box,     fillcolor="#77AAFF"];
    RTX_CDC       [label="CDC\n(C1q→MAC)",                            shape=box,     fillcolor="#77AAFF"];
    RTX_apoptosis [label="Direct Apoptosis\n(caspase cascade)",        shape=box,     fillcolor="#77AAFF"];
    B_depletion   [label="B Cell Depletion\n(>99% early\nnadir 4 wks)", shape=box,   fillcolor="#3366EE"];
    B_repop_RTX   [label="B Cell\nRepopulation\n(6-12 months)",        shape=box,     fillcolor="#5588FF"];
    HACA_form     [label="HACA\n(Anti-RTX Ab\nimmunogenicity)",        shape=box,     fillcolor="#99AAFF"];
    RTX_half_life [label="RTX t1/2\n~22 days\n(non-linear PK)",        shape=box,     fillcolor="#AABBFF"];
  }

  // ==========================================================
  // CLUSTER 12 : Adjuvant Immunosuppressants
  // ==========================================================
  subgraph cluster_immuno {
    label="Adjuvant Immunosuppressants";
    style=filled; fillcolor="#FFF0FF"; color="#660066"; fontsize=11;

    MMF_dose      [label="Mycophenolate\nMofetil (MMF)\n2-3 g/day",   shape=box,     fillcolor="#FF99DD"];
    MPA_plasma    [label="MPA Plasma\nLevel (active)\nCmax ~15 mg/L",  shape=box,     fillcolor="#FF66BB"];
    IMPDH_block   [label="IMPDH\nInhibition\n(de novo purine)",        shape=box,     fillcolor="#FF99DD"];
    AZA_dose      [label="Azathioprine\n1-2 mg/kg/day",               shape=box,     fillcolor="#FF99DD"];
    TPMT_metab    [label="TPMT\nMetabolism",                          shape=box,     fillcolor="#FF99DD"];
    TGN_active    [label="6-TGN\n(Active thiopurine\nDNA incorporation)", shape=box, fillcolor="#FF66BB"];
    IVIg_dose     [label="IVIg\n2 g/kg\nover 5 days",                 shape=box,     fillcolor="#FF99DD"];
    IVIg_FcRn_sat [label="FcRn\nSaturation\n→ IgG catabolism",        shape=box,     fillcolor="#FF66BB"];
    IVIg_FcR_block[label="FcγR\nBlockade",                            shape=box,     fillcolor="#FF99DD"];
    dapsone       [label="Dapsone\n50-200 mg/day\n(anti-neutrophil)", shape=box,     fillcolor="#FF99DD"];
    CsA_drug      [label="Cyclosporine\n3-5 mg/kg/day",              shape=box,     fillcolor="#FF99DD"];
    belimumab     [label="Belimumab\n(BAFF inhibitor)\n200mg/4wk SC", shape=box,     fillcolor="#FF99DD"];
    efgartigimod  [label="Efgartigimod\n(FcRn blocker)\n→ IgG lowering", shape=box,  fillcolor="#FF66BB"];
    rozanolixizumab [label="Rozanolixizumab\n(FcRn blocker)\nPhase III", shape=box,  fillcolor="#FF66BB"];
  }

  // ==========================================================
  // EDGES — Triggers → Antigen Processing
  // ==========================================================
  HLA_DRB10402  -> MHC_II        [label="DQ5-restricted\nDsg3 binding",  color="#CC0000"];
  HLA_DQB10503  -> MHC_II        [label="DR4-restricted\nDsg1 binding",  color="#CC0000"];
  HLA_DRB10301  -> Treg          [label="protective",                     color="#006600", style=dashed];
  UV_radiation  -> keratinocyte  [label="stress/Dsg3 exposure",           color="#CC0000"];
  drug_trigger  -> Dsg3_protein  [label="hapten/cross-react",             color="#CC0000"];
  infection_trg -> APC_DC        [label="adjuvant/bystander",             color="#CC0000"];
  thymoma       -> thymic_escape [label="T cell tolerance\nfailure",      color="#CC0000"];
  genetic_stress -> keratinocyte [label="neo-antigen",                    color="#CC0000"];
  CTLA4_poly    -> Th0           [label="reduced Treg\nfunction",         color="#CC0000"];
  AIRE_loss     -> thymic_escape [label="Dsg3 not expressed\nin thymus",  color="#CC0000"];

  // Antigen processing
  Dsg3_protein  -> Dsg3_peptide  [label="proteasomal\nprocessing"];
  Dsg1_protein  -> Dsg1_peptide  [label="processing"];
  Dsg3_peptide  -> MHC_II;
  Dsg1_peptide  -> MHC_II;
  MHC_II        -> APC_DC;
  MHC_II        -> APC_macro;
  thymic_escape -> naive_CD4     [label="autoreactive\nescape",           color="#CC0000"];
  AIRE_loss     -> APC_DC        [label="Dsg3 peptide\npresentation"];

  // APC → T cells
  APC_DC        -> Th0           [label="peptide:MHC-II\n→ TCR activation"];
  APC_macro     -> Th0;
  CD28_CTLA4    -> Th0           [label="costimulation"];
  Th0           -> Th2           [label="IL-4 environment"];
  Th0           -> Tfh           [label="CXCR5 up,\nBcl6+"];
  Th0           -> Th17          [label="IL-6 + TGF-β"];
  Th0           -> Treg          [label="TGF-β"];
  Th0           -> Th1           [label="IL-12, minor"];
  ICOS_Tfh      -> Tfh           [label="Tfh maintenance"];

  // T cell cytokines
  Th2           -> IL4;
  Th2           -> IL13;
  Tfh           -> IL21;
  Tfh           -> ICOS_Tfh;
  Tfh           -> CD40L_help;
  Treg          -> IL10_treg;
  Treg          -> TGFb_treg;
  Th17          -> IL17;
  Th1           -> IFNg;

  // T cell → B cell help
  IL21          -> GC_B          [label="GC reaction\npromotion",         color="#006600"];
  CD40L_help    -> naive_B       [label="CD40 ligation\nclass switch",    color="#006600"];
  IL4           -> CSR_IgG       [label="IgG4 switch",                   color="#006600"];
  IL10_treg     -> GC_B          [label="suppression",                   color="#006600", arrowhead=tee];
  TGFb_treg     -> naive_B       [label="suppression",                   color="#006600", arrowhead=tee];
  PD1_exhaust   -> Tfh           [label="checkpoint",                    color="#888800"];

  // B cell differentiation
  pre_B         -> naive_B       [label="maturation"];
  naive_B       -> GC_B          [label="Ag activation"];
  CXCR5_homing  -> GC_B         [label="GC entry"];
  GC_B          -> SHM_GC        [label="mutation"];
  SHM_GC        -> memory_B     [label="positive\nselection"];
  SHM_GC        -> SLPC          [label="PC fate"];
  memory_B      -> plasmablast   [label="re-activation"];
  plasmablast   -> LLPC          [label="BM niche\nhoming"];
  plasmablast   -> SLPC;
  CSR_IgG       -> IGHV_usage;
  PD1_L1_GC     -> GC_B          [label="checkpoint",                    color="#888800"];
  BAFF          -> naive_B       [label="survival signal",               color="#AA9900"];
  BAFF          -> memory_B      [label="survival",                      color="#AA9900"];
  APRIL         -> LLPC          [label="BCMA signaling\nsurvival",      color="#AA9900"];
  BCR_signal    -> naive_B       [label="Btk activation"];

  // Plasma cells → Antibodies
  SLPC          -> AntiDsg3_IgG  [label="secretion"];
  LLPC          -> AntiDsg3_IgG  [label="sustained\nsecretion"];
  SLPC          -> AntiDsg1_IgG;
  LLPC          -> AntiDsg1_IgG;
  IGHV_usage    -> AntiDsg3_IgG4;
  IGHV_usage    -> AntiDsg1_IgG4;
  IGHV_usage    -> AntiDsg3_IgG1;

  // Antibody effectors
  FcRn_cycle    -> AntiDsg3_IgG  [label="IgG recycling\nextend half-life"];
  FcgR_effector -> RTX_ADCC;
  AntiDsg3_IgG  -> Ab_complex;
  AntiDsg3_IgG4 -> AntiDsg3_IgG [label="dominant subclass\n(no complement)"];

  // Antibodies → Skin target
  AntiDsg3_IgG  -> Dsg3_EC_domain [label="EC1-EC2\nbinding",             color="#CC4400", penwidth=2];
  AntiDsg1_IgG  -> Dsg1_protein  [label="EC1-EC2\nbinding",             color="#CC4400", penwidth=2];
  AntiDsg3_IgG4 -> Dsg3_EC_domain [label="binds\n(no comp fix)",         color="#CC4400"];
  AntiDsg1_IgG4 -> Dsg1_protein;
  AntiDsg3_IgG1 -> C1q_bind      [label="complement\nactivation"];
  anti_PERP     -> keratinocyte  [label="apoptosis\nsignal"];
  anti_a9AChR   -> keratinocyte  [label="nicotinic receptor\nblock"];

  // Desmosome assembly
  Dsg3_protein  -> desmosome_cplx [label="core cadherin"];
  Dsg1_protein  -> desmosome_cplx [label="superficial"];
  Dsg2_intact   -> desmosome_cplx [label="component"];
  Dsg3_EC_domain -> Dsg3_protein;
  plakophilin   -> desmosome_cplx [label="plaque protein"];
  desmoplakin   -> desmosome_cplx [label="scaffold"];
  desmocollin   -> desmosome_cplx [label="cadherin pair"];
  pemphaxin     -> anti_a9AChR    [label="ligand"];
  periplakin    -> desmosome_cplx [label="periplakin\ncomplex"];
  KF14_KF5      -> desmosome_cplx [label="IF attachment"];
  E_cadherin    -> keratinocyte   [label="adherens jxn"];

  // Acantholysis signaling
  AntiDsg3_IgG  -> steric_block  [label="EC1 trans-dimer\nblock",        color="#6600CC", penwidth=2];
  steric_block  -> Dsg3_internal [label="adhesion loss\n→ internalize",  color="#6600CC"];
  AntiDsg3_IgG  -> p38_MAPK      [label="FcR-independent\nsignaling",    color="#6600CC"];
  p38_MAPK      -> Dsg3_internal [label="phosphorylation\n→ endocytosis"];
  AntiDsg3_IgG  -> EGFR_trans    [label="outside-in\nsignaling",         color="#6600CC"];
  EGFR_trans    -> RhoA_ROCK     [label="→ actin"];
  EGFR_trans    -> Src_kinase;
  Src_kinase    -> PKC_alpha     [label="activation"];
  PKC_alpha     -> Dsg3_internal [label="p120-catenin\nphosphorylation"];
  RhoA_ROCK     -> cytokeratin_rt [label="stress fiber\ncontraction"];
  PLC_pathway   -> PKC_alpha     [label="Ca2+/DAG"];
  AntiDsg3_IgG  -> PLC_pathway;
  Akt_PI3K      -> mTOR_sig;
  STAT3_sig     -> caspase_act   [label="Bcl-2 down"];
  FasL_pathway  -> caspase_act   [label="extrinsic"];
  Dsg3_internal -> acantholysis  [label="Dsg3 loss →\ncell separation", color="#CC0000", penwidth=3];
  cytokeratin_rt -> acantholysis [label="cytoskeleton\ncollapse",        color="#CC0000"];
  actin_dysreg  -> acantholysis  [label="cortical actin\nloss",          color="#CC0000"];
  caspase_act   -> acantholysis  [label="apoptotic\nacantholysis"];

  // Complement & Innate
  C1q_bind      -> C3b_opson;
  C3b_opson     -> MAC_form;
  MAC_form      -> keratinocyte  [label="membrane\nattack"];
  C3b_opson     -> C5a_anaphyl;
  C5a_anaphyl   -> neutrophil_inf [label="chemotaxis"];
  C5a_anaphyl   -> mast_cell_deg;
  Ab_complex    -> C1q_bind;
  neutrophil_inf -> histamine_rel;
  neutrophil_inf -> uPA_plasmin  [label="NET/elastase"];
  neutrophil_inf -> NETosis;
  mast_cell_deg -> histamine_rel;
  mast_cell_deg -> TNFa_innate;
  IgE_mast      -> mast_cell_deg;
  TNFa_innate   -> IL6_innate    [label="cascade"];
  IL6_innate    -> STAT3_sig;
  IL1b_innate   -> p38_MAPK;
  IL8_CXCL8     -> neutrophil_inf [label="chemotaxis"];
  uPA_plasmin   -> acantholysis  [label="protease\ndigestion"];

  // Clinical outcomes
  acantholysis  -> oral_blister  [label="Dsg3 >> Dsg1\noral/mucosa",    color="#AA8800", penwidth=2];
  acantholysis  -> skin_blister  [label="Dsg3 + Dsg1\nskin",            color="#AA8800", penwidth=2];
  acantholysis  -> conjunctival;
  acantholysis  -> genital_mucos;
  oral_blister  -> PDAI_score;
  skin_blister  -> PDAI_score;
  PDAI_score    -> ABSIS_score;
  PDAI_score    -> DQLI_score;
  PDAI_score    -> relapse       [label="PDAI ≥5\nfrom minimal", style=dashed];
  PDAI_score    -> complete_rem  [dir=back, label="treatment\nsuccess"];
  PDAI_score    -> partial_rem;
  skin_blister  -> secondary_inf [label="barrier\nbreakdown"];
  secondary_inf -> mortality_end;
  skin_blister  -> Tzanck_smear;
  skin_blister  -> DIF_test;
  AntiDsg3_IgG  -> ELISA_Dsg;
  AntiDsg1_IgG  -> ELISA_Dsg;
  ELISA_Dsg     -> PDAI_score    [label="titer ∝\ndisease\nactivity", style=dashed];
  steroid_compl -> mortality_end [label="iatrogenic\nrisk"];

  // Corticosteroid PK/PD
  PRED_dose     -> PRED_gut      [label="oral"];
  PRED_gut      -> PRED_C1       [label="F=0.82"];
  PRED_C1       -> PRED_C2       [label="Cl=5.1 L/h\ndistrib"];
  PRED_C2       -> PRED_C1       [label="redistrib"];
  IVMP_pulse    -> PRED_C1       [label="rapid Cmax"];
  PRED_C1       -> GR_alpha      [label="cytoplasmic\nbinding"];
  GR_alpha      -> GRE_transact  [label="nuclear\ntranslocation"];
  GR_alpha      -> NFkB_inh      [label="protein-protein\ntethering"];
  GR_alpha      -> AP1_inh;
  GRE_transact  -> MKP1_induct;
  GRE_transact  -> lipocortin1;
  MKP1_induct   -> p38_MAPK      [arrowhead=tee, label="inactivate"];
  NFkB_inh      -> TNFa_innate   [arrowhead=tee, color="#006600"];
  NFkB_inh      -> IL6_innate    [arrowhead=tee, color="#006600"];
  NFkB_inh      -> IL1b_innate   [arrowhead=tee, color="#006600"];
  NFkB_inh      -> IL8_CXCL8    [arrowhead=tee, color="#006600"];
  AP1_inh       -> Th2           [arrowhead=tee, label="reduce IL-4\nIL-13", color="#006600"];
  GRE_transact  -> Tfh           [arrowhead=tee, label="Tfh suppression", color="#006600"];
  GRE_transact  -> GC_B          [arrowhead=tee, color="#006600"];
  PRED_C1       -> pred_SE       [label="dose-dependent"];

  // Rituximab PK/PD
  RTX_dose      -> RTX_C1        [label="IV infusion\nInfusion Rxn risk"];
  RTX_C1        -> RTX_C2        [label="distribution\nVd=3.1→4.4 L"];
  RTX_C2        -> RTX_C1        [label="redistribution"];
  RTX_half_life -> RTX_C1        [label="eliminates"];
  RTX_C1        -> CD20_target   [label="target binding\nkon=0.3/nM/h"];
  CD20_target   -> RTX_ADCC      [label="Fc engagement"];
  CD20_target   -> RTX_CDC       [label="C1q binding"];
  CD20_target   -> RTX_apoptosis [label="direct signal"];
  RTX_ADCC      -> B_depletion   [label="NK lysis",                     color="#003399", penwidth=2];
  RTX_CDC       -> B_depletion   [label="complement\nlysis",            color="#003399"];
  RTX_apoptosis -> B_depletion   [label="direct\napoptosis",            color="#003399"];
  B_depletion   -> naive_B       [arrowhead=tee, label="-99%",          color="#003399", penwidth=2];
  B_depletion   -> memory_B      [arrowhead=tee, label="-90%",          color="#003399"];
  B_depletion   -> plasmablast   [arrowhead=tee,                        color="#003399"];
  B_depletion   -> B_repop_RTX   [label="→ 6-12 months\nlater"];
  B_repop_RTX   -> memory_B      [label="reconstitution\n→ naive-like"];
  RTX_C1        -> HACA_form     [label="immunogenicity\nrisk"];
  HACA_form     -> RTX_C1        [arrowhead=tee, label="accelerated\nclearance"];
  LLPC          -> B_depletion   [arrowhead=tee, label="CD20-\nresistant", style=dashed];

  // MMF/AZA/IVIg PK/PD
  MMF_dose      -> MPA_plasma    [label="de-esterification\nF=0.94"];
  MPA_plasma    -> IMPDH_block   [label="competitive\ninhibition"];
  IMPDH_block   -> GC_B          [arrowhead=tee, label="GC proliferation\nblocked",   color="#660066"];
  IMPDH_block   -> SLPC          [arrowhead=tee, label="PC expansion\nblocked",       color="#660066"];

  AZA_dose      -> TPMT_metab    [label="xanthine\noxidase"];
  TPMT_metab    -> TGN_active    [label="6-TGN\nproduction"];
  TGN_active    -> GC_B          [arrowhead=tee, label="DNA synthesis\nblock",        color="#660066"];
  TGN_active    -> Th2           [arrowhead=tee, label="T cell\nsuppression",         color="#660066"];

  IVIg_dose     -> IVIg_FcRn_sat [label="FcRn saturation\n→ 4× IgG cat"];
  IVIg_FcRn_sat -> AntiDsg3_IgG  [arrowhead=tee, label="accelerated\ncatabolism",   color="#660066"];
  IVIg_FcRn_sat -> AntiDsg1_IgG  [arrowhead=tee, color="#660066"];
  IVIg_dose     -> IVIg_FcR_block [label="FcR blockade"];
  IVIg_FcR_block -> C1q_bind     [arrowhead=tee, label="Fc block"];
  IVIg_FcR_block -> FcgR_effector [arrowhead=tee];

  dapsone       -> neutrophil_inf [arrowhead=tee, label="MPO inhibition\nNET↓",      color="#660066"];
  belimumab     -> BAFF           [arrowhead=tee, label="BAFF block",               color="#003399", penwidth=2];
  efgartigimod  -> FcRn_cycle     [arrowhead=tee, label="FcRn block\n→ IgG↓↓",      color="#003399", penwidth=2];
  rozanolixizumab -> FcRn_cycle   [arrowhead=tee, label="FcRn block",               color="#003399"];
  CsA_drug      -> Tfh            [arrowhead=tee, label="IL-2/calcineurin\nblock",   color="#660066"];
  CsA_drug      -> Th2            [arrowhead=tee, color="#660066"];

  // Cross-cluster feedback
  PRED_C1       -> steroid_compl  [label="ADR"];
  steroid_compl -> secondary_inf  [label="immunosupp\nrisk"];
}
