digraph VTE_QSP_Model {
    graph [
        rankdir=LR,
        splines=ortho,
        nodesep=0.35,
        ranksep=0.7,
        fontname="Helvetica",
        bgcolor="#f8f9fa",
        label="Venous Thromboembolism (VTE) — Quantitative Systems Pharmacology Model\nCoagulation Cascade · Platelet Biology · Fibrinolysis · Drug PK/PD · Clinical Endpoints",
        labelloc=t,
        fontsize=14,
        fontcolor="#212121"
    ];
    node [fontname="Helvetica", fontsize=8, style="filled,rounded", shape=box, margin="0.1,0.05"];
    edge [fontname="Helvetica", fontsize=7, arrowsize=0.7];

    // ═══════════════════════════════════════════════════════════
    // CLUSTER 1: Virchow's Triad & Risk Factors
    // ═══════════════════════════════════════════════════════════
    subgraph cluster_risk {
        label="① Virchow's Triad & Risk Factors";
        style=filled; fillcolor="#fff3e0"; color="#e65100";
        fontcolor="#e65100"; fontsize=10;

        node [fillcolor="#ffe0b2"];
        VenStasis     [label="Venous Stasis\n(Immobility/Surgery/\nProlonged Bed Rest)"];
        EndoInj       [label="Endothelial Injury\n(Trauma/Surgery/\nCVC Insertion)"];
        Hypercoag     [label="Hypercoagulable\nState"];
        FVLeiden      [label="Factor V Leiden\n(FV R506Q)\nAPC Resistance"];
        PT20210A      [label="Prothrombin G20210A\n(↑ FII levels)"];
        ATDefic       [label="Antithrombin III\nDeficiency"];
        ProtCDefic    [label="Protein C\nDeficiency"];
        ProtSDefic    [label="Protein S\nDeficiency"];
        APS_risk      [label="Antiphospholipid\nAntibody Syndrome"];
        OralContr     [label="Oral Contraceptives/\nHRT (↑ FII/FVII/X)"];
        Malignancy    [label="Active Malignancy\n(Trousseau Syndrome\nTF/MV shedding)"];
        CVC           [label="Central Venous\nCatheter (CVC)"];
        Obesity_r     [label="Obesity (BMI>30)\n↑ PAI-1/TF\n↓ tPA"];
        AgeFactor     [label="Advanced Age\n>60yr (↓ AT\n↑ FVIII/vWF)"];
        Immobility    [label="Hospitalization\nImmobility\n>3 days"];
        Pregnancy     [label="Pregnancy/\nPuerperium\n(↑ Clotting Factors)"];
        PrevVTE       [label="Prior VTE\nHistory\n(↑ Recurrence Risk)"];

        FVLeiden -> Hypercoag;
        PT20210A -> Hypercoag;
        ATDefic -> Hypercoag;
        ProtCDefic -> Hypercoag;
        ProtSDefic -> Hypercoag;
        APS_risk -> Hypercoag;
        OralContr -> Hypercoag;
        Malignancy -> Hypercoag;
        Obesity_r -> Hypercoag;
        Pregnancy -> Hypercoag;
        Immobility -> VenStasis;
    }

    // ═══════════════════════════════════════════════════════════
    // CLUSTER 2: Endothelial Biology
    // ═══════════════════════════════════════════════════════════
    subgraph cluster_endothelium {
        label="② Vascular Endothelium";
        style=filled; fillcolor="#e8f5e9"; color="#2e7d32";
        fontcolor="#2e7d32"; fontsize=10;

        node [fillcolor="#c8e6c9"];
        EndoNormal    [label="Normal Endothelium\n(Antithrombotic\nPhenotype)"];
        EndoDysf      [label="Endothelial\nDysfunction/Injury"];
        TF_Endo       [label="Tissue Factor (TF)\nExpression ↑"];
        vWF_WP        [label="vWF Release\n(Weibel-Palade\nBodies)"];
        PGI2          [label="Prostacyclin (PGI2)\nSynthesis\n(Anti-platelet)"];
        NO_Endo       [label="Nitric Oxide (NO)\nProduction\n(Anti-aggregation)"];
        TM_Endo       [label="Thrombomodulin (TM)\nExpression"];
        EPCR_Endo     [label="EPCR (Endothelial\nProtein C Receptor)"];
        TFPI_Endo     [label="TFPI Synthesis\n(Constitutive)"];
        PAI1_Endo     [label="PAI-1 Release\n(Acute Phase)"];
        tPA_Endo      [label="tPA Release\n(Fibrinolytic)"];
        P_selectin_E  [label="P-selectin\nExpression\n(Platelet/Leukocyte\nRecruitment)"];
        ICAM1         [label="ICAM-1/VCAM-1\nUpregulation\n(Leukocyte Adhesion)"];
        MV_Shed       [label="Microparticle\nShedding (TF+)"];

        EndoNormal -> PGI2 [label="Constitutive"];
        EndoNormal -> NO_Endo [label="Constitutive\n(eNOS)"];
        EndoNormal -> TM_Endo [label="Constitutive"];
        EndoNormal -> EPCR_Endo [label="Constitutive"];
        EndoNormal -> TFPI_Endo [label="Constitutive"];
        EndoNormal -> tPA_Endo [label="On demand"];
        EndoNormal -> EndoDysf [label="Injury/\nInflammation"];
        EndoDysf -> TF_Endo [label="↑"];
        EndoDysf -> vWF_WP [label="↑ Release"];
        EndoDysf -> PAI1_Endo [label="↑"];
        EndoDysf -> P_selectin_E [label="↑"];
        EndoDysf -> ICAM1 [label="↑"];
        EndoDysf -> MV_Shed [label="↑"];
    }

    // ═══════════════════════════════════════════════════════════
    // CLUSTER 3: Extrinsic Pathway
    // ═══════════════════════════════════════════════════════════
    subgraph cluster_extrinsic {
        label="③ Extrinsic Pathway (TF Pathway)";
        style=filled; fillcolor="#fce4ec"; color="#c2185b";
        fontcolor="#c2185b"; fontsize=10;

        node [fillcolor="#f8bbd0"];
        TF_Exposed    [label="Tissue Factor (TF)\nExposed/Expressed\n(Subendothelium)"];
        FVII_z        [label="Factor VII\n(Zymogen)\n~10 nM plasma"];
        FVIIa_free    [label="Factor VIIa\n(~0.1% circulating)"];
        TF_FVIIa      [label="TF-FVIIa Complex\n(Extrinsic Tenase)"];
        FX_ext        [label="Factor X → FXa\n(Extrinsic activation)"];
        FIX_ext       [label="Factor IX → FIXa\n(Extrinsic activation)"];
        TFPI_block    [label="TFPI\n(Rapid inhibition\nof TF-FVIIa-FXa)"];
        TNF_TF        [label="TNFα/IL-1β\n→ ↑TF Expression\n(Inflammatory TF)"];

        TF_Exposed -> TF_FVIIa [label="Binds FVII/FVIIa"];
        FVII_z -> FVIIa_free [label="FIIa/FXa/FIXa\nactivate FVII"];
        FVIIa_free -> TF_FVIIa;
        TF_FVIIa -> FX_ext [label="Proteolysis\nof FX"];
        TF_FVIIa -> FIX_ext [label="Proteolysis\nof FIX"];
        TFPI_block -> TF_FVIIa [label="Inhibits", color=red, style=dashed, arrowhead=tee];
        TNF_TF -> TF_Exposed [label="Cytokine\nInduction"];
    }

    // ═══════════════════════════════════════════════════════════
    // CLUSTER 4: Intrinsic Pathway
    // ═══════════════════════════════════════════════════════════
    subgraph cluster_intrinsic {
        label="④ Intrinsic Pathway (Contact Activation)";
        style=filled; fillcolor="#e3f2fd"; color="#1565c0";
        fontcolor="#1565c0"; fontsize=10;

        node [fillcolor="#bbdefb"];
        FXII_z        [label="Factor XII\n(Hageman Factor)"];
        FXIIa         [label="Factor XIIa\n(Active)"];
        HMWK          [label="HMWK\n(Kininogen\nCofactor)"];
        PreKallik     [label="Prekallikrein\n→ Kallikrein"];
        Kallikrein    [label="Kallikrein\n(+ HMWK →\nAmplifies FXIIa)"];
        BradyKinin    [label="Bradykinin\n(Inflammation/\nVasodilatation)"];
        FXI_z         [label="Factor XI\n(Zymogen)"];
        FXIa          [label="Factor XIa\n(Active)"];
        FIX_int       [label="Factor IX → FIXa\n(Intrinsic)"];
        FVIII_z       [label="Factor VIII\n(Zymogen\nCarried by vWF)"];
        FVIIIa        [label="Factor VIIIa\n(Active Cofactor\nFIIa-activated)"];
        Int_Tenase    [label="Intrinsic Tenase\nFIXa-FVIIIa\n(on PS surface)"];
        FX_int        [label="Factor X → FXa\n(Intrinsic tenase)"];
        vWF_FVIII     [label="vWF-FVIII\nComplex\n(Carrier)"];

        FXII_z -> FXIIa [label="Contact: collagen\nglass/negsurf"];
        HMWK -> FXIIa [label="Cofactor"];
        FXIIa -> PreKallik [label="Activates"];
        PreKallik -> Kallikrein;
        Kallikrein -> FXIIa [label="Feedback\nAmplification"];
        Kallikrein -> BradyKinin [label="HMWK cleavage"];
        FXIIa -> FXIa [label="Activates FXI"];
        FXI_z -> FXIa;
        FXIa -> FIX_int [label="Activates FIX"];
        FVIII_z -> FVIIIa [label="Thrombin\nactivation"];
        vWF_FVIII -> FVIII_z [label="Protects FVIII\nfrom proteolysis"];
        FIX_int -> Int_Tenase;
        FVIIIa -> Int_Tenase;
        Int_Tenase -> FX_int [label="Activates FX\n~50x extrinsic"];
    }

    // ═══════════════════════════════════════════════════════════
    // CLUSTER 5: Common Pathway & Thrombin Generation
    // ═══════════════════════════════════════════════════════════
    subgraph cluster_common {
        label="⑤ Common Pathway — Thrombin Generation";
        style=filled; fillcolor="#ede7f6"; color="#6a1b9a";
        fontcolor="#6a1b9a"; fontsize=10;

        node [fillcolor="#d1c4e9"];
        FX_pool_cp    [label="Factor X Pool\n(FX)\nt½ ~40h"];
        FXa_active    [label="Factor Xa\n(Active Serine\nProtease)"];
        FV_z          [label="Factor V\n(Zymogen)\n~20 nM plasma"];
        FVa           [label="Factor Va\n(Active Cofactor\nFIIa-activated)"];
        Prothrombinase[label="Prothrombinase\nComplex\nFXa-FVa\n(PS surface)"];
        FII_pool_cp   [label="Prothrombin (FII)\n~1.4 μM plasma\nt½ ~60h"];
        FIIa_thrombin [label="Thrombin (FIIa)\n(Active Serine\nProtease)"];
        Fibrinogen_cp [label="Fibrinogen\n(FI) ~7-10 μM\n(α2β2γ2 hexamer)"];
        FPA_FPB       [label="Fibrinopeptides\nA & B Released\n(FPA/FPB)"];
        Fibrin_Mon    [label="Fibrin Monomers\n(Soluble)"];
        Fibrin_Pol    [label="Fibrin Polymer\n(Soft Clot)"];
        FXIII_z       [label="Factor XIII\n(Transglutaminase\nZymogen)"];
        FXIIIa        [label="Factor XIIIa\n(Active)\n+ Ca2+"];
        Fibrin_XL     [label="Cross-linked Fibrin\n(Stable Clot\nFibrin Network)"];

        FX_pool_cp -> FXa_active [label="Activation by\nExtrinsic/Intrinsic\nTenase"];
        FV_z -> FVa [label="Thrombin\nactivates FV"];
        FXa_active -> Prothrombinase;
        FVa -> Prothrombinase;
        Prothrombinase -> FIIa_thrombin [label="Cleaves\nProthrombin\n~300s-1 rate"];
        FII_pool_cp -> FIIa_thrombin;
        FIIa_thrombin -> FPA_FPB [label="Cleaves Fgn\n→ releases FPA/FPB"];
        Fibrinogen_cp -> FPA_FPB;
        FPA_FPB -> Fibrin_Mon;
        Fibrin_Mon -> Fibrin_Pol [label="Self-assembly\n(half-staggered)"];
        FIIa_thrombin -> FXIIIa [label="Activates FXIII\n+ Ca2+"];
        FXIII_z -> FXIIIa;
        FXIIIa -> Fibrin_XL [label="ε-(γ-glutamyl)lysine\ncross-links"];
        Fibrin_Pol -> Fibrin_XL;

        // Thrombin positive feedback (amplification)
        FIIa_thrombin -> FVa [label="Amplifies\nFV→FVa", color="#7b1fa2", style=bold];
        FIIa_thrombin -> FVIIIa [label="Amplifies\nFVIII→FVIIIa", color="#7b1fa2", style=bold];
        FIIa_thrombin -> FXIa [label="Amplifies\nFXI→FXIa", color="#7b1fa2", style=bold];
    }

    // ═══════════════════════════════════════════════════════════
    // CLUSTER 6: Platelet Activation
    // ═══════════════════════════════════════════════════════════
    subgraph cluster_platelets {
        label="⑥ Platelet Activation & Aggregation";
        style=filled; fillcolor="#fff8e1"; color="#f57f17";
        fontcolor="#f57f17"; fontsize=10;

        node [fillcolor="#ffecb3"];
        Plt_rest      [label="Resting Platelets\n(Discoid ~2×10¹¹/L)"];
        GPIb_bind     [label="GPIb-IX-V\n+ vWF (High Shear)\nTethering"];
        GPVI_coll     [label="GPVI\n+ Collagen\nActivation Signal"];
        PAR1_PAR4     [label="PAR1/PAR4\n+ Thrombin\nActivation"];
        P2Y12_ADP     [label="P2Y12/P2Y1\n+ ADP\n(Gi signaling)"];
        TP_TXA2       [label="TP Receptor\n+ TXA2/PGH2\nActivation"];

        IP_PGI2       [label="IP Receptor\n+ PGI2\n(↑cAMP → Inhibit)"];
        Ca2plus_plt   [label="Cytosolic Ca²⁺ ↑\n(IP3/DAG pathway)"];
        PKC_plt       [label="PKC Activation\n(Granule Release)"];
        PI3K_plt      [label="PI3K/Akt\nActivation"];
        cAMP_plt      [label="↓ cAMP\n(Gi: P2Y12)"];

        Plt_active    [label="Activated Platelets\n(Shape Changed)"];
        Dense_Gran    [label="Dense Granule\nSecretion\n(ADP/Serotonin/Ca2+)"];
        Alpha_Gran    [label="α-Granule Release\n(P-selectin/PF4/\nvWF/FV/Fgn)"];
        GPIIbIIIa     [label="GPIIb/IIIa (αIIbβ3)\nInside-Out Activation\n(High Affinity)"];
        FgBridge      [label="Fibrinogen/vWF\nBridge (Aggregation)"];
        Plt_aggr      [label="Platelet Aggregate\n(Primary Hemostatic Plug)"];
        PS_exposure   [label="Phosphatidylserine\nExposure\n(Procoagulant Surface)"];
        TXA2_synth    [label="TXA2 Synthesis\n(COX-1/TXS)\n→ Amplification"];

        Plt_rest -> GPIb_bind [label="vWF exposed\n(injury/shear)"];
        GPIb_bind -> Plt_active;
        Plt_rest -> GPVI_coll [label="Collagen"];
        GPVI_coll -> Ca2plus_plt;
        Plt_rest -> PAR1_PAR4 [label="Thrombin (FIIa)"];
        PAR1_PAR4 -> Ca2plus_plt;
        ADP_releas -> P2Y12_ADP [label="Autocrine/\nParacrine"];
        P2Y12_ADP -> cAMP_plt;
        TXA2_synth -> TP_TXA2;
        TP_TXA2 -> Ca2plus_plt;
        PGI2 -> IP_PGI2 [label="Endothelial\nPGI2"];
        IP_PGI2 -> cAMP_plt [label="↑ cAMP\n(Inhibitory)", style=dashed, color=green];
        Ca2plus_plt -> PKC_plt;
        Ca2plus_plt -> PI3K_plt;
        cAMP_plt -> PI3K_plt [label="Cross-talk"];
        PKC_plt -> Plt_active;
        PI3K_plt -> Plt_active;
        Plt_active -> Dense_Gran;
        Plt_active -> Alpha_Gran;
        Plt_active -> GPIIbIIIa;
        Plt_active -> PS_exposure;
        Plt_active -> TXA2_synth;
        Dense_Gran -> ADP_releas [label="ADP released"];
        Alpha_Gran -> vWF_WP [label="vWF released"];
        GPIIbIIIa -> FgBridge;
        FgBridge -> Plt_aggr;
        PS_exposure -> Prothrombinase [label="Assembly site\n↑ 1000x rate"];
        Plt_aggr -> Fibrin_XL [label="Platelet-fibrin\nthrombus"];
    }

    node [fillcolor="#ffecb3"];
    ADP_releas [label="ADP\n(Released from\nDense Granules)"];

    // ═══════════════════════════════════════════════════════════
    // CLUSTER 7: Natural Anticoagulant Systems
    // ═══════════════════════════════════════════════════════════
    subgraph cluster_natural_anticoag {
        label="⑦ Natural Anticoagulant Systems";
        style=filled; fillcolor="#e0f7fa"; color="#00695c";
        fontcolor="#00695c"; fontsize=10;

        node [fillcolor="#b2ebf2"];
        AT3_free      [label="Antithrombin III\n(AT3/Serpin C1)\n~2.3 μM plasma"];
        AT3_HS        [label="AT3-Heparan Sulfate\nComplex (Endothelial\nHS Proteoglycan)"];
        AT3_Xa_inh    [label="AT3→FXa Inhibition\n(t½ ~23h alone\n~20s +heparin)"];
        AT3_IIa_inh   [label="AT3→FIIa Inhibition\n(FIXa/FXIa/FXIIa)"];

        ProtC_z       [label="Protein C\n(Zymogen)\n~65 nM plasma\nVit K-dependent"];
        ProtC_act     [label="Activated Protein C\n(APC)\nSerine Protease"];
        ProtS_free    [label="Protein S\n(Cofactor)\n~~350 nM free\nVit K-dependent"];
        TM_complex    [label="Thrombin-TM\nComplex\n(Rate ↑ 20,000x)"];
        EPCR_complex  [label="EPCR-ProtC\nComplex\n(Rate ↑ 20x)"];
        APC_FVa_inh   [label="APC Cleaves FVa\n(R506, R306)\n→ Inactivation"];
        APC_FVIIIa_i  [label="APC Cleaves FVIIIa\n→ Inactivation"];

        C4BP          [label="C4b-Binding Protein\n(Binds ProtS 60%)\n↓ APC cofactor"];

        TFPI_full     [label="TFPI\n(Tissue Factor\nPathway Inhibitor)\nKunitz domain 1,2,3"];
        TFPI_FXa      [label="TFPI-FXa Complex\n→ Inhibits TF-FVIIa"];

        AT3_free -> AT3_HS [label="Binds HS\n(Vessel wall)"];
        AT3_HS -> AT3_Xa_inh [label="Active complex"];
        AT3_HS -> AT3_IIa_inh [label="Active complex"];
        AT3_free -> AT3_Xa_inh [label="Slow (basal)"];
        AT3_free -> AT3_IIa_inh [label="Slow (basal)"];

        TM_Endo -> TM_complex [label="TM binds\nThrombin"];
        FIIa_thrombin -> TM_complex;
        TM_complex -> ProtC_act [label="Activates PC\n(+EPCR 20x)"];
        EPCR_Endo -> EPCR_complex;
        ProtC_z -> EPCR_complex;
        EPCR_complex -> ProtC_act [label="Enhanced\nactivation"];
        ProtC_z -> ProtC_act;
        ProtC_act -> APC_FVa_inh [label="+ ProtS"];
        ProtC_act -> APC_FVIIIa_i [label="+ ProtS"];
        ProtS_free -> APC_FVa_inh [label="Cofactor"];
        ProtS_free -> APC_FVIIIa_i [label="Cofactor"];
        C4BP -> ProtS_free [label="Binds (60%)\n↓ Free ProtS\n(OCP effect)"];

        TFPI_full -> TFPI_FXa [label="Binds FXa first\n(Kunitz-2)"];
        TFPI_FXa -> TF_FVIIa [label="Quaternary complex\ninhibits TF-FVIIa-FXa", color=red, style=dashed, arrowhead=tee];
        FXa_active -> TFPI_FXa;
    }

    // ═══════════════════════════════════════════════════════════
    // CLUSTER 8: Fibrinolysis
    // ═══════════════════════════════════════════════════════════
    subgraph cluster_fibrinolysis {
        label="⑧ Fibrinolytic System";
        style=filled; fillcolor="#f3e5f5"; color="#6a1b9a";
        fontcolor="#6a1b9a"; fontsize=10;

        node [fillcolor="#e1bee7"];
        Plasminogen   [label="Plasminogen\n(Glu-Plg) ~2 μM\nFibrin-bound"];
        tPA_circ      [label="tPA\n(t-PA) Endothelial\n~70 pM circulating"];
        uPA_circ      [label="uPA\n(u-PA) Urokinase\nMonocyte/Endothelium"];
        SCU_PA        [label="scuPA (proUK)\n→ uPA (Fibrin-bound)"];
        Plasmin_act   [label="Plasmin\n(Serine Protease)\nFibrin + Protein"];
        FDP_pieces    [label="Fibrin Degradation\nProducts (FDP)\nX/Y/D/E Fragments"];
        D_dimer_fib   [label="D-dimer\n(D:D Fragment)\nCross-linked FDP\n[VTE Biomarker]"];
        PAI1_circ     [label="PAI-1\n(Serpin E1)\nMajor tPA/uPA\nInhibitor"];
        PAI2          [label="PAI-2\n(Placental)\n↑ Pregnancy"];
        Alpha2AP      [label="α2-Antiplasmin\n(SERPINF2)\nRapid Plasmin\nInhibitor"];
        TAFI          [label="TAFI\n(Thrombin-Activatable\nFibrinolysis Inhibitor\nCPB2)"];
        TAFI_act      [label="TAFIa\n(Active)\n→ ↓ Fibrin\nLysine sites"];
        Fibrin_lysis  [label="Fibrin Clot\nDissolving\n(Thrombolysis)"];

        Plasminogen -> Plasmin_act [label="tPA/uPA\n(Fibrin surface)"];
        tPA_circ -> Plasmin_act [label="Activates on\nfibrin surface\n(300x ↑)"];
        uPA_circ -> Plasmin_act [label="Activates\n(fluid phase)"];
        SCU_PA -> uPA_circ;
        Plasmin_act -> FDP_pieces [label="Digests\ncross-linked fibrin"];
        Fibrin_XL -> FDP_pieces [label="Substrate"];
        FDP_pieces -> D_dimer_fib [label="D:D fragment\n(cross-linked)"];
        PAI1_circ -> tPA_circ [label="Inhibits (k=7×10⁷)", color=red, style=dashed, arrowhead=tee];
        PAI1_circ -> uPA_circ [label="Inhibits", color=red, style=dashed, arrowhead=tee];
        Alpha2AP -> Plasmin_act [label="Rapid inhibition\n(k=3.7×10⁷)", color=red, style=dashed, arrowhead=tee];
        FIIa_thrombin -> TAFI [label="Activates TAFI\n(+TM cofactor)"];
        TM_complex -> TAFI_act [label="↑ TAFI activation\n300x"];
        TAFI -> TAFI_act;
        TAFI_act -> Plasminogen [label="Removes C-terminal\nlysines on fibrin\n→ ↓ Plg binding", color=red, style=dashed, arrowhead=tee];
        Plasmin_act -> Fibrin_lysis [label="Dissolves clot"];
    }

    // ═══════════════════════════════════════════════════════════
    // CLUSTER 9: Drug Pharmacokinetics
    // ═══════════════════════════════════════════════════════════
    subgraph cluster_pk {
        label="⑨ Drug Pharmacokinetics";
        style=filled; fillcolor="#e8eaf6"; color="#283593";
        fontcolor="#283593"; fontsize=10;

        node [fillcolor="#c5cae9"];
        // Rivaroxaban PK
        RIV_dose      [label="Rivaroxaban\nDose\n(10/15/20 mg)"];
        RIV_gut       [label="Rivaroxaban\nGI Absorption\n(F 80-100% fed)"];
        RIV_cent      [label="Rivaroxaban\nCentral Plasma\nCp (ng/mL)\nTmax ~2-4h"];
        RIV_periph    [label="Rivaroxaban\nPeripheral Tissue\nVd ~50L"];
        RIV_elim      [label="Rivaroxaban\nElimination\n(CYP3A4 33%+\nDirect renal 33%)\nt½ 5-9h"];

        // Apixaban PK
        APIX_dose     [label="Apixaban\nDose\n(2.5/5/10 mg)"];
        APIX_cent     [label="Apixaban\nCentral Plasma\nCp (ng/mL)\nTmax ~3h F~50%"];
        APIX_elim     [label="Apixaban\nElimination\n(CYP3A4 25%+\nIntestinal 56%)\nt½ 12h"];

        // Dabigatran PK
        DABI_dose     [label="Dabigatran Etexilate\nProdrug\n(75/110/150 mg)"];
        DABI_cent     [label="Dabigatran\nCentral Plasma\nCp (ng/mL)\nF~3-7% (pH-dep)"];
        DABI_elim     [label="Dabigatran\nRenal Excretion\n(80%)\nt½ 12-17h"];

        // Warfarin PK
        WARF_dose     [label="Warfarin\nOral Dose\n(1-10 mg)"];
        WARF_cent     [label="Warfarin\nCentral Plasma\nCp (ng/mL)\nF~100% t½ 36h"];
        WARF_VK       [label="Warfarin → VK\nEpoxide Reductase\nInhibition (VKORC1)"];

        // Enoxaparin PK
        ENOX_dose     [label="Enoxaparin\nSC Dose\n(40/60/80/100 mg)"];
        ENOX_cent     [label="Enoxaparin\nAnti-Xa Activity\n(IU/mL)\nTmax ~3-5h F~92%"];
        ENOX_elim     [label="Enoxaparin\nRenal Clearance\n(Renal+Saturable\nHepatosplenic)\nt½ 4-7h"];

        // UFH
        UFH_infus     [label="UFH IV\nContinuous\nInfusion\n(aPTT-guided)"];
        UFH_cent      [label="UFH\nAnti-Xa/IIa\nActivity"];

        // Alteplase
        ALT_infus     [label="Alteplase (rt-PA)\nIV Infusion\n(0.6-100 mg)"];
        ALT_cent      [label="Alteplase\nPlasma\nCp (μg/mL)\nt½ ~5min"];

        RIV_dose -> RIV_gut -> RIV_cent;
        RIV_cent -> RIV_periph [dir=both, label="k12/k21"];
        RIV_cent -> RIV_elim;

        APIX_dose -> APIX_cent [label="F~50%"];
        APIX_cent -> APIX_elim;

        DABI_dose -> DABI_cent [label="Esterase\nconversion"];
        DABI_cent -> DABI_elim;

        WARF_dose -> WARF_cent [label="F~100%"];
        WARF_cent -> WARF_VK [label="PD Effect"];
        WARF_cent -> WARF_elim_node [label="CYP2C9\n(t½ 36h)"];

        ENOX_dose -> ENOX_cent [label="SC\nabsorption"];
        ENOX_cent -> ENOX_elim;

        UFH_infus -> UFH_cent [label="IV direct"];
        ALT_infus -> ALT_cent [label="IV infusion"];
    }
    node [fillcolor="#c5cae9"];
    WARF_elim_node [label="Warfarin\nMetabolism\n(CYP2C9/3A4)\nt½ ~36h"];

    // ═══════════════════════════════════════════════════════════
    // CLUSTER 10: Drug Pharmacodynamics
    // ═══════════════════════════════════════════════════════════
    subgraph cluster_pd {
        label="⑩ Drug Pharmacodynamics & PK-PD Linkage";
        style=filled; fillcolor="#fbe9e7"; color="#bf360c";
        fontcolor="#bf360c"; fontsize=10;

        node [fillcolor="#ffccbc"];
        // Xa inhibitors
        FXa_inhib     [label="FXa Inhibition\nRivaroxaban: Ki ~0.4nM\nApixaban: Ki ~0.08nM\nEdoxaban: Ki ~0.56nM"];
        FXa_inhib_inh [label="↓ Prothrombinase\nActivity\n→ ↓ Thrombin\nGeneration"];

        // DTI
        DTI_inhib     [label="Direct Thrombin\nInhibition\nDabigatran: Ki ~4.5nM\nArgatroban: Ki ~19nM"];
        DTI_effects   [label="↓ Fibrinogen→Fibrin\n↓ PAR1 activation\n↓ FXIII activation\n↓ Plt activation (PAR)"];

        // Warfarin/VKA PD
        VK_cycle      [label="Vitamin K Cycle\n(γ-Carboxylation)"];
        VKORC1_gene   [label="VKORC1\nPolymorphism\n(-1639G>A)\nWarfarin Sensitivity"];
        CYP2C9_gene   [label="CYP2C9\n*2/*3 Alleles\n↓ Warfarin\nMetabolism"];
        VitK_ox       [label="Vitamin K (Oxidized)\nEpoxide Form"];
        VitK_red      [label="Vitamin K (Reduced\nHydroquinone KH2)\n↓ by Warfarin"];
        GammaCarbox   [label="γ-Carboxylation\nof Gla-Factors\n(FII,FVII,FIX,FX\nProtC,ProtS)"];
        PIVKA_forms   [label="PIVKA\n(Undercarboxylated\nFactors) — Inactive\n(PIVKA-II = DesProm FII)"];
        FII_syn       [label="Prothrombin\nSynthesis Rate\n(t½ ~60h)"];
        FVII_syn      [label="FVII Synthesis\n(t½ ~4-6h)\nEarliest INR ↑"];
        FIX_syn       [label="FIX Synthesis\n(t½ ~24h)"];
        FX_syn        [label="FX Synthesis\n(t½ ~40h)"];
        INR_calc      [label="INR\n(PT ratio)\nTarget 2.0-3.0\n(2.5-3.5 high-risk)"];

        // Heparin PD
        Hepar_AT      [label="Heparin-AT\nComplex\n(LMWH: Anti-Xa>IIa\nUFH: Anti-Xa=IIa)"];
        Anti_Xa_act   [label="Anti-Xa\nActivity\nLMWH: 0.5-1.0 IU/mL\nFondaparinux\n0.2-1.5 μg/mL"];

        // Thrombolytic PD
        Thrombo_PA    [label="Thrombolytic\nAlteplase (rt-PA)\nExogenous tPA"];
        TG_ECA        [label="↑ Plasmin\nGeneration\n→ Clot Lysis\n(Systemic Fibrinolysis)"];
        Icb_risk      [label="ICH Risk\n↑ (0.5-1%)\nMajor Bleed\n↑ Risk"];

        // PGP / drug interactions
        P_gp          [label="P-glycoprotein\n(ABCB1)\nDrug Efflux\n(Riva/Apix/Dabi)"];
        CYP3A4_drug   [label="CYP3A4\nMetabolism\n(Riva/Apix)\nDrug interactions"];

        RIV_cent -> FXa_inhib [label="Direct FXa\ninhibitor", color="#1a237e", style=bold];
        APIX_cent -> FXa_inhib [label="Direct FXa\ninhibitor", color="#1a237e", style=bold];
        FXa_inhib -> FXa_inhib_inh;
        FXa_inhib_inh -> FIIa_thrombin [label="↓ Thrombin", color=red, style=dashed, arrowhead=tee];

        DABI_cent -> DTI_inhib [label="Direct thrombin\ninhibitor", color="#1a237e", style=bold];
        DTI_inhib -> DTI_effects;
        DTI_effects -> Fibrin_Mon [label="↓ Fibrin", color=red, style=dashed, arrowhead=tee];

        WARF_VK -> VitK_red [label="Blocks VKORC1\n→ ↓ VitK reduction"];
        VitK_ox -> VitK_red [label="VKORC1 reduces\n(Blocked by Warfarin)"];
        VitK_red -> GammaCarbox [label="KH2 cofactor\nfor γ-glutamyl\ncarboxylase"];
        GammaCarbox -> FII_syn [label="Active FII\nsynthesis"];
        GammaCarbox -> FVII_syn [label="Active FVII"];
        GammaCarbox -> FIX_syn [label="Active FIX"];
        GammaCarbox -> FX_syn [label="Active FX"];
        WARF_VK -> PIVKA_forms [label="→ ↑ PIVKA"];
        PIVKA_forms -> INR_calc [label="↑ INR"];
        VKORC1_gene -> VK_cycle [label="Genetic\nVariant"];
        CYP2C9_gene -> WARF_elim_node [label="↓ CL\n(*2/*3)"];
        FII_syn -> FII_pool_cp [label="Replenishes pool"];
        FVII_syn -> FVII_z [label="Replenishes pool"];
        INR_calc -> FII_pool_cp [label="Reflects FII/FX\nlevel change"];

        ENOX_cent -> Hepar_AT [label="Anti-Xa >>IIa"];
        UFH_cent -> Hepar_AT [label="Anti-Xa=IIa"];
        Hepar_AT -> Anti_Xa_act;
        Anti_Xa_act -> FXa_active [label="FXa inhibition\nvia AT", color=red, style=dashed, arrowhead=tee];
        Anti_Xa_act -> FIIa_thrombin [label="FIIa inhibition\n(UFH>LMWH)", color=red, style=dashed, arrowhead=tee];

        ALT_cent -> Thrombo_PA [label="Exogenous\ntPA bolus"];
        Thrombo_PA -> TG_ECA [label="↑↑ Plasminogen\nactivation"];
        TG_ECA -> tPA_circ [label="Mimics\nendogenous tPA", color=blue];
        Thrombo_PA -> Icb_risk [label="Bleeding risk"];

        P_gp -> RIV_cent [label="↓ Absorption/\n↑ Efflux", color=red, style=dashed, arrowhead=tee];
        P_gp -> APIX_cent [label="↓ Absorption", color=red, style=dashed, arrowhead=tee];
        CYP3A4_drug -> RIV_elim [label="CYP3A4\n±Interactions"];
        CYP3A4_drug -> APIX_elim;
    }

    // ═══════════════════════════════════════════════════════════
    // CLUSTER 11: Lab Monitoring & Biomarkers
    // ═══════════════════════════════════════════════════════════
    subgraph cluster_labs {
        label="⑪ Laboratory Monitoring & Biomarkers";
        style=filled; fillcolor="#f9fbe7"; color="#558b2f";
        fontcolor="#558b2f"; fontsize=10;

        node [fillcolor="#f0f4c3"];
        INR_lab       [label="PT/INR\n(Prothrombin Time)\nWarfarin target 2-3\nSensitive to FVII"];
        aPTT_lab      [label="aPTT\n(Activated PTT)\nUFH target 1.5-2.5x\nHeparin monitoring"];
        AntiXa_lab    [label="Anti-Xa Level\n(Chromogenic)\nLMWH: 0.5-1.0 IU/mL\nFondaparinux assay"];
        TT_lab        [label="Thrombin Time (TT)\nDiluted TT (dTT)\nDabigatran sensitive"];
        ECT_lab       [label="ECT (Ecarin)\nClotting Time\nDabigatran"];
        DOAC_Xa_lab   [label="Anti-Xa DOAC Assay\n(Calibrated for\nRiva/Apix/Edox)"];
        Ddimer_lab    [label="D-dimer Assay\n(ELISA/LFIA)\n<500 ng/mL = Low Risk\n(Age-adjusted cutoff)"];
        Fgn_lab       [label="Fibrinogen Level\n(Clauss method)\nConsumption coagulopathy\nNormal 200-400 mg/dL"];
        TG_lab        [label="Thrombin Generation\nAssay (TGA/CAT)\nPeak/ETP/Lagtime\nResearch/Emerging"];
        F12_lab       [label="F1+2 Fragment\n(Prothrombin\nCleavage)\nThrombin generation\nmarker"];
        TAT_lab       [label="TAT Complex\n(Thrombin-AT)\n↑ in Active VTE"];
        PLT_count     [label="Platelet Count\nNormal 150-400×10⁹/L\n↓ in HIT/ITP"];
        HIT_assay     [label="HIT Antibody\n(PF4/Heparin ELISA\n4T score)\nHeparin Side Effect"];
        Well_score    [label="Wells Score DVT/PE\nPretest Probability\n(0-8 DVT; 0-12.5 PE)"];

        VKA_Inhibit -> INR_lab [label="Reflects\nFVII(FX/FII)\ndepletion"];
        Hepar_AT -> aPTT_lab [label="aPTT\nmonitoring"];
        Hepar_AT -> AntiXa_lab [label="Anti-Xa\nmonitoring"];
        DABI_cent -> TT_lab;
        DABI_cent -> ECT_lab;
        RIV_cent -> DOAC_Xa_lab;
        APIX_cent -> DOAC_Xa_lab;
        D_dimer_fib -> Ddimer_lab [label="D-dimer\nassay input"];
        Fibrin_XL -> Fgn_lab [label="Consumption\nof fibrinogen"];
        FIIa_thrombin -> TG_lab;
        FIIa_thrombin -> F12_lab [label="F1+2 cleavage"];
        FIIa_thrombin -> TAT_lab [label="Complex with AT"];
        ENOX_cent -> HIT_assay [label="HIT: Heparin\nPF4 antibody\n(0.5-5%)"];
        UFH_cent -> HIT_assay [label="HIT risk\n~5% UFH"];
    }

    node [fillcolor="#fff3e0", style="filled,rounded", shape=box];
    VKA_Inhibit [label="Warfarin\nVKA Effect\n(VKORC1 Inhibition)"];

    // ═══════════════════════════════════════════════════════════
    // CLUSTER 12: Clinical Disease States & Endpoints
    // ═══════════════════════════════════════════════════════════
    subgraph cluster_clinical {
        label="⑫ Clinical Disease States & Endpoints";
        style=filled; fillcolor="#efebe9"; color="#4e342e";
        fontcolor="#4e342e"; fontsize=10;

        node [fillcolor="#d7ccc8"];
        Subclin_DVT   [label="Subclinical DVT\n(Calf Vein\nThrombosis)\nUsually silent"];
        Dist_DVT      [label="Distal DVT\n(Calf/Tibial)\n~20-30% extend\nProximal"];
        Prox_DVT      [label="Proximal DVT\n(Femoral/Popliteal)\nHigher PE risk\n50% if untreated"];
        Upper_DVT     [label="Upper Extremity\nDVT (UEDVT)\nCVC-related\n~1-4%"];
        PE_lowrisk    [label="Low-Risk PE\nPESI Class I/II\nHemodynamically\nStable"];
        PE_submass    [label="Submassive PE\nRV Dysfunction\n(Echo/BNP/Troponin)\nHemodynamic\nStable"];
        PE_massive    [label="Massive PE\nHemodynamic\nInstability\nSBP <90mmHg"];
        CTEPH         [label="CTEPH\n(Chronic TE PH)\n~3-4% of PE\n→ PH workup"];
        PTS           [label="Post-Thrombotic\nSyndrome (PTS)\n30-50% DVT\n(CEAP C3-C6)"];
        VTE_recurr    [label="VTE Recurrence\n(Unprovoked 30%\nat 5 yr)\nRisk stratification"];
        Fatal_PE      [label="Fatal PE\n(~1-3% Mortality\n↑ in massive PE)"];
        Bleed_major   [label="Major Bleeding\n(ISTH criteria)\nICH/GI/Fatal\n(~1-3%/yr)"];
        HIT_clin      [label="HIT\n(Heparin-Induced\nThrombocytopenia\nType II)\nArtvenous Thrombosis"];
        VTE_cancer    [label="Cancer-Associated\nVTE\n(Active Malignancy\n↑ Recurrence)"];
        RV_failure    [label="Right Ventricular\nFailure\n(McConnell sign)\nBNP↑ TnI↑"];
        PESI_score    [label="PESI Score\n(PE Severity Index)\nClass I-V\nMortality 0→25%"];

        Subclin_DVT -> Dist_DVT [label="Extension\n(Propagation)"];
        Dist_DVT -> Prox_DVT [label="20-30%\nextend proximally"];
        Prox_DVT -> PE_lowrisk [label="Embolizes\n(50% if untreated)"];
        Prox_DVT -> PE_submass [label="Large clot\nburden"];
        PE_submass -> PE_massive [label="Deterioration\nHemodynamic\ncompromise"];
        PE_submass -> RV_failure [label="RV pressure\n↑↑"];
        PE_massive -> Fatal_PE [label="RV failure\n→ Cardiac arrest"];
        PE_lowrisk -> CTEPH [label="2-4%\nincomplete\nresolution"];
        Prox_DVT -> PTS [label="Post-thrombotic\nsequelae\n(valve damage)"];
        Prox_DVT -> VTE_recurr [label="Recurrence\nrisk after DC"];
        UFH_cent -> HIT_clin [label="Type II HIT\nImmune-mediated\n(PF4 antibody)"];
        HIT_clin -> Bleed_major [label="Warrants\nalternative\nanticoag"];
        PESI_score -> PE_lowrisk;
        PESI_score -> PE_submass;
        RV_failure -> PESI_score;
    }

    // ═══════════════════════════════════════════════════════════
    // KEY CROSS-CLUSTER CONNECTIONS
    // ═══════════════════════════════════════════════════════════
    // Virchow → Pathways
    EndoInj -> EndoDysf [label="Vascular\ninjury"];
    VenStasis -> FX_pool_cp [label="↓ Shear →\naccumulation\nactivated Fx"];
    Hypercoag -> FX_pool_cp [label="↑ Procoagulant\nfactors"];
    FVLeiden -> APC_FVa_inh [label="FVa R506Q:\nAPC-resistant\nFVa", color=red, style=dashed, arrowhead=tee];
    ATDefic -> AT3_free [label="↓ AT3 level", color=red, style=dashed, arrowhead=tee];
    ProtCDefic -> ProtC_z [label="↓ ProtC\nlevel", color=red, style=dashed, arrowhead=tee];
    ProtSDefic -> ProtS_free [label="↓ Free ProtS", color=red, style=dashed, arrowhead=tee];

    // Endothelium → Coagulation
    TF_Endo -> TF_Exposed [label="Dysfunctional\nendothelium →\nTF expression"];
    vWF_WP -> vWF_FVIII [label="vWF\nreleased"];
    vWF_WP -> GPIb_bind [label="vWF mediates\nplatelet\ntethering"];
    tPA_Endo -> tPA_circ [label="tPA released\nfrom endothelium"];
    PAI1_Endo -> PAI1_circ [label="PAI-1 released"];

    // Extrinsic → Common
    FX_ext -> FXa_active [label="FXa from\nextrinsic tenase"];
    FIX_ext -> Int_Tenase [label="FIXa from\nextrinsic pathway"];

    // Intrinsic → Common
    FX_int -> FXa_active [label="FXa from\nintrinsic tenase"];

    // Common → Fibrinolysis
    FIIa_thrombin -> PAI1_Endo [label="↑ PAI-1\nrelease\n(Endo)", color=red];
    FIIa_thrombin -> TAFI [label="Procoagulant:\nTAFI activation\n→ ↓ fibrinolysis"];

    // Anticoagulants → Common
    AT3_Xa_inh -> FXa_active [label="AT3 inhibits\nFXa", color=red, style=dashed, arrowhead=tee];
    AT3_IIa_inh -> FIIa_thrombin [label="AT3 inhibits\nFIIa", color=red, style=dashed, arrowhead=tee];
    APC_FVa_inh -> FVa [label="APC cleaves FVa\n→ inactivates", color=red, style=dashed, arrowhead=tee];
    APC_FVIIIa_i -> FVIIIa [label="APC cleaves FVIIIa\n→ inactivates", color=red, style=dashed, arrowhead=tee];

    // Fibrinolysis → Clinical
    Fibrin_lysis -> Dist_DVT [label="Clot resolved\n(Distal)"];
    Fibrin_lysis -> Prox_DVT [label="Partial/complete\nlysis"];
    D_dimer_fib -> Ddimer_lab;

    // Clinical outcomes ← thrombus
    Fibrin_XL -> Prox_DVT [label="Organized\nvenous\nthrombus"];
    Fibrin_XL -> PE_submass [label="Embolized\nfibrin"];
    Plt_aggr -> Fibrin_XL [label="Platelet-rich\ntrombus core"];

    // Drug PK → Clinical
    FXa_inhib -> Bleed_major [label="Excess\nAnticoag\n→ Bleeding", color=red];
    DTI_inhib -> Bleed_major [label="Excess\nDTI\n→ Bleeding", color=red];
    VKA_Inhibit -> INR_lab;
    INR_lab -> Bleed_major [label="INR >4\n→ Bleed risk", color=red];
    Hepar_AT -> AntiXa_lab;

    // Cancer VTE
    Malignancy -> VTE_cancer;
    VTE_cancer -> Prox_DVT;
}
