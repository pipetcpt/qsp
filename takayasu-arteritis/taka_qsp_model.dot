    // Layout hints
    {rank=same; DC_mature; Mac_M1; NK_cell; pDC}
    {rank=same; Th1_cell; Th17_cell; Treg_cell; Tfh_cell}
    {rank=same; IL6; TNFa; IFNg; IL17A}
    {rank=same; Granuloma_adv; Media_layer; Intima_layer}
    {rank=same; Stenosis_prog; Aneurysm_form; Wall_Thick}
    {rank=same; CRP_lab; ESR_lab; NIH_score; ITAS_2010}
    {rank=same; Clinical_Rem; Clinical_Rel; VDI_score; GC_side}

    // Relapse reservoir node
    Relapse_pool [label="Relapse Pool\n(Th17 mem reservoir)" shape=diamond style="filled,rounded" fillcolor="#FF8A65" color="#BF360C" fontsize=9]
