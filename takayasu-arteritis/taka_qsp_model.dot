digraph TakayasuArteritis_QSP {
    graph [
        label="Takayasu Arteritis — Comprehensive QSP Mechanistic Map\nLarge-Vessel Vasculitis · Immune Pathways · Drug PK/PD · Vascular Remodeling · Clinical Endpoints"
        labelloc=t fontsize=20 fontname="Helvetica-Bold"
        bgcolor="#F7F8FA" rankdir=TB
        pad=1.0 nodesep=0.45 ranksep=0.65
    ]
    node [shape=box style="filled,rounded" fontname="Helvetica" fontsize=9 margin="0.12,0.05"]
    edge [fontname="Helvetica" fontsize=8 penwidth=1.1 arrowsize=0.8]

    // ======================================================
    // CLUSTER 1: Genetic & Environmental Triggers
    // ======================================================
    subgraph cluster_trigger {
        label="Genetic & Environmental Triggers" style="filled,rounded"
        fillcolor="#FFF8E1" color="#F9A825" penwidth=2.5
        fontname="Helvetica-Bold" fontsize=12

        node [fillcolor="#FFE082" color="#F57F17"]
        HLA_B52  [label="HLA-B*52:01\n(susceptibility allele)"]
        HLA_B39  [label="HLA-B*39:01\n(East Asian)"]
        HLA_DRB1 [label="HLA-DRB1*\n(antigen presentation)"]
        RNF213   [label="RNF213 p.R4810K\n(vascular fragility)"]
        FCGR2A   [label="FCGR2A H131R\n(immune complex)"]
        IL12B_SNP [label="IL12B SNP\n(Th1 skew)"]
        MLX_SNP  [label="MLX/PTPN22\npolymorphism"]

        node [fillcolor="#FFCC02" color="#E65100"]
        MtbHSP65 [label="M.tuberculosis\nHSP65 antigen"]
        OwnHSP65 [label="Human HSP65\n(self-antigen)"]
        MolecMimicry [label="Molecular\nMimicry (HSP)"]
        Aortic_AG   [label="Aortic Wall\nNeoantigen"]
        DAMP_signal [label="DAMP/PAMP\n(danger signal)"]
        Perforin_G  [label="Perforin/Granzyme B\nRelease"]
    }

    // ======================================================
    // CLUSTER 2: Innate Immune Activation
    // ======================================================
    subgraph cluster_innate {
        label="Innate Immune Activation" style="filled,rounded"
        fillcolor="#E8F5E9" color="#2E7D32" penwidth=2.5
        fontname="Helvetica-Bold" fontsize=12

        node [fillcolor="#C8E6C9" color="#1B5E20"]
        DC_immature [label="Immature\nDendritic Cell"]
        DC_mature   [label="Mature DC\n(CD83+/CD86+/MHC-II+)"]
        TLR2_4      [label="TLR2/TLR4\nActivation"]
        PRR_signal  [label="PRR → MyD88-NF-κB\nActivation"]
        NLRP3_infl  [label="NLRP3\nInflammasome"]
        Caspase1    [label="Caspase-1\nActivation"]

        node [fillcolor="#A5D6A7" color="#1B5E20"]
        Mac_M1      [label="M1 Macrophage\n(pro-inflammatory)"]
        Mac_M2      [label="M2 Macrophage\n(pro-fibrotic)"]
        NK_cell     [label="NK Cell\n(CD16+CD56+)"]
        NKT_cell    [label="NKT Cell\n(CD56+CD3+)"]
        GammaDelta_T [label="γδ T Cell\n(MICA/B ligand)"]
        Giant_Cell  [label="Multinucleated\nGiant Cell"]
        Mast_Cell   [label="Mast Cell\n(adventitia)"]
        Neutrophil  [label="Neutrophil\n(acute phase)"]
        pDC         [label="Plasmacytoid DC\n(type-I IFN)"]

        node [fillcolor="#81C784" color="#1B5E20"]
        IL1b_prod   [label="IL-1β\nProduction"]
        IL18_prod   [label="IL-18\nProduction"]
        IFN_I       [label="Type-I IFN\n(IFN-α/β)"]
        NET_form    [label="NET Formation\n(NETs → DAMPs)"]
    }

    // ======================================================
    // CLUSTER 3: Adaptive Immune Response
    // ======================================================
    subgraph cluster_adaptive {
        label="Adaptive Immune Response (Th1 / Th17 / Treg)" style="filled,rounded"
        fillcolor="#E3F2FD" color="#1565C0" penwidth=2.5
        fontname="Helvetica-Bold" fontsize=12

        node [fillcolor="#BBDEFB" color="#0D47A1"]
        Naive_CD4   [label="Naïve\nCD4+ T Cell"]
        Th1_cell    [label="Th1 Cell\n(IFN-γ+/CXCR3+)"]
        Th17_cell   [label="Th17 Cell\n(IL-17A+/CCR6+)"]
        Treg_cell   [label="Treg Cell\n(FoxP3+/CD25+)"]
        Tfh_cell    [label="Tfh Cell\n(PD-1hi/CXCR5+)"]
        Th1_mem     [label="Th1 Memory\n(long-lived)"]
        Th17_mem    [label="Th17 Memory\n(relapse pool)"]

        node [fillcolor="#90CAF9" color="#0D47A1"]
        Naive_CD8   [label="Naïve\nCD8+ T Cell"]
        CD8_eff     [label="CD8+ Effector\n(Perforin+/GzmB+)"]
        CD8_tissue  [label="CD8+ Tissue-\nInfiltrating"]
        CD8_mem     [label="CD8+ Memory\n(TEMRA)"]

        node [fillcolor="#E8EAF6" color="#3949AB"]
        STAT4_act   [label="STAT4\nActivation (Th1)"]
        STAT3_act   [label="STAT3\nActivation (Th17)"]
        Tbet_TF     [label="T-bet TF\n(Th1 master)"]
        RORgt_TF    [label="RORγt TF\n(Th17 master)"]
        FOXP3_TF    [label="FoxP3 TF\n(Treg master)"]

        node [fillcolor="#D1C4E9" color="#4527A0"]
        B_naive     [label="B Cell\n(naive, CD19+)"]
        Plasma_cell [label="Plasma Cell\n(IgG/IgA secreting)"]
        Memory_B    [label="Memory B Cell\n(CD27+)"]
        Anti_EC_Ab  [label="Anti-Endothelial\nAb (AECA)"]
        Anti_AORTA  [label="Anti-Aorta\nIgG (autoAb)"]
    }

    // ======================================================
    // CLUSTER 4: Cytokine & Chemokine Network
    // ======================================================
    subgraph cluster_cytokine {
        label="Cytokine & Chemokine Network" style="filled,rounded"
        fillcolor="#FCE4EC" color="#880E4F" penwidth=2.5
        fontname="Helvetica-Bold" fontsize=12

        node [fillcolor="#F8BBD0" color="#880E4F"]
        IL6        [label="IL-6\n(acute phase inducer)"]
        IL6R_mem   [label="mIL-6R\n(membrane)"]
        IL6R_sol   [label="sIL-6R\n(soluble, trans-signal)"]
        gp130      [label="gp130\n(co-receptor)"]
        TNFa       [label="TNF-α\n(master cytokine)"]
        TNFR1      [label="TNFR1\n(death domain)"]
        TNFR2      [label="TNFR2\n(survival signal)"]
        IFNg       [label="IFN-γ\n(Th1 effector cytokine)"]
        IFNGR      [label="IFN-γR\n(JAK1/JAK2)"]
        IL17A      [label="IL-17A\n(neutrophil recruiter)"]
        IL17F      [label="IL-17F\n(IL-17A dimer)"]
        IL12p70    [label="IL-12p70\n(Th1 polarizer)"]
        IL23p19    [label="IL-23p19\n(Th17 maintainer)"]
        IL1b       [label="IL-1β\n(NLRP3 product)"]
        IL2        [label="IL-2\n(T cell growth)"]
        IL10       [label="IL-10\n(anti-inflammatory)"]
        IL21       [label="IL-21\n(Tfh→B help)"]
        IL35       [label="IL-35\n(Treg → suppress)"]
        TGFb1      [label="TGF-β1\n(fibrosis/Treg)"]

        node [fillcolor="#EF9A9A" color="#B71C1C"]
        VEGF_A     [label="VEGF-A\n(angiogenesis)"]
        VEGF_C     [label="VEGF-C\n(lymphangiogenesis)"]
        VEGFR2     [label="VEGFR2\n(endothelial KDR)"]
        MCP1       [label="MCP-1/CCL2\n(monocyte chemotaxis)"]
        CXCL9      [label="CXCL9/MIG\n(T cell homing)"]
        CXCL10     [label="CXCL10/IP-10\n(Th1 homing)"]
        CXCL13     [label="CXCL13\n(B cell follicle)"]
        RANTES     [label="RANTES/CCL5\n(T cell recruit)"]
        MMP9       [label="MMP-9\n(ECM protease)"]
        MMP12      [label="MMP-12\n(macrophage elastase)"]
        MMP2       [label="MMP-2\n(gelatinase)"]
        TIMP1      [label="TIMP-1\n(MMP inhibitor)"]
        PDGF_BB    [label="PDGF-BB\n(SMC mitogen)"]
    }

    // ======================================================
    // CLUSTER 5: Intracellular Signaling
    // ======================================================
    subgraph cluster_signal {
        label="Intracellular Signaling: NF-κB · JAK-STAT · MAPK" style="filled,rounded"
        fillcolor="#FFF9C4" color="#F57F17" penwidth=2.5
        fontname="Helvetica-Bold" fontsize=12

        node [fillcolor="#FFF59D" color="#F57F17"]
        IKK_complex [label="IKK Complex\n(IKKα/β/NEMO)"]
        NFkB_p65p50 [label="NF-κB p65/p50\n(nuclear)"]
        IkBa_cyto   [label="IκBα\n(cytoplasmic trap)"]
        NFkB_genes  [label="NF-κB Target Genes:\nIL6/TNFα/IL1β/\nICAM-1/VCAM-1/MMP9"]

        node [fillcolor="#FFF176" color="#F9A825"]
        JAK1_sig    [label="JAK1/TYK2\n(IL-6R complex)"]
        JAK2_sig    [label="JAK2\n(IFN-γR)"]
        pSTAT3      [label="pSTAT3 (Y705)\nHomodimer"]
        pSTAT1      [label="pSTAT1 (Y701)\n(IFN-γ)"]
        SOCS3       [label="SOCS3\n(JAK-STAT feedback -)"]
        STAT3_genes [label="STAT3 Target Genes:\nCRP/SAA/Fibrinogen/\nMCP-1/VEGF/BCL-2"]

        node [fillcolor="#FFEE58" color="#E65100"]
        p38_MAPK    [label="p38 MAPK\n(stress kinase)"]
        ERK1_2      [label="ERK1/2\n(proliferation)"]
        JNK_path    [label="JNK\n(stress/apoptosis)"]
        PI3K_AKT    [label="PI3K–AKT–mTOR\n(survival)"]
        AP1_TF      [label="AP-1 (c-Fos/c-Jun)\n(pro-inflammatory TF)"]
    }

    // ======================================================
    // CLUSTER 6: Vascular Wall Pathology
    // ======================================================
    subgraph cluster_vascular {
        label="Vascular Wall Pathology & Remodeling" style="filled,rounded"
        fillcolor="#F3E5F5" color="#6A1B9A" penwidth=2.5
        fontname="Helvetica-Bold" fontsize=12

        node [fillcolor="#E1BEE7" color="#6A1B9A"]
        Adventitia     [label="Adventitia\n(lymphocyte nidus)"]
        Vasa_Vasorum   [label="Vasa Vasorum\n(neovascularization)"]
        Granuloma_adv  [label="Adventitial\nGranuloma"]
        Media_layer    [label="Media\n(SMC/elastin)"]
        Intima_layer   [label="Intima\n(endothelial cell)"]

        node [fillcolor="#CE93D8" color="#4A148C"]
        EC_act         [label="Endothelial Activation\n(ICAM-1+/VCAM-1+/E-selectin+)"]
        EC_dysfunc     [label="Endothelial\nDysfunction"]
        SMC_prolif     [label="SMC Proliferation\n(neointima)"]
        SMC_migration  [label="SMC Migration\n(intima invasion)"]
        Collagen_dep   [label="Collagen I/III\nDeposition"]
        Elastin_degrad [label="Elastin\nDegradation"]
        Fibroblast_act [label="Adventitial\nFibroblast Activation"]

        node [fillcolor="#AB47BC" color="#38006b"]
        Intimal_Hyper  [label="Intimal\nHyperplasia"]
        Stenosis_prog  [label="Arterial\nStenosis (grade 1-4)"]
        Occlusion_chr  [label="Chronic\nOcclusion"]
        Aneurysm_form  [label="Aneurysm\nFormation"]
        Calcification  [label="Mural\nCalcification"]
        Wall_Thick     [label="Aortic Wall\nThickness↑ (mm)"]
        FDG_uptake     [label="¹⁸F-FDG\nUptake (PET-CT)"]

        node [fillcolor="#CE93D8" color="#4A148C"]
        FGF2_loc       [label="FGF-2\n(local angiogenesis)"]
        Angiopoietin2  [label="Angiopoietin-2\n(vascular destabilize)"]
    }

    // ======================================================
    // CLUSTER 7: End-Organ Damage
    // ======================================================
    subgraph cluster_organ {
        label="End-Organ Damage & Clinical Manifestations" style="filled,rounded"
        fillcolor="#FBE9E7" color="#BF360C" penwidth=2.5
        fontname="Helvetica-Bold" fontsize=12

        node [fillcolor="#FFCCBC" color="#BF360C"]
        Renovasc_HTN  [label="Renovascular\nHypertension (>60%)"]
        Arm_Claudic   [label="Arm Claudication\n(subclavian stenosis)"]
        Carotidynia   [label="Carotidynia\n(carotid tenderness)"]
        Visual_Loss   [label="Visual Loss\n(retinal ischemia)"]
        Stroke_TIA    [label="Stroke / TIA\n(carotid/vertebral)"]
        MI_risk       [label="MI Risk\n(coronary ostia)"]
        Renal_Stenosis [label="Renal Artery\nStenosis"]
        Pulm_Art      [label="Pulmonary\nArteritis"]
        Mesenteric    [label="Mesenteric\nIschemia"]

        node [fillcolor="#FFAB91" color="#BF360C"]
        Aortic_Regurg [label="Aortic\nRegurgitation"]
        Pericarditis  [label="Pericarditis"]
        Asymm_BP      [label="Asymmetric\nBlood Pressure\n(>10 mmHg ΔBP)"]
        Bruit         [label="Vascular\nBruit"]
        Absent_Pulse  [label="Absent/\nDiminished Pulse"]

        node [fillcolor="#FF8A65" color="#BF360C"]
        Phase_I    [label="ACR Stage I:\nPre-Pulseless\n(systemic inflam)"]
        Phase_IIa  [label="ACR Stage IIa:\nVascular Sxs\nOnly"]
        Phase_IIb  [label="ACR Stage IIb:\nBoth Sxs"]
        Phase_III  [label="ACR Stage III:\nPulseless\n(ischemic)"]
        Phase_IV   [label="ACR Stage IV:\n+Hypertension"]
    }

    // ======================================================
    // CLUSTER 8: Biomarkers & Disease Monitoring
    // ======================================================
    subgraph cluster_biom {
        label="Biomarkers & Disease Monitoring Tools" style="filled,rounded"
        fillcolor="#E0F7FA" color="#006064" penwidth=2.5
        fontname="Helvetica-Bold" fontsize=12

        node [fillcolor="#B2EBF2" color="#006064"]
        CRP_lab    [label="CRP\n(mg/L; ULN=5)"]
        ESR_lab    [label="ESR\n(mm/h; F>20, M>15)"]
        IL6_serum  [label="Serum IL-6\n(pg/mL; ULN=7)"]
        VEGF_serum [label="Serum VEGF\n(pg/mL; ULN=240)"]
        Fibrinogen [label="Fibrinogen\n(g/L; ULN=4)"]
        SAA_lab    [label="SAA\n(Serum Amyloid A)"]
        WBC_lab    [label="WBC/\nNeutrophil count"]
        Pentraxin3 [label="Pentraxin-3\n(PTX3, novel marker)"]

        node [fillcolor="#80DEEA" color="#00838F"]
        NIH_score  [label="NIH Activity Score\n(0-4; active ≥2)"]
        ITAS_2010  [label="ITAS-2010\n(Indian TA Score; 0-57)"]
        ITAS_A     [label="ITAS-A\n(ITAS + CRP add-on)"]
        DEI_score  [label="DEI.Tak\n(disease extent idx)"]
        PET_score  [label="¹⁸F-FDG PET-CT\nTBR/SUVmax"]
        MRA_grade  [label="MRA/CTA Stenosis\nGrading (0-4)"]
        USG_IMT    [label="Carotid Intima-\nMedia Thickness (IMT)"]
        FMD_test   [label="Flow-Mediated\nDilation (FMD%)"]

        node [fillcolor="#4DD0E1" color="#006064"]
        Clinical_Rem  [label="Clinical Remission\n(NIH=0, CRP norm)"]
        Clinical_Rel  [label="Clinical Relapse\n(NIH≥2 after remission)"]
        VDI_score     [label="Vascular Damage\nIndex (VDI)"]
        ACR_criteria  [label="ACR 1990 Criteria\n(≥3 of 6)"]
    }

    // ======================================================
    // CLUSTER 9: Drug PK/PD — Glucocorticoids
    // ======================================================
    subgraph cluster_GC {
        label="Drug PK/PD: Glucocorticoids (Prednisolone)" style="filled,rounded"
        fillcolor="#E8EAF6" color="#283593" penwidth=2.5
        fontname="Helvetica-Bold" fontsize=12

        node [fillcolor="#C5CAE9" color="#283593"]
        Pred_dose    [label="Prednisolone PO\n0.5-1 mg/kg/d → taper"]
        Pred_GI      [label="GI Absorption\nF=82%, ka=1.2/h"]
        Pred_Cen     [label="Pred Central\nCpt (Vc=17 L)"]
        Pred_Per     [label="Pred Peripheral\nCpt (Vp=24 L)"]
        Pred_CBG     [label="CBG Binding\n(77% bound, Kd=5 nM)"]
        Pred_free    [label="Free Prednisolone\n(active PD fraction)"]
        Pred_elim    [label="CL=6.6 L/h\nt½≈3.5 h"]

        node [fillcolor="#9FA8DA" color="#1A237E"]
        GR_cyto      [label="Glucocorticoid\nReceptor-α (GRα)"]
        GR_hsp90     [label="GR-Hsp90/p23\nCytoplasmic Complex"]
        GR_nuc       [label="GR-Pred Nuclear\nComplex (active)"]
        GRE_trans    [label="GRE Transactivation\n(GILZ/DUSP1/AnnexA1↑)"]
        AP1_rep      [label="AP-1/NF-κB\nRepression (tethering)"]

        node [fillcolor="#7986CB" color="#1A237E"]
        GC_GILZ      [label="GILZ↑\n(T cell suppress)"]
        GC_DUSP1     [label="DUSP1/MKP-1↑\n(MAPK deactivate)"]
        GC_AnnA1     [label="Annexin-A1↑\n(PLA2 inhibit)"]
        GC_IkBa_up   [label="IκBα↑\n(NF-κB trap)"]
        GC_IL10_up   [label="IL-10↑\n(anti-inflam shift)"]
        GC_side      [label="Side Effects:\nDM / Osteoporosis\nHTN / Infection"]
        Taper_sched  [label="Taper Schedule\n(10% / 2-4 weeks)"]
    }

    // ======================================================
    // CLUSTER 10: Drug PK/PD — Biologics & csDMARDs
    // ======================================================
    subgraph cluster_biologic {
        label="Drug PK/PD: Tocilizumab · Anti-TNF · csDMARDs" style="filled,rounded"
        fillcolor="#E8F5E9" color="#1B5E20" penwidth=2.5
        fontname="Helvetica-Bold" fontsize=12

        node [fillcolor="#C8E6C9" color="#1B5E20"]
        TCZ_dose   [label="Tocilizumab\n8 mg/kg IV q4w\nor 162 mg SC qw"]
        TCZ_Cen    [label="TCZ Central Cpt\n(Vc=3.5 L/kg)"]
        TCZ_Per    [label="TCZ Peripheral Cpt\n(t½≈6-7 d IV)"]
        TCZ_bound  [label="TCZ-IL6R\nBound Complex (TMDD)"]
        TCZ_free   [label="Free TCZ\n(pharmacodynamically active)"]
        TCZ_IL6R_block [label="IL-6R Blockade\n(>95% receptor occupancy)"]

        node [fillcolor="#A5D6A7" color="#1B5E20"]
        IFX_dose   [label="Infliximab\n5 mg/kg IV q8w"]
        IFX_Cen    [label="IFX Central Cpt\n(t½≈8-10 d)"]
        IFX_TNF_B  [label="TNF-α\nNeutralization"]
        ADA_dose   [label="Adalimumab\n40 mg SC q2w"]
        ADA_Cen    [label="ADA Central Cpt\n(t½≈14 d)"]

        node [fillcolor="#81C784" color="#1B5E20"]
        MTX_dose   [label="Methotrexate\n15-25 mg/wk PO/SC"]
        MTX_PLG    [label="MTX Polyglutamates\n(intracellular active)"]
        MTX_DHFR   [label="DHFR Inhibition\n(folate pathway)"]
        MTX_ATIC   [label="ATIC Inhibition\n→ Adenosine↑"]
        AZA_dose   [label="Azathioprine\n2 mg/kg/d"]
        AZA_6TGN   [label="6-TGN\n(purine antimetabolite)"]
        MMF_dose   [label="Mycophenolate\n2-3 g/d"]
        MMF_MPA    [label="MPA\n(IMPDH inhibition)"]
        CYC_dose   [label="Cyclophosphamide\n(refractory cases)"]
        CYC_alky   [label="DNA Alkylation\n→ Lymphocyte Apoptosis"]

        node [fillcolor="#66BB6A" color="#1B5E20"]
        JAKi_exp   [label="JAK Inhibitors\n(Tofacitinib, exp.)"]
        AntiVEGF_exp [label="Anti-VEGF\n(Bevacizumab, exp.)"]
        AbatacCEPT [label="Abatacept\n(CTLA4-Ig, B7 block)"]
        Ustekin    [label="Ustekinumab\n(anti-IL-12/23, exp.)"]
    }

    // ============================================================
    // EDGES — Pathophysiology flows
    // ============================================================

    // Genetic predisposition
    HLA_B52  -> MolecMimicry [label="predispose"]
    HLA_B39  -> MolecMimicry [label="predispose"]
    HLA_DRB1 -> DC_mature    [label="Ag present"]
    RNF213   -> EC_act       [label="endo fragility"]
    FCGR2A   -> Mac_M1       [label="FcγR signal"]
    IL12B_SNP -> IL12p70     [label="↑ expression"]
    MLX_SNP  -> Treg_cell    [label="↓ function"]
    MtbHSP65 -> MolecMimicry [label="mimic self"]
    OwnHSP65 -> MolecMimicry
    MolecMimicry -> Aortic_AG
    Aortic_AG -> DAMP_signal  [label="alarm signal"]

    // Innate immune initiation
    DAMP_signal -> TLR2_4    [label="PAMP/DAMP"]
    TLR2_4 -> PRR_signal
    PRR_signal -> DC_immature [label="mature"]
    PRR_signal -> NLRP3_infl  [label="prime"]
    NLRP3_infl -> Caspase1   [label="activate"]
    Caspase1 -> IL1b_prod    [label="cleave pro-IL-1β"]
    Caspase1 -> IL18_prod    [label="cleave pro-IL-18"]
    IL1b_prod -> IL1b
    DC_immature -> DC_mature  [label="maturation\n(CD80/86↑)"]
    pDC -> IFN_I             [label="produce"]
    IFN_I -> DC_mature       [label="enhance"]
    Mac_M1 -> IL6            [label="secrete"]
    Mac_M1 -> TNFa           [label="secrete"]
    Mac_M1 -> IL12p70        [label="secrete"]
    Mac_M1 -> MMP9           [label="secrete"]
    Mac_M1 -> Giant_Cell     [label="cell fusion"]
    Mac_M2 -> TGFb1          [label="secrete"]
    Mac_M2 -> Collagen_dep   [label="promote"]
    Giant_Cell -> Granuloma_adv [label="form granuloma"]
    Giant_Cell -> MMP12      [label="secrete"]
    Mast_Cell -> TNFa        [label="degranulate"]
    Mast_Cell -> VEGF_A      [label="release"]
    Neutrophil -> MMP9       [label="NET/elastase"]
    Neutrophil -> NET_form   [label="→ DAMPs"]
    NET_form -> DAMP_signal  [label="amplify"]
    NK_cell -> Perforin_G    [label="cytotoxic"]
    NKT_cell -> IFNg         [label="rapid IFN-γ"]
    GammaDelta_T -> IL17A    [label="produce"]
    GammaDelta_T -> IFNg     [label="produce"]

    // NF-κB signaling
    PRR_signal -> IKK_complex
    TNFa -> TNFR1            [label="bind"]
    TNFR1 -> IKK_complex     [label="TRADD/TRAF2"]
    IL1b -> IKK_complex      [label="MyD88/TRAF6"]
    IKK_complex -> NFkB_p65p50 [label="phosph IκBα→degrade"]
    IkBa_cyto -> NFkB_p65p50  [label="sequester", style=dashed, color=gray]
    NFkB_p65p50 -> NFkB_genes  [label="transcribe"]
    NFkB_genes -> IL6          [label="↑"]
    NFkB_genes -> TNFa         [label="↑"]
    NFkB_genes -> IL1b         [label="↑"]
    NFkB_genes -> EC_act       [label="ICAM-1/VCAM-1↑"]
    NFkB_genes -> MMP9         [label="↑"]

    // JAK-STAT signaling
    IL6 -> IL6R_mem          [label="bind classical"]
    IL6 -> IL6R_sol          [label="trans-signaling"]
    IL6R_mem -> gp130        [label="complex"]
    IL6R_sol -> gp130        [label="trans"]
    gp130 -> JAK1_sig        [label="activate"]
    JAK1_sig -> pSTAT3       [label="Y705 phosph"]
    pSTAT3 -> SOCS3          [label="induce feedback"]
    pSTAT3 -> STAT3_genes    [label="transcribe"]
    STAT3_genes -> CRP_lab   [label="→ liver"]
    STAT3_genes -> SAA_lab   [label="→ liver"]
    STAT3_genes -> Fibrinogen [label="→ liver"]
