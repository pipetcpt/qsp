    /* ============================================================
       LEGEND
       ============================================================ */
    subgraph cluster_legend {
        label="Legend" style="filled,rounded" fillcolor="#FFFFFF" color="#666666"
        fontname="Helvetica-Bold" fontsize=11
        L1 [label="→ Activation / Stimulation",  shape=plaintext fontsize=9]
        L2 [label="→ (red) Inhibition",          shape=plaintext fontsize=9 fontcolor=red]
        L3 [label="→ (green) Compensation",       shape=plaintext fontsize=9 fontcolor=green]
        L4 [label="- - (dashed) Feedback loop",   shape=plaintext fontsize=9]
        L5 [label="Boxes: pathway components",    shape=plaintext fontsize=9]
    }
}
