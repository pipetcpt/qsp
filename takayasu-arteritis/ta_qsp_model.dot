digraph TakayasuArteritis_QSP {
    graph [
        label="Takayasu Arteritis — Quantitative Systems Pharmacology Model\nMechanistic Map: Disease Pathogenesis · Cytokine Network · Vessel Wall Biology · Drug PK/PD · Clinical Endpoints",
        labelloc=t, fontsize=22, fontname="Helvetica-Bold",
        rankdir=LR, splines=ortho, nodesep=0.45, ranksep=1.1,
        bgcolor="#F8F9FA", pad=0.6
    ]
    node [fontname="Helvetica", fontsize=10, style="filled,rounded", shape=box, penwidth=1.2]
    edge [fontname="Helvetica", fontsize=8, penwidth=1.1]

    /* ============================================================
       CLUSTER 1 — Genetic & Environmental Triggers / Innate Immunity
       ============================================================ */
    subgraph cluster_trigger {
        label="Genetic & Environmental Triggers\n/ Innate Immunity"
        style="filled,rounded" fillcolor="#FFF3E0" color="#E65100" penwidth=2
        fontname="Helvetica-Bold" fontsize=13

        HLA_B52      [label="HLA-B52\n(genetic risk)", fillcolor="#FFCC80"]
        HLA_B39      [label="HLA-B39\n(genetic risk)", fillcolor="#FFCC80"]
        MICA_gene    [label="MICA-A9\npolymorphism",  fillcolor="#FFCC80"]
        Env_trigger  [label="Environmental\nTrigger\n(infection, microbiome)", fillcolor="#FFB74D"]
        MTB_homolog  [label="Mycobacterium\ntuberculos (homology)", fillcolor="#FFB74D"]
        HSP70_65     [label="Heat Shock Protein\nHSP70/65 (target Ag)", fillcolor="#FF8A65"]
        Adventitial_DCs [label="Adventitial\nDendritic Cells", fillcolor="#FF7043"]
        TLR2_4       [label="TLR2 / TLR4\nPattern Recognition", fillcolor="#FF7043"]
        NOD_like_R   [label="NOD-like Receptor\nNLRP3 Inflammasome", fillcolor="#FF7043"]
        Macrophage_M1 [label="M1 Macrophage\n(proinflammatory)", fillcolor="#F4511E"]
        Macrophage_M2 [label="M2 Macrophage\n(fibrosis)", fillcolor="#BF360C"]
        NK_cells     [label="NK Cells\n(perforin/granzyme)", fillcolor="#D84315"]
        Neutrophil   [label="Neutrophil\nActivation", fillcolor="#E64A19"]
        Mast_cell    [label="Mast Cell\nActivation", fillcolor="#FF8A65"]
        DAMP_signals [label="DAMPs / PAMPs", fillcolor="#FFAB40"]
        Phagocytosis [label="Phagocytosis &\nAntigen Presentation", fillcolor="#FFA726"]
    }

    /* ============================================================
       CLUSTER 2 — Adaptive Immunity: T Cells
       ============================================================ */
    subgraph cluster_tcell {
        label="Adaptive Immunity: T Cells"
        style="filled,rounded" fillcolor="#E8F5E9" color="#1B5E20" penwidth=2
        fontname="Helvetica-Bold" fontsize=13

        Naive_CD4    [label="Naive CD4+ T Cell", fillcolor="#A5D6A7"]
        Naive_CD8    [label="Naive CD8+ T Cell", fillcolor="#A5D6A7"]
        APC_priming  [label="APC-mediated\nT Cell Priming", fillcolor="#81C784"]
        MHC_II       [label="MHC Class II\nPresentation", fillcolor="#66BB6A"]
        TCR_signal   [label="TCR Signaling\n(ZAP70, LCK)", fillcolor="#4CAF50"]
        CD28_costim  [label="CD28/B7\nCo-stimulation", fillcolor="#43A047"]
        CTLA4_inhib  [label="CTLA-4\nInhibitory Signal", fillcolor="#388E3C"]
        PD1_PDL1     [label="PD-1 / PD-L1\nCheckpoint", fillcolor="#2E7D32"]
        Th1_cell     [label="CD4+ Th1 Cell\n(IFN-γ, IL-12)", fillcolor="#1B5E20", fontcolor="white"]
        Th17_cell    [label="CD4+ Th17 Cell\n(IL-17A, IL-17F)", fillcolor="#1B5E20", fontcolor="white"]
        Th2_cell     [label="CD4+ Th2 Cell\n(IL-4, IL-13)", fillcolor="#4CAF50"]
        Treg_cell    [label="CD4+ Treg Cell\n(IL-10, TGF-β)", fillcolor="#81C784"]
        CD8_CTL      [label="CD8+ Cytotoxic T\n(perforin, granzyme)", fillcolor="#2E7D32", fontcolor="white"]
        Memory_T     [label="Memory T Cells\n(long-lived)", fillcolor="#C8E6C9"]
        T_proliferate [label="T Cell\nProliferation", fillcolor="#A5D6A7"]
        JAK1_3_T     [label="JAK1/JAK3\n(T cell signaling)", fillcolor="#66BB6A"]
        STAT1_STAT3  [label="STAT1/STAT3\nTranscription", fillcolor="#43A047"]
        IL2_autocrine [label="IL-2\n(autocrine growth)", fillcolor="#81C784"]
    }

    /* ============================================================
       CLUSTER 3 — B Cells & Humoral Immunity
       ============================================================ */
    subgraph cluster_bcell {
        label="B Cells & Humoral Immunity"
        style="filled,rounded" fillcolor="#E3F2FD" color="#0D47A1" penwidth=2
        fontname="Helvetica-Bold" fontsize=13

        Naive_B      [label="Naive B Cell", fillcolor="#BBDEFB"]
        B_activation [label="B Cell Activation\n(T helper-dependent)", fillcolor="#90CAF9"]
        Germinal_center [label="Germinal Center\nReaction", fillcolor="#64B5F6"]
        Plasma_cell  [label="Plasma Cell\n(antibody factory)", fillcolor="#42A5F5"]
        Memory_B     [label="Memory B Cell", fillcolor="#90CAF9"]
        AECA         [label="Anti-Endothelial Cell\nAntibody (AECA)", fillcolor="#1E88E5", fontcolor="white"]
        Anti_aorta_Ab [label="Anti-Aorta\nAntibody", fillcolor="#1565C0", fontcolor="white"]
        Anti_HSP_Ab  [label="Anti-HSP65/70\nAntibody", fillcolor="#1565C0", fontcolor="white"]
        IgG_subclass [label="IgG1/IgG4\nSubclass", fillcolor="#42A5F5"]
        Complement_C3 [label="Complement C3\nActivation", fillcolor="#1976D2"]
        Complement_C4 [label="Complement C4\nActivation", fillcolor="#1976D2"]
        Complement_MAC [label="Membrane Attack\nComplex (MAC)", fillcolor="#0D47A1", fontcolor="white"]
        FcR_activation [label="FcγR Activation\n(macrophage)", fillcolor="#42A5F5"]
        BAFF         [label="BAFF / APRIL\n(B cell survival)", fillcolor="#64B5F6"]
    }

    /* ============================================================
       CLUSTER 4 — Cytokine & Inflammatory Mediators
       ============================================================ */
    subgraph cluster_cytokine {
        label="Cytokine & Inflammatory Mediator Network"
        style="filled,rounded" fillcolor="#FCE4EC" color="#880E4F" penwidth=2
        fontname="Helvetica-Bold" fontsize=13

        IL6          [label="IL-6\n(key driver)", fillcolor="#F48FB1", penwidth=2.5]
        IL6R         [label="IL-6 Receptor\n(IL-6R / gp130)", fillcolor="#F06292"]
        sIL6R        [label="Soluble IL-6R\n(trans-signaling)", fillcolor="#EC407A"]
        IL6_complex  [label="IL-6:sIL6R\nComplex", fillcolor="#E91E63"]
        IL12         [label="IL-12\n(Th1 polarization)", fillcolor="#F48FB1"]
        IL23         [label="IL-23\n(Th17 maintenance)", fillcolor="#F48FB1"]
        IL17A        [label="IL-17A\n(vessel wall)", fillcolor="#E91E63"]
        IL17F        [label="IL-17F\n(co-inflammatory)", fillcolor="#F06292"]
        IL1beta      [label="IL-1β\n(NLRP3 output)", fillcolor="#C2185B", fontcolor="white"]
        TNF_alpha    [label="TNF-α\n(master proinflammatory)", fillcolor="#880E4F", fontcolor="white"]
        IFNgamma     [label="IFN-γ\n(Th1 effector)", fillcolor="#AD1457", fontcolor="white"]
        IL10         [label="IL-10\n(anti-inflammatory)", fillcolor="#F8BBD9"]
        TGFbeta      [label="TGF-β\n(fibrosis/Treg)", fillcolor="#F8BBD9"]
        IL18         [label="IL-18\n(IFN-γ induction)", fillcolor="#F48FB1"]
        IL21         [label="IL-21\n(B cell help)", fillcolor="#F48FB1"]
        VEGF         [label="VEGF\n(neovascularization)", fillcolor="#E91E63"]
        PDGF         [label="PDGF\n(SMC proliferation)", fillcolor="#EC407A"]
        FGF          [label="FGF\n(tissue remodeling)", fillcolor="#F48FB1"]
        MIF          [label="MIF\n(macrophage migration\ninhibitory factor)", fillcolor="#F06292"]
        CCL5_RANTES  [label="CCL5/RANTES\n(T cell chemokine)", fillcolor="#F48FB1"]
        CCL2_MCP1    [label="CCL2/MCP-1\n(monocyte recruitment)", fillcolor="#F48FB1"]
        CXCL10_IP10  [label="CXCL10/IP-10\n(Th1 chemokine)", fillcolor="#EC407A"]
        Pentraxin3   [label="Pentraxin-3\n(vascular inflammation)", fillcolor="#F06292"]
    }

    /* ============================================================
       CLUSTER 5 — Vessel Wall Pathobiology
       ============================================================ */
    subgraph cluster_vessel {
        label="Vessel Wall Pathobiology"
        style="filled,rounded" fillcolor="#F3E5F5" color="#4A148C" penwidth=2
        fontname="Helvetica-Bold" fontsize=13

        Adventitia   [label="Adventitia\n(outer layer)", fillcolor="#CE93D8"]
        Vasa_vasorum [label="Vasa Vasorum\n(supply vessels)", fillcolor="#BA68C8"]
        Media         [label="Media (tunica media)\n(smooth muscle)", fillcolor="#AB47BC"]
        Intima       [label="Intima (endothelium)\n(inner lining)", fillcolor="#9C27B0"]
        EC_cells     [label="Endothelial Cells\n(dysfunction/activation)", fillcolor="#7B1FA2", fontcolor="white"]
        SMC          [label="Vascular Smooth\nMuscle Cells (VSMC)", fillcolor="#6A1B9A", fontcolor="white"]
        Pericytes    [label="Pericytes &\nAdventitial Fibroblasts", fillcolor="#CE93D8"]
        ICAM1        [label="ICAM-1\n(adhesion molecule)", fillcolor="#BA68C8"]
        VCAM1        [label="VCAM-1\n(adhesion molecule)", fillcolor="#AB47BC"]
        E_selectin   [label="E-Selectin\n(leukocyte rolling)", fillcolor="#9C27B0"]
        NO_eNOS      [label="NO / eNOS\n(vasodilation)", fillcolor="#CE93D8"]
        ET1          [label="Endothelin-1\n(vasoconstriction)", fillcolor="#7B1FA2", fontcolor="white"]
        ROS          [label="Reactive Oxygen\nSpecies (ROS)", fillcolor="#AB47BC"]
        HIF1alpha    [label="HIF-1α\n(hypoxia response)", fillcolor="#CE93D8"]
        MMP_2_9      [label="MMP-2/MMP-9\n(matrix degradation)", fillcolor="#BA68C8"]
        TIMP         [label="TIMPs\n(MMP inhibitors)", fillcolor="#CE93D8"]
        Collagen_dep [label="Collagen I/III\nDeposition", fillcolor="#9C27B0"]
        Fibronectin  [label="Fibronectin\n(extracellular matrix)", fillcolor="#AB47BC"]
        Perforin_GZB [label="Perforin/GranzymeB\n(CTL/NK cytotoxicity)", fillcolor="#6A1B9A", fontcolor="white"]
        Vessel_edema [label="Vessel Wall Edema\n(acute)", fillcolor="#CE93D8"]
        Neovascularization [label="Neovascularization\n(new vasa vasorum)", fillcolor="#BA68C8"]
        NFkB_vessel  [label="NF-κB Activation\n(vessel wall)", fillcolor="#7B1FA2", fontcolor="white"]
        Intimal_hyperplasia [label="Intimal Hyperplasia\n(stenosis pathway)", fillcolor="#4A148C", fontcolor="white"]
    }

    /* ============================================================
       CLUSTER 6 — Arterial Lesions & Complications
       ============================================================ */
    subgraph cluster_arteries {
        label="Arterial Lesions & Vascular Complications"
        style="filled,rounded" fillcolor="#E8EAF6" color="#1A237E" penwidth=2
        fontname="Helvetica-Bold" fontsize=13

        Aortic_arch  [label="Aortic Arch\nInvolvement", fillcolor="#9FA8DA"]
        Asc_aorta    [label="Ascending Aorta\nLesion", fillcolor="#7986CB"]
        Desc_aorta   [label="Descending Aorta\nLesion", fillcolor="#7986CB"]
        Subclavian_R [label="Subclavian Artery\n(R) Stenosis", fillcolor="#5C6BC0"]
        Subclavian_L [label="Subclavian Artery\n(L) Stenosis", fillcolor="#5C6BC0"]
        Carotid_common [label="Common Carotid\nArtery Stenosis", fillcolor="#3949AB", fontcolor="white"]
        Renal_artery [label="Renal Artery\nStenosis", fillcolor="#1A237E", fontcolor="white"]
        Mesenteric_A [label="Mesenteric Artery\nInvolvement", fillcolor="#283593", fontcolor="white"]
        Coronary_art [label="Coronary Artery\nInvolvement", fillcolor="#283593", fontcolor="white"]
        Vessel_thick [label="Vessel Wall\nThickening (MRI)", fillcolor="#7986CB"]
        Luminal_narr [label="Luminal Narrowing\n(% stenosis)", fillcolor="#5C6BC0"]
        Aneurysm     [label="Aneurysm Formation\n(aortic)", fillcolor="#1A237E", fontcolor="white"]
        Mural_thrombus [label="Mural Thrombus\nFormation", fillcolor="#3949AB", fontcolor="white"]
        Calcification [label="Vessel Calcification\n(chronic)", fillcolor="#9FA8DA"]
        Collateral_circ [label="Collateral\nCirculation Development", fillcolor="#7986CB"]
        Aortic_regurg [label="Aortic Regurgitation\n(AR grade)", fillcolor="#5C6BC0"]
    }

    /* ============================================================
       CLUSTER 7 — Clinical Manifestations & Endpoints
       ============================================================ */
    subgraph cluster_clinical {
        label="Clinical Manifestations & Disease Activity Endpoints"
        style="filled,rounded" fillcolor="#E0F2F1" color="#004D40" penwidth=2
        fontname="Helvetica-Bold" fontsize=13

        NIH_score    [label="NIH Disease\nActivity Score", fillcolor="#80CBC4", penwidth=2.5]
        ITAS_score   [label="ITAS 2010\nActivity Score", fillcolor="#4DB6AC", penwidth=2.5]
        BVAS_score   [label="BVAS\n(Birmingham Vasculitis\nActivity Score)", fillcolor="#26A69A"]
        Arm_claudication [label="Arm Claudication\n/ Pulse Loss", fillcolor="#80CBC4"]
        BP_diff      [label="BP Difference\n(≥10 mmHg arm-arm)", fillcolor="#4DB6AC"]
        Carotid_bruit [label="Carotid/Subclavian\nBruit", fillcolor="#26A69A"]
        Hypertension [label="Renovascular\nHypertension", fillcolor="#00897B"]
        Retinopathy  [label="Takayasu\nRetinopathy", fillcolor="#00796B", fontcolor="white"]
        Ischemic_symp [label="Ischemic Symptoms\n(TIA, stroke risk)", fillcolor="#004D40", fontcolor="white"]
        Fever_systemic [label="Systemic Fever\n/ Night Sweats", fillcolor="#80CBC4"]
        Fatigue_wt_loss [label="Fatigue /\nWeight Loss", fillcolor="#4DB6AC"]
        Myalgia_arthralgia [label="Myalgia &\nArthralgia", fillcolor="#26A69A"]
        FDG_PET_score [label="FDG-PET\nVascular Activity Score", fillcolor="#00897B"]
        MRI_VWT      [label="MRI Vessel Wall\nThickness (mm)", fillcolor="#00796B", fontcolor="white"]
        ACR_response [label="ACR 20/50/70\nResponse", fillcolor="#004D40", fontcolor="white"]
        Relapse_rate [label="Relapse Rate\n(events/year)", fillcolor="#80CBC4"]
    }

    /* ============================================================
       CLUSTER 8 — Drug PK Compartments
       ============================================================ */
    subgraph cluster_pk {
        label="Drug Pharmacokinetics (PK)"
        style="filled,rounded" fillcolor="#FFF8E1" color="#E65100" penwidth=2
        fontname="Helvetica-Bold" fontsize=13

        /* Prednisone/Prednisolone */
        PRED_depot   [label="Prednisone\nGut (depot)", fillcolor="#FFE082"]
        PRED_central [label="Prednisolone\nPlasma (Vc)", fillcolor="#FFD54F", penwidth=2]
        PRED_peri    [label="Prednisolone\nPeripheral (Vp)", fillcolor="#FFCA28"]
        PRED_effect  [label="Prednisolone\nEffect-site", fillcolor="#FFB300"]

        /* Methotrexate */
        MTX_gut      [label="Methotrexate\nGut (oral)", fillcolor="#FFE082"]
        MTX_central  [label="MTX Plasma\n(Vc)", fillcolor="#FFD54F"]
        MTX_intracel [label="MTX-Polyglutamate\n(intracellular active)", fillcolor="#FFB300"]

        /* Azathioprine → 6-TGN */
        AZA_gut      [label="Azathioprine\nGut", fillcolor="#FFE082"]
        AZA_6MP      [label="6-Mercaptopurine\n(plasma)", fillcolor="#FFD54F"]
        AZA_6TGN     [label="6-Thioguanine\nNucleotides (active)", fillcolor="#FFB300"]

        /* Tocilizumab */
        TCZ_SC       [label="Tocilizumab SC\nAbsorption", fillcolor="#FFE082"]
        TCZ_central  [label="Tocilizumab\nPlasma (Vc)", fillcolor="#FFD54F", penwidth=2]
        TCZ_peri     [label="Tocilizumab\nPeripheral (Vp)", fillcolor="#FFCA28"]

        /* Infliximab */
        IFX_infuse   [label="Infliximab IV\nInfusion", fillcolor="#FFE082"]
        IFX_central  [label="Infliximab\nPlasma (Vc)", fillcolor="#FFD54F"]
        IFX_peri     [label="Infliximab\nPeripheral (Vp)", fillcolor="#FFCA28"]

        /* Tofacitinib */
        TOF_gut      [label="Tofacitinib\nGut (oral)", fillcolor="#FFE082"]
        TOF_central  [label="Tofacitinib\nPlasma (Vc)", fillcolor="#FFD54F"]
    }

    /* ============================================================
       CLUSTER 9 — Drug PD Mechanisms
       ============================================================ */
    subgraph cluster_pd {
        label="Drug Pharmacodynamics (PD) & Target Engagement"
        style="filled,rounded" fillcolor="#E8F5E9" color="#1B5E20" penwidth=2
        fontname="Helvetica-Bold" fontsize=13

        GR_activation [label="Glucocorticoid Receptor\n(GR) Activation", fillcolor="#A5D6A7"]
        NF_kB_inhib  [label="NF-κB Inhibition\n(prednisolone)", fillcolor="#66BB6A"]
        MAPK_inhib   [label="MAPK/AP-1\nInhibition", fillcolor="#43A047"]
        Cytokine_suppress [label="Cytokine mRNA\nSuppression", fillcolor="#2E7D32", fontcolor="white"]
        DHFR_inhib   [label="DHFR Inhibition\n(MTX)", fillcolor="#A5D6A7"]
        Adenosine_MTX [label="Adenosine Release\n(MTX anti-inflammatory)", fillcolor="#66BB6A"]
        Purine_inhib  [label="Purine Synthesis\nInhibition (AZA/6TGN)", fillcolor="#43A047"]
        T_proliferation_inhib [label="T Cell Proliferation\nInhibition (AZA/MTX)", fillcolor="#2E7D32", fontcolor="white"]
        IL6R_occ     [label="IL-6R Occupancy\n(tocilizumab)", fillcolor="#A5D6A7", penwidth=2.5]
        STAT3_block  [label="STAT3 Signaling\nBlock (TCZ→JAK→STAT3)", fillcolor="#66BB6A"]
        TNF_neutral  [label="TNF-α Neutralization\n(infliximab/adalimumab)", fillcolor="#A5D6A7"]
        JAK1_3_inhib [label="JAK1/JAK3\nInhibition (tofacitinib)", fillcolor="#43A047"]
        STAT3_1_inhib [label="STAT3/STAT1\nInhibition (TOF)", fillcolor="#2E7D32", fontcolor="white"]
        Drug_effect_combined [label="Combined\nDrug Effect (Emax)", fillcolor="#1B5E20", fontcolor="white"]
    }

    /* ============================================================
       CLUSTER 10 — Biomarkers & Serology
       ============================================================ */
    subgraph cluster_biomarker {
        label="Biomarkers, Serology & Monitoring"
        style="filled,rounded" fillcolor="#FAFAFA" color="#424242" penwidth=2
        fontname="Helvetica-Bold" fontsize=13

        ESR          [label="ESR\n(mm/hr)", fillcolor="#BDBDBD", penwidth=2]
        CRP          [label="CRP (mg/L)\nhigh-sensitivity", fillcolor="#9E9E9E", penwidth=2]
        SAA          [label="Serum Amyloid A\n(SAA)", fillcolor="#BDBDBD"]
        Fibrinogen_B [label="Fibrinogen\n(acute phase)", fillcolor="#9E9E9E"]
        IL6_serum    [label="Serum IL-6\n(ng/mL)", fillcolor="#757575", fontcolor="white"]
        sIL6R_serum  [label="Serum sIL-6R\n(ng/mL)", fillcolor="#616161", fontcolor="white"]
        VEGF_serum   [label="Serum VEGF\n(pg/mL)", fillcolor="#BDBDBD"]
        MMP3_serum   [label="MMP-3\n(serum marker)", fillcolor="#9E9E9E"]
        AECA_titer   [label="AECA Titer\n(IgG anti-EC Ab)", fillcolor="#757575", fontcolor="white"]
        PET_SUV_max  [label="PET-CT\nSUVmax (FDG)", fillcolor="#616161", fontcolor="white"]
        VWT_MRI      [label="MRI Vessel Wall\nThickness Index", fillcolor="#BDBDBD"]
        WBC_diff     [label="WBC / Differential\n(lymphocytes)", fillcolor="#9E9E9E"]
        Steroid_SE   [label="Steroid Side Effects\n(BMD, glucose, BP)", fillcolor="#757575", fontcolor="white"]
        ACR_toxicity [label="Drug Toxicity Score\n(hepatic, bone marrow)", fillcolor="#616161", fontcolor="white"]
    }

    /* ============================================================
       EDGES — Cluster 1 (Triggers/Innate) internal
       ============================================================ */
    HLA_B52 -> Adventitial_DCs [label="risk allele"]
    HLA_B39 -> Adventitial_DCs [label="risk allele"]
    MICA_gene -> NK_cells [label="activating ligand"]
    Env_trigger -> TLR2_4 [label="PAMP"]
    MTB_homolog -> HSP70_65 [label="molecular mimicry"]
    HSP70_65 -> Adventitial_DCs [label="antigen"]
    TLR2_4 -> NOD_like_R [label="synergy"]
    TLR2_4 -> Macrophage_M1 [label="activation"]
    NOD_like_R -> IL1beta [label="NLRP3→caspase-1"]
    Adventitial_DCs -> Phagocytosis [label="APC function"]
    Phagocytosis -> APC_priming [label="cross-presentation"]
    DAMP_signals -> TLR2_4 [label="endogenous ligands"]
    DAMP_signals -> NOD_like_R [label="stress signals"]
    Macrophage_M1 -> TNF_alpha [label="produce"]
    Macrophage_M1 -> IL12 [label="produce"]
    Macrophage_M1 -> IL18 [label="produce"]
    Macrophage_M1 -> ROS [label="produce"]
    Macrophage_M2 -> TGFbeta [label="fibrotic switch"]
    Macrophage_M2 -> Collagen_dep [label="fibrosis"]
    NK_cells -> Perforin_GZB [label="cytotoxicity"]
    Neutrophil -> ROS [label="oxidative burst"]
    Mast_cell -> TNF_alpha [label="degranulation"]
    IL1beta -> NOD_like_R [label="amplification loop", style=dashed]

    /* ============================================================
       EDGES — Cluster 1 → Cluster 2 (Innate → T cells)
       ============================================================ */
    APC_priming -> MHC_II [label="present"]
    MHC_II -> TCR_signal [label="TCR engagement"]
    TCR_signal -> CD28_costim [label="co-stimulation req."]
    CD28_costim -> T_proliferate [label="activation"]
    CTLA4_inhib -> T_proliferate [label="inhibit", color=red]
    PD1_PDL1 -> T_proliferate [label="inhibit", color=red]
    IL12 -> Th1_cell [label="polarize CD4+"]
    IL23 -> Th17_cell [label="polarize/maintain"]
    T_proliferate -> Naive_CD4 [label="expand from"]
    T_proliferate -> Naive_CD8 [label="expand from"]
    Naive_CD4 -> Th1_cell
    Naive_CD4 -> Th17_cell
    Naive_CD4 -> Treg_cell
    Naive_CD4 -> Th2_cell
    Naive_CD8 -> CD8_CTL
    JAK1_3_T -> STAT1_STAT3 [label="phosphorylate"]
    IL6 -> JAK1_3_T [label="via gp130"]
    IL2_autocrine -> T_proliferate [label="growth factor"]
    Th1_cell -> Memory_T [label="differentiate"]
    Th17_cell -> Memory_T
    CD8_CTL -> Memory_T

    /* ============================================================
       EDGES — Cluster 2 T cells → Cytokines
       ============================================================ */
    Th1_cell -> IFNgamma [label="secrete"]
    Th1_cell -> TNF_alpha [label="secrete"]
    Th1_cell -> IL2_autocrine [label="autocrine"]
    Th17_cell -> IL17A [label="secrete"]
    Th17_cell -> IL17F [label="secrete"]
    Th17_cell -> IL21 [label="secrete"]
    CD8_CTL -> IFNgamma [label="secrete"]
    CD8_CTL -> Perforin_GZB [label="cytotoxicity"]
    Treg_cell -> IL10 [label="secrete"]
    Treg_cell -> TGFbeta [label="secrete"]
    Treg_cell -> Th1_cell [label="suppress", color=red]
    Treg_cell -> Th17_cell [label="suppress", color=red]

    /* ============================================================
       EDGES — Cluster 3 B cells
       ============================================================ */
    Th2_cell -> B_activation [label="Tfh IL-4/IL-21"]
    IL21 -> B_activation [label="promote"]
    IL6 -> B_activation [label="survival"]
    BAFF -> Naive_B [label="survival"]
    Naive_B -> B_activation
    B_activation -> Germinal_center
    Germinal_center -> Plasma_cell
    Germinal_center -> Memory_B
    Plasma_cell -> AECA [label="secrete"]
    Plasma_cell -> Anti_aorta_Ab [label="secrete"]
    Plasma_cell -> Anti_HSP_Ab [label="secrete"]
    Plasma_cell -> IgG_subclass
    AECA -> Complement_C3 [label="activate"]
    Anti_aorta_Ab -> Complement_C3
    Complement_C3 -> Complement_C4
    Complement_C4 -> Complement_MAC [label="terminal pathway"]
    AECA -> FcR_activation [label="via Fc"]
    FcR_activation -> Macrophage_M1 [label="ADCC"]

    /* ============================================================
       EDGES — Cytokine Network Internal
       ============================================================ */
