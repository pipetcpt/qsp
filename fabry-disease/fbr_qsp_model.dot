  X_linked -> Hetero_female  [label="이형접합"]
  Hetero_female -> X_inactivation [label="불활성화 가변"]
  GLA_missense -> Amenable_mut [label="~40% 해당"]
  GLA_missense -> Classic_vs_late [label="변이→표현형"]
  GLA_nonsense -> Classic_male [label="완전 결핍"]

  GLA_gene -> alpha_GalA_pre [label="전사/번역" style=dashed]
