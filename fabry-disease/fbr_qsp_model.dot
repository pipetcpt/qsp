  Gb3_synthesis -> Gb3_kidney
  Gb3_synthesis -> Gb3_heart
  Gb3_synthesis -> Gb3_CNS
  Gb3_synthesis -> Gb3_skin
  Gb3_plasma -> Lyso_Gb3_from_Gb3 -> Lyso_Gb3 [label="탈아실화"]
  alpha_GalA_mature -> Gb3_clearance [label="Gb3 가수분해"]
  Residual_activity -> Gb3_clearance
  Gb3_clearance -> Gb3_plasma [label="억제" dir=back arrowhead=tee color=green]
  Gb3_plasma -> Gb3_urine [label="여과 배설"]

  // =========================================================
  // EDGES: KIDNEY PATHOLOGY
  // =========================================================
  Gb3_kidney -> Podocyte_Gb3 -> Podocyte_injury -> Foot_effacement -> Proteinuria
