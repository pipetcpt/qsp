  alpha_GalA_mature -> AlphaGalA_plasma [label="DBS 건조혈반"]
  Gb3_plasma -> Plasma_Gb3 [label="정량"]
  Macrophage_M1 -> Chitotriosidase [label="분비"]
  Macrophage_M1 -> CCL18_mac [label="분비"]
  eGFR_decline -> eGFR_CKD_EPI [label="산정"]
  LV_hypertrophy -> LVMi_echo [label="측정"]
  Proteinuria -> UPCR_biomarker [label="측정"]
  DBS_screening -> AlphaGalA_plasma [label="신생아 선별"]

  // =========================================================
  // EDGES: CLINICAL ENDPOINTS
  // =========================================================
