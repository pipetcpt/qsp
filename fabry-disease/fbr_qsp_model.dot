  Plasma_LysoGb3 -> MSSI_score [label="중증도 반영" style=dashed]
  LysoGb3_signal -> Podocyte_injury [label="직접 독성" style=dashed]
  LysoGb3_signal -> CM_Gb3 [label="직접 독성" style=dashed]
  LysoGb3_signal -> DRG_Gb3 [label="직접 독성" style=dashed]

  // Legend
  subgraph cluster_legend {
    label="범례 (Legend)" style=filled fillcolor="#FFFFFF" color="#9E9E9E"
    L1 [label="→ 활성화/촉진" shape=plaintext]
    L2 [label="─┤ 억제" shape=plaintext]
    L3 [label="- - → 간접/모델링 연결" shape=plaintext]
    L4 [label="녹색 = 치료 효과" shape=plaintext fontcolor=green]
    L5 [label="붉은색 = 부작용/억제" shape=plaintext fontcolor=red]
  }
