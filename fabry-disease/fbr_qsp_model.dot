// Fabry Disease QSP Mechanistic Map
// α-Galactosidase A deficiency → Gb3/lyso-Gb3 accumulation → multi-organ pathology
// Treatments: ERT (agalsidase alfa/beta, pegunigalsidase alfa), migalastat (chaperone), lucerastat/venglustat (SRT)
// 138 nodes, 14 clusters
// Layout: fdp (spring-based, good for large biological networks)

digraph FabryDisease_QSP {
  graph [
    label="Fabry Disease — Quantitative Systems Pharmacology Map\nα-Galactosidase A Deficiency · Lysosomal Storage · Multi-Organ Pathology · ERT / Chaperone / SRT"
    labelloc=t labeljust=c fontsize=22 fontname="Helvetica-Bold"
    splines=true overlap=false sep="+8" rankdir=TB
    bgcolor="#FAFAFA" pad=1.0
  ]
  node [fontname="Helvetica" fontsize=11 style="filled,rounded" shape=box height=0.38 margin="0.12,0.06"]
  edge [fontname="Helvetica" fontsize=9 arrowsize=0.7]

  // =========================================================
  // CLUSTER 1: GENETIC BASIS
  // =========================================================
  subgraph cluster_genetic {
    label="① 유전적 기반 (Genetic Basis)"
    style=filled fillcolor="#FFF3E0" color="#E65100" penwidth=2 fontname="Helvetica-Bold" fontsize=13

    GLA_gene         [label="GLA 유전자\n(Xq22.1)" fillcolor="#FF8F00" fontcolor=white]
    GLA_missense     [label="미스센스 변이\n(~60%)" fillcolor="#FFA726"]
    GLA_nonsense     [label="넌센스/프레임시프트" fillcolor="#FFA726"]
    GLA_splicing     [label="스플라이싱 변이" fillcolor="#FFA726"]
    GLA_deletion     [label="대형 결실/삽입" fillcolor="#FFA726"]
    X_linked         [label="X-연관 유전\n(반성유전)" fillcolor="#FFB74D"]
    Hemizygous_male  [label="반접합 남성\n(고전형 다수)" fillcolor="#FFCC80"]
    Hetero_female    [label="보인자 여성\n(X 불활성화 가변)" fillcolor="#FFCC80"]
    X_inactivation   [label="Lyon X-불활성화\n(증상 이질성)" fillcolor="#FFE0B2"]
    Amenable_mut     [label="미갈라스타트 적합\n변이 (~40%)" fillcolor="#FF7043" fontcolor=white]
    Classic_vs_late  [label="고전형 vs 후기 발현형\n(잔여 효소 활성에 따라)" fillcolor="#FFE0B2"]
  }

  // =========================================================
  // CLUSTER 2: α-GAL A ENZYME BIOLOGY
  // =========================================================
  subgraph cluster_enzyme {
    label="② α-갈락토시다제 A 효소 생물학 (α-Gal A Enzyme Biology)"
    style=filled fillcolor="#E8F5E9" color="#2E7D32" penwidth=2 fontname="Helvetica-Bold" fontsize=13

    alpha_GalA_pre   [label="α-Gal A 전구체\n(ER 합성)" fillcolor="#66BB6A"]
    ER_folding       [label="ER 단백질 접힘\n(HSP70/BiP 보조)" fillcolor="#81C784"]
    Golgi_M6P        [label="골지체 M6P\n인산화 수식" fillcolor="#81C784"]
    M6PR_receptor    [label="M6P 수용체\n(CI-MPR, CD-MPR)" fillcolor="#A5D6A7"]
    Lysosomal_delivery [label="리소솜 전달\n(산성 pH 4.5–5.0)" fillcolor="#A5D6A7"]
    alpha_GalA_mature [label="α-Gal A 성숙형\n(활성 이량체)" fillcolor="#4CAF50" fontcolor=white]
    Lysosomal_pH     [label="리소솜 pH\n(4.5–5.0 최적)" fillcolor="#C8E6C9"]
    Enzyme_activity  [label="효소 활성\n(nmol/h/mg 단백)" fillcolor="#C8E6C9"]
    Residual_activity [label="잔여 효소 활성\n(고전형 <1%, 후기 1–30%)" fillcolor="#DCEDC8"]
    Cross_correction [label="교차교정\n(세포외 α-Gal A 흡수)" fillcolor="#DCEDC8"]
  }

  // =========================================================
  // CLUSTER 3: GLYCOSPHINGOLIPID METABOLISM
  // =========================================================
  subgraph cluster_gsl {
    label="③ 당스핑고지질 대사 (Glycosphingolipid Metabolism)"
    style=filled fillcolor="#E3F2FD" color="#1565C0" penwidth=2 fontname="Helvetica-Bold" fontsize=13

    Ceramide         [label="세라미드\n(Sphingolipid 전구체)" fillcolor="#1E88E5" fontcolor=white]
    GCS_enzyme       [label="글루코실세라미드\n합성효소 (GCS/UGCG)" fillcolor="#42A5F5"]
    Glucosylceramide [label="글루코실세라미드\n(GlcCer)" fillcolor="#64B5F6"]
    Lactosylceramide [label="락토실세라미드\n(LacCer)" fillcolor="#64B5F6"]
    A4GalT           [label="α-1,4-갈락토실전달효소\n(A4GalT)" fillcolor="#90CAF9"]
    Gb3_synthesis    [label="Gb3 생합성\n(트리헥소실세라미드)" fillcolor="#1565C0" fontcolor=white]
    Gb3_plasma       [label="혈장 Gb3\n(μg/mL)" fillcolor="#1976D2" fontcolor=white]
    Gb3_urine        [label="소변 Gb3\n(nmol/mg Cr)" fillcolor="#1976D2" fontcolor=white]
    Lyso_Gb3         [label="Lyso-Gb3 (혈장)\n(μg/L, 민감한 바이오마커)" fillcolor="#E53935" fontcolor=white]
    Gb3_kidney       [label="신장 Gb3\n(족세포·세뇨관)" fillcolor="#5C6BC0" fontcolor=white]
    Gb3_heart        [label="심장 Gb3\n(심근세포·전도계)" fillcolor="#AB47BC" fontcolor=white]
    Gb3_CNS          [label="CNS Gb3\n(신경세포·혈관내피)" fillcolor="#7E57C2" fontcolor=white]
    Gb3_skin         [label="피부 Gb3\n(혈관내피·땀샘)" fillcolor="#42A5F5"]
    Gb3_clearance    [label="리소솜 Gb3 분해\n(α-Gal A 의존)" fillcolor="#90CAF9"]
    Lyso_Gb3_from_Gb3 [label="Lyso-Gb3 생성\n(Gb3 탈아실화)" fillcolor="#EF9A9A"]
  }

  // =========================================================
  // CLUSTER 4: KIDNEY PATHOLOGY
  // =========================================================
  subgraph cluster_kidney {
    label="④ 신장 병리 (Renal Pathology)"
    style=filled fillcolor="#FCE4EC" color="#880E4F" penwidth=2 fontname="Helvetica-Bold" fontsize=13

    Podocyte_Gb3     [label="족세포 Gb3 축적\n(사구체 여과 장벽)" fillcolor="#EC407A" fontcolor=white]
    Podocyte_injury  [label="족세포 손상\n(족돌기 소실)" fillcolor="#F06292"]
    Foot_effacement  [label="족돌기 소실\n(전자현미경)" fillcolor="#F48FB1"]
    Proteinuria      [label="단백뇨\n(UPCR mg/g)" fillcolor="#E91E63" fontcolor=white]
    Tubular_dysfunc  [label="세뇨관 기능장애\n(농축능↓, 리소솜 봉입체)" fillcolor="#F48FB1"]
    TGF_beta_renal   [label="TGF-β / 신장 섬유화" fillcolor="#CE93D8"]
    Mesangial_exp    [label="메산지움 팽창\n(비면역 침착)" fillcolor="#F8BBD0"]
    FSGS_renal       [label="국소분절사구체경화증\n(FSGS, 후기)" fillcolor="#AD1457" fontcolor=white]
    eGFR_decline     [label="eGFR 감소\n(mL/min/1.73m²/year)" fillcolor="#C2185B" fontcolor=white]
    ESRD             [label="말기 신부전\n(ESRD)" fillcolor="#880E4F" fontcolor=white]
    Renal_biopsy_LB  [label="신장 생검\n(리소솜 봉입체 증명)" fillcolor="#FCE4EC"]
  }

  // =========================================================
  // CLUSTER 5: CARDIAC PATHOLOGY
  // =========================================================
  subgraph cluster_cardiac {
    label="⑤ 심장 병리 (Cardiac Pathology)"
    style=filled fillcolor="#EDE7F6" color="#4A148C" penwidth=2 fontname="Helvetica-Bold" fontsize=13

    CM_Gb3           [label="심근세포 Gb3 축적\n(좌심실 이중층 비후)" fillcolor="#7B1FA2" fontcolor=white]
    LV_hypertrophy   [label="좌심실 비후\n(LVMi g/m²)" fillcolor="#9C27B0" fontcolor=white]
    Diastolic_dysfunc [label="이완기 기능 장애\n(E/e' 비)" fillcolor="#AB47BC"]
    Systolic_dysfunc [label="수축기 기능 저하\n(EF↓, 말기)" fillcolor="#CE93D8"]
    Short_PR         [label="단축 PR 간격\n(부전도로 가속)" fillcolor="#BA68C8"]
    Arrhythmia       [label="부정맥\n(SVT/VF/완전방실차단)" fillcolor="#7B1FA2" fontcolor=white]
    LGE_fibrosis     [label="지연 가돌리늄 증강\n(LGE = 심근 섬유화)" fillcolor="#9C27B0" fontcolor=white]
    Cardiac_fibrosis [label="심장 섬유화\n(TGF-β 매개)" fillcolor="#CE93D8"]
    Conduction_defect [label="전도계 이상\n(SA결절·AVN 침범)" fillcolor="#D1C4E9"]
    Sudden_death     [label="급사\n(VF/VT)" fillcolor="#4A148C" fontcolor=white]
    Cardiac_biopsy   [label="심근 생검\n(Zebra body 봉입체)" fillcolor="#EDE7F6"]
  }

  // =========================================================
  // CLUSTER 6: NEUROLOGICAL PATHOLOGY
  // =========================================================
  subgraph cluster_neuro {
    label="⑥ 신경계 병리 (Neurological Pathology)"
    style=filled fillcolor="#E8EAF6" color="#1A237E" penwidth=2 fontname="Helvetica-Bold" fontsize=13

    DRG_Gb3          [label="배근 신경절 Gb3\n(DRG, 소섬유신경병증)" fillcolor="#3949AB" fontcolor=white]
    Small_fiber_neuro [label="소섬유 신경병증\n(표피내신경밀도↓)" fillcolor="#5C6BC0" fontcolor=white]
    Neuropathic_pain [label="신경병성 통증\n(BPI-SF, 0-10)" fillcolor="#3F51B5" fontcolor=white]
    Burning_pain     [label="화끈거리는 통증\n(손발·더위·운동 유발)" fillcolor="#5C6BC0"]
    Central_sensitiz [label="중추 감작\n(통증 과민)" fillcolor="#7986CB"]
    Endothelial_CNS  [label="CNS 혈관내피 Gb3\n(소혈관 협착)" fillcolor="#9FA8DA"]
    WM_lesions       [label="백질 병변\n(FLAIR MRI)" fillcolor="#7986CB"]
    TIA_stroke       [label="TIA/뇌경색\n(젊은 연령 뇌졸중)" fillcolor="#1A237E" fontcolor=white]
    Autonomic_neuro  [label="자율신경 이상\n(기립성 저혈압·빈맥)" fillcolor="#9FA8DA"]
    Hearing_loss     [label="감각신경성 난청\n(와우 침범)" fillcolor="#C5CAE9"]
    Dizziness        [label="현기증/전정 이상\n(삼반고리관)" fillcolor="#C5CAE9"]
    Cerebrovascular  [label="뇌혈관 위험도\n(조기 뇌졸중 예측)" fillcolor="#283593" fontcolor=white]
  }

  // =========================================================
  // CLUSTER 7: OTHER ORGAN SYSTEMS
  // =========================================================
  subgraph cluster_other {
    label="⑦ 기타 장기 (Other Organ Systems)"
    style=filled fillcolor="#E0F7FA" color="#006064" penwidth=2 fontname="Helvetica-Bold" fontsize=13

    Angiokeratoma    [label="혈관각화종\n(피부 Gb3 혈관 침범)" fillcolor="#00838F" fontcolor=white]
    Anhidrosis       [label="무한증/저한증\n(땀샘 기능 저하)" fillcolor="#0097A7"]
    Skin_pain        [label="피부 화끈통증\n(소섬유신경·피부침범)" fillcolor="#26C6DA"]
    GI_dysmotility   [label="위장관 운동장애\n(조기 포만·팽만)" fillcolor="#0097A7"]
    GI_pain_diarrhea [label="복통·설사·변비\n(장관 자율신경 침범)" fillcolor="#26C6DA"]
    Cornea_verticillata [label="각막 소용돌이\n(cornea verticillata)" fillcolor="#00838F" fontcolor=white]
    Pulmonary_obstruct [label="폐쇄성 폐질환\n(기도 Gb3)" fillcolor="#4DD0E1"]
    Lymphedema       [label="림프부종\n(림프관 내피 침범)" fillcolor="#80DEEA"]
  }

  // =========================================================
  // CLUSTER 8: INFLAMMATORY CASCADE
  // =========================================================
  subgraph cluster_inflam {
    label="⑧ 염증 폭포 (Inflammatory Cascade)"
    style=filled fillcolor="#FFF8E1" color="#F57F17" penwidth=2 fontname="Helvetica-Bold" fontsize=13

    LysoGb3_signal   [label="Lyso-Gb3\n신호전달 활성" fillcolor="#FF8F00" fontcolor=white]
    TLR4_activation  [label="TLR4 활성화\n(Lyso-Gb3 DAMP 역할)" fillcolor="#F9A825"]
    NF_kB            [label="NF-κB 경로\n(전사 활성화)" fillcolor="#F57F17" fontcolor=white]
    IL6_TNFa         [label="IL-6 / TNF-α\n(전신 염증 매개자)" fillcolor="#FF6F00" fontcolor=white]
    Oxidative_stress [label="산화 스트레스\n(ROS/NOX2)" fillcolor="#FFA000"]
    Macrophage_M1    [label="M1 대식세포 활성화\n(IL-1β 분비)" fillcolor="#FFB300"]
    NLRP3            [label="NLRP3 인플라마좀\n(caspase-1 활성)" fillcolor="#FF8F00" fontcolor=white]
    Complement_act   [label="보체 활성화\n(C3·C5a 생성)" fillcolor="#FFC107"]
    eNOS_reduction   [label="eNOS 감소\n(혈관이완능↓)" fillcolor="#FFECB3"]
    Endothelial_activ [label="내피세포 활성화\n(VCAM-1·ICAM-1↑)" fillcolor="#FFD54F"]
  }

  // =========================================================
  // CLUSTER 9: ERT PK/PD
  // =========================================================
  subgraph cluster_ert {
    label="⑨ 효소대체요법 PK/PD (ERT Pharmacokinetics / Pharmacodynamics)"
    style=filled fillcolor="#F3E5F5" color="#6A1B9A" penwidth=2 fontname="Helvetica-Bold" fontsize=13

    AgaB_dose        [label="아갈시다제 베타\n(Fabrazyme, 1 mg/kg IV Q2W)" fillcolor="#7B1FA2" fontcolor=white]
    AgaA_dose        [label="아갈시다제 알파\n(Replagal, 0.2 mg/kg IV Q2W)" fillcolor="#8E24AA" fontcolor=white]
    PeguniAga_dose   [label="페구니알시다제 알파\n(Elfabrio, 1 mg/kg IV Q4W)" fillcolor="#9C27B0" fontcolor=white]
    ERT_plasma_C     [label="ERT 혈장(중심구획)\n(ng/mL)" fillcolor="#AB47BC"]
    ERT_plasma_P     [label="ERT 말초구획\n(분포)" fillcolor="#CE93D8"]
    ERT_t_half       [label="소실 t½\n(AgaB: ~45min, Pegu: ~80h)" fillcolor="#BA68C8"]
    M6PR_uptake      [label="M6P 수용체 매개 흡수\n(간·신장·심장·내피)" fillcolor="#9C27B0" fontcolor=white]
    Lysosomal_ERT    [label="리소솜 내 ERT 활성\n(Gb3 분해 가속)" fillcolor="#7B1FA2" fontcolor=white]
    ERT_antibody     [label="항ERT IgG 항체\n(일부 환자, 고역가시 효능↓)" fillcolor="#E1BEE7"]
    ERT_infusion_rxn [label="주입 관련 반응\n(발열·두드러기·아나필락시)" fillcolor="#E1BEE7"]
    ERT_Emax         [label="ERT 최대 효과\n(Emax Gb3 감소 65–80%)" fillcolor="#CE93D8"]
    ERT_EC50         [label="ERT EC50\n(반최대 효소활성 농도)" fillcolor="#D1C4E9"]
    Gb3_KID_clear    [label="신장 Gb3 감소\n(족세포 ERT 반응)" fillcolor="#CE93D8"]
    Gb3_HRT_clear    [label="심장 Gb3 감소\n(심근세포 ERT 반응)" fillcolor="#CE93D8"]
  }

  // =========================================================
  // CLUSTER 10: MIGALASTAT (CHAPERONE)
  // =========================================================
  subgraph cluster_chaperone {
    label="⑩ 미갈라스타트 샤페론 (Migalastat Pharmacological Chaperone)"
    style=filled fillcolor="#E8F5E9" color="#1B5E20" penwidth=2 fontname="Helvetica-Bold" fontsize=13

    Migalastat_oral  [label="미갈라스타트 경구\n(150 mg 1일 간격 격일)" fillcolor="#2E7D32" fontcolor=white]
    MIG_plasma       [label="미갈라스타트 혈장\n(1구획 PK, t½~3–4h)" fillcolor="#388E3C"]
    MIG_lysosome     [label="리소솜 내 미갈라스타트\n(효소 활성 부위 결합)" fillcolor="#43A047"]
    Chaperone_bind   [label="샤페론 결합\n(가역적 경쟁적)" fillcolor="#4CAF50"]
    GLA_stabilize    [label="GLA 단백질 안정화\n(미스폴딩 방지, ER→리소솜)" fillcolor="#66BB6A"]
    Enzyme_restore   [label="효소 활성 복원\n(+50–100% vs 기저치)" fillcolor="#81C784"]
    Amenable_check   [label="적합성 확인\n(HEK293 세포 검정, ~340종 적합)" fillcolor="#A5D6A7"]
    MIG_Emax         [label="미갈라스타트 Emax\n(α-Gal A 활성 +75%)" fillcolor="#C8E6C9"]
    ATTRACT_trial    [label="ATTRACT 임상시험\n(vs ERT, 18개월, 비열등)" fillcolor="#DCEDC8"]
  }

  // =========================================================
  // CLUSTER 11: SUBSTRATE REDUCTION THERAPY
  // =========================================================
  subgraph cluster_srt {
    label="⑪ 기질감소요법 (Substrate Reduction Therapy · SRT)"
    style=filled fillcolor="#FBE9E7" color="#BF360C" penwidth=2 fontname="Helvetica-Bold" fontsize=13

    Lucerastat_oral  [label="루세라스탓 경구\n(1000 mg TID, GCS 억제제)" fillcolor="#E64A19" fontcolor=white]
    Venglustat_oral  [label="벵글루스탓 경구\n(CNS 투과, GCS 억제제)" fillcolor="#F4511E" fontcolor=white]
    GCS_inhib_effect [label="GCS 억제\n(글루코실세라미드 합성↓)" fillcolor="#FF5722" fontcolor=white]
    GlcCer_reduction [label="글루코실세라미드 감소\n(상류 기질 감소)" fillcolor="#FF7043"]
    Gb3_upstream_red [label="Gb3 감소\n(기질 공급 감소)" fillcolor="#FF8A65"]
    SRT_plasma_C     [label="SRT 혈장 농도\n(경구 PK)" fillcolor="#FFAB91"]
    SRT_Emax         [label="SRT 최대 효과\n(Emax Gb3 -30–40%)" fillcolor="#FFCCBC"]
    SRT_CNS_penetr   [label="CNS 투과\n(venglustat 전용)" fillcolor="#FBE9E7"]
  }

  // =========================================================
  // CLUSTER 12: BIOMARKERS
  // =========================================================
  subgraph cluster_biomarkers {
    label="⑫ 바이오마커 (Biomarkers)"
    style=filled fillcolor="#F1F8E9" color="#33691E" penwidth=2 fontname="Helvetica-Bold" fontsize=13

    Plasma_LysoGb3   [label="혈장 Lyso-Gb3\n(μg/L, 민감·특이 바이오마커)" fillcolor="#558B2F" fontcolor=white]
    Urine_Gb3        [label="소변 Gb3\n(nmol/mg 크레아티닌)" fillcolor="#689F38" fontcolor=white]
    AlphaGalA_leuko  [label="백혈구 α-Gal A 활성\n(남성 진단 기준)" fillcolor="#7CB342"]
    AlphaGalA_plasma [label="혈장 α-Gal A 활성\n(DBS 건조혈반 선별)" fillcolor="#8BC34A"]
    Plasma_Gb3       [label="혈장 Gb3\n(μg/mL)" fillcolor="#9CCC65"]
    Chitotriosidase  [label="키토트리오시다제\n(대식세포 활성 지표)" fillcolor="#AED581"]
    CCL18_mac        [label="CCL18 (PARC)\n(대식세포 활성화 지표)" fillcolor="#C5E1A5"]
    eGFR_CKD_EPI     [label="eGFR (CKD-EPI)\n(mL/min/1.73m²)" fillcolor="#DCEDC8"]
    LVMi_echo        [label="LVMi 심초음파\n(g/m²)" fillcolor="#F0F4C3"]
    UPCR_biomarker   [label="UPCR\n(mg/g 크레아티닌)" fillcolor="#DCEDC8"]
    DBS_screening    [label="건조혈반 신생아\n선별검사 (DBS)" fillcolor="#F1F8E9"]
  }

  // =========================================================
  // CLUSTER 13: CLINICAL ENDPOINTS
  // =========================================================
  subgraph cluster_endpoints {
    label="⑬ 임상 엔드포인트 (Clinical Endpoints)"
    style=filled fillcolor="#ECEFF1" color="#263238" penwidth=2 fontname="Helvetica-Bold" fontsize=13

    eGFR_slope       [label="eGFR 기울기\n(mL/min/1.73m²/yr)" fillcolor="#37474F" fontcolor=white]
    UPCR_endpoint    [label="UPCR 변화\n(단백뇨 감소율)" fillcolor="#455A64" fontcolor=white]
    LVMi_endpoint    [label="LVMi 변화\n(g/m², 심장 비후 역전)" fillcolor="#546E7A" fontcolor=white]
    BPI_SF           [label="Brief Pain Inventory\n(BPI-SF, 0–10)" fillcolor="#607D8B" fontcolor=white]
    EQ5D_QoL         [label="EQ-5D / SF-36\n(삶의 질)" fillcolor="#78909C"]
    MSSI             [label="마인츠 중증도 점수\n(MSSI, 0–138)" fillcolor="#90A4AE"]
    Composite_event  [label="복합 임상 사건\n(신·심·뇌혈관 결과)" fillcolor="#B0BEC5"]
    Stroke_TIA_event [label="뇌졸중/TIA 발생률\n(년간 위험도)" fillcolor="#455A64" fontcolor=white]
    Cardiac_event    [label="심장 사건\n(급사·심부전 입원)" fillcolor="#546E7A" fontcolor=white]
    Renal_event      [label="신장 사건\n(투석 시작/이식)" fillcolor="#607D8B" fontcolor=white]
  }

  // =========================================================
  // CLUSTER 14: NATURAL HISTORY & STAGING
  // =========================================================
  subgraph cluster_nathistory {
    label="⑭ 자연 경과 및 병기 (Natural History & Disease Staging)"
    style=filled fillcolor="#FCE4EC" color="#AD1457" penwidth=2 fontname="Helvetica-Bold" fontsize=13

    Classic_male     [label="고전형 남성\n(소아기 발현, <1% 잔여)" fillcolor="#C2185B" fontcolor=white]
    Nonclassic_male  [label="후기 발현 남성\n(심장/신장, 잔여 1–30%)" fillcolor="#D81B60" fontcolor=white]
    Female_carrier   [label="여성 보인자\n(다양한 증상 스펙트럼)" fillcolor="#E91E63" fontcolor=white]
    Childhood_Fabry  [label="소아기 파브리\n(통증·angiokeratoma·발한장애)" fillcolor="#F06292"]
    Adult_Fabry      [label="성인기 파브리\n(신·심·뇌 합병증 축적)" fillcolor="#F48FB1"]
    Late_Fabry       [label="말기 파브리\n(투석·심부전·사망)" fillcolor="#E91E63" fontcolor=white]
    Registry_data    [label="파브리 레지스트리\n(Fabry Registry/FOS)" fillcolor="#FCE4EC"]
    MSSI_score       [label="MSSI 중증도\n(0=없음 ~ 138=최중증)" fillcolor="#F48FB1"]
    Treatment_delay  [label="진단 지연\n(평균 10–20년 지연 진단)" fillcolor="#FCE4EC"]
    Gene_therapy     [label="유전자 치료\n(ST-920, isaralgagene civaparvovec)" fillcolor="#FCE4EC"]
  }

  // =========================================================
  // EDGES: GENETIC → ENZYME
  // =========================================================
  GLA_gene -> GLA_missense [label="변이 유형별"]
