  Female_carrier -> Adult_Fabry [style=dashed label="다양한 경과"]
  Adult_Fabry -> MSSI_score [label="중증도 평가"]
  Treatment_delay -> Childhood_Fabry [style=dashed label="진단 지연"]
  Registry_data -> MSSI_score [style=dashed]
  Gene_therapy -> GLA_gene [label="미래 치료 (임상시험)" style=dashed color=gray]
  Late_Fabry -> ESRD [style=dashed]
  Late_Fabry -> Sudden_death [style=dashed]
  Late_Fabry -> TIA_stroke [style=dashed]

  // =========================================================
  // CROSS-CLUSTER CONNECTIONS
  // =========================================================
  Hemizygous_male -> Classic_male [style=dashed]
  Hetero_female -> Female_carrier [style=dashed]
  Residual_activity -> Nonclassic_male [label="1–30% 잔여" style=dashed]
