digraph bullous_pemphigoid_qsp {
    graph [
        label="Bullous Pemphigoid — Quantitative Systems Pharmacology Model\n(Mechanistic Map v1.0)",
        labelloc=t,
        fontname="Helvetica",
        fontsize=18,
        bgcolor="#F8F9FA",
        splines=ortho,
        nodesep=0.3,
        ranksep=0.5,
        compound=true
    ];
    node [
        shape=box,
        style="rounded,filled",
        fontname="Helvetica",
        fontsize=9,
        fillcolor="#FFFFFF",
        color="#555555",
        margin="0.1,0.05"
    ];
    edge [
        fontname="Helvetica",
        fontsize=7,
        color="#666666",
        arrowsize=0.6
    ];

    /* =====================================================================
       CLUSTER 1: Genetic & Environmental Triggers
    ===================================================================== */
    subgraph cluster_triggers {
        label="Genetic & Environmental\nTriggers";
        style=filled;
        fillcolor="#FFF3CD";
        color="#E6A817";
        fontsize=11;

        HLA_DQB1    [label="HLA-DQB1*03:01\n(Susceptibility Allele)", fillcolor="#FFE08A"];
        HLA_DQ7     [label="HLA-DQ7 Haplotype", fillcolor="#FFE08A"];
        age_factor  [label="Aging / Elderly\n(>65 years)", fillcolor="#FFD580"];
        neuro_comorbid [label="Neurological Comorbidities\n(MS, Parkinson's, Dementia,\nEpilepsy, Stroke)", fillcolor="#FFD580"];
        drug_triggers  [label="Drug Triggers\n(Checkpoint inhibitors, Gliptins,\nFurosemide, Penicillin)", fillcolor="#FFD580"];
        skin_trauma    [label="Skin Trauma / UV\n/ Burns", fillcolor="#FFD580"];
        checkpoint_inh [label="PD-1/PD-L1 Inhibitors\n(Pembrolizumab,\nNivolumab)", fillcolor="#FFC0CB"];
        gliptins       [label="DPP-4 Inhibitors\n(Gliptins)", fillcolor="#FFC0CB"];
        immune_dysreg  [label="Age-related Immune\nDysregulation (Inflammaging)", fillcolor="#FFD580"];
    }

    /* =====================================================================
       CLUSTER 2: Antigen Presentation & Innate Immunity
    ===================================================================== */
    subgraph cluster_innate {
        label="Innate Immunity &\nAntigen Presentation";
        style=filled;
        fillcolor="#D1ECF1";
        color="#17A2B8";
        fontsize=11;

        plasmacytoid_DC [label="Plasmacytoid\nDendritic Cells (pDC)", fillcolor="#85D4E3"];
        myeloid_DC      [label="Myeloid Dendritic\nCells (mDC)", fillcolor="#85D4E3"];
        langerhans_cells[label="Langerhans Cells\n(Epidermis)", fillcolor="#85D4E3"];
        macrophage_M2   [label="M2 Macrophages\n(Tissue)", fillcolor="#85D4E3"];
        TSLP_epid       [label="TSLP\n(Thymic Stromal\nLymphopoietin)", fillcolor="#A8D5E2"];
        IL_33_src       [label="IL-33\n(Alarmin)", fillcolor="#A8D5E2"];
        IL_25_src       [label="IL-25 (IL-17E)\n(Alarmin)", fillcolor="#A8D5E2"];
        TLR_signaling   [label="TLR2/4/9\nSignaling", fillcolor="#85D4E3"];
        NF_kB_innate    [label="NF-κB Activation\n(Innate)", fillcolor="#85D4E3"];
        MHC_II          [label="MHC-II /\nHLA-DQ Complex", fillcolor="#A8D5E2"];
        antigen_processing [label="Antigen Processing\n& Presentation", fillcolor="#A8D5E2"];
        IFN_alpha_pDC   [label="IFN-α Production\n(pDC)", fillcolor="#85D4E3"];
    }

    /* =====================================================================
       CLUSTER 3: Target Antigens at DEJ
    ===================================================================== */
    subgraph cluster_DEJ {
        label="Target Antigens\n(Dermal-Epidermal Junction)";
        style=filled;
        fillcolor="#D4EDDA";
        color="#28A745";
        fontsize=11;

        BP180_NC16A  [label="BP180 / Collagen XVII\nNC16A Domain\n(Immunodominant Epitope)", fillcolor="#6BCB77"];
        BP180_full   [label="BP180 Full-length\n(ectodomain shedding)", fillcolor="#6BCB77"];
        BP230_spectrin[label="BP230 / BPAG1-e\n(Plakin Domain)", fillcolor="#6BCB77"];
        hemidesmosome[label="Hemidesmosome\nComplex Integrity", fillcolor="#9EE09E"];
        alpha6_integrin [label="α6β4 Integrin\n(Hemidesmosome Anchor)", fillcolor="#9EE09E"];
        laminin_332  [label="Laminin-332\n(DEJ Scaffold)", fillcolor="#9EE09E"];
        Collagen_VII [label="Collagen VII\n(Anchoring Fibrils)", fillcolor="#9EE09E"];
        DEJ_cleavage [label="DEJ Structural\nCleavage", fillcolor="#FF7B7B"];
        BP180_shed_ectodomain [label="Shed BP180\nEctodomain\n(Serum Marker)", fillcolor="#FFB347"];
    }

    /* =====================================================================
       CLUSTER 4: T Cell Activation (Th2 Skewing)
    ===================================================================== */
    subgraph cluster_tcell {
        label="T Cell Activation\n(Th2 Immunological Skewing)";
        style=filled;
        fillcolor="#E2D9F3";
        color="#6F42C1";
        fontsize=11;

        naive_CD4      [label="Naive CD4+ T Cells", fillcolor="#C3A6E8"];
        Th0            [label="Th0 (Uncommitted)", fillcolor="#C3A6E8"];
        Th2_cells      [label="Th2 Cells\n(Dominant in BP)", fillcolor="#9B72CF", fontcolor="#FFFFFF"];
        Th1_cells      [label="Th1 Cells\n(Minor Role)", fillcolor="#C3A6E8"];
        Treg_cells     [label="Regulatory T Cells\n(Treg / FoxP3+)", fillcolor="#C3A6E8"];
        Tfh_cells      [label="Tfh Cells\n(B-cell Help)", fillcolor="#C3A6E8"];
        TCR_activation [label="TCR / CD3\nActivation", fillcolor="#C3A6E8"];
        CD28_B7        [label="CD28–B7\nCo-stimulation", fillcolor="#C3A6E8"];
        CTLA4_check    [label="CTLA-4\nCheckpoint", fillcolor="#E8D5F5"];
        PD1_check      [label="PD-1 / PD-L1\nCheckpoint", fillcolor="#E8D5F5"];
        IL_4_Th2       [label="IL-4 (Th2 Cytokine)", fillcolor="#9B72CF", fontcolor="#FFFFFF"];
        IL_13_Th2      [label="IL-13 (Th2 Cytokine)", fillcolor="#9B72CF", fontcolor="#FFFFFF"];
        IL_5_Th2       [label="IL-5\n(Eosinophil Growth)", fillcolor="#9B72CF", fontcolor="#FFFFFF"];
        IL_31_Th2      [label="IL-31\n(Pruritus Mediator)", fillcolor="#9B72CF", fontcolor="#FFFFFF"];
        IL_2_Tcell     [label="IL-2\n(T-cell Proliferation)", fillcolor="#C3A6E8"];
        STAT6_path     [label="JAK1/STAT6\nSignaling (IL-4R)", fillcolor="#E8D5F5"];
        class_switch_IgE [label="IgE Class Switch\n(IL-4 driven)", fillcolor="#FFB3C1"];
        class_switch_IgG4 [label="IgG4 Class Switch\n(IL-4/IL-13)", fillcolor="#FFB3C1"];
    }

    /* =====================================================================
       CLUSTER 5: B Cell & Autoantibody Production
    ===================================================================== */
    subgraph cluster_bcell {
        label="B Cell Activation &\nAutoantibody Production";
        style=filled;
        fillcolor="#FCE4EC";
        color="#E83E8C";
        fontsize=11;

        naive_B        [label="Naive B Cells\n(IgM+, CD19+)", fillcolor="#F48FB1"];
        activated_B    [label="Activated B Cells\n(CD19+, CD86+)", fillcolor="#F48FB1"];
        GC_B           [label="Germinal Center\nB Cells", fillcolor="#F48FB1"];
        memory_B       [label="Memory B Cells\n(CD27+)", fillcolor="#F48FB1"];
        short_plasma   [label="Short-lived Plasma\nCells (SLPC)", fillcolor="#E91E8C"];
        long_plasma    [label="Long-lived Plasma\nCells (LLPC)\n(Bone Marrow)", fillcolor="#E91E8C", fontcolor="#FFFFFF"];
        anti_BP180_IgG [label="Anti-BP180 IgG\n(Pathogenic Ab)", fillcolor="#C2185B", fontcolor="#FFFFFF"];
        anti_BP180_IgE [label="Anti-BP180 IgE\n(Itch/Mast cell)", fillcolor="#C2185B", fontcolor="#FFFFFF"];
        anti_BP230_IgG [label="Anti-BP230 IgG\n(Secondary Ab)", fillcolor="#E91E8C"];
        BAFF_signal    [label="BAFF / BLyS\n(B-cell Survival)", fillcolor="#F8BBD0"];
        APRIL_signal   [label="APRIL\n(Plasma Cell\nSurvival)", fillcolor="#F8BBD0"];
        BCR_activation [label="BCR Activation\n(Antigen Binding)", fillcolor="#F48FB1"];
        CD40_CD40L     [label="CD40–CD40L\nInteraction", fillcolor="#F48FB1"];
    }

    /* =====================================================================
       CLUSTER 6: Complement System
    ===================================================================== */
    subgraph cluster_complement {
        label="Complement System\nActivation";
        style=filled;
        fillcolor="#FFF0F0";
        color="#DC3545";
        fontsize=11;

        C1q_bind    [label="C1q Binding to\nIgG Fc (Classical)", fillcolor="#FF8A80"];
        C1r_s       [label="C1r/C1s Serine\nProteases", fillcolor="#FF8A80"];
        C4b_C2a     [label="C4b2a\nConvertase", fillcolor="#FF8A80"];
        C3_conv     [label="C3 Convertase\n(C4b2a3b)", fillcolor="#FF8A80"];
        C3a_anaphyl [label="C3a\n(Anaphylatoxin)", fillcolor="#FF5252", fontcolor="#FFFFFF"];
        C3b_opson   [label="C3b\n(Opsonin)", fillcolor="#FF8A80"];
        C5_conv     [label="C5 Convertase", fillcolor="#FF8A80"];
        C5a_chemotax[label="C5a\n(Chemotaxin/\nMast Cell Trigger)", fillcolor="#FF5252", fontcolor="#FFFFFF"];
        MAC_C5b9    [label="MAC (C5b-9)\n(Membrane Attack\nComplex)", fillcolor="#FF5252", fontcolor="#FFFFFF"];
        C1inh       [label="C1-Inhibitor\n(Regulation)", fillcolor="#FFCDD2"];
        CD55_CD59   [label="CD55 / CD59\n(Complement Regulators)", fillcolor="#FFCDD2"];
    }

    /* =====================================================================
       CLUSTER 7: Effector Cells & Mediators
    ===================================================================== */
    subgraph cluster_effectors {
        label="Effector Cells &\nInflammatory Mediators";
        style=filled;
        fillcolor="#FFF8E1";
        color="#FFC107";
        fontsize=11;

        eosinophils_blood [label="Blood Eosinophils\n(↑ in active BP)", fillcolor="#FFEE58"];
        eosinophils_skin  [label="Skin/Lesional\nEosinophils", fillcolor="#FFEE58"];
        mast_cells_skin   [label="Skin Mast Cells\n(FcεRI+)", fillcolor="#FFD700"];
        basophils         [label="Basophils\n(FcεRI+)", fillcolor="#FFEE58"];
        neutrophils_skin  [label="Skin Neutrophils", fillcolor="#FFEE58"];
        FcR_activation    [label="FcεRI Activation\n(IgE-Ag Cross-linking)", fillcolor="#FFB300"];
        FcgRIII_ADCC      [label="FcγRIII (CD16)\nADCC / ADCP", fillcolor="#FFB300"];
        MBP_release       [label="Major Basic Protein\n(MBP)", fillcolor="#FF8F00", fontcolor="#FFFFFF"];
        ECP_release       [label="Eosinophil Cationic\nProtein (ECP)", fillcolor="#FF8F00", fontcolor="#FFFFFF"];
        NE_release        [label="Neutrophil Elastase\n(NE)", fillcolor="#FF8F00", fontcolor="#FFFFFF"];
        MMP9_release      [label="MMP-9\n(Gelatinase B)", fillcolor="#FF8F00", fontcolor="#FFFFFF"];
        MMP2_release      [label="MMP-2\n(Gelatinase A)", fillcolor="#FF8F00", fontcolor="#FFFFFF"];
        ROS_generation    [label="Reactive Oxygen\nSpecies (ROS)", fillcolor="#FF8F00", fontcolor="#FFFFFF"];
        histamine_release [label="Histamine Release\n(Mast Cells)", fillcolor="#FFB300"];
        tryptase_release  [label="Tryptase\n(Mast Cell)", fillcolor="#FFB300"];
        LTB4_prod         [label="LTB4\n(Leukotriene B4)", fillcolor="#FFB300"];
        eotaxin_CCL11     [label="Eotaxin-1 / CCL11\n(Eosinophil Recruit.)", fillcolor="#FFEE58"];
        eotaxin3_CCL26    [label="Eotaxin-3 / CCL26", fillcolor="#FFEE58"];
    }

    /* =====================================================================
       CLUSTER 8: Skin Pathology & Blister Formation
    ===================================================================== */
    subgraph cluster_skin {
        label="Skin Pathology &\nBlister Formation";
        style=filled;
        fillcolor="#E8F5E9";
        color="#388E3C";
        fontsize=11;

        basal_keratinocytes [label="Basal Keratinocytes\n(BP180-expressing)", fillcolor="#81C784"];
        TSLP_keratino      [label="Keratinocyte-derived\nTSLP / IL-33", fillcolor="#81C784"];
        periostin_skin     [label="Periostin\n(Th2 tissue marker)", fillcolor="#81C784"];
        DEJ_disruption     [label="DEJ Structural\nDisruption", fillcolor="#E53935", fontcolor="#FFFFFF"];
        subepidermal_blister [label="Subepidermal\nBlister Formation", fillcolor="#E53935", fontcolor="#FFFFFF"];
        tense_bullae       [label="Tense Bullae\n(Clinical Lesion)", fillcolor="#E53935", fontcolor="#FFFFFF"];
        urticaria_lesions  [label="Urticarial/Pre-bullous\nLesions", fillcolor="#EF9A9A"];
        erythematous_plaques [label="Erythematous\nPlaques", fillcolor="#EF9A9A"];
        skin_healing       [label="Skin Wound Healing\n(Post-blister)", fillcolor="#A5D6A7"];
        BPDAI_activity     [label="BPDAI Activity\nScore", fillcolor="#FF7043", fontcolor="#FFFFFF"];
        BPDAI_damage       [label="BPDAI Damage\nScore", fillcolor="#FF7043", fontcolor="#FFFFFF"];
        BSA_affected       [label="BSA Affected (%)", fillcolor="#FF7043", fontcolor="#FFFFFF"];
        blister_count      [label="Blister Count\n(per day)", fillcolor="#FF7043", fontcolor="#FFFFFF"];
    }

    /* =====================================================================
       CLUSTER 9: Pruritus Signaling
    ===================================================================== */
    subgraph cluster_pruritus {
        label="Pruritus (Itch)\nSignaling";
        style=filled;
        fillcolor="#F3E5F5";
        color="#9C27B0";
        fontsize=11;

        IL31_receptor  [label="IL-31 Receptor\n(IL-31RA / OSMR)", fillcolor="#CE93D8"];
        JAK1_IL31      [label="JAK1/TYK2\nSignaling (IL-31R)", fillcolor="#CE93D8"];
        STAT3_itch     [label="STAT3 Activation\n(Itch Signaling)", fillcolor="#CE93D8"];
        H1_receptor    [label="H1 Histamine\nReceptor", fillcolor="#CE93D8"];
        TRPV1_channel  [label="TRPV1 Ion Channel\n(Itch/Pain)", fillcolor="#CE93D8"];
        TRPA1_channel  [label="TRPA1 Ion Channel", fillcolor="#CE93D8"];
        substance_P    [label="Substance P\n(Neuropeptide)", fillcolor="#CE93D8"];
        sensory_C_fiber[label="Sensory C Fibers\n(Itch-specific)", fillcolor="#CE93D8"];
        dorsal_horn_spinal [label="Dorsal Horn\nSpinal Cord Processing", fillcolor="#CE93D8"];
        itch_NRS       [label="Itch NRS Score\n(0-10)", fillcolor="#9C27B0", fontcolor="#FFFFFF"];
        scratch_damage [label="Scratch-induced\nSkin Damage", fillcolor="#9C27B0", fontcolor="#FFFFFF"];
    }

    /* =====================================================================
       CLUSTER 10: Corticosteroid PK/PD
    ===================================================================== */
    subgraph cluster_cs_pk {
        label="Corticosteroid PK/PD\n(Prednisolone / Clobetasol)";
        style=filled;
        fillcolor="#E0F7FA";
        color="#00BCD4";
        fontsize=11;

        pred_oral_dose [label="Prednisolone Oral\nDose (0.5-1 mg/kg/d)", fillcolor="#80DEEA"];
        pred_gut       [label="GI Absorption\n(F≈0.82)", fillcolor="#80DEEA"];
        pred_central   [label="Prednisolone\nCentral (Plasma)", fillcolor="#4DD0E1"];
        pred_peripheral[label="Prednisolone\nPeripheral Tissue", fillcolor="#80DEEA"];
        GR_alpha       [label="Glucocorticoid\nReceptor-α (GRα)", fillcolor="#4DD0E1"];
        GR_complex_form[label="GR-Ligand Complex\n(Nuclear Transport)", fillcolor="#4DD0E1"];
        GRE_transact   [label="GRE Transactivation\n(Anti-inflam genes)", fillcolor="#26C6DA"];
        NF_kB_repression [label="NF-κB Repression\n(Pro-inflam suppression)", fillcolor="#26C6DA"];
        AP1_repression [label="AP-1 / c-Jun\nRepression", fillcolor="#26C6DA"];
        cortisol_suppression [label="HPA Axis Suppression\n(Endogenous Cortisol ↓)", fillcolor="#80DEEA"];
        clobetasol_topical [label="Clobetasol Propionate\n(Topical, Class I)", fillcolor="#80DEEA"];
    }

    /* =====================================================================
       CLUSTER 11: Dupilumab PK/PD (IL-4Rα blockade)
    ===================================================================== */
    subgraph cluster_dupilumab {
        label="Dupilumab PK/PD\n(anti-IL-4Rα)";
        style=filled;
        fillcolor="#E8EAF6";
        color="#3F51B5";
        fontsize=11;

        dup_dose       [label="Dupilumab Dose\n(300 mg SC Q2W)", fillcolor="#9FA8DA"];
        dup_depot      [label="SC Depot\n(Absorption site)", fillcolor="#9FA8DA"];
        dup_central    [label="Dupilumab\nCentral Compartment", fillcolor="#7986CB"];
        dup_IL4Ra_bound[label="Dupilumab–IL-4Rα\nBound Complex", fillcolor="#5C6BC0"];
        IL4Ra_free     [label="Free IL-4Rα\n(Target)", fillcolor="#9FA8DA"];
        IL4Ra_suppression [label="IL-4 / IL-13\nSignaling Block", fillcolor="#5C6BC0"];
        STAT6_block    [label="STAT6 Phosphorylation\nInhibition", fillcolor="#5C6BC0"];
        Th2_suppression_dup [label="Th2 Cytokine\nSuppression", fillcolor="#7986CB"];
    }

    /* =====================================================================
       CLUSTER 12: Omalizumab & Rituximab PK/PD
    ===================================================================== */
    subgraph cluster_other_biol {
        label="Omalizumab & Rituximab\nPK/PD";
        style=filled;
        fillcolor="#FFEBEE";
        color="#F44336";
        fontsize=11;

        oma_dose       [label="Omalizumab Dose\n(300 mg SC Q4W)", fillcolor="#FFCDD2"];
        oma_depot      [label="Omalizumab SC\nDepot", fillcolor="#FFCDD2"];
        oma_central    [label="Omalizumab\nCentral Compartment", fillcolor="#EF9A9A"];
        oma_IgE_complex[label="Omalizumab–IgE\nComplex (Neutralization)", fillcolor="#E57373"];
        FcepsilonRI_downreg [label="FcεRI\nDownregulation", fillcolor="#E57373"];
        mast_basophil_suppress [label="Mast Cell/Basophil\nActivation Suppressed", fillcolor="#E57373"];
        ritu_dose      [label="Rituximab Dose\n(1g IV × 2, then Q6M)", fillcolor="#FFCDD2"];
        ritu_central   [label="Rituximab\nCentral Compartment", fillcolor="#EF9A9A"];
        CD20_target    [label="CD20 Target\n(B Cells)", fillcolor="#E57373"];
        Bcell_depletion[label="B Cell Depletion\n(>95%)", fillcolor="#C62828", fontcolor="#FFFFFF"];
        Bcell_recovery [label="B Cell Recovery\n(12-18 months)", fillcolor="#FFCDD2"];
        doxy_dose      [label="Doxycycline Dose\n(200 mg/d PO)", fillcolor="#FFCDD2"];
        doxy_central   [label="Doxycycline\nCentral (Plasma)", fillcolor="#EF9A9A"];
        MMP_inhibition_doxy [label="MMP-9 Inhibition\n(Doxycycline)", fillcolor="#E57373"];
        NF_kB_doxy     [label="NF-κB\nInhibition (Doxy)", fillcolor="#E57373"];
    }

    /* =====================================================================
       CLUSTER 13: Clinical Endpoints & Outcomes
    ===================================================================== */
    subgraph cluster_endpoints {
        label="Clinical Endpoints\n& Outcomes";
        style=filled;
        fillcolor="#F1F8E9";
        color="#33691E";
        fontsize=11;

        BPDAI_total    [label="BPDAI Total Score\n(Activity + Damage)", fillcolor="#AED581"];
        new_blister_rate [label="New Blister Formation\nRate (/day)", fillcolor="#AED581"];
        IGA_BP         [label="IGA-BP Score\n(0=clear, 5=very severe)", fillcolor="#AED581"];
        DLQI_score     [label="DLQI\n(Quality of Life, 0-30)", fillcolor="#AED581"];
        complete_remission [label="Complete Remission\n(off therapy)", fillcolor="#558B2F", fontcolor="#FFFFFF"];
        partial_remission  [label="Partial Remission\n(on minimal therapy)", fillcolor="#7CB342", fontcolor="#FFFFFF"];
        relapse_event  [label="Relapse Event\n(≥3 new blisters/day)", fillcolor="#F57F17", fontcolor="#FFFFFF"];
        steroid_sparing[label="Cumulative Steroid\nExposure (Steroid-sparing)", fillcolor="#AED581"];
        mortality_risk [label="Mortality Risk\n(Zegarnik score)", fillcolor="#BF360C", fontcolor="#FFFFFF"];
        anti_BP180_titer [label="Anti-BP180 NC16A\nAntibody Titer (U/mL)", fillcolor="#AED581"];
    }

    /* =====================================================================
       EDGES — Triggers → Antigen Presentation
    ===================================================================== */
    age_factor      -> immune_dysreg  [label="promotes"];
    immune_dysreg   -> plasmacytoid_DC [label="activates"];
    neuro_comorbid  -> drug_triggers  [label="may require"];
    drug_triggers   -> antigen_processing [label="induces aberrant\nBP180 exposure"];
    checkpoint_inh  -> PD1_check      [label="blocks", color="#E53935"];
    gliptins        -> antigen_processing [label="alter DPP-4\npeptide epitopes"];
    skin_trauma     -> TSLP_epid      [label="induces", color="#FF6F00"];
    skin_trauma     -> IL_33_src      [label="releases", color="#FF6F00"];
    HLA_DQB1        -> MHC_II         [label="confers\nsusceptibility"];
    HLA_DQ7         -> MHC_II         [label="confers\nsusceptibility"];

    /* Innate to Adaptive */
    TSLP_epid       -> plasmacytoid_DC [label="activates DC"];
    IL_33_src       -> mast_cells_skin [label="activates"];
    IL_25_src       -> Th0             [label="promotes Th2"];
    TLR_signaling   -> NF_kB_innate   [label="activates"];
    NF_kB_innate    -> TSLP_epid      [label="induces"];
    plasmacytoid_DC -> IFN_alpha_pDC  [label="secretes"];
    myeloid_DC      -> antigen_processing [label="performs"];
    langerhans_cells-> antigen_processing [label="performs"];
    antigen_processing -> MHC_II      [label="loads peptide"];
    MHC_II          -> TCR_activation  [label="presents to\nCD4+ T cells"];

    /* DEJ Antigen */
    basal_keratinocytes -> BP180_NC16A   [label="expresses"];
    basal_keratinocytes -> BP230_spectrin[label="expresses"];
    BP180_NC16A     -> hemidesmosome    [label="component of"];
    BP180_full      -> BP180_shed_ectodomain [label="ectodomain\nshedding"];
    alpha6_integrin -> hemidesmosome    [label="anchors to"];
    laminin_332     -> hemidesmosome    [label="connects to"];
    hemidesmosome   -> DEJ_cleavage     [label="disruption →", color="#E53935"];

    /* T Cell Activation */
    TCR_activation  -> naive_CD4        [label="activates"];
    CD28_B7         -> naive_CD4        [label="co-stim."];
    PD1_check       -> naive_CD4        [label="inhibits", arrowhead=tee, color="#888888"];
    CTLA4_check     -> naive_CD4        [label="inhibits", arrowhead=tee, color="#888888"];
    naive_CD4       -> Th0              [label="differentiates"];
    IL_4_Th2        -> Th0              [label="drives Th2\npolarization"];
    IL_25_src       -> Th0              [label="promotes Th2"];
    TSLP_epid       -> myeloid_DC       [label="licenses DC\nfor Th2"];
    Th0             -> Th2_cells        [label="IL-4 signals\npolarize"];
    Th0             -> Th1_cells        [label="IFN-γ signals\npolarize"];
    Th0             -> Treg_cells       [label="TGF-β/IL-2\npolarize"];
    Th2_cells       -> IL_4_Th2         [label="secretes"];
    Th2_cells       -> IL_13_Th2        [label="secretes"];
    Th2_cells       -> IL_5_Th2         [label="secretes"];
    Th2_cells       -> IL_31_Th2        [label="secretes"];
    Tfh_cells       -> IL_4_Th2         [label="secretes"];
    Tfh_cells       -> CD40_CD40L       [label="provides help"];
    IL_2_Tcell      -> Treg_cells       [label="expands"];
    STAT6_path      -> class_switch_IgE [label="drives"];
    IL_4_Th2        -> STAT6_path       [label="activates"];
    IL_4_Th2        -> class_switch_IgE [label="directly drives"];
    IL_4_Th2        -> class_switch_IgG4[label="drives"];

    /* B Cell Activation & Antibody */
    MHC_II          -> Tfh_cells        [label="activates"];
    BCR_activation  -> naive_B          [label="activates"];
    CD40_CD40L      -> activated_B      [label="drives GC"];
    BAFF_signal     -> activated_B      [label="survival"];
    naive_B         -> activated_B      [label="activation"];
    activated_B     -> GC_B             [label="GC reaction"];
    GC_B            -> memory_B         [label="differentiation"];
    GC_B            -> short_plasma     [label="differentiation"];
    short_plasma    -> long_plasma      [label="migration to\nbone marrow"];
    APRIL_signal    -> long_plasma      [label="survival"];
    class_switch_IgE -> anti_BP180_IgE  [label="produces"];
    class_switch_IgG4-> anti_BP180_IgG  [label="produces"];
    long_plasma     -> anti_BP180_IgG   [label="secretes"];
    long_plasma     -> anti_BP230_IgG   [label="secretes"];
    short_plasma    -> anti_BP180_IgE   [label="secretes"];

    /* Pathogenic Antibody Mechanisms */
    anti_BP180_IgG  -> BP180_NC16A      [label="binds NC16A", color="#C2185B"];
    anti_BP180_IgG  -> C1q_bind         [label="activates\ncomplement"];
    anti_BP180_IgE  -> FcR_activation   [label="cross-links\nFcεRI"];
    anti_BP180_IgG  -> FcgRIII_ADCC     [label="ADCC via\nFcγRIII"];

    /* Complement */
    C1q_bind        -> C1r_s            [label="activates"];
    C1r_s           -> C4b_C2a          [label="cleaves C4/C2"];
    C4b_C2a         -> C3_conv          [label="forms"];
    C3_conv         -> C3a_anaphyl      [label="generates"];
    C3_conv         -> C3b_opson        [label="generates"];
    C3_conv         -> C5_conv          [label="→"];
    C5_conv         -> C5a_chemotax     [label="generates"];
    C5_conv         -> MAC_C5b9         [label="generates"];
    C5a_chemotax    -> neutrophils_skin [label="recruits"];
    C5a_chemotax    -> mast_cells_skin  [label="activates"];
    C3a_anaphyl     -> mast_cells_skin  [label="activates"];
    C1inh           -> C1r_s            [label="inhibits", arrowhead=tee, color="#888888"];
    CD55_CD59       -> C3_conv          [label="inhibits", arrowhead=tee, color="#888888"];

    /* Effector Cells & Mediators */
    IL_5_Th2        -> eosinophils_blood [label="proliferation\n& activation"];
    eotaxin_CCL11   -> eosinophils_blood [label="recruits"];
    eotaxin3_CCL26  -> eosinophils_blood [label="recruits"];
    eosinophils_blood -> eosinophils_skin [label="tissue\nmigration"];
    FcR_activation  -> mast_cells_skin  [label="activates"];
    FcgRIII_ADCC    -> neutrophils_skin [label="activates"];
    mast_cells_skin -> histamine_release [label="releases"];
    mast_cells_skin -> tryptase_release  [label="releases"];
    mast_cells_skin -> LTB4_prod         [label="produces"];
    mast_cells_skin -> eotaxin_CCL11    [label="secretes"];
    eosinophils_skin -> MBP_release      [label="releases"];
    eosinophils_skin -> ECP_release      [label="releases"];
    eosinophils_skin -> MMP9_release     [label="releases"];
    eosinophils_skin -> ROS_generation   [label="produces"];
    neutrophils_skin -> NE_release       [label="releases"];
    neutrophils_skin -> MMP9_release     [label="releases"];
    neutrophils_skin -> ROS_generation   [label="produces"];

    /* Blister Formation */
    MBP_release     -> DEJ_disruption   [label="cleaves laminin"];
    ECP_release     -> DEJ_disruption   [label="degrades DEJ"];
    NE_release      -> DEJ_disruption   [label="cleaves BP180"];
    MMP9_release    -> DEJ_disruption   [label="cleaves collagen"];
    MAC_C5b9        -> DEJ_disruption   [label="membrane lysis"];
    ROS_generation  -> DEJ_disruption   [label="oxidative\ndamage"];
    DEJ_cleavage    -> subepidermal_blister [label="leads to"];
    DEJ_disruption  -> DEJ_cleavage     [label="causes"];
    subepidermal_blister -> tense_bullae [label="clinically"];
    histamine_release -> urticaria_lesions [label="causes"];
    urticaria_lesions -> erythematous_plaques [label="progresses"];
    erythematous_plaques -> tense_bullae [label="may progress"];

    /* Pruritus */
    IL_31_Th2       -> IL31_receptor    [label="binds"];
    IL31_receptor   -> JAK1_IL31        [label="activates"];
    JAK1_IL31       -> STAT3_itch       [label="→"];
    STAT3_itch      -> itch_NRS         [label="drives"];
    histamine_release -> H1_receptor    [label="activates"];
    H1_receptor     -> sensory_C_fiber  [label="activates"];
    TRPV1_channel   -> sensory_C_fiber  [label="activates"];
    TRPA1_channel   -> sensory_C_fiber  [label="activates"];
    tryptase_release -> TRPV1_channel   [label="sensitizes"];
    substance_P     -> mast_cells_skin  [label="activates\n(neurogenic)"];
    sensory_C_fiber -> dorsal_horn_spinal [label="transmits"];
    dorsal_horn_spinal -> itch_NRS      [label="perceived as"];
    itch_NRS        -> scratch_damage   [label="leads to"];
    scratch_damage  -> skin_trauma      [label="perpetuates", style=dashed];

    /* Keratinocyte amplification loop */
    IL_4_Th2        -> basal_keratinocytes [label="dysregulates"];
    IL_13_Th2       -> basal_keratinocytes [label="impairs barrier"];
    basal_keratinocytes -> TSLP_keratino  [label="secretes"];
    TSLP_keratino   -> TSLP_epid          [label="amplifies"];
    basal_keratinocytes -> periostin_skin  [label="secretes"];
    periostin_skin  -> eosinophils_skin    [label="retains"];
    IL_33_src       -> IL31_receptor       [label="synergizes\nwith IL-31"];

    /* Clinical Outcomes */
    DEJ_disruption  -> BPDAI_activity    [label="determines"];
    tense_bullae    -> blister_count     [label="counted as"];
    subepidermal_blister -> BSA_affected [label="determines"];
    skin_healing    -> BPDAI_damage      [label="reduces"];
    BPDAI_activity  -> BPDAI_total       [label="+"];
    BPDAI_damage    -> BPDAI_total       [label="+"];
    blister_count   -> IGA_BP            [label="determines"];
    BSA_affected    -> IGA_BP            [label="determines"];
    BPDAI_total     -> DLQI_score        [label="correlates"];
    itch_NRS        -> DLQI_score        [label="contributes"];
    BPDAI_total     -> complete_remission [label="score=0 →", color="#388E3C"];
    blister_count   -> relapse_event     [label="≥3/day →"];
    anti_BP180_IgG  -> anti_BP180_titer  [label="measured as"];
    anti_BP180_titer -> BPDAI_total      [label="predicts"];
    anti_BP180_titer -> relapse_event    [label="elevation\npredicts"];

    /* Corticosteroid PK/PD */
    pred_oral_dose  -> pred_gut          [label="absorbed\n(F=0.82)"];
    pred_gut        -> pred_central      [label="first-pass\nmetabolism"];
    pred_central    -> pred_peripheral   [label="distribution"];
    pred_central    -> GR_alpha          [label="binds"];
    GR_alpha        -> GR_complex_form   [label="forms\nligand-complex"];
    GR_complex_form -> GRE_transact      [label="nuclear\ntranslocates"];
    GR_complex_form -> NF_kB_repression  [label="represses"];
    GR_complex_form -> AP1_repression    [label="represses"];
    GRE_transact    -> IL_4_Th2          [label="suppresses", arrowhead=tee, color="#00BCD4"];
    GRE_transact    -> IL_13_Th2         [label="suppresses", arrowhead=tee, color="#00BCD4"];
    NF_kB_repression -> eotaxin_CCL11    [label="suppresses", arrowhead=tee, color="#00BCD4"];
    NF_kB_repression -> CXCL8           [label="suppresses", arrowhead=tee, color="#00BCD4"];
    NF_kB_repression -> IL_5_Th2         [label="suppresses", arrowhead=tee, color="#00BCD4"];
    GRE_transact    -> eosinophils_blood  [label="reduces\napoptosis ↑", arrowhead=tee, color="#00BCD4"];
    pred_central    -> cortisol_suppression [label="suppresses\nHPA axis"];
    clobetasol_topical -> GR_alpha        [label="topical\nbinding"];
    pred_central    -> steroid_sparing    [label="cumulative\nexposure"];

    /* Dupilumab PK/PD */
    dup_dose        -> dup_depot         [label="SC injection"];
    dup_depot       -> dup_central       [label="absorption\n(ka=0.15/d)"];
    dup_central     -> IL4Ra_free        [label="binds", color="#3F51B5"];
    IL4Ra_free      -> dup_IL4Ra_bound   [label="+ dupilumab →"];
    dup_IL4Ra_bound -> IL4Ra_suppression [label="blocks IL-4/IL-13\nsignaling"];
    IL4Ra_suppression -> STAT6_block     [label="prevents"];
    STAT6_block     -> Th2_suppression_dup [label="reduces"];
    Th2_suppression_dup -> IL_4_Th2      [label="suppresses", arrowhead=tee, color="#3F51B5"];
    Th2_suppression_dup -> IL_13_Th2     [label="suppresses", arrowhead=tee, color="#3F51B5"];
    Th2_suppression_dup -> IL_31_Th2     [label="suppresses", arrowhead=tee, color="#3F51B5"];
    STAT6_block     -> class_switch_IgE  [label="inhibits", arrowhead=tee, color="#3F51B5"];
    Th2_suppression_dup -> itch_NRS      [label="reduces", arrowhead=tee, color="#3F51B5"];

    /* Omalizumab PK/PD */
    oma_dose        -> oma_depot         [label="SC injection"];
    oma_depot       -> oma_central       [label="absorption\n(F≈0.62)"];
    oma_central     -> oma_IgE_complex   [label="binds free IgE"];
    oma_IgE_complex -> FcR_activation    [label="prevents IgE\ncross-linking", arrowhead=tee, color="#F44336"];
    oma_IgE_complex -> FcepsilonRI_downreg [label="induces FcεRI\ndownregulation"];
    FcepsilonRI_downreg -> mast_basophil_suppress [label="suppresses"];
    mast_basophil_suppress -> histamine_release [label="reduces", arrowhead=tee, color="#F44336"];
    mast_basophil_suppress -> LTB4_prod  [label="reduces", arrowhead=tee, color="#F44336"];

    /* Rituximab PK/PD */
    ritu_dose       -> ritu_central      [label="IV infusion"];
    ritu_central    -> CD20_target       [label="binds"];
    CD20_target     -> Bcell_depletion   [label="ADCC/CDC\ndepletion"];
    Bcell_depletion -> activated_B       [label="depletes", arrowhead=tee, color="#C62828"];
    Bcell_depletion -> memory_B          [label="depletes", arrowhead=tee, color="#C62828"];
    Bcell_depletion -> short_plasma      [label="partial depletion", arrowhead=tee, color="#C62828"];
    Bcell_depletion -> anti_BP180_IgG    [label="reduces production", arrowhead=tee, color="#C62828"];
    Bcell_recovery  -> naive_B           [label="→ reconstitution"];

    /* Doxycycline PK/PD */
    doxy_dose       -> doxy_central      [label="PO absorption\n(F≈0.93)"];
    doxy_central    -> MMP_inhibition_doxy [label="inhibits\nMMP-9"];
    doxy_central    -> NF_kB_doxy        [label="inhibits\nNF-κB"];
    MMP_inhibition_doxy -> MMP9_release  [label="reduces", arrowhead=tee, color="#F44336"];
    NF_kB_doxy      -> eotaxin_CCL11     [label="reduces", arrowhead=tee, color="#F44336"];

    /* CXCL8 node */
    CXCL8 [label="CXCL8 (IL-8)\n(Neutrophil Chemoattract.)", fillcolor="#FFEE58", style="rounded,filled", fontsize=9];
    CXCL8           -> neutrophils_skin  [label="recruits"];

    /* Mortality */
    BPDAI_total     -> mortality_risk    [label="severe disease\n→ infection\nrisk"];
    steroid_sparing -> mortality_risk    [label="high steroids\n→ comorbidities"];
    age_factor      -> mortality_risk    [label="elderly\n→ ↑ risk"];
    complete_remission -> partial_remission [label="achievable"];
    partial_remission  -> relapse_event  [label="may lead to\nif undertreated"];

    /* Anti-BP180 feedback */
    BP180_shed_ectodomain -> BCR_activation [label="provides antigen"];
    DEJ_disruption -> BP180_shed_ectodomain [label="increases\nshedding"];
}
