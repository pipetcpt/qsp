digraph CLL_QSP {
    graph [
        label="Chronic Lymphocytic Leukemia (CLL)\nQuantitative Systems Pharmacology Model\nBCR Signaling · Apoptosis · Microenvironment · BTKi · BCL-2i · Anti-CD20",
        labelloc=t, fontname="Helvetica", fontsize=20,
        rankdir=TB, splines=ortho,
        nodesep=0.45, ranksep=0.75, bgcolor="#F8F9FA"
    ]
    node [fontname="Helvetica", fontsize=9, shape=box, style="filled,rounded"]
    edge [fontname="Helvetica", fontsize=8]

    // ═══════════════════════════════════════════════════════════════════════
    // Cluster 1: Normal B-cell Development
    // ═══════════════════════════════════════════════════════════════════════
    subgraph cluster_normal_bcell {
        label="Normal B-cell Development"
        style=filled; fillcolor="#E3F2FD"; color="#1565C0"; fontcolor="#1565C0"; fontsize=12
        hsc         [label="HSC\n(Hematopoietic\nStem Cell)",       fillcolor="#BBDEFB"]
        clp         [label="CLP\n(Common Lymphoid\nProgenitor)",     fillcolor="#BBDEFB"]
        pro_bcell   [label="Pro-B Cell\n(D-J rearrangement)",        fillcolor="#90CAF9"]
        pre_bcell   [label="Pre-B Cell\n(V-DJ rearrangement)",       fillcolor="#90CAF9"]
        imm_bcell   [label="Immature B Cell\n(IgM+)",                fillcolor="#64B5F6"]
        naive_bcell [label="Naive B Cell\n(IgM+ IgD+)",              fillcolor="#42A5F5"]
        gc          [label="Germinal Center\nReaction",               fillcolor="#2196F3", fontcolor="white"]
        mem_bcell   [label="Memory B Cell\n(long-lived)",             fillcolor="#1976D2", fontcolor="white"]
        plasma_cell [label="Plasma Cell\n(Ig secretion)",             fillcolor="#1565C0", fontcolor="white"]
        ighv_shm    [label="IGHV Somatic\nHypermutation (SHM)",       fillcolor="#0D47A1", fontcolor="white"]
    }

    // ═══════════════════════════════════════════════════════════════════════
    // Cluster 2: CLL Cell Biology & Staging
    // ═══════════════════════════════════════════════════════════════════════
    subgraph cluster_cll_biology {
        label="CLL Cell Biology & Staging"
        style=filled; fillcolor="#FCE4EC"; color="#B71C1C"; fontcolor="#B71C1C"; fontsize=12
        cll_cell    [label="CLL B Cell\nCD19+CD5+CD23+\nCD200+ sIgM(low)", fillcolor="#FFCDD2"]
        alc         [label="ALC\n(Absolute Lymphocyte\nCount ×10⁹/L)",      fillcolor="#EF9A9A"]
        ldt         [label="Lymphocyte Doubling\nTime (LDT, months)",        fillcolor="#E57373"]
        binet_a     [label="Binet A\n<3 lymphoid areas",                     fillcolor="#FFCDD2"]
        binet_b     [label="Binet B\n≥3 lymphoid areas",                     fillcolor="#EF9A9A"]
        binet_c     [label="Binet C\nanemia/thrombocytopenia",                fillcolor="#E57373"]
        rai_0       [label="Rai 0\nlymphocytosis only",                       fillcolor="#FFCDD2"]
        rai_1       [label="Rai I\n+lymphadenopathy",                         fillcolor="#EF9A9A"]
        rai_2       [label="Rai II\n+splenomegaly",                           fillcolor="#E57373"]
        rai_34      [label="Rai III/IV\n+anemia/thrombocytopenia",            fillcolor="#D32F2F", fontcolor="white"]
        cd38        [label="CD38 Expression\n(poor prognosis marker)",         fillcolor="#FFCDD2"]
        zap70       [label="ZAP-70 Expression\n(poor prognosis proxy)",        fillcolor="#EF9A9A"]
        cd49d       [label="CD49d (VLA-4)\nadhesion/homing",                   fillcolor="#E57373"]
        smudge      [label="Smudge Cells\n(hallmark morphology)",              fillcolor="#FFCDD2"]
    }

    // ═══════════════════════════════════════════════════════════════════════
    // Cluster 3: BCR Signaling Pathway
    // ═══════════════════════════════════════════════════════════════════════
    subgraph cluster_bcr {
        label="BCR Signaling Pathway"
        style=filled; fillcolor="#E8F5E9"; color="#1B5E20"; fontcolor="#1B5E20"; fontsize=12
        ag          [label="Antigen / Auto-antigen\n(SLAMF7, IgM self-Ag)",  fillcolor="#C8E6C9"]
        bcr         [label="BCR Complex\nmIgM/mIgD + Igα/Igβ",              fillcolor="#A5D6A7"]
        lyn         [label="LYN Kinase\n(BCR proximal initiation)",           fillcolor="#81C784"]
        syk         [label="SYK Kinase\n(BCR amplification)",                 fillcolor="#66BB6A"]
        blnk        [label="BLNK (SLP-65)\nAdaptor protein",                  fillcolor="#4CAF50"]
        btk         [label="BTK\n(Bruton's Tyrosine Kinase)\nCys481 target",  fillcolor="#388E3C", fontcolor="white"]
        plcg2       [label="PLCγ2\n(phospholipase Cγ2)",                      fillcolor="#2E7D32", fontcolor="white"]
        ip3         [label="IP₃\n(inositol 1,4,5-P₃)",                        fillcolor="#81C784"]
        dag         [label="DAG\n(diacylglycerol)",                            fillcolor="#66BB6A"]
        ca_flux     [label="Ca²⁺ Flux\nER + extracellular stores",            fillcolor="#4CAF50"]
        nfat        [label="NFAT\n(Ca²⁺-dependent TF)",                       fillcolor="#388E3C", fontcolor="white"]
        pkc_b       [label="PKCβ\n(protein kinase C-β)",                      fillcolor="#2E7D32", fontcolor="white"]
        pi3k_d      [label="PI3Kδ\n(phosphoinositide-3-kinase delta)",        fillcolor="#81C784"]
        pip3        [label="PIP₃\n(PI-3,4,5-P₃)",                             fillcolor="#66BB6A"]
        akt         [label="AKT\n(serine/threonine kinase)",                   fillcolor="#4CAF50"]
        mtor        [label="mTOR\n(mTORC1/mTORC2)",                           fillcolor="#388E3C", fontcolor="white"]
        pten        [label="PTEN\n(PI3K antagonist\ntumor suppressor)",        fillcolor="#C8E6C9"]
        ras_raf     [label="RAS/RAF\n(MAPK cascade entry)",                    fillcolor="#A5D6A7"]
        mek_erk     [label="MEK/ERK\n(proliferation MAPK)",                   fillcolor="#81C784"]
        nfkb        [label="NF-κB\n(master survival TF)",                     fillcolor="#66BB6A"]
        ikk         [label="IKK Complex\n(IκB kinase)",                        fillcolor="#4CAF50"]
    }

    // ═══════════════════════════════════════════════════════════════════════
    // Cluster 4: Apoptosis Regulation (BCL-2 Family)
    // ═══════════════════════════════════════════════════════════════════════
    subgraph cluster_apoptosis {
        label="Apoptosis Regulation — BCL-2 Family"
        style=filled; fillcolor="#FFF3E0"; color="#E65100"; fontcolor="#E65100"; fontsize=12
        bcl2        [label="BCL-2\n(anti-apoptotic\nmain CLL target)",  fillcolor="#FFE0B2"]
        bcl_xl      [label="BCL-XL\n(anti-apoptotic)",                  fillcolor="#FFCC80"]
        bcl_w       [label="BCL-W\n(anti-apoptotic)",                   fillcolor="#FFB74D"]
        mcl1        [label="MCL-1\n(anti-apoptotic\nshort t½ ~2-4h)",   fillcolor="#FFA726"]
        a1_bfl1     [label="A1/BFL-1\n(NF-κB regulated)",              fillcolor="#FF9800"]
        bax         [label="BAX\n(pro-apoptotic effector)",             fillcolor="#F57C00", fontcolor="white"]
        bak         [label="BAK\n(pro-apoptotic effector)",             fillcolor="#E65100", fontcolor="white"]
        bid         [label="BID / tBID\n(caspase-8 activated)",         fillcolor="#FFE0B2"]
        bad         [label="BAD\n(BH3-only, AKT regulated)",            fillcolor="#FFCC80"]
        bim         [label="BIM\n(BH3-only, key in CLL)",               fillcolor="#FFB74D"]
        noxa        [label="NOXA\n(BH3-only, MCL-1 specific)",          fillcolor="#FFA726"]
        puma        [label="PUMA\n(BH3-only, p53 target)",              fillcolor="#FF9800"]
        hrk         [label="HRK\n(BH3-only, BCL-XL specific)",         fillcolor="#F57C00", fontcolor="white"]
        momp        [label="MOMP\n(mitochondrial outer\nmembrane permeabilization)", fillcolor="#E65100", fontcolor="white"]
        cyto_c      [label="Cytochrome C\nrelease",                     fillcolor="#BF360C", fontcolor="white"]
        apaf1       [label="APAF-1\nApoptosome",                        fillcolor="#BF360C", fontcolor="white"]
        casp9       [label="Caspase-9\n(initiator)",                    fillcolor="#870000", fontcolor="white"]
        casp3       [label="Caspase-3/7\n(executioner)",                fillcolor="#870000", fontcolor="white"]
        p53         [label="p53\n(TP53 tumor suppressor)",              fillcolor="#FF6F00", fontcolor="white"]
    }

    // ═══════════════════════════════════════════════════════════════════════
    // Cluster 5: Tumor Microenvironment
    // ═══════════════════════════════════════════════════════════════════════
    subgraph cluster_tme {
        label="Tumor Microenvironment (TME)"
        style=filled; fillcolor="#F3E5F5"; color="#4A148C"; fontcolor="#4A148C"; fontsize=12
        bone_marrow [label="Bone Marrow Niche\n(primary reservoir)",     fillcolor="#E1BEE7"]
        lymph_node  [label="Lymph Node\n(proliferation center)",         fillcolor="#CE93D8"]
        periph_blood[label="Peripheral Blood\n(surveillance/egress)",    fillcolor="#BA68C8"]
        th_cell     [label="CD4+ T Helper Cell\n(CD40L+ contact)",       fillcolor="#AB47BC"]
        treg        [label="T Regulatory Cell\n(immunosuppression)",     fillcolor="#9C27B0", fontcolor="white"]
        nk_cell     [label="NK Cell\n(ADCC effector)\nFcγRIIIA+",        fillcolor="#7B1FA2", fontcolor="white"]
        tam         [label="Tumor-Associated\nMacrophage (TAM)",         fillcolor="#6A1B9A", fontcolor="white"]
        fdc         [label="Follicular Dendritic\nCell (FDC)",           fillcolor="#4A148C", fontcolor="white"]
        cxcl12      [label="CXCL12/SDF-1\n(BM retention chemokine)",    fillcolor="#E1BEE7"]
        cxcl13      [label="CXCL13\n(LN homing chemokine)",             fillcolor="#CE93D8"]
        cxcr4_r     [label="CXCR4\n(BM receptor on CLL)",               fillcolor="#BA68C8"]
        cxcr5_r     [label="CXCR5\n(LN receptor on CLL)",               fillcolor="#AB47BC"]
        cd40        [label="CD40/CD40L\nT-cell contact",                  fillcolor="#9C27B0", fontcolor="white"]
        il4_s       [label="IL-4\n(stromal survival signal)",            fillcolor="#7B1FA2", fontcolor="white"]
        il21_s      [label="IL-21\n(stromal co-stimulation)",            fillcolor="#6A1B9A", fontcolor="white"]
        baff        [label="BAFF/BLyS\n(B-cell survival factor\nBAFF-R)", fillcolor="#4A148C", fontcolor="white"]
    }

    // ═══════════════════════════════════════════════════════════════════════
    // Cluster 6: Genetic Risk Factors
    // ═══════════════════════════════════════════════════════════════════════
    subgraph cluster_genetics {
        label="Genetic & Molecular Prognostics"
        style=filled; fillcolor="#FFFDE7"; color="#F57F17"; fontcolor="#F57F17"; fontsize=12
        ighv_mut    [label="IGHV Mutated\n(SHM ≥2%, favorable)",        fillcolor="#FFF9C4"]
        ighv_unmut  [label="IGHV Unmutated\n(SHM <2%, unfavorable)",    fillcolor="#FFF176"]
        del13q      [label="del(13q14)\nmiR-15a/16-1 loss\n(most common, favorable)", fillcolor="#FFEE58"]
        del11q      [label="del(11q22-23)\nATM loss (high risk)",        fillcolor="#FFE000"]
        del17p      [label="del(17p13)\nTP53 loss (very high risk\nPI pathway resistance)", fillcolor="#FFCA28"]
        tri12       [label="Trisomy 12\n(intermediate risk)",            fillcolor="#FFB300"]
        tp53_mut    [label="TP53 Mutation\n(loss of function\n+/- del17p)", fillcolor="#FFA000", fontcolor="white"]
        atm_mut     [label="ATM Mutation\n(DNA damage response\n+/- del11q)", fillcolor="#FF8F00", fontcolor="white"]
        notch1_mut  [label="NOTCH1 Mutation\n(transcriptional activation\npoor prognosis)", fillcolor="#FF6F00", fontcolor="white"]
        sf3b1_mut   [label="SF3B1 Mutation\n(splicing factor\npoor prognosis)", fillcolor="#E65100", fontcolor="white"]
        birc3_mut   [label="BIRC3 Mutation\n(cIAP2, NF-κB dysregulation)", fillcolor="#FFF9C4"]
        myc_amp     [label="MYC Amplification\n(Richter transformation risk)", fillcolor="#FFF176"]
        cll_ipi     [label="CLL-IPI Score\n(0–10 points)\nLow/Int/High/Very-High", fillcolor="#FFEE58"]
        miR_15a     [label="miR-15a/miR-16-1\n(BCL-2 suppressors, del13q)", fillcolor="#FFE000"]
    }

    // ═══════════════════════════════════════════════════════════════════════
    // Cluster 7: BTK Inhibitor PK/PD
    // ═══════════════════════════════════════════════════════════════════════
    subgraph cluster_btki {
        label="BTK Inhibitor PK/PD  (Ibrutinib · Acalabrutinib · Zanubrutinib)"
        style=filled; fillcolor="#E0F7FA"; color="#006064"; fontcolor="#006064"; fontsize=12
        ib_dose     [label="Ibrutinib 420 mg QD\n(CLL, covalent irreversible)",  fillcolor="#B2EBF2"]
        ac_dose     [label="Acalabrutinib 100 mg BID\n(more selective, covalent)", fillcolor="#80DEEA"]
        zn_dose     [label="Zanubrutinib 160 mg BID\n(selective, CNS penetrant)", fillcolor="#4DD0E1"]
        gut_btki    [label="GI Absorption\nF~25% (ibru), ~25% (acala)\nfood effect", fillcolor="#26C6DA"]
        c_btki      [label="Central Compartment\n1-comp PK (ibrutinib)\nCmax ~100-300 ng/mL", fillcolor="#00BCD4", fontcolor="white"]
        btk_occ     [label="BTK Cys481\nCovalent Occupancy\n(>95% required q24h)", fillcolor="#00ACC1", fontcolor="white"]
        btk_resyn   [label="BTK Resynthesis\nt½ protein ~2.9 days\n(limits trough coverage)", fillcolor="#0097A7", fontcolor="white"]
        lymphocytos [label="BTKi-Induced\nLymphocytosis\n(BM/LN → PB redistribution)", fillcolor="#B2EBF2"]
        off_targets [label="Off-Target Kinases\nITK, TEC, EGFR\n(ibrutinib selective issue)", fillcolor="#80DEEA"]
        af_risk     [label="Atrial Fibrillation\n~5%/year (ibrutinib)\n<2% (acala/zanu)", fillcolor="#4DD0E1"]
        bleed_risk  [label="Bleeding Risk\nGPIb/GPIIbIIIa inhibition\nplatelet aggregation↓", fillcolor="#26C6DA"]
        btk_resist  [label="BTK C481S Mutation\nacquired resistance\ncovalent → non-covalent Rx", fillcolor="#00BCD4", fontcolor="white"]
        plcg2_res   [label="PLCγ2 GOF Mutation\nbypasses BTK\nacquired resistance", fillcolor="#00ACC1", fontcolor="white"]
        cyp3a4      [label="CYP3A4 Metabolism\nDDI risk (azoles, etc.)\nibrutinib ~3h t½", fillcolor="#0097A7", fontcolor="white"]
    }

    // ═══════════════════════════════════════════════════════════════════════
    // Cluster 8: BCL-2 Inhibitor PK/PD (Venetoclax)
    // ═══════════════════════════════════════════════════════════════════════
    subgraph cluster_bcl2i {
        label="BCL-2 Inhibitor PK/PD  (Venetoclax)"
        style=filled; fillcolor="#F1F8E9"; color="#33691E"; fontcolor="#33691E"; fontsize=12
        ven_dose    [label="Venetoclax\nRamp-up Dosing\n20→50→100→200→400 mg QD", fillcolor="#DCEDC8"]
        ven_abs     [label="GI Absorption\nF~50% with fat meal\nCmax ~2 µg/mL@400mg", fillcolor="#C5E1A5"]
        c1_ven      [label="Central Compartment\n2-comp PK\nV1=250 L",              fillcolor="#AED581"]
        c2_ven      [label="Peripheral Compartment\nV2=500 L\nt½~26h",              fillcolor="#9CCC65", fontcolor="white"]
        bcl2_occ    [label="BCL-2 Occupancy\nBH3 binding groove\nKi~0.01 nM",       fillcolor="#8BC34A", fontcolor="white"]
        bh3_mim     [label="BH3-Mimetic Action\ndisplaces BIM/BAX/BAK\nfrom BCL-2", fillcolor="#7CB342", fontcolor="white"]
        tls         [label="Tumor Lysis Syndrome\nRisk: Low/Medium/High\n(by ALC, LN, Cr)", fillcolor="#689F38", fontcolor="white"]
        tls_ppx     [label="TLS Prophylaxis\nHydration, Allopurinol\nRasburicase (high risk)", fillcolor="#558B2F", fontcolor="white"]
        uric_acid   [label="Uric Acid ↑\n(TLS biomarker\n>8 mg/dL = TLS)",         fillcolor="#33691E", fontcolor="white"]
        ldh         [label="LDH / Creatinine ↑\n(TLS monitoring)",                 fillcolor="#DCEDC8"]
        mcl1_up     [label="MCL-1 Upregulation\n(compensatory resistance\nunder venetoclax)", fillcolor="#C5E1A5"]
        ven_resist  [label="BCL-2 G101V Mutation\nacquired venetoclax resistance\nreduced BH3 affinity", fillcolor="#AED581"]
        neutropenia [label="Neutropenia Gr3-4\n(dose-limiting toxicity\n~46% monotherapy)", fillcolor="#9CCC65", fontcolor="white"]
        ven_cyp3a4  [label="CYP3A4 Metabolism\nDDI risk similar ibrutinib\nt½~26h",  fillcolor="#8BC34A", fontcolor="white"]
    }

    // ═══════════════════════════════════════════════════════════════════════
    // Cluster 9: Anti-CD20 mAb PK/PD
    // ═══════════════════════════════════════════════════════════════════════
    subgraph cluster_cd20 {
        label="Anti-CD20 mAb PK/PD  (Rituximab · Obinutuzumab)"
        style=filled; fillcolor="#FBE9E7"; color="#BF360C"; fontcolor="#BF360C"; fontsize=12
        rtx_dose    [label="Rituximab\n375 mg/m² IV\n(Type I anti-CD20)",        fillcolor="#FFCCBC"]
        obi_dose    [label="Obinutuzumab\n1000 mg IV\n(Type II, glyco-eng.)",     fillcolor="#FFAB91"]
        cd20_ag     [label="CD20 Antigen\n(MS4A1, 4-TM domain\nnon-glycosylated)", fillcolor="#FF8A65"]
        c1_obi      [label="IgG Central Compartment\nV1~3.4 L\nCmax ~400 µg/mL", fillcolor="#FF7043", fontcolor="white"]
        tmdd        [label="TMDD\n(Target-Mediated Drug\nDisposition)",            fillcolor="#F4511E", fontcolor="white"]
        adcc        [label="ADCC\n(NK + FcγRIIIA)\nType II antibody superior",    fillcolor="#E64A19", fontcolor="white"]
        cdc_path    [label="CDC\n(C1q→C3→MAC)\nType I antibody superior",         fillcolor="#D84315", fontcolor="white"]
        adcp        [label="ADCP\n(Macrophage phagocytosis)\nFcγR-dependent",     fillcolor="#BF360C", fontcolor="white"]
        pcd         [label="Direct Cell Death\n(non-apoptotic homotypic\nagg. Type II mAb)", fillcolor="#FFCCBC"]
        c1q_bind    [label="C1q Binding\n(complement initiation\nType I > Type II)", fillcolor="#FFAB91"]
        c3_dep      [label="C3d Deposition\n(opsonization\nenhanced phagocytosis)", fillcolor="#FF8A65"]
        cd20_intern [label="CD20 Internalization\nType I > Type II\n(limits CDC)", fillcolor="#FF7043", fontcolor="white"]
        infusion_rx [label="Infusion Reactions\nCytokine Release\n1st infusion split-dose", fillcolor="#F4511E", fontcolor="white"]
        cd20_shed   [label="CD20 Shedding\n(resistance mechanism\nsoluble CD20)", fillcolor="#E64A19", fontcolor="white"]
    }

    // ═══════════════════════════════════════════════════════════════════════
    // Cluster 10: Clinical Endpoints & Response
    // ═══════════════════════════════════════════════════════════════════════
    subgraph cluster_outcomes {
        label="Clinical Endpoints & Response Criteria (IWCLL 2018)"
        style=filled; fillcolor="#ECEFF1"; color="#263238"; fontcolor="#263238"; fontsize=12
        iwcll_cr    [label="IWCLL CR\nALC<4k · nodes<1.5cm\nneutro>1.5k · plt>100k\nno B symptoms", fillcolor="#CFD8DC"]
        iwcll_pr    [label="IWCLL PR\n≥50% reduction in\nALC+adenopathy+spleen", fillcolor="#B0BEC5"]
        iwcll_sd    [label="Stable Disease\n<50% reduction\n<50% increase",         fillcolor="#90A4AE"]
        iwcll_pd    [label="Progressive Disease\n≥50% increase OR\nnew site OR Richter", fillcolor="#78909C", fontcolor="white"]
        mrd_neg     [label="MRD-Undetectable\n<10⁻⁴ CLL cells\n(flow or ASO-PCR)",  fillcolor="#607D8B", fontcolor="white"]
        pfs         [label="Progression-Free\nSurvival (PFS)",                       fillcolor="#546E7A", fontcolor="white"]
        os_end      [label="Overall Survival\n(OS)",                                  fillcolor="#455A64", fontcolor="white"]
        richter     [label="Richter Transformation\n→ DLBCL or HL\n~5% at 5yr",      fillcolor="#37474F", fontcolor="white"]
        ttnt        [label="Time to Next\nTreatment (TTNT)",                          fillcolor="#263238", fontcolor="white"]
        qol_end     [label="Quality of Life\nFACT-G · EQ-5D",                        fillcolor="#CFD8DC"]
        bm_biopsy   [label="BM Biopsy Response\n(core + aspirate\nMRD by flow)",      fillcolor="#B0BEC5"]
        ct_response [label="CT Scan Response\n(SPD, sum-of-products\nlymphadenopathy)", fillcolor="#90A4AE"]
    }

    // ═══════════════════════════════════════════════════════════════════════
    // EDGES — Normal B-cell development
    // ═══════════════════════════════════════════════════════════════════════
    hsc         -> clp         [color="#1565C0"]
    clp         -> pro_bcell   [color="#1565C0"]
    pro_bcell   -> pre_bcell   [color="#1565C0"]
    pre_bcell   -> imm_bcell   [color="#1565C0"]
    imm_bcell   -> naive_bcell [color="#1565C0"]
    naive_bcell -> gc          [color="#1565C0"]
    gc          -> mem_bcell   [color="#1565C0"]
    gc          -> plasma_cell [color="#1565C0"]
    gc          -> ighv_shm    [color="#1565C0"]
    ighv_shm    -> ighv_mut    [color="#1565C0", style=dashed]

    // ═══════════════════════════════════════════════════════════════════════
    // EDGES — CLL transformation & staging
    // ═══════════════════════════════════════════════════════════════════════
    naive_bcell -> cll_cell    [label="malignant\ntransformation", color="#B71C1C", style=dashed, penwidth=2]
    mem_bcell   -> cll_cell    [label="post-GC\norigin (IGHV-mut)", color="#B71C1C", style=dashed]
    cll_cell    -> alc         [color="#B71C1C"]
    alc         -> ldt         [color="#B71C1C"]
    cll_cell    -> cd38        [color="#B71C1C"]
    cll_cell    -> zap70       [color="#B71C1C"]
    cll_cell    -> cd49d       [color="#B71C1C"]
    cll_cell    -> smudge      [color="#B71C1C"]
    alc         -> binet_a     [color="#B71C1C"]
    binet_a     -> binet_b     [color="#B71C1C", style=dashed]
    binet_b     -> binet_c     [color="#B71C1C", style=dashed]
    alc         -> rai_0       [color="#B71C1C"]
    rai_0       -> rai_1       [color="#B71C1C", style=dashed]
    rai_1       -> rai_2       [color="#B71C1C", style=dashed]
    rai_2       -> rai_34      [color="#B71C1C", style=dashed]

    // ═══════════════════════════════════════════════════════════════════════
    // EDGES — BCR signaling
    // ═══════════════════════════════════════════════════════════════════════
    ag          -> bcr         [color="#1B5E20"]
    bcr         -> lyn         [color="#1B5E20"]
    lyn         -> syk         [color="#1B5E20"]
    syk         -> blnk        [color="#1B5E20"]
    blnk        -> btk         [color="#1B5E20"]
    btk         -> plcg2       [color="#1B5E20"]
    plcg2       -> ip3         [color="#1B5E20"]
    plcg2       -> dag         [color="#1B5E20"]
    ip3         -> ca_flux     [color="#1B5E20"]
    ca_flux     -> nfat        [color="#1B5E20"]
    dag         -> pkc_b       [color="#1B5E20"]
    pkc_b       -> ikk         [color="#1B5E20"]
    ikk         -> nfkb        [color="#1B5E20"]
    syk         -> pi3k_d      [color="#1B5E20"]
    btk         -> pi3k_d      [color="#1B5E20"]
    pi3k_d      -> pip3        [color="#1B5E20"]
    pip3        -> akt         [color="#1B5E20"]
    akt         -> mtor        [color="#1B5E20"]
    pten        -> pip3        [label="-|", color="#D32F2F", arrowhead=tee]
    lyn         -> ras_raf     [color="#1B5E20"]
    ras_raf     -> mek_erk     [color="#1B5E20"]
    pkc_b       -> nfkb        [color="#1B5E20"]

    // ═══════════════════════════════════════════════════════════════════════
    // EDGES — NF-κB → survival genes
    // ═══════════════════════════════════════════════════════════════════════
    nfkb        -> bcl2        [label="transcription", color="#E65100"]
    nfkb        -> mcl1        [label="transcription", color="#E65100"]
    nfkb        -> a1_bfl1     [label="transcription", color="#E65100"]
    mek_erk     -> mcl1        [color="#E65100"]
    akt         -> bad         [label="pSer136\ninactivates", color="#D32F2F"]
    mtor        -> cll_cell    [label="protein synth.\nproliferation", color="#1B5E20"]
    nfat        -> cll_cell    [label="survival genes", color="#1B5E20"]

    // ═══════════════════════════════════════════════════════════════════════
    // EDGES — Apoptosis pathway
    // ═══════════════════════════════════════════════════════════════════════
    bcl2        -> bax         [label="-|", color="#D32F2F", arrowhead=tee]
    bcl2        -> bak         [label="-|", color="#D32F2F", arrowhead=tee]
    bcl_xl      -> bax         [label="-|", color="#D32F2F", arrowhead=tee]
    bcl_xl      -> bak         [label="-|", color="#D32F2F", arrowhead=tee]
    mcl1        -> bak         [label="-|", color="#D32F2F", arrowhead=tee]
    bim         -> bcl2        [label="BH3 bind", color="#E65100"]
    bim         -> mcl1        [label="BH3 bind", color="#E65100"]
    bim         -> bcl_xl      [label="BH3 bind", color="#E65100"]
    noxa        -> mcl1        [label="specific BH3", color="#E65100"]
    puma        -> bcl2        [label="BH3 bind", color="#E65100"]
    bad         -> bcl2        [label="BH3 bind\n(dephospho)", color="#E65100"]
    bad         -> bcl_xl      [label="BH3 bind", color="#E65100"]
    hrk         -> bcl_xl      [label="BH3 bind", color="#E65100"]
    bid         -> bcl2        [label="tBID activates\nBAX/BAK", color="#E65100"]
    p53         -> puma        [color="#FF6F00"]
    p53         -> noxa        [color="#FF6F00"]
    p53         -> bax         [color="#FF6F00"]
    bax         -> momp        [color="#E65100"]
    bak         -> momp        [color="#E65100"]
    momp        -> cyto_c      [color="#E65100"]
    cyto_c      -> apaf1       [color="#E65100"]
    apaf1       -> casp9       [color="#E65100"]
    casp9       -> casp3       [color="#E65100"]
    casp3       -> cll_cell    [label="apoptosis →\ncell death", color="#D32F2F", penwidth=2]

    // ═══════════════════════════════════════════════════════════════════════
    // EDGES — Microenvironment
    // ═══════════════════════════════════════════════════════════════════════
    bone_marrow -> cxcl12      [color="#4A148C"]
    lymph_node  -> cxcl13      [color="#4A148C"]
    cxcl12      -> cxcr4_r     [label="CXCR4\nactivation", color="#4A148C"]
    cxcl13      -> cxcr5_r     [label="CXCR5\nactivation", color="#4A148C"]
    cxcr4_r     -> cll_cell    [label="BM retention", color="#4A148C"]
    cxcr5_r     -> cll_cell    [label="LN homing", color="#4A148C"]
    cd49d       -> cxcr4_r     [color="#4A148C"]
    th_cell     -> cd40        [label="CD40L", color="#4A148C"]
    cd40        -> nfkb        [color="#4A148C"]
    il4_s       -> cll_cell    [label="survival", color="#4A148C"]
    il21_s      -> cll_cell    [label="proliferation", color="#4A148C"]
    baff        -> cll_cell    [label="BCR-independent\nsurvival", color="#4A148C"]
    fdc         -> bcr         [label="antigen\npresentation", color="#4A148C"]
    cll_cell    -> periph_blood [label="egress\n(BTKi effect)", color="#4A148C", style=dashed]

    // ═══════════════════════════════════════════════════════════════════════
    // EDGES — Genetics & risk
    // ═══════════════════════════════════════════════════════════════════════
    ighv_mut    -> cll_ipi     [color="#F57F17"]
    ighv_unmut  -> cll_ipi     [color="#F57F17"]
    del13q      -> cll_ipi     [color="#F57F17"]
    del11q      -> cll_ipi     [color="#F57F17"]
    del17p      -> cll_ipi     [color="#F57F17"]
    tri12       -> cll_ipi     [color="#F57F17"]
    tp53_mut    -> p53         [label="-| loss", color="#D32F2F", arrowhead=tee]
    del17p      -> tp53_mut    [color="#F57F17"]
    atm_mut     -> p53         [label="ATM upstream\nDNA-PK", color="#F57F17"]
    del11q      -> atm_mut     [color="#F57F17"]
    notch1_mut  -> nfkb        [color="#F57F17"]
    sf3b1_mut   -> bcl2        [label="aberrant splicing", color="#F57F17"]
    birc3_mut   -> nfkb        [color="#F57F17"]
    del13q      -> miR_15a     [label="deletion\nloss of repression", color="#F57F17"]
    miR_15a     -> bcl2        [label="-| suppression", color="#D32F2F", arrowhead=tee]
    myc_amp     -> richter     [color="#F57F17"]
    cd38        -> cll_ipi     [color="#F57F17"]
    zap70       -> cll_ipi     [color="#F57F17"]
    ighv_unmut  -> bcr         [label="stronger BCR\nsignaling", color="#F57F17", penwidth=2]

    // ═══════════════════════════════════════════════════════════════════════
    // EDGES — BTK inhibitor PK/PD
    // ═══════════════════════════════════════════════════════════════════════
    ib_dose     -> gut_btki    [color="#006064"]
    ac_dose     -> gut_btki    [color="#006064"]
    zn_dose     -> gut_btki    [color="#006064"]
    gut_btki    -> c_btki      [color="#006064"]
    c_btki      -> cyp3a4      [color="#006064"]
    c_btki      -> btk_occ     [label="Cys481 covalent\n(irreversible)", color="#006064", penwidth=2]
    btk_occ     -> btk         [label="-| >95% occ.\nrequired QD", color="#D32F2F", arrowhead=tee, penwidth=2]
    btk_resyn   -> btk         [label="de novo\nt½~2.9d", color="#006064"]
    btk_occ     -> lymphocytos [label="BM/LN → PB\negress", color="#006064"]
    lymphocytos -> alc         [label="transient\nincrease", color="#006064"]
    c_btki      -> off_targets [color="#006064"]
    off_targets -> af_risk     [color="#006064"]
    off_targets -> bleed_risk  [color="#006064"]
    btk_resist  -> btk         [label="C481S bypasses\ncovalent binding", color="#D32F2F", style=dashed]
    plcg2_res   -> plcg2       [label="GOF bypasses\nBTK block", color="#D32F2F", style=dashed]
    btk_occ     -> nfkb        [label="-| indirect\nNF-κB↓", color="#006064", style=dashed]
    btk_occ     -> pi3k_d      [label="-| indirect\nPI3K↓", color="#006064", style=dashed]

    // ═══════════════════════════════════════════════════════════════════════
    // EDGES — Venetoclax PK/PD
    // ═══════════════════════════════════════════════════════════════════════
    ven_dose    -> ven_abs     [color="#33691E"]
    ven_abs     -> c1_ven      [color="#33691E"]
    c1_ven      -> c2_ven      [label="distribution", color="#33691E"]
    c1_ven      -> ven_cyp3a4  [color="#33691E"]
    c1_ven      -> bcl2_occ    [label="BH3-mimetic\nKi~0.01 nM", color="#33691E", penwidth=2]
    bcl2_occ    -> bh3_mim     [color="#33691E"]
    bh3_mim     -> bcl2        [label="-| BH3 groove\nblockade", color="#D32F2F", arrowhead=tee, penwidth=2]
    bh3_mim     -> bim         [label="frees BIM\n→ BAX/BAK", color="#33691E"]
    ven_dose    -> tls         [label="ramp-up limits\nTLS risk", color="#33691E"]
    bcl2_occ    -> tls         [label="rapid kill\n→ TLS", color="#33691E"]
    tls         -> tls_ppx     [color="#33691E"]
    tls         -> uric_acid   [color="#33691E"]
    tls         -> ldh         [color="#33691E"]
    bcl2_occ    -> mcl1_up     [label="MCL-1 compensatory\nupregulation", color="#D32F2F"]
    mcl1_up     -> mcl1        [label="↑ MCL-1\nresistance", color="#D32F2F"]
    ven_resist  -> bcl2        [label="G101V reduces\nbinding affinity", color="#D32F2F", style=dashed]
    bcl2_occ    -> neutropenia [color="#33691E"]

    // ═══════════════════════════════════════════════════════════════════════
    // EDGES — Anti-CD20 mAb
    // ═══════════════════════════════════════════════════════════════════════
    rtx_dose    -> c1_obi      [color="#BF360C"]
    obi_dose    -> c1_obi      [color="#BF360C"]
    c1_obi      -> tmdd        [color="#BF360C"]
    tmdd        -> cd20_ag     [label="TMDD binding", color="#BF360C"]
    cd20_ag     -> adcc        [color="#BF360C"]
    cd20_ag     -> cdc_path    [color="#BF360C"]
    cd20_ag     -> adcp        [color="#BF360C"]
    adcc        -> nk_cell     [label="NK activation\nFcγRIIIA", color="#BF360C"]
    cdc_path    -> c1q_bind    [color="#BF360C"]
    c1q_bind    -> c3_dep      [color="#BF360C"]
    obi_dose    -> pcd         [label="Type II: direct\ncell death", color="#BF360C"]
    obi_dose    -> cd20_intern [label="Type II less\ninternalized", color="#BF360C", style=dashed]
    rtx_dose    -> cd20_intern [label="Type I: more\ninternalized", color="#BF360C"]
    c1_obi      -> infusion_rx [color="#BF360C"]
    adcc        -> cll_cell    [label="ADCC kill", color="#D32F2F", penwidth=2]
    cdc_path    -> cll_cell    [label="CDC kill", color="#D32F2F", penwidth=2]
    pcd         -> cll_cell    [label="direct kill", color="#D32F2F"]
    cd20_shed   -> tmdd        [label="antigen sink\n(resistance)", color="#D32F2F", style=dashed]

    // ═══════════════════════════════════════════════════════════════════════
    // EDGES — Clinical outcomes
    // ═══════════════════════════════════════════════════════════════════════
    alc         -> iwcll_cr    [color="#263238"]
    alc         -> iwcll_pr    [color="#263238"]
    alc         -> iwcll_pd    [color="#263238"]
    bm_biopsy   -> iwcll_cr    [color="#263238"]
    ct_response -> iwcll_cr    [color="#263238"]
    ct_response -> iwcll_pr    [color="#263238"]
    iwcll_cr    -> mrd_neg     [color="#263238"]
    mrd_neg     -> pfs         [label="uMRD predicts\nprolonged PFS", color="#263238", penwidth=2]
    pfs         -> os_end      [color="#263238"]
    iwcll_pd    -> richter     [color="#263238", style=dashed]
    iwcll_cr    -> qol_end     [color="#263238"]
    pfs         -> ttnt        [color="#263238"]
    del17p      -> iwcll_pd    [label="primary resistance\nchemoimmunotherapy", color="#D32F2F", style=dashed]

    // ═══════════════════════════════════════════════════════════════════════
    // Cross-cluster key connections
    // ═══════════════════════════════════════════════════════════════════════
    cll_cell    -> bcr         [label="autonomous BCR\nself-stimulation", color="#1B5E20", style=dotted]
    bcl2        -> cll_cell    [label="survival\nanti-apoptosis", color="#E65100", style=dotted]
    mek_erk     -> cll_cell    [label="proliferation", color="#1B5E20"]
    nk_cell     -> cll_cell    [label="ADCC kill\n(FcγRIIIA)", color="#7B1FA2"]
    tam         -> cll_cell    [label="pro-survival\ncytokines", color="#4A148C"]
    treg        -> nk_cell     [label="-| suppress\nADCC", color="#D32F2F", arrowhead=tee]
}
