digraph ProstateCancer_QSP {
  graph [
    label="Prostate Cancer QSP Mechanistic Map\nAndrogen Signaling · HPG Axis · Tumor Biology · Bone Metastasis · Drug PK/PD"
    fontname="Helvetica" fontsize=22 fontcolor="#1a1a2e"
    bgcolor="#f8f9fa"
    splines=curved
    overlap=prism
    nodesep=0.3
    ranksep=0.6
    compound=true
  ]

  node [fontname="Helvetica" fontsize=10 style="filled,rounded" shape=box margin="0.1,0.05"]
  edge [fontname="Helvetica" fontsize=8 arrowsize=0.7]

  /* =====================================================
     CLUSTER 1: HYPOTHALAMIC-PITUITARY-GONADAL (HPG) AXIS
     ===================================================== */
  subgraph cluster_hpg {
    label="HPG Axis (Hypothalamic-Pituitary-Gonadal)"
    fontsize=14 fontcolor="#1a1a2e"
    style="filled,rounded" bgcolor="#e8f4f8" color="#2196F3" penwidth=2

    KiSS1 [label="KiSS1\n(Kisspeptin)" fillcolor="#bbdefb" color="#1565C0"]
    GPR54 [label="GPR54\n(Kisspeptin Receptor)" fillcolor="#bbdefb" color="#1565C0"]
    GnRH [label="GnRH\n(Gonadotropin-Releasing\nHormone)" fillcolor="#90caf9" color="#1565C0" fontsize=9]
    GnRHR [label="GnRH-R\n(GnRH Receptor)" fillcolor="#90caf9" color="#1565C0"]
    Gq_protein [label="Gq Protein\nSignaling" fillcolor="#bbdefb" color="#1565C0"]
    LH [label="LH\n(Luteinizing Hormone)" fillcolor="#64b5f6" color="#1565C0"]
    FSH [label="FSH\n(Follicle-Stimulating\nHormone)" fillcolor="#64b5f6" color="#1565C0" fontsize=9]
    LHR [label="LH Receptor\n(Leydig Cells)" fillcolor="#42a5f5" color="#1565C0"]
    cAMP_leydig [label="cAMP\n(Leydig Cells)" fillcolor="#bbdefb" color="#1565C0"]
    Negative_FB_T [label="Negative Feedback\n(Testosterone → HP Axis)" fillcolor="#ef9a9a" color="#c62828" fontsize=9]
    Negative_FB_E2 [label="Negative Feedback\n(Estradiol → HP Axis)" fillcolor="#ef9a9a" color="#c62828" fontsize=9]
  }

  /* =====================================================
     CLUSTER 2: ANDROGEN BIOSYNTHESIS
     ===================================================== */
  subgraph cluster_androgen_biosynthesis {
    label="Androgen Biosynthesis (Testicular + Adrenal)"
    fontsize=14 fontcolor="#1a1a2e"
    style="filled,rounded" bgcolor="#fff8e1" color="#FF9800" penwidth=2

    Cholesterol [label="Cholesterol" fillcolor="#fff9c4" color="#F57F17"]
    CYP11A1 [label="CYP11A1\n(P450scc)" fillcolor="#ffe082" color="#F57F17"]
    Pregnenolone [label="Pregnenolone" fillcolor="#fff9c4" color="#F57F17"]
    HSD3B2 [label="HSD3B2\n(3β-HSD)" fillcolor="#ffe082" color="#F57F17"]
    Progesterone [label="Progesterone" fillcolor="#fff9c4" color="#F57F17"]
    CYP17A1_OH [label="CYP17A1\n(17α-hydroxylase)" fillcolor="#ffca28" color="#F57F17"]
    OH_Pregnenolone [label="17OH-Pregnenolone" fillcolor="#fff9c4" color="#F57F17"]
    OH_Progesterone [label="17OH-Progesterone" fillcolor="#fff9c4" color="#F57F17"]
    CYP17A1_lyase [label="CYP17A1\n(C17,20-lyase)" fillcolor="#ffca28" color="#F57F17"]
    DHEA [label="DHEA\n(Dehydroepiandrosterone)" fillcolor="#ffe082" color="#F57F17"]
    Androstenedione [label="Androstenedione\n(AD)" fillcolor="#ffe082" color="#F57F17"]
    HSD17B3 [label="HSD17B3\n(17β-HSD3)" fillcolor="#ffd54f" color="#F57F17"]
    Testosterone [label="Testosterone\n(T)" fillcolor="#ffc107" color="#E65100" fontsize=11 fontcolor="black"]
    SRD5A1 [label="SRD5A1\n(5α-Reductase 1)" fillcolor="#ffb300" color="#E65100"]
    SRD5A2 [label="SRD5A2\n(5α-Reductase 2)" fillcolor="#ffb300" color="#E65100"]
    DHT [label="DHT\n(Dihydrotestosterone)" fillcolor="#ff8f00" color="#E65100" fontsize=11 fontcolor="white"]
    DHEAS [label="DHEAS\n(Adrenal)" fillcolor="#ffe0b2" color="#F57F17"]
    Androstenediol [label="Androstenediol" fillcolor="#fff9c4" color="#F57F17"]
    ARKO [label="Aromatase\n(CYP19A1)" fillcolor="#ffe082" color="#F57F17"]
    Estradiol [label="Estradiol\n(E2)" fillcolor="#f8bbd0" color="#880e4f"]
    SHBG [label="SHBG\n(Sex Hormone\nBinding Globulin)" fillcolor="#ffe0b2" color="#F57F17" fontsize=9]
    Free_T [label="Free Testosterone\n(Bioavailable)" fillcolor="#ffc107" color="#E65100"]
  }

  /* =====================================================
     CLUSTER 3: ANDROGEN RECEPTOR (AR) SIGNALING
     ===================================================== */
  subgraph cluster_AR_signaling {
    label="Androgen Receptor (AR) Signaling Cascade"
    fontsize=14 fontcolor="#1a1a2e"
    style="filled,rounded" bgcolor="#f3e5f5" color="#9C27B0" penwidth=2

    AR_gene [label="AR Gene\n(Xq11-12)" fillcolor="#e1bee7" color="#7B1FA2"]
    AR_mRNA [label="AR mRNA" fillcolor="#ce93d8" color="#7B1FA2"]
    AR_protein [label="AR Protein\n(Inactive)" fillcolor="#ba68c8" color="#7B1FA2"]
    HSP90 [label="HSP90\n(Chaperone)" fillcolor="#e1bee7" color="#7B1FA2"]
    FKBP51 [label="FKBP51\n(Co-chaperone)" fillcolor="#e1bee7" color="#7B1FA2"]
    AR_HSP_complex [label="AR-HSP90\nComplex (Inactive)" fillcolor="#ce93d8" color="#7B1FA2"]
    AR_DHT_complex [label="AR-DHT\nComplex (Active)" fillcolor="#ab47bc" color="#7B1FA2" fontcolor="white"]
    AR_nuclear [label="AR Nuclear\nTranslocation" fillcolor="#9c27b0" color="#6a1b9a" fontcolor="white"]
    AR_dimerization [label="AR Dimerization\n(Head-to-tail)" fillcolor="#ba68c8" color="#7B1FA2"]
    ARE [label="ARE\n(Androgen Response Element)" fillcolor="#e1bee7" color="#7B1FA2"]
    Coactivators [label="Coactivators\n(SRC-1, p300, NCOA1)" fillcolor="#e1bee7" color="#7B1FA2" fontsize=9]
    AR_transcription [label="AR-Driven\nTranscription" fillcolor="#ab47bc" color="#7B1FA2" fontcolor="white"]
    PSA [label="PSA / KLK3\n(Serum Biomarker)" fillcolor="#9c27b0" color="#6a1b9a" fontcolor="white" fontsize=12]
    TMPRSS2 [label="TMPRSS2\n(Androgen-regulated)" fillcolor="#ce93d8" color="#7B1FA2"]
    NKX3_1 [label="NKX3-1\n(Homeobox)" fillcolor="#e1bee7" color="#7B1FA2"]
    FOXA1 [label="FOXA1\n(Pioneer Factor)" fillcolor="#e1bee7" color="#7B1FA2"]
    ARv7 [label="AR-V7\n(Splice Variant)" fillcolor="#ef9a9a" color="#c62828"]
    AR_amplification [label="AR Gene\nAmplification (mCRPC)" fillcolor="#ef9a9a" color="#c62828" fontsize=9]
    AR_mutation_F876L [label="AR Mutation\n(F876L, T878A)" fillcolor="#ef9a9a" color="#c62828" fontsize=9]
    TMPRSS2_ERG [label="TMPRSS2-ERG\nFusion (50%)" fillcolor="#ef9a9a" color="#c62828" fontsize=9]
  }

  /* =====================================================
     CLUSTER 4: TUMOR CELL BIOLOGY - PROLIFERATION & APOPTOSIS
     ===================================================== */
  subgraph cluster_tumor_biology {
    label="Tumor Cell Biology · Cell Cycle · Apoptosis"
    fontsize=14 fontcolor="#1a1a2e"
    style="filled,rounded" bgcolor="#e8f5e9" color="#4CAF50" penwidth=2

    Stem_cells [label="Prostate Stem\nCells (CSC)" fillcolor="#c8e6c9" color="#1B5E20"]
    Luminal_cells [label="Luminal Epithelial\nCells" fillcolor="#a5d6a7" color="#2E7D32"]
    Basal_cells [label="Basal Epithelial\nCells" fillcolor="#c8e6c9" color="#1B5E20"]
    Tumor_initiated [label="Tumor-Initiating\nCells" fillcolor="#81c784" color="#2E7D32"]
    Proliferating_cells [label="Proliferating\nTumor Cells" fillcolor="#66bb6a" color="#1B5E20"]
    Quiescent_cells [label="Quiescent\nTumor Cells" fillcolor="#a5d6a7" color="#2E7D32"]
    Necrotic_cells [label="Necrotic /\nApoptotic Cells" fillcolor="#ef9a9a" color="#c62828"]
    CDK4_6 [label="CDK4/6\nKinase" fillcolor="#c8e6c9" color="#2E7D32"]
    CyclinD1 [label="Cyclin D1\n(CCND1)" fillcolor="#c8e6c9" color="#2E7D32"]
    pRb [label="pRb\n(Retinoblastoma)" fillcolor="#81c784" color="#2E7D32"]
    E2F [label="E2F\nTranscription Factor" fillcolor="#81c784" color="#2E7D32"]
    CDK2 [label="CDK2 / Cyclin E" fillcolor="#c8e6c9" color="#2E7D32"]
    p21 [label="p21 (CDKN1A)\nCDK Inhibitor" fillcolor="#ef9a9a" color="#c62828"]
    p27 [label="p27 (CDKN1B)\nCDK Inhibitor" fillcolor="#ef9a9a" color="#c62828"]
    cMYC [label="c-MYC\n(Proto-oncogene)" fillcolor="#66bb6a" color="#1B5E20"]
    BCL2 [label="BCL-2\n(Anti-apoptotic)" fillcolor="#a5d6a7" color="#2E7D32"]
    BCL_XL [label="BCL-XL\n(Anti-apoptotic)" fillcolor="#a5d6a7" color="#2E7D32"]
    MCL1 [label="MCL-1\n(Anti-apoptotic)" fillcolor="#a5d6a7" color="#2E7D32"]
    BAX [label="BAX\n(Pro-apoptotic)" fillcolor="#ef9a9a" color="#c62828"]
    BAD [label="BAD\n(Pro-apoptotic)" fillcolor="#ef9a9a" color="#c62828"]
    Cytochrome_c [label="Cytochrome c\nRelease" fillcolor="#ef9a9a" color="#c62828"]
    Caspase9 [label="Caspase-9\n(Intrinsic)" fillcolor="#ef9a9a" color="#c62828"]
    Caspase3 [label="Caspase-3\n(Executioner)" fillcolor="#ef9a9a" color="#c62828"]
    p53 [label="p53\n(Tumor Suppressor)" fillcolor="#66bb6a" color="#1B5E20"]
    MDM2 [label="MDM2\n(p53 Ubiquitin Ligase)" fillcolor="#ef9a9a" color="#c62828"]
    ATM_ATR [label="ATM / ATR\nDNA Damage Response" fillcolor="#c8e6c9" color="#2E7D32"]
    CHK1_2 [label="CHK1 / CHK2\n(Checkpoint Kinase)" fillcolor="#c8e6c9" color="#2E7D32"]
    PARP [label="PARP-1/2\n(DNA Repair)" fillcolor="#c8e6c9" color="#2E7D32"]
    BRCA1_2 [label="BRCA1/2\n(DNA Repair, ~20%)" fillcolor="#ef9a9a" color="#c62828"]
    Telomere_short [label="Telomere\nShortening" fillcolor="#ef9a9a" color="#c62828"]
    Senescence [label="Cellular\nSenescence" fillcolor="#ef9a9a" color="#c62828"]
  }

  /* =====================================================
     CLUSTER 5: PI3K/AKT/mTOR PATHWAY
     ===================================================== */
  subgraph cluster_PI3K_mTOR {
    label="PI3K / AKT / mTOR Pathway"
    fontsize=14 fontcolor="#1a1a2e"
    style="filled,rounded" bgcolor="#e3f2fd" color="#2196F3" penwidth=2

    PTEN [label="PTEN\n(Tumor Suppressor,\n~70% loss in PCa)" fillcolor="#ef9a9a" color="#c62828" fontsize=9]
    PIP2 [label="PIP2\n(PI(4,5)P2)" fillcolor="#bbdefb" color="#1565C0"]
    PIP3 [label="PIP3\n(PI(3,4,5)P3)" fillcolor="#90caf9" color="#1565C0"]
    PI3K_cat [label="PI3K\n(p110 catalytic)" fillcolor="#42a5f5" color="#1565C0"]
    PI3K_reg [label="PI3K\n(p85 regulatory)" fillcolor="#bbdefb" color="#1565C0"]
    PDK1 [label="PDK1\n(Phosphoinositide-\nDependent Kinase 1)" fillcolor="#64b5f6" color="#1565C0" fontsize=9]
    AKT1 [label="AKT1\n(PKB, active)" fillcolor="#1976d2" color="#0d47a1" fontcolor="white"]
    AKT2 [label="AKT2\n(PKB)" fillcolor="#42a5f5" color="#1565C0"]
    TSC1_2 [label="TSC1/TSC2\nComplex" fillcolor="#bbdefb" color="#1565C0"]
    Rheb [label="Rheb GTPase" fillcolor="#90caf9" color="#1565C0"]
    mTORC1 [label="mTORC1\n(mTOR + RAPTOR)" fillcolor="#1565c0" color="#0d47a1" fontcolor="white"]
    mTORC2 [label="mTORC2\n(mTOR + RICTOR)" fillcolor="#1976d2" color="#0d47a1" fontcolor="white"]
    S6K1 [label="S6K1\n(Ribosomal Protein\nS6 Kinase)" fillcolor="#64b5f6" color="#1565C0" fontsize=9]
    S6_ribo [label="S6 Ribosomal\nProtein (pS6)" fillcolor="#bbdefb" color="#1565C0"]
    BP4E1 [label="4E-BP1\n(Translation\nRegulator)" fillcolor="#bbdefb" color="#1565C0"]
    eIF4E [label="eIF4E\n(Cap-binding)" fillcolor="#90caf9" color="#1565C0"]
    GSK3B [label="GSK3β\n(Glycogen Synthase\nKinase)" fillcolor="#64b5f6" color="#1565C0" fontsize=9]
    FOXO3a [label="FOXO3a\n(Transcription Factor)" fillcolor="#42a5f5" color="#1565C0"]
    HIF1a [label="HIF-1α\n(Hypoxia-Inducible\nFactor)" fillcolor="#ef9a9a" color="#c62828" fontsize=9]
    VEGF [label="VEGF\n(Angiogenesis)" fillcolor="#ef9a9a" color="#c62828"]
    IRS1 [label="IRS-1\n(Insulin Receptor\nSubstrate)" fillcolor="#bbdefb" color="#1565C0" fontsize=9]
    RTK_insulin [label="Insulin / IGF-1R\nSignaling" fillcolor="#90caf9" color="#1565C0"]
  }

  /* =====================================================
