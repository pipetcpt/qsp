  /* =====================================================
     CLUSTER 9: DRUG PK/PD - ALL TREATMENT MODALITIES
     ===================================================== */
  subgraph cluster_drug_PKPD {
    label="Drug PK/PD: Hormonal · ARPI · Chemotherapy · Targeted · Immunotherapy"
    fontsize=14 fontcolor="#1a1a2e"
    style="filled,rounded" bgcolor="#ede7f6" color="#673AB7" penwidth=2

    /* GnRH Agonists */
    Leuprolide [label="Leuprolide\n(GnRH Agonist)\n7.5mg IM monthly" fillcolor="#b39ddb" color="#4527A0"]
    Goserelin [label="Goserelin\n(GnRH Agonist)\n3.6mg SC monthly" fillcolor="#b39ddb" color="#4527A0"]
    Triptorelin [label="Triptorelin\n(GnRH Agonist)\n3.75mg IM monthly" fillcolor="#b39ddb" color="#4527A0"]

    /* GnRH Antagonists */
    Degarelix [label="Degarelix\n(GnRH Antagonist)\n240mg SC loading" fillcolor="#9575cd" color="#4527A0"]
    Relugolix [label="Relugolix\n(Oral GnRH Antagonist)\n120mg QD" fillcolor="#7e57c2" color="#4527A0"]

    /* AR Pathway Inhibitors (ARPI) */
    Enzalutamide [label="Enzalutamide\n(ARPI, 2nd gen)\n160mg QD" fillcolor="#7b1fa2" color="#4a148c" fontcolor="white"]
    Apalutamide [label="Apalutamide\n(ARPI, 2nd gen)\n240mg QD" fillcolor="#8e24aa" color="#4a148c" fontcolor="white"]
    Darolutamide [label="Darolutamide\n(ARPI, 2nd gen)\n600mg BID" fillcolor="#9c27b0" color="#4a148c" fontcolor="white"]
    Bicalutamide [label="Bicalutamide\n(Anti-androgen 1st)\n50mg QD" fillcolor="#ce93d8" color="#7B1FA2"]
    Flutamide [label="Flutamide\n(Anti-androgen 1st)\n250mg TID" fillcolor="#e1bee7" color="#7B1FA2"]

    /* CYP17A1 Inhibitors */
    Abiraterone [label="Abiraterone Acetate\n(CYP17A1 Inhibitor)\n1000mg QD" fillcolor="#6a1b9a" color="#4a148c" fontcolor="white"]

