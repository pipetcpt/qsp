     ===================================================== */
  subgraph cluster_MAPK {
    label="RAS / MAPK / ERK Signaling Pathway"
    fontsize=14 fontcolor="#1a1a2e"
    style="filled,rounded" bgcolor="#fce4ec" color="#E91E63" penwidth=2

    EGFR [label="EGFR\n(ErbB1, ~30%)" fillcolor="#f8bbd0" color="#880E4F"]
