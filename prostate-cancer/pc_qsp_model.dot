    MEK1_2 [label="MEK1/2\n(MAP2K)" fillcolor="#e91e63" color="#880E4F" fontcolor="white"]
    ERK1_2 [label="ERK1/2\n(MAPK)" fillcolor="#c2185b" color="#880E4F" fontcolor="white"]
    RSK [label="RSK\n(p90 RSK)" fillcolor="#f48fb1" color="#880E4F"]
    ETS_factors [label="ETS Factors\n(ETV1, ERG)" fillcolor="#f8bbd0" color="#880E4F"]
    RAS_GAP [label="RAS-GAP\n(NF1, ~10%)" fillcolor="#ef9a9a" color="#c62828"]
    EGF_ligand [label="EGF / HB-EGF\nLigands" fillcolor="#fce4ec" color="#E91E63"]
    FGF2 [label="FGF2\n(Basic FGF)" fillcolor="#f8bbd0" color="#880E4F"]
    Amphiregulin [label="Amphiregulin\n(AREG)" fillcolor="#fce4ec" color="#E91E63"]
  }

  /* =====================================================
     CLUSTER 7: BONE METASTASIS MICROENVIRONMENT
     ===================================================== */
  subgraph cluster_bone_mets {
    label="Bone Metastasis Microenvironment (Vicious Cycle)"
    fontsize=14 fontcolor="#1a1a2e"
    style="filled,rounded" bgcolor="#fff3e0" color="#FF5722" penwidth=2

    Osteoblast [label="Osteoblasts\n(Bone Formation)" fillcolor="#ffe0b2" color="#BF360C"]
    Osteoclast [label="Osteoclasts\n(Bone Resorption)" fillcolor="#ffccbc" color="#BF360C"]
