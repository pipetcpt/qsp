    DKK1 [label="DKK1\n(Wnt Inhibitor)" fillcolor="#ef9a9a" color="#c62828"]
    Wnt_bone [label="Wnt Ligands\n(Bone Formation)" fillcolor="#a5d6a7" color="#2E7D32"]
    PTHrP [label="PTHrP\n(Parathyroid Hormone-\nRelated Protein)" fillcolor="#ff8a65" color="#BF360C" fontsize=9]
    Endothelin1 [label="Endothelin-1\n(ET-1, Sclerotic)" fillcolor="#ffccbc" color="#BF360C"]
    TGFb_bone [label="TGF-β\n(From Bone Matrix)" fillcolor="#f8bbd0" color="#880E4F"]
    SMAD2_3 [label="SMAD2/3\n(TGF-β Signal)" fillcolor="#f8bbd0" color="#880E4F"]
    CXCL12 [label="CXCL12\n(SDF-1, Bone Homing)" fillcolor="#ffe0b2" color="#BF360C"]
    CXCR4 [label="CXCR4\n(Tumor Cell Receptor)" fillcolor="#ffccbc" color="#BF360C"]
    BSP [label="BSP\n(Bone Sialoprotein)" fillcolor="#ffe0b2" color="#BF360C"]
    OPN [label="Osteopontin\n(OPN)" fillcolor="#ffe0b2" color="#BF360C"]
    Bone_matrix [label="Bone Matrix\n(Hydroxyapatite +\nCollagen Type I)" fillcolor="#ff8a65" color="#BF360C" fontsize=9]
    Lytic_lesion [label="Osteolytic\nLesions" fillcolor="#ef9a9a" color="#c62828"]
    Sclerotic_lesion [label="Osteosclerotic\nLesions (80%)" fillcolor="#a5d6a7" color="#2E7D32"]
    IGF1_bone [label="IGF-1\n(From Bone Matrix)" fillcolor="#ffe0b2" color="#BF360C"]
    ALP_bone [label="ALP\n(Alkaline Phosphatase)" fillcolor="#ffe0b2" color="#BF360C"]
    CTx [label="CTx\n(Bone Resorption\nMarker)" fillcolor="#ffccbc" color="#BF360C" fontsize=9]
