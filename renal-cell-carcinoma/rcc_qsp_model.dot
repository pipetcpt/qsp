digraph RCC_QSP {
  graph [rankdir=LR, fontname="Helvetica", fontsize=11, bgcolor="#F8F9FA",
         label="Renal Cell Carcinoma (RCC) — Quantitative Systems Pharmacology Map\nVHL/HIF Axis · Angiogenesis · mTOR · Immune Microenvironment · Drug PK/PD",
         labelloc=t, labeljust=c, pad=0.6, nodesep=0.35, ranksep=0.7]
  node [shape=box, style="filled,rounded", fontname="Helvetica", fontsize=9, width=1.5, height=0.38]
  edge [fontname="Helvetica", fontsize=8, arrowsize=0.7]

  subgraph cluster_genetics {
    label="Somatic Mutations & Epigenetics"
    style=filled; color="#E8F4FD"; fontsize=11
    node [fillcolor="#AED6F1", color="#1A5276"]
    VHL_mut [label="VHL Mutation\n(60-90% ccRCC)"]
    PBRM1_loss [label="PBRM1 Loss\n(~40% ccRCC)"]
    BAP1_loss [label="BAP1 Loss\n(~15%)"]
    SETD2_loss [label="SETD2 Loss\n(~12%)"]
    KDM5C_loss [label="KDM5C Loss\n(~7%)"]
    MTOR_mut [label="mTOR Mutation\n(~6%)"]
    TSC1_mut [label="TSC1 Mutation"]
    TSC2_mut [label="TSC2 Mutation"]
    FH_loss [label="FH Loss\n(pRCC type 2)"]
    MET_amp [label="MET Amplification\n(pRCC type 1)"]
    CDKN2A_del [label="CDKN2A Deletion\n(p16 loss)"]
  }

  subgraph cluster_vhl_hif {
    label="VHL/HIF Oxygen-Sensing Pathway"
    style=filled; color="#EBF5FB"; fontsize=11
    node [fillcolor="#85C1E9", color="#154360"]
    pVHL [label="pVHL\n(E3 ubiquitin ligase)", shape=diamond, fillcolor="#2980B9", fontcolor=white]
    PHD2 [label="PHD2 (EGLN1)\nProlyl-hydroxylase"]
    PHD1 [label="PHD1 (EGLN2)"]
    PHD3 [label="PHD3 (EGLN3)"]
    FIH [label="FIH\nAsparaginyl-hydroxylase"]
    HIF1A [label="HIF-1alpha\n(bHLH-PAS)", shape=ellipse, fillcolor="#1F618D", fontcolor=white]
    HIF2A [label="HIF-2alpha (EPAS1)\n(bHLH-PAS)", shape=ellipse, fillcolor="#1F618D", fontcolor=white]
    HIF1B [label="HIF-1beta (ARNT)\nObligate partner"]
    HIF1A_HIF1B [label="HIF-1a:HIF-1b Dimer", shape=ellipse, fillcolor="#117A65", fontcolor=white]
    HIF2A_HIF1B [label="HIF-2a:HIF-1b Dimer", shape=ellipse, fillcolor="#117A65", fontcolor=white]
    HRE [label="HRE\n(Hypoxia Response Element)", shape=hexagon, fillcolor="#0E6655", fontcolor=white]
    Ubiquitination [label="Poly-Ubiquitination\nProteasomal Degradation"]
    Hypoxia [label="Hypoxia / VHL Loss\nO2 signal absent"]
  }

  subgraph cluster_hif_targets {
    label="HIF Transcriptional Targets"
    style=filled; color="#E9F7EF"; fontsize=11
    node [fillcolor="#A9DFBF", color="#145A32"]
    VEGFA [label="VEGF-A\n(primary target)", shape=ellipse, fillcolor="#1E8449", fontcolor=white]
    VEGFB [label="VEGF-B"]
    VEGFC [label="VEGF-C\nLymphangiogenesis"]
    VEGFD [label="VEGF-D"]
    PDGFB_lig [label="PDGF-B\nPericyte recruit"]
    TGFalpha [label="TGF-alpha\nEGFR ligand"]
    EPO_gene [label="EPO\nErythropoiesis"]
    CA9 [label="Carbonic Anhydrase IX\n(CA9, biomarker)", shape=diamond, fillcolor="#1E8449", fontcolor=white]
    GLUT1 [label="GLUT1\nGlucose transporter"]
    GLUT3 [label="GLUT3\nGlucose transporter"]
    LDHA_gene [label="LDHA\nLactate dehydrogenase"]
    PDK1_gene [label="PDK1\nPyruvate DH kinase"]
    CXCL12 [label="CXCL12/SDF-1\nChemoattractant"]
    MMP2_9 [label="MMP-2/9\nECM remodeling"]
    TWIST1 [label="TWIST1\nEMT driver"]
    HK2_gene [label="HK2\nHexokinase-2"]
    CCND1 [label="Cyclin D1\nCell cycle G1/S"]
  }

  subgraph cluster_angiogenesis {
    label="Angiogenesis Network"
    style=filled; color="#FDEDEC"; fontsize=11
    node [fillcolor="#F1948A", color="#6E2C00"]
    VEGFR1 [label="VEGFR-1 (Flt-1)\nDecoy/signaling"]
    VEGFR2 [label="VEGFR-2 (KDR)\nPrimary angiogenic", shape=diamond, fillcolor="#C0392B", fontcolor=white]
    VEGFR3 [label="VEGFR-3\nLymphangiogenic"]
    PDGFRB [label="PDGFR-beta\nPericyte survival"]
    PDGFRA [label="PDGFR-alpha\nStromal signaling"]
    FGFR1_2 [label="FGFR1/2\nAlternate angio"]
    KIT [label="c-KIT\nHematopoietic"]
    RET [label="RET\nNeurotrophic RTK"]
    AXL [label="AXL/MER\nResistance RTK"]
    MET_rec [label="MET (HGF-R)\nInvasion/scatter"]
    Ang1 [label="Angiopoietin-1\nVessel maturation"]
    Ang2 [label="Angiopoietin-2\nVessel destabilize"]
    Tie2 [label="Tie2/TEK\nAng receptor"]
    DLL4 [label="DLL4\nNotch1 ligand"]
    Notch1 [label="Notch1\nTip/stalk cell"]
    Neuropilin1 [label="Neuropilin-1\nVEGF co-receptor"]
    Endothelial [label="Endothelial Cell\nProliferation/Tube", shape=ellipse, fillcolor="#922B21", fontcolor=white]
    Neovascularization [label="Tumor Neovascularization", shape=hexagon, fillcolor="#7B241C", fontcolor=white]
  }

  subgraph cluster_mtor {
    label="PI3K/AKT/mTOR Signaling"
    style=filled; color="#F5EEF8"; fontsize=11
    node [fillcolor="#D7BDE2", color="#4A235A"]
    PI3K [label="PI3K (p110/p85)"]
    PTEN [label="PTEN\nTumor suppressor", fillcolor="#8E44AD", fontcolor=white]
    AKT [label="AKT (PKB)\nSurvival kinase", shape=diamond, fillcolor="#7D3C98", fontcolor=white]
    TSC1_prot [label="TSC1 (hamartin)"]
    TSC2_prot [label="TSC2 (tuberin)"]
    Rheb [label="Rheb-GTP\nmTORC1 activator"]
    mTORC1 [label="mTORC1\n(mTOR·RAPTOR)", shape=ellipse, fillcolor="#6C3483", fontcolor=white]
    mTORC2 [label="mTORC2\n(mTOR·RICTOR)"]
    S6K1 [label="S6K1\nTranslation control"]
    FourEBP1 [label="4EBP1\nTranslation control"]
    eIF4E [label="eIF4E\nCap-dep. translation"]
    AMPK [label="AMPK\nEnergy sensor"]
    HIF1A_mTOR [label="HIF-1alpha synthesis\n(mTOR-dependent)"]
  }

  subgraph cluster_mapk {
    label="MAPK/RAS Proliferation Axis"
    style=filled; color="#FEF9E7"; fontsize=11
    node [fillcolor="#FAD7A0", color="#7D6608"]
    RAS [label="RAS GTPase"]
    RAF [label="RAF kinase"]
    MEK1_2 [label="MEK1/2"]
    ERK1_2 [label="ERK1/2\nMitogenic MAPK", shape=diamond, fillcolor="#D4AC0D", fontcolor=white]
    cMyc [label="c-Myc\nTranscription factor"]
    GRB2_SOS [label="GRB2/SOS\nRAS activator"]
  }

  subgraph cluster_immune {
    label="Tumor Immune Microenvironment (TME)"
    style=filled; color="#EAFAF1"; fontsize=11
    node [fillcolor="#A9CCE3", color="#1B4F72"]
    PD1 [label="PD-1 (CD279)\nT-cell exhaustion", fillcolor="#1A5276", fontcolor=white]
    PDL1 [label="PD-L1 (CD274)\nImmune evasion", fillcolor="#1A5276", fontcolor=white]
    CTLA4 [label="CTLA-4\nCo-inhibitory"]
    CD80_86 [label="CD80/CD86 (B7)\nAPCs"]
    CD8T [label="CD8+ T cells\nCytotoxic TILs", shape=ellipse, fillcolor="#154360", fontcolor=white]
    CD4T [label="CD4+ Th1 cells\nIFN-gamma"]
    Treg [label="Regulatory T cells\n(FOXP3+)", fillcolor="#7FB3D3"]
    NK_cell [label="NK cells\nNKG2D/DNAM-1"]
    MDSC_m [label="M-MDSC\nImmune suppress"]
    MDSC_g [label="G-MDSC\nArginase-1"]
    TAM_M2 [label="TAM M2\nPro-tumor", fillcolor="#7FB3D3"]
    IFNg [label="IFN-gamma\nT-cell cytokine"]
    IL10 [label="IL-10\nImmunosuppression"]
    TGFb_imm [label="TGF-beta\nTreg induction"]
    CXCL10_imm [label="CXCL10/IP-10\nT-cell recruit"]
    IDO1 [label="IDO1\nTryptophan catab."]
    ARG1 [label="Arginase-1\nArg depletion"]
    VEGF_imm [label="VEGF in TME\nImmunosuppression"]
    LAG3 [label="LAG-3\nExhaustion marker"]
    TIM3 [label="TIM-3\nExhaustion marker"]
  }

  subgraph cluster_cell_cycle {
    label="Cell Cycle, Proliferation & Apoptosis"
    style=filled; color="#FDFEFE"; fontsize=11
    node [fillcolor="#BFC9CA", color="#2C3E50"]
    CyclinD1 [label="Cyclin D1\nG1 driver"]
    CDK4_6 [label="CDK4/6\nRb kinase"]
    Rb_prot [label="Rb (pRb)\nTumor suppressor", fillcolor="#2E4057", fontcolor=white]
    E2F_TF [label="E2F1/2/3\nS-phase genes"]
    p53 [label="p53 (TP53)\nDNA guardian", fillcolor="#2E4057", fontcolor=white]
    p21 [label="p21 (CDKN1A)\nCDK inhibitor"]
    Bcl2 [label="Bcl-2\nAnti-apoptotic"]
    BclXL [label="Bcl-xL\nAnti-apoptotic"]
    Bax [label="Bax/Bak\nPro-apoptotic"]
    Caspase3 [label="Caspase-3\nExecutioner", shape=diamond, fillcolor="#17202A", fontcolor=white]
    Cytochrome_c [label="Cytochrome c\nMitochondrial"]
  }

  subgraph cluster_metabolism {
    label="Tumor Metabolism (Warburg / HIF-driven)"
    style=filled; color="#FEF5E7"; fontsize=11
    node [fillcolor="#F0B27A", color="#7E5109"]
    Warburg [label="Warburg Effect\nAerobic Glycolysis", shape=hexagon, fillcolor="#D35400", fontcolor=white]
    Glucose_uptk [label="Glucose Uptake\n(GLUT1/3)"]
    HK2_act [label="HK2 Activity\nGlycolysis entry"]
    PKM2_act [label="PKM2\nDimer signaling"]
    LDHA_act [label="LDHA\nPyruvate to Lactate"]
    Fatty_acid [label="Fatty Acid Synthesis\nFASN/ACC"]
    Glutamine [label="Glutaminolysis\nGLS1/2"]
    ROS_tumor [label="ROS Production\nMitochondrial"]
    Autophagy [label="Autophagy\nULK1/Beclin-1"]
  }

  subgraph cluster_drugs {
    label="Drug Mechanisms of Action (PK/PD)"
    style=filled; color="#F2F3F4"; fontsize=11
    node [fillcolor="#CCD1D1", color="#212121"]
    Sunitinib [label="Sunitinib\n(SU11248)", shape=ellipse, fillcolor="#E74C3C", fontcolor=white]
    SU12662 [label="SU12662\nActive metabolite", fillcolor="#C0392B", fontcolor=white]
    Pazopanib [label="Pazopanib", shape=ellipse, fillcolor="#E74C3C", fontcolor=white]
    Axitinib [label="Axitinib", shape=ellipse, fillcolor="#E74C3C", fontcolor=white]
    Cabozantinib [label="Cabozantinib\n(MET+VEGFR2+AXL)", shape=ellipse, fillcolor="#E74C3C", fontcolor=white]
    Lenvatinib [label="Lenvatinib\n(VEGFR+FGFR)", shape=ellipse, fillcolor="#E74C3C", fontcolor=white]
    Everolimus [label="Everolimus\n(mTORC1 inh)", shape=ellipse, fillcolor="#8E44AD", fontcolor=white]
    Temsirolimus [label="Temsirolimus\n(mTORC1 inh)", shape=ellipse, fillcolor="#8E44AD", fontcolor=white]
    Nivolumab [label="Nivolumab\n(anti-PD-1)", shape=ellipse, fillcolor="#1ABC9C", fontcolor=white]
    Pembrolizumab [label="Pembrolizumab\n(anti-PD-1)", shape=ellipse, fillcolor="#1ABC9C", fontcolor=white]
    Ipilimumab [label="Ipilimumab\n(anti-CTLA-4)", shape=ellipse, fillcolor="#16A085", fontcolor=white]
    Atezolizumab [label="Atezolizumab\n(anti-PD-L1)", shape=ellipse, fillcolor="#1ABC9C", fontcolor=white]
    Belzutifan [label="Belzutifan\n(HIF-2alpha inh)", shape=ellipse, fillcolor="#F39C12", fontcolor=white]
    Nivo_Ipi [label="Nivo+Ipi\n(CheckMate 214)", shape=hexagon, fillcolor="#117A65", fontcolor=white]
    Pembro_Axiti [label="Pembro+Axitinib\n(KEYNOTE-426)", shape=hexagon, fillcolor="#117A65", fontcolor=white]
    Nivo_Cabo [label="Nivo+Cabozantinib\n(CheckMate 9ER)", shape=hexagon, fillcolor="#117A65", fontcolor=white]
  }

  subgraph cluster_outcomes {
    label="Clinical Outcomes & Biomarkers"
    style=filled; color="#EBF5FB"; fontsize=11
    node [fillcolor="#85C1E9", color="#1B2631"]
    Tumor_Volume [label="Tumor Volume (SLD)", shape=diamond, fillcolor="#2980B9", fontcolor=white]
    ORR [label="Objective Response\nRate (ORR)"]
    PFS [label="Progression-Free\nSurvival (PFS)", shape=diamond, fillcolor="#1F618D", fontcolor=white]
    OS [label="Overall Survival\n(OS)", shape=diamond, fillcolor="#1F618D", fontcolor=white]
    RECIST [label="RECIST 1.1\nCR/PR/SD/PD"]
    CA9_serum [label="sCA9 (serum)\nHypoxia biomarker"]
    VEGF_serum [label="Plasma VEGF\nPD marker"]
    IMDC_score [label="IMDC Risk Score\n(0-6)"]
    Metastasis [label="Metastasis\n(lung/bone/brain)"]
  }

  VHL_mut -> pVHL [label="loss of function", color="#C0392B", style=dashed]
