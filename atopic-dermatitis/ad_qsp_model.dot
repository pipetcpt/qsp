digraph AtopicDermatitis_QSP {

  graph [
    label="Atopic Dermatitis (AD) — Quantitative Systems Pharmacology Model\nEpidermal Barrier Dysfunction · Th2 Immune Activation · Itch Signaling · Drug PK/PD",
    labelloc=t, labeljust=c,
    fontname="Helvetica", fontsize=22, fontcolor="#1a1a2e",
    bgcolor="#f8f9fa",
    rankdir=TB,
    splines=ortho,
    nodesep=0.4,
    ranksep=0.7,
    pad=0.5,
    compound=true
  ]

  node [fontname="Helvetica", fontsize=10, style="filled,rounded", penwidth=1.5, margin="0.12,0.06"]
  edge [fontname="Helvetica", fontsize=8, penwidth=1.2, arrowsize=0.8]

  /* ================================================================
     CLUSTER 1: Environmental & Genetic Triggers
  ================================================================ */
  subgraph cluster_triggers {
    label="Environmental & Genetic Triggers"
    style="filled,rounded"
    color="#c0392b"
    fillcolor="#fdecea"
    fontcolor="#c0392b"
    fontsize=13
    fontname="Helvetica-Bold"

    Allergens        [label="Allergens\n(HDM, pollen,\npet dander)", shape=ellipse, fillcolor="#e74c3c", fontcolor=white]
    Microbiome       [label="Skin Microbiome\nDysbiosis\n(S. aureus↑)", shape=ellipse, fillcolor="#e74c3c", fontcolor=white]
    MechTrauma       [label="Mechanical\nTrauma /\nScratch", shape=ellipse, fillcolor="#e74c3c", fontcolor=white]
    UVradiation      [label="UV / Pollution\nExposure", shape=ellipse, fillcolor="#c0392b", fontcolor=white]
    FLGmut           [label="FLG Gene\nMutation\n(R501X, 2282del4)", shape=diamond, fillcolor="#922b21", fontcolor=white]
    SPINK5mut        [label="SPINK5/LEKTI\nDeficiency", shape=diamond, fillcolor="#922b21", fontcolor=white]
    TH2skew          [label="Genetic Th2\nSkewing\n(IL4/IL13 SNPs)", shape=diamond, fillcolor="#922b21", fontcolor=white]
    SweatingDefect   [label="Sweat Gland\nDysfunction", shape=ellipse, fillcolor="#e74c3c", fontcolor=white]
  }

  /* ================================================================
     CLUSTER 2: Epidermal Barrier Dysfunction
  ================================================================ */
  subgraph cluster_barrier {
    label="Epidermal Barrier Dysfunction"
    style="filled,rounded"
    color="#d35400"
    fillcolor="#fef5e7"
    fontcolor="#d35400"
    fontsize=13
    fontname="Helvetica-Bold"

    Filaggrin        [label="Filaggrin\n(FLG↓)", shape=box, fillcolor="#e67e22", fontcolor=white]
    Ceramides        [label="Ceramides ↓\n(Ceramide 1,3,6)", shape=box, fillcolor="#e67e22", fontcolor=white]
    Loricrin         [label="Loricrin /\nInvolucrin ↓", shape=box, fillcolor="#e67e22", fontcolor=white]
    CLDN1            [label="Claudin-1\n(Tight Junction↓)", shape=box, fillcolor="#e67e22", fontcolor=white]
    NMF              [label="Natural\nMoisturizing\nFactor↓", shape=box, fillcolor="#f39c12", fontcolor=white]
    TEWL             [label="↑ TEWL\n(Trans-epidermal\nWater Loss)", shape=box, fillcolor="#d35400", fontcolor=white]
    pHalkaline       [label="Skin pH↑\n(Alkaline shift)", shape=box, fillcolor="#d35400", fontcolor=white]
    KLK5act          [label="↑ KLK5\nSerine Protease", shape=box, fillcolor="#e67e22", fontcolor=white]
    DSG1cleave       [label="Desmoglein-1\nCleavage", shape=box, fillcolor="#e67e22", fontcolor=white]
    BarrierBreach    [label="Barrier Breach\n→ Allergen\nPenetration", shape=box, fillcolor="#d35400", fontcolor=white]
    Staphylococcus   [label="S. aureus\nColonization ↑\n(Toxin secretion)", shape=ellipse, fillcolor="#922b21", fontcolor=white]
  }

  /* ================================================================
     CLUSTER 3: Innate Immunity & Alarmins
  ================================================================ */
  subgraph cluster_innate {
    label="Innate Immunity & Alarmins"
    style="filled,rounded"
    color="#1a5276"
    fillcolor="#eaf2ff"
    fontcolor="#1a5276"
    fontsize=13
    fontname="Helvetica-Bold"

    TSLP             [label="TSLP\n(Thymic Stromal\nLymphopoietin)", shape=ellipse, fillcolor="#2980b9", fontcolor=white]
    IL25             [label="IL-25\n(IL-17E)", shape=ellipse, fillcolor="#2980b9", fontcolor=white]
    IL33             [label="IL-33 /\nST2 axis", shape=ellipse, fillcolor="#2980b9", fontcolor=white]
    ILC2             [label="ILC2\n(Innate Lymphoid\nCell Type 2)", shape=ellipse, fillcolor="#1a5276", fontcolor=white]
    MastCell         [label="Mast Cell\nActivation", shape=ellipse, fillcolor="#2471a3", fontcolor=white]
    Histamine        [label="Histamine\nRelease", shape=ellipse, fillcolor="#2471a3", fontcolor=white]
    BasophilAct      [label="Basophil\nActivation", shape=ellipse, fillcolor="#2471a3", fontcolor=white]
    pDC              [label="Plasmacytoid DC\n(pDC)", shape=ellipse, fillcolor="#2e4057", fontcolor=white]
    mDC              [label="Myeloid DC\n(mDC) Activation", shape=ellipse, fillcolor="#2e4057", fontcolor=white]
    LangCell         [label="Langerhans\nCell Migration", shape=ellipse, fillcolor="#2e4057", fontcolor=white]
    NFkB_innate      [label="NF-κB\nActivation\n(Keratinocytes)", shape=box, fillcolor="#1a5276", fontcolor=white]
    TSLPR            [label="TSLP-R /\nIL-7Rα Complex\n(on DC, ILC2)", shape=box, fillcolor="#2980b9", fontcolor=white]
    Amphiregulin     [label="Amphiregulin\n(ILC2→tissue\nremodeling)", shape=ellipse, fillcolor="#2471a3", fontcolor=white]
    OX40L            [label="OX40L\n(DC→T cell\nactivation)", shape=ellipse, fillcolor="#2e4057", fontcolor=white]
  }

  /* ================================================================
     CLUSTER 4: Th2 Adaptive Immunity
  ================================================================ */
  subgraph cluster_th2 {
    label="Th2 Adaptive Immunity (Core Pathogenic Axis)"
    style="filled,rounded"
    color="#6c3483"
    fillcolor="#f3e5f5"
    fontcolor="#6c3483"
    fontsize=13
    fontname="Helvetica-Bold"

    NaiveTcell       [label="Naive\nCD4+ T Cell", shape=ellipse, fillcolor="#9b59b6", fontcolor=white]
    Th2cell          [label="Th2 Cell\n(Differentiated)", shape=ellipse, fillcolor="#6c3483", fontcolor=white]
    IL4              [label="IL-4\n(Th2 signature)", shape=ellipse, fillcolor="#8e44ad", fontcolor=white]
    IL13             [label="IL-13\n(Barrier↓,\nIgE↑, Itch)", shape=ellipse, fillcolor="#8e44ad", fontcolor=white]
    IL31             [label="IL-31\n(Pruritus\ncytokine)", shape=ellipse, fillcolor="#7d3c98", fontcolor=white]
    IL10             [label="IL-10\n(Regulatory)", shape=ellipse, fillcolor="#6c3483", fontcolor=white]
    GATA3            [label="GATA-3\nTranscription\nFactor", shape=box, fillcolor="#5b2c6f", fontcolor=white]
    STAT6            [label="STAT6\nPhosphorylation\n(IL-4/IL-13)", shape=box, fillcolor="#5b2c6f", fontcolor=white]
    IL4Ra            [label="IL-4Rα\nReceptor\n(Shared chain)", shape=box, fillcolor="#884ea0", fontcolor=white]
    IL13Ra1          [label="IL-13Rα1\nReceptor", shape=box, fillcolor="#884ea0", fontcolor=white]
    IL13Ra2          [label="IL-13Rα2\n(Decoy receptor)", shape=box, fillcolor="#884ea0", fontcolor=white]
    JAK1_pathway     [label="JAK1/TYK2\nSignaling\n(IL-4 type I)", shape=box, fillcolor="#5b2c6f", fontcolor=white]
    JAK1JAK2         [label="JAK1/JAK2\nSignaling\n(IL-4 type II)", shape=box, fillcolor="#5b2c6f", fontcolor=white]
    TARC_CCL17       [label="TARC/CCL17\n↑(Th2 recruitment\nbiomarker)", shape=ellipse, fillcolor="#9b59b6", fontcolor=white]
    MDC_CCL22        [label="MDC/CCL22\n↑(Th2 chemokine)", shape=ellipse, fillcolor="#9b59b6", fontcolor=white]
    IgE              [label="Total IgE ↑\n& Allergen-\nspecific IgE", shape=ellipse, fillcolor="#6c3483", fontcolor=white]
    BCellIgE         [label="B Cell\nIgE Class\nSwitching", shape=ellipse, fillcolor="#7d3c98", fontcolor=white]
    FCERI            [label="FcεRI on\nMast/Basophil\n(IgE-loaded)", shape=box, fillcolor="#6c3483", fontcolor=white]
    Periostin        [label="Periostin\n(Subepithelial\nfibronectin)", shape=ellipse, fillcolor="#9b59b6", fontcolor=white]
    Eotaxin3         [label="Eotaxin-3\n(CCL26)\n↑Eosinophil", shape=ellipse, fillcolor="#9b59b6", fontcolor=white]
  }

  /* ================================================================
     CLUSTER 5: Eosinophil & Mast Cell Effectors
  ================================================================ */
  subgraph cluster_effectors {
    label="Eosinophil / Mast Cell Effectors"
    style="filled,rounded"
    color="#1e8449"
    fillcolor="#eafaf1"
    fontcolor="#1e8449"
    fontsize=13
    fontname="Helvetica-Bold"

    Eosinophil       [label="Eosinophil\nRecruitment\n& Activation", shape=ellipse, fillcolor="#27ae60", fontcolor=white]
    IL5              [label="IL-5\n(Eosinophil\nsurvival/maturation)", shape=ellipse, fillcolor="#27ae60", fontcolor=white]
    ECP              [label="ECP\n(Eosinophil\nCationic Protein)", shape=ellipse, fillcolor="#1e8449", fontcolor=white]
    MBP              [label="MBP\n(Major Basic\nProtein)", shape=ellipse, fillcolor="#1e8449", fontcolor=white]
    IL4_from_mast    [label="IL-4/IL-13\nfrom Mast Cells", shape=ellipse, fillcolor="#27ae60", fontcolor=white]
    PGD2             [label="PGD2\n(Mast cell\nprostaglandin)", shape=ellipse, fillcolor="#27ae60", fontcolor=white]
    LTC4             [label="LTC4/D4\n(Leukotrienes)", shape=ellipse, fillcolor="#1e8449", fontcolor=white]
    Tryptase         [label="Tryptase\n(Mast cell\nprotease)", shape=ellipse, fillcolor="#1e8449", fontcolor=white]
    BloodEosino      [label="Blood\nEosinophil\nCount (CBC)", shape=box, fillcolor="#145a32", fontcolor=white]
    Duplex_Th2       [label="Duplex\nTh2 Signature\n(TARC+ECP)", shape=box, fillcolor="#145a32", fontcolor=white]
  }

  /* ================================================================
     CLUSTER 6: Th1/Th17/Th22 Counter-Regulation
  ================================================================ */
  subgraph cluster_th1_th17 {
    label="Th1 / Th17 / Th22 Counter-Regulation"
    style="filled,rounded"
    color="#7f8c8d"
    fillcolor="#f2f3f4"
    fontcolor="#2c3e50"
    fontsize=13
    fontname="Helvetica-Bold"

    Th1cell          [label="Th1 Cell\n(IFN-γ)", shape=ellipse, fillcolor="#5d6d7e", fontcolor=white]
    IFNgamma         [label="IFN-γ\n(counter-reg.)", shape=ellipse, fillcolor="#5d6d7e", fontcolor=white]
    Th17cell         [label="Th17 Cell\n(Asian AD↑)", shape=ellipse, fillcolor="#717d7e", fontcolor=white]
    IL17A            [label="IL-17A\n(Barrier disruption\nAsian subtype)", shape=ellipse, fillcolor="#717d7e", fontcolor=white]
    Th22cell         [label="Th22 Cell\n(Chronic AD)", shape=ellipse, fillcolor="#5d6d7e", fontcolor=white]
    IL22             [label="IL-22\n(Epidermal\nhyperplasia)", shape=ellipse, fillcolor="#5d6d7e", fontcolor=white]
    Treg             [label="T Regulatory\nCell (Treg)\nIL-10/TGFβ", shape=ellipse, fillcolor="#2c3e50", fontcolor=white]
    TGFbeta          [label="TGF-β\n(Fibrosis in\nchronic AD)", shape=ellipse, fillcolor="#2c3e50", fontcolor=white]
    RORgt            [label="RORγt\n(Th17\ntranscription)", shape=box, fillcolor="#717d7e", fontcolor=white]
    STAT3_Th17       [label="STAT3\n(IL-22/IL-17\nsignaling)", shape=box, fillcolor="#717d7e", fontcolor=white]
  }

  /* ================================================================
     CLUSTER 7: Pruritus / Itch Neural Pathway
  ================================================================ */
  subgraph cluster_itch {
    label="Pruritus (Itch) Signaling Pathway"
    style="filled,rounded"
    color="#b7770d"
    fillcolor="#fef9e7"
    fontcolor="#b7770d"
    fontsize=13
    fontname="Helvetica-Bold"

    IL31_itch        [label="IL-31\n(Primary\nitch driver)", shape=ellipse, fillcolor="#f39c12", fontcolor=white]
    IL31Ra           [label="IL-31RA /\nOSMR complex\n(DRG neurons)", shape=box, fillcolor="#e67e22", fontcolor=white]
    OSM              [label="Oncostatin M\n(OSM)", shape=ellipse, fillcolor="#f39c12", fontcolor=white]
    TRPV1            [label="TRPV1\n(Capsaicin R)\nSensitization", shape=box, fillcolor="#d68910", fontcolor=white]
    TRPA1            [label="TRPA1\n(Itch ion\nchannel)", shape=box, fillcolor="#d68910", fontcolor=white]
    DRGneuron        [label="Dorsal Root\nGanglion (DRG)\nNeuron", shape=ellipse, fillcolor="#b7770d", fontcolor=white]
    Histamine_itch   [label="Histamine\n(H1/H4R)", shape=ellipse, fillcolor="#f39c12", fontcolor=white]
    TSLP_itch        [label="TSLP-R\n(Itch neuron)", shape=box, fillcolor="#e67e22", fontcolor=white]
    SubstanceP       [label="Substance P\n(neuropeptide)", shape=ellipse, fillcolor="#e67e22", fontcolor=white]
    CGRP             [label="CGRP\n(Neurogenic\ninflammation)", shape=ellipse, fillcolor="#e67e22", fontcolor=white]
    SpinalCord       [label="Spinal Cord\nDorsal Horn\n(GRPR neurons)", shape=box, fillcolor="#9a7d0a", fontcolor=white]
    PruritusNRS      [label="Pruritus NRS\n(0-10 Clinical\nOutcome)", shape=box, fillcolor="#784212", fontcolor=white, penwidth=3]
    ScratchCycle     [label="Itch-Scratch\nCycle\n(barrier ↓↓)", shape=ellipse, fillcolor="#9a7d0a", fontcolor=white]
  }

  /* ================================================================
     CLUSTER 8: Keratinocyte Responses
  ================================================================ */
  subgraph cluster_kc {
    label="Keratinocyte Inflammatory Responses"
    style="filled,rounded"
    color="#1a6b4a"
    fillcolor="#e9f7ef"
    fontcolor="#1a6b4a"
    fontsize=13
    fontname="Helvetica-Bold"

    Keratinocyte     [label="Keratinocyte\n(Stressed)", shape=ellipse, fillcolor="#1e8449", fontcolor=white]
    TSLP_KC          [label="TSLP Release\n(KC→Innate)", shape=ellipse, fillcolor="#27ae60", fontcolor=white]
    IL33_KC          [label="IL-33 Release\n(KC→ILC2)", shape=ellipse, fillcolor="#27ae60", fontcolor=white]
    IL25_KC          [label="IL-25 Release\n(KC→ILC2)", shape=ellipse, fillcolor="#27ae60", fontcolor=white]
    CCL27            [label="CCL27\n(KC→CLA+T\ncell recruit)", shape=ellipse, fillcolor="#1e8449", fontcolor=white]
    ICAM1            [label="ICAM-1↑\n(KC surface)", shape=box, fillcolor="#1e8449", fontcolor=white]
    CXCL10           [label="CXCL10/IP-10\n(IFN-γ induced)", shape=ellipse, fillcolor="#1e8449", fontcolor=white]
    IL36             [label="IL-36α/γ\n(KC damage\nsignal)", shape=ellipse, fillcolor="#1e8449", fontcolor=white]
    Spongiosis       [label="Epidermal\nSpongiosis\n(intercellular edema)", shape=box, fillcolor="#145a32", fontcolor=white]
    Acanthosis       [label="Acanthosis\n(Epidermal\nthickening)", shape=box, fillcolor="#145a32", fontcolor=white]
  }

  /* ================================================================
     CLUSTER 9: Drug PK — Biologics
  ================================================================ */
  subgraph cluster_pk_biologic {
    label="Drug PK: Biologic Agents"
    style="filled,rounded"
    color="#2e86ab"
    fillcolor="#e8f4f8"
    fontcolor="#2e86ab"
    fontsize=13
    fontname="Helvetica-Bold"

    Dupilumab_depot  [label="Dupilumab SC\nDepot (Q2W)", shape=cylinder, fillcolor="#2e86ab", fontcolor=white]
    Dupilumab_C      [label="Dupilumab\nCentral (Cp)", shape=box, fillcolor="#2980b9", fontcolor=white]
    Dupilumab_P      [label="Dupilumab\nPeripheral (Cp2)", shape=box, fillcolor="#2980b9", fontcolor=white]
    Dupilumab_skin   [label="Dupilumab\nSkin Conc.", shape=box, fillcolor="#1a5276", fontcolor=white]
    Tralokinumab     [label="Tralokinumab\n(anti-IL-13)\nSC Q2W", shape=cylinder, fillcolor="#2e86ab", fontcolor=white]
    Lebrikizumab     [label="Lebrikizumab\n(anti-IL-13)\nSC Q2W/Q4W", shape=cylinder, fillcolor="#2e86ab", fontcolor=white]
    Nemolizumab      [label="Nemolizumab\n(anti-IL-31Ra)\nSC Q4W", shape=cylinder, fillcolor="#21618c", fontcolor=white]
    Cendakimab       [label="Cendakimab\n(anti-IL-13Ra1)\nOral", shape=cylinder, fillcolor="#21618c", fontcolor=white]
    AntibodyFcRn     [label="FcRn Recycling\n(IgG half-life\nextension)", shape=box, fillcolor="#1a5276", fontcolor=white]
    Immunogenicity   [label="ADA /\nImmunogenicity\n(rare)", shape=box, fillcolor="#1a5276", fontcolor=white]
  }

  /* ================================================================
     CLUSTER 10: Drug PK — JAK Inhibitors (Small Molecules)
  ================================================================ */
  subgraph cluster_pk_jak {
    label="Drug PK: JAK Inhibitors (Small Molecules)"
    style="filled,rounded"
    color="#154360"
    fillcolor="#eaf2ff"
    fontcolor="#154360"
    fontsize=13
    fontname="Helvetica-Bold"

    Upadacitinib_abs [label="Upadacitinib\nAbsorption (oral)\n15/30mg QD", shape=cylinder, fillcolor="#154360", fontcolor=white]
    Upadacitinib_C   [label="Upadacitinib\nPlasma (Cp)", shape=box, fillcolor="#1a5276", fontcolor=white]
    Upadacitinib_sk  [label="Upadacitinib\nSkin Conc.", shape=box, fillcolor="#1a5276", fontcolor=white]
    Abrocitinib_abs  [label="Abrocitinib\nAbsorption (oral)\n100/200mg QD", shape=cylinder, fillcolor="#154360", fontcolor=white]
    Abrocitinib_C    [label="Abrocitinib\nPlasma (Cp)", shape=box, fillcolor="#1a5276", fontcolor=white]
    Baricitinib_C    [label="Baricitinib\nPlasma (Cp)\n2/4mg QD", shape=box, fillcolor="#1a5276", fontcolor=white]
    JAK1inh          [label="JAK1\nInhibition (%)\n(Upadacitinib,\nAbrocitinib)", shape=box, fillcolor="#0e2b5c", fontcolor=white]
    JAK2inh          [label="JAK2\nInhibition\n(Baricitinib)", shape=box, fillcolor="#0e2b5c", fontcolor=white]
    TYK2inh          [label="TYK2\nInhibition\n(Deucravacitinib)", shape=box, fillcolor="#0e2b5c", fontcolor=white]
    Deucravacitinib  [label="Deucravacitinib\n(TYK2 allosteric\ninhibitor)", shape=cylinder, fillcolor="#154360", fontcolor=white]
  }

  /* ================================================================
     CLUSTER 11: Drug PD — Pharmacodynamic Effects
  ================================================================ */
  subgraph cluster_pd {
    label="Drug PD Effects (Pharmacodynamic)"
    style="filled,rounded"
    color="#0b5345"
    fillcolor="#e8f8f5"
    fontcolor="#0b5345"
    fontsize=13
    fontname="Helvetica-Bold"

    IL4Ra_occupancy  [label="IL-4Rα Receptor\nOccupancy (RO%)\n(Dupilumab target)", shape=box, fillcolor="#0e6655", fontcolor=white]
    IL13_suppression [label="IL-13 Pathway\nSuppression (%)", shape=box, fillcolor="#0e6655", fontcolor=white]
    IL4_suppression  [label="IL-4 Pathway\nSuppression (%)", shape=box, fillcolor="#0e6655", fontcolor=white]
    STAT6_inhibit    [label="pSTAT6\nInhibition (%)", shape=box, fillcolor="#0b5345", fontcolor=white]
    TARC_reduction   [label="TARC/CCL17\nReduction (%)\n(PD biomarker)", shape=box, fillcolor="#0b5345", fontcolor=white]
    IL31_block       [label="IL-31\nSignaling Block\n(Nemolizumab)", shape=box, fillcolor="#0e6655", fontcolor=white]
    JAK_STAT_block   [label="JAK-STAT\nBroadband Block\n(JAKi→IL4/13/\nIL31/TSLP)", shape=box, fillcolor="#0b5345", fontcolor=white]
    Eosinophil_down  [label="Blood Eosinophil\nReduction\n(PD effect)", shape=box, fillcolor="#0e6655", fontcolor=white]
    IgE_suppression  [label="IgE Level\nSuppression\n(long-term)", shape=box, fillcolor="#0b5345", fontcolor=white]
    TCS_synergy      [label="Topical CS\nSynergy\n(TCS+Dupilumab)", shape=box, fillcolor="#145a32", fontcolor=white]
    Emollient_PD     [label="Emollient\nBarrier Repair\n(adjunct PD)", shape=box, fillcolor="#145a32", fontcolor=white]
  }

  /* ================================================================
     CLUSTER 12: Clinical Endpoints & Scores
  ================================================================ */
  subgraph cluster_endpoints {
    label="Clinical Endpoints & Outcome Scores"
    style="filled,rounded"
    color="#512e5f"
    fillcolor="#f5eef8"
    fontcolor="#512e5f"
    fontsize=13
    fontname="Helvetica-Bold"

    EASI             [label="EASI Score\n(Eczema Area\n& Severity Index)", shape=box, fillcolor="#6c3483", fontcolor=white, penwidth=3]
    SCORAD           [label="SCORAD\n(SCORing\nAtopic Dermatitis)", shape=box, fillcolor="#6c3483", fontcolor=white, penwidth=3]
    IGA              [label="IGA 0/1\n(Investigator\nGlobal Assessment)", shape=box, fillcolor="#6c3483", fontcolor=white, penwidth=3]
    DLQI             [label="DLQI Score\n(Quality of Life)", shape=box, fillcolor="#512e5f", fontcolor=white, penwidth=2]
    POEM             [label="POEM\n(Patient-Oriented\nEczema Measure)", shape=box, fillcolor="#512e5f", fontcolor=white, penwidth=2]
    NRS_itch         [label="NRS Itch\n(0-10 scale)\nPrimary PPSD", shape=box, fillcolor="#7d3c98", fontcolor=white, penwidth=3]
    SkinClear        [label="Skin Clearance\n(EASI-75/90/100)", shape=box, fillcolor="#6c3483", fontcolor=white]
    Erythema_score   [label="Erythema\n(EASI sub-score)", shape=box, fillcolor="#5b2c6f", fontcolor=white]
    Lichenification  [label="Lichenification\n(Chronic EASI\nsub-score)", shape=box, fillcolor="#5b2c6f", fontcolor=white]
    Excoriation      [label="Excoriation\n(EASI sub-score)", shape=box, fillcolor="#5b2c6f", fontcolor=white]
    SleepQuality     [label="Sleep Disturbance\n(Itch-related)", shape=box, fillcolor="#5b2c6f", fontcolor=white]
    ECZTRA_trial     [label="ECZTRA-1/2/3\n(Tralokinumab\nRCT data)", shape=note, fillcolor="#d7bde2", fontcolor="#2c3e50"]
    SOLO_trial       [label="SOLO 1&2\n(Dupilumab\nPhase 3 RCT)", shape=note, fillcolor="#d7bde2", fontcolor="#2c3e50"]
    Measure_Up       [label="Measure Up 1/2\n(Lebrikizumab\nPhase 3 RCT)", shape=note, fillcolor="#d7bde2", fontcolor="#2c3e50"]
    Jade_trial       [label="JADE MONO 1/2\n(Abrocitinib\nPhase 3 RCT)", shape=note, fillcolor="#d7bde2", fontcolor="#2c3e50"]
    Rising_Up        [label="Rising Up\n(Upadacitinib\nPhase 3 RCT)", shape=note, fillcolor="#d7bde2", fontcolor="#2c3e50"]
  }

  /* ================================================================
     CLUSTER 13: Systemic Comorbidities
  ================================================================ */
  subgraph cluster_comorbid {
    label="Systemic Comorbidities & Atopic March"
    style="filled,rounded"
    color="#7f8c8d"
    fillcolor="#fdfefe"
    fontcolor="#2c3e50"
    fontsize=13
    fontname="Helvetica-Bold"

