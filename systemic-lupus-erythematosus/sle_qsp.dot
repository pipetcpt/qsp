digraph SLE_QSP {
  graph [
    label="Systemic Lupus Erythematosus (SLE)\nQuantitative Systems Pharmacology Map"
    labelloc=t
    fontname="Helvetica-Bold"
    fontsize=22
    bgcolor="#FAFAFA"
    overlap=prism
    splines=true
    sep="+12"
    esep="+6"
    outputorder=edgesfirst
    K=1.2
  ]
  node [fontname="Helvetica" fontsize=9 style="filled,rounded" shape=ellipse margin="0.06,0.03"]
  edge [fontname="Helvetica" fontsize=7.5 arrowsize=0.7]

  /* ============================================================
     CLUSTER 1 — Cell Death & Nuclear Antigen Release
  ============================================================ */
  subgraph cluster_celldeath {
    label="Cell Death & Antigen Release"
    style=filled fillcolor="#FFF0EE" color="#CC4444" fontcolor="#8B0000" fontsize=11

    UV_radiation  [label="UV Radiation"         shape=rectangle fillcolor="#FFD700" fontcolor=black]
    Apoptosis     [label="Apoptosis"             fillcolor="#FF6B6B"]
    SecNecrosis   [label="Secondary\nNecrosis"   fillcolor="#FF4500"]
    NETosis       [label="NETosis\n(NADPH/PAD4)" fillcolor="#FF6347"]
    NETs          [label="NETs\n(DNA+Histones\n+LL-37+MPO)" fillcolor="#FF7F50"]
    Chromatin     [label="Chromatin/\nNuclear Debris" fillcolor="#FFA07A"]
    HMGB1         [label="HMGB1\n(alarmin)"     fillcolor="#FA8072"]
    mtDNA         [label="Mitochondrial\nDNA"    fillcolor="#E9967A"]
    ApopCells     [label="Apoptotic\nCells"      fillcolor="#F08080"]
    Phago_defect  [label="Defective\nPhagocytosis" shape=diamond fillcolor="#CD5C5C"]
    TREX1_def     [label="TREX1↓\n(cytosol DNA\naccumulates)" shape=rectangle fillcolor="#DC143C" fontcolor=white]
    PAD4          [label="PAD4\n(citrullination)" fillcolor="#FF8C8C"]
  }

  /* ============================================================
     CLUSTER 2 — Innate Immunity & Type I IFN
  ============================================================ */
  subgraph cluster_IFN {
    label="Innate Immunity & Type I IFN Pathway"
    style=filled fillcolor="#F0EEFF" color="#5500AA" fontcolor="#3D008B" fontsize=11

    pDC          [label="Plasmacytoid DC\n(pDC)" fillcolor="#DDA0DD"]
    mDC          [label="Myeloid DC\n(mDC)"      fillcolor="#DA70D6"]
    Mono_macro   [label="Monocyte/\nMacrophage"  fillcolor="#BA55D3"]
    TLR7         [label="TLR7\n(ssRNA sensor)"   shape=rectangle fillcolor="#9370DB"]
    TLR9         [label="TLR9\n(CpG-DNA sensor)" shape=rectangle fillcolor="#8A2BE2"]
    TLR4         [label="TLR4\n(HMGB1/LPS)"      shape=rectangle fillcolor="#7B68EE"]
    cGAS_prot    [label="cGAS\n(dsDNA sensor)"   shape=rectangle fillcolor="#9400D3"]
    STING_prot   [label="STING"                  shape=rectangle fillcolor="#8B008B"]
    cGAMP_mol    [label="cGAMP\n(2nd messenger)" fillcolor="#800080"]
    IRF3         [label="IRF3\n(phospho)"        fillcolor="#9B5FC0"]
    IRF5         [label="IRF5"                   fillcolor="#7B4EA0"]
    IRF7         [label="IRF7\n(master IFN Reg)" fillcolor="#5B3E80"]
    MyD88        [label="MyD88"                  fillcolor="#9932CC"]
    TRIF_ad      [label="TRIF"                   fillcolor="#BF5FFF"]
    NF_kB        [label="NF-κB"                  shape=diamond fillcolor="#CC44CC"]
    IFNalpha     [label="IFN-α\n(type I)"        fillcolor="#EE82EE" fontcolor=black]
    IFNbeta      [label="IFN-β\n(type I)"        fillcolor="#D580EE" fontcolor=black]
    IFNsig       [label="IFN Signature\n(ISG)" fillcolor="#C060D8"]
    JAK1_ifn     [label="JAK1"                   fillcolor="#AB82FF"]
    TYK2         [label="TYK2"                   fillcolor="#9A32CD"]
    STAT1_ifn    [label="STAT1\n(pY701)"         fillcolor="#7A52AA"]
    STAT2_ifn    [label="STAT2\n(pY690)"         fillcolor="#6A3888"]
    IRF9         [label="IRF9\n(ISGF3)"          fillcolor="#5A2068"]
    ISGF3        [label="ISGF3 Complex\n(STAT1/STAT2/IRF9)" fillcolor="#4A1058"]
    ISGs         [label="ISGs\n(MX1/IFIT1/OAS\n/ISG15/SIGLEC1)" fillcolor="#3A0048"]
    IFNAR1       [label="IFNAR1\n(IFN Receptor α)" shape=rectangle fillcolor="#550088" fontcolor=white]
    IFNAR2       [label="IFNAR2"                 shape=rectangle fillcolor="#440077" fontcolor=white]
    DNase_I      [label="DNase I\n(NETs clearance)" fillcolor="#B0C4DE"]
    IL1beta_inn  [label="IL-1β\n(inflammasome)"  fillcolor="#CC88FF"]
    NLRP3        [label="NLRP3\nInflammasome"    shape=rectangle fillcolor="#BB77EE"]
    TNFalpha_inn [label="TNF-α\n(innate)"        fillcolor="#AA66DD"]
    IL12         [label="IL-12\n(p70)"           fillcolor="#9955CC"]
    IL18         [label="IL-18"                  fillcolor="#8844BB"]
  }

  /* ============================================================
     CLUSTER 3 — B Cell Biology & Autoantibodies
  ============================================================ */
  subgraph cluster_Bcell {
    label="B Cell Activation & Autoantibody Production"
    style=filled fillcolor="#EEFFEE" color="#228B22" fontcolor="#004400" fontsize=11

    NaiveB       [label="Naïve B Cell"           fillcolor="#98FB98"]
    ActivatedB   [label="Activated B Cell"       fillcolor="#90EE90"]
    GC           [label="Germinal Center\nReaction" shape=rectangle fillcolor="#66CD00"]
    Plasmablast  [label="Plasmablast"            fillcolor="#7CFC00"]
    LLPC         [label="Long-lived\nPlasma Cell" fillcolor="#32CD32"]
    MemB         [label="Memory B Cell"          fillcolor="#228B22" fontcolor=white]
    BAFF_mol     [label="BAFF/BLyS"             fillcolor="#006400" fontcolor=white]
    APRIL_mol    [label="APRIL"                  fillcolor="#556B2F" fontcolor=white]
    BAFFR        [label="BAFF-R\n(TNFRSF13C)"   shape=rectangle fillcolor="#6B8E23"]
    TACI         [label="TACI\n(TNFRSF13B)"     shape=rectangle fillcolor="#8FBC8F"]
    BCMA         [label="BCMA\n(TNFRSF17)"      shape=rectangle fillcolor="#9ACD32"]
    BCR          [label="BCR Complex"            shape=rectangle fillcolor="#ADFF2F"]
    CD40_b       [label="CD40"                   shape=rectangle fillcolor="#7FFF00"]
    CD40L        [label="CD40L\n(CD154)"         shape=rectangle fillcolor="#76EE00"]
    IL21_b       [label="IL-21\n(Tfh-derived)"  fillcolor="#00EE00"]
    IL10_b       [label="IL-10\n(B-cell)" fillcolor="#00CC88"]
    ANA          [label="ANA\n(Anti-Nuclear Ab)" fillcolor="#00FF00"]
    anti_dsDNA   [label="Anti-dsDNA IgG"        fillcolor="#00C957"]
    anti_Sm      [label="Anti-Sm Ab"             fillcolor="#00FA9A"]
    anti_Ro      [label="Anti-Ro/SSA Ab"         fillcolor="#00FF7F"]
    anti_La      [label="Anti-La/SSB Ab"         fillcolor="#7FFFD4"]
    anti_C1q     [label="Anti-C1q Ab"            fillcolor="#66CDAA"]
    anti_nucs    [label="Anti-Nucleosome Ab"     fillcolor="#20B2AA"]
    IgG_IC       [label="IgG Immune\nComplexes"  fillcolor="#008080" fontcolor=white]
    PI3Kd        [label="PI3Kδ\n(BCR signaling)" fillcolor="#3CB371"]
    SYK          [label="SYK kinase\n(BCR)"      shape=rectangle fillcolor="#2E8B57"]
    BTK          [label="BTK\n(BCR/TLR9)"        shape=rectangle fillcolor="#006400" fontcolor=white]
  }

  /* ============================================================
     CLUSTER 4 — T Cell Dysregulation
  ============================================================ */
  subgraph cluster_Tcell {
    label="T Cell Dysregulation"
    style=filled fillcolor="#FFF8EE" color="#B8632A" fontcolor="#704010" fontsize=11

    NaiveCD4     [label="Naïve CD4+ T"           fillcolor="#FFDEAD"]
    Th1          [label="Th1\n(IFN-γ, TNF-α)"   fillcolor="#FFE4B5"]
    Th2          [label="Th2\n(IL-4, IL-13)"     fillcolor="#FFEFD5"]
    Th17         [label="Th17\n(IL-17A/F)"       fillcolor="#FFDAB9"]
    Tfh          [label="Tfh\n(T follicular\nhelper)" fillcolor="#FFCBA4"]
    Treg         [label="Treg\n(FoxP3+)"         fillcolor="#FFB347"]
    DN_T         [label="DN T cells\n(CD3+CD4-CD8-)" fillcolor="#FFA500"]
    CD8_CTL      [label="CD8+ CTL"               fillcolor="#FF8C00"]
    TCR_complex  [label="TCR/CD3"                shape=rectangle fillcolor="#FF7043"]
    CD28_b       [label="CD28"                   shape=rectangle fillcolor="#FF6A00"]
    CTLA4        [label="CTLA-4"                 shape=rectangle fillcolor="#E55B00"]
    PD1          [label="PD-1"                   shape=rectangle fillcolor="#CC5500"]
    PDL1         [label="PD-L1"                  shape=rectangle fillcolor="#B34700"]
    ICOS         [label="ICOS\n(Tfh marker)"     shape=rectangle fillcolor="#A03B00"]
    IFNgamma     [label="IFN-γ"                  fillcolor="#FF8247"]
    IL17A        [label="IL-17A"                 fillcolor="#FF7F24"]
    IL4_T        [label="IL-4"                   fillcolor="#EE7600"]
    IL6_T        [label="IL-6"                   fillcolor="#CD6600"]
    IL2_T        [label="IL-2\n(reduced in SLE)" fillcolor="#B85C00"]
    TGFbeta      [label="TGF-β"                  fillcolor="#FF9955"]
    Calcineurin  [label="Calcineurin\n(NFAT act.)" fillcolor="#FFB070"]
    NFAT_T       [label="NFAT"                   fillcolor="#FFC080"]
    mTOR_T       [label="mTOR\n(metabolic)"      fillcolor="#FFD090"]
    FoxP3        [label="FoxP3\n(Treg transcription\nfactor)" fillcolor="#FFE0A0"]
    RORgt        [label="RORγt\n(Th17 TF)"       fillcolor="#FFF0B0"]
    Tbet         [label="T-bet\n(Th1 TF)"        fillcolor="#FFFFA0"]
    JAK3         [label="JAK3\n(IL-2 signaling)" shape=rectangle fillcolor="#FFD070"]
    STAT3_T      [label="STAT3\n(Th17 axis)"     fillcolor="#FFCC60"]
    STAT5_T      [label="STAT5\n(IL-2 axis)"     fillcolor="#FFB850"]
  }

  /* ============================================================
     CLUSTER 5 — Complement System
  ============================================================ */
  subgraph cluster_Complement {
    label="Complement System"
    style=filled fillcolor="#EEF4FF" color="#1144AA" fontcolor="#000880" fontsize=11

    C1q          [label="C1q"                    fillcolor="#B0D0FF"]
    C1rs         [label="C1r/C1s"               fillcolor="#A0C0FF"]
    C4_c         [label="C4"                     fillcolor="#90B0FF"]
    C4b          [label="C4b"                    fillcolor="#80A0FF"]
    C2_c         [label="C2"                     fillcolor="#7090FF"]
    C3_c         [label="C3"                     fillcolor="#6080FF"]
    C3a          [label="C3a\n(anaphylatoxin)"   fillcolor="#5070EF"]
    C3b          [label="C3b\n(opsonin)"         fillcolor="#4060DF"]
    C5_c         [label="C5"                     fillcolor="#3050CF"]
    C5a          [label="C5a\n(anaphylatoxin)"   fillcolor="#2040BF"]
    C5b          [label="C5b"                    fillcolor="#1030AF"]
    MAC          [label="MAC\n(C5b-9)"           fillcolor="#0020AF" fontcolor=white]
    ClassPath    [label="Classical Pathway\n(C1q+IgG IC)" shape=rectangle fillcolor="#B8D0FF"]
    AltPath      [label="Alternative\nPathway"   shape=rectangle fillcolor="#C8D8FF"]
    LectPath     [label="Lectin Pathway\n(MBL)"  shape=rectangle fillcolor="#D8E8FF"]
    FcRIIA       [label="FcγRIIA\n(mono/neutro)" shape=rectangle fillcolor="#4169E1" fontcolor=white]
    FcRIII       [label="FcγRIII\n(NK/macro)"   shape=rectangle fillcolor="#0000CD" fontcolor=white]
    CR1_rec      [label="CR1\n(C3b receptor)"    shape=rectangle fillcolor="#00008B" fontcolor=white]
    C_deficiency [label="C1q/C2/C4\nGene Def."  shape=diamond fillcolor="#ADD8E6"]
    C4d_dep      [label="C4d Deposition\n(renal)" fillcolor="#87CEEB"]
    Factor_H     [label="Factor H\n(AltPath reg)" fillcolor="#6699FF"]
    Factor_B     [label="Factor B\n(AltPath)"    fillcolor="#7788FF"]
    Properdin    [label="Properdin\n(stabilizes)" fillcolor="#8877FF"]
    C3_tick      [label="C3 Tick-over"           fillcolor="#9966FF"]
  }

  /* ============================================================
     CLUSTER 6 — Lupus Nephritis
  ============================================================ */
  subgraph cluster_kidney {
    label="Lupus Nephritis (Organ Damage)"
    style=filled fillcolor="#FFFFF0" color="#A08020" fontcolor="#705010" fontsize=11

    IC_glom      [label="IC Deposition\n(Glomerulus)"     fillcolor="#F0E68C"]
    MesCell      [label="Mesangial Cell\nActivation"      fillcolor="#EEE8AA"]
    Endo_kid     [label="Glomerular\nEndothelial Injury"  fillcolor="#FAFAD2"]
    Podocyte     [label="Podocyte\nDysfunction"           fillcolor="#FFD700"]
    GBM_dam      [label="GBM Damage"                     fillcolor="#FFC200"]
    Proteinuria  [label="Proteinuria\n(UPCR↑)"           fillcolor="#FFB000"]
    GFR_dec      [label="eGFR Decline"                   fillcolor="#FFA000"]
    ISN_class    [label="ISN/RPS Class\n(I→VI)"          shape=rectangle fillcolor="#FF9000"]
    Mes_expand   [label="Mesangial\nExpansion"            fillcolor="#FF8000"]
    TIF          [label="Tubulo-interstitial\nFibrosis"   fillcolor="#FF7000"]
    ESRD         [label="ESRD\n(End-stage Renal)" fillcolor="#FF6000"]
    Creat_s      [label="Serum\nCreatinine↑"             fillcolor="#EE5500"]
    Neutro_kid   [label="Neutrophil\nInfiltration"        fillcolor="#DD4400"]
    TGFb_kid     [label="TGF-β\n(fibrosis driver)"       fillcolor="#CC3300"]
    VEGF_kid     [label="VEGF\n(mesangial)"               fillcolor="#BB2200"]
    IL6_kid      [label="IL-6\n(renal)"                   fillcolor="#AA1100"]
    Hematuria    [label="Hematuria"                      fillcolor="#FF4444"]
    Hypertension [label="Hypertension\n(renal)"           fillcolor="#EE3333"]
  }

  /* ============================================================
     CLUSTER 7 — Skin, CNS, CV Involvement
  ============================================================ */
  subgraph cluster_systemic {
    label="Multi-Organ Involvement"
    style=filled fillcolor="#F5F5F5" color="#555555" fontcolor="#222222" fontsize=11

    MalarRash    [label="Malar Rash\n(butterfly)" fillcolor="#FFB6C1"]
    DiscoidLE    [label="Discoid Lupus\n(CCLE)"   fillcolor="#FFC0CB"]
    Photosens    [label="Photosensitivity"        fillcolor="#FFD0D5"]
    SCLE         [label="Subacute CLE\n(Anti-Ro)" fillcolor="#FFAABB"]
    BBB_break    [label="BBB Disruption"          fillcolor="#D3D3D3"]
    AntiNMDAR    [label="Anti-NMDAR Ab\n(NPSLE)"  fillcolor="#C0C0C0"]
    NPSLE        [label="NPSLE\n(seizure/psychosis\n/cognitive)" fillcolor="#A9A9A9"]
    CVrisk       [label="Accelerated\nAtherosclerosis" fillcolor="#909090"]
    Endo_dysf    [label="Endothelial\nDysfunction" fillcolor="#808080"]
    Pericarditis [label="Pericarditis"            fillcolor="#787878"]
    aPL_ab       [label="aPL Antibodies\n(anti-phospholipid)" fillcolor="#B0B0B0"]
    Thrombosis_v [label="Thrombosis\n(APS)"       fillcolor="#989898"]
    Serositis    [label="Serositis\n(pleuritis/\npericarditis)" fillcolor="#D8D8D8"]
    Arthritis_s  [label="Arthritis\n(non-erosive)" fillcolor="#CCCCCC"]
    Alopecia     [label="Alopecia"                fillcolor="#BBBBBB"]
    Cytopenias   [label="Cytopenias\n(WBC/Plt/Hb)" fillcolor="#AAAAAA"]
    Fatigue      [label="Fatigue &\nMalaise"       fillcolor="#F0F0F0"]
  }

  /* ============================================================
     CLUSTER 8 — Drug PK/PD
  ============================================================ */
  subgraph cluster_drugs {
    label="Drug PK/PD Mechanisms"
    style=filled fillcolor="#E8FFE8" color="#007700" fontcolor="#003300" fontsize=11

    HCQ          [label="Hydroxychloroquine\n(HCQ)"         shape=rectangle fillcolor="#00C000" fontcolor=white]
    Belimumab_d  [label="Belimumab\n(anti-BAFF mAb)"        shape=rectangle fillcolor="#00A000" fontcolor=white]
    Anifrolumab  [label="Anifrolumab\n(anti-IFNAR1 mAb)"    shape=rectangle fillcolor="#009000" fontcolor=white]
    MMF_d        [label="Mycophenolate\nMofetil (MMF)"       shape=rectangle fillcolor="#008000" fontcolor=white]
    Voclosporin_d [label="Voclosporin\n(Calcineurin-inh)"    shape=rectangle fillcolor="#007000" fontcolor=white]
    Cycloph_d    [label="Cyclophosphamide\n(IV/oral)"        shape=rectangle fillcolor="#006000" fontcolor=white]
    AZA_d        [label="Azathioprine\n(AZA)"                shape=rectangle fillcolor="#005500" fontcolor=white]
    CS_d         [label="Corticosteroids\n(prednisone)"      shape=rectangle fillcolor="#005000" fontcolor=white]
    Tacrolimus_d [label="Tacrolimus\n(FK506)"                shape=rectangle fillcolor="#004000" fontcolor=white]
    Obinut_d     [label="Obinutuzumab\n(anti-CD20 mAb)"      shape=rectangle fillcolor="#003500" fontcolor=white]
    MPA_met      [label="MPA\n(active metabolite)"           fillcolor="#80FF80"]
    IMPDH_enz    [label="IMPDH\n(inosine monoph.\ndehydrogenase)" shape=diamond fillcolor="#60DF60"]
    Purine_inh   [label="Purine Synthesis\n↓ (lymphocytes)" fillcolor="#40BF40"]
    DNA_alk      [label="DNA Alkylation\n(Cycloph.)"         fillcolor="#20A020"]
    GR_rec       [label="Glucocorticoid\nReceptor (GR)"      shape=rectangle fillcolor="#008080" fontcolor=white]
    Lys_pH       [label="Lysosomal pH↑\n(HCQ)"              fillcolor="#00CED1"]
    FcRn_rec     [label="FcRn\n(IgG recycling)"             shape=rectangle fillcolor="#5F9EA0"]
    TMDD_BAFF    [label="TMDD\n(Belimumab-BAFF\ncomplex)"   shape=diamond fillcolor="#2E8B57"]
    CD20_b       [label="CD20\n(B-cell marker)"             shape=rectangle fillcolor="#3CB371"]
    ADA_d        [label="Anti-Drug Ab\n(ADA risk)"          fillcolor="#66CDAA"]
    HCQ_gut      [label="HCQ\nGut (Ka)"                     fillcolor="#B0FFB0"]
    HCQ_cent     [label="HCQ Central\n(Vd ~5000 L)"         fillcolor="#90EE90"]
    BELI_cent    [label="Belimumab\nCentral (PK)"           fillcolor="#70DD70"]
    BELI_periph  [label="Belimumab\nPeripheral"             fillcolor="#50CC50"]
    MMF_gut      [label="MMF\nGut (oral)"                   fillcolor="#30BB30"]
    MPA_cent     [label="MPA Central\n(PK)"                 fillcolor="#10AA10"]
    ANIF_cent    [label="Anifrolumab\nCentral (PK)"         fillcolor="#00BB88"]
  }

  /* ============================================================
     CLUSTER 9 — Biomarkers & Clinical Endpoints
  ============================================================ */
  subgraph cluster_endpoints {
    label="Biomarkers & Clinical Endpoints"
    style=filled fillcolor="#FFF0FF" color="#880088" fontcolor="#550055" fontsize=11

    SLEDAI2K     [label="SLEDAI-2K\n(activity score 0–105)" shape=rectangle fillcolor="#EE82EE"]
    BILAG        [label="BILAG\n(organ-based\nactivity)" shape=rectangle fillcolor="#DA70D6"]
    SLICC_dam    [label="SLICC Damage\nIndex"            shape=rectangle fillcolor="#C060C0"]
    dsDNA_titer  [label="Anti-dsDNA Titer\n(biomarker)"  fillcolor="#BA55D3"]
    C3_serum     [label="C3 Serum ↓\n(consumption)"     fillcolor="#9370DB"]
    C4_serum     [label="C4 Serum ↓"                    fillcolor="#8A2BE2"]
    ESR_v        [label="ESR\n(acute phase)"             fillcolor="#9932CC"]
    CRP_v        [label="CRP"                            fillcolor="#8B008B"]
    Lymphopenia  [label="Lymphopenia\n(<1000/µL)"        fillcolor="#800080"]
    Plt_low      [label="Thrombocytopenia\n(<100K/µL)"   fillcolor="#700070"]
    UPCR_ep      [label="UPCR\n(proteinuria endpoint)"  fillcolor="#600060"]
    IFNscore_ep  [label="IFN Score\n(gene expression)"  fillcolor="#500050" fontcolor=white]
    BAFF_ep      [label="BLyS/BAFF\nSerum Level"        fillcolor="#440044" fontcolor=white]
    SRI4         [label="SRI-4\n(≥4pt SLEDAI↓\n+no worsening)" shape=rectangle fillcolor="#4B0082" fontcolor=white]
    BICLA        [label="BICLA\nResponse"               shape=rectangle fillcolor="#3B0072" fontcolor=white]
    CR_renal     [label="Complete Renal\nResponse"       shape=rectangle fillcolor="#2B0062" fontcolor=white]
    PR_renal     [label="Partial Renal\nResponse"        shape=rectangle fillcolor="#1B0052" fontcolor=white]
    Flare_rate   [label="Flare Rate\n(severe)"           fillcolor="#0B0042" fontcolor=white]
    LLDAS        [label="LLDAS\n(low disease\nactivity state)" shape=rectangle fillcolor="#6B0066" fontcolor=white]
    Remission    [label="Remission\n(DORIS criteria)"    shape=rectangle fillcolor="#5B0055" fontcolor=white]
  }

  /* ============================================================
     EDGES — Cell Death & Antigen Release
  ============================================================ */
  UV_radiation  -> Apoptosis         [label="induces"]
  UV_radiation  -> Photosens         [label="→ skin reaction"]
  NETosis       -> NETs              [label="produces"]
  NETosis       -> PAD4              [label="activates"]
  PAD4          -> NETs              [label="citrullinates\nhistones"]
  ApopCells     -> Phago_defect      [label="if not cleared →"]
  Phago_defect  -> SecNecrosis       [label="leads to"]
  Apoptosis     -> Chromatin         [label="releases"]
  Apoptosis     -> HMGB1             [label="releases"]
  SecNecrosis   -> Chromatin         [label="releases"]
  SecNecrosis   -> HMGB1             [label="releases"]
  NETs          -> Chromatin         [label="DNA/histones"]
  NETs          -> HMGB1             [label="releases"]
  TREX1_def     -> mtDNA             [label="accumulates\ncytosol DNA"]
  mtDNA         -> cGAS_prot         [label="activates"]

  /* ============================================================
     EDGES — TLR/cGAS/STING → IFN
  ============================================================ */
  NETs          -> TLR7              [label="ssRNA"]
  NETs          -> TLR9              [label="CpG-DNA"]
  Chromatin     -> TLR9              [label="CpG-DNA"]
  HMGB1         -> TLR4             [label="danger signal"]
  TLR7          -> MyD88
  TLR9          -> MyD88
  TLR4          -> MyD88
  TLR4          -> TRIF_ad
  MyD88         -> IRF7
  MyD88         -> NF_kB
  MyD88         -> IRF5
  TRIF_ad       -> IRF3
  TRIF_ad       -> NF_kB
  cGAS_prot     -> cGAMP_mol
  cGAMP_mol     -> STING_prot
  STING_prot    -> IRF3              [label="activates"]
  STING_prot    -> NF_kB
  IRF3          -> IFNbeta           [label="→ transcription"]
  IRF7          -> IFNalpha          [label="→ transcription"]
  IRF7          -> IFNbeta
  IRF5          -> IFNalpha          [style=dashed]
  NF_kB         -> IL1beta_inn       [label="transcription"]
  NF_kB         -> TNFalpha_inn
  NF_kB         -> IL6_T             [label="NF-κB→IL-6"]
  NLRP3         -> IL1beta_inn       [label="cleaves\nproCasp1"]
  IFNalpha      -> IFNAR1
  IFNbeta       -> IFNAR1
  IFNAR1        -> IFNAR2            [label="heterodimerize"]
  IFNAR1        -> JAK1_ifn          [label="phospho"]
  IFNAR2        -> TYK2              [label="phospho"]
  JAK1_ifn      -> STAT1_ifn
  TYK2          -> STAT2_ifn
  STAT1_ifn     -> ISGF3
  STAT2_ifn     -> ISGF3
  IRF9          -> ISGF3
  ISGF3         -> ISGs              [label="ISRE-driven\ntranscription"]
  ISGs          -> IFNsig            [label="elevated"]
  IFNsig        -> pDC               [label="positive\nfeedback"]
  pDC           -> IFNalpha          [label="major\nproducer"]
  mDC           -> IL12              [label="produces"]
  mDC           -> TNFalpha_inn
  Mono_macro    -> IL1beta_inn
  Mono_macro    -> TNFalpha_inn
  Mono_macro    -> IL12
  Mono_macro    -> IL18
  IFNalpha      -> BAFF_mol          [label="upregulates\n(key link)"]
  IFNalpha      -> Mono_macro        [label="primes"]
  IFNsig        -> IFNscore_ep       [label="measured"]
