digraph BEX_QSP {
    graph [
        label="Bronchiectasis — Quantitative Systems Pharmacology Map\nVicious Cycle: Infection · Neutrophilic Inflammation · Mucociliary Dysfunction · Airway Remodeling · Drug PK/PD"
        fontname="Helvetica" fontsize=20 bgcolor="#F7F9FC"
        rankdir=TB splines=ortho nodesep=0.45 ranksep=0.75
        labelloc=t
    ]
    node [fontname="Helvetica" fontsize=9 style=filled shape=box]
    edge [fontname="Helvetica" fontsize=8 arrowsize=0.65]

    // ============================================================
    // 1. AETIOLOGY & PREDISPOSING CONDITIONS
    // ============================================================
    subgraph cluster_aetiology {
        label="Aetiology & Predisposing Conditions"
        style=filled fillcolor="#FFF3E0" color="#E65100"
        fontsize=12 fontcolor="#E65100"

        cf      [label="Cystic Fibrosis\n(CFTR mutation)" fillcolor="#FFB74D" shape=ellipse]
        postinf  [label="Post-Infectious\n(TB, Whooping Cough\nPneumonia, Measles)" fillcolor="#FF8A65" shape=ellipse]
        pid      [label="Primary Immune\nDeficiency\n(CVID, XLA)" fillcolor="#FFB74D" shape=ellipse]
        allergic [label="ABPA\n(Allergic\nBronchopulm.)" fillcolor="#FFB74D" shape=ellipse]
        autoimmune_cause [label="Rheumatoid\nArthritis, SLE\nSjögren" fillcolor="#FF8A65" shape=ellipse]
        ciliary_dyskin [label="Primary Ciliary\nDyskinesia (PCD)\nKartagener" fillcolor="#FFCC02" shape=ellipse]
        idiopathic [label="Idiopathic\n(~50% of cases)" fillcolor="#FFF9C4" shape=ellipse]
        gerd_cause [label="GERD / Aspiration\nRecurrent micro-\naspiration" fillcolor="#FF8A65" shape=ellipse]
        alpha1_anti [label="α1-Antitrypsin\nDeficiency" fillcolor="#FFB74D" shape=ellipse]
        ibd_assoc  [label="IBD-associated\n(UC, Crohn's)" fillcolor="#FFB74D" shape=ellipse]
    }

    // ============================================================
    // 2. MUCOCILIARY DEFENSE & DYSFUNCTION
    // ============================================================
    subgraph cluster_mucus {
        label="Mucociliary Defence & Dysfunction"
        style=filled fillcolor="#E3F2FD" color="#1565C0"
        fontsize=12 fontcolor="#1565C0"

        airway_surface [label="Airway Surface\nLiquid (ASL)\nPericiliary Layer" fillcolor="#90CAF9" shape=ellipse]
        cilia         [label="Airway Cilia\n(CBF ~12 Hz)" fillcolor="#64B5F6" shape=ellipse]
        mucin_gel     [label="Mucus Gel Layer\n(MUC5B / MUC5AC)" fillcolor="#42A5F5" shape=box]
        cftr_channel  [label="CFTR Cl– Channel\n(Fluid secretion)" fillcolor="#2196F3" shape=box fontcolor=white]
        enac          [label="ENaC\n(Na+ absorption)" fillcolor="#1E88E5" shape=box fontcolor=white]
        asl_depletion [label="ASL Depletion\n(Mucus\nConcentration ↑)" fillcolor="#1565C0" shape=hexagon fontcolor=white]
        mcc_failure   [label="Mucociliary\nClearance (MCC)\nImpairment" fillcolor="#0D47A1" shape=hexagon fontcolor=white]
        mucus_plug    [label="Mucus\nPlugging\nObstruction" fillcolor="#1565C0" shape=hexagon fontcolor=white]
        cilia_beat_freq [label="Ciliary Beat\nFrequency (CBF)\n↓ in infection" fillcolor="#90CAF9" shape=diamond]
        mucus_viscosity [label="Mucus Viscosity\n& Elasticity\n(G', G'')" fillcolor="#64B5F6" shape=diamond]
    }

    // ============================================================
    // 3. BACTERIAL PATHOBIOLOGY
    // ============================================================
    subgraph cluster_bacteria {
        label="Bacterial Pathobiology (Chronic Infection)"
        style=filled fillcolor="#E8F5E9" color="#1B5E20"
        fontsize=12 fontcolor="#1B5E20"

        pa        [label="Pseudomonas aeruginosa\n(Dominant pathogen)" fillcolor="#66BB6A" shape=ellipse]
        hi        [label="H. influenzae\n(Non-typeable)" fillcolor="#81C784" shape=ellipse]
        morax     [label="Moraxella catarrhalis" fillcolor="#A5D6A7" shape=ellipse]
        staph     [label="S. aureus /\nMRSA" fillcolor="#C8E6C9" shape=ellipse]
        mac       [label="M. avium Complex\n(NTM)" fillcolor="#DCEDC8" shape=ellipse]
        biofilm   [label="Bacterial Biofilm\nFormation\n(Alginate / Pel / Psl)" fillcolor="#388E3C" shape=hexagon fontcolor=white]
        quorum    [label="Quorum Sensing\n(las/rhl/pqs\nsystems)" fillcolor="#2E7D32" shape=box fontcolor=white]
        virulence [label="Virulence Factors\n(ExoS/T/U/Y\nLPS, flagellin)" fillcolor="#43A047" shape=box fontcolor=white]
        pili_adh  [label="Pili & Adhesins\n(Surface attachment)" fillcolor="#66BB6A" shape=box]
        resistance [label="Antibiotic\nResistance\nMechanisms" fillcolor="#1B5E20" shape=hexagon fontcolor=white]
        persistence [label="Persistent\nInfection\n(Low-metabolic\nstate cells)" fillcolor="#2E7D32" shape=box fontcolor=white]
        lps       [label="LPS / Endotoxin\n(TLR4 ligand)" fillcolor="#81C784" shape=box]
        flagellin [label="Flagellin\n(TLR5 ligand)" fillcolor="#A5D6A7" shape=box]
        dna_released [label="Extracellular\nDNA (eDNA)\nNeutrophil NETs" fillcolor="#C8E6C9" shape=box]
    }

    // ============================================================
    // 4. INNATE IMMUNITY & NEUTROPHILIC INFLAMMATION
    // ============================================================
    subgraph cluster_innate {
        label="Innate Immunity & Neutrophilic Inflammation (Central)"
        style=filled fillcolor="#FCE4EC" color="#B71C1C"
        fontsize=12 fontcolor="#B71C1C"

        ptn [label="Pattern Recognition\n(TLR2, TLR4, TLR5\nNOD1/2, NLRPs)" fillcolor="#EF9A9A" shape=box]
        nfkb [label="NF-κB Signalling\n(Master regulator)" fillcolor="#E53935" shape=hexagon fontcolor=white]
        mapk [label="MAPK / p38\nSignaling Cascade" fillcolor="#EF5350" shape=box fontcolor=white]
        neutrophil_recruit [label="Neutrophil\nRecruitment\n(CXCL8 / IL-8)" fillcolor="#F44336" shape=hexagon fontcolor=white]
        neutrophil [label="Airway Neutrophil\n(Key effector)" fillcolor="#C62828" shape=ellipse fontcolor=white]
        neti [label="NETs\n(Neutrophil\nExtracellular Traps)" fillcolor="#B71C1C" shape=hexagon fontcolor=white]
        ne   [label="Neutrophil Elastase\n(NE) — Serine\nProtease" fillcolor="#C62828" shape=hexagon fontcolor=white]
        mpo  [label="Myeloperoxidase\n(MPO)\nOxidative burst" fillcolor="#E53935" shape=box fontcolor=white]
        mmp8 [label="MMP-8 / MMP-9\n(Matrix\nMetalloprotease)" fillcolor="#EF5350" shape=box fontcolor=white]
        ros  [label="Reactive Oxygen\nSpecies (ROS)\nSuperoxide, H2O2" fillcolor="#F44336" shape=box fontcolor=white]
        macro [label="Airway\nMacrophage\n(M1/M2)" fillcolor="#EF9A9A" shape=ellipse]
        nlrp3 [label="NLRP3\nInflammasome" fillcolor="#C62828" shape=box fontcolor=white]
        il1b  [label="IL-1β\n(mature, active)" fillcolor="#EF9A9A" shape=box]
        il18  [label="IL-18\n(inflammasome)" fillcolor="#EF9A9A" shape=box]
        dc_airway [label="Dendritic Cells\n(Airway DCs)" fillcolor="#FFCDD2" shape=ellipse]
    }

    // ============================================================
    // 5. CYTOKINE NETWORK
    // ============================================================
    subgraph cluster_cytokines {
        label="Cytokine & Chemokine Network"
        style=filled fillcolor="#FFF8E1" color="#F57F17"
        fontsize=12 fontcolor="#F57F17"

        il8    [label="IL-8 / CXCL8\n(Neutrophil\nchemokine)" fillcolor="#FFE082" shape=box]
        il6    [label="IL-6\n(Systemic\ninflammation)" fillcolor="#FFD54F" shape=box]
        il17   [label="IL-17A/F\n(Neutrophil\nrecruitment)" fillcolor="#FFCA28" shape=box]
        tnfa   [label="TNF-α\n(Macrophage\neffector)" fillcolor="#FFB300" shape=box]
        il10   [label="IL-10\n(Anti-inflam\nsuppressor)" fillcolor="#FFC107" shape=box]
        tgfb   [label="TGF-β1\n(Fibrosis /\nRemodeling)" fillcolor="#FF8F00" shape=box fontcolor=white]
        gcsf   [label="G-CSF / GM-CSF\n(Myeloid\nproduction)" fillcolor="#FFE082" shape=box]
        cxcl1  [label="CXCL1 / CXCL2\n(Chemokines)" fillcolor="#FFCA28" shape=box]
        ccl2   [label="CCL2 / MCP-1\n(Monocyte\nattract)" fillcolor="#FFB300" shape=box]
        il33   [label="IL-33 / TSLP\n(Alarmin)" fillcolor="#FFF176" shape=box]
        lta4   [label="LTB4\n(Leukotriene B4)\nPotent chemoattract" fillcolor="#FFD600" shape=box fontcolor=white]
    }

    // ============================================================
    // 6. ADAPTIVE IMMUNITY
    // ============================================================
    subgraph cluster_adaptive {
        label="Adaptive Immune Response"
        style=filled fillcolor="#F3E5F5" color="#4A148C"
        fontsize=12 fontcolor="#4A148C"

        cd4_th17 [label="CD4+ Th17\nCells (IL-17\nProducer)" fillcolor="#CE93D8" shape=ellipse]
        cd4_th2  [label="CD4+ Th2\n(Allergy/ABPA)" fillcolor="#BA68C8" shape=ellipse]
        cd8_t    [label="CD8+ Cytotoxic\nT Cells" fillcolor="#9C27B0" shape=ellipse fontcolor=white]
        treg_a   [label="Treg\n(Immunosuppression)" fillcolor="#7B1FA2" shape=ellipse fontcolor=white]
        bcell_a  [label="B Cells\n(Antibody\nproduction)" fillcolor="#CE93D8" shape=ellipse]
        igg      [label="Serum IgG\n(Opsonization)" fillcolor="#E1BEE7" shape=box]
        iga_sec  [label="Secretory IgA\n(Mucosal\nimmunity)" fillcolor="#CE93D8" shape=box]
        cvid_igg [label="Low IgG / IgA\n(in CVID/XLA)" fillcolor="#7B1FA2" shape=box fontcolor=white]
    }

    // ============================================================
    // 7. AIRWAY STRUCTURAL CHANGES
    // ============================================================
    subgraph cluster_airway {
        label="Airway Structural Remodeling & Dilation"
        style=filled fillcolor="#E8EAF6" color="#283593"
        fontsize=12 fontcolor="#283593"

        airway_dilation [label="Bronchial Dilation\n(Irreversible)\nBronchiectasis\nDefined Lesion" fillcolor="#7986CB" shape=hexagon fontcolor=white]
        airway_wall_thick [label="Airway Wall\nThickening\n(CT-measured)" fillcolor="#9FA8DA" shape=box]
        cartilage_destr [label="Cartilage &\nElastin Destruction\n(NE / MMP)" fillcolor="#5C6BC0" shape=box fontcolor=white]
        collagen_deposition [label="Collagen\nDeposition\n(TGF-β driven)" fillcolor="#3949AB" shape=box fontcolor=white]
        fibrosis_peri  [label="Peribronchial\nFibrosis" fillcolor="#283593" shape=box fontcolor=white]
        airway_hyper   [label="Airway\nHyperreactivity\n(AHR)" fillcolor="#9FA8DA" shape=box]
        bronchiolar_ob [label="Bronchiolar\nObstruction\n(Small airway)" fillcolor="#7986CB" shape=box fontcolor=white]
        air_trapping   [label="Air Trapping\n& Hyperinflation" fillcolor="#3F51B5" shape=box fontcolor=white]
        vascular_remod [label="Vascular\nRemodeling\n(Bronchial artery\nhypertrophy)" fillcolor="#5C6BC0" shape=box fontcolor=white]
        hemoptysis     [label="Hemoptysis\n(Erosion of\nbronchial artery)" fillcolor="#283593" shape=hexagon fontcolor=white]
    }

    // ============================================================
    // 8. PROTEASE / ANTI-PROTEASE IMBALANCE
    // ============================================================
    subgraph cluster_protease {
        label="Protease–Antiprotease Imbalance"
        style=filled fillcolor="#ECEFF1" color="#37474F"
        fontsize=12 fontcolor="#37474F"

        ne_act    [label="Neutrophil Elastase\n(Active NE)\nElastin cleavage" fillcolor="#78909C" shape=hexagon fontcolor=white]
        mmp9_act  [label="Active MMP-9\n(Gelatinase B)" fillcolor="#607D8B" shape=box fontcolor=white]
        mmp8_act  [label="Active MMP-8\n(Collagenase 2)" fillcolor="#546E7A" shape=box fontcolor=white]
        ctg       [label="Cathepsin G\n(Serine protease)" fillcolor="#78909C" shape=box fontcolor=white]
        pr3       [label="Proteinase 3\n(PR3)" fillcolor="#607D8B" shape=box fontcolor=white]
        a1at      [label="α1-Antitrypsin\n(SERPINA1)\nNE inhibitor" fillcolor="#90A4AE" shape=box]
        slpi      [label="SLPI\n(Secretory\nLeukoprotease\nInhibitor)" fillcolor="#B0BEC5" shape=box]
        timp      [label="TIMP-1/2\n(MMP inhibitors)" fillcolor="#CFD8DC" shape=box]
        ecm       [label="ECM Degradation\n(Elastin, Collagen\nFibronectin)" fillcolor="#455A64" shape=hexagon fontcolor=white]
        ecm_frag  [label="ECM Fragments\n(DAMP signals)" fillcolor="#607D8B" shape=box fontcolor=white]
    }

    // ============================================================
    // 9. LUNG FUNCTION & CLINICAL ENDPOINTS
    // ============================================================
    subgraph cluster_lung_function {
        label="Lung Function & Pulmonary Physiology"
        style=filled fillcolor="#F9FBE7" color="#827717"
        fontsize=12 fontcolor="#827717"

        fev1    [label="FEV1\n(mL, % predicted)" fillcolor="#DCE775" shape=diamond]
        fvc     [label="FVC\n(mL, % predicted)" fillcolor="#D4E157" shape=diamond]
        fev1_fvc [label="FEV1/FVC Ratio\n(<0.7 = airflow\nobstruction)" fillcolor="#CDDC39" shape=diamond]
        fef25   [label="FEF25-75%\n(Small airway\nfunction)" fillcolor="#C6CC33" shape=diamond]
        rvtlc   [label="RV/TLC Ratio\n(Air trapping)" fillcolor="#AFB42B" shape=diamond]
        dlco    [label="DLCO\n(Gas transfer)" fillcolor="#9E9D24" shape=diamond]
        spo2    [label="SpO2 / PaO2\n(Oxygenation)" fillcolor="#827717" shape=diamond fontcolor=white]
        exacerbation [label="Exacerbation\n(Acute worsening\n≥3 per year = severe)" fillcolor="#F57F17" shape=hexagon fontcolor=white]
        hospitalization [label="Hospitalization\n& ICU Admission" fillcolor="#BF360C" shape=hexagon fontcolor=white]
        mortality [label="Mortality\n(Long-term\noutcome)" fillcolor="#870000" shape=hexagon fontcolor=white]
        qol      [label="Quality of Life\n(SGRQ, QOL-B)" fillcolor="#CDDC39" shape=diamond]
        exac_freq [label="Exacerbation\nFrequency\n(per year)" fillcolor="#F9A825" shape=diamond]
    }

    // ============================================================
    // 10. PK/PD: ANTIBIOTICS (Systemic)
    // ============================================================
    subgraph cluster_ab_sys {
        label="Drug PK/PD: Systemic Antibiotics"
        style=filled fillcolor="#E1F5FE" color="#01579B"
        fontsize=12 fontcolor="#01579B"

        pip_taz  [label="Piperacillin-\nTazobactam\n(Anti-Pseudomonal)" fillcolor="#81D4FA" shape=box]
        mero     [label="Meropenem\n(Carbapenem\n1-2g q8h IV)" fillcolor="#4FC3F7" shape=box]
        ceft     [label="Ceftazidime /\nCefepime (β-lactam)" fillcolor="#29B6F6" shape=box]
        cipro    [label="Ciprofloxacin\n(FQ oral/IV)" fillcolor="#03A9F4" shape=box fontcolor=white]
        trigen   [label="Tobramycin\n(Aminoglycoside)" fillcolor="#0288D1" shape=box fontcolor=white]
        colistin [label="Colistin\n(Polymyxin E\nSalvage)" fillcolor="#01579B" shape=box fontcolor=white]
        ab_gut   [label="GI Absorption\n(Oral ABx)" fillcolor="#81D4FA" shape=box]
        ab_central [label="Plasma\nCompartment\n(Systemic ABx)" fillcolor="#4FC3F7" shape=box fontcolor=white]
        ab_lung  [label="Lung/ELF\nConcentration\n(ELF = 10-50× plasma\nfor macrolides)" fillcolor="#0288D1" shape=box fontcolor=white]
        fT_mic   [label="fT>MIC\n(β-lactam PD target\n%T>MIC ≥40-50%)" fillcolor="#03A9F4" shape=diamond fontcolor=white]
        auc_mic  [label="AUC/MIC\n(FQ/aminoglycoside\nPD target ≥125)" fillcolor="#0288D1" shape=diamond fontcolor=white]
        mic_pa   [label="PA MIC\n(Breakpoint\nECOFF)" fillcolor="#01579B" shape=diamond fontcolor=white]
        pkpd_para_ab [label="ABx PK Params\nCipro: Vd 2-3L/kg\nt½ 3-5h, F ~70%\nMero: Vd 0.25L/kg\nt½ 1h (renal)" fillcolor="#B3E5FC" shape=diamond]
    }

    // ============================================================
    // 11. PK/PD: INHALED ANTIBIOTICS
    // ============================================================
    subgraph cluster_inh_ab {
        label="Drug PK/PD: Inhaled Antibiotics"
        style=filled fillcolor="#E8F5E9" color="#1B5E20"
        fontsize=12 fontcolor="#1B5E20"

        tobra_inh [label="Inhaled\nTobramycin\n(TIP 300mg BID)" fillcolor="#A5D6A7" shape=box]
        aztr_inh  [label="Inhaled\nAztreonam\n(AZLI 75mg TID)" fillcolor="#81C784" shape=box]
        colist_inh [label="Inhaled Colistin\n(1-2MU BID)" fillcolor="#66BB6A" shape=box]
        cipro_inh  [label="Inhaled Cipro\n(32mg BID DPI)" fillcolor="#43A047" shape=box fontcolor=white]
        inh_deposit [label="Airway Deposition\n(MMAD 2-5µm)\n(Central + Peripheral)" fillcolor="#81C784" shape=box]
        inh_mucus  [label="Drug Diffusion\nThrough Mucus\n(Reduced in BEX)" fillcolor="#A5D6A7" shape=box]
        inh_biofilm [label="Biofilm\nPenetration\n(Limited by EPS\nmatrix)" fillcolor="#388E3C" shape=box fontcolor=white]
        inh_elim   [label="Mucociliary &\nEnzymatic\nElimination" fillcolor="#4CAF50" shape=box]
        local_conc [label="Local Sputum\nConcentration\n(High local\nexposure)" fillcolor="#2E7D32" shape=diamond fontcolor=white]
        inh_sys_abs [label="Systemic\nAbsorption\n(Minimal ~10%)" fillcolor="#C8E6C9" shape=box]
        pkpd_inh_ab [label="Inhaled ABx PK\nTobra peak ELF\n>1000 µg/mL\nVd minimal" fillcolor="#DCEDC8" shape=diamond]
    }

    // ============================================================
    // 12. PK/PD: AZITHROMYCIN (Anti-inflammatory)
    // ============================================================
    subgraph cluster_azithro {
        label="Drug PK/PD: Azithromycin (Long-term Anti-inflammatory)"
        style=filled fillcolor="#FFF3E0" color="#E65100"
        fontsize=12 fontcolor="#E65100"

        azithro_dose [label="Azithromycin\n250mg 3×/wk or\n500mg daily\n(EMBRACE, BLESS)" fillcolor="#FFB74D" shape=box]
        azithro_gut  [label="GI Absorption\nF ~37%\nFood reduces" fillcolor="#FFCC80" shape=box]
        azithro_central [label="Plasma\nAzithromycin\nVd ~31 L/kg (!)" fillcolor="#FF9800" shape=box fontcolor=white]
        azithro_tissue [label="Tissue / Lung\nAccumulation\n(t½ 68h\n2-5d clearance)" fillcolor="#F57C00" shape=box fontcolor=white]
        azithro_pmn   [label="Neutrophil\nIntracellular\nConc. >100× plasma" fillcolor="#E65100" shape=hexagon fontcolor=white]
        azithro_antiinflam [label="Anti-inflammatory\nMechanisms\n(Non-macrolide)" fillcolor="#BF360C" shape=hexagon fontcolor=white]
        azithro_lta4_inh  [label="↓ LTB4\nRelease" fillcolor="#FF8A65" shape=box]
        azithro_il8_inh   [label="↓ IL-8 / CXCL8\nRelease" fillcolor="#FFB74D" shape=box]
        azithro_qs_inh    [label="Quorum Sensing\nInhibition\n(Sub-inhibitory\nconc.)" fillcolor="#FF7043" shape=box fontcolor=white]
        azithro_biofilm_inh [label="Biofilm\nDisruption\n(Alginate↓)" fillcolor="#E64A19" shape=box fontcolor=white]
        azithro_mucocil   [label="↑ Mucociliary\nClearance\n(Controversial)" fillcolor="#FF5722" shape=box fontcolor=white]
        azithro_pkparam   [label="AZM PK Params\nVd: 31 L/kg\nt½: 68h\nF: 37%\nCYP3A4 substrate" fillcolor="#FFE0B2" shape=diamond]
        azithro_qt [label="QTc Prolongation\nRisk\n(Cardiac safety)" fillcolor="#FF5722" shape=box fontcolor=white]
        azithro_resist [label="Macrolide Resistance\nNTM induction\n(Monitoring needed)" fillcolor="#BF360C" shape=box fontcolor=white]
    }

    // ============================================================
    // 13. PK/PD: MUCOACTIVE THERAPIES
    // ============================================================
    subgraph cluster_mucoactive {
        label="Drug PK/PD: Mucoactive & Airway Clearance Therapies"
        style=filled fillcolor="#F3E5F5" color="#4A148C"
        fontsize=12 fontcolor="#4A148C"

        dnase [label="Dornase Alfa\n(rhDNase / Pulmozyme\n2.5mg daily inh)" fillcolor="#CE93D8" shape=box]
        hs_saline [label="Hypertonic Saline\n(7% NaCl 4mL BID)\n(HINT trial)" fillcolor="#AB47BC" shape=box fontcolor=white]
        mannitol [label="Inhaled Mannitol\n(400mg BID\nBronchitol)" fillcolor="#9C27B0" shape=box fontcolor=white]
        nac [label="N-Acetylcysteine\n(NAC 600mg TID)" fillcolor="#BA68C8" shape=box]
        erdosteine [label="Erdosteine\n(Thiol-based\nmucolytic)" fillcolor="#CE93D8" shape=box]
        osm_effect [label="Osmotic Effect\n(ASL Hydration\n→ ↑MCC)" fillcolor="#7B1FA2" shape=box fontcolor=white]
        dna_digest [label="eDNA Digestion\n(NETosis products\n↓ mucus viscosity)" fillcolor="#6A1B9A" shape=box fontcolor=white]
        oppt [label="Airway Clearance\nPhysiotherapy\n(ACBT, OPEP,\nAutogenic Drainage)" fillcolor="#4A148C" shape=box fontcolor=white]
        mucocil_enhance [label="Enhanced\nMucociliary\nTransport" fillcolor="#9C27B0" shape=diamond fontcolor=white]
    }

    // ============================================================
    // 14. CFTR MODULATORS (CF-specific)
    // ============================================================
    subgraph cluster_cftr_mod {
        label="CFTR Modulators (CF-associated Bronchiectasis)"
        style=filled fillcolor="#E0F7FA" color="#006064"
        fontsize=12 fontcolor="#006064"

        lumacaftor [label="Lumacaftor\n(VX-809\nCFTR corrector)" fillcolor="#80DEEA" shape=box]
        ivacaftor  [label="Ivacaftor\n(VX-770\nCFTR potentiator)" fillcolor="#4DD0E1" shape=box]
        tezacaftor [label="Tezacaftor\n(VX-661\ncorrector)" fillcolor="#26C6DA" shape=box]
        elexacaftor [label="Elexacaftor\n(VX-445 next-gen\ncorrector)" fillcolor="#00BCD4" shape=box fontcolor=white]
        triple_combo [label="Triple Therapy\n(ETI: Elexacaftor\n+Tezacaftor\n+Ivacaftor)" fillcolor="#00838F" shape=hexagon fontcolor=white]
        cftr_rescue [label="CFTR Protein\nFolding Rescue\n(↑Surface expression)" fillcolor="#006064" shape=box fontcolor=white]
        cftr_activity [label="CFTR Cl–\nChannel Activity\n(↑Open probability)" fillcolor="#00838F" shape=box fontcolor=white]
        asl_restored [label="ASL Volume\nRestoration\n(pcASL → normal)" fillcolor="#006064" shape=diamond fontcolor=white]
        sweat_cl [label="Sweat Chloride\n(Biomarker\n<60 mEq/L target)" fillcolor="#4DD0E1" shape=diamond]
        cftr_pk [label="ETI PK Params\nElexacaftor t½: 19h\nTezacaftor t½: 15h\nIvacaftor t½: 12h" fillcolor="#B2EBF2" shape=diamond]
    }

    // ============================================================
    // 15. BIOMARKERS
    // ============================================================
    subgraph cluster_biomarkers {
        label="Biomarkers & Monitoring"
        style=filled fillcolor="#FBE9E7" color="#BF360C"
        fontsize=12 fontcolor="#BF360C"

        crp      [label="CRP / ESR\n(Systemic\ninflammation)" fillcolor="#FFAB91" shape=diamond]
        wbc      [label="WBC / Neutrophil\nCount" fillcolor="#FF8A65" shape=diamond]
        sputum_cult [label="Sputum Culture\n& Sensitivity\n(3-monthly)" fillcolor="#FF7043" shape=diamond]
        sputum_vol  [label="24h Sputum\nVolume (mL)" fillcolor="#FF8A65" shape=diamond]
        ne_sputum   [label="Sputum NE\nActivity\n(µg/mL)" fillcolor="#F44336" shape=diamond fontcolor=white]
        il8_sputum  [label="Sputum IL-8\n(ng/mL)" fillcolor="#FF7043" shape=diamond fontcolor=white]
        ct_scan     [label="HRCT\n(Reiff / BSI\nScoring)" fillcolor="#FF5722" shape=box fontcolor=white]
        bsi_score   [label="Bronchiectasis\nSeverity Index (BSI)\n(0-26 scale)" fillcolor="#BF360C" shape=hexagon fontcolor=white]
        faced       [label="FACED Score\n(Prognostic)" fillcolor="#E64A19" shape=box fontcolor=white]
        microbiome  [label="Airway Microbiome\n(Diversity, Pathogens\n16S rRNA)" fillcolor="#FF6E40" shape=box]
        procalciton [label="Procalcitonin\n(Exacerbation\nbiomarker)" fillcolor="#FFAB91" shape=diamond]
        fibrinogen  [label="Fibrinogen\n(Exacerbation)" fillcolor="#FF8A65" shape=diamond]
    }

    // ============================================================
    // EDGES — PATHOPHYSIOLOGY
    // ============================================================

    // Aetiology → MCC failure
    cf -> cftr_channel [color="#1565C0" label="mutation\n→ dysfunct."]
    cf -> cilia [color="#1565C0" style=dashed]
    ciliary_dyskin -> cilia [color="#1565C0" arrowhead=tee label="CBF=0"]
    postinf -> mcc_failure [color="#0D47A1" style=dashed]
    pid -> cvid_igg [color="#4A148C"]
    gerd_cause -> bacteria [color="#1B5E20" style=dashed label="aspiration"]
    alpha1_anti -> a1at [color="#37474F" arrowhead=tee label="↓levels"]

    // Mucus layer
    airway_surface -> cilia [color="#1565C0"]
    cilia -> cilia_beat_freq [color="#1565C0"]
    cilia_beat_freq -> mcc_failure [color="#0D47A1" arrowhead=tee label="when↓"]
    cftr_channel -> airway_surface [color="#1565C0" label="Cl– + water"]
    enac -> airway_surface [color="#1565C0" arrowhead=tee label="Na+ abs\n→ dehydrate"]
    asl_depletion -> mcc_failure [color="#0D47A1"]
    asl_depletion -> mucus_viscosity [color="#1565C0"]
    mucus_plug -> mucus_viscosity [color="#1565C0"]
    mcc_failure -> mucus_plug [color="#0D47A1"]
    mucin_gel -> mucus_viscosity [color="#1565C0"]

    // Bacteria
    mcc_failure -> pa [color="#1B5E20" label="colonization"]
    mcc_failure -> hi [color="#1B5E20"]
    mucus_plug -> pa [color="#1B5E20"]
    pa -> biofilm [color="#2E7D32"]
    pa -> quorum [color="#2E7D32"]
    pa -> virulence [color="#2E7D32"]
    pa -> pili_adh [color="#2E7D32"]
    hi -> lps [color="#2E7D32"]
    pa -> lps [color="#2E7D32"]
    pa -> flagellin [color="#2E7D32"]
    quorum -> virulence [color="#2E7D32"]
    quorum -> biofilm [color="#2E7D32" label="promotes"]
    biofilm -> resistance [color="#1B5E20"]
    biofilm -> persistence [color="#1B5E20"]
    dna_released -> biofilm [color="#2E7D32" label="stabilizes"]

    // Innate Immunity
    lps -> ptn [color="#B71C1C" label="TLR4"]
    flagellin -> ptn [color="#B71C1C" label="TLR5"]
    ecm_frag -> ptn [color="#B71C1C" label="DAMP"]
    ptn -> nfkb [color="#B71C1C"]
    ptn -> mapk [color="#B71C1C"]
    nfkb -> il8 [color="#F57F17"]
    nfkb -> tnfa [color="#F57F17"]
    nfkb -> il6 [color="#F57F17"]
    nfkb -> gcsf [color="#F57F17"]
    mapk -> il8 [color="#F57F17"]
    nfkb -> neutrophil_recruit [color="#B71C1C"]
    il8 -> neutrophil_recruit [color="#B71C1C"]
    lta4 -> neutrophil_recruit [color="#B71C1C"]
    cxcl1 -> neutrophil_recruit [color="#B71C1C"]
    neutrophil_recruit -> neutrophil [color="#C62828"]
    neutrophil -> ne [color="#C62828"]
    neutrophil -> mpo [color="#C62828"]
    neutrophil -> mmp8 [color="#C62828"]
    neutrophil -> ros [color="#C62828"]
    neutrophil -> neti [color="#C62828"]
    neti -> dna_released [color="#1B5E20"]
    neti -> ne_act [color="#37474F"]
    ne -> ne_act [color="#37474F"]
    mmp8 -> mmp8_act [color="#37474F"]
    mmp8 -> mmp9_act [color="#37474F"]
    macro -> nlrp3 [color="#B71C1C"]
    nlrp3 -> il1b [color="#F57F17"]
    nlrp3 -> il18 [color="#F57F17"]
    macro -> tnfa [color="#F57F17"]
    macro -> lta4 [color="#F57F17"]
    macro -> ccl2 [color="#F57F17"]
    dc_airway -> cd4_th17 [color="#4A148C" label="antigen pres."]

    // Cytokines
    il8 -> neutrophil_recruit [color="#B71C1C"]
    tnfa -> nfkb [color="#B71C1C" label="amplify"]
    il6 -> gcsf [color="#F57F17"]
    gcsf -> neutrophil_recruit [color="#B71C1C"]
    il17 -> il8 [color="#F57F17" label="↑CXCL8"]
    il33 -> macro [color="#F57F17"]
    il10 -> nfkb [color="#F57F17" arrowhead=tee label="suppresses"]
    tgfb -> collagen_deposition [color="#283593"]
    tgfb -> fibrosis_peri [color="#283593"]
    lta4 -> ros [color="#B71C1C"]

    // Adaptive Immunity
    cd4_th17 -> il17 [color="#4A148C"]
    cd4_th2 -> il33 [color="#4A148C"]
    cd8_t -> macro [color="#4A148C"]
    bcell_a -> igg [color="#4A148C"]
    bcell_a -> iga_sec [color="#4A148C"]
    igg -> macro [color="#4A148C" label="opsonize"]
    cvid_igg -> igg [color="#4A148C" arrowhead=tee label="↓IgG"]

    // Protease-Antiprotease
    ne_act -> a1at [color="#37474F" arrowhead=tee label="consumes"]
    ne_act -> slpi [color="#37474F" arrowhead=tee label="cleaves"]
    ne_act -> ecm [color="#37474F"]
    ne_act -> mcc_failure [color="#0D47A1" arrowhead=tee label="damages cilia"]
    mmp9_act -> ecm [color="#37474F"]
    mmp8_act -> ecm [color="#37474F"]
    ctg -> ecm [color="#37474F"]
    pr3 -> ecm [color="#37474F"]
    ecm -> ecm_frag [color="#37474F"]
    ecm -> cartilage_destr [color="#283593"]
    a1at -> ne_act [color="#37474F" arrowhead=tee label="inhibits"]
    slpi -> ne_act [color="#37474F" arrowhead=tee label="inhibits"]
    timp -> mmp9_act [color="#37474F" arrowhead=tee]
    timp -> mmp8_act [color="#37474F" arrowhead=tee]

    // Structural Remodeling
    cartilage_destr -> airway_dilation [color="#283593"]
    collagen_deposition -> airway_wall_thick [color="#283593"]
    fibrosis_peri -> airway_wall_thick [color="#283593"]
    airway_wall_thick -> airway_hyper [color="#283593"]
    airway_dilation -> bronchiolar_ob [color="#283593"]
    bronchiolar_ob -> air_trapping [color="#283593"]
    vascular_remod -> hemoptysis [color="#283593"]
    airway_dilation -> vascular_remod [color="#283593" style=dashed]

    // Lung function impact
    mucus_plug -> fev1 [color="#827717" arrowhead=tee label="obstruct"]
    air_trapping -> fev1_fvc [color="#827717" arrowhead=tee]
    airway_dilation -> fev1 [color="#827717" arrowhead=tee]
    airway_hyper -> fev1 [color="#827717" arrowhead=tee style=dashed]
    exacerbation -> fev1 [color="#827717" arrowhead=tee label="acute↓"]
    fev1 -> exac_freq [color="#827717" arrowhead=tee label="low FEV1\n→ more exac"]
    exacerbation -> hospitalization [color="#827717"]
    exacerbation -> mortality [color="#827717" style=dashed]
    bsi_score -> mortality [color="#BF360C" style=dashed]

    // Biomarkers
    neutrophil -> wbc [color="#BF360C"]
    il6 -> crp [color="#BF360C"]
    il1b -> procalciton [color="#BF360C" style=dashed]
    ne_act -> ne_sputum [color="#BF360C"]
    il8 -> il8_sputum [color="#BF360C"]
    pa -> sputum_cult [color="#BF360C"]
    hi -> sputum_cult [color="#BF360C"]
    airway_dilation -> ct_scan [color="#BF360C"]
    airway_wall_thick -> ct_scan [color="#BF360C"]
    ct_scan -> bsi_score [color="#BF360C"]
    bsi_score -> faced [color="#BF360C"]
    sputum_vol -> bsi_score [color="#BF360C" style=dashed]

    // ============================================================
    // EDGES — DRUG PK/PD
    // ============================================================

    // Systemic ABx PK/PD
    cipro -> ab_gut [color="#01579B"]
    pip_taz -> ab_central [color="#01579B"]
    mero -> ab_central [color="#01579B"]
    ceft -> ab_central [color="#01579B"]
    trigen -> ab_central [color="#01579B"]
    colistin -> ab_central [color="#01579B"]
    ab_gut -> ab_central [color="#01579B"]
    ab_central -> ab_lung [color="#01579B"]
    ab_lung -> fT_mic [color="#01579B"]
    ab_lung -> auc_mic [color="#01579B"]
    fT_mic -> pa [color="#01579B" arrowhead=tee label="bactericidal"]
    auc_mic -> pa [color="#01579B" arrowhead=tee]
    mic_pa -> fT_mic [color="#01579B" style=dashed]
    mic_pa -> auc_mic [color="#01579B" style=dashed]
    resistance -> mic_pa [color="#1B5E20" label="↑MIC"]
    ab_lung -> pkpd_para_ab [color="#01579B" style=dashed]

    // Inhaled ABx
    tobra_inh -> inh_deposit [color="#1B5E20"]
    aztr_inh -> inh_deposit [color="#1B5E20"]
    colist_inh -> inh_deposit [color="#1B5E20"]
    cipro_inh -> inh_deposit [color="#1B5E20"]
    inh_deposit -> inh_mucus [color="#1B5E20"]
    inh_mucus -> inh_biofilm [color="#1B5E20"]
    inh_biofilm -> local_conc [color="#1B5E20"]
    local_conc -> pa [color="#1B5E20" arrowhead=tee label="direct\nkilling"]
    inh_deposit -> inh_elim [color="#1B5E20"]
    inh_deposit -> inh_sys_abs [color="#1B5E20"]
    inh_sys_abs -> ab_central [color="#01579B" style=dashed label="small\nfraction"]
    local_conc -> pkpd_inh_ab [color="#1B5E20" style=dashed]

    // Azithromycin
    azithro_dose -> azithro_gut [color="#E65100"]
    azithro_gut -> azithro_central [color="#E65100"]
    azithro_central -> azithro_tissue [color="#E65100"]
    azithro_tissue -> azithro_pmn [color="#E65100"]
    azithro_pmn -> azithro_antiinflam [color="#E65100"]
    azithro_antiinflam -> azithro_lta4_inh [color="#E65100"]
    azithro_antiinflam -> azithro_il8_inh [color="#E65100"]
    azithro_antiinflam -> azithro_qs_inh [color="#E65100"]
    azithro_antiinflam -> azithro_biofilm_inh [color="#E65100"]
    azithro_antiinflam -> azithro_mucocil [color="#E65100"]
    azithro_lta4_inh -> lta4 [color="#F57F17" arrowhead=tee label="↓"]
    azithro_il8_inh -> il8 [color="#F57F17" arrowhead=tee label="↓"]
    azithro_qs_inh -> quorum [color="#1B5E20" arrowhead=tee label="↓"]
    azithro_biofilm_inh -> biofilm [color="#1B5E20" arrowhead=tee label="partial↓"]
    azithro_mucocil -> mcc_failure [color="#0D47A1" arrowhead=tee style=dashed]
    azithro_tissue -> azithro_pkparam [color="#E65100" style=dashed]
    azithro_dose -> azithro_qt [color="#E65100" style=dashed]
    azithro_dose -> azithro_resist [color="#E65100" style=dashed]

    // Mucoactive
    dnase -> dna_digest [color="#4A148C"]
    hs_saline -> osm_effect [color="#4A148C"]
    mannitol -> osm_effect [color="#4A148C"]
    nac -> mucus_viscosity [color="#1565C0" arrowhead=tee label="↓S-S bonds"]
    erdosteine -> mucus_viscosity [color="#1565C0" arrowhead=tee]
    osm_effect -> airway_surface [color="#1565C0" label="hydrates ASL"]
    dna_digest -> mucus_viscosity [color="#1565C0" arrowhead=tee label="↓viscosity"]
    osm_effect -> mucocil_enhance [color="#4A148C"]
    dna_digest -> mucocil_enhance [color="#4A148C"]
    oppt -> mucocil_enhance [color="#4A148C"]
    mucocil_enhance -> mcc_failure [color="#0D47A1" arrowhead=tee label="improves"]
    mucocil_enhance -> sputum_vol [color="#BF360C" arrowhead=tee label="↓"]

    // CFTR Modulators
    lumacaftor -> cftr_rescue [color="#006064"]
    tezacaftor -> cftr_rescue [color="#006064"]
    elexacaftor -> cftr_rescue [color="#006064"]
    ivacaftor -> cftr_activity [color="#006064"]
    cftr_rescue -> cftr_channel [color="#1565C0"]
    cftr_activity -> cftr_channel [color="#1565C0"]
    triple_combo -> cftr_rescue [color="#006064"]
    triple_combo -> cftr_activity [color="#006064"]
    cftr_channel -> asl_restored [color="#006064"]
    asl_restored -> airway_surface [color="#1565C0"]
    asl_restored -> mcc_failure [color="#0D47A1" arrowhead=tee label="restores\nMCC"]
    cftr_activity -> sweat_cl [color="#006064"]
    triple_combo -> cftr_pk [color="#006064" style=dashed]

    // Treatment → Outcomes
    pa -> exacerbation [color="#827717" label="triggers"]
    hi -> exacerbation [color="#827717" style=dashed]
    neutrophil -> exacerbation [color="#827717" style=dashed]
    ne_act -> exacerbation [color="#827717" style=dashed label="perpetuates"]
    fev1 -> qol [color="#827717"]
    exac_freq -> qol [color="#827717" arrowhead=tee]
    exac_freq -> bsi_score [color="#BF360C"]

    // Drug effects on outcomes
    cipro -> exacerbation [color="#01579B" arrowhead=tee label="↓freq"]
    azithro_dose -> exac_freq [color="#E65100" arrowhead=tee label="↓29%\n(EMBRACE)"]
    tobra_inh -> pa [color="#1B5E20" arrowhead=tee label="suppresses"]
    tobra_inh -> exac_freq [color="#E65100" arrowhead=tee style=dashed]

    // Vicious cycle arrows (key concept)
    airway_dilation -> mcc_failure [color="#C62828" style=bold label="↓clearance\nVICIOUS\nCYCLE" fontcolor="#C62828"]
    mcc_failure -> pa [color="#C62828" style=bold fontcolor="#C62828"]
    pa -> neutrophil_recruit [color="#C62828" style=bold]
    neutrophil -> ne_act [color="#C62828" style=bold]
    ne_act -> airway_dilation [color="#C62828" style=bold label="structural\ndamage"]
}
