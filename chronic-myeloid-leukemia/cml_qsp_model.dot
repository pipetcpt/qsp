digraph CML_QSP {

  graph [
    label="Chronic Myeloid Leukemia (CML) — Quantitative Systems Pharmacology Model\nBCR-ABL Oncogenesis · Leukemic Hierarchy · TKI Pharmacology · Resistance · Immune Surveillance · Molecular Monitoring"
    labelloc=t
    labeljust=c
    fontname="Helvetica-Bold"
    fontsize=18
    rankdir=LR
    bgcolor="#F8F9FA"
    splines=ortho
    nodesep=0.4
    ranksep=0.8
    pad=0.5
  ]

  node [fontname="Helvetica" fontsize=10 style="filled,rounded" shape=box]
  edge [fontname="Helvetica" fontsize=8 penwidth=1.2]

  // ============================================================
  // CLUSTER 1: Philadelphia Chromosome & BCR-ABL Oncogenesis
  // ============================================================
  subgraph cluster_oncogenesis {
    label="① Philadelphia Chromosome & BCR-ABL Oncogenesis"
    style="filled,rounded"
    bgcolor="#FFE8E8"
    color="#CC0000"
    fontname="Helvetica-Bold"
    fontsize=12

    Ph_chrom    [label="Philadelphia\nChromosome\nt(9;22)(q34;q11)" fillcolor="#FF6666" fontcolor=white shape=ellipse]
    t922        [label="Translocation\nt(9;22)" fillcolor="#FF8888"]
    BCR_gene    [label="BCR Gene\n(chr22q11)" fillcolor="#FFAAAA"]
    ABL1_gene   [label="ABL1 Gene\n(chr9q34)" fillcolor="#FFAAAA"]
    BCR_ABL1    [label="BCR-ABL1\nFusion Gene" fillcolor="#FF4444" fontcolor=white shape=ellipse]
    p210        [label="p210 BCR-ABL\nProtein Kinase\n(major CML)" fillcolor="#CC0000" fontcolor=white shape=ellipse]
    p190        [label="p190 BCR-ABL\n(e1a2; ALL-type)" fillcolor="#FF6666" fontcolor=white]
    p230        [label="p230 BCR-ABL\n(e19a2; CML-N)" fillcolor="#FF9999"]
    ABL_kinase  [label="ABL Kinase\nDomain\n(DFG-in active)" fillcolor="#FFBBBB"]
    SH2_dom     [label="SH2 Domain\n(substrate docking)" fillcolor="#FFCCCC"]
    SH3_dom     [label="SH3 Domain\n(auto-inhibition\nlost in BCR-ABL)" fillcolor="#FFCCCC"]
    myristoyl   [label="Myristoyl\nPocket\n(STAMP target)" fillcolor="#FFD0D0"]
    ATP_site    [label="ATP Binding\nSite\n(TKI target)" fillcolor="#FF8888"]
    coiled_coil [label="BCR Coiled-Coil\nDomain\n(oligomerization)" fillcolor="#FFDDDD"]
  }

  // ============================================================
  // CLUSTER 2: BCR-ABL Downstream Signaling
  // ============================================================
  subgraph cluster_signaling {
    label="② BCR-ABL Downstream Signaling"
    style="filled,rounded"
    bgcolor="#FFF0D0"
    color="#CC6600"
    fontname="Helvetica-Bold"
    fontsize=12

    // RAS-MAPK
    GRB2        [label="GRB2\nAdapter" fillcolor="#FFD080"]
    SOS1        [label="SOS1\nGEF" fillcolor="#FFD080"]
    RAS_GDP     [label="RAS-GDP\n(inactive)" fillcolor="#FFCC66"]
    RAS_GTP     [label="RAS-GTP\n(active)" fillcolor="#FF9900" fontcolor=white]
    RAF1        [label="RAF1\nKinase" fillcolor="#FFB833"]
    MEK12       [label="MEK1/2" fillcolor="#FFAA00"]
    ERK12       [label="ERK1/2\np-ERK" fillcolor="#FF8800" fontcolor=white]
    // PI3K-AKT-mTOR
    PI3K        [label="PI3K\np85/p110" fillcolor="#FFD080"]
    PIP2        [label="PIP2" fillcolor="#FFCC99"]
    PIP3        [label="PIP3" fillcolor="#FF9933"]
    PTEN        [label="PTEN\n(tumor suppressor)" fillcolor="#FFDDAA"]
    AKT         [label="AKT/PKB\np-AKT(Ser473)" fillcolor="#FF8800" fontcolor=white]
    mTORC1      [label="mTORC1\n(rapamycin-sensitive)" fillcolor="#FF6600" fontcolor=white]
    mTORC2      [label="mTORC2\n(rictor complex)" fillcolor="#FF9966"]
    S6K1        [label="S6K1\n(protein synthesis)" fillcolor="#FFAA44"]
    FoxO3a      [label="FoxO3a\n(apoptosis/quiescence)" fillcolor="#FFCC88"]
    // JAK-STAT
    JAK2        [label="JAK2\n(cytokine signaling)" fillcolor="#FFD060"]
    STAT5       [label="STAT5\np-STAT5" fillcolor="#FF9900" fontcolor=white]
    BCL2        [label="BCL-2\n(anti-apoptosis)" fillcolor="#FF6600" fontcolor=white]
    BCLxL       [label="BCL-xL\n(survival)" fillcolor="#FF7722"]
    // MYC/proliferation
    MYC         [label="c-MYC\n(proliferation)" fillcolor="#FF8800" fontcolor=white]
    CCND1       [label="Cyclin D1\nCCND1" fillcolor="#FFAA44"]
    CDK4_6      [label="CDK4/6\nCyclin D" fillcolor="#FFBB55"]
    // Apoptosis
    BAX         [label="BAX/BAK\n(pro-apoptotic)" fillcolor="#FFD0A0"]
    CASP9       [label="Caspase-9\n(intrinsic)" fillcolor="#FFCC99"]
    CASP3       [label="Caspase-3\n(effector)" fillcolor="#FFAA88"]
  }

  // ============================================================
  // CLUSTER 3: Normal Hematopoietic Hierarchy
  // ============================================================
  subgraph cluster_normal_hema {
    label="③ Normal Hematopoietic Hierarchy"
    style="filled,rounded"
    bgcolor="#E8F4E8"
    color="#006600"
    fontname="Helvetica-Bold"
    fontsize=12

    HSC         [label="HSC\nHematopoietic\nStem Cell (y0)" fillcolor="#66BB66" fontcolor=white shape=ellipse]
    CMP         [label="CMP\nCommon Myeloid\nProgenitor (y1)" fillcolor="#88CC88"]
    GMP         [label="GMP\nGranulocyte-Macrophage\nProgenitor (y2)" fillcolor="#AADDAA"]
    mature_N    [label="Mature\nNeutrophils (y3)\nWBC normal" fillcolor="#CCEECC"]
    MEP         [label="MEP\nMegakaryocyte-Erythroid\nProgenitor" fillcolor="#99CC99"]
    RBC         [label="Red Blood Cells\n(Erythrocytes)" fillcolor="#BBDDBB"]
    Platelet    [label="Platelets\n(Thrombocytes)" fillcolor="#AACCAA"]
    NK_precursor [label="NK Cell\nPrecursor" fillcolor="#88BB88"]
    // Cytokines supporting normal hematopoiesis
    SCF         [label="SCF\nStem Cell Factor" fillcolor="#DDFFDD"]
    TPO         [label="TPO\nThrombopoietin" fillcolor="#DDFFDD"]
    EPO         [label="EPO\nErythropoietin" fillcolor="#DDFFDD"]
    GCSF        [label="G-CSF\n(Filgrastim)" fillcolor="#DDFFDD"]
    IL3_n       [label="IL-3\n(normal)" fillcolor="#DDEEDD"]
    CXCL12      [label="CXCL12/SDF-1\n(BM retention)" fillcolor="#CCEECC"]
  }

  // ============================================================
  // CLUSTER 4: CML Leukemic Hierarchy
  // ============================================================
  subgraph cluster_leukemic {
    label="④ CML Leukemic Hierarchy (Michor 2005 framework)"
    style="filled,rounded"
    bgcolor="#E8E0F8"
    color="#6600CC"
    fontname="Helvetica-Bold"
    fontsize=12

    LSC_q       [label="Quiescent LSC (x0q)\nG0 phase · TKI-resistant\nSelf-renewal ↑" fillcolor="#9966CC" fontcolor=white shape=ellipse]
    LSC_p       [label="Cycling LSC (x0p)\nBCR-ABL+ active\nTKI-sensitive" fillcolor="#7744AA" fontcolor=white shape=ellipse]
    LPC1        [label="Leukemic Progenitor\nCommitted (x1)\nRapid expansion" fillcolor="#AA88DD"]
    LPC2        [label="Leukemic Progenitor\nDifferentiated (x2)" fillcolor="#BBAAEE"]
    LBC         [label="Leukemic Blasts\n/ WBC (x3)\nBCR-ABL IS% numerator" fillcolor="#8855BB" fontcolor=white]
    LSC_sens    [label="TKI-Sensitive\nLSC Clone (xs)\nBCR-ABL WT" fillcolor="#AA77CC" fontcolor=white]
    LSC_resist  [label="TKI-Resistant\nLSC Clone (xr)\nT315I / E255K" fillcolor="#CC3399" fontcolor=white]
    // Microenvironment
    BM_niche    [label="BM Niche\nOsteoblast signals\nQuiescence support" fillcolor="#D0C8F0"]
    CXCR4       [label="CXCR4/SDF-1\nRetention signal" fillcolor="#D8D0F8"]
    JAM_A       [label="JAM-A\nCell adhesion" fillcolor="#E0D8FF"]
    ICAM1       [label="ICAM-1\nStem cell anchor" fillcolor="#E0D8FF"]
  }

  // ============================================================
  // CLUSTER 5: TKI Drug Pharmacokinetics
  // ============================================================
  subgraph cluster_PK {
    label="⑤ TKI Pharmacokinetics (6 Agents)"
    style="filled,rounded"
    bgcolor="#E0EFFF"
    color="#003388"
    fontname="Helvetica-Bold"
    fontsize=12

    // Absorption
    GI_abs      [label="GI Absorption\n(oral bioavailability)" fillcolor="#AACCFF"]
    food_imt    [label="Food Effect\n(imatinib: no effect\nnilotinib: ↑ exposure)" fillcolor="#C0D8FF"]
    // Imatinib
    Cimt        [label="Imatinib\nPlasma (Cp)\n400-800 mg/day" fillcolor="#5588DD" fontcolor=white]
    Cimt_ic     [label="Imatinib\nIntracellular\n(OCT1-dependent)" fillcolor="#3366BB" fontcolor=white]
    // Dasatinib
    Cdas        [label="Dasatinib\nPlasma (Cp)\n100 mg/day" fillcolor="#4477CC" fontcolor=white]
    Cdas_ic     [label="Dasatinib\nIntracellular\n(passive, high IC)" fillcolor="#2255AA" fontcolor=white]
    // Nilotinib
    Cnil        [label="Nilotinib\nPlasma (Cp)\n300-400 mg BID" fillcolor="#5599EE" fontcolor=white]
    Cnil_ic     [label="Nilotinib\nIntracellular" fillcolor="#3377CC" fontcolor=white]
    // Bosutinib
    Cbos        [label="Bosutinib\nPlasma (Cp)\n400-500 mg/day" fillcolor="#66AAFF" fontcolor=white]
    // Ponatinib
    Cpon        [label="Ponatinib\nPlasma (Cp)\n15-45 mg/day\n(T315I active)" fillcolor="#4488EE" fontcolor=white]
    // Asciminib
    Casc        [label="Asciminib\nPlasma (Cp)\n40 mg BID\n(STAMP inhibitor)" fillcolor="#77BBFF" fontcolor=white]
    // Transporters
    OCT1        [label="OCT1\nSLC22A1\n(imatinib influx)" fillcolor="#99CCFF"]
    ABCB1       [label="ABCB1/P-gp\nMDR1 efflux pump" fillcolor="#99CCFF"]
    ABCG2       [label="ABCG2/BCRP\nefflux pump" fillcolor="#99CCFF"]
    CYP3A4      [label="CYP3A4\nHepatic metabolism\nDDI risk" fillcolor="#BBDDFF"]
  }

  // ============================================================
  // CLUSTER 6: TKI Pharmacodynamics & Kinase Inhibition
  // ============================================================
  subgraph cluster_PD {
    label="⑥ TKI Pharmacodynamics & Kinase Inhibition"
    style="filled,rounded"
    bgcolor="#FFF8E0"
    color="#886600"
    fontname="Helvetica-Bold"
    fontsize=12

    BCR_ABL_act [label="BCR-ABL\nActive Kinase\n(ATP-bound)" fillcolor="#FFCC44"]
    BCR_ABL_inh [label="BCR-ABL\nInhibited\n(TKI-bound)" fillcolor="#FFEE99"]
    DFG_in      [label="DFG-in\nConformation\n(dasatinib/nilotinib)" fillcolor="#FFD060"]
    DFG_out     [label="DFG-out\nConformation\n(imatinib)" fillcolor="#FFD080"]
    STAMP_bind  [label="STAMP Binding\nMyristoyl pocket\n(asciminib)" fillcolor="#FFE090"]
    Emax_imt    [label="Emax (Imatinib)\nIC50=0.1-1 µM\nHill=1.2" fillcolor="#FFDD66"]
    Emax_das    [label="Emax (Dasatinib)\nIC50=0.01 µM\n(10x more potent)" fillcolor="#FFCC44"]
    Emax_nil    [label="Emax (Nilotinib)\nIC50=0.02 µM\n(20x imatinib)" fillcolor="#FFDD55"]
    Emax_asc    [label="Emax (Asciminib)\nIC50=0.5 nM\nActive vs T315I (200mg)" fillcolor="#FFE066"]
    kill_rate   [label="Cell Kill Rate\nkill = Emax×f(C)\n×BCR-ABL signaling" fillcolor="#FFBB33"]
    prolif_inh  [label="Proliferation\nInhibition\nG1/S arrest" fillcolor="#FFCC55"]
    apop_induct [label="Apoptosis\nInduction\nmitochondrial" fillcolor="#FFAA22"]
  }

  // ============================================================
  // CLUSTER 7: Resistance Mechanisms
  // ============================================================
  subgraph cluster_resistance {
    label="⑦ Resistance Mechanisms"
    style="filled,rounded"
    bgcolor="#FFE8F8"
    color="#990066"
    fontname="Helvetica-Bold"
    fontsize=12

    // Point mutations
    T315I       [label="T315I Mutation\n'Gatekeeper'\nResistant to all\nexcept ponatinib/asciminib" fillcolor="#FF44AA" fontcolor=white shape=ellipse]
    E255K       [label="E255K\nP-loop mutation\nResistant to imatinib" fillcolor="#FF66BB" fontcolor=white]
    Y253H       [label="Y253H\nP-loop mutation" fillcolor="#FF88CC"]
    F317L       [label="F317L\nDasatinib-resistant" fillcolor="#FF99DD"]
    E459K       [label="E459K\nAsciminib-resistant\n(myristoyl pocket)" fillcolor="#FFAAE8"]
    // Amplification & overexpression
    BCR_ABL_amp [label="BCR-ABL\nAmplification\n(gene copy ↑)" fillcolor="#FF77CC" fontcolor=white]
    BCR_ABL_over [label="BCR-ABL\nOverexpression\nmRNA ↑" fillcolor="#FF99DD"]
    // Bypass pathways
    LYN_kinas   [label="LYN Kinase\nBypass\n(dasatinib-resistant)" fillcolor="#FFBBEE"]
    HCK         [label="HCK Kinase\nSrc family" fillcolor="#FFCCF0"]
    FGF2_sig    [label="FGF2/FGFR\nBypass\nBM niche signal" fillcolor="#FFDDFF"]
    // Epigenetic & LSC
    LSC_quies   [label="LSC Quiescence\nG0 phase\nPrimary resistance" fillcolor="#FF55BB" fontcolor=white]
    SIRT1       [label="SIRT1\nDeacetylase\nLSC maintenance" fillcolor="#FFAAE0"]
    PP2A_inhib  [label="PP2A Inhibition\n(SET protein)\nPhosphatase" fillcolor="#FFCCEE"]
    // Drug efflux
    ABCB1_efflux [label="ABCB1/MDR1\nOverexpression\nDrug efflux ↑" fillcolor="#FF99CC"]
    OCT1_down   [label="OCT1\nDownregulation\nImport ↓" fillcolor="#FFBBDD"]
    // Clonal evolution
    clone_evol  [label="Clonal Evolution\nAdditional mutations\n+8, i(17q), +Ph" fillcolor="#FF6699" fontcolor=white]
  }

  // ============================================================
  // CLUSTER 8: Immune Surveillance
  // ============================================================
  subgraph cluster_immune {
    label="⑧ Immune Surveillance & Escape"
    style="filled,rounded"
    bgcolor="#E8F8E8"
    color="#006633"
    fontname="Helvetica-Bold"
    fontsize=12

    NK_cell     [label="NK Cells\n(CD56+CD16+)\nCML surveillance" fillcolor="#44BB88" fontcolor=white shape=ellipse]
    CTL         [label="CD8+ CTL\nCML-specific\nT cells" fillcolor="#55AA77" fontcolor=white shape=ellipse]
    Thelper     [label="CD4+ T Helper\nTh1 response" fillcolor="#66BB88"]
    Treg        [label="CD4+FoxP3+\nTreg\nImmune suppressor" fillcolor="#88CCAA"]
    // NK cytotoxicity
    DNAM1       [label="DNAM-1\nNKG2D\nActivating receptors" fillcolor="#99DDBB"]
    MICA_MICB   [label="MICA/MICB\nStress ligands\non CML cells" fillcolor="#AADDCC"]
    perforin    [label="Perforin/\nGranzyme B\nCytotoxicity" fillcolor="#77CC99"]
    // Immune escape
    PD_L1       [label="PD-L1\nCD274\nImmune checkpoint" fillcolor="#BBEECC"]
    PD1         [label="PD-1\nCD279\nT cell exhaustion" fillcolor="#CCFFDD"]
    IDO         [label="IDO\nTryptophan\ndepletion" fillcolor="#AADDBB"]
    IL10        [label="IL-10\nImmunosuppressive\ncytokine" fillcolor="#BBEEDD"]
    TGFb_imm    [label="TGF-β\nImmune suppression\nTreg induction" fillcolor="#CCFFEE"]
    // TFR immune
    NK_TFR      [label="NK Activity\n(predict TFR\nsuccess)" fillcolor="#55BB77" fontcolor=white]
    IFNg        [label="IFN-γ\nTh1 cytokine\nAnti-leukemic" fillcolor="#66CC88"]
  }

  // ============================================================
  // CLUSTER 9: CML Phase Progression
  // ============================================================
  subgraph cluster_phase {
    label="⑨ CML Phase Progression & Clonal Evolution"
    style="filled,rounded"
    bgcolor="#F0E8FF"
    color="#440088"
    fontname="Helvetica-Bold"
    fontsize=12

    CP_phase    [label="Chronic Phase (CP)\nWBC 25-300×10⁹/L\nSplenomegaly\nPh+ 95-100%" fillcolor="#8855CC" fontcolor=white shape=ellipse]
    AP_phase    [label="Accelerated Phase (AP)\nBlasts 10-19%\nBasophils ≥20%\nEWI 2022 criteria" fillcolor="#AA33BB" fontcolor=white shape=ellipse]
    BC_phase    [label="Blast Crisis (BC)\nBlasts ≥20%\nMyeloid 70%\nLymphoid 30%" fillcolor="#CC1188" fontcolor=white shape=ellipse]
    // Genetic events
    add_mut8    [label="+8 Trisomy\nClonal evolution\n(CP→AP)" fillcolor="#CC88EE"]
    iso17q      [label="i(17q)\nTP53 deletion\n(BC evolution)" fillcolor="#BB66DD"]
    double_Ph   [label="Double Ph\nBCR-ABL amp\n(AP/BC)" fillcolor="#CC77EE"]
    TP53_mut    [label="TP53 Mutation\n17p deletion\n(lymphoid BC)" fillcolor="#DD88FF"]
    RUNX1_mut   [label="RUNX1 Mutation\n(myeloid BC)" fillcolor="#EE99FF"]
    IKZF1_del   [label="IKZF1 Deletion\n(lymphoid BC)" fillcolor="#FFAAFF"]
    RB1_loss    [label="RB1 Loss\nCell cycle escape" fillcolor="#DDAAFF"]
    sokal_score [label="Sokal Score\nRisk stratification\n(Low/Int/High)" fillcolor="#CCBBFF"]
    eutos_score [label="EUTOS Score\nLTS/ELTS score\n2016 updated" fillcolor="#DDBFFF"]
  }

  // ============================================================
  // CLUSTER 10: Molecular Monitoring
  // ============================================================
  subgraph cluster_monitoring {
    label="⑩ Molecular Monitoring & Response Assessment"
    style="filled,rounded"
    bgcolor="#FFF8F0"
    color="#884400"
    fontname="Helvetica-Bold"
    fontsize=12

    BCR_ABL_IS  [label="BCR-ABL IS%\nInternational Scale\n(IRIS standardized)" fillcolor="#FFBB88" shape=ellipse]
    RT_PCR      [label="RT-qPCR\nBCR-ABL quantitation\nABL1 control gene" fillcolor="#FFAA66"]
    cyto_Ph     [label="Cytogenetics\nPh+ metaphases\n(G-banding, FISH)" fillcolor="#FFD0A0"]
    FISH        [label="FISH\nt(9;22) signals\nBCR-ABL dual fusion" fillcolor="#FFCC99"]
    NGS_panel   [label="NGS Mutation\nPanel\nKinase domain\nsequencing" fillcolor="#FFD0B0"]
    ddPCR       [label="ddPCR\nDigital droplet\nUMN detection" fillcolor="#FFBB77"]
    ABL_ctrl    [label="ABL1 Control\nGene\nNormalization" fillcolor="#FFDDCC"]
    IS_conv     [label="IS Conversion\nFactor CF\nLab-specific" fillcolor="#FFEECC"]
    sensitivity [label="Assay Sensitivity\nMR4: 0.01%\nMR4.5: 0.0032%" fillcolor="#FFEEDD"]
    BM_biopsy   [label="BM Biopsy\nCellularity\nFibrosis grade" fillcolor="#FFD8B8"]
  }

  // ============================================================
  // CLUSTER 11: Clinical Endpoints & Response Milestones
  // ============================================================
  subgraph cluster_endpoints {
    label="⑪ Clinical Response Milestones & ELN Recommendations"
    style="filled,rounded"
    bgcolor="#E0F0FF"
    color="#002288"
    fontname="Helvetica-Bold"
    fontsize=12

    CHR         [label="CHR\nComplete Hematologic\nResponse\nWBC <10×10⁹/L\n(3 months)" fillcolor="#4488CC" fontcolor=white]
    CCyR        [label="CCyR\nComplete Cytogenetic\nResponse\nPh+: 0%\n(12 months)" fillcolor="#3366BB" fontcolor=white]
    PCyR        [label="PCyR\nPartial Cytogenetic\nResponse\nPh+ 1-35%" fillcolor="#5599DD" fontcolor=white]
    MMR         [label="MMR/MR3\nMajor Molecular\nResponse\nBCR-ABL ≤0.1%\n(12-18 months)" fillcolor="#2255AA" fontcolor=white]
    MR4         [label="MR4\nDeep Molecular\nResponse\nBCR-ABL ≤0.01%" fillcolor="#1144AA" fontcolor=white]
    MR4_5       [label="MR4.5\nVery Deep\nBCR-ABL ≤0.0032%\nTFR prerequisite" fillcolor="#003399" fontcolor=white]
    TFR         [label="TFR\nTreatment-Free\nRemission\n>2yr DMR → stop TKI" fillcolor="#002288" fontcolor=white shape=ellipse]
    // ELN warnings
    warn_3mo    [label="Warning @ 3mo\nBCR-ABL >10%\nPh+ >95%" fillcolor="#88AADD"]
    fail_6mo    [label="Failure @ 6mo\nBCR-ABL >10%\nPh+ >35%" fillcolor="#6688CC"]
    fail_12mo   [label="Failure @ 12mo\nBCR-ABL >1%\nPh+ >0%" fillcolor="#5577BB"]
    // Endpoints
    OS_EP       [label="Overall Survival\n(OS)\n10yr: ~85%\n(imatinib era)" fillcolor="#99BBEE"]
    PFS_EP      [label="Progression-Free\nSurvival (PFS)" fillcolor="#AACCFF"]
    EFS_EP      [label="Event-Free\nSurvival (EFS)" fillcolor="#BBDDFF"]
  }

  // ============================================================
  // CLUSTER 12: Organ Effects & Microenvironment
  // ============================================================
  subgraph cluster_organ {
    label="⑫ Organ Effects & Bone Marrow Microenvironment"
    style="filled,rounded"
    bgcolor="#F0FFF0"
    color="#004400"
    fontname="Helvetica-Bold"
    fontsize=12

    BM_micro    [label="Bone Marrow\nMicroenvironment\n(niche)" fillcolor="#66BB66" fontcolor=white]
    osteoblast  [label="Osteoblasts\nN-cadherin+\nQuiescence signal" fillcolor="#88CC88"]
    MSC         [label="Mesenchymal\nStem Cells\n(stromal support)" fillcolor="#99DD99"]
    CAF         [label="Cancer-Assoc\nFibroblasts\nSDF-1 secretion" fillcolor="#AADDAA"]
    spleen      [label="Spleen\nExtramedullary\nhematopoiesis" fillcolor="#77BB77" fontcolor=white]
    liver_met   [label="Liver\nCYP3A4/3A5\nTKI metabolism" fillcolor="#88CC88"]
    // BM signals
    IL6_BM      [label="IL-6\nBM-derived\nSTAT3 activation" fillcolor="#BBEEAA"]
    CXCL12_BM  [label="CXCL12/SDF-1\nBM retention\nLSC niche" fillcolor="#CCFFBB"]
    SCF_BM      [label="SCF/KIT\nc-KIT signaling" fillcolor="#DDFFCC"]
    VCAM1       [label="VCAM-1/VLA-4\nCell adhesion\nCAM-DR" fillcolor="#CCEECC"]
    // Adverse effects
    QTc_nil     [label="QTc Prolongation\n(nilotinib/bosutinib)\nHERG channel" fillcolor="#AADDAA"]
    pleural_das [label="Pleural Effusion\n(dasatinib)\nLYN inhibition" fillcolor="#BBEEAA"]
    PAOD_pon    [label="Arterial Occlusion\n(ponatinib)\nPAOD/MI risk" fillcolor="#99CC99"]
    hepatotox   [label="Hepatotoxicity\nALT/AST elevation\n(all TKIs)" fillcolor="#AACCAA"]
  }

  // ============================================================
  // INTER-CLUSTER EDGES
  // ============================================================

  // Oncogenesis → Signaling
  BCR_gene -> BCR_ABL1 [label="fusion" color="#CC0000"]
  ABL1_gene -> BCR_ABL1 [label="fusion" color="#CC0000"]
  BCR_ABL1 -> p210 [label="translation" color="#CC0000"]
  BCR_ABL1 -> p190 [label="e1a2" color="#CC0000" style=dashed]
  BCR_ABL1 -> p230 [label="e19a2" color="#CC0000" style=dashed]
  t922 -> Ph_chrom [color="#CC0000"]
  BCR_gene -> t922 [color="#CC0000"]
  ABL1_gene -> t922 [color="#CC0000"]
  Ph_chrom -> BCR_ABL1 [color="#CC0000" penwidth=2]
  p210 -> ABL_kinase [color="#CC0000"]
  ABL_kinase -> ATP_site [color="#CC0000"]
  ABL_kinase -> SH2_dom [color="#CC0000"]
  BCR_ABL1 -> coiled_coil [color="#CC0000"]
  SH3_dom -> ABL_kinase [label="auto-inhibits\n(lost)" color="#999999" style=dashed]

  // BCR-ABL → Downstream Signaling
  p210 -> GRB2 [label="recruits" color="#FF6600"]
  p210 -> PI3K [label="activates" color="#FF6600"]
  p210 -> JAK2 [label="activates" color="#FF6600"]
  p210 -> STAT5 [label="direct\nactivation" color="#FF6600" penwidth=2]
  GRB2 -> SOS1 [color="#FF9900"]
  SOS1 -> RAS_GDP [color="#FF9900"]
