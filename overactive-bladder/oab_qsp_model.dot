digraph OAB_QSP_Model {
  // ──────────────────────────────────────────────
  //  Overactive Bladder (OAB) — Comprehensive QSP
  //  Mechanistic Map  |  127 nodes, 170+ edges
  //  12 subgraph clusters
  // ──────────────────────────────────────────────
  graph [
    rankdir=LR,
    compound=true,
    fontname="Helvetica Neue",
    fontsize=13,
    overlap=false,
    splines=ortho,
    nodesep=0.4,
    ranksep=0.8,
    bgcolor="#F7F8FA",
    label="Overactive Bladder (OAB) — QSP Mechanistic Map\nDrug PK·PD · Neural Pathways · Detrusor Biology · Clinical Endpoints",
    labelloc=t,
    labelfontsize=16
  ]
  node [fontname="Helvetica Neue", fontsize=9, style="filled,rounded", shape=box]
  edge [fontname="Helvetica Neue", fontsize=7, arrowsize=0.7]

  // ═══════════════════════════════════════════════════
  //  CLUSTER 1: Bladder Urothelium & Sensory Signaling
  // ═══════════════════════════════════════════════════
  subgraph cluster_urothelium {
    label="Urothelium & Sensory Signaling"
    style=filled; fillcolor="#EBF5FB"; color="#2980B9"; penwidth=2

    umbrella_cells     [label="Umbrella Cells\n(Apical Urothelium)", fillcolor="#AED6F1"]
    intermediate_cells [label="Intermediate Cells\n(Urothelium)", fillcolor="#AED6F1"]
    basal_cells        [label="Basal Cells\n(Urothelium)", fillcolor="#AED6F1"]
    PIEZO2             [label="PIEZO2\n(Mechano-stretch)", fillcolor="#5DADE2"]
    urothelial_ATP     [label="Urothelial ATP\nRelease", fillcolor="#F9E79F"]
    urothelial_ACh     [label="Urothelial ACh\nRelease", fillcolor="#F9E79F"]
    P2X3_receptor      [label="P2X3 Receptor\n(Purinergic)", fillcolor="#A9CCE3"]
    P2X2_receptor      [label="P2X2 Receptor\n(Purinergic)", fillcolor="#A9CCE3"]
    P2Y2_receptor      [label="P2Y2 Receptor\n(Purinergic)", fillcolor="#A9CCE3"]
    M2_uro             [label="M2 Receptor\n(Urothelium)", fillcolor="#A9CCE3"]
    M3_uro             [label="M3 Receptor\n(Urothelium)", fillcolor="#A9CCE3"]
    eNOS_bladder       [label="eNOS/iNOS\n(Urothelium)", fillcolor="#A9CCE3"]
    nitric_oxide       [label="Nitric Oxide\n(NO)", fillcolor="#E8DAEF"]
    prostaglandins     [label="Prostaglandins\n(PGE2/PGI2)", fillcolor="#E8DAEF"]
    urothelial_NGF     [label="NGF\n(Urothelial)", fillcolor="#FADBD8"]
    urothelial_BDNF    [label="BDNF\n(Urothelial)", fillcolor="#FADBD8"]
  }

  // ═══════════════════════════════════════════
  //  CLUSTER 2: Suburothelial & Afferent Nerve
  // ═══════════════════════════════════════════
  subgraph cluster_afferent {
    label="Suburothelial & Afferent Neural Pathways"
    style=filled; fillcolor="#EAFAF1"; color="#27AE60"; penwidth=2

    suburothelial_layer [label="Suburothelial Layer\n(Lamina Propria)", fillcolor="#A9DFBF"]
    interstitial_cajal  [label="Interstitial Cells\nof Cajal (ICC)", fillcolor="#58D68D"]
    Adelta_fibers       [label="Aδ-Fibers\n(Myelinated)", fillcolor="#A9DFBF"]
    C_fibers            [label="C-Fibers\n(Unmyelinated)", fillcolor="#A9DFBF"]
    TRPV1_afferent      [label="TRPV1\n(Capsaicin R)", fillcolor="#58D68D"]
    TRPM8_afferent      [label="TRPM8\n(Cold Receptor)", fillcolor="#58D68D"]
    TRPA1_afferent      [label="TRPA1\n(Irritants)", fillcolor="#58D68D"]
    P2X3_afferent       [label="P2X3 on Afferents\n(ATP-gated)", fillcolor="#A9DFBF"]
    DRG_L1_L2           [label="DRG (L1-L2)\nHypogastric", fillcolor="#A9DFBF"]
    DRG_S2_S4           [label="DRG (S2-S4)\nPelvic", fillcolor="#A9DFBF"]
    substance_P         [label="Substance P\n(Neuropeptide)", fillcolor="#ABEBC6"]
    CGRP                [label="CGRP\n(Neuropeptide)", fillcolor="#ABEBC6"]
    glutamate_aff       [label="Glutamate\n(Afferent)", fillcolor="#ABEBC6"]
    spinal_dorsal_horn  [label="Spinal Dorsal Horn\n(L1-L2, S2-S4)", fillcolor="#58D68D"]
    spinothalamic_tract [label="Spinothalamic Tract\n(Ascending)", fillcolor="#A9DFBF"]
  }

  // ═══════════════════════════════════════════════
  //  CLUSTER 3: Central Micturition Circuit
  // ═══════════════════════════════════════════════
  subgraph cluster_CNS {
    label="Central Micturition Control"
    style=filled; fillcolor="#FEF9E7"; color="#D35400"; penwidth=2

    thalamus           [label="Thalamus\n(Sensory Relay)", fillcolor="#FAD7A0"]
    insula             [label="Insula Cortex\n(Interoception)", fillcolor="#FAD7A0"]
    anterior_cingulate [label="Anterior Cingulate\nCortex (ACC)", fillcolor="#FAD7A0"]
    prefrontal_cortex  [label="Prefrontal Cortex\n(Voluntary Control)", fillcolor="#F0B27A"]
    PAG                [label="Periaqueductal Gray\n(PAG)", fillcolor="#E59866"]
    PMC                [label="Pontine Micturition\nCenter (PMC/Barrington)", fillcolor="#E59866"]
    locus_coeruleus    [label="Locus Coeruleus\n(NE Modulation)", fillcolor="#FAD7A0"]
    raphe_nucleus      [label="Raphe Nuclei\n(5-HT)", fillcolor="#FAD7A0"]
    basal_ganglia      [label="Basal Ganglia\n(Inhibitory Gate)", fillcolor="#FAD7A0"]
    cerebellum         [label="Cerebellum\n(Coordination)", fillcolor="#FAD7A0"]
    sacral_PMC_relay   [label="Sacral Spinal Cord\n(Micturition Reflex)", fillcolor="#E59866"]
    descending_inhib   [label="Descending\nInhibition (GABA)", fillcolor="#FDEBD0"]
    dopamine_D1D2      [label="Dopamine D1/D2\n(Basal Ganglia)", fillcolor="#FDEBD0"]
  }

  // ═══════════════════════════════════════════
  //  CLUSTER 4: Efferent Neural Pathways
  // ═══════════════════════════════════════════
  subgraph cluster_efferent {
    label="Efferent Neural Pathways"
    style=filled; fillcolor="#F5EEF8"; color="#8E44AD"; penwidth=2

    pelvic_nerve       [label="Pelvic Nerve\n(S2-S4, Parasympathetic)", fillcolor="#D2B4DE"]
    hypogastric_nerve  [label="Hypogastric Nerve\n(L1-L2, Sympathetic)", fillcolor="#D2B4DE"]
    pudendal_nerve     [label="Pudendal Nerve\n(Somatic)", fillcolor="#D2B4DE"]
    sacral_parasympath [label="Sacral Parasympathetic\nNucleus (SPN)", fillcolor="#A569BD"]
    sympathetic_chain  [label="Sympathetic Chain\n(Inferior Mesenteric)", fillcolor="#A569BD"]
    ganglionic_ACh     [label="Ganglionic ACh\n(Nicotinic NR)", fillcolor="#D2B4DE"]
    postganglionic_ACh [label="Postganglionic ACh\n(Muscarinic Release)", fillcolor="#D2B4DE"]
    NE_release         [label="NE Release\n(Sympathetic)", fillcolor="#D2B4DE"]
    EUS_activation     [label="External Urethral\nSphincter (EUS)", fillcolor="#A569BD"]
  }

  // ═══════════════════════════════════════════════════
  //  CLUSTER 5: Detrusor Smooth Muscle Signaling
  // ═══════════════════════════════════════════════════
  subgraph cluster_detrusor {
    label="Detrusor Smooth Muscle — Contraction/Relaxation"
    style=filled; fillcolor="#FDEDEC"; color="#C0392B"; penwidth=2

    detrusor_muscle    [label="Detrusor Muscle\n(Smooth Muscle)", fillcolor="#F1948A"]
    M2_receptor_det    [label="M2 Receptor\n(80% of muscarinic)", fillcolor="#EC7063"]
    M3_receptor_det    [label="M3 Receptor\n(20%, dominant PD)", fillcolor="#EC7063"]
    beta3_AR_det       [label="β3-Adrenoceptor\n(Detrusor Relaxation)", fillcolor="#EC7063"]
    alpha1_AR_urethra  [label="α1-Adrenoceptor\n(Urethral Closure)", fillcolor="#EC7063"]
    Gq_M3              [label="Gq Protein\n(M3 → PLC)", fillcolor="#F5B7B1"]
    PLC_IP3            [label="PLC → IP3 + DAG\n(Gq Cascade)", fillcolor="#F5B7B1"]
    IP3R_Ca            [label="IP3R → Ca²⁺ Release\n(SR/ER)", fillcolor="#F5B7B1"]
    intracellular_Ca   [label="[Ca²⁺]i Rise\n(Contraction Signal)", fillcolor="#E74C3C"]
    calmodulin_CaM     [label="Calmodulin (CaM)\nActivation", fillcolor="#F5B7B1"]
    MLCK               [label="MLCK\n(MLC Phosphorylation)", fillcolor="#F5B7B1"]
    MLCP               [label="MLCP (MLC Phosphatase)\nRho-kinase Inhibition", fillcolor="#F5B7B1"]
    rho_kinase         [label="RhoA/ROCK\nPathway", fillcolor="#F5B7B1"]
    cAMP_PKA           [label="cAMP → PKA\n(β3-AR Relaxation)", fillcolor="#A9CCE3"]
    BK_channel         [label="BK Channel\n(Ca²⁺-activated K⁺)", fillcolor="#D5D8DC"]
    Kv_channels        [label="Kv Channels\n(Voltage-gated K⁺)", fillcolor="#D5D8DC"]
    SERCA_pump         [label="SERCA Pump\n(Ca²⁺ Reuptake)", fillcolor="#D5D8DC"]
  }

  // ═══════════════════════════════════════════
  //  CLUSTER 6: Disease Pathophysiology
  // ═══════════════════════════════════════════
  subgraph cluster_pathophys {
    label="OAB Pathophysiology — Detrusor Overactivity"
    style=filled; fillcolor="#FDF2E9"; color="#E67E22"; penwidth=2

    DO_idiopathic      [label="Idiopathic DO\n(Myogenic/Neurogenic)", fillcolor="#FAD7A0"]
    DO_neurogenic      [label="Neurogenic DO\n(CNS/SCI/MSA)", fillcolor="#FAD7A0"]
    detrusor_overact   [label="Detrusor Overactivity\n(Involuntary Contractions)", fillcolor="#E67E22", fontcolor=white]
    bladder_hypersens  [label="Bladder\nHypersensitivity", fillcolor="#FAD7A0"]
    mast_cells_OAB     [label="Mast Cell\nDegranulation", fillcolor="#FAD7A0"]
    urothelial_injury  [label="Urothelial Barrier\nDysfunction", fillcolor="#FAD7A0"]
    NGF_overexpr       [label="NGF Overexpression\n(Nerve Sprouting)", fillcolor="#FDEBD0"]
    BDNF_upregul       [label="BDNF Upregulation\n(Sensitization)", fillcolor="#FDEBD0"]
    suburothelial_infl [label="Suburothelial\nInflammation", fillcolor="#FAD7A0"]
    purinergic_hyperex [label="Purinergic\nHyperexcitability", fillcolor="#FDEBD0"]
    myogenic_instab    [label="Myogenic Instability\n(Autonomous Contractions)", fillcolor="#FAD7A0"]
    bladder_aging      [label="Bladder Aging\n(Denervation↑)", fillcolor="#FDEBD0"]
  }

  // ══════════════════════════════════════════════
  //  CLUSTER 7: Antimuscarinic Drug PK
  // ══════════════════════════════════════════════
  subgraph cluster_PK_antim {
    label="Antimuscarinic Drugs — Pharmacokinetics"
    style=filled; fillcolor="#EAF2FF"; color="#2471A3"; penwidth=2

    OXY_GUT    [label="Oxybutynin\nGut (F=6%)", fillcolor="#AED6F1", shape=ellipse]
    OXY_CENT   [label="Oxybutynin\nPlasma (t½=2h)", fillcolor="#5DADE2", shape=ellipse]
    OXY_NDEO   [label="N-DEO\n(Active Metab, t½=8h)", fillcolor="#2E86C1", shape=ellipse]
    TOL_GUT    [label="Tolterodine\nGut (F≈17-77%)", fillcolor="#AED6F1", shape=ellipse]
    TOL_CENT   [label="Tolterodine ER\nPlasma (t½=12h)", fillcolor="#5DADE2", shape=ellipse]
    TOL_5HM    [label="5-HM Metabolite\n(CYP2D6, Active)", fillcolor="#2E86C1", shape=ellipse]
    SOL_GUT    [label="Solifenacin\nGut (F=90%)", fillcolor="#AED6F1", shape=ellipse]
    SOL_CENT   [label="Solifenacin\nPlasma (t½=45-68h)", fillcolor="#5DADE2", shape=ellipse]
    DAR_GUT    [label="Darifenacin\nGut (F=15-19%)", fillcolor="#AED6F1", shape=ellipse]
    DAR_CENT   [label="Darifenacin\nPlasma (t½=13-19h)", fillcolor="#5DADE2", shape=ellipse]
    FES_GUT    [label="Fesoterodine\nGut (Prodrug)", fillcolor="#AED6F1", shape=ellipse]
    FES_5HM    [label="5-HM Active\n(Hydrolysis, t½=7h)", fillcolor="#5DADE2", shape=ellipse]
    CYP3A4_met [label="CYP3A4\nMetabolism", fillcolor="#D6EAF8"]
    CYP2D6_met [label="CYP2D6\nPolymorphism", fillcolor="#D6EAF8"]
  }

  // ══════════════════════════════════════════════
  //  CLUSTER 8: β3-Agonist & BoNT PK
  // ══════════════════════════════════════════════
  subgraph cluster_PK_beta3 {
    label="β3-Agonist (Mirabegron) & OnaBotulinumtoxinA — PK"
    style=filled; fillcolor="#E8F8F5"; color="#1A8C6A"; penwidth=2

    MIR_GUT    [label="Mirabegron\nGut (F=29-35%)", fillcolor="#A9DFBF", shape=ellipse]
    MIR_CENT   [label="Mirabegron\nPlasma (t½=50h)", fillcolor="#52BE80", shape=ellipse]
    MIR_CYP3A4 [label="CYP3A4/2D6\nMetab (Mirabegron)", fillcolor="#A9DFBF"]
    VIBEG_GUT  [label="Vibegron\nGut (F=~60%)", fillcolor="#A9DFBF", shape=ellipse]
    VIBEG_CENT [label="Vibegron\nPlasma (t½=30.8h)", fillcolor="#52BE80", shape=ellipse]
    BONT_A_inj [label="OnaBotulinumtoxinA\nIntravesical Injection\n100-200 IU", fillcolor="#1E8449", fontcolor=white, shape=ellipse]
    BONT_uptake[label="BoNT-A Uptake\n(SNAP25 Cleavage)", fillcolor="#A9DFBF"]
    BONT_local [label="Local Muscle\n& Afferent Effect", fillcolor="#A9DFBF"]
  }

  // ══════════════════════════════════════════════
  //  CLUSTER 9: Drug Pharmacodynamics
  // ══════════════════════════════════════════════
  subgraph cluster_PD {
    label="Drug Pharmacodynamics — PD Mechanisms"
    style=filled; fillcolor="#F4F6F7"; color="#5D6D7E"; penwidth=2

    M3_blockade    [label="M3 Receptor\nOccupancy (RO_M3)", fillcolor="#D5D8DC"]
    M2_blockade    [label="M2 Receptor\nOccupancy (RO_M2)", fillcolor="#D5D8DC"]
    beta3_activ    [label="β3-AR\nActivation (RO_B3)", fillcolor="#A9DFBF"]
    Emax_antim     [label="Emax Model\n(Antimuscarinic)", fillcolor="#BFC9CA"]
    Emax_beta3     [label="Emax Model\n(β3-Agonist)", fillcolor="#BFC9CA"]
    SNAP25_cleav   [label="SNAP25 Cleavage\n(BoNT-A Target)", fillcolor="#F5B7B1"]
    ACh_inhib_bont [label="ACh Release\nInhibition (BoNT)", fillcolor="#F5B7B1"]
    urothelial_bont[label="Urothelial BoNT\nEffect (Afferent)", fillcolor="#F5B7B1"]
    receptor_desens[label="Receptor\nDesensitization", fillcolor="#D5D8DC"]
    drug_tolerance [label="Drug\nTolerance/Tachyphylaxis", fillcolor="#D5D8DC"]
  }

  // ══════════════════════════════════════════════════
  //  CLUSTER 10: Clinical Endpoints
  // ══════════════════════════════════════════════════
  subgraph cluster_endpoints {
    label="Clinical Endpoints & Bladder Diary"
    style=filled; fillcolor="#FEF5E7"; color="#B7950B"; penwidth=2

    urgency_eps    [label="Urgency Episodes\n(/24h)", fillcolor="#F9E79F"]
    void_freq      [label="Micturitions\n(/24h)", fillcolor="#F9E79F"]
    UUI_eps        [label="UUI Episodes\n(/24h)", fillcolor="#F4D03F"]
    nocturia       [label="Nocturia\n(Nocturnal Voids)", fillcolor="#F9E79F"]
    voided_vol     [label="Voided Volume\n(mL/void)", fillcolor="#F9E79F"]
    max_cmc        [label="Maximum Cystometric\nCapacity (mL)", fillcolor="#F9E79F"]
    bladder_diary  [label="3-Day Bladder Diary\nComposite", fillcolor="#F0B27A"]
    OABq_score     [label="OAB-q Score\n(Symptom Bother)", fillcolor="#F9E79F"]
    PPBC_score     [label="PPBC Score\n(Patient Perception)", fillcolor="#F9E79F"]
    ICIQ_OAB       [label="ICIQ-OAB\n(Validated PRO)", fillcolor="#F9E79F"]
    treatment_resp [label="Treatment Response\n(≥50% UUI reduction)", fillcolor="#E67E22", fontcolor=white]
  }

  // ══════════════════════════════════════════════
  //  CLUSTER 11: Biomarkers
  // ══════════════════════════════════════════════
  subgraph cluster_biomarkers {
    label="Urine & Tissue Biomarkers"
    style=filled; fillcolor="#F5EEF8"; color="#6C3483"; penwidth=2

    urinary_NGF    [label="Urinary NGF\n(↑ in OAB vs control)", fillcolor="#D2B4DE"]
    urinary_BDNF   [label="Urinary BDNF\n(↑ neurogenic OAB)", fillcolor="#D2B4DE"]
    urinary_ATP    [label="Urinary ATP\n(Purinergic marker)", fillcolor="#D2B4DE"]
    urinary_PGE2   [label="Urinary PGE2\n(Inflammatory)", fillcolor="#D2B4DE"]
    urinary_IL6    [label="Urinary IL-6\n(Bladder inflammation)", fillcolor="#D2B4DE"]
    urinary_TNFa   [label="Urinary TNF-α", fillcolor="#D2B4DE"]
    bladder_wall_t [label="Bladder Wall\nThickness (BWT)", fillcolor="#BB8FCE"]
    uroflow_Qmax   [label="Uroflow Qmax\n(mL/s)", fillcolor="#BB8FCE"]
    PVR_volume     [label="Post-void Residual\n(PVR, mL)", fillcolor="#BB8FCE"]
    cystometry_CMG [label="Cystometry (CMG)\nPdet.max", fillcolor="#BB8FCE"]
  }

  // ══════════════════════════════════════════════
  //  CLUSTER 12: Comorbidities & Risk Factors
  // ══════════════════════════════════════════════
  subgraph cluster_comorbid {
    label="Risk Factors & Comorbidities"
    style=filled; fillcolor="#EAFAF1"; color="#1E8449"; penwidth=2

    age_OAB      [label="Age\n(↑ Risk with Aging)", fillcolor="#A9DFBF"]
    obesity_OAB  [label="Obesity\n(BMI↑→OAB Risk)", fillcolor="#A9DFBF"]
    diabetes_OAB [label="Diabetes Mellitus\n(Cystopathy Risk)", fillcolor="#A9DFBF"]
    SCI_OAB      [label="Spinal Cord Injury\n(Neurogenic OAB)", fillcolor="#A9DFBF"]
    MSA_OAB      [label="Multiple System Atrophy\n(PMC Dysf.)", fillcolor="#A9DFBF"]
    PD_OAB       [label="Parkinson Disease\n(Neurogenic)", fillcolor="#A9DFBF"]
    stroke_OAB   [label="Stroke\n(Cortical Disinhibition)", fillcolor="#A9DFBF"]
    BPH_OAB      [label="BPH/BOO\n(Bladder Remodeling)", fillcolor="#A9DFBF"]
  }

  // ══════════════════════════════════════════════════════════════
  //  EDGES — Urothelium → Afferent
  // ══════════════════════════════════════════════════════════════
  umbrella_cells -> PIEZO2 [label="Stretch"]
  umbrella_cells -> urothelial_ATP [label="Exocytosis\n(P2X3/P2Y)"]
  umbrella_cells -> urothelial_ACh [label="Non-neuronal\nACh"]
  umbrella_cells -> urothelial_NGF [label="NGF secretion"]
  umbrella_cells -> urothelial_BDNF [label="BDNF secretion"]
  PIEZO2 -> urothelial_ATP [label="Mechano-gated"]
  urothelial_ATP -> P2X3_receptor [label="Purinergic\nActivation"]
  urothelial_ATP -> P2X2_receptor
  urothelial_ATP -> P2Y2_receptor
  urothelial_ACh -> M2_uro
  urothelial_ACh -> M3_uro
  eNOS_bladder -> nitric_oxide [label="NOS→NO"]
  nitric_oxide -> detrusor_muscle [label="cGMP↑\nRelaxation", color="#27AE60"]
  prostaglandins -> P2X3_receptor [label="Sensitization"]
  prostaglandins -> TRPV1_afferent [label="PGE2→\nTRPV1 sens"]

  // Afferent activation
  P2X3_receptor -> P2X3_afferent [label="Activation →\nAfferent"]
  P2X3_receptor -> C_fibers
  P2Y2_receptor -> Adelta_fibers
  TRPV1_afferent -> C_fibers [label="C-fiber firing"]
  TRPM8_afferent -> Adelta_fibers
  TRPA1_afferent -> C_fibers
  urothelial_NGF -> DRG_S2_S4 [label="NGF→TrkA\nSensitization"]
  urothelial_NGF -> DRG_L1_L2
  urothelial_BDNF -> TRPV1_afferent [label="↑TRPV1\nExpression"]
  P2X3_afferent -> C_fibers
  C_fibers -> substance_P [label="Release"]
  C_fibers -> CGRP [label="Release"]
  C_fibers -> glutamate_aff
  Adelta_fibers -> glutamate_aff
  substance_P -> spinal_dorsal_horn [label="NK1R\nActivation"]
  CGRP -> spinal_dorsal_horn [label="Sensitization"]
  glutamate_aff -> spinal_dorsal_horn [label="NMDAR\nActivation"]
  DRG_S2_S4 -> C_fibers [label="Cell body"]
  DRG_L1_L2 -> Adelta_fibers
  spinal_dorsal_horn -> spinothalamic_tract [label="Ascending\nSignal"]
  suburothelial_layer -> Adelta_fibers [label="Innervation"]
  suburothelial_layer -> C_fibers
  interstitial_cajal -> Adelta_fibers [label="Signal\nCoordination"]

  // CNS circuit
  spinothalamic_tract -> thalamus [label="Afferent\nInput"]
  thalamus -> insula [label="Interoceptive\nSensation"]
  thalamus -> anterior_cingulate [label="Urgency\nPerception"]
  insula -> prefrontal_cortex [label="Cortical\nProcessing"]
  anterior_cingulate -> prefrontal_cortex
  prefrontal_cortex -> PAG [label="Voluntary\nControl ↓"]
  PAG -> PMC [label="Gate → Voiding\nDecision"]
  PMC -> sacral_PMC_relay [label="Descending\nExcitation"]
  PMC -> descending_inhib [label="Storage\nInhibition"]
  locus_coeruleus -> PAG [label="NE Modulation"]
  raphe_nucleus -> PMC [label="5-HT\nModulation"]
  basal_ganglia -> PAG [label="Inhibitory\nGate (D1/D2)"]
  cerebellum -> PMC [label="Coordination"]
  dopamine_D1D2 -> basal_ganglia [label="D1→excite\nD2→inhibit"]
  descending_inhib -> spinal_dorsal_horn [label="GABAergic\nInhibition ↓", color="#27AE60"]

  // Efferent pathways
  sacral_PMC_relay -> sacral_parasympath [label="PMC →\nSPN activation"]
  sacral_parasympath -> pelvic_nerve [label="Preganglionic\nParsympathetic"]
  pelvic_nerve -> ganglionic_ACh [label="Ganglionic\nTransmission"]
  ganglionic_ACh -> postganglionic_ACh [label="→ M3/M2\nDetrusor"]
  postganglionic_ACh -> M3_receptor_det [label="ACh → M3\nContraction"]
  postganglionic_ACh -> M2_receptor_det [label="ACh → M2\n(cAMP↓)"]
  sympathetic_chain -> hypogastric_nerve [label="Preganglionic\nSymp"]
  hypogastric_nerve -> NE_release [label="NE → β3/α1\nARs"]
  NE_release -> beta3_AR_det [label="β3-AR\nRelaxation"]
  NE_release -> alpha1_AR_urethra [label="α1-AR\nUrethral Closure"]
  pudendal_nerve -> EUS_activation [label="Somatic\nControl"]
  descending_inhib -> EUS_activation [label="Guarding\nReflex"]

  // Detrusor signaling
  M3_receptor_det -> Gq_M3 [label="Gq coupling"]
  Gq_M3 -> PLC_IP3 [label="PLC activation"]
  PLC_IP3 -> IP3R_Ca [label="IP3 → IP3R"]
