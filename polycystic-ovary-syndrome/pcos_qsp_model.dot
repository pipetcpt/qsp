  Theca_cells -> CYP11A1_ovary    [label="induces"]
  Theca_cells -> CYP17A1_ovary    [label="induces ↑↑\n(hyperactive in PCOS)", color=red]
  Theca_cells -> INSL3            [label="produces"]
  Cholesterol_ovary -> StAR_protein [label="substrate"]
  StAR_protein -> CYP11A1_ovary  [label="delivers"]
