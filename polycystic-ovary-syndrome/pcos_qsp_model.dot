  IGFBP1 -> IGF1_circulating      [label="sequesters ↓\nfree IGF-1", color=red]
  mTOR_S6K -> IRS1_Ser            [label="feedback\nserine phos\n(negative loop)", color=red]
  PI3K_AKT -> mTOR_S6K            [label="activates"]

  GlucoseBlood -> HOMA_IR         [label="× fasting insulin"]
  Insulin_plasma -> HOMA_IR       [label="/ 22.5"]
  HOMA_IR -> T2DM_risk            [label="predicts"]
  Insulin_plasma -> SHBG          [label="suppresses ↓\n(hepatic)", color=red]
