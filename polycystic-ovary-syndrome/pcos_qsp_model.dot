  P4_neg_feedback -> GnRH_neurons [label="↓ frequency\n(absent PCOS)", color=red]
  Inhibin_B -> FSH                [label="neg. feedback ↓", color=red]
  Inhibin_A -> FSH                [label="neg. feedback ↓", color=red]
  Activin_A -> FSH                [label="stimulates ↑", color=green]
  Prolactin -> GnRH_neurons       [label="inhibits\n(high prolactin)", color=red, style=dashed]
  GH_pituitary -> IGF1_circulating [label="stimulates IGF-1\nproduction (hepatic)"]

  // ===========================================================
  // EDGES: Ovarian Steroidogenesis
  // ===========================================================
  LH -> LH_receptor_theca         [label="binds"]
