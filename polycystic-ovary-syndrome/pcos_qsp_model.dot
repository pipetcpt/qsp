digraph PCOS_QSP {
  graph [
    label="PCOS Quantitative Systems Pharmacology Model\nPolycystic Ovary Syndrome — Mechanistic Map v1.0",
    labelloc=t,
    fontsize=22,
    fontname="Helvetica",
    rankdir=TB,
    splines=ortho,
    nodesep=0.35,
    ranksep=0.55,
    bgcolor="#FAFAFA"
  ]

  node [fontname="Helvetica", fontsize=9, style=filled, shape=box]
  edge [fontsize=8, fontname="Helvetica"]

  // ===========================================================
  // CLUSTER 1: HPO Axis
  // ===========================================================
  subgraph cluster_hpo {
    label="Hypothalamo-Pituitary-Ovarian (HPO) Axis"
    style=filled; fillcolor="#EBF5FB"; color="#1A5276"
    fontsize=13; fontname="Helvetica-Bold"

    KNDy_neurons      [label="KNDy Neurons\n(Hypothalamus)", fillcolor="#AED6F1"]
    Kisspeptin        [label="Kisspeptin\n(KISS1)", fillcolor="#AED6F1"]
    NeurokininB       [label="Neurokinin B\n(NKB)", fillcolor="#AED6F1"]
    Dynorphin         [label="Dynorphin\n(DYN)", fillcolor="#AED6F1"]
    GnRH_neurons      [label="GnRH Neurons\n(Arcuate Nucleus)", fillcolor="#85C1E9"]
    GnRH_pulse        [label="GnRH Pulse\n(pulsatile secretion)", fillcolor="#85C1E9"]
    GnRH_pulse_freq   [label="GnRH Pulse\nFrequency ↑↑", fillcolor="#F1948A"]
    GnRH_pulse_amp    [label="GnRH Pulse\nAmplitude", fillcolor="#85C1E9"]
    GnRH_receptor     [label="GnRH Receptor\n(GnRHR, pituitary)", fillcolor="#5DADE2"]
    LH                [label="LH ↑↑\n(Luteinizing Hormone\n8-12 mIU/mL PCOS)", fillcolor="#F1948A"]
    FSH               [label="FSH\n(Follicle Stimulating\nHormone 4-6 mIU/mL)", fillcolor="#AED6F1"]
    LH_FSH_ratio      [label="LH:FSH Ratio\n(>2-3 in PCOS)", fillcolor="#F1948A", shape=ellipse]
    LH_surge          [label="LH Surge\n(absent/abnormal)", fillcolor="#F1948A"]
    Prolactin         [label="Prolactin\n(normal-mildly ↑)", fillcolor="#AED6F1"]
    GH_pituitary      [label="Growth Hormone\n(GH)", fillcolor="#AED6F1"]
    Inhibin_B         [label="Inhibin B\n(FSH negative feedback)", fillcolor="#A9DFBF"]
    Inhibin_A         [label="Inhibin A", fillcolor="#A9DFBF"]
    Activin_A         [label="Activin A\n(FSH stimulator)", fillcolor="#A9DFBF"]
    E2_neg_feedback   [label="E2 Negative\nFeedback\n(impaired in PCOS)", fillcolor="#F1948A"]
    P4_neg_feedback   [label="Progesterone\nNeg. Feedback\n(absent/reduced)", fillcolor="#F8C471"]
  }

  // ===========================================================
  // CLUSTER 2: Ovarian Steroidogenesis
  // ===========================================================
  subgraph cluster_steroid {
    label="Ovarian Steroidogenesis"
    style=filled; fillcolor="#EAFAF1"; color="#1E8449"
    fontsize=13; fontname="Helvetica-Bold"

    Theca_cells         [label="Theca Cells\n(↑LH-stimulated)", fillcolor="#A9DFBF"]
    Granulosa_cells     [label="Granulosa Cells\n(FSH-stimulated)", fillcolor="#A9DFBF"]
    LH_receptor_theca   [label="LH Receptor\n(LHR, theca)", fillcolor="#A9DFBF"]
    FSH_receptor_gran   [label="FSH Receptor\n(FSHR, granulosa)", fillcolor="#D5F5E3"]
    Cholesterol_ovary   [label="Cholesterol\n(substrate)", fillcolor="#F9E79F"]
    StAR_protein        [label="StAR Protein\n(cholesterol transport)", fillcolor="#F9E79F"]
    CYP11A1_ovary       [label="CYP11A1 (P450scc)\nCholesterol→Pregnenolone", fillcolor="#F9E79F"]
    Pregnenolone_ov     [label="Pregnenolone\n(ovarian)", fillcolor="#F9E79F"]
    CYP17A1_ovary       [label="CYP17A1 ↑↑\n(17α-hydroxylase\n17,20-lyase)", fillcolor="#F1948A"]
    HSD3B2_ovary        [label="3β-HSD2\n(HSD3B2)", fillcolor="#F9E79F"]
    HSD17B3_ovary       [label="17β-HSD3\n(HSD17B3)", fillcolor="#F9E79F"]
    HSD17B1_gran        [label="17β-HSD1\n(E1→E2, granulosa)", fillcolor="#F9E79F"]
    Androstenedione_ov  [label="Androstenedione\n(ovarian ↑↑)", fillcolor="#F1948A"]
    Testosterone_ov     [label="Testosterone\n(ovarian ↑↑)", fillcolor="#F1948A"]
    CYP19A1_aromatase   [label="CYP19A1 (Aromatase)\n↓ per follicle\n(AMH-inhibited)", fillcolor="#F1948A"]
    Estradiol_E2        [label="17β-Estradiol E2\n(tonic moderate ↑)", fillcolor="#D7BDE2"]
    Estrone_E1          [label="Estrone E1\n(↑ extragonadal)", fillcolor="#D7BDE2"]
    Progesterone_P4     [label="Progesterone P4\n(↓↓ anovulatory)", fillcolor="#F8C471"]
    DHEA_ovary          [label="DHEA (ovarian)", fillcolor="#F1948A"]
    AMH_gran            [label="AMH ↑↑\n(Anti-Müllerian Hormone\n3-8× normal)", fillcolor="#F1948A"]
    INSL3               [label="INSL3\n(theca marker ↑)", fillcolor="#A9DFBF"]
    cAMP_PKA_theca      [label="cAMP/PKA\n(theca signaling)", fillcolor="#D5F5E3"]
    cAMP_PKA_gran       [label="cAMP/PKA\n(granulosa signaling)", fillcolor="#D5F5E3"]
  }

  // ===========================================================
  // CLUSTER 3: Folliculogenesis & Ovarian Morphology
  // ===========================================================
  subgraph cluster_follicle {
    label="Folliculogenesis & Ovarian Morphology"
    style=filled; fillcolor="#FEF9E7"; color="#7D6608"
    fontsize=13; fontname="Helvetica-Bold"

    Primordial_pool     [label="Primordial Follicle\nPool", fillcolor="#F9E79F"]
    Primary_follicles   [label="Primary Follicles\n(FSH-independent)", fillcolor="#F9E79F"]
    Secondary_follicles [label="Secondary Follicles", fillcolor="#F9E79F"]
    SmallAntral         [label="Small Antral Follicles\n(2-5 mm, excess ↑↑)", fillcolor="#F1948A"]
    LargeAntral         [label="Antral Follicles\n(6-9 mm, arrested ↑)", fillcolor="#F1948A"]
    DominantFollicle    [label="Dominant Follicle\n(≥14 mm, absent PCOS)", fillcolor="#85C1E9"]
    CorpusLuteum        [label="Corpus Luteum\n(absent in anovulation)", fillcolor="#85C1E9"]
    FollicleAtresia     [label="Follicle Atresia ↑\n(arrested development)", fillcolor="#F1948A"]
    AFC                 [label="Antral Follicle\nCount >12 ↑", fillcolor="#F1948A", shape=ellipse]
    OvarianVolume       [label="Ovarian Volume\n(>10 mL ↑)", fillcolor="#F1948A", shape=ellipse]
    PCOM                [label="Polycystic Ovary\nMorphology (PCOM)", fillcolor="#F1948A", shape=ellipse]
    AMH_arrest          [label="AMH-Mediated\nFollicle Arrest ↑", fillcolor="#F1948A"]
    Ovulation           [label="Ovulation\n(↓/absent)", fillcolor="#85C1E9", shape=ellipse]
    OocyteQuality       [label="Oocyte Quality ↓\n(oxidative stress)", fillcolor="#F8C471", shape=ellipse]
    Endometrium         [label="Endometrium\n(unopposed E2)", fillcolor="#D7BDE2"]
    EndometrialHyperpl  [label="Endometrial\nHyperplasia Risk ↑", fillcolor="#F1948A", shape=ellipse]
  }

  // ===========================================================
  // CLUSTER 4: Insulin Signaling & Metabolic Dysfunction
  // ===========================================================
  subgraph cluster_insulin {
    label="Insulin Signaling & Metabolic Pathways"
    style=filled; fillcolor="#EBF5FB"; color="#154360"
    fontsize=13; fontname="Helvetica-Bold"

    BetaCells           [label="Pancreatic β-cells\n(compensatory ↑ secretion)", fillcolor="#AED6F1"]
    Insulin_plasma      [label="Insulin ↑\n(Hyperinsulinemia\n>15 μIU/mL fasting)", fillcolor="#F1948A"]
    InsReceptor         [label="Insulin Receptor\n(IR)", fillcolor="#AED6F1"]
    IRS1_Ser            [label="IRS1 Serine\nPhosphorylation ↑\n(insulin resistance)", fillcolor="#F1948A"]
    IRS1_Tyr            [label="IRS1 Tyrosine\nPhosphorylation ↓\n(defective)", fillcolor="#F1948A"]
    PI3K_AKT            [label="PI3K-AKT\nPathway ↓\n(metabolic, defective)", fillcolor="#F1948A"]
    GLUT4_trans         [label="GLUT4 Translocation ↓\n(skeletal muscle)", fillcolor="#F1948A"]
    GlucoseUptake       [label="Peripheral Glucose\nUptake ↓", fillcolor="#F1948A"]
    HepGluconeo         [label="Hepatic\nGluconeogenesis ↑\n(PEPCK, G6Pase ↑)", fillcolor="#F1948A"]
    FOXO1_active        [label="FOXO1 ↑\n(active, not\ninhibited by AKT)", fillcolor="#F1948A"]
    MAPK_ERK            [label="MAPK-ERK\nPathway ↑\n(mitogenic, preserved)", fillcolor="#AED6F1"]
    mTOR_S6K            [label="mTOR-S6K1\n(feedback inhibitor)", fillcolor="#F9E79F"]
    GlucoseBlood        [label="Blood Glucose ↑\n(fasting ≥100 mg/dL)", fillcolor="#F1948A", shape=ellipse]
    InsulinBlood        [label="Serum Insulin ↑\n(hyperinsulinemia)", fillcolor="#F1948A", shape=ellipse]
    HOMA_IR             [label="HOMA-IR ↑\n(≥2.5 in PCOS)", fillcolor="#F1948A", shape=ellipse]
    IGF1_circulating    [label="Free IGF-1 ↑\n(circulating)", fillcolor="#F1948A"]
    IGF1R               [label="IGF-1 Receptor\n(IGF1R, ovarian)", fillcolor="#AED6F1"]
    IGFBP1              [label="IGFBP-1 ↓\n(insulin-suppressed)", fillcolor="#F1948A"]
    IGFBP3              [label="IGFBP-3\n(partial suppression)", fillcolor="#AED6F1"]
    SHBG                [label="SHBG ↓\n(sex hormone binding\nglobulin <30 nmol/L)", fillcolor="#F1948A", shape=ellipse]
    FreeAndrogen_idx    [label="Free Androgen\nIndex (FAI) ↑", fillcolor="#F1948A", shape=ellipse]
    T2DM_risk           [label="T2DM Risk ↑\n(6-10× lifetime)", fillcolor="#F1948A", shape=ellipse]
    AdiponectinR        [label="Adiponectin\nReceptors (↓ signaling)", fillcolor="#AED6F1"]
  }

  // ===========================================================
  // CLUSTER 5: Adrenal Androgen Pathway
  // ===========================================================
  subgraph cluster_adrenal {
    label="Adrenal Androgen Pathway (50% of PCOS)"
    style=filled; fillcolor="#FDEDEC"; color="#922B21"
    fontsize=13; fontname="Helvetica-Bold"

    HPA_axis            [label="HPA Axis\n(stress)", fillcolor="#F5B7B1"]
    CRH                 [label="CRH\n(Corticotropin-releasing\nHormone)", fillcolor="#F5B7B1"]
    ACTH                [label="ACTH\n(pituitary)", fillcolor="#F5B7B1"]
    AdrenalCortexZR     [label="Adrenal Cortex\n(Zona Reticularis)", fillcolor="#F5B7B1"]
    CYP11A1_adr         [label="CYP11A1\n(adrenal scc)", fillcolor="#F5B7B1"]
    CYP17A1_adr         [label="CYP17A1 ↑\n(adrenal, 50% PCOS)", fillcolor="#F1948A"]
    HSD3B2_adr          [label="3β-HSD2\n(adrenal)", fillcolor="#F5B7B1"]
    DHEA_adr            [label="DHEA\n(adrenal)", fillcolor="#F1948A"]
    DHEAS               [label="DHEAS ↑\n(adrenal androgen\nmarker >200 μg/dL)", fillcolor="#F1948A", shape=ellipse]
    Androstenedione_adr [label="Androstenedione\n(adrenal)", fillcolor="#F1948A"]
    Cortisol            [label="Cortisol\n(normal or mildly ↑)", fillcolor="#F5B7B1"]
    SULT2A1             [label="SULT2A1\n(DHEA sulfation)", fillcolor="#F5B7B1"]
  }

  // ===========================================================
  // CLUSTER 6: Peripheral Androgen Metabolism
  // ===========================================================
  subgraph cluster_peripheral {
    label="Peripheral Androgen Metabolism & Clinical Manifestations"
    style=filled; fillcolor="#F9EBEA"; color="#7B241C"
    fontsize=13; fontname="Helvetica-Bold"

    TestosteroneCirc    [label="Total Testosterone ↑\n(>0.6 ng/mL circulating)", fillcolor="#F1948A", shape=ellipse]
    FreeTestosterone    [label="Free Testosterone ↑↑\n(bioavailable >1.5 ng/dL)", fillcolor="#F1948A", shape=ellipse]
    SRD5A1              [label="5α-Reductase 1\n(SRD5A1, skin/liver)", fillcolor="#F5B7B1"]
    SRD5A2              [label="5α-Reductase 2\n(SRD5A2, scalp/hair)", fillcolor="#F5B7B1"]
    DHT                 [label="DHT ↑\n(Dihydrotestosterone)", fillcolor="#F1948A"]
    AR_skin             [label="Androgen Receptor\n(AR, skin/pilosebaceous)", fillcolor="#F5B7B1"]
    AR_sebaceous        [label="AR in Sebaceous\nGlands", fillcolor="#F5B7B1"]
    SebumProduction     [label="Sebum Production ↑", fillcolor="#F1948A"]
    AcneVulgaris        [label="Acne Vulgaris\n(clinical hyperandrogenism)", fillcolor="#F1948A", shape=ellipse]
    HairFollicle_body   [label="Terminal Body\nHair Follicle", fillcolor="#F5B7B1"]
    Hirsutism           [label="Hirsutism\n(FG Score ≥8)", fillcolor="#F1948A", shape=ellipse]
    FG_score            [label="Ferriman-Gallwey\nScore ↑", fillcolor="#F1948A", shape=ellipse]
    ScalpHairFollicle   [label="Scalp Hair Follicle\n(miniaturization)", fillcolor="#F5B7B1"]
    AndroAlopecia       [label="Androgenic Alopecia\n(pattern)", fillcolor="#F1948A", shape=ellipse]
    CYP1A2_liver        [label="CYP1A2 (liver)\nandrogen catabolism", fillcolor="#F9E79F"]
    UGT_conjugation     [label="UGT Glucuronidation\n(excretion pathway)", fillcolor="#F9E79F"]
    ADG                 [label="3α-Androstanediol\nGlucuronide\n(5α-RA activity marker)", fillcolor="#F9E79F", shape=ellipse]
    Hyperandrogenism_cl [label="Clinical\nHyperandrogenism\n(PCOS Criterion 2)", fillcolor="#F1948A", shape=hexagon]
  }

  // ===========================================================
  // CLUSTER 7: Inflammation & Adipokines
  // ===========================================================
  subgraph cluster_inflam {
    label="Inflammatory Pathways & Adipokines"
    style=filled; fillcolor="#F4ECF7"; color="#7D3C98"
    fontsize=13; fontname="Helvetica-Bold"

    AdiposeTissue       [label="Adipose Tissue\n(visceral ↑)", fillcolor="#D7BDE2"]
    VisceralFat         [label="Visceral Adiposity ↑", fillcolor="#F1948A"]
    BMI_node            [label="BMI ↑\n(overweight/obese\n40-80% PCOS)", fillcolor="#F1948A", shape=ellipse]
    AdiposeMacrophage   [label="Adipose Macrophages\n(M1 polarization ↑)", fillcolor="#D2B4DE"]
    Adiponectin         [label="Adiponectin ↓\n(<4 μg/mL)", fillcolor="#F1948A", shape=ellipse]
    Leptin              [label="Leptin ↑\n(pro-inflammatory)", fillcolor="#F1948A", shape=ellipse]
    Resistin            [label="Resistin ↑", fillcolor="#F1948A"]
    Visfatin_NAMPT      [label="Visfatin/NAMPT ↑", fillcolor="#F1948A"]
    Chemerin            [label="Chemerin ↑", fillcolor="#F1948A"]
    TNF_alpha           [label="TNF-α ↑\n(IR mediator)", fillcolor="#F1948A"]
    IL6                 [label="IL-6 ↑", fillcolor="#F1948A"]
    IL1beta             [label="IL-1β ↑", fillcolor="#F1948A"]
    IL18                [label="IL-18 ↑\n(CVD predictor)", fillcolor="#F1948A"]
    CRP_node            [label="hsCRP ↑\n(>3 mg/L in PCOS)", fillcolor="#F1948A", shape=ellipse]
    NFkB                [label="NF-κB Pathway ↑", fillcolor="#F1948A"]
    OxidativeStress     [label="Oxidative Stress\n(↑ ROS, ↓ antioxidants)", fillcolor="#F1948A"]
    ROS_node            [label="ROS ↑\n(mitochondrial leak)", fillcolor="#F1948A"]
    MDA_node            [label="MDA ↑\n(lipid peroxidation)", fillcolor="#F1948A"]
    NO_production       [label="Nitric Oxide ↓\n(eNOS uncoupling)", fillcolor="#F1948A"]
    EndothelialDysfn    [label="Endothelial\nDysfunction", fillcolor="#F1948A"]
    AMPK_adipose        [label="AMPK Pathway ↓\n(adipose tissue)", fillcolor="#F1948A"]
  }

  // ===========================================================
  // CLUSTER 8a: Metformin PK/PD
  // ===========================================================
  subgraph cluster_metformin {
    label="Drug PK/PD: Metformin (1st-line)"
    style=filled; fillcolor="#D5F5E3"; color="#1E8449"
    fontsize=12; fontname="Helvetica-Bold"

    MET_dose            [label="Metformin Dose\n(500-2000 mg/day\noral)", fillcolor="#A9DFBF"]
    MET_gut             [label="Metformin Gut\n(absorption F≈50%)", fillcolor="#A9DFBF"]
    MET_plasma          [label="Metformin Plasma\n(Cp 1-2 mg/L at ss)", fillcolor="#A9DFBF"]
    MET_liver           [label="Metformin Liver\n(OCT1-mediated uptake)", fillcolor="#A9DFBF"]
    MET_mtETC           [label="Complex I Inhibition\n(mitochondria)", fillcolor="#58D68D"]
    MET_AMPK            [label="AMPK Activation ↑\n(hepatic + muscle)", fillcolor="#58D68D"]
    MET_gluconeo        [label="PEPCK/G6Pase ↓\nGluconeogenesis ↓", fillcolor="#58D68D"]
    MET_GLP1            [label="GLP-1 ↑\n(gut L-cells)", fillcolor="#58D68D"]
    MET_CYP17           [label="CYP17A1 ↓\n(ovary/adrenal)", fillcolor="#58D68D"]
    MET_SHBG            [label="SHBG ↑\n(secondary effect)", fillcolor="#58D68D"]
  }

  // ===========================================================
  // CLUSTER 8b: Letrozole PK/PD
  // ===========================================================
  subgraph cluster_letrozole {
    label="Drug PK/PD: Letrozole (Ovulation Induction)"
    style=filled; fillcolor="#FDEDEC"; color="#922B21"
    fontsize=12; fontname="Helvetica-Bold"

    LET_dose            [label="Letrozole 2.5-7.5 mg\n(day 3-7, oral)", fillcolor="#F5B7B1"]
    LET_plasma          [label="Letrozole Plasma\nt1/2 ≈ 48h, F≈99%", fillcolor="#F5B7B1"]
    LET_aromatase_inh   [label="CYP19A1 Inhibition\n(Ki ≈ 11 nM)", fillcolor="#E74C3C", fontcolor=white]
    LET_E2_supp         [label="E2 Suppression ↓97%\n(transient)", fillcolor="#F5B7B1"]
    LET_FSH_rise        [label="FSH Rise ↑\n(pituitary disinhibition)", fillcolor="#AED6F1"]
    LET_dominant        [label="Dominant Follicle\nDevelopment ↑", fillcolor="#A9DFBF"]
  }

  // ===========================================================
  // CLUSTER 8c: Clomiphene Citrate
  // ===========================================================
  subgraph cluster_clomiphene {
    label="Drug PK/PD: Clomiphene Citrate (SERM)"
    style=filled; fillcolor="#EBF5FB"; color="#1A5276"
    fontsize=12; fontname="Helvetica-Bold"

    CC_dose             [label="Clomiphene 50-150 mg\n(day 3-7, oral)", fillcolor="#AED6F1"]
    CC_plasma           [label="Clomiphene Plasma\nt1/2 ≈ 5-7 days", fillcolor="#AED6F1"]
    CC_ER_central       [label="Central ER Antagonism\n(hypothalamus/pituitary)", fillcolor="#5DADE2"]
    CC_GnRH_up          [label="GnRH Pulse ↑\n(central ER block)", fillcolor="#AED6F1"]
    CC_FSH_LH_rise      [label="FSH + LH Rise ↑", fillcolor="#AED6F1"]
    CC_cervical         [label="Cervical Mucus ↓\n(peripheral adverse)", fillcolor="#F1948A"]
    CC_endo_thin        [label="Endometrium ↓\n(peripheral adverse)", fillcolor="#F1948A"]
  }

  // ===========================================================
  // CLUSTER 8d: Spironolactone
  // ===========================================================
  subgraph cluster_spiro {
    label="Drug PK/PD: Spironolactone (Anti-androgen)"
    style=filled; fillcolor="#F9EBEA"; color="#7B241C"
    fontsize=12; fontname="Helvetica-Bold"

    SPR_dose            [label="Spironolactone\n50-200 mg/day", fillcolor="#F5B7B1"]
    SPR_plasma          [label="Spironolactone Plasma\nt1/2 (metabolite) ≈ 16h", fillcolor="#F5B7B1"]
    SPR_AR_block        [label="AR Competitive\nBlockade ↑", fillcolor="#E74C3C", fontcolor=white]
    SPR_SRD5A_inh       [label="5α-Reductase ↓\n(SRD5A1 partial inhib)", fillcolor="#F5B7B1"]
    SPR_T_prod_inh      [label="Testosterone\nProduction ↓\n(CYP enzyme inhibition)", fillcolor="#F5B7B1"]
    SPR_hirsutism_rx    [label="Hirsutism ↓\n(FG score ↓ 30-40%)", fillcolor="#A9DFBF"]
  }

  // ===========================================================
  // CLUSTER 8e: Combined OCP
  // ===========================================================
  subgraph cluster_ocp {
    label="Drug PK/PD: Combined OCP (EE + Progestin)"
    style=filled; fillcolor="#F4ECF7"; color="#7D3C98"
    fontsize=12; fontname="Helvetica-Bold"

    EE_dose             [label="Ethinyl Estradiol\n20-35 μg/day", fillcolor="#D7BDE2"]
    Progestin_dose      [label="Progestin\n(DRSP/LNG/NETA/CPA)", fillcolor="#D7BDE2"]
    OCP_plasma          [label="OCP Plasma\n(steady state)", fillcolor="#D7BDE2"]
    OCP_GnRH_supp       [label="GnRH/LH/FSH\nSuppression", fillcolor="#D7BDE2"]
    OCP_SHBG_up         [label="SHBG ↑ 2-4×\n(hepatic EE induction)", fillcolor="#A9DFBF"]
    OCP_T_reduce        [label="Free Testosterone ↓\n(total + free)", fillcolor="#A9DFBF"]
    OCP_ovarian_supp    [label="Ovarian\nSuppression", fillcolor="#D7BDE2"]
    OCP_menstrual_reg   [label="Menstrual Cycle\nRegulation", fillcolor="#A9DFBF"]
    DRSP_anti_andro     [label="DRSP Anti-androgen\n(3rd-gen progestin)", fillcolor="#A9DFBF"]
    CPA_anti_andro      [label="Cyproterone Acetate\n(potent anti-androgen)", fillcolor="#A9DFBF"]
  }

  // ===========================================================
  // CLUSTER 8f: GnRH Analogs (IVF)
  // ===========================================================
  subgraph cluster_gnrha {
    label="Drug PK/PD: GnRH Agonist/Antagonist (IVF)"
    style=filled; fillcolor="#FEF9E7"; color="#7D6608"
    fontsize=12; fontname="Helvetica-Bold"

    GnRHa_admin         [label="GnRH Agonist\n(Leuprolide/Buserelin\nIVF long protocol)", fillcolor="#F9E79F"]
    GnRHant_admin       [label="GnRH Antagonist\n(Cetrorelix/Ganirelix\nIVF short protocol)", fillcolor="#F9E79F"]
    GnRHa_flare         [label="Initial Flare\n(LH surge d1-2)", fillcolor="#F1948A"]
    GnRHa_downreg       [label="GnRHR\nDownregulation\n(chronic desensitization)", fillcolor="#F9E79F"]
    GnRHa_supp          [label="LH/FSH Suppression\n(pituitary downreg)", fillcolor="#F9E79F"]
    GnRHant_block       [label="GnRHR Competitive\nBlock (immediate,\nno flare)", fillcolor="#F9E79F"]
  }

  // ===========================================================
  // CLUSTER 9: Clinical Endpoints & Long-term Outcomes
  // ===========================================================
  subgraph cluster_outcomes {
    label="Clinical Endpoints & Long-term Outcomes"
    style=filled; fillcolor="#FDFDFD"; color="#17202A"
    fontsize=13; fontname="Helvetica-Bold"

    OligoAmenorrhea     [label="Oligomenorrhea/\nAmenorrhea\n(cycle >35 days)", fillcolor="#F1948A", shape=ellipse]
    Anovulation         [label="Chronic Anovulation\n(PCOS Criterion 1)", fillcolor="#F1948A", shape=hexagon]
    Infertility         [label="Infertility\n(40-80% of PCOS)", fillcolor="#F1948A", shape=ellipse]
    PregnancyRate       [label="Pregnancy Rate\n(treatment goal)", fillcolor="#A9DFBF", shape=ellipse]
    LiveBirthRate       [label="Live Birth Rate", fillcolor="#A9DFBF", shape=ellipse]
    MiscarriageRate     [label="Miscarriage Rate ↑\n(early pregnancy)", fillcolor="#F1948A", shape=ellipse]
    MetabolicSyndrome   [label="Metabolic Syndrome\n(2-3× risk ↑)", fillcolor="#F1948A", shape=ellipse]
    CVD_risk            [label="Cardiovascular Risk ↑\n(CAD, stroke 4×)", fillcolor="#F1948A", shape=ellipse]
    MenstrualRegularity [label="Menstrual\nRegularity ↑\n(treatment outcome)", fillcolor="#A9DFBF", shape=ellipse]
    DepressionAnxiety   [label="Depression/Anxiety\n(30-40% PCOS)", fillcolor="#F1948A", shape=ellipse]
    SleepApnea          [label="Sleep Apnea ↑\n(androgen-mediated)", fillcolor="#F1948A", shape=ellipse]
    GDM_risk            [label="Gestational DM ↑\n(3× risk)", fillcolor="#F1948A", shape=ellipse]
