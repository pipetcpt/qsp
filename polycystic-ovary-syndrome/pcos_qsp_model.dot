  Pregnenolone_ov -> CYP17A1_ovary [label="substrate"]
  CYP17A1_ovary -> DHEA_ovary    [label="Δ5 pathway"]
  CYP17A1_ovary -> Androstenedione_ov [label="Δ4 pathway"]
  DHEA_ovary -> Androstenedione_ov [label="3β-HSD\n(HSD3B2)"]
  HSD3B2_ovary -> Androstenedione_ov [label="catalyzes"]
  HSD3B2_ovary -> Progesterone_P4 [label="catalyzes\n(corpus luteum)"]
  Androstenedione_ov -> Testosterone_ov [label="17β-HSD3\nreduction"]
  HSD17B3_ovary -> Testosterone_ov [label="catalyzes"]
  Testosterone_ov -> CYP19A1_aromatase [label="substrate"]
  CYP19A1_aromatase -> Estradiol_E2 [label="aromatizes\n(↓ per follicle PCOS)"]
  Androstenedione_ov -> CYP19A1_aromatase [label="substrate"]
  CYP19A1_aromatase -> Estrone_E1 [label="aromatizes"]
  Estrone_E1 -> Estradiol_E2      [label="HSD17B1 reduction"]
  HSD17B1_gran -> Estradiol_E2    [label="catalyzes (gran.)"]

  FSH -> FSH_receptor_gran        [label="binds"]
  FSH_receptor_gran -> cAMP_PKA_gran [label="activates"]
  cAMP_PKA_gran -> Granulosa_cells [label="stimulates"]
  Granulosa_cells -> CYP19A1_aromatase [label="expresses ↑"]
  Granulosa_cells -> AMH_gran     [label="produces ↑↑\n(excess in PCOS)"]
  Granulosa_cells -> Inhibin_B    [label="produces"]
  Granulosa_cells -> Inhibin_A    [label="produces"]
  Granulosa_cells -> Activin_A    [label="produces"]

  Estradiol_E2 -> E2_neg_feedback [label="signals"]
  Progesterone_P4 -> P4_neg_feedback [label="signals"]

  // ===========================================================
  // EDGES: Folliculogenesis
  // ===========================================================
  Primordial_pool -> Primary_follicles [label="recruitment"]
