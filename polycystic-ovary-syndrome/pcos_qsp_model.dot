    PCOS_Rotterdam      [label="Rotterdam Criteria\n(2 of 3: OA + HA + PCOM)", fillcolor="#F1948A", shape=hexagon]
    NASHrisk            [label="NASH/NAFLD Risk ↑\n(metabolic comorbidity)", fillcolor="#F1948A", shape=ellipse]
  }

  // ===========================================================
  // EDGES: HPO Axis
  // ===========================================================
  KNDy_neurons -> Kisspeptin      [label="secretes"]
