digraph SarcopeniaQSP {
  /* Sarcopenia (Age-Related Skeletal Muscle Wasting) QSP Map
     12 clusters, 130+ nodes covering aging mechanisms, mTOR/FoxO/UPS/autophagy,
     myostatin-activin-ActRII axis, IGF-1/insulin, satellite cell senescence,
     mitochondrial dysfunction, anabolic resistance, neuromuscular junction
     decay, drug PK/PD (bimagrumab, apitegromab, GDF-15 antagonists,
     testosterone, SARMs, vitamin D, leucine/HMB, MAS receptor agonists),
     clinical endpoints (EWGSOP2: ASMI, gait speed, grip strength, SPPB).
  */
  rankdir=LR;
  graph [splines=true, overlap=false, fontname="Helvetica", labelloc="t",
         label="Sarcopenia · Age-Related Skeletal Muscle Wasting · QSP Map",
         fontsize=18, ranksep=0.55, nodesep=0.30, bgcolor="#fbfbfd"];
  node  [fontname="Helvetica", fontsize=10, style="filled,rounded",
         shape=box, color="#444", penwidth=0.6];
  edge  [fontname="Helvetica", fontsize=8, color="#666", arrowsize=0.6];

  /* ============ 1. Aging Drivers & Risk Factors ============ */
  subgraph cluster_aging {
    label="1. Aging Drivers & Risk Factors";
    style="filled,rounded"; color="#f4d8b0"; fillcolor="#fff5e1";
    AGE          [label="Chronological Aging\n(>65 y · accelerated >75)"];
    SENESCENCE   [label="Cellular Senescence\nSASP (IL-6, TNFα, MMP)"];
    INFLAMAGING  [label="Inflammaging\nIL-6↑, TNFα↑, CRP↑"];
    MITO_AGE     [label="Mitochondrial Aging\nmtDNA mutations, Δψ↓"];
    ANABOLIC_RES [label="Anabolic Resistance\n↓protein synthesis response"];
    HORMONE_DECL [label="Hormonal Decline\n↓T, ↓E2, ↓GH/IGF-1, ↓DHEA"];
    NEURO_DECL   [label="Motor Neuron Loss\n↓Alpha-MN (lumbar)"];
    PHYS_INACTIV [label="Physical Inactivity\nDisuse, Bedrest, Hospital"];
    MALNUTRITION [label="Protein/Energy Malnutrition\n<0.8 g/kg/d"];
    CHRONIC_DIS  [label="Chronic Disease\nCKD, COPD, CHF, Cancer"];
    OXIDATIVE    [label="Oxidative Stress\nROS, 4-HNE, 8-OHdG"];
    GUT_DYS      [label="Gut Dysbiosis\n↓SCFA, leaky barrier"];
    EPIGENETICS  [label="Epigenetic Drift\nDNAm aging clock"];
  }

  /* ============ 2. Protein Synthesis (MPS) — Anabolic Pathway ============ */
  subgraph cluster_mps {
    label="2. Muscle Protein Synthesis (MPS) — mTORC1/Akt Axis";
    style="filled,rounded"; color="#a0c8e8"; fillcolor="#eaf3fb";
    LEUCINE      [label="Leucine\n(EAA trigger)"];
    HMB          [label="β-Hydroxy-β-methylbutyrate (HMB)\nLeucine metabolite"];
    DIETARY_AA   [label="Dietary Amino Acids\n(EAA, BCAA)"];
    INSULIN      [label="Insulin\n(postprandial)"];
    IGF1         [label="IGF-1\n(systemic + autocrine)"];
    GH           [label="Growth Hormone\n(pituitary, pulsatile)"];
    IR_IGF1R     [label="IR / IGF-1R\n(membrane RTK)"];
    IRS1         [label="IRS-1\nphosphorylation"];
    PI3K         [label="PI3K"];
    AKT          [label="Akt (PKB)\np-Ser473, p-Thr308"];
    TSC1_TSC2    [label="TSC1/TSC2\nGAP for Rheb"];
    RHEB         [label="Rheb-GTP"];
    MTORC1       [label="mTORC1\nRaptor·mLST8·PRAS40"];
    S6K1         [label="p70 S6K1\np-Thr389"];
    RPS6         [label="rpS6\np-Ser235/236"];
    EIF4EBP1     [label="4E-BP1\np-Thr37/46"];
    EIF4E        [label="eIF4E"];
    EIF4F_CPLX   [label="eIF4F complex\nCap-dep translation"];
    MUSCLE_PROT  [label="Muscle Protein Synthesis\n(FSR %·d⁻¹)"];
    MYOFIBRIL    [label="Myofibrillar Proteins\n(actin/myosin/titin)"];
    SARCO_PROT   [label="Sarcoplasmic Proteins"];
    RAGULATOR    [label="Ragulator/Rag GTPases\nLysosomal mTOR docking"];
    SESN2        [label="Sestrin2\nLeucine sensor (GATOR2)"];
    CASTOR1      [label="CASTOR1\nArginine sensor"];
    SAMTOR       [label="SAMTOR\nSAM/methionine sensor"];
  }

  /* ============ 3. Protein Degradation — UPS & Autophagy ============ */
  subgraph cluster_degradation {
    label="3. Protein Degradation — UPS & Autophagy/Lysosomes";
    style="filled,rounded"; color="#e8a0a0"; fillcolor="#fbeaea";
    FOXO         [label="FoxO1/3a\nnuclear translocation"];
    ATROGIN1     [label="Atrogin-1 / MAFbx\n(FBXO32)"];
    MURF1        [label="MuRF1 / TRIM63"];
    UBIQUITIN    [label="Ubiquitin-Proteasome\n(26S, K48-poly-Ub)"];
    PROTEOLYSIS  [label="Myofibrillar Proteolysis\n(MPB, FBR)"];
    LC3          [label="LC3-II\n(autophagosome)"];
    BECLIN1      [label="Beclin-1\n(VPS34 complex)"];
    P62_SQSTM    [label="p62 / SQSTM1\n(cargo adaptor)"];
    ATG7         [label="ATG7 / ATG12-5"];
    AUTOPHAGY    [label="Autophagy Flux\n(macroautophagy)"];
    CHAPERONE    [label="Chaperone-Mediated\nAutophagy (LAMP2A)"];
    LYSOSOME     [label="Lysosomal Proteolysis\nCathepsin B/L"];
    CALPAIN      [label="Calpain 1/2\n(Ca²⁺-activated)"];
    CASPASE3     [label="Caspase-3\n(apoptotic cleavage)"];
    AMPK         [label="AMPK\np-Thr172"];
    ULK1         [label="ULK1\np-Ser555 (active)\np-Ser757 (inhibited)"];
    REDD1        [label="REDD1 / DDIT4\n(stress-induced)"];
  }

  /* ============ 4. Myostatin–Activin–ActRII Axis ============ */
  subgraph cluster_myostatin {
    label="4. Myostatin–Activin–ActRII Negative Regulator Axis";
    style="filled,rounded"; color="#d0b0e0"; fillcolor="#f3e8f8";
    MSTN         [label="Myostatin (GDF-8)\n(MSTN gene)"];
    PROMSTN      [label="Promyostatin / Latent\n(LAP·prodomain)"];
    ACTIVIN_A    [label="Activin A (INHBA)"];
    ACTIVIN_B    [label="Activin B (INHBB)"];
    GDF11        [label="GDF-11"];
    BMP_LIGANDS  [label="BMP-7, BMP-14\n(anabolic counter)"];
    FOLLISTATIN  [label="Follistatin / FSTL3\n(natural antagonist)"];
    ACTRIIA      [label="ActRIIA\n(receptor)"];
    ACTRIIB      [label="ActRIIB\n(primary signal)"];
    ALK4_ALK5    [label="ALK4 / ALK5\n(type I)"];
    SMAD2_3      [label="SMAD2/3\n(p-C-term)"];
    SMAD4        [label="SMAD4\n(co-SMAD)"];
    SMAD7        [label="SMAD7\n(I-SMAD feedback)"];
    SMAD_TARGETS [label="SMAD Targets\n(transcription)"];
    GDF15        [label="GDF-15\n(stress cytokine)"];
    GFRAL        [label="GFRAL\n(hindbrain)"];
  }

  /* ============ 5. Inflammation & Cytokines ============ */
  subgraph cluster_inflamm {
    label="5. Inflammation, Cytokines & NF-κB";
    style="filled,rounded"; color="#f0c060"; fillcolor="#fdf3d8";
    IL6          [label="IL-6\n(myokine·systemic)"];
    TNF_ALPHA    [label="TNF-α\n(catabolic)"];
    IL1B         [label="IL-1β"];
    IL15         [label="IL-15\n(anti-sarcopenic myokine)"];
    NFKB         [label="NF-κB (p65/p50)\nnuclear"];
    IKBA         [label="IκBα\n(phospho-degradation)"];
    JAK_STAT     [label="JAK1/2-STAT3"];
    SOCS3        [label="SOCS3\n(IL-6 feedback)"];
    CRP_SERUM    [label="hsCRP\n(serum)"];
    MACROPHAGE   [label="M1 Macrophage\ninfiltration"];
    NEUTROPHIL   [label="Neutrophil\n(low-grade)"];
    REG_T        [label="Treg / Anti-inflam"];
    COX2_PGE2    [label="COX-2 / PGE2"];
  }

  /* ============ 6. Mitochondrial Function & Energy ============ */
  subgraph cluster_mito {
    label="6. Mitochondrial Function, Biogenesis & ROS";
    style="filled,rounded"; color="#80c8a8"; fillcolor="#e6f3ec";
    PGC1A        [label="PGC-1α\n(master regulator)"];
    NRF1_NRF2    [label="NRF1 / NRF2"];
    TFAM         [label="TFAM\n(mtDNA replication)"];
    MITO_BIOG    [label="Mitochondrial\nBiogenesis"];
    MITO_MASS    [label="Mitochondrial Content\n(citrate synth., mtDNA)"];
    OXPHOS       [label="OXPHOS Capacity\nETC complex I-V"];
    ATP_PROD     [label="ATP Production\n(MyoP-CK / OXPHOS)"];
    ROS          [label="Mitochondrial ROS\nO₂⁻, H₂O₂"];
    SOD2         [label="MnSOD / SOD2"];
    UCP3         [label="UCP3\n(uncoupling)"];
    PARKIN_PINK1 [label="PINK1 / Parkin\nMitophagy"];
    DRP1_MFN     [label="Drp1 / Mfn1/2\nFission-Fusion"];
    SIRT1        [label="SIRT1\nNAD⁺-dependent"];
    NAD_NADH     [label="NAD⁺ / NADH ratio"];
    NMN_NR       [label="NMN / NR\n(precursor)"];
  }

  /* ============ 7. Satellite Cells & Regeneration ============ */
  subgraph cluster_satellite {
    label="7. Satellite Cells, Myogenesis & Regeneration";
    style="filled,rounded"; color="#b0a0d8"; fillcolor="#ece8f7";
    SATELLITE    [label="Satellite Cells\nPax7⁺ (quiescent pool)"];
    MYOD         [label="MyoD\n(activation)"];
    MYF5         [label="Myf5\n(commitment)"];
    MYOGENIN     [label="Myogenin\n(differentiation)"];
    MYOBLAST     [label="Myoblast\n(proliferating)"];
    MYOCYTE      [label="Myocyte\n(differentiating)"];
    MYOTUBE      [label="Myotube → Myofiber\n(fusion)"];
    NOTCH        [label="Notch signaling\n(quiescence)"];
    WNT          [label="Wnt / β-catenin\n(commitment)"];
    SC_SENES     [label="SC Senescence\np16⁺ / p21⁺ (aged)"];
    GDF11_AGE    [label="GDF-11 (age↑)\nimpairs SC"];
  }

  /* ============ 8. NMJ, Fiber Type, Bone ============ */
  subgraph cluster_nmj_fiber {
    label="8. Neuromuscular Junction, Fiber Type, Muscle-Bone Crosstalk";
    style="filled,rounded"; color="#c0d8a0"; fillcolor="#f0f5e2";
    ALPHA_MN     [label="α-Motor Neuron\n(lumbar spinal)"];
    AXON_TERM    [label="Axon Terminal\nSchwann cell"];
    NMJ          [label="NMJ Morphology\nendplate fragmentation"];
    AGRIN        [label="Agrin / MuSK / LRP4\n(AChR clustering)"];
    ACHE         [label="AChE / AChR\n(neuromuscular signal)"];
    DENERVATION  [label="Denervation\n(motor unit loss)"];
    REINNERV     [label="Reinnervation\n(collateral sprouting)"];
    FIBER_I      [label="Type I Slow-Twitch\nMHCI (oxidative)"];
    FIBER_IIA    [label="Type IIA Fast-Ox"];
    FIBER_IIX    [label="Type IIX Fast-Glycolytic\n(preferential atrophy)"];
    FIBER_SHIFT  [label="Fiber Type Switch\n(I→IIa→IIx loss)"];
    OSTEO_CROSS  [label="Muscle-Bone Crosstalk\nosteokines (RANKL, IGF-1)"];
    BMD          [label="Bone Mineral Density\n(secondary loss)"];
    MYOSTEATOSIS [label="Myosteatosis\n(IMAT, IMCL)"];
  }

  /* ============ 9. Drug PK/PD ============ */
  subgraph cluster_drugs {
    label="9. Pharmacological Interventions (PK/PD)";
    style="filled,rounded"; color="#f8b8d8"; fillcolor="#fde8f3";
    BIMAGRUMAB   [label="Bimagrumab (BYM338)\nActRII mAb (anti-IIA/B)"];
    APITEGROMAB  [label="Apitegromab (SRK-015)\npro/latent-MSTN mAb"];
    LANDOGROZUMAB[label="Landogrozumab (LY2495655)\nmyostatin mAb"];
    TROVAGENE    [label="Trevogrumab (REGN1033)\nmyostatin mAb"];
    DOMAGROZUMAB [label="Domagrozumab (PF-06252616)"];
    GARETOSMAB   [label="Garetosmab\nActivin A mAb"];
    SOTATERCEPT  [label="Sotatercept / Luspatercept\nActRIIA-Fc trap"];
    TESTOSTERONE [label="Testosterone\n(IM 100 mg/wk, transdermal)"];
    DHEA         [label="DHEA / Δ4-androstene"];
    GH_DRUG      [label="rhGH (Somatropin)\n(SC injection)"];
    MK677        [label="Ibutamoren / MK-677\n(ghrelin agonist)"];
    SARM         [label="SARMs\n(LGD-4033 ligandrol, enobosarm)"];
    VITD         [label="Vitamin D₃ / Calcifediol\n800-2000 IU/d"];
    OMEGA3       [label="ω-3 PUFA (EPA/DHA)\n2-3 g/d"];
    LEUCINE_DRUG [label="Leucine / HMB (drug)\n3 g/d"];
    CREATINE     [label="Creatine Monohydrate\n3-5 g/d"];
    UROLITHIN_A  [label="Urolithin A\n(mitophagy enhancer)"];
    BCAA         [label="BCAA Mixture"];
    MAS_AG       [label="MAS Receptor Agonists\n(Ang-(1-7))"];
    ANAMORELIN   [label="Anamorelin\n(ghrelin agonist - cachexia)"];
    METFORMIN    [label="Metformin\n(MASTERS trial)"];
    RAPAMYCIN    [label="Rapamycin (mTOR inhibitor)\n(controversial)"];
    EXERCISE     [label="Resistance Exercise\n(non-drug standard)"];
    EAA_SUPP     [label="EAA Supplementation\n(15-20 g/meal)"];
    NMN_DRUG     [label="NMN / NR\n(NAD⁺ precursor)"];
  }

  /* ============ 10. Clinical Endpoints (EWGSOP2 / FNIH) ============ */
  subgraph cluster_clinical {
    label="10. Clinical Endpoints — EWGSOP2 / FNIH / SDOC";
    style="filled,rounded"; color="#f8e0a0"; fillcolor="#fef6e1";
    MUSCLE_MASS  [label="Skeletal Muscle Mass\n(DXA, MRI, BIA)"];
    ASMI         [label="Appendicular Lean Mass Index\n(ALM/h², kg/m²)"];
    MUSCLE_STR   [label="Muscle Strength\n(grip, knee extension)"];
    GRIP         [label="Hand Grip Strength\nM<27 kg, F<16 kg (EWGSOP2)"];
    PHYS_PERF    [label="Physical Performance\n(gait, SPPB, TUG)"];
    GAIT_SPEED   [label="Gait Speed (4 m)\n<0.8 m/s (severe sarcopenia)"];
    SPPB         [label="SPPB ≤8 / 12"];
    CHAIR_STAND  [label="5-Times Chair Stand\n>15 s"];
    SARC_F       [label="SARC-F Questionnaire\n≥4 → screen+"];
    FALLS        [label="Falls & Fractures"];
    DISABILITY   [label="ADL/IADL Disability"];
    FRAILTY      [label="Frailty Index\n(Fried criteria)"];
    HOSPITAL     [label="Hospitalization Risk\n(HR↑)"];
    MORTALITY    [label="All-Cause Mortality\nHR 1.7-3.0"];
    BODY_COMP    [label="Body Composition\n(SMI, IMAT, IMCL)"];
    QOL          [label="Quality of Life\nSF-36, SarQoL"];
  }

  /* ============ 11. Biomarkers ============ */
  subgraph cluster_biomarkers {
    label="11. Biomarkers & Lab Surrogates";
    style="filled,rounded"; color="#a8d8d8"; fillcolor="#e4f1f1";
    P3NP         [label="P3NP\n(serum collagen synthesis)"];
    CK_SERUM     [label="Creatine Kinase\n(serum)"];
    CREATININE   [label="Serum Creatinine\n(low → low mass)"];
    SCD          [label="D3-Creatine Dilution\n(total body MM)"];
    GDF15_BIO    [label="GDF-15 (serum)\naging biomarker"];
    CAF          [label="C-Agrin Fragment\n(CAF22) urine"];
    SERUM_MSTN   [label="Serum Myostatin\n(GDF-8)"];
    IGF1_BIO     [label="Serum IGF-1\n(<100 ng/mL)"];
    VITD_BIO     [label="25(OH)D\n(<30 ng/mL)"];
    ALBUMIN      [label="Serum Albumin\n<3.5 g/dL"];
    PHASE_ANGLE  [label="BIA Phase Angle\n(<4.5°)"];
  }

  /* ============ 12. Comorbidity / Subtypes ============ */
  subgraph cluster_subtype {
    label="12. Sarcopenia Subtypes & Comorbid Drivers";
    style="filled,rounded"; color="#d8b890"; fillcolor="#f5ead8";
    PRIMARY_SARC [label="Primary Sarcopenia\n(age-related)"];
    SECONDARY    [label="Secondary Sarcopenia"];
    SARCOPENIC_O [label="Sarcopenic Obesity\n(high IMAT + low MM)"];
    CACHEXIA     [label="Cancer Cachexia\n(weight loss + low MM)"];
    CKD_MM       [label="CKD-Related Muscle Wasting"];
    COPD_MM      [label="COPD-Related Wasting"];
    POSTOP       [label="Postoperative / ICU\n(acute disuse)"];
    DIABETES_MM  [label="Type 2 DM\n(anabolic resistance)"];
  }

  /* ===================== Edges ===================== */

  /* Aging drivers → mechanisms */
  AGE -> SENESCENCE [label="cell stress"];
  AGE -> MITO_AGE; AGE -> NEURO_DECL; AGE -> HORMONE_DECL;
  AGE -> ANABOLIC_RES; AGE -> EPIGENETICS; AGE -> NMJ;
  SENESCENCE -> INFLAMAGING [label="SASP"];
  INFLAMAGING -> IL6; INFLAMAGING -> TNF_ALPHA; INFLAMAGING -> CRP_SERUM;
  MITO_AGE -> OXPHOS [arrowhead=tee]; MITO_AGE -> ROS;
  HORMONE_DECL -> IGF1 [arrowhead=tee]; HORMONE_DECL -> GH [arrowhead=tee];
  HORMONE_DECL -> TESTOSTERONE [arrowhead=tee];
  PHYS_INACTIV -> MUSCLE_PROT [arrowhead=tee];
  PHYS_INACTIV -> FOXO; PHYS_INACTIV -> ATROGIN1;
  MALNUTRITION -> LEUCINE [arrowhead=tee]; MALNUTRITION -> DIETARY_AA [arrowhead=tee];
  MALNUTRITION -> ALBUMIN [arrowhead=tee];
  CHRONIC_DIS -> INFLAMAGING; CHRONIC_DIS -> ANABOLIC_RES;
  OXIDATIVE -> MITO_AGE; OXIDATIVE -> PROTEOLYSIS;
  GUT_DYS -> INFLAMAGING; GUT_DYS -> DIETARY_AA [arrowhead=tee];
  EPIGENETICS -> SC_SENES;
  NEURO_DECL -> DENERVATION; NEURO_DECL -> NMJ;

  /* MPS pathway */
  LEUCINE -> SESN2 [arrowhead=tee, label="releases GATOR2"];
  LEUCINE -> RAGULATOR; HMB -> MTORC1;
  DIETARY_AA -> LEUCINE; DIETARY_AA -> BCAA;
  INSULIN -> IR_IGF1R; IGF1 -> IR_IGF1R;
  GH -> IGF1 [label="hepatic"];
  IR_IGF1R -> IRS1 -> PI3K -> AKT;
  AKT -> TSC1_TSC2 [arrowhead=tee, label="phospho-inhibit"];
  TSC1_TSC2 -> RHEB [arrowhead=tee, label="GAP"];
  RHEB -> MTORC1;
  RAGULATOR -> MTORC1 [label="lysosomal"];
  MTORC1 -> S6K1; S6K1 -> RPS6;
  MTORC1 -> EIF4EBP1 [arrowhead=tee, label="releases eIF4E"];
  EIF4EBP1 -> EIF4E [arrowhead=tee];
  EIF4E -> EIF4F_CPLX;
  S6K1 -> EIF4F_CPLX;
  EIF4F_CPLX -> MUSCLE_PROT;
  MUSCLE_PROT -> MYOFIBRIL; MUSCLE_PROT -> SARCO_PROT;
  CASTOR1 -> MTORC1 [arrowhead=tee]; SAMTOR -> MTORC1 [arrowhead=tee];

  /* Akt → FoxO branch */
  AKT -> FOXO [arrowhead=tee, label="phospho → cytosol"];
  FOXO -> ATROGIN1; FOXO -> MURF1; FOXO -> LC3; FOXO -> BECLIN1;
  ATROGIN1 -> UBIQUITIN; MURF1 -> UBIQUITIN;
  UBIQUITIN -> PROTEOLYSIS [label="K48 → 26S"];
  P62_SQSTM -> AUTOPHAGY; BECLIN1 -> AUTOPHAGY; ATG7 -> AUTOPHAGY;
  LC3 -> AUTOPHAGY; CHAPERONE -> LYSOSOME;
  AUTOPHAGY -> PROTEOLYSIS; LYSOSOME -> PROTEOLYSIS;
  CALPAIN -> PROTEOLYSIS; CASPASE3 -> PROTEOLYSIS;
  AMPK -> TSC1_TSC2 [label="phospho-activate"];
  AMPK -> ULK1; ULK1 -> AUTOPHAGY;
  MTORC1 -> ULK1 [arrowhead=tee, label="p-Ser757"];
  REDD1 -> TSC1_TSC2 [label="stabilize"];
  PROTEOLYSIS -> MYOFIBRIL [arrowhead=tee];

  /* Myostatin axis */
  PROMSTN -> MSTN [label="furin/BMP1 cleavage"];
  MSTN -> ACTRIIB; MSTN -> ACTRIIA;
  ACTIVIN_A -> ACTRIIB; ACTIVIN_A -> ACTRIIA;
  ACTIVIN_B -> ACTRIIB; GDF11 -> ACTRIIB;
  ACTRIIB -> ALK4_ALK5; ACTRIIA -> ALK4_ALK5;
  ALK4_ALK5 -> SMAD2_3; SMAD2_3 -> SMAD4;
  SMAD2_3 -> SMAD_TARGETS; SMAD4 -> SMAD_TARGETS;
  SMAD7 -> SMAD2_3 [arrowhead=tee];
  SMAD_TARGETS -> ATROGIN1; SMAD_TARGETS -> MURF1;
  SMAD_TARGETS -> MUSCLE_PROT [arrowhead=tee];
  SMAD2_3 -> AKT [arrowhead=tee, label="cross-inhibit"];
  FOLLISTATIN -> MSTN [arrowhead=tee]; FOLLISTATIN -> ACTIVIN_A [arrowhead=tee];
  FOLLISTATIN -> ACTIVIN_B [arrowhead=tee];
  BMP_LIGANDS -> MUSCLE_PROT [label="anabolic"];
  GDF15 -> GFRAL [label="hindbrain"]; GFRAL -> MALNUTRITION [label="anorexia"];
  AGE -> GDF15; MITO_AGE -> GDF15;

  /* Inflammation */
  IL6 -> JAK_STAT; JAK_STAT -> SOCS3 [label="feedback"];
  SOCS3 -> IRS1 [arrowhead=tee, label="anabolic resistance"];
  TNF_ALPHA -> IKBA [label="phospho"]; IKBA -> NFKB [label="release"];
  IL1B -> NFKB; NFKB -> ATROGIN1; NFKB -> MURF1;
  NFKB -> IL6; NFKB -> TNF_ALPHA;
  IL15 -> MUSCLE_PROT [label="anabolic myokine"];
  MACROPHAGE -> TNF_ALPHA; MACROPHAGE -> IL6;
  NEUTROPHIL -> COX2_PGE2; COX2_PGE2 -> MUSCLE_PROT [arrowhead=tee];
  REG_T -> INFLAMAGING [arrowhead=tee];
  INFLAMAGING -> ANABOLIC_RES;

  /* Mitochondria */
  PGC1A -> NRF1_NRF2; NRF1_NRF2 -> TFAM; TFAM -> MITO_MASS;
  PGC1A -> MITO_BIOG; MITO_BIOG -> MITO_MASS; MITO_MASS -> OXPHOS;
  OXPHOS -> ATP_PROD; OXPHOS -> ROS;
  ROS -> SOD2 [arrowhead=tee, label="scavenge"];
  ROS -> MITO_AGE; ROS -> NFKB;
  UCP3 -> OXPHOS [arrowhead=tee];
  PARKIN_PINK1 -> AUTOPHAGY [label="mitophagy"];
  PARKIN_PINK1 -> MITO_MASS [arrowhead=tee];
  DRP1_MFN -> MITO_MASS;
  SIRT1 -> PGC1A; NAD_NADH -> SIRT1; NMN_NR -> NAD_NADH;
  AMPK -> PGC1A; ATP_PROD -> AMPK [arrowhead=tee, label="AMP:ATP ratio"];

  /* Satellite cells */
  SATELLITE -> MYOD; MYOD -> MYF5; MYF5 -> MYOGENIN;
  MYOGENIN -> MYOBLAST; MYOBLAST -> MYOCYTE; MYOCYTE -> MYOTUBE;
  MYOTUBE -> MUSCLE_PROT;
  NOTCH -> SATELLITE [label="self-renewal"];
  WNT -> MYOD; SC_SENES -> SATELLITE [arrowhead=tee];
  GDF11_AGE -> SC_SENES;
  EPIGENETICS -> SC_SENES;
  AGE -> SATELLITE [arrowhead=tee];

  /* NMJ / fiber type */
  ALPHA_MN -> AXON_TERM; AXON_TERM -> NMJ;
  AGRIN -> NMJ; ACHE -> NMJ; NMJ -> FIBER_I; NMJ -> FIBER_IIA;
  DENERVATION -> FIBER_IIX [label="preferential atrophy"];
  DENERVATION -> REINNERV; REINNERV -> FIBER_I [label="type grouping"];
  FIBER_I -> MUSCLE_MASS; FIBER_IIA -> MUSCLE_MASS; FIBER_IIX -> MUSCLE_MASS;
  FIBER_SHIFT -> MUSCLE_STR;
  MYOSTEATOSIS -> MUSCLE_STR [arrowhead=tee];
  MUSCLE_MASS -> OSTEO_CROSS; OSTEO_CROSS -> BMD;

  /* Drugs */
  BIMAGRUMAB -> ACTRIIA [arrowhead=tee]; BIMAGRUMAB -> ACTRIIB [arrowhead=tee];
  APITEGROMAB -> PROMSTN [arrowhead=tee, label="latent only"];
  LANDOGROZUMAB -> MSTN [arrowhead=tee];
  TROVAGENE -> MSTN [arrowhead=tee];
  DOMAGROZUMAB -> MSTN [arrowhead=tee];
  GARETOSMAB -> ACTIVIN_A [arrowhead=tee];
  SOTATERCEPT -> ACTRIIA [arrowhead=tee, label="ligand trap"];
  TESTOSTERONE -> MUSCLE_PROT [label="AR transcription"];
  TESTOSTERONE -> SATELLITE; DHEA -> TESTOSTERONE;
  GH_DRUG -> GH; MK677 -> GH;
  SARM -> MUSCLE_PROT [label="AR tissue selective"];
  VITD -> MUSCLE_STR [label="VDR / Ca²⁺ flux"];
  OMEGA3 -> ANABOLIC_RES [arrowhead=tee, label="enhance MPS"];
  OMEGA3 -> INFLAMAGING [arrowhead=tee];
  LEUCINE_DRUG -> LEUCINE; CREATINE -> ATP_PROD;
  UROLITHIN_A -> PARKIN_PINK1; UROLITHIN_A -> MITO_MASS;
  BCAA -> LEUCINE;
  MAS_AG -> MUSCLE_PROT; MAS_AG -> AKT;
  ANAMORELIN -> GH; ANAMORELIN -> MK677;
  METFORMIN -> AMPK; RAPAMYCIN -> MTORC1 [arrowhead=tee];
  EXERCISE -> MTORC1; EXERCISE -> PGC1A; EXERCISE -> SATELLITE;
  EXERCISE -> ANABOLIC_RES [arrowhead=tee];
  EAA_SUPP -> DIETARY_AA; EAA_SUPP -> LEUCINE;
  NMN_DRUG -> NMN_NR;

  /* Clinical translations */
  MUSCLE_PROT -> MUSCLE_MASS [label="net balance"];
  PROTEOLYSIS -> MUSCLE_MASS [arrowhead=tee];
  MUSCLE_MASS -> ASMI; MUSCLE_MASS -> SCD; MUSCLE_MASS -> CREATININE;
  MUSCLE_STR -> GRIP; MUSCLE_STR -> SPPB; MUSCLE_STR -> CHAIR_STAND;
  GAIT_SPEED -> PHYS_PERF; SPPB -> PHYS_PERF;
  SARC_F -> PHYS_PERF; SARC_F -> GRIP;
  PHYS_PERF -> FALLS; MUSCLE_STR -> FALLS;
  FALLS -> FRAILTY; FRAILTY -> HOSPITAL; HOSPITAL -> MORTALITY;
  DISABILITY -> QOL; FRAILTY -> DISABILITY;
  BODY_COMP -> ASMI; BODY_COMP -> MYOSTEATOSIS;
  MYOSTEATOSIS -> ANABOLIC_RES;

  /* Biomarker links */
  MUSCLE_PROT -> P3NP; PROTEOLYSIS -> CK_SERUM;
  MSTN -> SERUM_MSTN; IGF1 -> IGF1_BIO; VITD -> VITD_BIO;
  GDF15 -> GDF15_BIO; DENERVATION -> CAF;
  MALNUTRITION -> ALBUMIN;

  /* Subtypes */
  AGE -> PRIMARY_SARC; CHRONIC_DIS -> SECONDARY;
  SARCOPENIC_O -> MYOSTEATOSIS; CACHEXIA -> GDF15;
  CKD_MM -> ACIDOSIS_DUMMY [style=invis]; /* placeholder */
  CKD_MM -> SECONDARY; COPD_MM -> SECONDARY;
  POSTOP -> PHYS_INACTIV; DIABETES_MM -> ANABOLIC_RES;
  PRIMARY_SARC -> ASMI; SECONDARY -> ASMI;

  /* Diagnostic gates */
  ASMI -> SARC_F [style=dotted, color="#aa6"];
  GAIT_SPEED -> SARC_F [style=dotted, color="#aa6"];
  GRIP -> SARC_F [style=dotted, color="#aa6"];

  /* Legend */
  subgraph cluster_legend {
    label="Legend"; style="filled,rounded"; color="#888"; fillcolor="#f0f0f0";
    LGD1 [label="Solid arrow: activation / stimulation", shape=plaintext];
    LGD2 [label="⊥ (T-arrow): inhibition / suppression", shape=plaintext];
    LGD3 [label="Dotted: clinical diagnostic gate", shape=plaintext];
    LGD4 [label="Cluster colors: 12 functional domains", shape=plaintext];
  }
}
