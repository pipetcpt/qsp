        dose_VBZ -> VBZ_plasma [label="F~49%"]
        dose_tominersen -> tominersen_CSF [label="intrathecal\ndelivery"]
        dose_branaplam -> branaplam_brain [label="oral→CNS"]
        dose_riluzole -> riluzole_plasma [label="F~60%"]
        dose_memantine -> memantine_brain [label="F~100%"]
        HTBZ_active -> BBB [label="CNS entry"]
        VBZ_plasma -> BBB [label="CNS entry"]
        riluzole_plasma -> BBB [label="CNS entry"]
        memantine_brain -> NMDAR_extra [label="NMDAR\nblockade" color="#388e3c"]
    }

    // ============================================================
