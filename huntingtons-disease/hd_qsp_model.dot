        GABA_enhancement [label="GABAergic\nEnhancement" fillcolor="#a5d6a7"]
        memantine_pd [label="Memantine\neNMDAR Blockade" fillcolor="#b2dfdb"]

        HTBZ_active -> VMAT2_inhibition [label="VMAT2 binding"]
        VBZ_plasma -> VMAT2_inhibition [label="VMAT2 binding"]
        VMAT2_inhibition -> VMAT2 [label="reduces" color="#e53935"]
        VMAT2 -> DA_vesicular [label="stores"]
