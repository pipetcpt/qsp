digraph HuntingtonsDisease_QSP {
    graph [
        label="Huntington's Disease — Quantitative Systems Pharmacology Model\nCAG Repeat Expansion → mHTT Pathology → Striatal Neurodegeneration → Clinical Endpoints"
        fontname="Helvetica" fontsize=20 fontcolor="#1a1a2e"
        bgcolor="#f8f9fa"
        rankdir=TB
        nodesep=0.35 ranksep=0.55
        pad=0.6
        concentrate=false
    ]
    node [fontname="Helvetica" fontsize=9 style="filled,rounded" shape=box width=1.6 height=0.45]
    edge [fontname="Helvetica" fontsize=7 arrowsize=0.55]

    // ============================================================
    // SUBGRAPH 1: GENETIC BASIS & mHTT PRODUCTION
    // ============================================================
    subgraph cluster_genetic {
        label="1. Genetic Basis & mHTT Production"
        style=filled fillcolor="#e8f4f8" color="#2196F3" penwidth=2
        fontname="Helvetica-Bold" fontsize=11 fontcolor="#2196F3"

        HTT_gene [label="HTT Gene\n(Chr 4p16.3)" fillcolor="#bbdefb"]
        CAG_repeat [label="CAG Repeat ≥36\nExpansion" fillcolor="#ef9a9a"]
        polyQ [label="PolyGlutamine\nTract (polyQ)" fillcolor="#ef9a9a"]
        wtHTT [label="Wild-type HTT\nProtein" fillcolor="#c8e6c9"]
        mHTT_mRNA [label="mHTT mRNA\n(pre-mRNA)" fillcolor="#ffcc80"]
        mHTT_protein [label="Mutant HTT\nProtein (mHTT)" fillcolor="#e53935" fontcolor=white]
        HTT_cleavage [label="HTT Cleavage\n(Caspase-3/6)" fillcolor="#ff8a65"]
        mHTT_Nterm [label="mHTT N-terminal\nFragments" fillcolor="#e53935" fontcolor=white]
        CAP_score [label="CAP Score\n(CAG × Age)" fillcolor="#ef9a9a"]

        HTT_gene -> CAG_repeat [label=">36 repeats" color="#e53935"]
        CAG_repeat -> polyQ [label="translation"]
        polyQ -> mHTT_protein
        HTT_gene -> mHTT_mRNA [label="transcription"]
        mHTT_mRNA -> mHTT_protein [label="translation"]
        HTT_gene -> wtHTT [label="normal allele" color="#388e3c"]
        mHTT_protein -> HTT_cleavage [label="caspase\nactivation"]
        HTT_cleavage -> mHTT_Nterm [label="toxic\nfragments"]
        CAG_repeat -> CAP_score [label="× patient age" color="#e53935"]
    }

    // ============================================================
    // SUBGRAPH 2: mHTT AGGREGATION CASCADE
    // ============================================================
    subgraph cluster_aggregation {
        label="2. mHTT Aggregation Cascade"
        style=filled fillcolor="#fce4ec" color="#e91e63" penwidth=2
        fontname="Helvetica-Bold" fontsize=11 fontcolor="#e91e63"

        mHTT_monomer [label="mHTT Monomer\n(soluble)" fillcolor="#f48fb1"]
        mHTT_oligomer [label="mHTT Oligomers\n(toxic)" fillcolor="#e91e63" fontcolor=white]
        mHTT_fibril [label="mHTT Protofibrils\n& Fibrils" fillcolor="#ad1457" fontcolor=white]
        mHTT_inclusion [label="Intranuclear\nInclusion Bodies" fillcolor="#880e4f" fontcolor=white]
        mHTT_cyto [label="Cytoplasmic\nAggregates" fillcolor="#c2185b" fontcolor=white]
        chaperone_hsp70 [label="Hsp70/Hsp40\nChaperones" fillcolor="#f8bbd0"]
        chaperone_hsp90 [label="Hsp90\nChaperone" fillcolor="#f8bbd0"]
        ubiquitin [label="Ubiquitin\nTagging" fillcolor="#f06292"]
        SUMO [label="SUMOylation\nof mHTT" fillcolor="#f48fb1"]

        mHTT_monomer -> mHTT_oligomer [label="nucleation" color="#e91e63"]
        mHTT_Nterm -> mHTT_monomer [label="seeding"]
        mHTT_protein -> mHTT_monomer [label="misfolding"]
        mHTT_oligomer -> mHTT_fibril [label="elongation"]
        mHTT_fibril -> mHTT_inclusion [label="nuclear transport"]
        mHTT_fibril -> mHTT_cyto [label="cytoplasmic"]
        chaperone_hsp70 -> mHTT_monomer [label="disaggregation" style=dashed color="#388e3c" dir=back]
        chaperone_hsp90 -> mHTT_oligomer [label="stabilizes" style=dashed color="#e53935"]
        ubiquitin -> mHTT_oligomer [label="tags for UPS"]
        SUMO -> mHTT_inclusion [label="nuclear sequestr."]
    }

    // ============================================================
    // SUBGRAPH 3: PROTEIN QUALITY CONTROL
    // ============================================================
    subgraph cluster_pqc {
        label="3. Protein Quality Control"
        style=filled fillcolor="#e8f5e9" color="#4caf50" penwidth=2
        fontname="Helvetica-Bold" fontsize=11 fontcolor="#4caf50"

        UPS_26S [label="26S Proteasome\n(UPS)" fillcolor="#a5d6a7"]
        UPS_impair [label="UPS Impairment\n(mHTT overload)" fillcolor="#ef9a9a"]
        autophagy_init [label="Autophagy\nInitiation (ULK1)" fillcolor="#c8e6c9"]
        beclin1 [label="Beclin-1 / VPS34\nComplex" fillcolor="#a5d6a7"]
        LC3_II [label="LC3-II\nAutophagosome" fillcolor="#81c784"]
        p62_seq [label="p62/Sequestosome-1\n(cargo receptor)" fillcolor="#c8e6c9"]
        lysosome [label="Lysosome\nFusion & Degradation" fillcolor="#66bb6a"]
        mTOR_auto [label="mTORC1\n(autophagy brake)" fillcolor="#ffcc80"]
        TFEB [label="TFEB\nLysosomal Biogenesis" fillcolor="#a5d6a7"]
        aggrephagy [label="Aggrephagy\n(mHTT clearance)" fillcolor="#4caf50" fontcolor=white]

        mHTT_oligomer -> UPS_26S [label="substrate" color="#e53935"]
        UPS_26S -> UPS_impair [label="saturation" color="#e53935"]
        UPS_impair -> mHTT_oligomer [label="accumulation\nfeedback" color="#e53935"]
        autophagy_init -> beclin1
        beclin1 -> LC3_II [label="autophagosome"]
        p62_seq -> mHTT_oligomer [label="cargo recognition"]
        p62_seq -> LC3_II [label="tethers cargo"]
        LC3_II -> lysosome [label="fusion"]
        lysosome -> aggrephagy [label="mHTT clearance" color="#388e3c"]
        mTOR_auto -> autophagy_init [label="inhibits" style=dashed color="#e53935"]
        TFEB -> lysosome [label="transcriptional\nactivation" color="#388e3c"]
        mHTT_inclusion -> p62_seq [label="recognition"]
    }

    // ============================================================
    // SUBGRAPH 4: TRANSCRIPTIONAL DYSREGULATION
    // ============================================================
    subgraph cluster_transcription {
        label="4. Transcriptional Dysregulation"
        style=filled fillcolor="#fff3e0" color="#ff9800" penwidth=2
        fontname="Helvetica-Bold" fontsize=11 fontcolor="#ff9800"

        REST_NRSF [label="REST/NRSF\nRepressor" fillcolor="#ffcc80"]
        CREB [label="CREB\nTranscription Factor" fillcolor="#ffe0b2"]
        SP1 [label="Sp1\nTranscription Factor" fillcolor="#ffcc80"]
        CBP [label="CBP/p300\nCoactivator" fillcolor="#ffb74d"]
        HDAC [label="HDACs\n(class I/II)" fillcolor="#ff9800" fontcolor=white]
        PGC1alpha [label="PGC-1α\nMito Biogenesis" fillcolor="#ffa726"]
        BDNF_gene [label="BDNF Gene\nTranscription" fillcolor="#ffcc80"]
        DA_rec_gene [label="D1/D2 Receptor\nGene Expression" fillcolor="#ffe0b2"]
        enk_gene [label="Enkephalin Gene\nExpression" fillcolor="#ffe0b2"]
        subP_gene [label="Substance P Gene\nExpression" fillcolor="#ffe0b2"]

        mHTT_inclusion -> REST_NRSF [label="sequesters" color="#e53935"]
        REST_NRSF -> BDNF_gene [label="represses" color="#e53935"]
        mHTT_protein -> CBP [label="sequesters" color="#e53935"]
        CBP -> HDAC [label="counteracts" style=dashed color="#388e3c"]
        HDAC -> BDNF_gene [label="represses\n(deacetylation)" color="#e53935"]
        mHTT_protein -> SP1 [label="aberrant\ninteraction" color="#e53935"]
        SP1 -> DA_rec_gene
        CREB -> BDNF_gene [label="activates" color="#388e3c"]
        mHTT_protein -> PGC1alpha [label="suppresses" color="#e53935"]
        HDAC -> enk_gene [label="suppresses" color="#e53935"]
        HDAC -> subP_gene [label="suppresses" color="#e53935"]
    }

    // ============================================================
    // SUBGRAPH 5: BDNF-TrkB SIGNALING
    // ============================================================
    subgraph cluster_bdnf {
        label="5. BDNF-TrkB Neurotrophic Signaling"
        style=filled fillcolor="#e3f2fd" color="#1976d2" penwidth=2
        fontname="Helvetica-Bold" fontsize=11 fontcolor="#1976d2"

        BDNF_cortex [label="Cortical BDNF\nProduction" fillcolor="#90caf9"]
        BDNF_striatum [label="Striatal BDNF\nLevel" fillcolor="#90caf9"]
        TrkB [label="TrkB Receptor\n(striatal MSN)" fillcolor="#42a5f5"]
        BDNF_transport [label="BDNF Anterograde\nAxonal Transport" fillcolor="#64b5f6"]
        HAP1 [label="HAP1\n(HTT-assoc. Prot. 1)" fillcolor="#90caf9"]
        PI3K_Akt [label="PI3K/Akt\nSurvival Pathway" fillcolor="#1e88e5" fontcolor=white]
        MAPK_ERK [label="MAPK/ERK\nSurvival Pathway" fillcolor="#1976d2" fontcolor=white]
        PLC_gamma [label="PLCγ/IP3\nPathway" fillcolor="#42a5f5"]
        CREB_phos [label="CREB\nPhosphorylation" fillcolor="#90caf9"]
        proBDNF [label="proBDNF\np75NTR apoptosis" fillcolor="#ef9a9a"]

        BDNF_gene -> BDNF_cortex [label="expression" color="#388e3c"]
        BDNF_cortex -> BDNF_transport [label="vesicular transport"]
        HAP1 -> BDNF_transport [label="facilitates" color="#388e3c"]
        mHTT_protein -> HAP1 [label="impairs" color="#e53935"]
        BDNF_transport -> BDNF_striatum [label="delivery"]
        BDNF_striatum -> TrkB [label="binds & activates" color="#388e3c"]
        TrkB -> PI3K_Akt [label="activates" color="#388e3c"]
        TrkB -> MAPK_ERK [label="activates" color="#388e3c"]
        TrkB -> PLC_gamma [label="activates" color="#388e3c"]
        PI3K_Akt -> CREB_phos [label="phosphorylation"]
        CREB_phos -> BDNF_gene [label="positive feedback" color="#388e3c"]
        proBDNF -> PI3K_Akt [label="inhibits" color="#e53935"]
        mHTT_protein -> BDNF_cortex [label="reduces synthesis" color="#e53935"]
    }

    // ============================================================
    // SUBGRAPH 6: MITOCHONDRIAL DYSFUNCTION
    // ============================================================
    subgraph cluster_mito {
        label="6. Mitochondrial Dysfunction & Oxidative Stress"
        style=filled fillcolor="#fce4ec" color="#c62828" penwidth=2
        fontname="Helvetica-Bold" fontsize=11 fontcolor="#c62828"

        mito_membrane [label="Mito Membrane\nPotential (ΔΨm)" fillcolor="#ef9a9a"]
        mito_complex_I [label="Complex I\n(NADH dehydrogenase)" fillcolor="#ef9a9a"]
        mito_complex_II [label="Complex II\n(Succinate DH)" fillcolor="#ef9a9a"]
        mito_complex_III [label="Complex III\n(bc1 complex)" fillcolor="#ef9a9a"]
        ROS [label="Reactive Oxygen\nSpecies (ROS)" fillcolor="#e53935" fontcolor=white]
        oxidative_stress [label="Oxidative Stress\n(8-OHdG, 4-HNE)" fillcolor="#c62828" fontcolor=white]
        mito_biogenesis [label="Mitochondrial\nBiogenesis" fillcolor="#ffcdd2"]
        cytochrome_c [label="Cytochrome c\nRelease" fillcolor="#e57373"]
        ATP_deficit [label="ATP Deficit\n(energy failure)" fillcolor="#ef9a9a"]
        calcium_mito [label="Mito Ca²⁺\nOverload" fillcolor="#ef9a9a"]

        mHTT_protein -> mito_complex_I [label="binds & inhibits" color="#e53935"]
        mHTT_protein -> mito_complex_II [label="impairs" color="#e53935"]
        mHTT_protein -> mito_complex_III [label="impairs" color="#e53935"]
        mito_complex_I -> ATP_deficit [label="reduced ATP" color="#e53935"]
        mito_complex_I -> ROS [label="electron leak" color="#e53935"]
        ROS -> oxidative_stress
        oxidative_stress -> mito_membrane [label="depolarizes" color="#e53935"]
        mito_membrane -> cytochrome_c [label="permeability\ntransition" color="#e53935"]
        calcium_mito -> mito_membrane [label="overload" color="#e53935"]
        mHTT_protein -> calcium_mito [label="disrupts Ca²⁺\nhomeostasis" color="#e53935"]
        PGC1alpha -> mito_biogenesis [label="drives" color="#388e3c"]
        oxidative_stress -> mHTT_protein [label="promotes\naggregation" color="#e53935"]
    }

    // ============================================================
    // SUBGRAPH 7: EXCITOTOXICITY
    // ============================================================
    subgraph cluster_excitotox {
        label="7. Excitotoxicity & Glutamate Signaling"
        style=filled fillcolor="#f3e5f5" color="#7b1fa2" penwidth=2
        fontname="Helvetica-Bold" fontsize=11 fontcolor="#7b1fa2"

        glutamate_cortex [label="Cortical Glutamate\nRelease" fillcolor="#ce93d8"]
        NMDAR [label="NMDA Receptor\n(NR1/NR2A/NR2B)" fillcolor="#ab47bc"]
        AMPAR [label="AMPA Receptor\n(GluR1-4)" fillcolor="#ba68c8"]
        NMDAR_extra [label="Extrasynaptic\nNMDAR" fillcolor="#7b1fa2" fontcolor=white]
        calcium_influx [label="Ca²⁺ Influx\n(excitotoxic)" fillcolor="#e53935" fontcolor=white]
        nNOS [label="nNOS\nNO Synthesis" fillcolor="#9c27b0" fontcolor=white]
        NO_toxic [label="Nitric Oxide /\nPeroxynitrite" fillcolor="#c62828" fontcolor=white]
        calpain [label="Calpain\nActivation" fillcolor="#ba68c8"]
        mGluR5 [label="mGluR5\n(HOMER-1)" fillcolor="#ce93d8"]
        IP3R [label="IP3 Receptor\nER Ca²⁺ Release" fillcolor="#ba68c8"]
        spine_loss [label="Dendritic Spine\nLoss" fillcolor="#7b1fa2" fontcolor=white]

        glutamate_cortex -> NMDAR [label="synaptic"]
        glutamate_cortex -> NMDAR_extra [label="spillover" color="#e53935"]
        NMDAR -> calcium_influx [label="gating" color="#e53935"]
        NMDAR_extra -> calcium_influx [label="excess" color="#e53935"]
        mHTT_protein -> NMDAR_extra [label="sensitizes" color="#e53935"]
        calcium_influx -> nNOS [label="activates" color="#e53935"]
        nNOS -> NO_toxic
        NO_toxic -> mito_complex_I [label="nitrosylates" color="#e53935"]
        calcium_influx -> calpain [label="activates"]
        calpain -> HTT_cleavage [label="cleaves mHTT" color="#e53935"]
        mGluR5 -> IP3R [label="PLC cascade"]
        IP3R -> calcium_influx [label="ER Ca²⁺\nrelease" color="#e53935"]
        calcium_influx -> spine_loss [label="cytoskeletal\ndisruption" color="#e53935"]
        mHTT_protein -> mGluR5 [label="alters coupling" color="#e53935"]
        glutamate_cortex -> AMPAR [label="fast\nexcitation"]
        AMPAR -> calcium_influx [label="Ca²⁺\npermeable" color="#e53935"]
        calcium_influx -> calcium_mito [label="mitochondrial\nuptake"]
    }

    // ============================================================
    // SUBGRAPH 8: STRIATAL CIRCUITRY
    // ============================================================
    subgraph cluster_striatum {
        label="8. Striatal Circuitry — Dopamine & GABA"
        style=filled fillcolor="#e8eaf6" color="#3f51b5" penwidth=2
        fontname="Helvetica-Bold" fontsize=11 fontcolor="#3f51b5"

        SNc_DA [label="Substantia Nigra\nDopamine Neurons" fillcolor="#9fa8da"]
        VTA_DA [label="Ventral Tegmental\nArea (VTA)" fillcolor="#9fa8da"]
        D1_MSN [label="D1-MSN\n(direct pathway)" fillcolor="#5c6bc0" fontcolor=white]
        D2_MSN [label="D2-MSN\n(indirect pathway)" fillcolor="#3f51b5" fontcolor=white]
        VMAT2 [label="VMAT2\nVesicular DA Storage" fillcolor="#7986cb"]
        DA_release [label="Striatal Dopamine\nRelease" fillcolor="#9fa8da"]
        DAT [label="DAT\nDopamine Reuptake" fillcolor="#7986cb"]
        GABA_direct [label="GABA (direct)\nGPi/SNr inhibition" fillcolor="#5c6bc0" fontcolor=white]
        GABA_indirect [label="GABA (indirect)\nGPe activation" fillcolor="#3f51b5" fontcolor=white]
        enkephalin_str [label="Enkephalin\n(D2-MSN co-peptide)" fillcolor="#9fa8da"]
        substanceP_str [label="Substance P\n(D1-MSN co-peptide)" fillcolor="#9fa8da"]
        cholinergic_IN [label="Cholinergic\nInterneurons" fillcolor="#7986cb"]
        PV_IN [label="PV+\nInterneurons" fillcolor="#7986cb"]

        SNc_DA -> DA_release [label="nigrostriatal"]
        VTA_DA -> DA_release [label="mesolimbic"]
        DA_release -> VMAT2 [label="stored"]
        VMAT2 -> D1_MSN [label="D1 activation" color="#388e3c"]
        VMAT2 -> D2_MSN [label="D2 activation" color="#388e3c"]
        D1_MSN -> GABA_direct [label="direct pathway" color="#388e3c"]
        D2_MSN -> GABA_indirect [label="indirect pathway" color="#388e3c"]
        D2_MSN -> enkephalin_str [label="co-release"]
        D1_MSN -> substanceP_str [label="co-release"]
        DAT -> DA_release [label="reuptake loop"]
        cholinergic_IN -> D1_MSN [label="ACh modulation"]
        PV_IN -> D1_MSN [label="fast inhibition"]
        mHTT_protein -> D1_MSN [label="MSN degeneration" color="#e53935"]
        mHTT_protein -> D2_MSN [label="MSN degeneration\n(earlier onset)" color="#e53935"]
        spine_loss -> D1_MSN [label="structural loss" color="#e53935"]
        spine_loss -> D2_MSN [label="structural loss" color="#e53935"]
    }

    // ============================================================
    // SUBGRAPH 9: NEUROINFLAMMATION
    // ============================================================
    subgraph cluster_neuroinflam {
        label="9. Neuroinflammation"
        style=filled fillcolor="#fff8e1" color="#f57f17" penwidth=2
        fontname="Helvetica-Bold" fontsize=11 fontcolor="#f57f17"

        microglia_rest [label="Resting\nMicroglia (M0)" fillcolor="#fff9c4"]
        microglia_M1 [label="M1 Microglia\n(pro-inflammatory)" fillcolor="#f57f17" fontcolor=white]
        microglia_M2 [label="M2 Microglia\n(neuroprotective)" fillcolor="#ffcc80"]
        astrocyte_react [label="Reactive\nAstrogliosis" fillcolor="#ffe082"]
        IL1b [label="IL-1β\nPyroptosis" fillcolor="#f57f17" fontcolor=white]
        TNFalpha [label="TNF-α\nNeuroinflammation" fillcolor="#ef6c00" fontcolor=white]
        IL6_neuro [label="IL-6\nGlia-Neuron" fillcolor="#ff8f00" fontcolor=white]
        NLRP3 [label="NLRP3\nInflammasome" fillcolor="#f57f17" fontcolor=white]
        complement [label="Complement\nC1q/C3" fillcolor="#ffcc80"]
        NF_kB_glia [label="NF-κB\nGlial Activation" fillcolor="#ffa000" fontcolor=white]
        TLR4_glia [label="TLR4\nPattern Recognition" fillcolor="#ffe082"]

        microglia_rest -> microglia_M1 [label="mHTT activation" color="#e53935"]
        mHTT_protein -> TLR4_glia [label="DAMP signal" color="#e53935"]
        TLR4_glia -> NF_kB_glia [label="activates" color="#e53935"]
        NF_kB_glia -> IL1b [label="produces" color="#e53935"]
        NF_kB_glia -> TNFalpha [label="produces" color="#e53935"]
        NF_kB_glia -> IL6_neuro [label="produces" color="#e53935"]
        microglia_M1 -> NLRP3 [label="assembles" color="#e53935"]
        NLRP3 -> IL1b [label="cleaves pro-IL-1β" color="#e53935"]
        astrocyte_react -> IL6_neuro [label="secretes" color="#e53935"]
        complement -> D1_MSN [label="synapse elimination" color="#e53935"]
        complement -> D2_MSN [label="synapse elimination" color="#e53935"]
        microglia_M1 -> microglia_M2 [label="resolution" color="#388e3c" style=dashed]
        IL1b -> calcium_influx [label="enhances NMDAR" color="#e53935"]
        TNFalpha -> NMDAR_extra [label="upregulates\nextrasynaptic" color="#e53935"]
    }

    // ============================================================
    // SUBGRAPH 10: APOPTOSIS
    // ============================================================
    subgraph cluster_apoptosis {
        label="10. Neuronal Apoptosis"
        style=filled fillcolor="#ffebee" color="#b71c1c" penwidth=2
        fontname="Helvetica-Bold" fontsize=11 fontcolor="#b71c1c"

        BAX [label="BAX/BAK\nPro-apoptotic" fillcolor="#ef9a9a"]
        BCL2 [label="BCL-2/BCL-xL\nAnti-apoptotic" fillcolor="#c8e6c9"]
        cytochrome_c_cyto [label="Cytochrome c\n(cytosolic)" fillcolor="#ef9a9a"]
        apoptosome [label="Apoptosome\nApaf-1/Casp-9" fillcolor="#e53935" fontcolor=white]
        caspase3 [label="Caspase-3\n(executioner)" fillcolor="#b71c1c" fontcolor=white]
        caspase6 [label="Caspase-6\nHTT cleavage" fillcolor="#c62828" fontcolor=white]
        PUMA [label="PUMA/NOXA\nBH3-only" fillcolor="#ef9a9a"]
        p53_death [label="p53\nApoptotic Driver" fillcolor="#e53935" fontcolor=white]
        AIF [label="AIF\n(caspase-indep.)" fillcolor="#ef9a9a"]
        striatal_volume [label="Striatal Volume\nLoss (MRI)" fillcolor="#b71c1c" fontcolor=white]

        mHTT_protein -> p53_death [label="activates" color="#e53935"]
        p53_death -> PUMA [label="transcribes" color="#e53935"]
        PUMA -> BAX [label="activates" color="#e53935"]
        BAX -> cytochrome_c [label="mito pore" color="#e53935"]
        cytochrome_c -> cytochrome_c_cyto [label="released"]
        cytochrome_c_cyto -> apoptosome [label="assembles" color="#e53935"]
        apoptosome -> caspase3 [label="activates" color="#e53935"]
        caspase3 -> HTT_cleavage [label="cleaves mHTT\nat aa513/552" color="#e53935"]
        caspase6 -> mHTT_Nterm [label="toxic fragments" color="#e53935"]
        BCL2 -> BAX [label="sequesters" color="#388e3c"]
        mHTT_protein -> BCL2 [label="reduces" color="#e53935"]
        AIF -> striatal_volume [label="nuclear condensation" color="#e53935"]
        caspase3 -> striatal_volume [label="MSN death" color="#e53935"]
        calcium_influx -> BAX [label="activates" color="#e53935"]
        PI3K_Akt -> BCL2 [label="upregulates" color="#388e3c"]
    }

    // ============================================================
    // SUBGRAPH 11: DRUG PHARMACOKINETICS
    // ============================================================
    subgraph cluster_pk {
        label="11. Drug Pharmacokinetics"
        style=filled fillcolor="#e0f7fa" color="#00838f" penwidth=2
        fontname="Helvetica-Bold" fontsize=11 fontcolor="#00838f"

        dose_TBZ [label="Tetrabenazine\nOral Dose" fillcolor="#b2ebf2"]
        dose_DTBZ [label="Deutetrabenazine\nOral Dose" fillcolor="#b2ebf2"]
        dose_VBZ [label="Valbenazine\nOral Dose" fillcolor="#b2ebf2"]
        dose_tominersen [label="Tominersen (ASO)\nIntrathecal" fillcolor="#b2ebf2"]
        dose_branaplam [label="Branaplam\nOral" fillcolor="#b2ebf2"]
        dose_riluzole [label="Riluzole\nOral" fillcolor="#b2ebf2"]
        dose_memantine [label="Memantine\nOral" fillcolor="#b2ebf2"]

        TBZ_plasma [label="TBZ Plasma\n(Cp)" fillcolor="#4dd0e1"]
        DTBZ_plasma [label="Deutetrabenazine\nPlasma" fillcolor="#4dd0e1"]
        VBZ_plasma [label="Valbenazine\nPlasma" fillcolor="#4dd0e1"]
        HTBZ_active [label="α/β-HTBZ\nActive Metabolites" fillcolor="#00838f" fontcolor=white]
        tominersen_CSF [label="Tominersen\nCSF Conc." fillcolor="#00838f" fontcolor=white]
        branaplam_brain [label="Branaplam\nBrain Conc." fillcolor="#00838f" fontcolor=white]
        riluzole_plasma [label="Riluzole\nPlasma" fillcolor="#4dd0e1"]
        memantine_brain [label="Memantine\nBrain Conc." fillcolor="#4dd0e1"]
        CYP2D6 [label="CYP2D6\nMetabolism" fillcolor="#b2ebf2"]
        BBB [label="Blood-Brain\nBarrier" fillcolor="#80deea"]

        dose_TBZ -> TBZ_plasma [label="F~20%"]
        TBZ_plasma -> CYP2D6 [label="extensive\nmetabolism"]
        CYP2D6 -> HTBZ_active [label="α/β-HTBZ"]
        dose_DTBZ -> DTBZ_plasma [label="slower CYP2D6"]
