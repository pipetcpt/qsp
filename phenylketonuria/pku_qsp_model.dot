digraph PKU_QSP {
  graph [rankdir=LR, fontname="Helvetica", fontsize=11, labelloc=t,
         label="Phenylketonuria (페닐케톤뇨증, PKU) — Integrated QSP Mechanistic Map\nPAH-gene loss-of-function → hyperphenylalaninemia → LAT1/BBB amino-acid competition → cerebral monoamine deficit & neurotoxicity\nDiet (Phe-restriction/medical formula) · Sapropterin (BH4 cofactor) · Pegvaliase (PEG-PAL enzyme substitution) · Investigational gene/mRNA/microbiome therapy",
         splines=spline, overlap=false, nodesep=0.28, ranksep=0.55,
         bgcolor="#fbfbfd"];
  node  [shape=box, style="rounded,filled", fontname="Helvetica", fontsize=10,
         fillcolor="#ffffff", color="#7d8590"];
  edge  [fontname="Helvetica", fontsize=9, color="#6e7681", arrowsize=0.7];

  /* ───────────────────────── 1. Genetics & Etiology ───────────────────────── */
  subgraph cluster_genetics {
    label="1. Genetics, Inheritance & Phenotype Spectrum";
    style="filled,rounded"; color="#5c6370"; fillcolor="#f3f0ff"; fontsize=12;
    PAHGene         [label="PAH gene\n(12q23.2)"];
    AutosomalRec    [label="Autosomal recessive\ninheritance (carrier ~1:50)"];
    Incidence       [label="Incidence\n~1:10,000-15,000 births"];
    PAHMutClass     [label="Mutation class:\nnull / missense / splice"];
    PAHGenotype     [label="Compound heterozygous /\nhomozygous genotype"];
    ClassicPKU      [label="Classic PKU\n(residual PAH <1%)"];
    ModeratePKU     [label="Moderate PKU\n(residual PAH 1-5%)"];
    MildPKU         [label="Mild PKU\n(residual PAH 5-10%)"];
    MHP             [label="Mild hyperphenyl-\nalaninemia (MHP, >10%)"];
    BH4Responsive   [label="BH4-responsive\nvariant (misfolding)"];
    BH4NonResp      [label="BH4 non-responsive\nvariant (null allele)"];
    AutosomalRec -> PAHGene -> PAHMutClass -> PAHGenotype;
    PAHGenotype -> ClassicPKU; PAHGenotype -> ModeratePKU;
    PAHGenotype -> MildPKU; PAHGenotype -> MHP;
    PAHGenotype -> BH4Responsive [style=dashed]; PAHGenotype -> BH4NonResp [style=dashed];
    Incidence -> PAHGene [style=dashed, label="population\nprevalence"];
  }

  /* ───────────────────────── 2. Newborn Screening & Diagnosis ─────────────── */
  subgraph cluster_dx {
    label="2. Newborn Screening & Diagnosis";
    style="filled,rounded"; color="#5c6370"; fillcolor="#fff4e6"; fontsize=12;
    NBS             [label="Newborn screening\n(dried blood spot, day 2-3)"];
    MSMS            [label="Tandem MS/MS\nPhe & Phe/Tyr ratio"];
    ConfirmPlasma   [label="Confirmatory plasma\namino-acid analysis"];
    DxThreshold     [label="Diagnostic threshold\nPhe >120 (>1200 classic) umol/L"];
    BH4LoadTest     [label="BH4 loading test\n(responsiveness)"];
    MolecularTest   [label="PAH gene\nsequencing"];
    PterinAnalysis  [label="Urine pterin analysis\n(exclude cofactor defects)"];
    CofactorScreen  [label="DHPR activity /\ncofactor-deficiency screen"];
    NBS -> MSMS -> ConfirmPlasma -> DxThreshold;
    DxThreshold -> BH4LoadTest -> MolecularTest;
    ConfirmPlasma -> PterinAnalysis -> CofactorScreen;
    ClassicPKU -> DxThreshold [style=dashed];
  }

  /* ───────────────────────── 3. Dietary Phe Intake & GI Absorption ────────── */
  subgraph cluster_diet {
    label="3. Dietary Phe Intake & GI Absorption";
    style="filled,rounded"; color="#5c6370"; fillcolor="#e8f8f0"; fontsize=12;
    DietaryProtein  [label="Natural dietary\nprotein intake"];
    DietPheLoad     [label="Dietary phenylalanine\nload (mg/kg/d)"];
    GutLumenPhe     [label="Gut luminal\nPhe pool"];
    GIAbsorption    [label="Intestinal Phe absorption\n(PEPT1/B0AT1 transporters)"];
    MedFormula      [label="Phe-free medical\namino-acid formula"];
    GMPFood         [label="Glycomacropeptide (GMP)\nmedical food (low-Phe)"];
    TyrSuppl        [label="Tyrosine\nsupplementation"];
    DietAdherence   [label="Diet adherence /\ncompliance behavior"];
    DietaryProtein -> DietPheLoad -> GutLumenPhe -> GIAbsorption;
    MedFormula -> GIAbsorption [style=dashed, label="Phe-free\nprotein equivalent"];
    GMPFood -> GIAbsorption [style=dashed];
    TyrSuppl -> GIAbsorption [style=dashed];
    DietAdherence -> DietPheLoad [style=dashed, label="modulates"];
  }

  /* ───────────────────────── 4. Hepatic PAH / BH4 Catalytic Cycle ─────────── */
  subgraph cluster_pah {
    label="4. Hepatic PAH Enzyme & BH4 Catalytic Cycle";
    style="filled,rounded"; color="#5c6370"; fillcolor="#fdf0f5"; fontsize=12;
    HepatocytePAH   [label="Hepatic phenylalanine\nhydroxylase (PAH)"];
    PAHActivity     [label="Residual PAH\ncatalytic activity"];
    PAHMisfolding   [label="Mutant PAH protein\nmisfolding/aggregation"];
    PAHChaperone    [label="BH4 pharmacological\nchaperone stabilization"];
    PheHydroxyl     [label="Phe + O2 + BH4 →\nTyr + BH2 + H2O"];
    BH4Cofactor     [label="Tetrahydrobiopterin\n(BH4) cofactor pool"];
    BH2Byproduct    [label="Dihydrobiopterin\n(BH2) byproduct"];
    PCD             [label="Pterin-4a-carbinolamine\ndehydratase (PCD)"];
    DHPR            [label="Dihydropteridine\nreductase (DHPR, BH2→BH4)"];
    HepaticPheClear [label="Net hepatic Phe\nclearance rate"];
    HepatocytePAH -> PAHActivity;
    PAHMutClass -> PAHMisfolding -> PAHActivity [style=dashed, label="loss of\nfunction"];
    PAHChaperone -> PAHMisfolding [style=dashed, label="refolding\n(responders)"];
    PAHActivity -> PheHydroxyl;
    BH4Cofactor -> PheHydroxyl -> BH2Byproduct;
    BH2Byproduct -> PCD -> DHPR -> BH4Cofactor [label="cofactor\nrecycling"];
    PheHydroxyl -> HepaticPheClear;
    GIAbsorption -> PheHydroxyl [label="portal\nPhe delivery"];
  }

  /* ───────────────────────── 5. De Novo BH4 Biosynthesis ──────────────────── */
  subgraph cluster_bh4synth {
    label="5. De Novo BH4 Biosynthesis";
    style="filled,rounded"; color="#5c6370"; fillcolor="#eef3ff"; fontsize=12;
    GTP             [label="GTP\nsubstrate"];
    GTPCH           [label="GTP cyclohydrolase I\n(GTPCH)"];
    PTPS            [label="6-pyruvoyl-tetrahydropterin\nsynthase (PTPS)"];
    SR              [label="Sepiapterin\nreductase (SR)"];
    BH4DeNovo       [label="De novo BH4\nbiosynthesis flux"];
    GTP -> GTPCH -> PTPS -> SR -> BH4DeNovo -> BH4Cofactor;
  }

  /* ───────────────────────── 6. Alternative (Minor) Phe Catabolism ────────── */
  subgraph cluster_minor {
    label="6. Alternative Minor Phe Catabolism (Transamination)";
    style="filled,rounded"; color="#5c6370"; fillcolor="#fff9e6"; fontsize=12;
    PheTransaminase [label="Phenylalanine\naminotransferase"];
    Phenylpyruvate  [label="Phenylpyruvic\nacid"];
    Phenylacetate   [label="Phenylacetic acid\n(\"mousy\" odor)"];
    Phenyllactate   [label="Phenyllactic\nacid"];
    UrinePK         [label="Urinary phenylketone\nexcretion (namesake)"];
    MinorPathFlux   [label="Minor-pathway flux\n(rises with plasma Phe)"];
    PheTransaminase -> Phenylpyruvate -> Phenylacetate -> UrinePK;
    Phenylpyruvate -> Phenyllactate -> UrinePK;
    MinorPathFlux -> PheTransaminase;
  }

  /* ───────────────────────── 7. Systemic Transport & BBB Competition ──────── */
  subgraph cluster_transport {
    label="7. Plasma Amino-Acid Pool & BBB LAT1 Competition";
    style="filled,rounded"; color="#5c6370"; fillcolor="#f0faff"; fontsize=12;
    PlasmaPhe       [label="Plasma phenylalanine\nconcentration"];
    PlasmaTyr       [label="Plasma tyrosine\nconcentration"];
    PlasmaTrp       [label="Plasma tryptophan\nconcentration"];
    PlasmaBCAA      [label="Plasma branched-chain\namino acids"];
    LAT1            [label="LAT1/SLC7A5\n(BBB large-neutral-AA transporter)"];
    CompetInhib     [label="Competitive inhibition of\nTyr/Trp/BCAA transport by Phe"];
    BrainPhe        [label="Brain (CNS)\nphenylalanine"];
    BrainTyr        [label="Brain\ntyrosine"];
    BrainTrp        [label="Brain\ntryptophan"];
    HepaticPheClear -> PlasmaPhe [style=dashed, label="clearance ↓Phe"];
    GIAbsorption -> PlasmaPhe [label="systemic\nPhe influx"];
    TyrSuppl -> PlasmaTyr [style=dashed];
    PlasmaPhe -> LAT1; PlasmaTyr -> LAT1; PlasmaTrp -> LAT1; PlasmaBCAA -> LAT1;
    LAT1 -> CompetInhib;
    PlasmaPhe -> CompetInhib [label="high-affinity,\nhigh-concentration substrate"];
    CompetInhib -> BrainPhe; CompetInhib -> BrainTyr [style=dashed, label="↓ influx"];
    CompetInhib -> BrainTrp [style=dashed, label="↓ influx"];
  }

  /* ───────────────────────── 8. Brain Neurotoxicity & Monoamine Synthesis ─── */
  subgraph cluster_brain {
    label="8. Cerebral Neurotoxicity & Monoamine Synthesis";
    style="filled,rounded"; color="#5c6370"; fillcolor="#ffeef0"; fontsize=12;
    TyrHydroxylase  [label="Tyrosine hydroxylase\n(rate-limiting, catecholamines)"];
    TrpHydroxylase  [label="Tryptophan hydroxylase\n(rate-limiting, serotonin)"];
    DopamineSynth   [label="Dopamine\nsynthesis rate"];
    NESynth         [label="Norepinephrine\nsynthesis"];
    SerotoninSynth  [label="Serotonin\nsynthesis rate"];
    ProteinSynthInh [label="Cerebral protein-synthesis\ninhibition (high Phe)"];
    MyelinSynth     [label="Myelin / oligodendrocyte\nlipid-protein synthesis"];
    WhiteMatterInt  [label="White-matter integrity\n(MRI T2 hyperintensity)"];
    SynapticPruning [label="Synaptic/dendritic\nspine development"];
    OxidStressCNS   [label="CNS oxidative stress /\nmitochondrial dysfunction"];
    BrainTyr -> TyrHydroxylase -> DopamineSynth -> NESynth;
    BrainTrp -> TrpHydroxylase -> SerotoninSynth;
    BrainPhe -> ProteinSynthInh [label="competitive inhibition of\nbrain protein synthesis"];
    BrainPhe -> OxidStressCNS;
    ProteinSynthInh -> MyelinSynth [style=dashed, label="↓"];
    MyelinSynth -> WhiteMatterInt;
    ProteinSynthInh -> SynapticPruning [style=dashed, label="↓"];
    OxidStressCNS -> WhiteMatterInt [style=dashed];
  }

  /* ───────────────────────── 9. Peripheral Tyrosine-Deficiency Effects ────── */
  subgraph cluster_tyrdef {
    label="9. Peripheral Tyrosine-Deficiency Downstream Effects";
    style="filled,rounded"; color="#5c6370"; fillcolor="#f5f5f0"; fontsize=12;
    MelaninSynth    [label="Melanin synthesis\n(tyrosinase)"];
    SkinHairPigment [label="Fair skin / hair / eye\nphenotype (hypopigmentation)"];
    CatecholDefic   [label="Peripheral catecholamine\nsynthesis reduction"];
    GrowthImpair    [label="Growth impairment\n(Tyr/BCAA imbalance)"];
    ThyroidSynthMin [label="Thyroxine synthesis\n(minor Tyr-dependent effect)"];
    PlasmaTyr -> MelaninSynth [style=dashed, label="substrate\nlimitation"];
    MelaninSynth -> SkinHairPigment;
    PlasmaTyr -> CatecholDefic [style=dashed];
    DietAdherence -> GrowthImpair [style=dashed, label="over-restriction\nrisk"];
    PlasmaTyr -> ThyroidSynthMin [style=dashed];
  }

  /* ───────────────────────── 10. Maternal PKU & Fetal Effects ─────────────── */
  subgraph cluster_maternal {
    label="10. Maternal PKU & Fetal Teratogenicity";
    style="filled,rounded"; color="#5c6370"; fillcolor="#f7eaff"; fontsize=12;
    MaternalPhe     [label="Maternal plasma Phe\nduring pregnancy"];
    PlacentalTransp [label="Placental active transport\n(fetal:maternal Phe >1)"];
    FetalPheExpo    [label="Fetal Phe\nexposure"];
    CHD             [label="Fetal congenital heart\ndisease risk"];
    Microcephaly    [label="Fetal microcephaly /\nIUGR"];
    MaternalPKUSynd [label="Maternal PKU syndrome\n(uncontrolled)"];
    PreconceptControl [label="Pre-conception Phe\ncontrol (<360 umol/L)"];
    PlasmaPhe -> MaternalPhe [style=dashed, label="pregnancy\ncontext"];
    MaternalPhe -> PlacentalTransp -> FetalPheExpo;
    FetalPheExpo -> CHD; FetalPheExpo -> Microcephaly;
    CHD -> MaternalPKUSynd; Microcephaly -> MaternalPKUSynd;
    PreconceptControl -> MaternalPhe [style=dashed, label="strict control\nprevents"];
  }

  /* ───────────────────────── 11. Clinical & Neurocognitive Endpoints ──────── */
  subgraph cluster_clinical {
    label="11. Clinical & Neurocognitive Endpoints";
    style="filled,rounded"; color="#5c6370"; fillcolor="#eafaf1"; fontsize=12;
    IQTrajectory    [label="Full-scale IQ\ntrajectory"];
    ExecFunction    [label="Executive function\ndeficits"];
    ADHDSymptoms    [label="ADHD-like inattention/\nhyperactivity symptoms"];
    ProcessSpeed    [label="Processing speed\ndeficits"];
    AnxietyDepress  [label="Anxiety / depression\n(adult PKU)"];
    SeizureRisk     [label="Seizure risk\n(untreated/severe)"];
    PostnatalMicro  [label="Postnatal microcephaly\n(untreated)"];
    EczemaRash      [label="Eczema-like\nrash"];
    MousyOdor       [label="Musty/mousy\nbody odor"];
    QoL             [label="Quality of life /\nneuropsychiatric burden"];
    DopamineSynth -> ExecFunction [style=dashed, label="prefrontal\nDA deficit"];
    DopamineSynth -> ADHDSymptoms [style=dashed];
    SerotoninSynth -> AnxietyDepress [style=dashed];
    WhiteMatterInt -> ProcessSpeed [style=dashed];
    ProteinSynthInh -> IQTrajectory [label="cumulative\nneurotoxicity"];
    BrainPhe -> SeizureRisk [style=dashed];
    BrainPhe -> PostnatalMicro [style=dashed];
    UrinePK -> MousyOdor; UrinePK -> EczemaRash [style=dashed];
    IQTrajectory -> QoL; ExecFunction -> QoL; ADHDSymptoms -> QoL; AnxietyDepress -> QoL;
  }

  /* ───────────────────────── 12. Drug PK/PD — Sapropterin (BH4) ───────────── */
  subgraph cluster_sapropterin {
    label="12. Drug PK/PD — Sapropterin Dihydrochloride (Kuvan)";
    style="filled,rounded"; color="#5c6370"; fillcolor="#e6f7ff"; fontsize=12;
    SapropterinDose [label="Oral sapropterin\ndose (5-20 mg/kg/d)"];
    SapAbsorption   [label="GI absorption\n(food ↑ bioavailability ~2-fold)"];
    SapPlasma       [label="Plasma BH4/sapropterin\nconcentration"];
    SapTmax         [label="Tmax ~3-4h,\nt1/2 ~6-7h"];
    BH4Supplement   [label="Exogenous BH4 supplementation\nof hepatic cofactor pool"];
    PAHStabilize    [label="Chaperone-mediated PAH\nstabilization (↑ Vmax)"];
    ResponderDrop   [label="Responder: ≥30%\nplasma Phe reduction"];
    NonResponderFlg [label="Non-responder\n(null-genotype) flag"];
    SapropterinDose -> SapAbsorption -> SapPlasma -> SapTmax;
    SapPlasma -> BH4Supplement -> BH4Cofactor;
    BH4Supplement -> PAHStabilize;
    PAHChaperone -> PAHStabilize [style=dashed];
    PAHStabilize -> PAHActivity [label="↑ residual\nactivity"];
    BH4Responsive -> ResponderDrop [style=dashed];
    BH4NonResp -> NonResponderFlg [style=dashed];
    PAHActivity -> ResponderDrop [style=dashed];
  }

  /* ───────────────────────── 13. Drug PK/PD — Pegvaliase (PEG-PAL) ────────── */
  subgraph cluster_pegvaliase {
    label="13. Drug PK/PD — Pegvaliase (Palynziq, PEG-PAL)";
    style="filled,rounded"; color="#5c6370"; fillcolor="#fff0f0"; fontsize=12;
    PegvaliaseDose  [label="Subcutaneous pegvaliase\ndose (induction→maintenance)"];
    PegAbsorption   [label="SC absorption\n(lymphatic uptake)"];
    PegPlasma       [label="Plasma PEG-PAL\nconcentration"];
    PALActivity     [label="Phenylalanine ammonia-lyase\n(PAL) catalytic activity"];
    AltPheClear     [label="Alternative non-PAH Phe\nclearance route"];
    TransCinnamic   [label="trans-Cinnamic acid →\nbenzoate → hippurate"];
    InductionPhase  [label="Induction / titration /\nmaintenance dosing"];
    ADAFormation    [label="Anti-drug antibody (ADA)\nformation vs PEG-PAL/PEG"];
    ADANeutralize   [label="ADA-mediated\nenzyme neutralization"];
    HypersensRisk   [label="Type-I hypersensitivity /\nanaphylaxis risk"];
    PegvaliaseDose -> PegAbsorption -> PegPlasma;
    InductionPhase -> PegvaliaseDose;
    PegPlasma -> PALActivity -> AltPheClear -> TransCinnamic;
    AltPheClear -> PlasmaPhe [label="Phe consumption\nindependent of PAH"];
    PegPlasma -> ADAFormation -> ADANeutralize;
    ADANeutralize -> PALActivity [style=dashed, label="↓ efficacy\n(early therapy)"];
    ADAFormation -> HypersensRisk [style=dashed];
  }

  /* ───────────────────────── 14. Investigational / Emerging Therapies ─────── */
  subgraph cluster_investig {
    label="14. Investigational & Emerging Therapies";
    style="filled,rounded"; color="#5c6370"; fillcolor="#f2f2f2" ; fontsize=12;
    SYNB1618        [label="SYNB1618 engineered\nE. coli Nissle (gut PAL)"];
    mRNATherapy     [label="mRNA-encoded PAH\n(lipid nanoparticle)"];
    AAVGeneTx       [label="AAV-PAH liver-directed\ngene therapy"];
    CRISPRBaseEdit  [label="CRISPR base-editing\nPAH correction (preclinical)"];
    NextGenPAL      [label="Next-gen engineered/\nPEGylated PAL variants"];
    SYNB1618 -> GutLumenPhe [style=dashed, label="gut-luminal\nPhe degradation"];
    mRNATherapy -> HepatocytePAH [style=dashed, label="restores\nendogenous PAH"];
    AAVGeneTx -> HepatocytePAH [style=dashed, label="durable PAH\nexpression"];
    CRISPRBaseEdit -> PAHGene [style=dashed, label="corrects\nmutation"];
    NextGenPAL -> PALActivity [style=dashed, label="↓ immunogenicity"];
  }

  /* ───────────────────────── 15. Non-Pharmacologic Management ─────────────── */
  subgraph cluster_nonpharm {
    label="15. Non-Pharmacologic Management & Monitoring";
    style="filled,rounded"; color="#5c6370"; fillcolor="#f5fff0"; fontsize=12;
    LifelongDiet    [label="Lifelong low-Phe\ndiet management"];
    FreqMonitoring  [label="Frequent blood-Phe\nmonitoring (home DBS)"];
    MDClinic        [label="Multidisciplinary metabolic\nclinic follow-up"];
    ACMGTarget      [label="ACMG/NIH target range\n120-360 umol/L (lifelong)"];
    LifelongDiet -> DietaryProtein [style=dashed];
    FreqMonitoring -> PlasmaPhe [style=dashed, label="titrates\ntherapy"];
    ACMGTarget -> FreqMonitoring [style=dashed];
    MDClinic -> LifelongDiet [style=dashed];
  }

  /* ───────────────────────── 16. Adverse Effects & Safety Monitoring ──────── */
  subgraph cluster_safety {
    label="16. Adverse Effects & Safety Monitoring";
    style="filled,rounded"; color="#5c6370"; fillcolor="#fff5e0"; fontsize=12;
    SapropterinAE   [label="Sapropterin AEs:\nheadache, rhinorrhea, GI upset"];
    PegvaliaseAE    [label="Pegvaliase AEs:\ninjection-site rxn, arthralgia"];
    AnaphylaxisMon  [label="Anaphylaxis REMS\nmonitoring (3h post-dose)"];
    NutrientDefic   [label="Micronutrient deficiency\n(B12, Fe, Zn, EFA) risk"];
    BoneHealthMon   [label="Bone mineral density\nmonitoring"];
    LongTermSafety  [label="Long-term safety\nregistries (PKUDOS)"];
    SapPlasma -> SapropterinAE [style=dashed];
    PegPlasma -> PegvaliaseAE [style=dashed];
    HypersensRisk -> AnaphylaxisMon;
    LifelongDiet -> NutrientDefic [style=dashed, label="over-restriction"];
    NutrientDefic -> BoneHealthMon [style=dashed];
    SapropterinAE -> LongTermSafety [style=dashed];
    PegvaliaseAE -> LongTermSafety [style=dashed];
  }
}
