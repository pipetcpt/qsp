digraph GastricCancer_QSP {
  graph [
    label="Gastric Cancer (위선암) — Quantitative Systems Pharmacology Model\nMolecular Drivers · Signal Transduction · TME · Immunotherapy · Drug PK/PD",
    labelloc="t",
    fontname="Arial",
    fontsize=16,
    rankdir=LR,
    splines=true,
    nodesep=0.4,
    ranksep=0.8,
    bgcolor="white",
    pad=0.5
  ]
  node [fontname="Arial", fontsize=9, style="filled,rounded", shape=box, margin="0.1,0.05"]
  edge [fontname="Arial", fontsize=8, arrowsize=0.7]

  // =====================================================================
  // Cluster 1: H. pylori & Gastric Mucosal Inflammation
  // =====================================================================
  subgraph cluster_hpylori {
    label="H. pylori & Mucosal Inflammation"
    style="filled"
    color="darkorange"
    fillcolor="#FFF3E0"
    fontname="Arial"
    fontsize=11
    fontcolor="darkorange"

    HP [label="H. pylori\n(CagA+/VacA+)", fillcolor="#FF8F00", fontcolor="white", style="filled,rounded"]
    CagA [label="CagA oncoprotein", fillcolor="#FFB300", fontcolor="white"]
    VacA [label="VacA toxin", fillcolor="#FFB300", fontcolor="white"]
    OipA [label="OipA adhesin", fillcolor="#FFCC02", fontcolor="black"]
    BabA [label="BabA adhesin", fillcolor="#FFCC02", fontcolor="black"]
    LPS_HP [label="H. pylori LPS", fillcolor="#FFDD54", fontcolor="black"]
    Cag_T4SS [label="CagA T4SS\ninjection", fillcolor="#FFB300", fontcolor="white"]
    IL8_gastric [label="IL-8 (gastric)", fillcolor="#FFECB3", fontcolor="black"]
    TNFa_local [label="TNF-α (local)", fillcolor="#FFECB3", fontcolor="black"]
    IL1b_gastric [label="IL-1β (gastric)", fillcolor="#FFECB3", fontcolor="black"]
    IL6_gastric [label="IL-6 (gastric)", fillcolor="#FFECB3", fontcolor="black"]
    NF_kB_epithelial [label="NF-κB\n(epithelial)", fillcolor="#FFA726", fontcolor="white"]
    ROS_gastric [label="ROS / oxidative\nstress", fillcolor="#FF7043", fontcolor="white"]
    DNA_damage [label="DNA damage\n(8-OHdG↑)", fillcolor="#FF5722", fontcolor="white"]
    Atrophic_gastritis [label="Atrophic\ngastritis", fillcolor="#FFAB91", fontcolor="black"]
    Intestinal_meta [label="Intestinal\nmetaplasia", fillcolor="#FF8A65", fontcolor="black"]
    Dysplasia [label="Dysplasia", fillcolor="#FF7043", fontcolor="white"]
    Helicobacter_eradication [label="H. pylori\neradication Rx", fillcolor="#A5D6A7", fontcolor="black", shape=hexagon]
  }

  // =====================================================================
  // Cluster 2: Molecular Driver Pathways (Receptors & Oncogenes)
  // =====================================================================
  subgraph cluster_drivers {
    label="Molecular Drivers & Receptor Tyrosine Kinases"
    style="filled"
    color="steelblue"
    fillcolor="#E3F2FD"
    fontname="Arial"
    fontsize=11
    fontcolor="steelblue"

    HER2 [label="HER2 / ERBB2\n(IHC 3+ or FISH+)", fillcolor="#1565C0", fontcolor="white"]
    HER3 [label="HER3 / ERBB3", fillcolor="#42A5F5", fontcolor="white"]
    EGFR [label="EGFR / ERBB1", fillcolor="#42A5F5", fontcolor="white"]
    MET [label="c-MET\n(amplification)", fillcolor="#1976D2", fontcolor="white"]
    FGFR2 [label="FGFR2\n(amplification)", fillcolor="#1976D2", fontcolor="white"]
    VEGFR2 [label="VEGFR2\n(KDR)", fillcolor="#2196F3", fontcolor="white"]
    VEGFR1 [label="VEGFR1\n(FLT1)", fillcolor="#64B5F6", fontcolor="black"]
    CLDN18_2 [label="CLDN18.2\n(Claudin-18.2)", fillcolor="#1565C0", fontcolor="white"]
    FGFR2_amp [label="FGFR2\namplification", fillcolor="#0D47A1", fontcolor="white"]
    RET [label="RET fusion", fillcolor="#5C6BC0", fontcolor="white"]
    KRAS_mut [label="KRAS mutation\n(G12C/D/V)", fillcolor="#7986CB", fontcolor="white"]
    PIK3CA_mut [label="PIK3CA mutation\n(H1047R/E545K)", fillcolor="#7986CB", fontcolor="white"]
    ARID1A [label="ARID1A\n(chromatin rem.)", fillcolor="#9FA8DA", fontcolor="black"]
    RHOA [label="RHOA mutation\n(Y42C/L57V)", fillcolor="#7986CB", fontcolor="white"]
    CDH1_mut [label="CDH1 (E-cadherin)\nmutation/LOH", fillcolor="#9FA8DA", fontcolor="black"]
    HGF [label="HGF (c-MET ligand)", fillcolor="#90CAF9", fontcolor="black"]
    FGF [label="FGF2/4/7\n(FGFR ligands)", fillcolor="#90CAF9", fontcolor="black"]
    EGF [label="EGF / TGF-α\n(EGFR ligands)", fillcolor="#90CAF9", fontcolor="black"]
    NRG1 [label="NRG1\n(HER3 ligand)", fillcolor="#90CAF9", fontcolor="black"]
    HER2_dimer [label="HER2/HER3\nhetrodimer", fillcolor="#1976D2", fontcolor="white"]
  }

  // =====================================================================
  // Cluster 3: Signal Transduction (PI3K/AKT/mTOR, RAS/MAPK, JAK/STAT3)
