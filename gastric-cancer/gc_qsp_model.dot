    EZH2 [label="EZH2\n(H3K27me3)", fillcolor="#AB47BC", fontcolor="white"]
    TGFb [label="TGF-β1/2/3", fillcolor="#E1BEE7", fontcolor="black"]
    SMAD2_3 [label="SMAD2/3\n(R-SMAD)", fillcolor="#CE93D8", fontcolor="black"]
    SMAD4 [label="SMAD4\n(co-SMAD)", fillcolor="#CE93D8", fontcolor="black"]
    EMT_switch [label="EMT\n(epithelial→mesench.)", fillcolor="#7B1FA2", fontcolor="white"]
    E_cadherin [label="E-cadherin\n(CDH1↓)", fillcolor="#CE93D8", fontcolor="black"]
    N_cadherin [label="N-cadherin↑\n(CDH2)", fillcolor="#E1BEE7", fontcolor="black"]
    Vimentin [label="Vimentin↑\n(VIM)", fillcolor="#E1BEE7", fontcolor="black"]
    Snail [label="SNAIL\n(SNAI1/2)", fillcolor="#AB47BC", fontcolor="white"]
    ZEB1 [label="ZEB1/ZEB2\n(EMT-TF)", fillcolor="#CE93D8", fontcolor="black"]
    Twist [label="TWIST1/2\n(EMT-TF)", fillcolor="#CE93D8", fontcolor="black"]
    miR200 [label="miR-200 family\n(EMT suppressor)", fillcolor="#E1BEE7", fontcolor="black"]
    LncRNA_HOTAIR [label="HOTAIR lncRNA\n(epigenetic)", fillcolor="#CE93D8", fontcolor="black"]
    TMB_high [label="TMB-High\n(≥10 mut/Mb)", fillcolor="#AB47BC", fontcolor="white"]
    PIK3CA_EBV [label="PIK3CA mut\n(EBV subtype)", fillcolor="#E1BEE7", fontcolor="black"]
    CSC_marker [label="Cancer Stem Cells\n(CD44+/CD133+/ALDH1+)", fillcolor="#7B1FA2", fontcolor="white"]
