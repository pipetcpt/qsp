  subgraph cluster_signaling {
    label="Intracellular Signal Transduction"
    style="filled"
    color="darkgreen"
    fillcolor="#E8F5E9"
    fontname="Arial"
    fontsize=11
    fontcolor="darkgreen"

    PI3K [label="PI3K\n(p110α/p85)", fillcolor="#2E7D32", fontcolor="white"]
    PTEN [label="PTEN\n(tumor suppressor)", fillcolor="#388E3C", fontcolor="white"]
    PIP3 [label="PIP3", fillcolor="#66BB6A", fontcolor="black"]
    AKT [label="AKT / PKB\n(p-AKT S473)", fillcolor="#2E7D32", fontcolor="white"]
    mTORC1 [label="mTORC1\n(S6K1, 4EBP1)", fillcolor="#1B5E20", fontcolor="white"]
    mTORC2 [label="mTORC2", fillcolor="#388E3C", fontcolor="white"]
    S6K1 [label="S6K1\n(ribosome biogen.)", fillcolor="#A5D6A7", fontcolor="black"]
    fourEBP1 [label="4E-BP1\n(translation init.)", fillcolor="#A5D6A7", fontcolor="black"]
    RAS [label="RAS\n(H/K/N-RAS)", fillcolor="#43A047", fontcolor="white"]
    RAF [label="RAF / BRAF", fillcolor="#388E3C", fontcolor="white"]
    MEK [label="MEK1/2", fillcolor="#43A047", fontcolor="white"]
    ERK [label="ERK1/2\n(p-ERK T202/Y204)", fillcolor="#2E7D32", fontcolor="white"]
    JAK1 [label="JAK1", fillcolor="#66BB6A", fontcolor="black"]
    JAK2 [label="JAK2", fillcolor="#66BB6A", fontcolor="black"]
    STAT3 [label="STAT3\n(p-STAT3 Y705)", fillcolor="#1B5E20", fontcolor="white"]
    STAT3_dimer [label="STAT3 dimer\n(nuclear)", fillcolor="#388E3C", fontcolor="white"]
    SRC [label="SRC kinase", fillcolor="#81C784", fontcolor="black"]
    GRB2 [label="GRB2 / SOS\nadaptor", fillcolor="#A5D6A7", fontcolor="black"]
    SHP2 [label="SHP2\n(PTPN11)", fillcolor="#C8E6C9", fontcolor="black"]
    GSK3b [label="GSK3β\n(phosphorylation)", fillcolor="#81C784", fontcolor="black"]
    TSC1_2 [label="TSC1/TSC2\ncomplex", fillcolor="#A5D6A7", fontcolor="black"]
    RHEB [label="RHEB-GTP\n(mTOR activator)", fillcolor="#C8E6C9", fontcolor="black"]
    YAP_TAZ [label="YAP/TAZ\n(Hippo)", fillcolor="#81C784", fontcolor="black"]
    WNT_signal [label="WNT signal\n(β-catenin nuclear)", fillcolor="#66BB6A", fontcolor="black"]
  }

