    style="filled"
    color="red"
    fillcolor="#FFEBEE"
    fontname="Arial"
    fontsize=11
    fontcolor="darkred"

    TP53 [label="TP53\n(mut R175H/R248W)", fillcolor="#C62828", fontcolor="white"]
    MDM2 [label="MDM2\n(p53 degrader)", fillcolor="#EF5350", fontcolor="white"]
    p21 [label="p21 / CDKN1A\n(CKI)", fillcolor="#EF9A9A", fontcolor="black"]
    p16 [label="p16 / CDKN2A\n(CKI)", fillcolor="#EF9A9A", fontcolor="black"]
    Rb [label="Rb / RB1\n(E2F repressor)", fillcolor="#EF5350", fontcolor="white"]
    E2F [label="E2F1/2/3\n(transcription)", fillcolor="#FFCDD2", fontcolor="black"]
    CDK4 [label="CDK4/6\n(cyclin D)", fillcolor="#F44336", fontcolor="white"]
    CyclinD [label="Cyclin D1/D2\n(CCND1)", fillcolor="#FFCDD2", fontcolor="black"]
    CDK2 [label="CDK2\n(cyclin E/A)", fillcolor="#EF5350", fontcolor="white"]
    CyclinE [label="Cyclin E1\n(CCNE1)", fillcolor="#FFCDD2", fontcolor="black"]
    Bcl2 [label="BCL-2\n(anti-apoptotic)", fillcolor="#B71C1C", fontcolor="white"]
    BclXL [label="BCL-XL\n(anti-apoptotic)", fillcolor="#B71C1C", fontcolor="white"]
    BAX [label="BAX / BAK\n(pro-apoptotic)", fillcolor="#EF5350", fontcolor="white"]
    BIM [label="BIM / PUMA\n(BH3-only)", fillcolor="#EF9A9A", fontcolor="black"]
    Cytochrome_c [label="Cytochrome c\n(mitochondria)", fillcolor="#FFCDD2", fontcolor="black"]
    Caspase9 [label="Caspase-9\n(intrinsic)", fillcolor="#EF5350", fontcolor="white"]
    Caspase3 [label="Caspase-3/7\n(executioner)", fillcolor="#C62828", fontcolor="white"]
    XIAP [label="XIAP\n(IAP family)", fillcolor="#FFCDD2", fontcolor="black"]
    SURVIVIN [label="Survivin\n(BIRC5)", fillcolor="#EF9A9A", fontcolor="black"]
    Telomerase [label="Telomerase\n(hTERT↑)", fillcolor="#FFCDD2", fontcolor="black"]
