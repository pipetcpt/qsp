digraph GBS_QSP_Model {
    rankdir=LR;
    graph [fontname="Helvetica", fontsize=11, bgcolor="white", splines=ortho, nodesep=0.4, ranksep=0.8, label="Guillain-Barré Syndrome (GBS) — Quantitative Systems Pharmacology Model\nMechanistic Map: Infection → Molecular Mimicry → Immune Activation → Nerve Damage → Clinical Endpoints", labelloc=t, labeljust=c, fontsize=14];
    node  [fontname="Helvetica", fontsize=9];
    edge  [fontname="Helvetica", fontsize=8, arrowsize=0.7];

    // ─────────────────────────────────────────────
    // CLUSTER 1: Triggering Infections & Molecular Mimicry
    // ─────────────────────────────────────────────
    subgraph cluster_infection {
        label="Triggering Infections & Molecular Mimicry";
        style=filled; fillcolor="#FFF9C4"; color="#B8860B"; fontsize=10; fontcolor="#5D4037";

        C_jejuni            [label="C. jejuni\n(GI infection)", shape=ellipse, style=filled, fillcolor="#FFD54F"];
        CMV                 [label="CMV\n(viral)", shape=ellipse, style=filled, fillcolor="#FFD54F"];
        EBV                 [label="EBV\n(viral)", shape=ellipse, style=filled, fillcolor="#FFD54F"];
        Mycoplasma_pneumoniae [label="Mycoplasma\npneumoniae", shape=ellipse, style=filled, fillcolor="#FFD54F"];
        SARS_CoV2           [label="SARS-CoV-2\n(viral)", shape=ellipse, style=filled, fillcolor="#FFD54F"];
        Haemophilus_influenzae [label="Haemophilus\ninfluenzae", shape=ellipse, style=filled, fillcolor="#FFD54F"];
        LOS_lipo_oligosaccharide [label="LOS\n(lipo-oligosaccharide)", shape=box, style=filled, fillcolor="#FFF176"];
        Molecular_mimicry   [label="Molecular Mimicry\n(cross-reactivity)", shape=diamond, style=filled, fillcolor="#FFCC80"];
        GM1_epitope         [label="GM1 ganglioside\nepitope", shape=box, style=filled, fillcolor="#FFF176"];
        GD1a_epitope        [label="GD1a ganglioside\nepitope", shape=box, style=filled, fillcolor="#FFF176"];
        GD1b_epitope        [label="GD1b ganglioside\nepitope", shape=box, style=filled, fillcolor="#FFF176"];
        GQ1b_epitope        [label="GQ1b ganglioside\nepitope", shape=box, style=filled, fillcolor="#FFF176"];
        GT1b_epitope        [label="GT1b ganglioside\nepitope", shape=box, style=filled, fillcolor="#FFF176"];
        TLR4_LOS_binding    [label="TLR4–LOS\nbinding", shape=diamond, style=filled, fillcolor="#FFCC80"];
    }

    // ─────────────────────────────────────────────
    // CLUSTER 2: Innate Immunity
    // ─────────────────────────────────────────────
    subgraph cluster_innate {
        label="Innate Immune Activation";
        style=filled; fillcolor="#E3F2FD"; color="#1565C0"; fontsize=10; fontcolor="#0D47A1";

        TLR4_signaling      [label="TLR4\nSignaling", shape=diamond, style=filled, fillcolor="#90CAF9"];
        NF_kB_activation    [label="NF-κB\nActivation", shape=diamond, style=filled, fillcolor="#90CAF9"];
        DC_maturation       [label="Dendritic Cell\nMaturation", shape=ellipse, style=filled, fillcolor="#BBDEFB"];
        M1_macrophage       [label="M1 Macrophage\n(pro-inflam)", shape=ellipse, style=filled, fillcolor="#BBDEFB"];
        M2_macrophage       [label="M2 Macrophage\n(anti-inflam)", shape=ellipse, style=filled, fillcolor="#BBDEFB"];
        Monocyte_recruitment [label="Monocyte\nRecruitment", shape=ellipse, style=filled, fillcolor="#BBDEFB"];
        Neutrophil_infiltration [label="Neutrophil\nInfiltration", shape=ellipse, style=filled, fillcolor="#BBDEFB"];
        NK_cell             [label="NK Cell\nActivation", shape=ellipse, style=filled, fillcolor="#BBDEFB"];
        MHC_II_presentation [label="MHC-II\nAntigen Presentation", shape=diamond, style=filled, fillcolor="#90CAF9"];
        Antigen_processing  [label="Antigen\nProcessing", shape=diamond, style=filled, fillcolor="#90CAF9"];
        Complement_innate_activation [label="Innate Complement\nActivation", shape=diamond, style=filled, fillcolor="#90CAF9"];
        Phagocytosis        [label="Phagocytosis", shape=diamond, style=filled, fillcolor="#90CAF9"];
        PRR_signaling       [label="PRR\nSignaling", shape=diamond, style=filled, fillcolor="#90CAF9"];
    }

    // ─────────────────────────────────────────────
    // CLUSTER 3: B Cell Response & Antibodies
    // ─────────────────────────────────────────────
    subgraph cluster_bcell {
        label="B Cell Activation & Anti-ganglioside Antibodies";
        style=filled; fillcolor="#E8F5E9"; color="#2E7D32"; fontsize=10; fontcolor="#1B5E20";

        B_cell_activation   [label="B Cell\nActivation", shape=ellipse, style=filled, fillcolor="#A5D6A7"];
        GC_reaction         [label="Germinal Center\nReaction", shape=diamond, style=filled, fillcolor="#81C784"];
        Plasma_cell_differentiation [label="Plasma Cell\nDifferentiation", shape=ellipse, style=filled, fillcolor="#A5D6A7"];
        Memory_B_cell       [label="Memory B Cell\nFormation", shape=ellipse, style=filled, fillcolor="#A5D6A7"];
        Anti_GM1_IgG        [label="Anti-GM1 IgG\n(pathogenic Ab)", shape=box, style=filled, fillcolor="#C8E6C9"];
        Anti_GM1_IgM        [label="Anti-GM1 IgM\n(early Ab)", shape=box, style=filled, fillcolor="#C8E6C9"];
        Anti_GD1a_IgG       [label="Anti-GD1a IgG\n(AMAN marker)", shape=box, style=filled, fillcolor="#C8E6C9"];
        Anti_GQ1b_IgG       [label="Anti-GQ1b IgG\n(MFS marker)", shape=box, style=filled, fillcolor="#C8E6C9"];
        Anti_GD1b_IgG       [label="Anti-GD1b IgG\n(ataxic GBS)", shape=box, style=filled, fillcolor="#C8E6C9"];
        BAFF_APRIL_support  [label="BAFF/APRIL\nB cell survival", shape=box, style=filled, fillcolor="#C8E6C9"];
        BCR_signaling       [label="BCR\nSignaling", shape=diamond, style=filled, fillcolor="#81C784"];
        Somatic_hypermutation [label="Somatic\nHypermutation", shape=diamond, style=filled, fillcolor="#81C784"];
        Class_switching_IgG [label="Class Switch\nIgM→IgG", shape=diamond, style=filled, fillcolor="#81C784"];
    }

    // ─────────────────────────────────────────────
    // CLUSTER 4: T Cell Response
    // ─────────────────────────────────────────────
    subgraph cluster_tcell {
        label="T Cell Responses";
        style=filled; fillcolor="#F3E5F5"; color="#6A1B9A"; fontsize=10; fontcolor="#4A148C";

        Naive_Th_cell       [label="Naïve Th Cell", shape=ellipse, style=filled, fillcolor="#CE93D8"];
        Th1_differentiation [label="Th1\nDifferentiation", shape=ellipse, style=filled, fillcolor="#CE93D8"];
        Th2_differentiation [label="Th2\nDifferentiation", shape=ellipse, style=filled, fillcolor="#CE93D8"];
        Th17_differentiation [label="Th17\nDifferentiation", shape=ellipse, style=filled, fillcolor="#CE93D8"];
        Treg_cell           [label="Treg Cell\n(immunosuppressive)", shape=ellipse, style=filled, fillcolor="#CE93D8"];
        CD8_cytotoxic_T     [label="CD8+ Cytotoxic\nT Cell", shape=ellipse, style=filled, fillcolor="#CE93D8"];
        T_cell_CNS_trafficking [label="T Cell\nNeural Trafficking", shape=diamond, style=filled, fillcolor="#BA68C8"];
        TCR_signaling       [label="TCR\nSignaling", shape=diamond, style=filled, fillcolor="#BA68C8"];
        FOXP3_expression    [label="FOXP3\nExpression", shape=box, style=filled, fillcolor="#E1BEE7"];
        IL2_autocrine       [label="IL-2\nAutocrine Loop", shape=box, style=filled, fillcolor="#E1BEE7"];
        T_cell_exhaustion   [label="T Cell\nExhaustion", shape=diamond, style=filled, fillcolor="#BA68C8"];
        T_cell_nerve_infiltration [label="T Cell Nerve\nInfiltration", shape=diamond, style=filled, fillcolor="#BA68C8"];
    }

    // ─────────────────────────────────────────────
    // CLUSTER 5: Cytokines & Mediators
    // ─────────────────────────────────────────────
    subgraph cluster_cytokine {
        label="Cytokines & Inflammatory Mediators";
        style=filled; fillcolor="#FFFDE7"; color="#F57F17"; fontsize=10; fontcolor="#E65100";

        IL1_beta            [label="IL-1β", shape=box, style=filled, fillcolor="#FFF9C4"];
        IL6                 [label="IL-6", shape=box, style=filled, fillcolor="#FFF9C4"];
        IL17                [label="IL-17", shape=box, style=filled, fillcolor="#FFF9C4"];
        IL10                [label="IL-10\n(anti-inflam)", shape=box, style=filled, fillcolor="#FFF9C4"];
        IL4                 [label="IL-4\n(Th2)", shape=box, style=filled, fillcolor="#FFF9C4"];
        TNF_alpha           [label="TNF-α", shape=box, style=filled, fillcolor="#FFF9C4"];
        IFN_gamma           [label="IFN-γ\n(Th1)", shape=box, style=filled, fillcolor="#FFF9C4"];
        TGF_beta            [label="TGF-β\n(Treg/fibrosis)", shape=box, style=filled, fillcolor="#FFF9C4"];
        MCP1                [label="MCP-1/CCL2\n(monocyte chemo)", shape=box, style=filled, fillcolor="#FFF9C4"];
        CXCL10              [label="CXCL10/IP-10\n(T cell chemo)", shape=box, style=filled, fillcolor="#FFF9C4"];
        GM_CSF              [label="GM-CSF\n(myeloid)", shape=box, style=filled, fillcolor="#FFF9C4"];
        IL21                [label="IL-21\n(B cell help)", shape=box, style=filled, fillcolor="#FFF9C4"];
        IL12                [label="IL-12\n(Th1 polarize)", shape=box, style=filled, fillcolor="#FFF9C4"];
        IL23                [label="IL-23\n(Th17 polarize)", shape=box, style=filled, fillcolor="#FFF9C4"];
        BAFF                [label="BAFF\n(B cell survival)", shape=box, style=filled, fillcolor="#FFF9C4"];
        IL2                 [label="IL-2\n(T cell growth)", shape=box, style=filled, fillcolor="#FFF9C4"];
        IL13                [label="IL-13\n(Th2/repair)", shape=box, style=filled, fillcolor="#FFF9C4"];
    }

    // ─────────────────────────────────────────────
    // CLUSTER 6: Complement Cascade
    // ─────────────────────────────────────────────
    subgraph cluster_complement {
        label="Complement Cascade";
        style=filled; fillcolor="#FCE4EC"; color="#880E4F"; fontsize=10; fontcolor="#880E4F";

        C1q                 [label="C1q\n(classical)", shape=box, style=filled, fillcolor="#F8BBD9"];
        C1r_C1s             [label="C1r/C1s\nproteases", shape=box, style=filled, fillcolor="#F8BBD9"];
        C4_C2               [label="C4/C2\ncleavage", shape=box, style=filled, fillcolor="#F8BBD9"];
        C3                  [label="C3\n(central hub)", shape=box, style=filled, fillcolor="#F48FB1"];
        C3b_opsonin         [label="C3b\nOpsonin", shape=box, style=filled, fillcolor="#F8BBD9"];
        C3_convertase       [label="C3 Convertase\n(C4b2a / C3bBb)", shape=diamond, style=filled, fillcolor="#F48FB1"];
        C5                  [label="C5\n(pivotal)", shape=box, style=filled, fillcolor="#F48FB1"];
        C5a_anaphylatoxin   [label="C5a\nAnaphylatoxin", shape=box, style=filled, fillcolor="#F8BBD9"];
        C5b                 [label="C5b\n(MAC seed)", shape=box, style=filled, fillcolor="#F8BBD9"];
        C6_C7_C8            [label="C6/C7/C8\nassembly", shape=box, style=filled, fillcolor="#F8BBD9"];
        C9_polymerization   [label="C9\nPolymerization", shape=diamond, style=filled, fillcolor="#F48FB1"];
        MAC_C5b9            [label="MAC (C5b-9)\nMembrane Attack", shape=diamond, style=filled, fillcolor="#E91E63", fontcolor="white"];
        Properdin           [label="Properdin\n(alt stabilizer)", shape=box, style=filled, fillcolor="#F8BBD9"];
        Factor_B_D          [label="Factor B/D\n(alt pathway)", shape=box, style=filled, fillcolor="#F8BBD9"];
        Alternative_pathway [label="Alternative\nPathway", shape=diamond, style=filled, fillcolor="#F48FB1"];
        Lectin_pathway      [label="Lectin\nPathway (MBL)", shape=diamond, style=filled, fillcolor="#F48FB1"];
        Complement_receptor_CR3 [label="CR3\n(Mac-1) receptor", shape=box, style=filled, fillcolor="#F8BBD9"];
    }

    // ─────────────────────────────────────────────
    // CLUSTER 7: AIDP Pathology
    // ─────────────────────────────────────────────
    subgraph cluster_aidp {
        label="AIDP — Demyelinating Pathology";
        style=filled; fillcolor="#E8F5E9"; color="#1B5E20"; fontsize=10; fontcolor="#1B5E20";

        AIDP_subtype        [label="AIDP\nSubtype (~85% West)", shape=diamond, style=filled, fillcolor="#A5D6A7"];
        Schwann_cell_damage [label="Schwann Cell\nDamage", shape=ellipse, style=filled, fillcolor="#FFCDD2"];
        Myelin_stripping    [label="Myelin\nStripping", shape=diamond, style=filled, fillcolor="#EF9A9A"];
        Anti_myelin_Ab      [label="Anti-myelin\nAntibodies", shape=box, style=filled, fillcolor="#C8E6C9"];
        Segmental_demyelination [label="Segmental\nDemyelination", shape=diamond, style=filled, fillcolor="#EF9A9A"];
        Remyelination       [label="Remyelination\n(recovery)", shape=diamond, style=filled, fillcolor="#A5D6A7"];
        Schwann_cell_proliferation [label="Schwann Cell\nProliferation", shape=ellipse, style=filled, fillcolor="#C8E6C9"];
        Macrophage_myelin_phagocytosis [label="Macrophage\nMyelin Phagocytosis", shape=diamond, style=filled, fillcolor="#EF9A9A"];
        Onion_bulb_formation [label="Onion Bulb\nFormation (chronic)", shape=diamond, style=filled, fillcolor="#EF9A9A"];
        Conduction_block_demyelinating [label="Conduction Block\n(demyelinating)", shape=diamond, style=filled, fillcolor="#EF9A9A"];
        PMP22_target        [label="PMP22\n(myelin protein target)", shape=box, style=filled, fillcolor="#C8E6C9"];
        MBP_target          [label="MBP\n(myelin basic protein)", shape=box, style=filled, fillcolor="#C8E6C9"];
        MAG_target          [label="MAG\n(myelin assoc. glycoprot.)", shape=box, style=filled, fillcolor="#C8E6C9"];
        Periaxin_damage     [label="Periaxin\n(L-periaxin damage)", shape=box, style=filled, fillcolor="#C8E6C9"];
    }

    // ─────────────────────────────────────────────
    // CLUSTER 8: AMAN/AMSAN Pathology
    // ─────────────────────────────────────────────
    subgraph cluster_aman {
        label="AMAN/AMSAN — Axonal Pathology";
        style=filled; fillcolor="#FBE9E7"; color="#BF360C"; fontsize=10; fontcolor="#BF360C";

        AMAN_subtype        [label="AMAN Subtype\n(axonal motor)", shape=diamond, style=filled, fillcolor="#FFAB91"];
        AMSAN_subtype       [label="AMSAN Subtype\n(motor+sensory)", shape=diamond, style=filled, fillcolor="#FFAB91"];
        Anti_GM1_node_binding [label="Anti-GM1 IgG\nat Node of Ranvier", shape=box, style=filled, fillcolor="#FFCCBC"];
        Anti_GD1a_node_binding [label="Anti-GD1a IgG\nat Node of Ranvier", shape=box, style=filled, fillcolor="#FFCCBC"];
        MAC_at_node_Ranvier [label="MAC Deposition\nat Node of Ranvier", shape=diamond, style=filled, fillcolor="#FF7043"];
        Calcium_influx_axon [label="Calcium Influx\nInto Axon", shape=diamond, style=filled, fillcolor="#FF8A65"];
        Calpain_activation  [label="Calpain\nActivation", shape=diamond, style=filled, fillcolor="#FF8A65"];
        Spectrin_degradation [label="Spectrin\nDegradation", shape=box, style=filled, fillcolor="#FFCCBC"];
        Axon_retraction_bulb [label="Axon Retraction\nBulb Formation", shape=diamond, style=filled, fillcolor="#FF7043"];
        Reversible_conduction_failure [label="Reversible\nConduction Failure", shape=diamond, style=filled, fillcolor="#FFAB91"];
        Irreversible_axon_loss [label="Irreversible\nAxon Loss", shape=diamond, style=filled, fillcolor="#FF5722", fontcolor="white"];
        Wallerian_degeneration [label="Wallerian\nDegeneration", shape=diamond, style=filled, fillcolor="#FF5722", fontcolor="white"];
        Axonal_sprouting    [label="Axonal\nSprouting (repair)", shape=diamond, style=filled, fillcolor="#FFAB91"];
        NF186_disruption    [label="NF186/Caspr\nNode Disruption", shape=box, style=filled, fillcolor="#FFCCBC"];
    }

    // ─────────────────────────────────────────────
    // CLUSTER 9: Clinical Endpoints
    // ─────────────────────────────────────────────
    subgraph cluster_clinical {
        label="Clinical Endpoints & Outcomes";
        style=filled; fillcolor="#FFF3E0"; color="#E65100"; fontsize=10; fontcolor="#BF360C";

        GBS_disability_score_0to6 [label="GBS Disability\nScore (0–6)", shape=cylinder, style=filled, fillcolor="#FFCC80"];
        Hughes_grade        [label="Hughes\nFunctional Grade", shape=cylinder, style=filled, fillcolor="#FFCC80"];
        MRC_motor_sum       [label="MRC Motor\nSum Score", shape=cylinder, style=filled, fillcolor="#FFCC80"];
        FVC_percentage      [label="FVC %\nRespiratory Function", shape=cylinder, style=filled, fillcolor="#FFCC80"];
        ICU_admission       [label="ICU\nAdmission", shape=cylinder, style=filled, fillcolor="#FF8A65"];
        Mechanical_ventilation [label="Mechanical\nVentilation", shape=cylinder, style=filled, fillcolor="#FF8A65"];
        Autonomic_dysfunction [label="Autonomic\nDysfunction", shape=cylinder, style=filled, fillcolor="#FFCC80"];
        HR_variability      [label="Heart Rate\nVariability (HRV)", shape=cylinder, style=filled, fillcolor="#FFCC80"];
        BP_lability         [label="BP\nLability", shape=cylinder, style=filled, fillcolor="#FFCC80"];
        CSF_protein_elevation [label="CSF Protein\nElevation", shape=cylinder, style=filled, fillcolor="#FFE0B2"];
        NCV_velocity        [label="Nerve Conduction\nVelocity (NCV)", shape=cylinder, style=filled, fillcolor="#FFE0B2"];
        Distal_motor_latency [label="Distal Motor\nLatency (DML)", shape=cylinder, style=filled, fillcolor="#FFE0B2"];
        Fwave_latency       [label="F-wave\nLatency", shape=cylinder, style=filled, fillcolor="#FFE0B2"];
        Pain_NRS            [label="Pain\nNRS (0–10)", shape=cylinder, style=filled, fillcolor="#FFCC80"];
        Fatigue_VAS         [label="Fatigue\nVAS", shape=cylinder, style=filled, fillcolor="#FFCC80"];
        Residual_disability_6mo [label="Residual Disability\nat 6 months", shape=cylinder, style=filled, fillcolor="#FF8A65"];
    }

    // ─────────────────────────────────────────────
    // CLUSTER 10: IVIG PK
    // ─────────────────────────────────────────────
    subgraph cluster_ivig_pk {
        label="IVIG — Pharmacokinetics";
        style=filled; fillcolor="#EDE7F6"; color="#4527A0"; fontsize=10; fontcolor="#311B92";

        IVIG_dose_2gkg      [label="IVIG Dose\n2 g/kg over 5d", shape=hexagon, style=filled, fillcolor="#B39DDB"];
        IVIG_central_Vc     [label="Central Volume\nVc (plasma)", shape=box, style=filled, fillcolor="#D1C4E9"];
        IVIG_peripheral_Vp  [label="Peripheral Volume\nVp (tissue)", shape=box, style=filled, fillcolor="#D1C4E9"];
        FcRn_recycling      [label="FcRn\nRecycling", shape=diamond, style=filled, fillcolor="#9575CD"];
        IgG_catabolism      [label="IgG\nCatabolism", shape=diamond, style=filled, fillcolor="#9575CD"];
        IVIG_half_life_21d  [label="IgG Half-life\n~21 days", shape=box, style=filled, fillcolor="#D1C4E9"];
        Volume_of_distribution [label="Vd\n~0.06 L/kg", shape=box, style=filled, fillcolor="#D1C4E9"];
    }

    // ─────────────────────────────────────────────
    // CLUSTER 11: Plasma Exchange PK
    // ─────────────────────────────────────────────
    subgraph cluster_pe_pk {
        label="Plasma Exchange — Pharmacokinetics";
        style=filled; fillcolor="#E0F7FA"; color="#006064"; fontsize=10; fontcolor="#004D40";

        Plasma_exchange_5sessions [label="Plasma Exchange\n5 sessions/2wks", shape=hexagon, style=filled, fillcolor="#80DEEA"];
        PE_volume_50mLkg    [label="Exchange Volume\n~50 mL/kg/session", shape=box, style=filled, fillcolor="#B2EBF2"];
        Albumin_replacement [label="Albumin\nReplacement Fluid", shape=box, style=filled, fillcolor="#B2EBF2"];
        IgG_removal_rate    [label="IgG\nRemoval Rate", shape=diamond, style=filled, fillcolor="#4DD0E1"];
        Complement_removal_PE [label="Complement\nRemoval by PE", shape=diamond, style=filled, fillcolor="#4DD0E1"];
        Cytokine_clearance_PE [label="Cytokine\nClearance by PE", shape=diamond, style=filled, fillcolor="#4DD0E1"];
        Rebound_antibody    [label="Rebound\nAntibody Production", shape=diamond, style=filled, fillcolor="#FF8A65"];
    }

    // ─────────────────────────────────────────────
    // CLUSTER 12: Treatment Pharmacodynamics
    // ─────────────────────────────────────────────
    subgraph cluster_treatment_pd {
        label="Treatment Pharmacodynamics";
        style=filled; fillcolor="#F3E5F5"; color="#7B1FA2"; fontsize=10; fontcolor="#4A148C";

        IVIG_Fc_gamma_R_blockade [label="IVIG: FcγR\nBlockade", shape=diamond, style=filled, fillcolor="#CE93D8"];
        IVIG_antiidiotype_Ab [label="IVIG: Anti-idiotype\nAntibodies", shape=diamond, style=filled, fillcolor="#CE93D8"];
        IVIG_complement_scavenge [label="IVIG: Complement\nScavenging", shape=diamond, style=filled, fillcolor="#CE93D8"];
        IVIG_Treg_expansion [label="IVIG: Treg\nExpansion", shape=diamond, style=filled, fillcolor="#CE93D8"];
        PE_pathogenic_Ab_depletion [label="PE: Pathogenic Ab\nDepletion", shape=diamond, style=filled, fillcolor="#4DD0E1"];
        Eculizumab_C5_inhibition [label="Eculizumab\nC5 Inhibition", shape=hexagon, style=filled, fillcolor="#B39DDB"];
        Eculizumab_MAC_prevention [label="Eculizumab:\nMAC Prevention", shape=diamond, style=filled, fillcolor="#CE93D8"];
        Rituximab_B_cell_depletion [label="Rituximab\nB Cell Depletion", shape=hexagon, style=filled, fillcolor="#B39DDB"];
        BDNF_neuroprotection [label="BDNF\nNeuroprotection", shape=box, style=filled, fillcolor="#E1BEE7"];
        NGF_axon_regeneration [label="NGF\nAxon Regeneration", shape=box, style=filled, fillcolor="#E1BEE7"];
        Schwann_repair_signal [label="Schwann Cell\nRepair Signal", shape=diamond, style=filled, fillcolor="#CE93D8"];
        Corticosteroids_no_benefit [label="Corticosteroids\n(no benefit in GBS)", shape=hexagon, style=filled, fillcolor="#BDBDBD"];
    }

    // ==============================================
    // EDGES — Cluster 1 (Infection) internal
    // ==============================================
    C_jejuni -> LOS_lipo_oligosaccharide [label="produces", color="#8D6E63"];
    C_jejuni -> GM1_epitope [label="LOS mimics", color="#8D6E63"];
    C_jejuni -> GD1a_epitope [label="LOS mimics", color="#8D6E63"];
    LOS_lipo_oligosaccharide -> TLR4_LOS_binding [label="binds", color="#8D6E63"];
    LOS_lipo_oligosaccharide -> Molecular_mimicry [label="triggers", color="#8D6E63"];
    GM1_epitope -> Molecular_mimicry [label="cross-reactive", color="#8D6E63"];
    GD1a_epitope -> Molecular_mimicry [label="cross-reactive", color="#8D6E63"];
    GD1b_epitope -> Molecular_mimicry [label="cross-reactive", color="#8D6E63"];
    GQ1b_epitope -> Molecular_mimicry [label="cross-reactive", color="#8D6E63"];
    GT1b_epitope -> Molecular_mimicry [label="cross-reactive", color="#8D6E63"];
    CMV -> Molecular_mimicry [label="triggers", color="#8D6E63"];
    EBV -> Molecular_mimicry [label="triggers", color="#8D6E63"];
    Mycoplasma_pneumoniae -> Molecular_mimicry [label="triggers", color="#8D6E63"];
    SARS_CoV2 -> Molecular_mimicry [label="triggers", color="#8D6E63"];
    Haemophilus_influenzae -> Molecular_mimicry [label="triggers", color="#8D6E63"];

    // ==============================================
    // EDGES — Infection → Innate Immunity
    // ==============================================
    TLR4_LOS_binding -> TLR4_signaling [label="activates", color="#1565C0"];
    TLR4_signaling -> NF_kB_activation [label="downstream", color="#1565C0"];
    NF_kB_activation -> DC_maturation [label="drives", color="#1565C0"];
    NF_kB_activation -> M1_macrophage [label="drives", color="#1565C0"];
    NF_kB_activation -> Monocyte_recruitment [label="drives", color="#1565C0"];
    Molecular_mimicry -> PRR_signaling [label="via PAMPs", color="#1565C0"];
    PRR_signaling -> NF_kB_activation [label="activates", color="#1565C0"];
