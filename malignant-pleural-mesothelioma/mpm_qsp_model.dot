digraph MPM_QSP {
  graph [rankdir=LR, fontname="Helvetica", fontsize=11, labelloc=t,
         label="Malignant Pleural Mesothelioma (악성 흉막 중피종) — Integrated QSP Mechanistic Map\nAsbestos Fiber Exposure · Frustrated Phagocytosis/HMGB1-NLRP3 Inflammation · BAP1/CDKN2A/NF2-Hippo-YAP Tumor-Suppressor Loss\nChemotherapy (Cisplatin/Pemetrexed/Bevacizumab) · Checkpoint Immunotherapy (Nivolumab/Ipilimumab) · Mesothelin ADC · PARP inhibition (BAP1-deficient) · TTFields · Surgery/Radiation",
         splines=spline, overlap=false, nodesep=0.30, ranksep=0.55,
         bgcolor="#fbfbfd"];
  node  [shape=box, style="rounded,filled", fontname="Helvetica", fontsize=10,
         fillcolor="#ffffff", color="#7d8590"];
  edge  [fontname="Helvetica", fontsize=9, color="#6e7681", arrowsize=0.7];

  /* ───────────────────────── 1. Asbestos/Fiber Exposure & Etiology ───────── */
  subgraph cluster_expo {
    label="1. Fiber Exposure & Etiology";
    style="filled,rounded"; color="#5c6370"; fillcolor="#f3f0ff"; fontsize=12;
    Occup_Exp   [label="Occupational asbestos\nexposure (shipyard/insulation/mining)"];
    Environ_Exp [label="Environmental exposure\n(erionite, take-home dust)"];
    Fiber_Type  [label="Fiber type/geometry\n(amphibole crocidolite/amosite\n> chrysotile; length >8-20 μm)"];
    Latency     [label="Latency period\n(20-50 years exposure→diagnosis)"];
    Radiation_Exp [label="Prior thoracic\nradiotherapy (rare cofactor)"];
    SV40_Debate [label="SV40 co-carcinogen\n(controversial, minor role)"];
    PleuralCavity [label="Fibers lodge in\npleural cavity\n(mesothelial surface)"];
    Occup_Exp -> Fiber_Type; Environ_Exp -> Fiber_Type;
    Fiber_Type -> PleuralCavity -> Latency;
    Radiation_Exp -> PleuralCavity [style=dashed, label="cofactor"];
    SV40_Debate -> PleuralCavity [style=dotted, label="debated"];
  }

  /* ───────────────────────── 2. Frustrated Phagocytosis & Inflammation ───── */
  subgraph cluster_inflam {
    label="2. Frustrated Phagocytosis, ROS/RNS & HMGB1-NLRP3 Inflammation";
    style="filled,rounded"; color="#5c6370"; fillcolor="#fff4e6"; fontsize=12;
    Macro_Frust [label="Macrophage frustrated\nphagocytosis of long fibers"];
    ROS_RNS     [label="ROS/RNS generation\n(Fe-catalyzed Fenton reaction\non fiber surface)"];
    DNA_8OHdG   [label="8-OHdG DNA damage,\ndouble-strand breaks"];
    Mesoth_Necro [label="Programmed necrosis\nof mesothelial cells"];
    HMGB1_Rel   [label="HMGB1 release\nfrom necrotic mesothelial cells"];
    NLRP3_Inflam [label="NLRP3 inflammasome\nactivation in macrophages"];
    IL1B_Rel    [label="IL-1β release"];
    TNFa_Rel    [label="TNF-α release\n(macrophage-derived)"];
    Chronic_Inflam [label="Chronic pleural\ninflammation/fibrosis"];
    NFkB_Surv   [label="NF-κB activation in\ndamaged mesothelial cells"];
    Survival_Paradox [label="Survival-of-the-fittest\n(genomically unstable cells\nescape apoptosis)"];
    PleuralCavity -> Macro_Frust;
    Macro_Frust -> ROS_RNS -> DNA_8OHdG;
    DNA_8OHdG -> Mesoth_Necro;
    Mesoth_Necro -> HMGB1_Rel -> NLRP3_Inflam;
    NLRP3_Inflam -> IL1B_Rel; NLRP3_Inflam -> TNFa_Rel;
    IL1B_Rel -> Chronic_Inflam; TNFa_Rel -> Chronic_Inflam;
    TNFa_Rel -> NFkB_Surv [label="TNFR1"];
    NFkB_Surv -> Survival_Paradox [style=dashed, label="anti-apoptotic\n(mutagenic cell rescued)"];
    DNA_8OHdG -> Survival_Paradox;
    Chronic_Inflam -> Macro_Frust [style=dashed, label="amplification loop"];
  }

  /* ───────────────────────── 3. Genomic/Tumor-Suppressor Landscape ───────── */
  subgraph cluster_geno {
    label="3. Genomic Landscape — Tumor-Suppressor Loss";
    style="filled,rounded"; color="#5c6370"; fillcolor="#ffe6ec"; fontsize=12;
    BAP1_Somatic [label="BAP1 (3p21) somatic\nloss-of-function (~60% MPM)"];
    BAP1_Germline [label="BAP1 tumor predisposition\nsyndrome (germline, ~1-8%)"];
    CDKN2A_Del  [label="CDKN2A/p16-ARF (9p21)\nhomozygous deletion (~70-90%)"];
    NF2_Loss    [label="NF2/Merlin (22q12)\nloss-of-function (~40-50%)"];
    TP53_Mut    [label="TP53 mutation\n(~20%, less frequent than\nother solid tumors)"];
    SETD2_Loss  [label="SETD2 (H3K36 methyltransferase)\nco-mutation with BAP1"];
    DDX3X_Mut   [label="DDX3X mutation\n(subset, RNA helicase)"];
    Chromo_Instab [label="Chromosomal instability/\naneuploidy"];
    TCGA_Subtypes [label="Integrated molecular subtypes\n(epithelioid/biphasic-epithelioid/\nsarcomatoid, TCGA 2018)"];
    Survival_Paradox -> Chromo_Instab;
    Chromo_Instab -> BAP1_Somatic; Chromo_Instab -> CDKN2A_Del;
    Chromo_Instab -> NF2_Loss; Chromo_Instab -> TP53_Mut;
    BAP1_Germline -> BAP1_Somatic [style=dashed, label="2nd hit"];
    BAP1_Somatic -> SETD2_Loss [style=dashed, label="co-occurring"];
    Chromo_Instab -> DDX3X_Mut;
    BAP1_Somatic -> TCGA_Subtypes; CDKN2A_Del -> TCGA_Subtypes;
    NF2_Loss -> TCGA_Subtypes; TP53_Mut -> TCGA_Subtypes;
  }

  /* ───────────────────────── 4. BAP1 Loss — Chromatin/DNA Repair/Metabolism ── */
  subgraph cluster_bap1 {
    label="4. BAP1 Loss — Chromatin, DNA-Repair & Metabolic Reprogramming";
    style="filled,rounded"; color="#5c6370"; fillcolor="#e6f7ff"; fontsize=12;
    PRC1_Ub     [label="PRC1-mediated H2AK119\nubiquitination (loss of\nBAP1 deubiquitinase brake)"];
    Chromatin_Dysreg [label="Global chromatin\ndysregulation"];
    HR_Repair_Def [label="Homologous-recombination\n(BRCA1-pathway) repair deficiency"];
    PARP_Dep    [label="PARP1-dependent\nsingle-strand-break repair\n(synthetic-lethal vulnerability)"];
    IP3R3_Ca    [label="BAP1-IP3R3 axis:\nreduced ER→mitochondria\nCa2+ transfer"];
    Warburg_Shift [label="Warburg metabolic shift\n(glycolysis↑, OXPHOS↓)"];
    Apoptosis_Resist [label="Reduced Ca2+-driven\napoptosis (survival advantage)"];
    BAP1_Somatic -> PRC1_Ub -> Chromatin_Dysreg;
    BAP1_Somatic -> HR_Repair_Def -> PARP_Dep [style=dashed, label="synthetic lethality"];
    BAP1_Somatic -> IP3R3_Ca -> Warburg_Shift;
    IP3R3_Ca -> Apoptosis_Resist;
    Warburg_Shift -> Apoptosis_Resist;
  }

  /* ───────────────────────── 5. NF2-Hippo-YAP/TAZ Signaling ──────────────── */
  subgraph cluster_hippo {
    label="5. NF2/Merlin Loss — Hippo Pathway & YAP/TAZ Oncogenic Transcription";
    style="filled,rounded"; color="#5c6370"; fillcolor="#e6ffe9"; fontsize=12;
    LATS1_2_Inact [label="LATS1/2 kinase\ninactivation (loss of\nMerlin scaffold)"];
    MST1_2_Loss [label="MST1/2 (Hippo core\nkinase) pathway loss"];
    YAP_TAZ_Dephospho [label="YAP/TAZ\ndephosphorylation"];
    YAP_Nuclear [label="YAP/TAZ nuclear\ntranslocation"];
    TEAD_Txn    [label="TEAD1-4 transcription\nfactor complex"];
    CTGF_CYR61 [label="CTGF/CYR61, AXL,\nsurvivin transcription"];
    Prolif_Merlin [label="Uncontrolled\nproliferation & survival"];
    mTOR_Crosstalk [label="mTOR/PI3K-AKT\ncrosstalk activation"];
    YAPTEAD_Inhib [label="Investigational YAP-TEAD\ninhibitor (VT3989)"];
    NF2_Loss -> LATS1_2_Inact; NF2_Loss -> MST1_2_Loss;
    LATS1_2_Inact -> YAP_TAZ_Dephospho; MST1_2_Loss -> YAP_TAZ_Dephospho;
    YAP_TAZ_Dephospho -> YAP_Nuclear -> TEAD_Txn -> CTGF_CYR61 -> Prolif_Merlin;
    NF2_Loss -> mTOR_Crosstalk -> Prolif_Merlin;
    YAPTEAD_Inhib -> TEAD_Txn [style=dashed, color="#c0392b", label="blocks\n(investigational)"];
  }

  /* ───────────────────────── 6. Cell-Cycle & Apoptosis Dysregulation ─────── */
  subgraph cluster_cellcycle {
    label="6. Cell-Cycle Checkpoint & Apoptosis Dysregulation";
    style="filled,rounded"; color="#5c6370"; fillcolor="#fff9e6"; fontsize=12;
    p16_Loss    [label="p16INK4a loss\n(CDK4/6-Rb brake removed)"];
    p14ARF_Loss [label="p14ARF loss\n(MDM2-p53 brake removed)"];
    RB_Hyperphos [label="Rb hyperphosphorylation\n→ E2F release"];
    CellCycle_Prog [label="Unrestrained G1/S\ncell-cycle progression"];
    p53_Dysfunc [label="p53 pathway\ndysfunction"];
    Apoptosis_Evasion [label="Apoptosis evasion\n(BCL-2/MCL-1 upregulation)"];
    Telomerase_Reactiv [label="Telomerase (TERT)\nreactivation"];
    CDKN2A_Del -> p16_Loss -> RB_Hyperphos;
    CDKN2A_Del -> p14ARF_Loss -> p53_Dysfunc;
    TP53_Mut -> p53_Dysfunc;
    RB_Hyperphos -> CellCycle_Prog;
    p53_Dysfunc -> Apoptosis_Evasion;
    Apoptosis_Resist -> Apoptosis_Evasion [style=dashed];
    Chromo_Instab -> Telomerase_Reactiv;
  }

  /* ───────────────────────── 7. Histology, TME & Immune Evasion ──────────── */
  subgraph cluster_tme {
    label="7. Histologic Subtypes, Tumor Microenvironment & Immune Evasion";
    style="filled,rounded"; color="#5c6370"; fillcolor="#f0f0ff"; fontsize=12;
    Epithelioid [label="Epithelioid subtype\n(~60-80%, best prognosis)"];
    Sarcomatoid [label="Sarcomatoid subtype\n(worst prognosis,\nchemo/IO-resistant)"];
    Biphasic    [label="Biphasic subtype\n(mixed components)"];
    EMT_Program [label="Epithelial-mesenchymal\ntransition (EMT) program"];
    Mesothelin_Expr [label="Mesothelin (MSLN)\nsurface overexpression\n(epithelioid-dominant)"];
    TME_Stroma  [label="Desmoplastic stroma,\nCAF infiltration"];
    TAM_M2      [label="Tumor-associated\nmacrophages (M2-skewed)"];
    Treg_Infilt [label="Regulatory T-cell\ninfiltration"];
    PDL1_Expr   [label="PD-L1 expression\n(variable, ~20-40%)"];
    TMB_Low     [label="Low tumor mutational\nburden ('cold' but\nT-cell-inflamed subset exists"];
    CD8_Infilt  [label="CD8+ T-cell\ninfiltration (heterogeneous)"];
    Immune_Checkpoint [label="PD-1/CTLA-4 checkpoint\nengagement → T-cell exhaustion"];
    TCGA_Subtypes -> Epithelioid; TCGA_Subtypes -> Sarcomatoid; TCGA_Subtypes -> Biphasic;
    Prolif_Merlin -> EMT_Program; CellCycle_Prog -> EMT_Program;
    EMT_Program -> Sarcomatoid [style=dashed];
    Epithelioid -> Mesothelin_Expr;
    Sarcomatoid -> TME_Stroma; TME_Stroma -> TAM_M2; TAM_M2 -> Treg_Infilt;
    Epithelioid -> PDL1_Expr; Sarcomatoid -> PDL1_Expr [style=dashed, label="often higher"];
    Epithelioid -> TMB_Low;
    TAM_M2 -> Immune_Checkpoint; PDL1_Expr -> Immune_Checkpoint;
    CD8_Infilt -> Immune_Checkpoint [style=dashed];
    Treg_Infilt -> CD8_Infilt [style=dashed, label="suppresses"];
  }

  /* ───────────────────────── 8. Angiogenesis (VEGF axis) ──────────────────── */
  subgraph cluster_angio {
    label="8. Angiogenic Axis";
    style="filled,rounded"; color="#5c6370"; fillcolor="#e6fff5"; fontsize=12;
    HIF1a       [label="Intratumoral hypoxia\n→ HIF-1α stabilization"];
    VEGF_Auto   [label="Autocrine VEGF-A\nsecretion (tumor + stroma)"];
    VEGFR2_Endo [label="VEGFR2 signaling on\ntumor/pleural endothelium"];
    Neoangio    [label="Neoangiogenesis &\nvascular permeability"];
    Effusion_Driver [label="Pleural-fluid\nexudation driver"];
    Prolif_Merlin -> HIF1a; EMT_Program -> HIF1a;
    HIF1a -> VEGF_Auto -> VEGFR2_Endo -> Neoangio;
    VEGFR2_Endo -> Effusion_Driver;
  }

  /* ───────────────────────── 9. Clinical Phenotype & Staging ─────────────── */
  subgraph cluster_clinpheno {
    label="9. Clinical Phenotype, Local Invasion & Staging";
    style="filled,rounded"; color="#5c6370"; fillcolor="#fdf0e6"; fontsize=12;
    Pleural_Rind [label="Circumferential pleural\nrind / tumor thickening"];
    Pleural_Effusion [label="Malignant pleural\neffusion (exudative)"];
    ChestWall_Inv [label="Chest-wall/diaphragm/\npericardial invasion"];
    Mediastinal_LN [label="Mediastinal lymph-node\nmetastasis"];
    Distant_Met [label="Distant metastasis\n(uncommon, late)"];
    Dyspnea     [label="Dyspnea / restrictive\nventilatory impairment"];
    ChestPain   [label="Chest-wall pain\n(pleuritic/neuropathic)"];
    Weight_Loss [label="Weight loss / cachexia"];
    ECOG_PS     [label="ECOG performance\nstatus decline"];
    TNM_Stage   [label="IMIG/UICC TNM\nstage I-IV"];
    Prolif_Merlin -> Pleural_Rind; CellCycle_Prog -> Pleural_Rind;
    Effusion_Driver -> Pleural_Effusion;
    Pleural_Rind -> ChestWall_Inv -> Mediastinal_LN -> Distant_Met;
    Pleural_Effusion -> Dyspnea; ChestWall_Inv -> ChestPain;
    Distant_Met -> Weight_Loss; ChestWall_Inv -> Weight_Loss [style=dashed];
    Dyspnea -> ECOG_PS; ChestPain -> ECOG_PS; Weight_Loss -> ECOG_PS;
    Pleural_Rind -> TNM_Stage; ChestWall_Inv -> TNM_Stage; Mediastinal_LN -> TNM_Stage; Distant_Met -> TNM_Stage;
  }

  /* ───────────────────────── 10. Drug PK/PD — Chemotherapy ───────────────── */
  subgraph cluster_chemo {
    label="10. Drug PK/PD — Platinum/Antifolate/Anti-VEGF Chemotherapy";
    style="filled,rounded"; color="#5c6370"; fillcolor="#ffe6e6"; fontsize=12;
    Cisplatin_PK [label="Cisplatin IV\n(2-cpt, renal CL,\nDNA-Pt adduct formation)"];
    DNA_Crosslink [label="Intrastrand/interstrand\nDNA platination crosslinks"];
    Pemetrexed_PK [label="Pemetrexed IV\n(antifolate, TS/DHFR/GARFT\ninhibition, renal CL)"];
    Thymidylate_Block [label="Thymidylate synthase\nblockade → dTTP depletion"];
    Bevacizumab_PK [label="Bevacizumab IV\n(anti-VEGF-A mAb,\nq3w, t½ ~20d)"];
    Cytotoxic_Death [label="Mitotic catastrophe /\ncytotoxic tumor-cell death"];
    Nephrotox    [label="Cisplatin\nnephrotoxicity (↓CrCl)"];
    Myelosup_Chemo [label="Chemo-induced\nmyelosuppression (ANC/Plt)"];
    Cisplatin_PK -> DNA_Crosslink -> Cytotoxic_Death;
    Pemetrexed_PK -> Thymidylate_Block -> Cytotoxic_Death;
    Bevacizumab_PK -> VEGFR2_Endo [color="#c0392b", label="neutralizes\nVEGF-A"];
    Cisplatin_PK -> Nephrotox;
    Cisplatin_PK -> Myelosup_Chemo; Pemetrexed_PK -> Myelosup_Chemo;
    Cytotoxic_Death -> Pleural_Rind [color="#c0392b", style=dashed, label="tumor\nshrinkage"];
  }

  /* ───────────────────────── 11. Drug PK/PD — Immune Checkpoint Inhibitors ── */
  subgraph cluster_io {
    label="11. Drug PK/PD — Immune Checkpoint Inhibitors";
    style="filled,rounded"; color="#5c6370"; fillcolor="#e6f0ff"; fontsize=12;
    Nivolumab_PK [label="Nivolumab IV\n(anti-PD-1 mAb, q2-4w,\nt½ ~25d, target-mediated)"];
    Ipilimumab_PK [label="Ipilimumab IV\n(anti-CTLA-4 mAb, q6w,\nt½ ~15d)"];
    Pembrolizumab_PK [label="Pembrolizumab IV\n(anti-PD-1, off-label\n2L option)"];
    Avelumab_PK  [label="Avelumab IV\n(anti-PD-L1, JAVELIN)"];
    PD1_Block   [label="PD-1/PD-L1 axis\nblockade → checkpoint release"];
    CTLA4_Block [label="CTLA-4 blockade →\nTreg depletion + priming"];
    Tcell_Reinvig [label="Cytotoxic T-cell\nreinvigoration & clonal expansion"];
    ADCC_Tumor_Kill [label="T-cell-mediated\ntumor-cell killing"];
    irAE        [label="Immune-related adverse\nevents (colitis/pneumonitis/\nendocrinopathy)"];
    Nivolumab_PK -> PD1_Block; Pembrolizumab_PK -> PD1_Block; Avelumab_PK -> PD1_Block;
    Ipilimumab_PK -> CTLA4_Block;
    PD1_Block -> Tcell_Reinvig; CTLA4_Block -> Tcell_Reinvig;
    Immune_Checkpoint -> Tcell_Reinvig [style=dashed, label="target engaged"];
    Tcell_Reinvig -> ADCC_Tumor_Kill -> Pleural_Rind [color="#1f6feb", style=dashed, label="tumor\nshrinkage/PFS"];
    Nivolumab_PK -> irAE; Ipilimumab_PK -> irAE [label="dose-dependent"];
  }

  /* ───────────────────────── 12. Drug PK/PD — Targeted (ADC & PARPi) ─────── */
  subgraph cluster_targeted {
    label="12. Drug PK/PD — Mesothelin ADC & BAP1-Synthetic-Lethal PARP Inhibition";
    style="filled,rounded"; color="#5c6370"; fillcolor="#f5e6ff"; fontsize=12;
    Anetumab_PK [label="Anetumab ravtansine IV\n(anti-mesothelin ADC,\nDM4-maytansinoid payload)"];
    ADC_Internal [label="Mesothelin-mediated\nADC internalization"];
    Tubulin_Disrupt [label="DM4 tubulin\npolymerization inhibition"];
    Rucaparib_PK [label="Rucaparib PO\n(PARP1/2 inhibitor,\nBAP1/BRCA1-deficient MiST1)"];
    PARP_Trap   [label="PARP-DNA trapping at\nunrepaired SSBs"];
    Synthetic_Lethal [label="Synthetic lethality in\nHR-deficient (BAP1-mut) cells"];
    Mesothelin_Expr -> ADC_Internal;
    Anetumab_PK -> ADC_Internal -> Tubulin_Disrupt -> Cytotoxic_Death;
    Rucaparib_PK -> PARP_Trap;
    HR_Repair_Def -> Synthetic_Lethal; PARP_Trap -> Synthetic_Lethal -> Cytotoxic_Death;
  }

  /* ───────────────────────── 13. Non-Drug Interventions ──────────────────── */
  subgraph cluster_nondrug {
    label="13. Surgery, Radiotherapy, TTFields & Pleurodesis";
    style="filled,rounded"; color="#5c6370"; fillcolor="#fff0f5"; fontsize=12;
    EPP_Surgery [label="Extrapleural\npneumonectomy (EPP)"];
    PD_Surgery  [label="(Extended) Pleurectomy/\ndecortication (P/D)"];
    Hemithoracic_RT [label="Hemithoracic\nradiotherapy (adjuvant/palliative)"];
    ProcedureTract_RT [label="Prophylactic tract\nirradiation (seeding prevention)"];
    TTFields_Therapy [label="Tumor-Treating Fields\n(150 kHz, NovoTTF-100L)"];
    Mitotic_Disrupt [label="Antimitotic spindle/\nseptin disruption (TTFields)"];
    Talc_Pleurodesis [label="Talc slurry/\nVATS pleurodesis"];
    Surgical_Morbidity [label="Perioperative morbidity/\nmortality (EPP > P/D)"];
    EPP_Surgery -> Pleural_Rind [color="#8a6d3b", style=dashed, label="macroscopic\nresection"];
    PD_Surgery -> Pleural_Rind [color="#8a6d3b", style=dashed];
    EPP_Surgery -> Surgical_Morbidity; PD_Surgery -> Surgical_Morbidity [style=dashed, label="lower than EPP"];
    Hemithoracic_RT -> DNA_Crosslink [style=dashed, label="radiation-induced\nDSBs"];
    ProcedureTract_RT -> ChestWall_Inv [style=dashed, label="prevents\nseeding"];
    TTFields_Therapy -> Mitotic_Disrupt -> Cytotoxic_Death;
    Talc_Pleurodesis -> Pleural_Effusion [color="#1f6feb", style=dashed, label="↓ recurrence"];
  }

  /* ───────────────────────── 14. Clinical Endpoints & Biomarkers ─────────── */
  subgraph cluster_endpoint {
    label="14. Clinical Endpoints & Biomarkers";
    style="filled,rounded"; color="#5c6370"; fillcolor="#f0fff4"; fontsize=12;
    Tumor_Volume [label="Tumor volume\n(modified RECIST for\nmesothelioma)"];
    SMRP_Biomarker [label="Serum soluble mesothelin-\nrelated peptide (SMRP)"];
    Fibulin3_Biomarker [label="Plasma/effusion\nfibulin-3"];
    ORR         [label="Objective response\nrate (ORR)"];
    PFS         [label="Progression-free\nsurvival (PFS)"];
    OS          [label="Overall survival\n(OS)"];
    QoL_EORTC   [label="QoL (EORTC QLQ-C30/\nLC13), dyspnea/pain scores"];
    Pleural_Rind -> Tumor_Volume; Mesothelin_Expr -> SMRP_Biomarker;
    Tumor_Volume -> SMRP_Biomarker [style=dashed, label="correlates"];
    Tumor_Volume -> Fibulin3_Biomarker [style=dashed];
    Tumor_Volume -> ORR; Tumor_Volume -> PFS;
    Distant_Met -> OS; ECOG_PS -> OS; TNM_Stage -> OS;
    PFS -> OS [style=dashed];
    Dyspnea -> QoL_EORTC; ChestPain -> QoL_EORTC; Surgical_Morbidity -> QoL_EORTC [style=dashed];
    irAE -> QoL_EORTC [style=dashed]; Nephrotox -> QoL_EORTC [style=dashed];
  }
}
