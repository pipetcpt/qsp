digraph CSU_QSP {

  graph [
    label="Chronic Spontaneous Urticaria (CSU) — Quantitative Systems Pharmacology Map\nMast Cell Biology · IgE/FcεRI · Cytokines · Drug PK/PD · Clinical Endpoints"
    fontsize=22 fontname="Helvetica-Bold"
    bgcolor="#FDFCFA"
    pad=1.0 splines=ortho nodesep=0.30 ranksep=0.50
    compound=true
  ]

  node [fontname="Helvetica" fontsize=9 style="filled,rounded" shape=box width=1.3 height=0.38]
  edge [fontname="Helvetica" fontsize=7 arrowsize=0.6]

  /* ═══════════════════════════════════════════════════
     CLUSTER 1: Disease Triggers & Autoimmune Initiation
     ═══════════════════════════════════════════════════ */
  subgraph cluster_TRG {
    label="Disease Triggers & Autoimmune Initiation"
    style="filled,rounded" color="#6E2C00" fillcolor="#FEF9E7" fontcolor="#6E2C00" fontsize=13 fontname="Helvetica-Bold"

    Autoantigen    [label="Autoantigen\n(unknown)" fillcolor="#F8C471"]
    Anti_IgE_Ab    [label="IgG anti-IgE\n(Type IIb autoAb)" fillcolor="#F39C12" fontcolor=white]
    Anti_FceRI_Ab  [label="IgG anti-FcεRI\n(Type IIb autoAb)" fillcolor="#E67E22" fontcolor=white]
    IgG_Complement [label="IgG–Complement\nActivation" fillcolor="#FAD7A0"]
    C5a            [label="Complement C5a\n(anaphylatoxin)" fillcolor="#FAD7A0"]
    C3a            [label="Complement C3a" fillcolor="#FDEBD0"]
    Physical_trig  [label="Physical Triggers\n(dermographism, pressure\ncold, heat, exercise)" fillcolor="#D5F5E3"]
    Emotional_str  [label="Emotional Stress\n(CRH pathway)" fillcolor="#FADBD8"]
    Coagulation    [label="Coagulation\nActivation" fillcolor="#F9EBEA"]
    Thrombin       [label="Thrombin\n(serine protease)" fillcolor="#E74C3C" fontcolor=white]
    Tissue_factor  [label="Tissue Factor\n(extrinsic pathway)" fillcolor="#F1948A"]
    D_dimer        [label="D-dimer\n(biomarker)" fillcolor="#F5CBA7"]
    PAR1           [label="PAR-1 Receptor\n(thrombin receptor)" fillcolor="#F0D9B5"]
    Kinin_pathway  [label="Bradykinin\nKallikrein-Kinin" fillcolor="#FAD7A0"]
    MRGPRX2        [label="MRGPRX2\n(pseudo-allergic receptor)" fillcolor="#E59866"]
    Substance_P    [label="Substance P\n(neuropeptide)" fillcolor="#F0B27A"]
    VIP            [label="VIP\n(vasoactive intestinal\npeptide)" fillcolor="#F5CBA7"]
  }

  /* ═══════════════════════════════════════════════════
     CLUSTER 2: IgE & FcεRI Pathway
     ═══════════════════════════════════════════════════ */
  subgraph cluster_IGE {
    label="IgE & FcεRI Signalling Pathway"
    style="filled,rounded" color="#1A5276" fillcolor="#EBF5FB" fontcolor="#1A5276" fontsize=13 fontname="Helvetica-Bold"

    IgE_free       [label="Free IgE\n(serum, pg/mL)" fillcolor="#AED6F1"]
    IgE_bound      [label="FcεRI-bound IgE\n(mast cell surface)" fillcolor="#2E86C1" fontcolor=white]
    FceRI          [label="FcεRI\n(high-affinity\nIgE receptor)" fillcolor="#1A5276" fontcolor=white shape=diamond]
    IgE_crosslink  [label="IgE\nCrosslinking\n(antigen bridge)" fillcolor="#E74C3C" fontcolor=white]
    Lyn_kinase     [label="Lyn Kinase\n(src-family)" fillcolor="#85C1E9" shape=diamond]
    Syk_kinase     [label="Syk Kinase\n(non-receptor TK)" fillcolor="#5DADE2" shape=diamond fontcolor=white]
    BTK            [label="BTK\n(Bruton's TK)" fillcolor="#2874A6" shape=diamond fontcolor=white]
    PLCg           [label="PLCγ\n(phospholipase Cγ)" fillcolor="#AED6F1" shape=diamond]
    IP3            [label="IP₃\n(inositol-1,4,5-P₃)" fillcolor="#D6EAF8"]
    DAG            [label="DAG\n(diacylglycerol)" fillcolor="#D6EAF8"]
    Ca2_flux       [label="Ca²⁺ Flux\n(intracellular rise)" fillcolor="#85C1E9"]
    PKC            [label="PKC\n(protein kinase C)" fillcolor="#5DADE2" shape=diamond]
    NFAT           [label="NFAT\n(transcription factor)" fillcolor="#2E86C1" shape=diamond fontcolor=white]
    NF_kB_MC       [label="NF-κB\n(mast cell)" fillcolor="#1A5276" shape=diamond fontcolor=white]
    PI3K_MC        [label="PI3K\n(mast cell)" fillcolor="#7FB3D3" shape=diamond]
    MAPK_MC        [label="MAPK / p38\n(mast cell)" fillcolor="#7FB3D3" shape=diamond]
    SCF            [label="SCF\n(stem cell factor / c-Kit L)" fillcolor="#A9DFBF"]
    c_Kit          [label="c-Kit (CD117)\n(SCF receptor)" fillcolor="#58D68D" shape=diamond]
    IL33_R         [label="ST2 (IL-33R)\n(alarmin receptor)" fillcolor="#A9DFBF"]
    TSLPR          [label="TSLPR\n(TSLP receptor)" fillcolor="#76D7C4"]
  }

  /* ═══════════════════════════════════════════════════
     CLUSTER 3: Mast Cell Biology
     ═══════════════════════════════════════════════════ */
  subgraph cluster_MC {
    label="Mast Cell Biology"
    style="filled,rounded" color="#7B241C" fillcolor="#FDEDEC" fontcolor="#7B241C" fontsize=13 fontname="Helvetica-Bold"

    MC_precursor   [label="Mast Cell\nPrecursor (CD34+)" fillcolor="#FAD7A0"]
    MC_resting     [label="Resting\nMast Cell" fillcolor="#E59866"]
    MC_primed      [label="IgE-Primed\nMast Cell" fillcolor="#D35400" fontcolor=white]
    MC_activated   [label="Activated/\nDegranulating\nMast Cell" fillcolor="#922B21" fontcolor=white]
    MC_exhausted   [label="Refractory/\nExhausted MC" fillcolor="#CD6155"]
    Granule_preform[label="Preformed Granule\nMediator Pool" fillcolor="#F5B7B1"]
    Exocytosis     [label="Degranulation\n(exocytosis)" fillcolor="#E74C3C" fontcolor=white]
    Arachidonic_AA [label="Arachidonic Acid\n(membrane PL)" fillcolor="#F9EBEA"]
    COX1_MC        [label="COX-1\n(constitutive)" fillcolor="#FAD7A0"]
    COX2_MC        [label="COX-2\n(inducible)" fillcolor="#F39C12"]
    LOX5           [label="5-LOX\n(leukotriene pathway)" fillcolor="#E67E22" fontcolor=white]
    FLAP           [label="FLAP\n(5-LOX activating prot)" fillcolor="#FAD7A0"]
  }

  /* ═══════════════════════════════════════════════════
     CLUSTER 4: Mast Cell Mediators
     ═══════════════════════════════════════════════════ */
  subgraph cluster_MED {
    label="Mast Cell Mediators & Biomarkers"
    style="filled,rounded" color="#1B2631" fillcolor="#F2F3F4" fontcolor="#1B2631" fontsize=13 fontname="Helvetica-Bold"

    Histamine      [label="Histamine\n(skin/plasma)" fillcolor="#2C3E50" fontcolor=white]
    Tryptase       [label="β-Tryptase\n(serum biomarker)" fillcolor="#34495E" fontcolor=white]
    Chymase        [label="Chymase\n(enzyme)" fillcolor="#566573"]
    Heparin        [label="Heparin\n(anticoagulant)" fillcolor="#808B96"]
    PGD2           [label="PGD₂\n(prostaglandin D2)" fillcolor="#AAB7B8"]
    TXA2           [label="TXA₂\n(thromboxane)" fillcolor="#BDC3C7"]
    LTC4           [label="LTC₄\n(leukotriene C4)" fillcolor="#E74C3C" fontcolor=white]
    LTD4           [label="LTD₄\n(leukotriene D4)" fillcolor="#CB4335" fontcolor=white]
    LTE4           [label="LTE₄\n(leukotriene E4)" fillcolor="#CD6155"]
    CysLT_R        [label="CysLT₁/₂R\n(cysteinyl-LT receptor)" fillcolor="#F5B7B1"]
    TNF_MC         [label="TNF-α\n(mast cell-derived)" fillcolor="#E74C3C" fontcolor=white]
    VEGF_MC        [label="VEGF\n(angiogenic factor)" fillcolor="#F1948A"]
    PAF_MC         [label="PAF\n(platelet activ factor)" fillcolor="#FAD7A0"]
    Carboxypeptidase[label="Carboxypeptidase A\n(matrix enzyme)" fillcolor="#D5D8DC"]
  }

  /* ═══════════════════════════════════════════════════
     CLUSTER 5: Cytokine Network & Th2 Polarisation
     ═══════════════════════════════════════════════════ */
  subgraph cluster_CYT {
    label="Cytokine Network & Type-2 Inflammation"
    style="filled,rounded" color="#0B5345" fillcolor="#E8F8F5" fontcolor="#0B5345" fontsize=13 fontname="Helvetica-Bold"

    IL4            [label="IL-4\n(Th2 cytokine)" fillcolor="#2ECC71" fontcolor=white]
    IL13           [label="IL-13\n(Th2 cytokine)" fillcolor="#27AE60" fontcolor=white]
    IL31           [label="IL-31\n(pruritus driver)" fillcolor="#1E8449" fontcolor=white]
    IL33           [label="IL-33\n(alarmin)" fillcolor="#82E0AA"]
    TSLP           [label="TSLP\n(thymic stromal LP)" fillcolor="#A9DFBF"]
    IL25           [label="IL-25 (IL-17E)\n(type-2 alarmin)" fillcolor="#A3E4D7"]
    IL5            [label="IL-5\n(eosinophil poiesis)" fillcolor="#76D7C4"]
    IL6_skin       [label="IL-6\n(skin/systemic)" fillcolor="#E74C3C" fontcolor=white]
    IL8_CXCL8      [label="IL-8 (CXCL8)\n(neutrophil chemoattract)" fillcolor="#AED6F1"]
    CCL5_RANTES    [label="CCL5 (RANTES)\n(eosinophil recruit)" fillcolor="#85C1E9"]
    CCL11_eotaxin  [label="CCL11 (Eotaxin-1)\n(eosinophil recruit)" fillcolor="#7FB3D3"]
    CCL24_eotaxin2 [label="CCL24 (Eotaxin-2)\n(eosinophil recruit)" fillcolor="#7FB3D3"]
    CX3CL1         [label="CX3CL1\n(fractalkine/recruit)" fillcolor="#D6EAF8"]
    CXCL10         [label="CXCL10 (IP-10)\n(lymphocyte recruit)" fillcolor="#D6EAF8"]
    IFN_g_skin     [label="IFN-γ\n(Th1 — minority)" fillcolor="#5D6D7E"]
    IL4Ra          [label="IL-4Rα\n(shared receptor)" fillcolor="#A9DFBF" shape=diamond]
    JAK1_skin      [label="JAK1\n(skin)" fillcolor="#58D68D" shape=diamond]
    JAK2_skin      [label="JAK2\n(skin)" fillcolor="#58D68D" shape=diamond]
    STAT6_skin     [label="STAT6\n(IL-4/13 signal)" fillcolor="#2ECC71" shape=diamond fontcolor=white]
    STAT3_skin     [label="STAT3\n(IL-6 signal)" fillcolor="#27AE60" shape=diamond fontcolor=white]
    JAK1_IL31      [label="JAK1\n(IL-31R path)" fillcolor="#A9DFBF" shape=diamond]
    TYK2_skin      [label="TYK2\n(skin)" fillcolor="#A9DFBF" shape=diamond]
    IL31RA         [label="IL-31Rα\n(itch receptor)" fillcolor="#76D7C4" shape=diamond]
    OSM_R          [label="OSMRβ\n(IL-31 receptor β)" fillcolor="#A2D9CE" shape=diamond]
  }

  /* ═══════════════════════════════════════════════════
     CLUSTER 6: Cellular Skin Microenvironment
     ═══════════════════════════════════════════════════ */
  subgraph cluster_CELL {
    label="Cellular Skin Microenvironment"
    style="filled,rounded" color="#4A235A" fillcolor="#F5EEF8" fontcolor="#4A235A" fontsize=13 fontname="Helvetica-Bold"

    Basophil_rest  [label="Resting\nBasophil" fillcolor="#D7BDE2"]
    Basophil_act   [label="Activated\nBasophil" fillcolor="#8E44AD" fontcolor=white]
    Eosinophil     [label="Eosinophil\n(tissue)" fillcolor="#9B59B6" fontcolor=white]
    ILC2           [label="ILC2\n(innate lymphoid cell)" fillcolor="#C39BD3"]
    Th2_cell       [label="Th2 Cell\n(CRTH2+)" fillcolor="#A569BD"]
    Treg_skin      [label="Treg\n(skin suppressor)" fillcolor="#76D7C4"]
    DC_skin        [label="Plasmacytoid DC\n(pDC)" fillcolor="#D2B4DE"]
    NK_skin        [label="NK Cell\n(skin)" fillcolor="#BB8FCE"]
    Keratinocyte   [label="Keratinocyte\n(epidermal)" fillcolor="#FAD7A0"]
    Endothelial    [label="Endothelial Cell\n(dermal vessel)" fillcolor="#AED6F1"]
    Fibroblast_skin[label="Dermal\nFibroblast" fillcolor="#F5CBA7"]
    Neutrophil_skin[label="Neutrophil\n(recruited)" fillcolor="#AED6F1"]
    CutSensor_neuron[label="Cutaneous\nSensory Neuron\n(C-fibre)" fillcolor="#FDEBD0"]
    TRPV1          [label="TRPV1\n(pain/itch channel)" fillcolor="#FAD7A0" shape=diamond]
    DP2_CRTH2      [label="DP2/CRTH2\n(PGD2 receptor on Th2)" fillcolor="#C39BD3" shape=diamond]
    EPX            [label="Eosinophil\nPeroxidase (EPX)" fillcolor="#9B59B6" fontcolor=white]
    MBP            [label="Major Basic\nProtein (MBP)" fillcolor="#8E44AD" fontcolor=white]
    Platelet       [label="Platelet\n(PAF/serotonin)" fillcolor="#FAD7A0"]
  }

  /* ═══════════════════════════════════════════════════
     CLUSTER 7: Skin & Vascular Effects
     ═══════════════════════════════════════════════════ */
  subgraph cluster_SKIN {
    label="Skin & Vascular Pathophysiology"
    style="filled,rounded" color="#784212" fillcolor="#FDF2E9" fontcolor="#784212" fontsize=13 fontname="Helvetica-Bold"

    H1R_skin       [label="H1 Receptor\n(skin/sensory neuron)" fillcolor="#F0D9B5" shape=diamond]
    H2R_skin       [label="H2 Receptor\n(gastric/vascular)" fillcolor="#E8DAEF" shape=diamond]
    H4R_immune     [label="H4 Receptor\n(immune cells, itch)" fillcolor="#D7BDE2" shape=diamond]
    Vasodilation   [label="Vasodilation\n(arteriole relaxation)" fillcolor="#F1948A"]
    Vasc_perm      [label="Vascular\nPermeability ↑" fillcolor="#E74C3C" fontcolor=white]
    Plasma_leak    [label="Plasma Extravasation\n(oedema formation)" fillcolor="#CB4335" fontcolor=white]
    Wheal          [label="Wheal\n(raised lesion)" fillcolor="#922B21" fontcolor=white shape=ellipse]
    Flare          [label="Flare\n(erythema ring)" fillcolor="#A93226" fontcolor=white shape=ellipse]
    Angioedema     [label="Angioedema\n(deep dermis/subcutis)" fillcolor="#7B241C" fontcolor=white shape=ellipse]
    Pruritus       [label="Pruritus\n(itch sensation)" fillcolor="#D35400" fontcolor=white shape=ellipse]
    Itch_signal    [label="Itch-Specific\nAδ/C Fibres" fillcolor="#FAD7A0"]
    Scratch_injury [label="Scratch-Induced\nBarrier Disruption" fillcolor="#F5CBA7"]
    Neuroinflam    [label="Neurogenic\nInflammation" fillcolor="#E59866"]
    Wheal_resolve  [label="Wheal Resolution\n(<24h)" fillcolor="#A9DFBF"]
    Anti_H         [label="Histaminase\n(DAO enzyme)" fillcolor="#D5F5E3"]
    NW_axis        [label="Axon Reflex\n(flare)" fillcolor="#F0B27A"]
  }

  /* ═══════════════════════════════════════════════════
     CLUSTER 8: Drug PK & Mechanisms
     ═══════════════════════════════════════════════════ */
  subgraph cluster_PK {
    label="Drug PK & Pharmacological Mechanisms"
    style="filled,rounded" color="#154360" fillcolor="#EAF2FF" fontcolor="#154360" fontsize=13 fontname="Helvetica-Bold"

    Cetirizine_GI  [label="Cetirizine\nGI (oral)" fillcolor="#D6EAF8"]
    Cetirizine_C   [label="Cetirizine\nPlasma (central)" fillcolor="#AED6F1"]
    Bilastine_GI   [label="Bilastine\nGI (oral)" fillcolor="#D6EAF8"]
    Bilastine_C    [label="Bilastine\nPlasma (central)" fillcolor="#85C1E9"]
    Omalizumab_dep [label="Omalizumab\nSC Depot" fillcolor="#2E86C1" fontcolor=white]
    Omalizumab_C   [label="Omalizumab\nPlasma (central)" fillcolor="#1A5276" fontcolor=white]
    Omalizumab_IgE [label="Omalizumab–IgE\nComplex" fillcolor="#154360" fontcolor=white]
    Ligelizumab_dep[label="Ligelizumab (exptl)\nSC Depot" fillcolor="#5DADE2"]
    Ligelizumab_C  [label="Ligelizumab\nPlasma" fillcolor="#2E86C1" fontcolor=white]
    Dupilumab_dep  [label="Dupilumab\nSC Depot" fillcolor="#8E44AD" fontcolor=white]
    Dupilumab_C    [label="Dupilumab\nPlasma (central)" fillcolor="#6C3483" fontcolor=white]
    BTKi_GI        [label="BTK inhibitor (exptl)\nGI" fillcolor="#D5D8DC"]
    BTKi_C         [label="BTK inhibitor\nPlasma" fillcolor="#AAB7B8"]
    Cyclosporine_GI[label="Cyclosporine\nGI" fillcolor="#D5D8DC"]
    Cyclosporine_C [label="Cyclosporine\nPlasma" fillcolor="#808B96"]
    Drug_Clearance [label="Drug\nClearance" fillcolor="#5D6D7E" fontcolor=white shape=ellipse]

    Cetirizine_MoA  [label="Cetirizine/Bilastine\n→ H1R inverse agonist\n(antihistamine)" fillcolor="#AED6F1"]
    Omalizumab_MoA  [label="Omalizumab\n→ binds free IgE\n(prevents FcεRI loading)" fillcolor="#1F618D" fontcolor=white]
    Ligelizumab_MoA [label="Ligelizumab\n→ higher affinity\nanti-IgE mAb" fillcolor="#2E86C1" fontcolor=white]
    Dupilumab_MoA   [label="Dupilumab\n→ IL-4Rα blockade\n(↓IL-4 & IL-13 signal)" fillcolor="#6C3483" fontcolor=white]
    BTKi_MoA        [label="BTK inhibitor\n→ ↓ Syk/BTK\n(mast cell signal)" fillcolor="#85929E"]
    Cyclosporine_MoA[label="Cyclosporine\n→ calcineurin inhib\n(↓ NFAT, mast cell)" fillcolor="#717D7E"]
    NSAIDs_urticaria[label="NSAIDs\n(may exacerbate CSU\nvia COX-1 inhib)" fillcolor="#F39C12"]
  }

  /* ═══════════════════════════════════════════════════
     CLUSTER 9: Clinical Endpoints & Biomarkers
     ═══════════════════════════════════════════════════ */
  subgraph cluster_CE {
    label="Clinical Endpoints & Biomarkers"
    style="filled,rounded" color="#0E6655" fillcolor="#E9F7EF" fontcolor="#0E6655" fontsize=13 fontname="Helvetica-Bold"

    UAS7           [label="UAS7\n(Urticaria Activity Score)\n≤6=controlled" fillcolor="#1E8449" fontcolor=white shape=ellipse]
    ISS7           [label="ISS7\n(Itch Severity Score)" fillcolor="#27AE60" fontcolor=white shape=ellipse]
    HSS7           [label="HSS7\n(Hive Severity Score)" fillcolor="#2ECC71" fontcolor=white shape=ellipse]
    CU_Q2oL        [label="CU-Q2oL\n(Quality of Life)" fillcolor="#52BE80" shape=ellipse]
    AAS7           [label="AAS7\n(Angioedema Activity\nScore)" fillcolor="#58D68D" shape=ellipse]
    DLQI           [label="DLQI\n(Dermatology QoL)" fillcolor="#82E0AA"]
    Wheal_count    [label="Wheal Count\n(#/day)" fillcolor="#A9DFBF"]
    Wheal_size     [label="Wheal Size\n(diameter, mm)" fillcolor="#A9DFBF"]
    IgE_serum      [label="Total Serum IgE\n(kU/L)" fillcolor="#D5F5E3"]
    Tryptase_serum [label="Serum β-Tryptase\n(ng/mL)" fillcolor="#D5F5E3"]
    Eosinophil_CBC [label="Eosinophil Count\n(blood differential)" fillcolor="#A3E4D7"]
    Basophil_CBC   [label="Basophil Count\n(blood)" fillcolor="#A9DFBF"]
    BAT_test       [label="Basophil Activation\nTest (CD63+/CD203c+)" fillcolor="#76D7C4"]
    CRP_urticaria  [label="CRP\n(systemic inflammation)" fillcolor="#D5F5E3"]
    D_dimer_lab    [label="D-dimer\n(coagulation biomarker)" fillcolor="#F9EBEA"]
    Skin_biopsy    [label="Skin Biopsy\n(eos/mast infiltrate)" fillcolor="#FDEBD0"]
    WBC_diff       [label="WBC Differential\n(neutrophil, eos, baso)" fillcolor="#D5D8DC"]
    AntiTPO        [label="Anti-TPO Ab\n(thyroid autoimmunity)" fillcolor="#F5CBA7"]
    ASST           [label="ASST\n(Autologous Serum\nSkin Test)" fillcolor="#FAD7A0"]
  }

  /* ═══════════════════════════════════════════════════
     EDGES: Triggers → IgE / FcεRI
     ═══════════════════════════════════════════════════ */
  Autoantigen   -> Anti_IgE_Ab    [label="generates" color="#E74C3C"]
  Autoantigen   -> Anti_FceRI_Ab  [label="generates" color="#E74C3C"]
  Anti_IgE_Ab   -> IgE_free       [label="cross-links via\nIgE receptor" color="#E74C3C"]
  Anti_FceRI_Ab -> FceRI          [label="binds & activates" color="#E74C3C"]
  Anti_IgE_Ab   -> IgG_Complement [label="activates" color="#E74C3C"]
  Anti_FceRI_Ab -> IgG_Complement [label="activates" color="#E74C3C"]
  IgG_Complement -> C5a           [label="generates" color="#E74C3C"]
  IgG_Complement -> C3a           [label="generates" color="#E74C3C"]
  C5a           -> MC_resting     [label="activates" color="#E74C3C"]
  C3a           -> MC_resting     [label="activates" color="#E74C3C"]
  Physical_trig -> MC_resting     [label="triggers" color="#E74C3C"]
  Physical_trig -> Substance_P    [label="releases" color="#F39C12"]
  Emotional_str -> Substance_P    [label="releases (CRH)" color="#F39C12"]
  Substance_P   -> MRGPRX2        [label="binds" color="#E74C3C"]
  MRGPRX2       -> MC_activated   [label="pseudo-allergic\nactivation" color="#E74C3C"]
  VIP           -> MC_resting     [label="activates" color="#E74C3C"]
  Coagulation   -> Thrombin       [label="generates" color="#E74C3C"]
  Tissue_factor -> Coagulation    [label="initiates" color="#E74C3C"]
  Thrombin      -> PAR1           [label="cleaves/activates" color="#E74C3C"]
  Thrombin      -> D_dimer        [label="fibrin → D-dimer" color="#E74C3C"]
  PAR1          -> MC_activated   [label="activates mast cells" color="#E74C3C"]
  Kinin_pathway -> Angioedema     [label="bradykinin →\nslow angioedema" color="#E74C3C"]

  /* ═══════════════════════════════════════════════════
     EDGES: IgE / FcεRI Signalling
     ═══════════════════════════════════════════════════ */
  IgE_free      -> FceRI          [label="binds (Kd~1nM)" color="#2E86C1"]
  FceRI         -> IgE_bound      [label="forms" color="#2E86C1"]
  IgE_bound     -> IgE_crosslink  [label="antigen\ncrosslinks" color="#E74C3C"]
  IgE_crosslink -> Lyn_kinase     [label="phosphorylates\nITAMs" color="#E74C3C"]
  Lyn_kinase    -> Syk_kinase     [label="activates" color="#E74C3C"]
  Syk_kinase    -> BTK            [label="activates" color="#E74C3C"]
  Syk_kinase    -> PLCg           [label="activates" color="#E74C3C"]
  BTK           -> PLCg           [label="activates" color="#E74C3C"]
  PLCg          -> IP3            [label="generates" color="#E74C3C"]
  PLCg          -> DAG            [label="generates" color="#E74C3C"]
  IP3           -> Ca2_flux       [label="ER Ca²⁺\nrelease" color="#E74C3C"]
  Ca2_flux      -> Exocytosis     [label="triggers" color="#E74C3C"]
  Ca2_flux      -> NFAT           [label="activates" color="#E74C3C"]
  DAG           -> PKC            [label="activates" color="#E74C3C"]
  PKC           -> NF_kB_MC       [label="activates" color="#E74C3C"]
  NF_kB_MC      -> TNF_MC         [label="transcribes" color="#E74C3C"]
  NF_kB_MC      -> IL6_skin       [label="transcribes" color="#E74C3C"]
  NFAT          -> IL4            [label="transcribes" color="#27AE60"]
  NFAT          -> IL13           [label="transcribes" color="#27AE60"]
  MAPK_MC       -> NF_kB_MC       [label="activates"]
  PI3K_MC       -> MAPK_MC        [label="activates"]
  Syk_kinase    -> PI3K_MC        [label="activates"]
  SCF           -> c_Kit          [label="binds" color="#27AE60"]
  c_Kit         -> MC_resting     [label="survival/proliferation" color="#27AE60"]
  IL33          -> IL33_R         [label="binds" color="#82E0AA"]
  IL33_R        -> MC_primed      [label="sensitises" color="#82E0AA"]
  TSLP          -> TSLPR          [label="binds" color="#76D7C4"]
  TSLPR         -> MC_primed      [label="primes" color="#76D7C4"]

  /* ═══════════════════════════════════════════════════
     EDGES: Mast Cell Biology
     ═══════════════════════════════════════════════════ */
  MC_precursor  -> MC_resting     [label="differentiation\n(SCF/IL-3)" color="#27AE60"]
  MC_resting    -> MC_primed      [label="IgE loading\n(sensitisation)" color="#2E86C1"]
  MC_primed     -> MC_activated   [label="trigger\n(crosslink/C5a/PAR1)" color="#E74C3C"]
  MC_activated  -> Exocytosis     [label="degranulates" color="#E74C3C"]
  MC_activated  -> MC_exhausted   [label="refractory state" color="#5D6D7E"]
  MC_exhausted  -> MC_resting     [label="recovery\n(hours)" color="#A9DFBF"]
  Exocytosis    -> Granule_preform [label="releases" color="#E74C3C"]
  Granule_preform -> Histamine    [label="Histamine\n(preformed)" color="#2C3E50"]
  Granule_preform -> Tryptase     [label="β-Tryptase\n(preformed)" color="#34495E"]
  Granule_preform -> Heparin      [label="Heparin\n(preformed)" color="#808B96"]
  Granule_preform -> Chymase      [label="Chymase\n(preformed)" color="#566573"]
  Granule_preform -> Carboxypeptidase [label="CPA\n(preformed)" color="#D5D8DC"]
  MC_activated  -> Arachidonic_AA [label="membrane\nphospholipid\ncleavage" color="#E67E22"]
  Arachidonic_AA -> COX1_MC      [label="COX substrate"]
  Arachidonic_AA -> COX2_MC      [label="COX substrate"]
  Arachidonic_AA -> LOX5         [label="5-LOX substrate" color="#E67E22"]
  COX1_MC       -> PGD2          [label="synthesises" color="#AAB7B8"]
  COX2_MC       -> TXA2          [label="synthesises" color="#BDC3C7"]
  LOX5          -> FLAP          [label="needs" color="#E67E22"]
  FLAP          -> LTC4          [label="synthesises" color="#E74C3C"]
  LTC4          -> LTD4          [label="converted" color="#CB4335"]
  LTD4          -> LTE4          [label="converted" color="#CD6155"]
  LTC4          -> CysLT_R       [label="binds" color="#E74C3C"]
  LTD4          -> CysLT_R       [label="binds" color="#E74C3C"]
  CysLT_R       -> Vasc_perm     [label="↑permeability" color="#E74C3C"]
  MC_activated  -> PAF_MC        [label="secretes" color="#FAD7A0"]
  MC_activated  -> VEGF_MC       [label="secretes" color="#F1948A"]
  MC_activated  -> TNF_MC        [label="secretes" color="#E74C3C"]
  VEGF_MC       -> Angiogenesis  [label="stimulates" style=dashed]

  /* ═══════════════════════════════════════════════════
     EDGES: Cytokine Network
     ═══════════════════════════════════════════════════ */
  IL4           -> IL4Ra         [label="binds" color="#27AE60"]
  IL13          -> IL4Ra         [label="binds (shared)" color="#27AE60"]
  IL4Ra         -> JAK1_skin     [label="activates" color="#27AE60"]
  JAK1_skin     -> STAT6_skin    [label="phosphorylates" color="#27AE60"]
  STAT6_skin    -> IgE_free      [label="↑ IgE production\n(B cell class switch)" color="#27AE60"]
  STAT6_skin    -> IL4           [label="+ feedback" color="#27AE60" style=dashed]
  IL6_skin      -> JAK2_skin     [label="via gp130" color="#E74C3C"]
  JAK2_skin     -> STAT3_skin    [label="p→STAT3" color="#E74C3C"]
  IL31          -> IL31RA        [label="binds" color="#1E8449"]
  IL31RA        -> OSM_R         [label="heterodimer with" color="#1E8449"]
  IL31RA        -> JAK1_IL31     [label="activates" color="#1E8449"]
  JAK1_IL31     -> Pruritus      [label="itch signal\n(dorsal root ganglion)" color="#D35400"]
  IL33          -> Th2_cell      [label="activates" color="#82E0AA"]
  IL33          -> ILC2          [label="activates" color="#82E0AA"]
  IL33          -> Basophil_rest [label="activates" color="#82E0AA"]
  TSLP          -> DC_skin       [label="activates\n(Th2-biasing)" color="#76D7C4"]
  TSLP          -> ILC2          [label="activates" color="#76D7C4"]
  IL25          -> ILC2          [label="activates" color="#A3E4D7"]
  ILC2          -> IL4           [label="secretes" color="#27AE60"]
  ILC2          -> IL13          [label="secretes" color="#27AE60"]
  ILC2          -> IL5           [label="secretes" color="#76D7C4"]
  Th2_cell      -> IL4           [label="secretes" color="#27AE60"]
  Th2_cell      -> IL13          [label="secretes" color="#27AE60"]
  Th2_cell      -> IL31          [label="secretes" color="#1E8449"]
  IL4           -> Th2_cell      [label="Th2 polarise" color="#27AE60"]
  IL5           -> Eosinophil    [label="differentiation\n& survival" color="#9B59B6"]
  CCL11_eotaxin -> Eosinophil    [label="chemotaxis" color="#9B59B6"]
  CCL24_eotaxin2 -> Eosinophil   [label="chemotaxis" color="#9B59B6"]
  Eosinophil    -> EPX           [label="releases" color="#9B59B6"]
  Eosinophil    -> MBP           [label="releases" color="#8E44AD"]
  EPX           -> MC_activated  [label="amplifies MC\nactivation" color="#9B59B6"]
  MBP           -> Keratinocyte  [label="cytotoxic\n(skin injury)" color="#8E44AD"]
  Basophil_rest -> Basophil_act  [label="IgE/IL-33 signal" color="#8E44AD"]
  Basophil_act  -> Histamine     [label="releases" color="#2C3E50"]
  Basophil_act  -> IL4           [label="secretes" color="#27AE60"]
  Keratinocyte  -> IL33          [label="secretes\n(barrier disruption)" color="#82E0AA"]
  Keratinocyte  -> TSLP          [label="secretes\n(irritation)" color="#76D7C4"]
  Keratinocyte  -> IL25          [label="secretes" color="#A3E4D7"]
  Scratch_injury -> Keratinocyte [label="barrier break\n→ alarmin release" color="#E74C3C"]
  TNF_MC        -> Endothelial   [label="activates" color="#E74C3C"]
  Endothelial   -> Vasc_perm     [label="regulated by\ncytokines" color="#E74C3C"]

  /* ═══════════════════════════════════════════════════
     EDGES: Skin Pathophysiology
     ═══════════════════════════════════════════════════ */
  Histamine     -> H1R_skin      [label="binds" color="#2C3E50"]
  Histamine     -> H2R_skin      [label="binds" color="#34495E"]
  Histamine     -> H4R_immune    [label="binds (itch)" color="#566573"]
  H1R_skin      -> Vasodilation  [label="↑ NO,\nvascular relaxation" color="#E74C3C"]
  H1R_skin      -> Pruritus      [label="itch\n(direct)" color="#D35400"]
  H1R_skin      -> Neuroinflam   [label="axon reflex" color="#E59866"]
  H2R_skin      -> Vasodilation  [label="cAMP-mediated" color="#E74C3C"]
  H4R_immune    -> Pruritus      [label="immune-mediated\nitch" color="#D35400"]
  H4R_immune    -> Eosinophil    [label="chemotaxis" color="#9B59B6"]
  Vasodilation  -> Vasc_perm     [label="leads to" color="#E74C3C"]
  Vasc_perm     -> Plasma_leak   [label="extravasation" color="#E74C3C"]
  Plasma_leak   -> Wheal         [label="forms" color="#922B21"]
  Plasma_leak   -> Angioedema    [label="deep tissue\nforms" color="#7B241C"]
  Neuroinflam   -> Flare         [label="axon reflex\n→ erythema" color="#A93226"]
  Neuroinflam   -> NW_axis       [label="via"]
  PGD2          -> DP2_CRTH2     [label="binds" color="#AAB7B8"]
  DP2_CRTH2     -> Th2_cell      [label="recruits/activates" color="#A569BD"]
  Pruritus      -> Scratch_injury [label="causes" color="#E74C3C"]
  Pruritus      -> Itch_signal   [label="via C-fibres" color="#D35400"]
  Itch_signal   -> TRPV1         [label="activates" color="#D35400"]
  TRPV1         -> Substance_P   [label="releases" color="#F39C12"]
  Anti_H        -> Histamine     [label="enzymatic\nbreakdown" color="#27AE60"]
  Wheal_resolve -> Wheal         [label="spontaneous\n(<24h)" color="#27AE60" style=dashed]
  PAF_MC        -> Platelet      [label="activates" color="#FAD7A0"]
  Platelet      -> Thrombin      [label="amplifies\ncoagulation" color="#E74C3C"]

  /* ═══════════════════════════════════════════════════
     EDGES: Drug PK
     ═══════════════════════════════════════════════════ */
  Cetirizine_GI  -> Cetirizine_C  [label="absorption\n(Tmax~1h, F>70%)" color="#154360"]
  Bilastine_GI   -> Bilastine_C   [label="absorption\n(Tmax~1.3h, F~61%)" color="#154360"]
  Omalizumab_dep -> Omalizumab_C  [label="SC abs\n(ka~0.006/h, F~62%)" color="#154360"]
  Ligelizumab_dep -> Ligelizumab_C [label="SC abs\n(F~79%)" color="#154360"]
  Dupilumab_dep  -> Dupilumab_C   [label="SC abs\n(ka~0.01/h, F~64%)" color="#154360"]
  Omalizumab_C   -> Omalizumab_IgE [label="binds free IgE\n(Kd~1nM)" color="#154360"]
  Cetirizine_C   -> Drug_Clearance [label="renal\n(67% unchanged)" color="#5D6D7E"]
  Bilastine_C    -> Drug_Clearance [label="biliary\n(hepatic met min)" color="#5D6D7E"]
  Omalizumab_C   -> Drug_Clearance [label="FcRn-mediated\ncat + TMDD" color="#5D6D7E"]
  Dupilumab_C    -> Drug_Clearance [label="target-mediated\n+ catabolism" color="#5D6D7E"]

  /* ═══════════════════════════════════════════════════
     EDGES: Drug Mechanisms → Targets
     ═══════════════════════════════════════════════════ */
  Cetirizine_C   -> Cetirizine_MoA [label="drives"]
  Bilastine_C    -> Cetirizine_MoA [label="drives"]
  Cetirizine_MoA -> H1R_skin       [label="inverse agonist\nblocks histamine" color="#27AE60" style=bold]
  Cetirizine_MoA -> H1R_skin       [label="↓ itch & wheal" color="#27AE60" style=dashed]

  Omalizumab_C   -> Omalizumab_MoA [label="drives"]
  Omalizumab_MoA -> IgE_free       [label="binds & sequesters\nfree IgE (ε-Fc)" color="#27AE60" style=bold]
  Omalizumab_MoA -> FceRI          [label="↓ FcεRI loading\n(downregulates receptor)" color="#27AE60" style=dashed]
  Omalizumab_IgE -> IgE_free       [label="complex\n(cleared)" color="#27AE60"]

  Ligelizumab_C  -> Ligelizumab_MoA [label="drives"]
  Ligelizumab_MoA -> IgE_free       [label="higher affinity anti-IgE" color="#27AE60" style=bold]

  Dupilumab_C    -> Dupilumab_MoA  [label="drives"]
  Dupilumab_MoA  -> IL4Ra          [label="blocks IL-4Rα\n(↓ IL-4 & IL-13 signal)" color="#27AE60" style=bold]
  Dupilumab_MoA  -> STAT6_skin     [label="↓ pSTAT6\n(↓ IgE production)" color="#27AE60" style=dashed]
  Dupilumab_MoA  -> IL13           [label="↓ IL-13 pathway" color="#27AE60" style=dashed]

  BTKi_C        -> BTKi_MoA        [label="drives"]
  BTKi_MoA      -> BTK             [label="inhibits\n(mast cell signal)" color="#27AE60" style=bold]
  BTKi_MoA      -> Syk_kinase      [label="↓ degranulation" color="#27AE60" style=dashed]

  Cyclosporine_C -> Cyclosporine_MoA [label="drives"]
  Cyclosporine_MoA -> NFAT          [label="calcineurin → ↓NFAT" color="#27AE60" style=bold]
  Cyclosporine_MoA -> MC_activated  [label="↓ mast cell\nactivation" color="#27AE60" style=dashed]

  NSAIDs_urticaria -> COX1_MC      [label="inhibits COX-1\n→ LTC4 shunting" color="#E74C3C" style=dashed]

  /* ═══════════════════════════════════════════════════
     EDGES: Clinical Endpoints
     ═══════════════════════════════════════════════════ */
  ISS7          -> UAS7           [label="component\n(0-21 pts)"]
  HSS7          -> UAS7           [label="component\n(0-21 pts)"]
