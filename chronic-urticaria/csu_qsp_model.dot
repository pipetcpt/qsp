  AAS7          -> CU_Q2oL        [label="drives QoL"]
  CU_Q2oL       -> DLQI           [label="component"]
  IgE_free      -> IgE_serum      [label="measured as" color="#AED6F1"]
  Tryptase      -> Tryptase_serum [label="measured as" color="#34495E"]
  Eosinophil    -> Eosinophil_CBC [label="blood count" color="#9B59B6"]
  Basophil_act  -> Basophil_CBC   [label="blood count"]
  Basophil_act  -> BAT_test       [label="CD63/CD203c\n↑ on activation"]
  D_dimer       -> D_dimer_lab    [label="biomarker\nmeasured"]
  Anti_IgE_Ab   -> ASST           [label="cause +ASST" color="#E74C3C"]
  Anti_FceRI_Ab -> ASST           [label="cause +ASST" color="#E74C3C"]
  Coagulation   -> D_dimer_lab    [label="↑ in severe CSU"]
  IL6_skin      -> CRP_urticaria  [label="↑ APR"]
}
