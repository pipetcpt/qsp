digraph glaucoma_qsp {

  // Global graph settings
  graph [
    label="Primary Open-Angle Glaucoma (POAG)\nQuantitative Systems Pharmacology Model\nv1.0 · 2026-06-27",
    fontname="Helvetica-Bold",
    fontsize=22,
    labelloc="t",
    bgcolor="#F5F7FA",
    rankdir=TB,
    splines=spline,
    nodesep=0.28,
    ranksep=0.55,
    pad=0.4,
    compound=true
  ];

  node [fontname="Helvetica", fontsize=8, style="filled,rounded", shape=box, margin="0.06,0.04"];
  edge [fontname="Helvetica", fontsize=7, arrowsize=0.7];

  // =====================================================================
  // CLUSTER 1: Genetic & Molecular Risk Factors
  // =====================================================================
  subgraph cluster_genetics {
    label="1. 유전·위험인자 (Genetic & Risk Factors)";
    style=filled; bgcolor="#EEF2FB"; color="#1A237E"; fontcolor="#1A237E"; fontsize=12;

    MYOC   [label="MYOC\n(Myocilin\nGln368Stop)", fillcolor="#BBDEFB"];
    OPTN   [label="OPTN\n(Optineurin\nE50K)", fillcolor="#BBDEFB"];
    WDR36  [label="WDR36\n(rRNA Processing)", fillcolor="#BBDEFB"];
    NTF4   [label="NTF4\n(Neurotrophin-4)", fillcolor="#BBDEFB"];
    ASB10  [label="ASB10\n(Ankyrin Repeat)", fillcolor="#BBDEFB"];
    CDKN2B [label="CDKN2B-AS1\nSNP rs4977756", fillcolor="#BBDEFB"];
    SIX1_SIX6 [label="SIX1/SIX6\nLocus (9p21)", fillcolor="#BBDEFB"];
    CAV1_CAV2  [label="CAV1/CAV2\nCaveolin Locus", fillcolor="#BBDEFB"];
    ABCA1  [label="ABCA1\nCholesterol\nTransport", fillcolor="#BBDEFB"];
    ELOVL5 [label="ELOVL5\nFA Elongase", fillcolor="#BBDEFB"];
    TMCO1  [label="TMCO1\nCa²⁺ Channel", fillcolor="#BBDEFB"];
    age_risk   [label="Age >40y\nRisk Factor", fillcolor="#E8EAF6"];
    family_hx  [label="Family History\n(3–9× risk)", fillcolor="#E8EAF6"];
    race_risk  [label="African American\n(4× risk)", fillcolor="#E8EAF6"];
    myopia_rf  [label="High Myopia\n(axial >26 mm)", fillcolor="#E8EAF6"];
    thin_cornea [label="Thin Cornea\n(CCT <555 μm)\nUnderestimates IOP", fillcolor="#FFCDD2"];
    disc_hem   [label="Disc Hemorrhage\n(Progression Risk)", fillcolor="#FFCDD2"];
    XFS_gene   [label="LOXL1 SNP\nPseudo-exfoliation\nSyndrome", fillcolor="#E8EAF6"];
    PDG_gene   [label="Pigment Dispersion\nGlaucoma Risk", fillcolor="#E8EAF6"];
  }

  // =====================================================================
  // CLUSTER 2: Ciliary Body & Aqueous Humor Production
  // =====================================================================
  subgraph cluster_ciliary {
    label="2. 모양체·방수 생성 (Ciliary Body & Aqueous Production)";
    style=filled; bgcolor="#E8F5E9"; color="#1B5E20"; fontcolor="#1B5E20"; fontsize=12;

    ciliary_epithelium [label="Non-Pigmented\nCiliary Epithelium\n(NPE)", fillcolor="#C8E6C9", shape=ellipse];
    Na_K_ATPase  [label="Na⁺/K⁺-ATPase\nActive Transport", fillcolor="#A5D6A7"];
    CA_II        [label="CA-II\n(Carbonic\nAnhydrase II)", fillcolor="#A5D6A7"];
    CA_IV        [label="CA-IV\n(Carbonic\nAnhydrase IV)", fillcolor="#A5D6A7"];
    bicarb_sec   [label="HCO₃⁻ / Na⁺\nSecretion", fillcolor="#C8E6C9"];
    AQP1         [label="AQP1\n(Aquaporin-1)\nWater Channel", fillcolor="#A5D6A7"];
    beta2_AR     [label="β₂-Adrenergic\nReceptor", fillcolor="#66BB6A"];
    cAMP_cil     [label="cAMP ↑\n(Ciliary)", fillcolor="#A5D6A7"];
    PKA_cil      [label="PKA\n(Ciliary\nActivation)", fillcolor="#A5D6A7"];
    alpha2_AR    [label="α₂-Adrenergic\nReceptor", fillcolor="#66BB6A"];
    Gi_cil       [label="Gᵢ Protein\n(Inhibitory)", fillcolor="#A5D6A7"];
    Gs_cil       [label="Gₛ Protein\n(Stimulatory)", fillcolor="#A5D6A7"];
    VEGF_cil     [label="VEGF\n(Blood-Aqueous\nBarrier)", fillcolor="#C8E6C9"];
    F_prod       [label="Aqueous\nProduction Rate\nF_prod = 2.5 μL/min", fillcolor="#2E7D32", fontcolor="white", shape=diamond, penwidth=2.5];
    AH_volume    [label="Aqueous Humor\nVolume ~250 μL\nTurnover 100 min", fillcolor="#C8E6C9"];
    BRB          [label="Blood-Retinal\nBarrier (BRB)\nZO-1, Occludin", fillcolor="#A5D6A7"];
  }

  // =====================================================================
  // CLUSTER 3: Trabecular Meshwork & Conventional Outflow
  // =====================================================================
  subgraph cluster_tm {
    label="3. 섬유주·전통 유출로 (Trabecular Meshwork & Conventional Outflow)";
    style=filled; bgcolor="#FFF8E1"; color="#E65100"; fontcolor="#E65100"; fontsize=12;

    TM_cells    [label="Trabecular\nMeshwork (TM)\nCells", fillcolor="#FFE0B2", shape=ellipse];
    RhoA_TM     [label="RhoA GTPase\n(Cytoskeleton)", fillcolor="#FFCC80"];
    ROCK1_TM    [label="ROCK1/2\n(Rho Kinase)", fillcolor="#FFCC80"];
    MLCK_TM     [label="MLCK\n(Myosin Light\nChain Kinase)", fillcolor="#FFB74D"];
    pMLC        [label="p-MLC\n(Phospho-Myosin\nLight Chain)", fillcolor="#FFA726"];
    actin_cyt   [label="F-Actin\nCytoskeleton\n(Contraction)", fillcolor="#FF8A65"];
    TGFb2_TM    [label="TGF-β2 ↑\n(Major Fibrotic\nMediator)", fillcolor="#EF6C00"];
    Smad2_3     [label="SMAD2/3\n(TGF-β Signal)", fillcolor="#FFCC80"];
    ECM_TM      [label="ECM Accumulation\nFibronectin·Collagen\nLaminin·CTGF", fillcolor="#E65100", fontcolor="white", shape=diamond];
    MMP_TM      [label="MMP-2, MMP-9\n(ECM Degradation)", fillcolor="#FFCC80"];
    TIMP_TM     [label="TIMP-1, TIMP-3\n(MMP Inhibitors)", fillcolor="#FFB74D"];
    aSMA_TM     [label="α-SMA ↑\n(Myofibroblast\nActivation)", fillcolor="#FF7043"];
    TM_senescence [label="TM Cell\nSenescence\np21·p53·β-gal", fillcolor="#FF5722", fontcolor="white"];
    OX_stress_TM  [label="Oxidative Stress\n8-OHdG ↑\nROS ↑", fillcolor="#E64A19", fontcolor="white"];
    JCT         [label="Juxtacanalicular\nTissue (JCT)\n(High Resistance)", fillcolor="#FFE0B2"];
    schlemm_inn [label="Inner Wall\nSchlemm's Canal\n(Paracellular)", fillcolor="#FFD180"];
    schlemm_outer [label="Outer Wall\nSchlemm's Canal", fillcolor="#FFCA28"];
    giant_vac   [label="Giant Vacuoles\n(Pressure-Driven\nTranscellular)", fillcolor="#FFE0B2"];
    collector_ch [label="Collector\nChannels (25-35)\n→ Aqueous Veins", fillcolor="#FFCC80"];
    episcleral_v [label="Episcleral Veins\n(P_ep = 8 mmHg\nDraining)", fillcolor="#FF8F00", fontcolor="white"];
    C_tm         [label="Trabecular Outflow\nFacility C_tm\n0.30 μL/min/mmHg", fillcolor="#E65100", fontcolor="white", shape=diamond, penwidth=2.5];
    TM_phago     [label="TM Phagocytosis\n(Debris Clearance)", fillcolor="#FFE0B2"];
  }

  // =====================================================================
  // CLUSTER 4: Uveoscleral (Unconventional) Outflow
  // =====================================================================
  subgraph cluster_uveoscleral {
    label="4. 포도막공막 유출로 (Uveoscleral / Unconventional Outflow)";
    style=filled; bgcolor="#F3E5F5"; color="#4A148C"; fontcolor="#4A148C"; fontsize=12;

    cil_muscle   [label="Ciliary Muscle\n(Longitudinal\nFibers)", fillcolor="#CE93D8", shape=ellipse];
    FP_receptor  [label="FP Prostanoid\nReceptor (Gq)", fillcolor="#CE93D8"];
    Gq_prot      [label="Gq/PLC\nSignaling", fillcolor="#BA68C8"];
    PKC_uv       [label="PKC\nActivation", fillcolor="#AB47BC"];
    MMP_uv       [label="MMP-1, MMP-3\nMMP-13 ↑", fillcolor="#9C27B0", fontcolor="white"];
    ECM_uveoscl  [label="Ciliary Body\nECM Remodeling\n(Collagen ↓)", fillcolor="#7B1FA2", fontcolor="white"];
    suprachoroid [label="Suprachoroidal\nSpace (ICA)", fillcolor="#CE93D8"];
    F_uv         [label="Uveoscleral\nOutflow F_uv\n0.4 μL/min", fillcolor="#6A1B9A", fontcolor="white", shape=diamond, penwidth=2.5];
    PGE2_local   [label="PGE₂\n(Autocrine Loop)", fillcolor="#E1BEE7"];
    cAMP_cil2    [label="cAMP ↑\n(Ciliary Muscle)", fillcolor="#E1BEE7"];
    EP2_EP4      [label="EP2/EP4\nReceptors", fillcolor="#CE93D8"];
  }

  // =====================================================================
  // CLUSTER 5: IOP Dynamics (Goldmann Equation)
  // =====================================================================
  subgraph cluster_iop {
    label="5. 안압 역학 (IOP Dynamics — Goldmann Equation)";
    style=filled; bgcolor="#FCE4EC"; color="#880E4F"; fontcolor="#880E4F"; fontsize=12;

    IOP_node     [label="IOP\n(Intraocular\nPressure)", fillcolor="#F06292", shape=ellipse, penwidth=3, fontsize=11];
    goldmann_eq  [label="Goldmann Equation\nIOP = F_prod/C_tm\n    + P_ep − F_uv/C_tm", fillcolor="#FCE4EC", shape=note];
    diurnal_IOP  [label="Diurnal Variation\nPeak: 08–11h (±4)\nTrough: 22–02h", fillcolor="#F48FB1"];
    IOP_normal   [label="Normal Range\n10–21 mmHg\nMean 15.5 ± 2.6", fillcolor="#F8BBD0"];
    OHT          [label="Ocular Hypertension\nIOP >21 mmHg\n(Without Damage)", fillcolor="#F48FB1"];
    IOP_target   [label="Treatment Target\n<18 mmHg or\n30% ↓ Baseline", fillcolor="#AD1457", fontcolor="white"];
    NTG_node     [label="Normal-Tension\nGlaucoma (NTG)\nIOP ≤21 mmHg", fillcolor="#C2185B", fontcolor="white"];
    IOP_fluc     [label="IOP Fluctuation\n(24-hr SD >4 mmHg\nRisk Factor)", fillcolor="#F48FB1"];
    P_ep_node    [label="Episcleral Venous\nPressure P_ep\n= 8 mmHg", fillcolor="#F8BBD0"];
    posture_IOP  [label="Postural Effect\n(Supine: +5–6)\n(Standing: −2)", fillcolor="#F48FB1"];
    exercise_IOP [label="Aerobic Exercise\n(IOP ↓ during)", fillcolor="#FCE4EC"];
    CCT_correct  [label="Goldmann Correction\nCCT Adjustment\n(±0.71 mmHg per\n10 μm CCT)", fillcolor="#FCE4EC"];
  }

  // =====================================================================
  // CLUSTER 6: Drug PK/PD
  // =====================================================================
  subgraph cluster_drugs {
    label="6. 약물 PK/PD (Drug Pharmacokinetics & Pharmacodynamics)";
    style=filled; bgcolor="#EDE7F6"; color="#311B92"; fontcolor="#311B92"; fontsize=12;

    // ---- Prostaglandin Analogs ----
    PGA_route  [label="Prostaglandin Analogs\nLatanoprost 50 μg\nTravoprost 40 μg\nBimatoprost 300 μg\nTafluprost 15 μg (QD PM)", fillcolor="#B39DDB"];
    PGA_cornea [label="Corneal Ester\nHydrolysis\n(Pro-drug → Acid)", fillcolor="#CE93D8"];
    PGA_aq     [label="PGA Concentration\nAqueous\nCmax ~20 nM", fillcolor="#9575CD"];
    PGA_ke     [label="Aqueous Half-Life\n~2 h (Local PK)", fillcolor="#EDE7F6"];
    PGA_PD     [label="FP-R Agonism\nEC₅₀ ~0.3 nM\nEmax ↑F_uv +80–120%", fillcolor="#673AB7", fontcolor="white"];

    // ---- Beta-Blockers ----
    BB_route   [label="Beta-Blockers\nTimolol 0.5% BID\nBetaxolol 0.25% BID\n(β₁-selective)", fillcolor="#B39DDB"];
    BB_aq      [label="BB Concentration\nAqueous\nCmax ~800 nM", fillcolor="#9575CD"];
    BB_PD      [label="β₂-AR Blockade\nEC₅₀ ~150 nM\nEmax ↓F_prod 25–35%", fillcolor="#673AB7", fontcolor="white"];
    BB_systemic [label="Systemic BB Effects\nBradycardia\nBronchospasm Risk\nCNS Side Effects", fillcolor="#9575CD"];

    // ---- Carbonic Anhydrase Inhibitors ----
    CAI_route  [label="CAI (Topical)\nDorzolamide 2% TID\nBrinzolamide 1% BID\n+ Acetazolamide PO", fillcolor="#B39DDB"];
    CAI_aq     [label="CAI Concentration\nAqueous\nEC₅₀ ~0.5 μM", fillcolor="#9575CD"];
    CAI_PD     [label="CA-II/IV Inhibition\nEmax ↓F_prod 20–30%\n(Additive with BB)", fillcolor="#673AB7", fontcolor="white"];

    // ---- Alpha-2 Agonists ----
    A2A_route  [label="Alpha-2 Agonists\nBrimonidine 0.2% BID\nApraclonidine 1% TID", fillcolor="#B39DDB"];
    A2A_aq     [label="A2A Concentration\nAqueous\nCmax ~1.4 nM", fillcolor="#9575CD"];
    A2A_PD     [label="α₂-AR Agonism\nEmax ↓F_prod 25%\nEmax ↑F_uv 10%", fillcolor="#673AB7", fontcolor="white"];
    A2A_neuro  [label="Neuroprotection\nBDNF ↑ · ERK1/2 ↑\nPI3K/AKT ↑", fillcolor="#4527A0", fontcolor="white"];

    // ---- ROCK Inhibitors ----
    ROCKi_route [label="ROCK Inhibitors\nNetarsudil 0.02% QD\nLatanoprostene\nBunod 0.024% QD", fillcolor="#B39DDB"];
    ROCKi_aq   [label="ROCK-I Concentration\nAqueous\nEC₅₀ ~10 nM (ROCK2)", fillcolor="#9575CD"];
    ROCKi_PD_tm [label="ROCK1/2 Inhibition\n→ ↑ C_tm +30–40%\n→ ↓ ECM deposition", fillcolor="#673AB7", fontcolor="white"];
    ROCKi_PD_ep [label="↓ Episcleral\nVenous Pressure\n(−3 mmHg)", fillcolor="#9575CD"];
    LBN_extra  [label="Latanoprostene Bunod\nNO-Donor Component\n→ cGMP ↑ → ↑ C_tm", fillcolor="#9575CD"];

    // ---- Pilocarpine / Miotics ----
    PILO_route [label="Pilocarpine 2–4%\nQID (Miotic)\n(Carbachol 3%)", fillcolor="#B39DDB"];
    PILO_aq    [label="Pilocarpine\nAqueous", fillcolor="#9575CD"];
    PILO_PD    [label="M3-R → Ciliary\nMuscle Contraction\n→ ↑ C_tm (+40%)", fillcolor="#7E57C2"];

    // ---- Combination / Surgical ----
    COMBO_FDC  [label="Fixed-Dose Combos\nDuotrav (PGA+BB)\nCosopt (CAI+BB)\nGanfort (PGA+BB)\nRocklatan (ROCKi+PGA)", fillcolor="#9575CD"];
    SLT_laser  [label="Selective Laser\nTrabeculoplasty (SLT)\n↑ C_tm +30–50%\nRePOSIT Trial First-Rx", fillcolor="#6A1B9A", fontcolor="white"];
    ALT_laser  [label="Argon Laser\nTrabeculoplasty\n(ALT, older)", fillcolor="#7E57C2"];
    MIGS_dev   [label="MIGS Devices\niStent · Hydrus\nTrabecular bypass\n↑ C_tm", fillcolor="#4527A0", fontcolor="white"];
    Trab_surg  [label="Trabeculectomy\nFiltration Bleb\n→ IOP ~10–12 mmHg", fillcolor="#311B92", fontcolor="white"];
    ECP        [label="Endoscopic\nCyclophotocoagulation\n(ECP)\n↓ F_prod", fillcolor="#4527A0", fontcolor="white"];
    Tube_shunt [label="Tube Shunt\n(Ahmed/Baerveldt)\nRefractory Glaucoma", fillcolor="#311B92", fontcolor="white"];
  }

  // =====================================================================
  // CLUSTER 7: Optic Nerve Head Biology
  // =====================================================================
  subgraph cluster_onh {
    label="7. 시신경 유두 생물학 (Optic Nerve Head Biology)";
    style=filled; bgcolor="#E3F2FD"; color="#0D47A1"; fontcolor="#0D47A1"; fontsize=12;

    ONH_struct  [label="Optic Nerve Head\n(ONH) Anatomy", fillcolor="#90CAF9", shape=ellipse];
    lamina_crib [label="Lamina Cribrosa\n(LC)\nCollagen IV Plates", fillcolor="#64B5F6"];
    LC_pores    [label="LC Pore\nGeometry\n(Beam Thickness)", fillcolor="#90CAF9"];
    ICP_node    [label="Intracranial Pressure\n(ICP = 10–12 mmHg)\nCSF Pressure", fillcolor="#90CAF9"];
    TPG_node    [label="Trans-LC Pressure\nGradient (TPG)\nTPG = IOP − ICP", fillcolor="#42A5F5"];
    LC_deform   [label="LC Deformation\n→ Axon Beam\nCompression", fillcolor="#1E88E5"];
    BL_stress   [label="Biomechanical\nStress & Strain\n(FEM Models)", fillcolor="#64B5F6"];
    axon_trans  [label="Axonal Transport\nBlockade\n(BDNF Retrograde ↓)", fillcolor="#0D47A1", fontcolor="white"];
    astro_ONH   [label="ONH Astrocyte\nReactivation\n(GFAP ↑)", fillcolor="#64B5F6"];
    micro_ONH   [label="ONH Microglia\nActivation (M1)\nCytokine Release", fillcolor="#42A5F5"];
    BDNF_node   [label="BDNF\nBrain-Derived\nNeurotrophic Factor", fillcolor="#0D47A1", fontcolor="white", shape=diamond, penwidth=2.5];
    TrkB_node   [label="TrkB Receptor\n→ PI3K/AKT\n→ Survival ↑", fillcolor="#1565C0", fontcolor="white"];
    p75NTR_node [label="p75NTR\n(Pro-apoptotic\nWhen BDNF Low)", fillcolor="#1565C0", fontcolor="white"];
    BDNF_axon   [label="BDNF Retrograde\nTransport\n(TrkB Vesicles)", fillcolor="#1976D2", fontcolor="white"];
    ET1_ONH     [label="Endothelin-1 ↑\n(Vasoconstriction\nNTG Role)", fillcolor="#42A5F5"];
    NOS_ONH     [label="eNOS / NO\n(Vascular\nRegulation)", fillcolor="#64B5F6"];
    O2_ONH      [label="ONH O₂ Supply\n(Capillary Blood\nFlow)", fillcolor="#1976D2", fontcolor="white"];
    VEGF_ONH    [label="VEGF\n(Neovascularization\nRisk)", fillcolor="#90CAF9"];
    CDR_node    [label="Cup-to-Disc\nRatio (CDR)\nNormal <0.4", fillcolor="#E3F2FD"];
    rim_area    [label="Neuroretinal Rim\nArea (NRA)\nHEIDELBERG HRT", fillcolor="#BBDEFB"];
    RNFL_oct    [label="RNFL Thickness\n(OCT Imaging)\n95–105 μm Normal", fillcolor="#BBDEFB"];
  }

  // =====================================================================
  // CLUSTER 8: RGC Apoptosis Cascade
  // =====================================================================
  subgraph cluster_rgc {
    label="8. 망막신경절세포 사멸 (RGC Apoptosis Cascade)";
    style=filled; bgcolor="#FFEBEE"; color="#B71C1C"; fontcolor="#B71C1C"; fontsize=12;

    RGC_count   [label="Retinal Ganglion\nCells (RGC)\n~1.2 M Normal", fillcolor="#FFCDD2", shape=ellipse, penwidth=3, fontsize=10];
    soma_layer  [label="Ganglion Cell\nLayer (GCL)", fillcolor="#FFCDD2"];
    axon_NFL    [label="Nerve Fiber\nLayer (NFL)\nRGC Axons", fillcolor="#FFCDD2"];
    ipRGC       [label="ipRGC\n(Melanopsin)\nCircadian", fillcolor="#FFCDD2"];

    // Excitotoxicity
    Muller_cell [label="Müller Cell\nDysfunction\n(Glutamate ↑)", fillcolor="#FFAB91"];
    Glutamate_exc [label="Glutamate\nExcitotoxicity\n(EAA ↑)", fillcolor="#FF7043"];
    NMDA_R      [label="NMDA Receptor\nOveractivation\nGlu-Gated", fillcolor="#EF5350"];
    Ca_in       [label="Ca²⁺ Influx\n(Cytotoxic\nOverload)", fillcolor="#D32F2F", fontcolor="white"];
    nNOS_act    [label="nNOS/iNOS ↑\n→ Nitric Oxide↑\n→ ONOO⁻", fillcolor="#C62828", fontcolor="white"];

    // Oxidative stress in RGC
    ROS_RGC     [label="ROS\nSuperoxide H₂O₂\n(Mitochondrial)", fillcolor="#EF5350", shape=diamond];
    Nrf2_RGC    [label="Nrf2\nAntioxidant\nResponse Element", fillcolor="#EF9A9A"];
    SOD2_RGC    [label="SOD2 / Catalase\nAntioxidant\nDefense ↓ in POAG", fillcolor="#FFCDD2"];

    // Mitochondrial pathway
    mito_dysfun [label="Mitochondrial\nDysfunction\n(Complex I ↓)", fillcolor="#EF5350"];
    Bax_node    [label="Bax\n(Pro-apoptotic)\nMitochondrial", fillcolor="#D32F2F", fontcolor="white"];
    Bcl2_node   [label="Bcl-2\n(Anti-apoptotic)\n↓ in Glaucoma", fillcolor="#EF9A9A"];
    cyto_c      [label="Cytochrome c\nRelease\n(Mitochondria)", fillcolor="#B71C1C", fontcolor="white"];
    Casp9_node  [label="Caspase-9\n(Initiator\nCaspase)", fillcolor="#C62828", fontcolor="white"];
    Apaf1       [label="Apaf-1\nApoptosome\nFormation", fillcolor="#D32F2F", fontcolor="white"];
    Casp3_node  [label="Caspase-3\n(Executioner)\nFinal Apoptosis", fillcolor="#B71C1C", fontcolor="white", shape=diamond, penwidth=3];
    Casp6_node  [label="Caspase-6\n(Axonal\nDegeneration)", fillcolor="#C62828", fontcolor="white"];

    // Stress kinases & death signaling
    p53_RGC     [label="p53\n(DNA Damage\nResponse)", fillcolor="#EF5350"];
    JNK_RGC     [label="JNK / SAPK\nStress-Activated\nProtein Kinase", fillcolor="#EF9A9A"];
    DLK_RGC     [label="DLK\n(Dual Leucine\nZipper Kinase)\nAxon Damage", fillcolor="#E53935"];
    PUMA        [label="PUMA / NOXA\n(BH3-Only\nProteins)", fillcolor="#D32F2F", fontcolor="white"];

    // Inflammation
    NLRP3_ret   [label="NLRP3\nInflammasome\n(Retinal)", fillcolor="#FFAB91"];
    IL1b_ret    [label="IL-1β ↑\n(Retinal\nInflammation)", fillcolor="#FF8A65"];
    TNFa_ret    [label="TNF-α ↑\nDR5/TRAIL\n(Extrinsic Death)", fillcolor="#FF7043"];
    C1q_syn     [label="C1q / C3\nComplement\nSynapse Elimination", fillcolor="#FFAB91"];
    IFNg_ret    [label="IFN-γ\n(Microglia M1)", fillcolor="#FF8A65"];
    microglia_ret [label="Retinal Microglia\nActivation\nPhagocytosis", fillcolor="#EF9A9A", shape=ellipse];

    // Axon degeneration
    Wallerian_ret [label="Wallerian\nDegeneration\nDistal Axon", fillcolor="#C62828", fontcolor="white"];
    SARM1       [label="SARM1\n(NAD⁺ Depletion\nAxon Degen)", fillcolor="#D32F2F", fontcolor="white"];
    RGC_death   [label="RGC Apoptotic\nDeath\nIrreversible", fillcolor="#B71C1C", fontcolor="white", shape=ellipse, penwidth=3];
  }

  // =====================================================================
  // CLUSTER 9: Clinical Endpoints & Monitoring
  // =====================================================================
  subgraph cluster_endpoints {
    label="9. 임상 종점·모니터링 (Clinical Endpoints & Monitoring)";
    style=filled; bgcolor="#F9FBE7"; color="#33691E"; fontcolor="#33691E"; fontsize=12;

    RNFL_ep     [label="RNFL Thickness\n(Structural)\nNormal 95–105 μm", fillcolor="#F0F4C3", shape=diamond, penwidth=2];
    GCL_ip      [label="GCL+IPL\nThickness (OCT)\n60–90 μm Normal", fillcolor="#DCE775"];
    VF_MD_ep    [label="Visual Field\nMean Deviation\n(VF-MD, dB)\nNormal: 0 to −2", fillcolor="#9CCC65", shape=diamond, penwidth=3];
    VF_PSD_ep   [label="Pattern Standard\nDeviation (PSD)\n(Local Defects)", fillcolor="#DCE775"];
    VF_24_2     [label="Humphrey 24-2\nVF Test (SITA-S)\n54 Locations", fillcolor="#F9FBE7"];
    VF_rate_ep  [label="VF Progression\nRate (dB/year)\nSlow: <0.3\nFast: >1.0", fillcolor="#8BC34A"];
    CDR_ep      [label="Cup-to-Disc\nRatio (CDR)\n>0.6: Suspicious", fillcolor="#DCE775"];
    VF_stage    [label="Glaucoma Stage\nEarly: MD >−6\nMod: −6 to −12\nAdv: MD <−12", fillcolor="#689F38", fontcolor="white"];
    GPA_sw      [label="Guided Progression\nAnalysis (GPA)\nBoth Eyes", fillcolor="#F9FBE7"];
    VFI         [label="Visual Field\nIndex (VFI %)\n100% = Normal", fillcolor="#DCEDC8"];
    blindness_ep [label="Legal Blindness\n(MD <−22 dB)\nLifetime Risk 27%\nAdvanced POAG", fillcolor="#33691E", fontcolor="white"];
    QoL_ep      [label="Quality of Life\nNEI-VFQ-25\nVF-14 Score", fillcolor="#F0F4C3"];
    IOP_reduction [label="IOP Reduction\n(Primary Target)\n20–40% from Baseline", fillcolor="#AED581"];
  }

  // =====================================================================
  // CLUSTER 10: Systemic & Vascular Factors
  // =====================================================================
  subgraph cluster_systemic {
    label="10. 전신·혈관 인자 (Systemic & Vascular Factors)";
    style=filled; bgcolor="#FFF8E1"; color="#BF360C"; fontcolor="#BF360C"; fontsize=12;

    BP_sys      [label="Systemic Blood\nPressure (MAP)", fillcolor="#FFE082", shape=ellipse];
    OPP_node    [label="Ocular Perfusion\nPressure (OPP)\n= 2/3 MAP − IOP", fillcolor="#FFCA28"];
    autoregul   [label="ONH Autoregulation\nCapacity\n(↓ in NTG/DM)", fillcolor="#FFB300"];
    vasospasm_r [label="Vasospasm\nRaynaud·Migraine\nNTG Association", fillcolor="#FF8F00", fontcolor="white"];
    DM_vasc     [label="Diabetes Mellitus\nMicroangiopathy\nBRB Dysfunction", fillcolor="#E65100", fontcolor="white"];
    HTN_sys     [label="Systemic HTN\nOPP Dysregulation\nNight Dipping", fillcolor="#FFE082"];
    CSF_pres    [label="CSF Pressure\n(Affects TPG)\nLow CSF → ↑ TPG", fillcolor="#FFF3E0"];
    OSA_eff     [label="Sleep Apnea\nNocturnal IOP ↑\nIntermittent Hypoxia", fillcolor="#FFE0B2"];
    Thyroid_dis [label="Thyroid Disease\nAssociation", fillcolor="#FFF8E1"];
    XFS_mat     [label="Pseudo-exfoliation\nMaterial\n(LOXL1)\nTM Blockage", fillcolor="#BF360C", fontcolor="white"];
    PDG_pig     [label="Pigment Granules\n(Pigment Dispersion)\nTM Clogging", fillcolor="#E64A19", fontcolor="white"];

    // Neuroprotection cluster
    memantine_np [label="Memantine\n(NMDA Blocker)\nPhase III Negative", fillcolor="#FFF9C4"];
    CoQ10_np     [label="CoQ10 / NAC\nOral Antioxidants", fillcolor="#FFF9C4"];
    VitE_np      [label="Vitamin E / Lutein\nRetinal Protection", fillcolor="#FFF9C4"];
    StemCell_np  [label="Stem Cell / RGC\nTransplantation\n(Preclinical)", fillcolor="#FFF9C4"];
    CNTF_np      [label="CNTF\n(Ciliary NT\nFactor) Implant", fillcolor="#FFF9C4"];
    gene_therapy [label="AAV Gene Therapy\n(BDNF Delivery\nPreclinical)", fillcolor="#FFF9C4"];
  }

  // ===================================================================
  //  EDGES — Genetics / Risk → Pathways
  // ===================================================================
  MYOC      -> TM_senescence   [label="↑ ECM\nMutant Protein", color="#1A237E"];
  OPTN      -> axon_trans      [label="Mitophagy\nDefect", color="#1A237E"];
  WDR36     -> RGC_count       [label="→ Susceptibility", color="#1A237E", style=dashed];
  NTF4      -> BDNF_node       [label="Neurotrophic\nSignaling", color="#1A237E", style=dashed];
  CDKN2B    -> TM_senescence   [label="p15/p16 ↑", color="#1A237E", style=dashed];
  SIX1_SIX6 -> RGC_count      [label="Development\nRisk", color="#1A237E", style=dashed];
  CAV1_CAV2 -> C_tm            [label="Caveolae\nOutflow Reg", color="#1A237E", style=dashed];
  age_risk  -> TM_senescence   [style=dashed, color="#9E9E9E"];
  age_risk  -> RGC_count       [label="−0.5%/yr\nNormal Loss", style=dashed, color="#9E9E9E"];
  thin_cornea -> IOP_node      [label="Underestimates\nTrue IOP", color="#F44336", style=dashed];
  disc_hem  -> VF_rate_ep      [label="→ Accelerates", color="#D32F2F"];
  XFS_gene  -> XFS_mat         [color="#9E9E9E"];
  XFS_mat   -> ECM_TM          [label="XF Material\nTM Clogging", color="#E65100"];

  // ===================================================================
  //  EDGES — Aqueous Production
  // ===================================================================
  ciliary_epithelium -> Na_K_ATPase;
  ciliary_epithelium -> CA_II;
  ciliary_epithelium -> CA_IV;
  CA_II     -> bicarb_sec      [label="→ HCO₃⁻"];
  CA_IV     -> bicarb_sec;
  Na_K_ATPase -> bicarb_sec   [label="Na⁺/K⁺\nGradient"];
  bicarb_sec -> AH_volume      [label="→ Osmotic\nWater Flow"];
  AQP1      -> AH_volume       [label="H₂O\nTransport"];
  beta2_AR  -> Gs_cil          [label="Couples"];
  Gs_cil    -> cAMP_cil        [label="↑ cAMP", color="#4CAF50"];
  cAMP_cil  -> PKA_cil;
  PKA_cil   -> Na_K_ATPase     [label="↑ Activity"];
  alpha2_AR -> Gi_cil          [label="Couples"];
  Gi_cil    -> cAMP_cil        [label="↓ cAMP", color="#F44336"];
  AH_volume -> F_prod;
  VEGF_cil  -> BRB;
  BRB       -> AH_volume       [label="Barrier\nIntegrity"];

  // ===================================================================
  //  EDGES — TM Conventional Outflow
  // ===================================================================
  TM_cells  -> RhoA_TM;
  RhoA_TM   -> ROCK1_TM;
  ROCK1_TM  -> MLCK_TM;
  MLCK_TM   -> pMLC;
  pMLC      -> actin_cyt       [label="Contraction"];
  actin_cyt -> C_tm            [label="↓ (Stiffens\nTM Cells)", color="#F44336"];
  TGFb2_TM  -> Smad2_3;
  Smad2_3   -> ECM_TM          [label="↑ Fibronectin\nCollagen", color="#D32F2F"];
  Smad2_3   -> aSMA_TM;
  ECM_TM    -> JCT             [label="→ Resistance\n↑ in TM"];
  ECM_TM    -> C_tm            [label="↓ Outflow\nFacility", color="#F44336"];
  MMP_TM    -> ECM_TM          [label="↓ Degrades", color="#4CAF50"];
  TIMP_TM   -> MMP_TM          [label="↓ Inhibits", color="#F44336"];
  TM_senescence -> TGFb2_TM   [label="→ SASP"];
  OX_stress_TM -> TM_senescence [label="→ Drives"];
  IOP_node  -> OX_stress_TM   [label="Mechanical\nStress", color="#F44336"];
  aSMA_TM   -> actin_cyt;
  JCT       -> schlemm_inn;
  schlemm_inn -> giant_vac;
  schlemm_inn -> schlemm_outer;
  schlemm_outer -> collector_ch;
  collector_ch -> episcleral_v;
  episcleral_v -> IOP_node     [label="P_ep Back-\npressure", color="#FF9800"];
  C_tm      -> IOP_node        [label="↑ → ↓ IOP", color="#4CAF50", penwidth=2];
  TM_phago  -> ECM_TM          [label="Debris\nClearance ↓", color="#F44336", style=dashed];

  // ===================================================================
  //  EDGES — Uveoscleral Outflow
  // ===================================================================
  cil_muscle  -> FP_receptor;
  FP_receptor -> Gq_prot;
  Gq_prot     -> PKC_uv;
  PKC_uv      -> MMP_uv;
  MMP_uv      -> ECM_uveoscl   [label="↓ Collagen"];
  ECM_uveoscl -> suprachoroid  [label="→ Easier\nFlow"];
  suprachoroid -> F_uv;
  PGE2_local  -> EP2_EP4;
  EP2_EP4     -> cAMP_cil2     [label="↑ cAMP"];
  cAMP_cil2   -> cil_muscle    [label="Relaxation"];
  cil_muscle  -> F_uv          [label="→ Muscle\nGap ↑"];

  // ===================================================================
  //  EDGES — IOP Dynamics
  // ===================================================================
  F_prod    -> IOP_node         [label="↑ → ↑ IOP", color="#F44336", penwidth=2];
  F_uv      -> IOP_node         [label="↑ → ↓ IOP", color="#4CAF50", penwidth=2];
  P_ep_node -> IOP_node         [label="Venous BP\nFloor"];
  diurnal_IOP -> IOP_node       [style=dashed];
  posture_IOP -> IOP_node       [style=dashed];
  OHT         -> IOP_node       [label="Elevated"];
  NTG_node    -> RGC_count      [label="Damage\nDespite Normal", color="#D32F2F"];
  IOP_fluc    -> VF_rate_ep     [label="↑ Fluctuation\n→ Faster", color="#F44336"];

  // ===================================================================
  //  EDGES — Drug → IOP
  // ===================================================================
  // Prostaglandin analogs
  PGA_route  -> PGA_cornea;
  PGA_cornea -> PGA_aq;
  PGA_aq     -> PGA_PD;
  PGA_PD     -> FP_receptor     [label="Agonism", color="#6A1B9A"];
  PGA_PD     -> F_uv            [label="↑ +80–120%", color="#6A1B9A", penwidth=2.5, fontcolor="#6A1B9A"];

  // Beta-blockers
  BB_route   -> BB_aq;
  BB_aq      -> BB_PD;
  BB_PD      -> beta2_AR        [label="Blockade", color="#D32F2F"];
  BB_PD      -> F_prod          [label="↓ 25–35%", color="#D32F2F", penwidth=2.5, fontcolor="#D32F2F"];
  BB_aq      -> BB_systemic     [label="Systemic\nAbsorption"];

  // CAIs
  CAI_route  -> CAI_aq;
  CAI_aq     -> CAI_PD;
  CAI_PD     -> CA_II           [label="Inhibit", color="#D32F2F"];
  CAI_PD     -> CA_IV           [label="Inhibit", color="#D32F2F"];
  CAI_PD     -> F_prod          [label="↓ 20–30%", color="#D32F2F", penwidth=2, fontcolor="#D32F2F"];

  // Alpha-2 agonists
  A2A_route  -> A2A_aq;
  A2A_aq     -> A2A_PD;
  A2A_PD     -> alpha2_AR       [label="Agonism"];
  A2A_PD     -> F_prod          [label="↓ 25%", color="#D32F2F", penwidth=2, fontcolor="#D32F2F"];
  A2A_PD     -> F_uv            [label="↑ 10%", color="#4CAF50", penwidth=1];
  A2A_aq     -> A2A_neuro;
  A2A_neuro  -> BDNF_node       [label="↑ BDNF\nNeuroprot.", color="#1565C0"];

  // ROCK inhibitors
  ROCKi_route -> ROCKi_aq;
  ROCKi_aq   -> ROCKi_PD_tm;
  ROCKi_aq   -> ROCKi_PD_ep;
  ROCKi_PD_tm -> ROCK1_TM      [label="Inhibits", color="#D32F2F"];
  ROCKi_PD_tm -> actin_cyt     [label="Relaxation", color="#4CAF50"];
  ROCKi_PD_tm -> C_tm          [label="↑ 30–40%", color="#4CAF50", penwidth=2.5, fontcolor="#4CAF50"];
  ROCKi_PD_tm -> ECM_TM        [label="↓ Fibrosis", color="#4CAF50"];
  ROCKi_PD_ep -> episcleral_v  [label="↓ P_ep\n−3 mmHg", color="#4CAF50"];
  LBN_extra  -> C_tm           [label="NO·cGMP →\n↑ C_tm", color="#4CAF50"];

  // Pilocarpine
  PILO_route -> PILO_aq;
  PILO_aq    -> PILO_PD;
  PILO_PD    -> cil_muscle     [label="M3 Contract."];
  PILO_PD    -> C_tm           [label="↑ 40%", color="#4CAF50"];

  // Laser / Surgical
  SLT_laser  -> C_tm           [label="↑ 30–50%\nSelective", color="#4A148C", fontcolor="#4A148C", penwidth=2];
  ALT_laser  -> C_tm           [label="↑ (Less\nSpecific)", color="#7E57C2"];
  MIGS_dev   -> C_tm           [label="Direct Bypass\n↑ C_tm", color="#4527A0"];
  Trab_surg  -> IOP_node       [label="Bleb Filter\n→ ~10 mmHg", color="#311B92", penwidth=2];
  ECP        -> F_prod         [label="↓ Ablation", color="#D32F2F"];
  Tube_shunt -> IOP_node       [label="Shunt Drain", color="#311B92"];

  COMBO_FDC  -> F_prod         [label="Dual ↓ F_prod", color="#D32F2F"];
  COMBO_FDC  -> F_uv           [label="↑ F_uv (PGA)", color="#4CAF50"];

  // ===================================================================
  //  EDGES — IOP → ONH
  // ===================================================================
  IOP_node   -> TPG_node        [label="↑ IOP → ↑ TPG"];
  ICP_node   -> TPG_node        [label="Opposes\n(Protective)", color="#4CAF50"];
  TPG_node   -> LC_deform       [label="→ Compresses\nLC Beams"];
  LC_deform  -> BL_stress;
  BL_stress  -> axon_trans      [label="→ Blocks"];
  LC_deform  -> astro_ONH       [label="→ Activates"];
  axon_trans -> BDNF_node       [label="↓ BDNF\nRetrograde", color="#F44336"];
  axon_trans -> DLK_RGC         [label="→ Activates\nStress Signal"];
  BDNF_node  -> TrkB_node       [label="→ Binds"];
  BDNF_node  -> BDNF_axon       [label="Retrograde"];
  BDNF_axon  -> TrkB_node       [label="→ Soma\nSurvival"];
  TrkB_node  -> RGC_count       [label="Survival ↑", color="#4CAF50", penwidth=2];
  p75NTR_node -> Casp3_node     [label="Pro-death\n(Low BDNF)", color="#D32F2F"];
  astro_ONH  -> micro_ONH;
  micro_ONH  -> TNFa_ret        [label="→"];
  micro_ONH  -> IL1b_ret        [label="→"];
  micro_ONH  -> C1q_syn         [label="→"];
  ONH_struct -> lamina_crib;
  lamina_crib -> LC_pores;
  LC_pores   -> LC_deform       [label="Pore Geometry\nModulates"];
  O2_ONH     -> ONH_struct      [label="Blood Supply"];
  OPP_node   -> O2_ONH          [label="→ Perfusion"];
  NOS_ONH    -> O2_ONH          [label="NO → Vasodil.", color="#4CAF50"];
  ET1_ONH    -> O2_ONH          [label="↓ Flow\nVasoconstrict", color="#F44336"];
  lamina_crib -> CDR_node;
  CDR_node   -> CDR_ep;
  RNFL_oct   -> RNFL_ep;
  rim_area   -> CDR_node;

  // ===================================================================
  //  EDGES — RGC Apoptosis
  // ===================================================================
  IOP_node   -> Muller_cell     [label="→ Stress\nGlutamate ↑", color="#D32F2F"];
  Muller_cell -> Glutamate_exc;
  Glutamate_exc -> NMDA_R;
  NMDA_R     -> Ca_in           [label="→ Ca²⁺ ↑"];
  Ca_in      -> nNOS_act        [label="→ Activates"];
  nNOS_act   -> ROS_RGC         [label="ONOO⁻", color="#D32F2F"];
  Ca_in      -> mito_dysfun;
  mito_dysfun -> ROS_RGC        [label="Mitoch. ROS", color="#D32F2F"];
  ROS_RGC    -> Nrf2_RGC        [label="→ Activates"];
  Nrf2_RGC   -> SOD2_RGC        [label="→ Upregulates"];
  SOD2_RGC   -> ROS_RGC         [label="↓ Scavenges", color="#4CAF50"];
  ROS_RGC    -> Bax_node        [label="↑ Pro-apopt.", color="#D32F2F"];
  Bcl2_node  -> cyto_c          [label="↓ Inhibits", color="#4CAF50"];
  Bax_node   -> cyto_c          [label="→ Release\nMitochondria", color="#D32F2F"];
  cyto_c     -> Apaf1;
  Apaf1      -> Casp9_node;
  Casp9_node -> Casp3_node      [label="→ Activates", color="#D32F2F"];
  Casp3_node -> RGC_death       [label="→ Apoptosis", color="#B71C1C", penwidth=3];
  Casp3_node -> Casp6_node;
  Casp6_node -> Wallerian_ret;
  SARM1      -> Wallerian_ret   [label="NAD⁺ ↓"];
  DLK_RGC    -> JNK_RGC;
  JNK_RGC    -> p53_RGC;
  JNK_RGC    -> PUMA;
  p53_RGC    -> Bax_node        [label="→ Transcribes"];
  PUMA       -> Bcl2_node       [label="Neutralizes", color="#D32F2F"];
  TNFa_ret   -> Casp3_node      [label="→ Extrinsic\nDR5/TRAIL", color="#D32F2F"];
  IL1b_ret   -> ROS_RGC         [label="→"];
  NLRP3_ret  -> IL1b_ret;
  C1q_syn    -> soma_layer      [label="Synapse Elim.\nPruning ↑", color="#F44336"];
  IFNg_ret   -> microglia_ret;
  microglia_ret -> NLRP3_ret;
  microglia_ret -> IFNg_ret     [label="M1 Loop"];
  RGC_death  -> RGC_count       [label="↓ Loss", color="#B71C1C", penwidth=3];
  soma_layer -> RGC_count;
  axon_NFL   -> RGC_count;

  // ===================================================================
  //  EDGES — Clinical Endpoints
  // ===================================================================
  RGC_count  -> RNFL_ep         [label="↓ (1 μm/yr\ntypical)", color="#D32F2F"];
  RGC_count  -> VF_MD_ep        [label="↓ Loss →\n↓ VF", color="#D32F2F", penwidth=2];
  RGC_count  -> GCL_ip          [label="Structural\nCorrelate", color="#FF9800"];
  IOP_node   -> VF_rate_ep      [label="Higher IOP\n→ Faster Prog.", color="#F44336"];
  IOP_target -> VF_rate_ep      [label="↓ IOP\n→ Slows Prog.", color="#4CAF50", penwidth=2];
  VF_MD_ep   -> VF_stage;
  VF_stage   -> blindness_ep    [label="End-Stage"];
  VF_MD_ep   -> VFI;
  VF_MD_ep   -> QoL_ep          [label="↓ VF → ↓ QoL"];
  VF_24_2    -> VF_MD_ep        [label="Measures"];
  GPA_sw     -> VF_rate_ep      [label="Detects\nProgression"];
  VF_rate_ep -> VF_PSD_ep;
  IOP_reduction -> IOP_node     [label="Clinical\nTarget ↓", color="#4CAF50", style=dashed];

  // ===================================================================
  //  EDGES — Systemic / Vascular
  // ===================================================================
  BP_sys     -> OPP_node        [label="2/3 MAP"];
  IOP_node   -> OPP_node        [label="↑ IOP →\n↓ OPP", color="#F44336"];
  OPP_node   -> autoregul;
  autoregul  -> O2_ONH          [label="→ Regulates"];
  vasospasm_r -> O2_ONH         [label="↓ Ischemia", color="#F44336"];
  DM_vasc    -> O2_ONH          [label="↓ Capillary\nDensity", color="#F44336"];
  DM_vasc    -> BRB             [label="→ Dysfunction", color="#F44336"];
  HTN_sys    -> OPP_node        [label="→ Modifies"];
  CSF_pres   -> TPG_node        [label="Low CSF →\n↑ TPG Risk"];
  OSA_eff    -> IOP_node        [label="Nocturnal\nIOP ↑", color="#F44336"];
  PDG_pig    -> ECM_TM          [label="Pigment\nDeposition", color="#D32F2F"];

  // Neuroprotection
  memantine_np -> NMDA_R        [label="Blocks", color="#4CAF50"];
  CoQ10_np   -> ROS_RGC         [label="↓ Scavenges", color="#4CAF50"];
  CNTF_np    -> TrkB_node       [label="→ Activates", color="#4CAF50"];
  gene_therapy -> BDNF_node     [label="AAV-BDNF\nDelivery", color="#4CAF50"];

}
