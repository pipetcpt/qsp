digraph glaucoma_qsp {
  graph [
    label="녹내장 (Glaucoma) QSP 기계론적 지도\nPrimary Open-Angle Glaucoma (POAG) · GLAUC",
    labelloc="t", labeljust="c",
    fontsize=22, fontname="Helvetica-Bold",
    bgcolor="#0d1117", fontcolor="white",
    rankdir=LR, compound=true,
    splines=ortho, nodesep=0.45, ranksep=1.1,
    pad=0.6
  ]

  node [fontname="Helvetica", fontsize=9, style=filled, shape=box, width=1.5, height=0.48]
  edge [fontname="Helvetica", fontsize=8, fontcolor="#cccccc", color="#888888", penwidth=1.1]

  // ═══════════════════════════════════════
  // CLUSTER 1: Risk Factors & Pathophysiology
  // ═══════════════════════════════════════
  subgraph cluster_risk {
    label="① 위험 인자 & 병태생리 (Risk Factors & Pathophysiology)"
    style=filled; fillcolor="#1a0808"; color="#ff6666"; fontsize=13; fontcolor="#ffaaaa"; fontname="Helvetica-Bold"

    RF_age    [label="고령 (Age > 60)\n위험도 3–8배↑", fillcolor="#4a1515", fontcolor="white"]
    RF_IOP    [label="고안압\n(Elevated IOP)\n> 21 mmHg", fillcolor="#8b0000", fontcolor="white", shape=diamond, width=1.8]
    RF_fam    [label="가족력\n(Family History)\n1st degree 4배↑", fillcolor="#4a1515", fontcolor="white"]
    RF_myopia [label="고도 근시\n(High Myopia\n≥ -6D)", fillcolor="#4a1515", fontcolor="white"]
    RF_race   [label="인종 (흑인↑3–4배)\n히스패닉↑\n(Race/Ethnicity)", fillcolor="#4a1515", fontcolor="white"]
    RF_CCT    [label="얇은 각막\n(Thin CCT < 555μm)\n편향 IOP 측정", fillcolor="#6b1515", fontcolor="white"]
    RF_disc   [label="큰 시신경유두\n(Large Optic Disc)\n취약성↑", fillcolor="#4a1515", fontcolor="white"]
    RF_DM     [label="당뇨병\n(Diabetes)\n미세혈관 병변", fillcolor="#4a1515", fontcolor="white"]
    RF_HTN    [label="전신 고혈압\n(Systemic HTN)\nOPP에 영향", fillcolor="#4a1515", fontcolor="white"]
    RF_Vasosp [label="혈관연축\n(Vasospasm)\nNTG 위험", fillcolor="#4a1515", fontcolor="white"]
    MYOC_mut  [label="MYOC 변이\n(Myocilin Q368X)\nER stress → TM 손상", fillcolor="#6b1515", fontcolor="white"]
    OPTN_mut  [label="OPTN/TBK1 변이\n(Optineurin)\nNTG 위험 유전자", fillcolor="#6b1515", fontcolor="white"]
    CDKN2B    [label="CDKN2B-AS1\n(9p21 GWAS 위험 좌위)", fillcolor="#4a1515", fontcolor="white"]
    CAV1_2    [label="CAV1/CAV2 변이\n(Caveolin 1/2)\n소주 그물 기능↓", fillcolor="#4a1515", fontcolor="white"]
    LOXL1     [label="LOXL1 변이\n낙설 녹내장 90%\n(Exfoliation)", fillcolor="#4a1515", fontcolor="white"]
    PREV_node [label="전 세계 유병률\n3.5% (40세 이상)\n6천만 명 이상", shape=ellipse, fillcolor="#3d0000", fontcolor="#ffaaaa"]

    RF_age -> RF_IOP [color="#ff4444"]
    RF_fam -> MYOC_mut [color="#ff6666"]
    MYOC_mut -> RF_IOP [label="ER 스트레스\n→ 소주 저항↑", color="#ff4444"]
    RF_CCT -> RF_IOP [style=dashed, label="IOP 과소 측정"]
  }

  // ═══════════════════════════════════════
  // CLUSTER 2: Drug PK - Topical Administration
  // ═══════════════════════════════════════
  subgraph cluster_pk {
    label="② 약물 PK — 안약 점안 (Drug PK: Topical Ophthalmic Administration)"
    style=filled; fillcolor="#080818"; color="#6699ff"; fontsize=13; fontcolor="#aabbff"; fontname="Helvetica-Bold"

    LAT_DROP   [label="라타노프로스트\n0.005% 안약 QD\n(Latanoprost)", fillcolor="#1a2550", fontcolor="white", shape=ellipse]
    LAT_CORNEA [label="각막 투과·활성화\n(Corneal Permeation)\n에스테르 → 산(active)\nBioavail ~4%", fillcolor="#1a2550", fontcolor="white"]
    LAT_AC     [label="전방 라타노프로스트산\n(Latanoprost Acid AC)\nCmax~30 ng/mL · t½~2h", fillcolor="#2a3570", fontcolor="white", shape=box3d]
    LAT_PLASMA [label="혈장 라타노프로스트\n(Plasma Conc.)\nt½~17분 전신 소실", fillcolor="#1a2550", fontcolor="white"]

    TIM_DROP   [label="티몰롤\n0.5% 안약 BID\n(Timolol)", fillcolor="#1a3550", fontcolor="white", shape=ellipse]
    TIM_AC     [label="전방 티몰롤\n(Timolol AC)\nCmax~400 ng/mL", fillcolor="#2a4560", fontcolor="white", shape=box3d]
    TIM_PLASMA [label="전신 흡수 티몰롤\n(Systemic Timolol)\n비루관 흡수 ~80%\n→ 서맥·기관지연축", fillcolor="#1a3550", fontcolor="white"]

    DZL_DROP   [label="도르졸아마이드\n2% 안약 TID\n(Dorzolamide)", fillcolor="#1a4550", fontcolor="white", shape=ellipse]
    DZL_AC     [label="전방 도르졸아마이드\n(Dorzolamide AC)\nCA-II 비가역 결합", fillcolor="#2a5560", fontcolor="white", shape=box3d]
    DZL_RBC    [label="적혈구 내 축적\n(RBC Accumulation)\nt½~147일", fillcolor="#1a4040", fontcolor="white"]

    BRI_DROP   [label="브리모니딘\n0.2% 안약 TID\n(Brimonidine)", fillcolor="#1a5050", fontcolor="white", shape=ellipse]
    BRI_AC     [label="전방 브리모니딘\n(Brimonidine AC)\nα2-AR Kd~5nM", fillcolor="#2a6060", fontcolor="white", shape=box3d]
    BRI_CNS    [label="혈뇌장벽 통과\n(BBB Penetration)\nCNS 부작용: 졸음", fillcolor="#1a4545", fontcolor="white"]

    NET_DROP   [label="네타수딜\n0.02% 안약 QD\n(Netarsudil AR-13324)", fillcolor="#154050", fontcolor="white", shape=ellipse]
    NET_AC     [label="전방 네타수딜\n(Netarsudil AC)\nROCK1/2 IC50~5nM", fillcolor="#206060", fontcolor="white", shape=box3d]
    NET_METAB  [label="네타수딜 산(AR-13503)\n(Active Metabolite)\nNET 억제 추가", fillcolor="#154040", fontcolor="white"]

    COMBO_LT   [label="라타노프로스트+티몰롤\n복합 안약 QD\n(Fixed-dose Combo)", fillcolor="#1a2050", fontcolor="white", shape=diamond, width=2.0]
    RHOPRESSA  [label="네타수딜+라타노프로스트\n0.02%/0.005% QD\n(Rocklatan®)", fillcolor="#1a2050", fontcolor="white"]
    BIMATOPROST [label="비마토프로스트\n0.01/0.03% QD\n(Lumigan®)\nFP+EP 작용", fillcolor="#1a2540", fontcolor="white"]

    LAT_DROP -> LAT_CORNEA -> LAT_AC
    LAT_AC -> LAT_PLASMA [label="전신 흡수 ~1%"]
    TIM_DROP -> TIM_AC
    TIM_AC -> TIM_PLASMA [label="nasolacrimal 전신"]
    DZL_DROP -> DZL_AC
    DZL_AC -> DZL_RBC [label="전신 흡수 후 RBC"]
    BRI_DROP -> BRI_AC
    BRI_AC -> BRI_CNS [label="지용성↑ → BBB"]
    NET_DROP -> NET_AC
    NET_AC -> NET_METAB [label="에스테르가수분해"]
    COMBO_LT -> LAT_DROP [label="병용 성분"]
    COMBO_LT -> TIM_DROP [label="병용 성분"]
    RHOPRESSA -> NET_DROP
    RHOPRESSA -> LAT_DROP
  }

  // ═══════════════════════════════════════
  // CLUSTER 3: Molecular Targets & Signaling
  // ═══════════════════════════════════════
  subgraph cluster_sig {
    label="③ 분자 표적 & 세포내 신호 (Molecular Targets & Intracellular Signaling)"
    style=filled; fillcolor="#081818"; color="#44ddcc"; fontsize=13; fontcolor="#88ffee"; fontname="Helvetica-Bold"

    FP_R      [label="FP 수용체\n(Prostaglandin F2α R)\n섬모체 근육 발현", fillcolor="#1a3535", fontcolor="white", shape=hexagon]
    Gq11      [label="Gq/11 단백질\n(Gq/11 G-protein)", fillcolor="#1a3535", fontcolor="white"]
    PLC_b     [label="PLC-β\n(Phospholipase Cβ)", fillcolor="#1a3535", fontcolor="white"]
    IP3_DAG   [label="IP3 / DAG\n(2nd Messengers)", fillcolor="#1a3535", fontcolor="white"]
    PKC_act   [label="PKC 활성화\n(PKC Activation)", fillcolor="#1a3535", fontcolor="white"]
    MMP1_3    [label="MMP-1/3 발현↑\n(MMP Upregulation)\n섬모체 근육", fillcolor="#2a4545", fontcolor="white", shape=box3d]
    ECM_CM    [label="섬모체 근육 ECM 재형성\n(Ciliary Muscle\nECM Remodeling)", fillcolor="#2a5050", fontcolor="white", shape=box3d]

    BETA2_AR  [label="β2-AR\n(β2-Adrenergic Receptor)\n모양체 비색소 상피", fillcolor="#153540", fontcolor="white", shape=hexagon]
    GS_prot   [label="Gs 단백질\n(Gs Protein)", fillcolor="#153540", fontcolor="white"]
    AC_enz    [label="아데닐산 고리화효소\n(Adenylyl Cyclase)", fillcolor="#153540", fontcolor="white"]
    cAMP_CIL  [label="cAMP ↓↑\n모양체 상피\n(Ciliary Epithelium cAMP)", fillcolor="#1a4545", fontcolor="white", shape=box3d]

    ALPHA2_AR [label="α2-AR\n(α2-Adrenergic Receptor)\n모양체 상피·혈관", fillcolor="#153545", fontcolor="white", shape=hexagon]
    Gi_prot   [label="Gi 단백질\n(Gi → cAMP↓)", fillcolor="#153545", fontcolor="white"]

    CA_II_enz [label="탄산탈수효소 II\n(CA-II)\n모양체 비색소 상피", fillcolor="#152535", fontcolor="white", shape=hexagon]
    HCO3_syn  [label="HCO3- 합성↓\n→ Na+ 공동수송↓\n→ 방수 생성↓", fillcolor="#1a3040", fontcolor="white"]
    NaK_pump  [label="Na+/K+-ATPase\n(Na-K Pump)\n모양체 상피 에너지", fillcolor="#152535", fontcolor="white"]

    ROCK1_2   [label="ROCK1/ROCK2\n(Rho 키나제 1/2)\n소주 그물 세포", fillcolor="#153530", fontcolor="white", shape=hexagon]
    MLC_P     [label="MLC 인산화↑\n(MLC Phosphorylation)\n세포 수축", fillcolor="#153530", fontcolor="white"]
    ACTIN_TM  [label="소주 세포 액틴↓\n(TM Cell Actin\nRemodeling)", fillcolor="#2a4535", fontcolor="white"]

    BDNF_sig  [label="BDNF\n(Brain-Derived NF)\n역행 수송 RNFL→RGC", fillcolor="#154020", fontcolor="white"]
    TrkB_R    [label="TrkB 수용체\n(TrkB / NTRK2)", fillcolor="#154020", fontcolor="white"]
    PI3K_Akt  [label="PI3K/Akt\n(생존 경로)", fillcolor="#154020", fontcolor="white"]
    mTOR_S    [label="mTOR\n(단백질 합성·생존)", fillcolor="#154020", fontcolor="white"]

    eNOS_e    [label="eNOS\n(내피형 산화질소합성효소)\n소주 그물·ONH 혈관", fillcolor="#153030", fontcolor="white"]
    NO_cGMP   [label="NO/cGMP↑\n(혈관 이완·유출↑\nSchlemm 확장)", fillcolor="#153030", fontcolor="white"]
    sGC_enz   [label="sGC (가용성 구아닐산\n고리화효소)\nNO 수용체", fillcolor="#153030", fontcolor="white"]

    FP_R -> Gq11 -> PLC_b -> IP3_DAG -> PKC_act -> MMP1_3 -> ECM_CM
    BETA2_AR -> GS_prot -> AC_enz -> cAMP_CIL [label="β2→Gs→AC→cAMP↑(생리)\n티몰롤 차단 → cAMP↓"]
    ALPHA2_AR -> Gi_prot -> cAMP_CIL [label="α2→Gi→cAMP↓"]
    CA_II_enz -> HCO3_syn [style=dashed, label="도르졸아마이드\n억제"]
    HCO3_syn -> NaK_pump [label="의존적"]
    ROCK1_2 -> MLC_P -> ACTIN_TM [label="ROCK→MLC인산화\n→소주 경직↑(병리)"]
    BDNF_sig -> TrkB_R -> PI3K_Akt -> mTOR_S
    eNOS_e -> NO_cGMP
    NO_cGMP -> sGC_enz -> cAMP_CIL [style=dashed, label="간접 조절"]
  }

  // ═══════════════════════════════════════
  // CLUSTER 4: Aqueous Humor Dynamics
  // ═══════════════════════════════════════
  subgraph cluster_aq {
    label="④ 방수 역학 (Aqueous Humor Dynamics)"
    style=filled; fillcolor="#081a0e"; color="#44dd88"; fontsize=13; fontcolor="#88ffaa"; fontname="Helvetica-Bold"

    CIL_BODY  [label="모양체 (Ciliary Body)\n비색소 상피 → 방수 분비\n색소 상피 → 구조 지지", fillcolor="#153520", fontcolor="white"]
    AQ_PROD   [label="방수 생성률\n(Aqueous Production F)\n~2.5 μL/min (기저치)\n일중 변동: 야간 50% ↓", fillcolor="#1a4530", fontcolor="white", shape=box3d, width=2.2]

    ANT_CHAM  [label="전방 (Anterior Chamber)\n용량 ~250 μL\n단백질 농도 < 0.5 g/L\nPh=7.5~7.6", fillcolor="#1a4040", fontcolor="white", shape=ellipse, width=2.2]
    POST_CHAM [label="후방 (Posterior Chamber)\n용량 ~60 μL\n모양체돌기로 분비", fillcolor="#153530", fontcolor="white"]
    LENS      [label="수정체 (Lens)\n영양 공급 매개\n방수 흐름 경로", fillcolor="#152020", fontcolor="white"]

    TRAB_MESH [label="소주 그물\n(Trabecular Meshwork)\n주 유출로 75%\n압력 의존성", fillcolor="#1a4530", fontcolor="white", shape=component, width=2.0]
    JCT_LAYER [label="소주관 주변층\n(Juxtacanalicular Layer)\n최대 유출 저항 부위\n(~50-70% TM 저항)", fillcolor="#1a4530", fontcolor="white"]
    SCHLEMM_C [label="슐렘관\n(Schlemm's Canal)\n360° 연속 채널\n집합관으로 배출", fillcolor="#2a5040", fontcolor="white", shape=component]
    COLL_CH   [label="수집관·수성정맥\n(Collector Channels\n& Aqueous Veins)", fillcolor="#1a4030", fontcolor="white"]
    EPI_VEN   [label="공막 표면 정맥\n(Episcleral Veins)\n→ 혈관으로 귀환", fillcolor="#1a4030", fontcolor="white"]

    UVEO_SCP  [label="포도막·공막 유출로\n(Uveoscleral Pathway)\n25% · 압력 비의존\n라타노프로스트 주 표적", fillcolor="#154030", fontcolor="white", shape=component, width=2.0]
    IRIS_STR  [label="홍채 기질\n(Iris Stroma)\n → 섬모체 상부로", fillcolor="#153525", fontcolor="white"]
    SUPRA_CIL [label="섬모체 상부 공간\n(Supraciliary Space)\n→ 공막 흡수", fillcolor="#153525", fontcolor="white"]

    C_TRAB    [label="소주 유출 용이도 (C)\n정상: 0.20–0.30 μL/min/mmHg\n녹내장: < 0.15", fillcolor="#1a4535", fontcolor="white", shape=note]
    FU_UVEA   [label="포도막 유출량 (Fu)\n정상: 0.3–0.5 μL/min\n프로스타글란딘 효과↑", fillcolor="#153530", fontcolor="white", shape=note]
    EVP_node  [label="공막정맥압 (Pv)\n정상: 8–11 mmHg\n전신 CVP와 연동", fillcolor="#152025", fontcolor="white", shape=note]

    AQP1_prot [label="아쿠아포린-1\n(Aquaporin-1)\n모양체 상피·RBC", fillcolor="#152020", fontcolor="white"]
    AQP4_prot [label="아쿠아포린-4\n(Aquaporin-4)\n망막 뮬러 세포", fillcolor="#152020", fontcolor="white"]

    CIL_BODY -> POST_CHAM -> ANT_CHAM [label="분비 → 후방 → 전방"]
    ANT_CHAM -> LENS [label="영양"]
    AQ_PROD -> ANT_CHAM [label="순생성"]
    ANT_CHAM -> TRAB_MESH [label="전방각을 통해"]
    TRAB_MESH -> JCT_LAYER -> SCHLEMM_C -> COLL_CH -> EPI_VEN
    ANT_CHAM -> UVEO_SCP [label="홍채 뿌리 통과"]
    UVEO_SCP -> IRIS_STR -> SUPRA_CIL
  }

  // ═══════════════════════════════════════
  // CLUSTER 5: IOP Dynamics
  // ═══════════════════════════════════════
  subgraph cluster_IOP {
    label="⑤ 안압 동태 & 치료 목표 (IOP Dynamics & Therapeutic Targets)"
    style=filled; fillcolor="#1a1a08"; color="#ffdd44"; fontsize=13; fontcolor="#ffee88"; fontname="Helvetica-Bold"

    IOP_MAIN  [label="안압 (IOP)\n정상: 10–21 mmHg\n평균: ~15.5 mmHg", fillcolor="#554400", fontcolor="white", shape=doubleoctagon, width=2.5, height=0.9]

    GOLDMANN  [label="Goldman 방정식\n IOP = (F – Fu)/C + Pv\nF=생성율(2.5 μL/min)\nFu=포도막유출(0.4)\nC=소주용이도(0.22)\nPv=정맥압(9mmHg)", fillcolor="#4a4010", fontcolor="white", shape=note, width=3.0]

    IOP_DIURN [label="일중 변동\n(Diurnal Variation)\n오전 최고 (6–8시)\n수면 중 최저", fillcolor="#3a3000", fontcolor="white"]

    IOP_MECH  [label="고안압 기계적 손상\n사상판 후방 이동\n축삭 이동 장애\n(IOP > 21 mmHg)", fillcolor="#6a4500", fontcolor="white"]

    IOP_VASC  [label="고안압 혈관성 손상\n관류압 감소\nOPP = 2/3·MAP – IOP\n(Ocular Perfusion Pressure)", fillcolor="#5a3500", fontcolor="white"]

    TARGET_IOP [label="치료 목표 IOP\n(Target IOP)\n기저치 25–30% ↓\n진행 녹내장: 12–15 mmHg\nNTG: < 12 mmHg", fillcolor="#3a4000", fontcolor="white", shape=note, width=2.5]

    IOP_MILD  [label="경증: 21–24 mmHg\n1차 약물 단독", fillcolor="#2a3000", fontcolor="white"]
    IOP_MOD   [label="중등도: 25–30 mmHg\n2제 병용 요법", fillcolor="#3a3500", fontcolor="white"]
    IOP_SEV   [label="고도: > 30 mmHg\n3제 병용+수술", fillcolor="#5a4000", fontcolor="white"]

    SLT_node  [label="선택 레이저 소주성형술\n(SLT: Selective Laser\nTrabeculoplasty)\nIOP ↓ ~25% · 반복 가능\nLiGHT trial: 1차 치료 우세", fillcolor="#403500", fontcolor="white", shape=diamond]

    ALT_node  [label="아르곤 레이저 소주성형술\n(ALT) · SLT 대안\nIOP ↓ 20–25%", fillcolor="#363000", fontcolor="white"]

    TRABS_node [label="섬유주 절개술\n(Trabeculectomy)\nIOP ↓ 40–50%\n불투과 수포 형성\n5년 성공 70–80%", fillcolor="#503500", fontcolor="white", shape=diamond]

    MIGS_node [label="미세 침습 녹내장 수술\n(MIGS)\n·iStent·Hydrus·GATT\nIOP ↓ 20–35%", fillcolor="#404000", fontcolor="white"]

    IOP_MAIN -> IOP_MECH [label="IOP > 21"]
    IOP_MAIN -> IOP_VASC [label="OPP↓"]
    GOLDMANN -> IOP_MAIN [label="수식"]
    IOP_MILD -> IOP_MOD -> IOP_SEV [label="단계적 강화"]
    SLT_node -> C_TRAB [lhead=cluster_aq, style=dashed, label="소주 유출↑"]
  }

  // ═══════════════════════════════════════
  // CLUSTER 6: Optic Nerve Head Biology
  // ═══════════════════════════════════════
  subgraph cluster_ONH {
    label="⑥ 시신경 유두 생물학 (Optic Nerve Head Biology)"
    style=filled; fillcolor="#0e0818"; color="#9966ff"; fontsize=13; fontcolor="#ccaaff"; fontname="Helvetica-Bold"

    ONH_main  [label="시신경 유두\n(Optic Nerve Head)\n직경 1.5mm\nRGC 축삭 통과 지점", fillcolor="#2a1a40", fontcolor="white", shape=ellipse, width=2.0]

    LAMINA_C  [label="사상판\n(Lamina Cribrosa)\nRGC 축삭 통과 구조\n벌집 모양 콜라겐", fillcolor="#2a1a40", fontcolor="white", shape=component]

    LC_DEFORM [label="사상판 변형\n(LC Deformation)\nIOP↑ → 후방 이동\nkinking 및 비틀림", fillcolor="#3a2050", fontcolor="white"]

    AXON_TRAN [label="축삭 이동 장애\n(Axonal Transport\nImpairment)\n순행/역행 모두 차단\nBDNF 이동 차단 → RGC↓", fillcolor="#3a2550", fontcolor="white"]

    ONH_ASTRO [label="ONH 성상세포\n(ONH Astrocytes)\nIOP↑ → 활성화\nTGF-β·MMP 분비", fillcolor="#2a1a35", fontcolor="white"]

    MICROGLIA [label="미세아교세포\n(Microglia)\nM1 표현형 활성화\n신경독성 사이토카인", fillcolor="#2a1a35", fontcolor="white"]

    TNFa_ONH  [label="TNF-α\n(시신경 유두 내)\nRGC 아포토시스 유도", fillcolor="#3a1530", fontcolor="white"]

    ONH_CIRC  [label="시신경 유두 혈류\n(ONH Microcirculation)\n단 후모양체 동맥\n자동 조절 범위: IOP 10–35", fillcolor="#251535", fontcolor="white"]

    OPP_calc  [label="안구 관류압\n(OPP)\n= 2/3·MAP – IOP\n정상 > 40 mmHg", fillcolor="#2a1540", fontcolor="white", shape=note]

    ISCHEMIA  [label="ONH 허혈\n(ONH Ischemia)\n관류압 < 40 → 위험\nNTG 중요 기전", fillcolor="#401540", fontcolor="white"]

    GLUTAMATE [label="글루타메이트 독성\n(Glutamate\nExcitotoxicity)\nNMDA 수용체 과활성\nCa²⁺ 내유↑", fillcolor="#3a1540", fontcolor="white"]

    ROS_ONH   [label="활성 산소 (ROS)\n미토콘드리아 복합체 I↓\nMnSOD·GPx↓", fillcolor="#3a1540", fontcolor="white"]

    COLLAGEN_LC [label="사상판 콜라겐\n(LC Collagen Type I/IV)\n고령·녹내장 → 탄성↓\n강직↑", fillcolor="#251530", fontcolor="white"]

    ELAST_LC  [label="엘라스틴 감소\n(Elastin Loss)\n취약성↑\n압력 완충 실패", fillcolor="#251530", fontcolor="white"]

    ONH_main -> LAMINA_C -> LC_DEFORM
    LC_DEFORM -> AXON_TRAN [label="물리적 압박"]
    ONH_ASTRO -> MICROGLIA -> TNFa_ONH
    ONH_CIRC -> OPP_calc -> ISCHEMIA [label="관류압 감소"]
    ISCHEMIA -> GLUTAMATE -> ROS_ONH
    LAMINA_C -> COLLAGEN_LC
    COLLAGEN_LC -> ELAST_LC
  }

  // ═══════════════════════════════════════
  // CLUSTER 7: RGC Pathology
  // ═══════════════════════════════════════
  subgraph cluster_RGC {
    label="⑦ 망막 신경절 세포 병리 (Retinal Ganglion Cell Pathology)"
    style=filled; fillcolor="#1a0e08"; color="#ff8844"; fontsize=13; fontcolor="#ffaa88"; fontname="Helvetica-Bold"

    RGC_POOL  [label="망막 신경절 세포\n(Retinal Ganglion Cells)\n정상 ~1.2×10⁶ cells\n~5,000/mm² (황반부)", fillcolor="#3a1500", fontcolor="white", shape=box3d, width=2.5]

    RGC_DENDRITE [label="수상돌기 위축\n(Dendritic Atrophy)\n기능 저하 선행\n수상돌기 복잡도↓", fillcolor="#3a1500", fontcolor="white"]
    RGC_SOMA    [label="세포체 수축\n(Soma Shrinkage)\n아포토시스 직전 단계\n직경 감소", fillcolor="#3a1500", fontcolor="white"]

    RGC_APOP   [label="RGC 아포토시스\n(RGC Apoptosis)\nCasp-3/9 활성화\n비가역적 소실", fillcolor="#5a2000", fontcolor="white"]

    BAX_BCL2  [label="Bax/Bcl-2 비율\n(Pro/Anti-apoptosis)\nBax↑ Bcl-2↓ → 사멸", fillcolor="#4a2000", fontcolor="white"]
    CYTO_C    [label="사이토크롬 C 방출\n(Cytochrome C)\n미토콘드리아 외막 투과\n→ Apoptosome", fillcolor="#4a1500", fontcolor="white"]
    CASP9     [label="카스파제-9\n(Caspase-9)\n개시 카스파제\n→ 카스파제-3 활성화", fillcolor="#4a1800", fontcolor="white"]
    CASP3     [label="카스파제-3\n(Caspase-3)\n실행 카스파제\nPARP 절단·DNA 단편화", fillcolor="#5a2000", fontcolor="white"]

    RGC_M     [label="M세포 (대세포형)\n빠른 신호·운동 감지\n초기 손상 취약", fillcolor="#3a1800", fontcolor="white"]
    RGC_P     [label="P세포 (소세포형)\n색채·세밀 시각\n황반 중심 밀집", fillcolor="#3a1800", fontcolor="white"]
    RGC_ipRGC [label="내인성 광수용 RGC\n(ipRGC·melanopsin)\n생체리듬 조절", fillcolor="#3a1800", fontcolor="white"]

    AXON_DEG  [label="시신경 축삭 변성\n(Optic Nerve\nAxon Degeneration)", fillcolor="#5a2500", fontcolor="white"]
    RNFL_LOSS [label="망막 신경 섬유층 소실\n(RNFL Loss)\n소실 속도 ~1.5 μm/yr\n정상 100–120 μm", fillcolor="#6a2800", fontcolor="white", shape=box3d]

    RGC_POOL -> RGC_DENDRITE -> RGC_SOMA -> RGC_APOP [label="손상 진행 순서"]
    BAX_BCL2 -> CYTO_C -> CASP9 -> CASP3
    RGC_APOP -> CASP9
    RGC_APOP -> AXON_DEG -> RNFL_LOSS
    RGC_POOL -> RGC_M
    RGC_POOL -> RGC_P
    RGC_POOL -> RGC_ipRGC
  }

  // ═══════════════════════════════════════
  // CLUSTER 8: Neuroprotection
  // ═══════════════════════════════════════
  subgraph cluster_NP {
    label="⑧ 신경보호 (Neuroprotection Strategies)"
    style=filled; fillcolor="#081808"; color="#44cc44"; fontsize=13; fontcolor="#88ff88"; fontname="Helvetica-Bold"

    BRI_NP    [label="브리모니딘 신경보호\n(Brimonidine NP)\nBDNF↑·Akt↑\n(BMACS trial: 진행 차이 없음)", fillcolor="#1a5030", fontcolor="white"]

    MEMANTINE [label="메만틴\n(Memantine 20mg QD)\nNMDA 차단 → Ca²⁺↓\n(COGNIS Ph3: 실패)", fillcolor="#153020", fontcolor="white"]

    CITICOLINE [label="시티콜린\n(Citicoline 500mg/d)\n막 인지질 보호\n소규모 양성 결과", fillcolor="#153020", fontcolor="white"]

    VIT_E_NP  [label="항산화 치료\n(Vit E/C·CoQ10)\nROS↓→ 미토콘드리아\n보호 (전임상 근거)", fillcolor="#153020", fontcolor="white"]

    CNTF_th   [label="CNTF\n(Ciliary Neurotrophic\nFactor)\nRGC 생존 지지\n(Phase 2 진행 중)", fillcolor="#102015", fontcolor="white"]

    AAV_BDNF  [label="AAV-BDNF 유전자치료\n(Gene Therapy)\nBDNF 과발현 → RGC↑\n(전임상 성공)", fillcolor="#102015", fontcolor="white"]

    STEM_RGC  [label="줄기세포 치료\n(Stem Cell / iPSC)\nRGC 재생 시도\n(초기 임상 개발)", fillcolor="#102015", fontcolor="white"]

    OPTOGEN   [label="광유전학\n(Optogenetics)\nChR2·ReaChR AAV\n시력 복원 (실험)", fillcolor="#102015", fontcolor="white"]

    NP_BIOMARKER [label="신경보호 바이오마커\n(NP Biomarkers)\nNfL·GFAP·pNfH\n혈청/CSF 측정", fillcolor="#102015", fontcolor="white"]

    BRI_NP -> BDNF_sig [lhead=cluster_sig, style=dashed, color="#44cc44", label="BDNF↑"]
    MEMANTINE -> GLUTAMATE [lhead=cluster_ONH, style=dashed, color="#44cc44", label="NMDA 차단"]
    AAV_BDNF -> BDNF_sig [lhead=cluster_sig, style=dashed, color="#44cc44"]
  }

  // ═══════════════════════════════════════
  // CLUSTER 9: Clinical Endpoints & Monitoring
  // ═══════════════════════════════════════
  subgraph cluster_EP {
    label="⑨ 임상 평가 지표 & 모니터링 (Clinical Endpoints & Monitoring)"
    style=filled; fillcolor="#0f0f0f"; color="#aaaaaa"; fontsize=13; fontcolor="#cccccc"; fontname="Helvetica-Bold"

    IOP_EP    [label="안압 (IOP)\n치료 목표 달성률\n피크/트로프 측정\n비접촉·Goldmann", fillcolor="#1a1a25", fontcolor="white", shape=box3d]

    RNFL_EP   [label="RNFL 두께\n(OCT-RNFL)\n정상: 100–120 μm\n< 80 μm → 구조 이상\n소실 속도 1.5 μm/yr", fillcolor="#251525", fontcolor="white", shape=box3d]

    VF_EP     [label="시야 검사\n(Humphrey VF)\nMD (dB)·PSD·VFI(%)\n24-2·30-2 패턴\n신뢰성 지수 확인", fillcolor="#251525", fontcolor="white", shape=box3d]

    GCC_EP    [label="신경절세포복합체\n(GCC/GCIPL)\n마쿠라 OCT\nRGC 직접 측정 대리\n정상 80–100 μm", fillcolor="#202020", fontcolor="white", shape=box3d]

    DISC_EP   [label="시신경 유두 형태\n(Optic Disc Eval)\nC/D 비율 < 0.6 정상\nβ-구역 PPA (주변 위축)", fillcolor="#202020", fontcolor="white"]

    AGIS_SC   [label="AGIS 점수\n(Advanced Glaucoma\nIntervention Study)\n0–20점 (중증도)", fillcolor="#1a1a1a", fontcolor="white"]

    VFI_pct   [label="VFI (%)\n(Visual Field Index)\n0–100%\n100% = 정상 시야", fillcolor="#1a1a1a", fontcolor="white"]

    MD_RATE   [label="MD 악화 속도\n(MD Progression Rate)\n< –1.0 dB/yr = 빠른 진행\n목표: < –0.5 dB/yr", fillcolor="#252520", fontcolor="white"]

    QOL_VFQ  [label="삶의 질 (QoL)\nNEI-VFQ-25\nGSS (Glaucoma\nSymptom Scale)", fillcolor="#1a1a1a", fontcolor="white"]

    TONOMETRY [label="안압 측정\n(Tonometry)\nGoldmann GAT 표준\nCCT 보정 필요\n얇은 각막 → 실측 < 실제", fillcolor="#1a1a1a", fontcolor="white"]

    OHTS_RISK [label="OHTS 위험 계산기\n5년 POAG 위험\n→ 치료 결정 보조\n(IOP·CCT·C/D·PSD·나이)", fillcolor="#151515", fontcolor="white", shape=note]

    NfL_blood [label="혈중 NfL\n(Serum NfL)\n신경 손상 바이오마커\n녹내장 진행과 상관", fillcolor="#151515", fontcolor="white"]

    GFAP_bl   [label="혈중 GFAP\n(Serum GFAP)\n성상세포 활성화\n마커", fillcolor="#151515", fontcolor="white"]

    IOP_EP -> VF_EP [label="IOP↓ → VF 안정"]
    IOP_EP -> RNFL_EP [label="구조 보호"]
    RNFL_EP -> VF_EP [label="구조-기능 상관\n~20% RNFL 소실 후 VF↓"]
    VF_EP -> MD_RATE
    VF_EP -> VFI_pct
    VF_EP -> AGIS_SC
    VF_EP -> QOL_VFQ
  }

  // ═══════════════════════════════════════
  // CLUSTER 10: Special Glaucoma Types
  // ═══════════════════════════════════════
  subgraph cluster_types {
    label="⑩ 녹내장 유형 분류 (Glaucoma Classification & Special Types)"
    style=filled; fillcolor="#0e0e1a"; color="#8888ff"; fontsize=13; fontcolor="#aaaaff"; fontname="Helvetica-Bold"

    POAG_type [label="원발 개방각 녹내장\n(POAG)\n전 세계 유병 1위\nIOP > 21 or normal\n개방각 + 시신경 손상", fillcolor="#1a1a40", fontcolor="white", shape=ellipse]

    NTG_type  [label="정상 안압 녹내장\n(NTG)\nIOP ≤ 21 mmHg\n혈관·허혈 기전 우세\n(CNTGS: IOP ↓30% 효과)", fillcolor="#151530", fontcolor="white", shape=ellipse]

    PACG_type [label="원발 폐쇄각 녹내장\n(PACG)\n홍채 전방 이동 → 각도 폐쇄\n아시아 여성 많음\n레이저 홍채절제술", fillcolor="#1a1a40", fontcolor="white"]

    EXFOL_G   [label="낙설 녹내장\n(Exfoliation Glaucoma)\nLOXL1 변이\n낙설 물질 소주 폐색\n고령 스칸디나비아↑", fillcolor="#1a1540", fontcolor="white"]

    PIGMENT_G [label="색소 녹내장\n(Pigmentary)\n홍채 색소 상피 소실\n소주 그물 폐색\n젊은 근시 남성", fillcolor="#1a1535", fontcolor="white"]

    STEROID_G [label="스테로이드 유발 녹내장\n(Steroid-Induced)\nGR → MYOC↑ → TM 저항↑\n안약·전신·흡입 스테로이드", fillcolor="#201530", fontcolor="white"]

    NVG_type  [label="신생혈관 녹내장\n(Neovascular)\nDM·CRVO → VEGF↑\n각도 신생혈관 → 폐쇄\nAnti-VEGF + 수술", fillcolor="#201530", fontcolor="white"]

    CONG_G    [label="선천 녹내장\n(Congenital)\nCYP1B1 변이\n각도 발달 이상\n조기 수술 필요", fillcolor="#151535", fontcolor="white"]

    OCULAR_HTN [label="안구 고혈압\n(Ocular Hypertension)\nIOP > 21 but 정상 시신경\n치료 여부: OHTS 가이드", fillcolor="#151530", fontcolor="white"]

    NTG_type -> NTG_type [style=invis]
    POAG_type -> NTG_type [label="연속 스펙트럼"]
    STEROID_G -> MYOC_mut [lhead=cluster_risk, style=dashed, label="MYOC↑"]
  }

  // ═══════════════════════════════════════
  // CLUSTER 11: Drug Pharmacodynamics
  // ═══════════════════════════════════════
  subgraph cluster_PD {
    label="⑪ 약물 약력학 정량 효과 (Quantitative Drug Pharmacodynamics)"
    style=filled; fillcolor="#0a0a18"; color="#66aaff"; fontsize=13; fontcolor="#aaddff"; fontname="Helvetica-Bold"

    LAT_EFF   [label="라타노프로스트 효과\n포도막 유출↑ 60–100%\nIOP ↓ 25–32%\n밤 점안 효과 더 좋음\n각막 멜라닌 색소 침착", fillcolor="#1a2050", fontcolor="white", shape=note]

    TIM_EFF   [label="티몰롤 효과\n방수 생성↓ 20–30%\nIOP ↓ 20–25%\n전신 β1 차단 주의\n(서맥·기관지경련)", fillcolor="#1a3050", fontcolor="white", shape=note]

    DZL_EFF   [label="도르졸아마이드 효과\n방수 생성↓ 15–20%\nIOP ↓ 15–20%\n라타노프로스트 부가효과\n각막 내피 독성 주의", fillcolor="#1a3545", fontcolor="white", shape=note]

    BRI_EFF   [label="브리모니딘 효과\n방수 생성↓ 15–25%\n포도막 유출↑ 15%\nIOP ↓ 18–20%\nCNS 부작용: 졸음·구강건조", fillcolor="#1a4045", fontcolor="white", shape=note]

    NET_EFF   [label="네타수딜 효과\n소주 유출↑ 15–20%\n방수 생성↓ 5–10%\nIOP ↓ 15–20%\n출혈성 각막결막부종 25%", fillcolor="#1a3040", fontcolor="white", shape=note]

    COMBO_EFF [label="병용 부가 효과\n라타노+티몰 = ↓35%\n3제 병용 = ↓40–45%\n부가효과 (거의 선형)", fillcolor="#152040", fontcolor="white", shape=note]

    SLT_EFF   [label="SLT 효과\nIOP ↓ 20–30%\n반복 가능 (2년 후)\nLiGHT trial 2019:\n초기 치료로 약물보다\n목표 IOP 달성률↑", fillcolor="#202040", fontcolor="white", shape=note]

    TRABS_EFF [label="섬유주 절개술 효과\nIOP ↓ 40–50%\n수포 관리 필요\n5년 성공: 70–80%\n백내장·저안압 합병증", fillcolor="#252540", fontcolor="white", shape=note]
  }

  // ═══════════════════════════════════════
  // CLUSTER 12: Visual Pathway & Functional Impact
  // ═══════════════════════════════════════
  subgraph cluster_vis {
    label="⑫ 시각 경로 & 기능적 영향 (Visual Pathway & Functional Impact)"
    style=filled; fillcolor="#081008"; color="#66ff66"; fontsize=13; fontcolor="#aaff88"; fontname="Helvetica-Bold"

    RETINA_L  [label="망막 (Retina)\n광수용체→양극세포\n→아마크린세포→RGC", fillcolor="#152015", fontcolor="white"]
    ON_FIBER  [label="시신경 (Optic Nerve)\n1.2×10⁶ RGC 축삭\n직경 3–4 mm", fillcolor="#152520", fontcolor="white"]
    OPTIC_CH  [label="시신경 교차\n(Optic Chiasm)\n코쪽 섬유 교차", fillcolor="#152020", fontcolor="white"]
    LGN_node  [label="외측 슬상체\n(LGN)\n시상 중계 핵", fillcolor="#152020", fontcolor="white"]
    V1_cortex [label="일차 시각 피질 (V1)\n후두엽 (후두극)\n시야 표상", fillcolor="#152020", fontcolor="white"]

    VF_PATTERN [label="녹내장 시야 결손 패턴\n·비측 계단형\n·Bjerum 弓형 (상/하)\n·중심주변 신월형\n·반맹 구역형", fillcolor="#1a2520", fontcolor="white", shape=note]

    CENT_VIS  [label="중심 시력 보존\n(Central Vision)\n황반 회피 현상\n말기까지 보존됨", fillcolor="#152020", fontcolor="white"]

    TUNNEL_V  [label="터널 시야\n(Tunnel Vision)\n말기 녹내장\nVFI < 20%", fillcolor="#3a1500", fontcolor="white"]

    BLINDNESS [label="실명 (Blindness)\n세계 3위 실명 원인\n비가역·예방 가능\n연 7만 명 (한국)", fillcolor="#5a0000", fontcolor="white", shape=octagon]

    READING   [label="읽기 능력 저하\n(Reading Difficulty)\nVF 30% 소실 시", fillcolor="#152015", fontcolor="white"]
    DRIVING   [label="운전 능력 제한\n(Driving)\nMD < –12 dB\n(법적 제한)", fillcolor="#152015", fontcolor="white"]
    FALLS     [label="낙상 위험 2배↑\n(Falls Risk)\n대비 감도 저하\n보행 위험", fillcolor="#201510", fontcolor="white"]
    DEPRESSION [label="우울·불안 증가\n(Depression/Anxiety)\n삶의 질↓\n사회 활동 제한", fillcolor="#201510", fontcolor="white"]

    RETINA_L -> ON_FIBER -> OPTIC_CH -> LGN_node -> V1_cortex
    V1_cortex -> VF_PATTERN
    VF_PATTERN -> CENT_VIS
    VF_PATTERN -> TUNNEL_V -> BLINDNESS
    VF_PATTERN -> READING
    VF_PATTERN -> DRIVING
    VF_PATTERN -> FALLS
    BLINDNESS -> DEPRESSION
  }

  // ═══════════════════════════════════════════════════
  // INTER-CLUSTER CONNECTIONS
  // ═══════════════════════════════════════════════════

  // Risk → IOP
  RF_IOP -> IOP_MAIN [ltail=cluster_risk, lhead=cluster_IOP, color="#ff4444", penwidth=2.5, label="직접 IOP↑"]

  // Drug PK → Molecular Targets
  LAT_AC -> FP_R   [lhead=cluster_sig, color="#6699ff", penwidth=2.0, label="FP 효현"]
  TIM_AC -> BETA2_AR [lhead=cluster_sig, color="#6699ff", penwidth=2.0, label="β2 길항"]
  DZL_AC -> CA_II_enz [lhead=cluster_sig, color="#6699ff", penwidth=2.0, label="CA-II 억제"]
  BRI_AC -> ALPHA2_AR [lhead=cluster_sig, color="#6699ff", penwidth=2.0, label="α2 효현"]
  NET_AC -> ROCK1_2 [lhead=cluster_sig, color="#6699ff", penwidth=2.0, label="ROCK 억제"]

  // Signaling → Aqueous Dynamics
  ECM_CM -> UVEO_SCP [ltail=cluster_sig, lhead=cluster_aq, color="#44ddcc", penwidth=2.0, label="섬모체근육 ECM→\n포도막 유출↑"]
  cAMP_CIL -> AQ_PROD [ltail=cluster_sig, lhead=cluster_aq, color="#44ddcc", penwidth=2.0, label="cAMP↓→방수생성↓"]
  HCO3_syn -> AQ_PROD [ltail=cluster_sig, lhead=cluster_aq, color="#44ddcc", penwidth=2.0, label="HCO3↓→생성↓"]
  ACTIN_TM -> JCT_LAYER [ltail=cluster_sig, lhead=cluster_aq, color="#44ddcc", penwidth=2.0, label="ROCK억제→\n소주저항↓"]

  // Aqueous → IOP
  AQ_PROD -> IOP_MAIN [ltail=cluster_aq, lhead=cluster_IOP, color="#44dd88", penwidth=2.5, label="생성률 F"]
  C_TRAB -> IOP_MAIN [ltail=cluster_aq, lhead=cluster_IOP, color="#44dd88", penwidth=2.5, label="유출 용이도 C"]
  FU_UVEA -> IOP_MAIN [ltail=cluster_aq, lhead=cluster_IOP, color="#44dd88", penwidth=2.0, label="포도막 유출 Fu"]
  EVP_node -> IOP_MAIN [ltail=cluster_aq, lhead=cluster_IOP, color="#44dd88", penwidth=2.0, label="정맥압 Pv"]

  // IOP → ONH
  IOP_MAIN -> ONH_main [ltail=cluster_IOP, lhead=cluster_ONH, color="#ffdd44", penwidth=3.0, label="사상판 압박\n기계적 손상"]
  IOP_VASC -> OPP_calc [ltail=cluster_IOP, lhead=cluster_ONH, color="#ffdd44", penwidth=2.0, label="OPP↓"]

  // ONH → RGC
  AXON_TRAN -> BAX_BCL2 [ltail=cluster_ONH, lhead=cluster_RGC, color="#9966ff", penwidth=2.0, label="BDNF 결핍\n→ Bax↑"]
  TNFa_ONH -> RGC_APOP [ltail=cluster_ONH, lhead=cluster_RGC, color="#9966ff", penwidth=2.0, label="TNF-α→사멸"]
  GLUTAMATE -> RGC_APOP [ltail=cluster_ONH, lhead=cluster_RGC, color="#9966ff", penwidth=2.0, label="Ca²⁺↑→사멸"]
  ROS_ONH -> BAX_BCL2 [ltail=cluster_ONH, lhead=cluster_RGC, color="#9966ff", penwidth=2.0]

  // RGC → RNFL → Endpoint
  RNFL_LOSS -> RNFL_EP [ltail=cluster_RGC, lhead=cluster_EP, color="#ff8844", penwidth=2.5, label="OCT 측정"]
  RGC_POOL -> GCC_EP [ltail=cluster_RGC, lhead=cluster_EP, color="#ff8844", penwidth=2.0, label="GCC 두께"]

  // Endpoint → Visual Pathway
  RNFL_EP -> ON_FIBER [ltail=cluster_EP, lhead=cluster_vis, color="#66ff66", penwidth=2.0]
  VF_EP -> VF_PATTERN [ltail=cluster_EP, lhead=cluster_vis, color="#66ff66", penwidth=2.0]

  // Additional ONH → blood flow
  NO_cGMP -> ONH_CIRC [ltail=cluster_sig, lhead=cluster_ONH, color="#44ddcc", penwidth=1.5, label="혈관 이완"]
  RF_Vasosp -> ONH_CIRC [ltail=cluster_risk, lhead=cluster_ONH, color="#ff6666", penwidth=1.5, label="혈류↓"]
  RF_HTN -> OPP_calc [ltail=cluster_risk, lhead=cluster_ONH, color="#ff6666", penwidth=1.5, label="MAP에 영향"]

  // Neuroprotection → signaling/RGC
  BRI_NP -> TrkB_R [ltail=cluster_NP, lhead=cluster_sig, style=dashed, color="#44cc44", penwidth=1.5, label="BDNF↑"]
  MEMANTINE -> GLUTAMATE [ltail=cluster_NP, lhead=cluster_ONH, style=dashed, color="#44cc44", penwidth=1.5, label="NMDA 차단"]

  // Special types → pathomechanisms
  EXFOL_G -> JCT_LAYER [ltail=cluster_types, lhead=cluster_aq, style=dashed, color="#8888ff", penwidth=1.5, label="낙설물질\n소주 폐색"]
  NVG_type -> IOP_MAIN [ltail=cluster_types, lhead=cluster_IOP, style=dashed, color="#8888ff", penwidth=1.5, label="VEGF → 각도 폐쇄"]

  // IOP control → RGC protection
  TARGET_IOP -> RGC_POOL [ltail=cluster_IOP, lhead=cluster_RGC, style=dashed, color="#ffdd44", penwidth=2.0, label="치료 성공 →\nRGC 보존"]

  // Legend
  LEGEND [label="QSP 모델 요약\n━━━━━━━━━━\n구획: 26개 ODE\n약물 5종 PK/PD\n치료 시나리오: 7개\n임상시험 보정:\n· OHTS (n=1,636)\n· EMGT (n=255)\n· LiGHT (n=718)\n· CIGTS (n=607)\n· AGIS (n=591)\n엔드포인트:\nIOP·RNFL·MD·VFI\n147+ 노드 · 12 클러스터", shape=note, fillcolor="#0a1a0a", fontcolor="#88ff88", fontsize=9, width=2.8]
}
