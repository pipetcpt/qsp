digraph AddisonsQSP {
  graph [rankdir=LR, fontname="Helvetica", bgcolor="#1a1a2e",
         label="Addison's Disease (Primary Adrenal Insufficiency) — QSP Mechanistic Map\nAutoimmune Adrenalitis · HPA Axis · Steroid PK/PD · Adrenal Crisis",
         labelfontcolor="white", fontsize=20, labelloc=t, splines=true, nodesep=0.4, ranksep=1.0];
  node [fontname="Helvetica", fontsize=9, style=filled, shape=ellipse];
  edge [fontname="Helvetica", fontsize=7, color="#AAAAAA"];

  // ============================================================
  // CLUSTER 1: Drug PK / Administration
  // ============================================================
  subgraph cluster_drug_pk {
    label="Drug Administration & Pharmacokinetics"; style=filled; color="#2d1b69";
    fontcolor="white"; fontsize=13;

    HC_dose      [label="Hydrocortisone\nDose (mg/day)", shape=box, fillcolor="#4CAF50", fontcolor="black"];
    HC_imm       [label="HC Immediate\nRelease", fillcolor="#66BB6A", fontcolor="black"];
    HC_mod       [label="HC Modified\nRelease (Plenadren/Efmody)", fillcolor="#43A047", fontcolor="white"];
    HC_gut       [label="HC GI Absorption\n(Ka=1.2 h⁻¹, F=0.96)", fillcolor="#81C784", fontcolor="black"];
    HC_central   [label="HC Plasma\n(free+CBG+albumin)", fillcolor="#A5D6A7", fontcolor="black"];
    HC_free      [label="HC Free Fraction\n(fu=0.05)", fillcolor="#C8E6C9", fontcolor="black"];
    HC_CBG       [label="Cortisol-Binding\nGlobulin (CBG)", fillcolor="#DCEDC8", fontcolor="black"];
    HC_albumin   [label="Albumin-bound\nHC (≈10%)", fillcolor="#F1F8E9", fontcolor="black"];
    HC_periph    [label="HC Peripheral\nTissue (Vd=47L)", fillcolor="#CCFF90", fontcolor="black"];
    HC_elim      [label="HC Hepatic\nElimination\n(CL=90 L/h, t½=1.7h)", shape=diamond, fillcolor="#AED581", fontcolor="black"];
    HC_11BHSD2   [label="11β-HSD2\n(cortisol→cortisone)", fillcolor="#9CCC65", fontcolor="black"];
    HC_metabolite[label="Cortisone &\nUFC (urine)", fillcolor="#DCE775", fontcolor="black"];

    HC_iv        [label="HC IV Bolus\n100 mg Emergency", shape=box, fillcolor="#FF5722", fontcolor="white"];
    HC_iv_pool   [label="IV HC Plasma\nPool", fillcolor="#FF8A65", fontcolor="black"];

    FC_dose      [label="Fludrocortisone\n50–200 μg/day", shape=box, fillcolor="#1976D2", fontcolor="white"];
    FC_gut       [label="FC GI Absorption\n(Ka=1.5 h⁻¹, F=0.98)", fillcolor="#64B5F6", fontcolor="black"];
    FC_central   [label="FC Plasma\nConcentration", fillcolor="#90CAF9", fontcolor="black"];
    FC_periph    [label="FC Peripheral\nTissue", fillcolor="#BBDEFB", fontcolor="black"];
    FC_elim      [label="FC Elimination\n(t½=18–36h)", shape=diamond, fillcolor="#42A5F5", fontcolor="black"];

    DHEA_dose    [label="DHEA Supplement\n25–50 mg/day", shape=box, fillcolor="#7B1FA2", fontcolor="white"];
    DHEA_gut     [label="DHEA GI\nAbsorption", fillcolor="#CE93D8", fontcolor="black"];
    DHEA_plasma  [label="DHEA-S Plasma\n(μg/dL)", fillcolor="#BA68C8", fontcolor="black"];
    DHEA_elim    [label="DHEA-S\nElimination", shape=diamond, fillcolor="#AB47BC", fontcolor="black"];

    HC_dose -> HC_imm;
    HC_dose -> HC_mod [label="MR formulation"];
    HC_imm -> HC_gut;
    HC_mod -> HC_gut [label="delayed/slow"];
    HC_iv -> HC_iv_pool [label="bolus"];
    HC_iv_pool -> HC_central [label="rapid";color="#FF8A65"];
    HC_gut -> HC_central [label="bioavailability"];
    HC_central -> HC_free [label="fu=0.05"];
    HC_central -> HC_CBG [label="80% binding"];
    HC_central -> HC_albumin [label="10% binding"];
    HC_free -> HC_periph [label="Kpt"];
    HC_periph -> HC_central [label="Ktp"];
    HC_central -> HC_elim [label="CL"];
    HC_central -> HC_11BHSD2 [label="kidney/colon"];
    HC_11BHSD2 -> HC_metabolite;

    FC_dose -> FC_gut;
    FC_gut -> FC_central;
    FC_central -> FC_periph [label="Vd=67L"];
    FC_central -> FC_elim;

    DHEA_dose -> DHEA_gut;
    DHEA_gut -> DHEA_plasma;
    DHEA_plasma -> DHEA_elim;
  }

  // ============================================================
  // CLUSTER 2: HPA Axis & Circadian Control
  // ============================================================
  subgraph cluster_hpa {
    label="HPA Axis, Circadian Rhythm & Stress Response"; style=filled; color="#1a3a5c";
    fontcolor="white"; fontsize=13;

    SCN          [label="Suprachiasmatic\nNucleus (SCN)", shape=box, fillcolor="#FFF176", fontcolor="black"];
    zeitgeber    [label="Light/Wake\nZeitgeber", fillcolor="#FFEE58", fontcolor="black"];
    circadian    [label="Circadian\nOscillator\n(CLOCK/BMAL1)", shape=diamond, fillcolor="#FFD54F", fontcolor="black"];

    hypothalamus [label="Hypothalamus\n(PVN)", shape=box, fillcolor="#FF7043", fontcolor="white"];
    CRH          [label="CRH\n(Corticotropin-\nReleasing Hormone)", fillcolor="#FF8A65", fontcolor="black"];
    AVP          [label="AVP/Vasopressin\n(CRH synergist)", fillcolor="#FFAB91", fontcolor="black"];

    pituitary    [label="Anterior\nPituitary\n(corticotroph)", shape=box, fillcolor="#EF5350", fontcolor="white"];
    POMC         [label="POMC\n(pro-opiomelanocortin)", fillcolor="#EF9A9A", fontcolor="black"];
    ACTH         [label="ACTH\n(corticotropin, pg/mL)", fillcolor="#FFCDD2", fontcolor="black"];
    proACTH      [label="Pro-ACTH\n(inactive precursor)", fillcolor="#FFEBEE", fontcolor="black"];
    MSH          [label="α-MSH\n(melanocyte stimulation)", fillcolor="#F48FB1", fontcolor="black"];
    CLIP         [label="CLIP\n(ACTH 18–39)", fillcolor="#F8BBD0", fontcolor="black"];

    HPA_negative [label="Negative Feedback\n(GR in pit/hypo)", shape=diamond, fillcolor="#80DEEA", fontcolor="black"];
    HPA_stress   [label="Stress Inputs\n(physical/psychological)", shape=box, fillcolor="#FF6E40", fontcolor="white"];
    cytokine_HPA [label="Cytokine Drive\n(IL-1β, IL-6, TNFα)", fillcolor="#FFCCBC", fontcolor="black"];
    serotonin    [label="Serotonin\n(5-HT, CRH stimulation)", fillcolor="#FFF9C4", fontcolor="black"];
    acetylcholine[label="Acetylcholine\n(CRH stimulation)", fillcolor="#FFFDE7", fontcolor="black"];
    GABA_inhib   [label="GABA\n(CRH inhibition)", fillcolor="#E8F5E9", fontcolor="black"];

    zeitgeber -> SCN;
    SCN -> circadian;
    circadian -> hypothalamus [label="morning peak\n(06:00–08:00)"];
    HPA_stress -> hypothalamus;
    cytokine_HPA -> hypothalamus;
    serotonin -> hypothalamus;
    acetylcholine -> hypothalamus;
    GABA_inhib -> hypothalamus [label="inhibit",style=dashed];

    hypothalamus -> CRH [label="secretion"];
    hypothalamus -> AVP [label="co-release"];
    CRH -> pituitary [label="portal blood\n(CRH-R1)"];
    AVP -> pituitary [label="V3R synergy"];
    pituitary -> POMC [label="transcription"];
    POMC -> proACTH;
    proACTH -> ACTH [label="PC1 cleavage"];
    POMC -> MSH [label="PC2 (arcuate)"];
    ACTH -> MSH [label="excess ACTH\n→MCR1"];
    ACTH -> CLIP;

    HPA_negative -> pituitary [label="GR suppression",style=dashed,color="#80DEEA"];
    HPA_negative -> hypothalamus [label="GR suppression",style=dashed,color="#80DEEA"];
  }

  // ============================================================
  // CLUSTER 3: Adrenal Cortex Zones & Steroidogenesis
  // ============================================================
  subgraph cluster_adrenal {
    label="Adrenal Cortex Zones & Steroidogenesis"; style=filled; color="#1b3a1b";
    fontcolor="white"; fontsize=13;

    adrenal_gland[label="Adrenal\nGlands (bilateral)", shape=box, fillcolor="#8BC34A", fontcolor="white"];
    zona_glom    [label="Zona Glomerulosa\n(aldosterone synthesis)", shape=box, fillcolor="#AED581", fontcolor="black"];
    zona_fasc    [label="Zona Fasciculata\n(cortisol synthesis)", shape=box, fillcolor="#CDDC39", fontcolor="black"];
    zona_retic   [label="Zona Reticularis\n(DHEA synthesis)", shape=box, fillcolor="#D4E157", fontcolor="black"];
    adrenal_med  [label="Adrenal Medulla\n(epinephrine)", fillcolor="#558B2F", fontcolor="white"];

    cholesterol  [label="Cholesterol\n(substrate pool)", fillcolor="#80CBC4", fontcolor="black"];
    StAR         [label="StAR Protein\n(cholesterol transport)", fillcolor="#4DB6AC", fontcolor="black"];
    CYP11A1      [label="CYP11A1\n(side-chain cleavage)", fillcolor="#26A69A", fontcolor="white"];
    pregnenolone [label="Pregnenolone", fillcolor="#00897B", fontcolor="white"];
    progesterone [label="Progesterone", fillcolor="#00796B", fontcolor="white"];
    CYP17A1      [label="CYP17A1\n(17α-hydroxylation)", fillcolor="#00695C", fontcolor="white"];
    OH_preg      [label="17-OH\nPregnenolone", fillcolor="#A5D6A7", fontcolor="black"];
    OH_prog      [label="17-OH\nProgesterone", fillcolor="#81C784", fontcolor="black"];
    CYP21A2      [label="CYP21A2\n(21-hydroxylase)", fillcolor="#66BB6A", fontcolor="black"];
    DOC          [label="DOC\n(desoxycorticosterone)", fillcolor="#4CAF50", fontcolor="black"];
    CYP11B2      [label="CYP11B2\n(aldosterone synthase)", fillcolor="#43A047", fontcolor="white"];
    CYP11B1      [label="CYP11B1\n(11β-hydroxylase)", fillcolor="#388E3C", fontcolor="white"];
    aldo_prod    [label="Aldosterone\nProduction (ng/dL)", fillcolor="#C8E6C9", fontcolor="black"];
    cortisol_prod[label="Cortisol\nProduction (μg/dL)", fillcolor="#E6EE9C", fontcolor="black"];
    DHEA_prod    [label="DHEA/DHEA-S\nProduction", fillcolor="#F9FBE7", fontcolor="black"];
    androstenedione[label="Androstene-\ndione", fillcolor="#FFF8E1", fontcolor="black"];

    adrenal_reserve[label="Functional Adrenal\nReserve (0→100%)", shape=diamond, fillcolor="#69F0AE", fontcolor="black"];
    adrenal_damage [label="Cumulative Adrenal\nDamage Index", fillcolor="#F44336", fontcolor="white"];
    adrenal_fibrosis[label="Adrenal\nAtrophy/Fibrosis", fillcolor="#EF5350", fontcolor="white"];
    remaining_cortex[label="Remaining Functional\nCortex (%)", fillcolor="#FF8A65", fontcolor="black"];

    ACTH -> adrenal_gland [label="ACTH-R\n(MC2R)"];
    ACTH -> StAR [label="cAMP/PKA\nstimulation"];
    ACTH -> CYP11A1 [label="upregulation"];
    cholesterol -> StAR;
    StAR -> CYP11A1 [label="mitochondria"];
    CYP11A1 -> pregnenolone;
    pregnenolone -> progesterone [label="3β-HSD"];
    pregnenolone -> OH_preg [label="CYP17A1"];
    progesterone -> OH_prog [label="CYP17A1"];
    OH_preg -> androstenedione [label="lyase\nactivity"];
    androstenedione -> DHEA_prod [label="3β-HSD↑"];
    OH_prog -> DOC [label="CYP21A2"];
    DOC -> aldo_prod [label="CYP11B2\n(zona glom)"];
    OH_prog -> cortisol_prod [label="CYP11B1\n(zona fasc)"];

    adrenal_gland -> zona_glom;
    adrenal_gland -> zona_fasc;
    adrenal_gland -> zona_retic;
    adrenal_gland -> adrenal_med;
    zona_glom -> aldo_prod;
    zona_fasc -> cortisol_prod;
    zona_retic -> DHEA_prod;

    adrenal_reserve -> cortisol_prod [label="proportional\noutput"];
    adrenal_reserve -> aldo_prod [label="proportional"];
    adrenal_damage -> adrenal_reserve [label="reduces",style=dashed];
    adrenal_damage -> adrenal_fibrosis;
    adrenal_fibrosis -> remaining_cortex [label="loss"];
    remaining_cortex -> adrenal_reserve;
  }

  // ============================================================
  // CLUSTER 4: Autoimmune Destruction Mechanism
  // ============================================================
  subgraph cluster_autoimmune {
    label="Autoimmune Adrenalitis — Destruction Mechanism"; style=filled; color="#3a1a1a";
    fontcolor="white"; fontsize=13;

    HLA_DR3    [label="HLA-DR3/DR4\nGenetic Risk", shape=box, fillcolor="#9575CD", fontcolor="white"];
    HLA_B8     [label="HLA-B8\nHaplotype", fillcolor="#7E57C2", fontcolor="white"];
    CTLA4_snp  [label="CTLA-4\nPolymorphism", fillcolor="#673AB7", fontcolor="white"];
    PTPN22     [label="PTPN22\nVariant", fillcolor="#512DA8", fontcolor="white"];
    AIRE_gene  [label="AIRE Gene\n(central tolerance)", shape=box, fillcolor="#6A1B9A", fontcolor="white"];

    APS1       [label="APS-1 (APECED)\nAIRE mutation", shape=box, fillcolor="#E040FB", fontcolor="white"];
    APS2       [label="APS-2\n(Schmidt syndrome)", shape=box, fillcolor="#AA00FF", fontcolor="white"];

    thymus_tolerance[label="Thymic Tolerance\nBreakdown", fillcolor="#FF4081", fontcolor="white"];
    DC_present [label="Dendritic Cell\nAntigen Presentation\n(21-OH peptides)", fillcolor="#F06292", fontcolor="black"];

    Th0_cells  [label="Naive CD4+\nT cells", fillcolor="#FFB74D", fontcolor="black"];
    Th1_cells  [label="Th1 CD4+\n(IFN-γ, TNFα)", fillcolor="#FF7043", fontcolor="white"];
    Th17_cells [label="Th17 CD4+\n(IL-17A, IL-22)", fillcolor="#FF5722", fontcolor="white"];
    Th2_cells  [label="Th2 CD4+\n(IL-4, IL-13)", fillcolor="#FFA726", fontcolor="black"];
    Treg       [label="Regulatory T cells\n(FoxP3+ Treg)", fillcolor="#26C6DA", fontcolor="black"];
    CD8_CTL    [label="CD8+ Cytotoxic\nT Lymphocytes", fillcolor="#E64A19", fontcolor="white"];

    B_cells    [label="B Lymphocytes\n& Plasma Cells", fillcolor="#EC407A", fontcolor="white"];
    GC_B       [label="Germinal Center\nB Cell Reaction", fillcolor="#E91E63", fontcolor="white"];

    autoAb_21OH[label="Anti-21-Hydroxylase\nIgG Antibodies", fillcolor="#D32F2F", fontcolor="white"];
    autoAb_SCC [label="Anti-Side-Chain\nCleavage Ab", fillcolor="#C62828", fontcolor="white"];
    autoAb_17OH[label="Anti-17α-Hydroxylase\nAb", fillcolor="#B71C1C", fontcolor="white"];
    autoAb_StAR[label="Anti-StAR\nAntibodies", fillcolor="#BF360C", fontcolor="white"];

    complement [label="Complement Cascade\n(C3b/C5b-9 MAC)", fillcolor="#FF1744", fontcolor="white"];
    ADCC       [label="Antibody-Dependent\nCell Cytotoxicity", fillcolor="#FF6D00", fontcolor="white"];
    adrenal_apoptosis[label="Adrenocortical\nApoptosis", fillcolor="#FF3D00", fontcolor="white"];
    lymph_infiltrate[label="Lymphocytic\nInfiltration", fillcolor="#FF8F00", fontcolor="white"];
    local_inflam[label="Local Adrenal\nInflammation", fillcolor="#FF6F00", fontcolor="white"];
    ros_oxidative[label="ROS/Oxidative\nStress", fillcolor="#E65100", fontcolor="white"];

    AIRE_gene -> thymus_tolerance [label="maintains"];
    APS1 -> AIRE_gene [label="mutation\nloss-of-function"];
    APS2 -> HLA_DR3 [label="HLA assoc"];
    HLA_DR3 -> DC_present [label="risk allele"];
    HLA_B8 -> HLA_DR3 [label="linkage"];
    CTLA4_snp -> Treg [label="impairs"];
    PTPN22 -> Th1_cells [label="hyperactivation"];
    thymus_tolerance -> Th0_cells [label="breakdown\nreleases autoreactive"];
    DC_present -> Th0_cells [label="21-OH antigen\npresentation"];

    Th0_cells -> Th1_cells [label="IL-12"];
    Th0_cells -> Th17_cells [label="TGFβ+IL-6"];
    Th0_cells -> Th2_cells [label="IL-4"];
    Th0_cells -> Treg [label="TGFβ+IL-2"];

    Th1_cells -> CD8_CTL [label="IFN-γ support"];
    Th1_cells -> B_cells [label="T-B help"];
    Th2_cells -> B_cells [label="IL-4,13 help"];
    B_cells -> GC_B [label="affinity\nmaturation"];
    GC_B -> autoAb_21OH [label="class switch\nIgG"];
    GC_B -> autoAb_SCC;
    GC_B -> autoAb_17OH;
    GC_B -> autoAb_StAR;

    autoAb_21OH -> complement [label="Fc-mediated"];
    autoAb_21OH -> ADCC [label="NK cells"];
    complement -> adrenal_apoptosis;
    ADCC -> adrenal_apoptosis;
    CD8_CTL -> adrenal_apoptosis [label="perforin/granzyme"];
    Th17_cells -> lymph_infiltrate [label="chemokines"];
    Th1_cells -> local_inflam [label="IFN-γ, TNFα"];
    local_inflam -> ros_oxidative;
    ros_oxidative -> adrenal_apoptosis;
    lymph_infiltrate -> local_inflam;
    adrenal_apoptosis -> adrenal_damage [label="cell loss"];
    local_inflam -> adrenal_damage;

    Treg -> Th1_cells [label="suppress",style=dashed,color="#26C6DA"];
    Treg -> Th17_cells [label="suppress",style=dashed,color="#26C6DA"];
    Treg -> B_cells [label="suppress",style=dashed,color="#26C6DA"];
  }

  // ============================================================
  // CLUSTER 5: Glucocorticoid Receptor Signaling
  // ============================================================
  subgraph cluster_gc {
    label="Glucocorticoid Receptor (GR/NR3C1) Signaling & Systemic Effects"; style=filled; color="#1a2a3a";
    fontcolor="white"; fontsize=13;

    GR_cyto    [label="GR Cytoplasmic\n(HSP90 complex)", fillcolor="#4FC3F7", fontcolor="black"];
    GR_bound   [label="GR-Cortisol\nComplex", fillcolor="#29B6F6", fontcolor="black"];
    GR_nuc     [label="GR Nuclear\nTranslocation", fillcolor="#0288D1", fontcolor="white"];
    GRE        [label="Glucocorticoid\nResponse Element\n(GRE)", shape=box, fillcolor="#01579B", fontcolor="white"];
    nGRE       [label="Negative GRE\n(transrepression)", shape=box, fillcolor="#003c8f", fontcolor="white"];

    IkBa       [label="IκBα\n(NF-κB inhibitor ↑)", fillcolor="#81D4FA", fontcolor="black"];
    MKP1       [label="MKP-1\n(MAPK phosphatase ↑)", fillcolor="#4FC3F7", fontcolor="black"];
    NFkB_supp  [label="NF-κB\nSuppression", fillcolor="#29B6F6", fontcolor="black"];
    AP1_supp   [label="AP-1\nSuppression", fillcolor="#039BE5", fontcolor="white"];

    liver_PEPCK[label="Liver PEPCK/G6Pase\n(gluconeogenesis ↑)", fillcolor="#FFF176", fontcolor="black"];
    hepatic_glucose[label="Hepatic Glucose\nOutput ↑", fillcolor="#FFEE58", fontcolor="black"];
    peripheral_IR  [label="Peripheral Insulin\nResistance ↑", fillcolor="#FFD54F", fontcolor="black"];
    adipose_lip[label="Adipose Lipolysis ↑\n(HSL activation)", fillcolor="#FFCA28", fontcolor="black"];
    FFA_release[label="Free Fatty Acid\nRelease ↑", fillcolor="#FFC107", fontcolor="black"];
    glycogen_syn[label="Glycogen Synthesis\n(liver)", fillcolor="#FFB300", fontcolor="black"];

    muscle_MuRF[label="Muscle MuRF1/MAFbx\n(protein catabolism ↑)", fillcolor="#FFCCBC", fontcolor="black"];
    muscle_IGF1[label="IGF-1\n(anabolic, suppressed)", fillcolor="#FFAB91", fontcolor="black"];

    osteocalcin[label="Osteocalcin\n(osteoblast marker ↓)", fillcolor="#D7CCC8", fontcolor="black"];
    OPG        [label="OPG\n(anti-resorptive ↓)", fillcolor="#BCAAA4", fontcolor="black"];
    RANKL_bone [label="RANKL\n(osteoclast activation ↑)", fillcolor="#A1887F", fontcolor="black"];
    bone_resorb[label="Bone Resorption ↑\n(GC excess risk)", fillcolor="#8D6E63", fontcolor="white"];

    CNS_GR     [label="CNS Hippocampal\nGR Activation", fillcolor="#CE93D8", fontcolor="black"];
    mood_GC    [label="Mood/Sleep\nEffects", fillcolor="#BA68C8", fontcolor="black"];
    CRF_stress [label="CRF Stress\nSensitivity", fillcolor="#AB47BC", fontcolor="black"];

    immune_GC  [label="Lymphocyte\nApoptosis ↑", fillcolor="#80DEEA", fontcolor="black"];
    NK_suppress[label="NK Cell\nSuppression", fillcolor="#4DD0E1", fontcolor="black"];
    cytokine_GC[label="Pro-inflammatory\nCytokines ↓\n(IL-1β, IL-6, TNFα)", fillcolor="#26C6DA", fontcolor="black"];

    HC_free -> GR_cyto [label="ligand binding"];
    GR_cyto -> GR_bound [label="HSP90 release"];
    GR_bound -> GR_nuc [label="translocation"];
    GR_nuc -> GRE [label="homodimerization\nbinding"];
    GR_nuc -> nGRE [label="monomer\nbinding"];

    GRE -> IkBa [label="transactivation"];
    GRE -> MKP1 [label="transactivation"];
    nGRE -> NFkB_supp [label="transrepression"];
    nGRE -> AP1_supp [label="transrepression"];
    IkBa -> NFkB_supp;
    NFkB_supp -> cytokine_GC;
    AP1_supp -> cytokine_GC;
    MKP1 -> immune_GC;

    GRE -> liver_PEPCK [label="transactivation"];
    liver_PEPCK -> hepatic_glucose;
    hepatic_glucose -> peripheral_IR;
    GRE -> adipose_lip;
    adipose_lip -> FFA_release;
    GRE -> glycogen_syn;

    GRE -> muscle_MuRF [label="catabolic genes ↑"];
    muscle_MuRF -> muscle_IGF1 [label="suppresses",style=dashed];

    GRE -> OPG [label="suppresses",style=dashed];
    GRE -> osteocalcin [label="suppresses",style=dashed];
    RANKL_bone -> bone_resorb [label="osteoclast\nactivation"];
    OPG -> RANKL_bone [label="inhibits",style=dashed];

    GR_nuc -> CNS_GR;
    CNS_GR -> mood_GC;
    CNS_GR -> CRF_stress;

    immune_GC -> NK_suppress;
    cytokine_GC -> cytokine_HPA [label="feedback",style=dashed];

    GR_nuc -> HPA_negative [label="negative\nfeedback",color="#80DEEA"];
  }

  // ============================================================
  // CLUSTER 6: Mineralocorticoid Receptor (MR) Signaling
  // ============================================================
  subgraph cluster_mc {
    label="Mineralocorticoid Receptor (MR/NR3C2) Signaling — Renal & Cardiovascular"; style=filled; color="#1a3a2a";
    fontcolor="white"; fontsize=13;

    MR_cyto    [label="MR Cytoplasmic\n(kidney distal tubule)", fillcolor="#A5D6A7", fontcolor="black"];
    MR_aldo    [label="MR-Aldosterone\nComplex", fillcolor="#81C784", fontcolor="black"];
    MR_FC      [label="MR-Fludrocortisone\nComplex", fillcolor="#66BB6A", fontcolor="black"];
    MR_nuc     [label="MR Nuclear\nTranslocation", fillcolor="#4CAF50", fontcolor="white"];
    MRE        [label="Mineralocorticoid\nResponse Element", shape=box, fillcolor="#388E3C", fontcolor="white"];

    ENaC       [label="ENaC α/β/γ\n(apical Na channel ↑)", fillcolor="#1B5E20", fontcolor="white"];
    ROMK       [label="ROMK\n(K+ secretion ↑)", fillcolor="#2E7D32", fontcolor="white"];
    NKATPase   [label="Na+/K+-ATPase\n(basolateral ↑)", fillcolor="#388E3C", fontcolor="white"];
    SGK1       [label="SGK1 Kinase\n(ENaC trafficking)", fillcolor="#43A047", fontcolor="white"];

    Na_reabs   [label="Renal Na+\nReabsorption ↑", fillcolor="#C8E6C9", fontcolor="black"];
    K_excret   [label="Renal K+\nExcretion ↑", fillcolor="#DCEDC8", fontcolor="black"];
    H_excret   [label="H+ Excretion ↑\n(metabolic alkalosis)", fillcolor="#F1F8E9", fontcolor="black"];
    H2O_ret    [label="Water Retention\n(ADH co-effect)", fillcolor="#E8F5E9", fontcolor="black"];

    plasma_Na  [label="Plasma Na+\n(mEq/L, target 138–142)", shape=box, fillcolor="#B3E5FC", fontcolor="black"];
    plasma_K   [label="Plasma K+\n(mEq/L, target 3.5–5.0)", shape=box, fillcolor="#81D4FA", fontcolor="black"];
    plasma_Cl  [label="Plasma Cl-\n(mEq/L)", fillcolor="#4FC3F7", fontcolor="black"];
    plasma_bicarb[label="Plasma HCO3-\n(alkalosis)", fillcolor="#29B6F6", fontcolor="black"];
    plasma_vol [label="Plasma Volume\n(L)", fillcolor="#E1F5FE", fontcolor="black"];
    MAP        [label="Mean Arterial\nPressure (mmHg)", shape=box, fillcolor="#B3E5FC", fontcolor="black"];

    renin_sec  [label="Renin Secretion\n(macula densa/JGA)", fillcolor="#0288D1", fontcolor="white"];
    angioI     [label="Angiotensin I\n(ACE substrate)", fillcolor="#0277BD", fontcolor="white"];
    angioII    [label="Angiotensin II\n(vasoconstriction)", fillcolor="#01579B", fontcolor="white"];
    ACE        [label="ACE\n(ang-converting enzyme)", fillcolor="#0D47A1", fontcolor="white"];
    RAAS       [label="RAAS\nActivation", shape=box, fillcolor="#1565C0", fontcolor="white"];

    aldo_prod -> MR_cyto [label="physiologic\naldosterone"];
    FC_central -> MR_FC [label="pharmacologic\n(synthetic MC)"];
    MR_cyto -> MR_aldo [label="aldo binding"];
    MR_FC -> MR_nuc [label="translocation"];
    MR_aldo -> MR_nuc [label="translocation"];
    MR_nuc -> MRE [label="binding"];
    MRE -> ENaC [label="SCNN1 upregulation"];
    MRE -> SGK1 [label="kinase ↑"];
    SGK1 -> ENaC [label="stabilization"];
    MRE -> ROMK [label="KCNJ1 ↑"];
    MRE -> NKATPase [label="ATP1A upregulation"];

    ENaC -> Na_reabs [label="Na+ transport"];
    ROMK -> K_excret [label="K+ secretion"];
    NKATPase -> Na_reabs;
    Na_reabs -> H2O_ret [label="osmotic"];
    Na_reabs -> plasma_Na [label="↑"];
    K_excret -> plasma_K [label="↓"];
    H2O_ret -> plasma_vol [label="↑"];
    H2O_ret -> plasma_Cl;
    Na_reabs -> H_excret;
    H_excret -> plasma_bicarb [label="↑"];

    plasma_vol -> MAP [label="Starling"];
    plasma_Na -> MAP [label="osmotic"];
    angioII -> MAP [label="vasoconstriction"];

    renin_sec -> RAAS;
    RAAS -> angioI;
    angioI -> ACE;
    ACE -> angioII;
    angioII -> aldo_prod [label="AT1R→CYP11B2"];

    plasma_Na -> renin_sec [label="tubular Na\n→ feedback", style=dashed];
    MAP -> renin_sec [label="pressure\n→ feedback", style=dashed];
    aldo_prod -> renin_sec [label="aldo\n→ renin↓", style=dashed];
  }

  // ============================================================
  // CLUSTER 7: Clinical Manifestations & Diagnostics
  // ============================================================
  subgraph cluster_clinical {
    label="Clinical Manifestations, Diagnostics & Laboratory"; style=filled; color="#2a2a1a";
    fontcolor="white"; fontsize=13;

    // Acute symptoms
    hypotension  [label="Hypotension\n(SBP <90 mmHg)", shape=box, fillcolor="#EF5350", fontcolor="white"];
    orthostatic  [label="Orthostatic\nHypotension", fillcolor="#E53935", fontcolor="white"];
    hyponatremia [label="Hyponatremia\n(Na <135 mEq/L)", fillcolor="#FF7043", fontcolor="white"];
    hyperkalemia [label="Hyperkalemia\n(K >5.5 mEq/L)", fillcolor="#FF5722", fontcolor="white"];
    hypoglycemia [label="Hypoglycemia\n(BG <70 mg/dL)", fillcolor="#FF8F00", fontcolor="white"];
    metabolic_acid[label="Metabolic Acidosis\n(non-anion gap)", fillcolor="#E64A19", fontcolor="white"];

    // Symptoms
    fatigue      [label="Profound\nFatigue & Weakness", fillcolor="#BDBDBD", fontcolor="black"];
    weight_loss  [label="Weight Loss\nAnorexia", fillcolor="#9E9E9E", fontcolor="white"];
    nausea_vomit [label="Nausea/Vomiting\nAbdominal Pain", fillcolor="#757575", fontcolor="white"];
    hyperpigment [label="Hyperpigmentation\n(buccal, skin creases,\nscars, areolae)", fillcolor="#8D6E63", fontcolor="white"];
    salt_craving [label="Salt Craving\n(mineralocorticoid def)", fillcolor="#795548", fontcolor="white"];
    muscle_cramps[label="Muscle Cramps\n(hyponatremia/hypoK)", fillcolor="#6D4C41", fontcolor="white"];
    myalgia_joint[label="Myalgia/\nArthralgias", fillcolor="#5D4037", fontcolor="white"];
    amenorrhea   [label="Amenorrhea\n(DHEA/androgen def)", fillcolor="#4E342E", fontcolor="white"];
    decreased_libido[label="Decreased\nLibido (DHEA def)", fillcolor="#3E2723", fontcolor="white"];

    // Diagnostics
    morning_cortisol[label="8am Cortisol\n(<3 μg/dL = diagnostic)", shape=box, fillcolor="#FFF8E1", fontcolor="black"];
    plasma_ACTH  [label="Plasma ACTH\n(>2× ULN = primary)", shape=box, fillcolor="#FFF3E0", fontcolor="black"];
    cosyntropin  [label="Cosyntropin Stim Test\n(250 μg ACTH IV)", shape=box, fillcolor="#FFFDE7", fontcolor="black"];
    peak_cortisol[label="Peak Cortisol <18 μg/dL\n(= test failure)", shape=box, fillcolor="#F9FBE7", fontcolor="black"];
    ACTH_1μg     [label="Low-Dose ACTH\n1 μg Test (sensitive)", shape=box, fillcolor="#F1F8E9", fontcolor="black"];

    aldo_lab     [label="Aldosterone <5 ng/dL\n(+ high renin)", fillcolor="#E3F2FD", fontcolor="black"];
    renin_lab    [label="Plasma Renin\nActivity ↑", fillcolor="#BBDEFB", fontcolor="black"];
    DHEAS_lab    [label="DHEA-S <100 μg/dL\n(zone reticularis loss)", fillcolor="#E8EAF6", fontcolor="black"];

    eosinophilia [label="Eosinophilia\n(>500/μL, GC effect loss)", fillcolor="#E8F5E9", fontcolor="black"];
    lymphocytosis[label="Relative\nLymphocytosis", fillcolor="#F3E5F5", fontcolor="black"];
    anemia_norm  [label="Normocytic\nAnemia (mild)", fillcolor="#FCE4EC", fontcolor="black"];
    CT_adrenal   [label="CT/MRI Adrenal\n(atrophy vs calcif)", shape=box, fillcolor="#E0E0E0", fontcolor="black"];
    adrenal_calcif[label="Adrenal\nCalcification (TB)", fillcolor="#BDBDBD", fontcolor="black"];

    plasma_Na -> hyponatremia [label="if low",style=dashed];
    plasma_K -> hyperkalemia [label="if high",style=dashed];
    MAP -> hypotension [label="if low",style=dashed];
    MAP -> orthostatic [label="if postural drop",style=dashed];
    hepatic_glucose -> hypoglycemia [label="deficient GC→\nhypoglycemia",style=dashed];
    plasma_bicarb -> metabolic_acid [label="if HCO3↓",style=dashed];

    MSH -> hyperpigment [label="MC1R activation"];
    ACTH -> hyperpigment [label="excess ACTH\n→ skin"];

    aldo_prod -> aldo_lab [label="deficiency",style=dashed];
    renin_sec -> renin_lab [label="compensatory ↑"];
    DHEA_prod -> DHEAS_lab [label="deficiency",style=dashed];

    cortisol_prod -> morning_cortisol [label="reflects\noutput"];
    ACTH -> plasma_ACTH;
    cosyntropin -> peak_cortisol [label="measures reserve"];
    morning_cortisol -> cosyntropin [label="if 3–18 μg/dL\n→ confirm with"];
    ACTH_1μg -> peak_cortisol [label="sensitive\ndetection"];
  }

  // ============================================================
  // CLUSTER 8: Adrenal Crisis
  // ============================================================
  subgraph cluster_crisis {
    label="Adrenal Crisis — Triggers, Pathophysiology & Emergency Management"; style=filled; color="#3a1a2a";
    fontcolor="white"; fontsize=13;

    crisis_trigger[label="Adrenal Crisis\nTrigger", shape=box, fillcolor="#B71C1C", fontcolor="white"];
    infection_t  [label="Infection/Sepsis\n(most common, 30%)", fillcolor="#D32F2F", fontcolor="white"];
    surgery_t    [label="Surgery/\nTrauma/Procedure", fillcolor="#C62828", fontcolor="white"];
    GI_t         [label="GI Illness\n(vomiting = dose loss)", fillcolor="#E53935", fontcolor="white"];
    miss_dose    [label="Missed/Stopped\nDose", fillcolor="#F44336", fontcolor="white"];
    psycho_stress[label="Severe Psychological\nStress", fillcolor="#EF5350", fontcolor="white"];

    crisis_physio[label="Crisis Pathophysiology\n(absolute cortisol\ndeficiency + demand)", shape=diamond, fillcolor="#FF5722", fontcolor="white"];
    CO_drop      [label="Cardiac Output ↓\n(preload + afterload)", fillcolor="#BF360C", fontcolor="white"];
    vascular_tone[label="Vascular Tone ↓\n(catecholamine resistance)", fillcolor="#DD2C00", fontcolor="white"];
    shock        [label="Distributive\nShock", shape=box, fillcolor="#FF3D00", fontcolor="white"];
    coma         [label="Altered Consciousness\nComa", fillcolor="#FF6D00", fontcolor="white"];
    crisis_death [label="Adrenal Crisis\nDeath (6–17%)", shape=box, fillcolor="#FF1744", fontcolor="white"];

    // Emergency management
    HC_iv_emerg [label="HC IV 100 mg\n(stat bolus)", shape=box, fillcolor="#00C853", fontcolor="white"];
    HC_infusion  [label="HC IV Infusion\n200 mg/24h", shape=box, fillcolor="#00B248", fontcolor="white"];
    NS_fluid     [label="Normal Saline\n1–2L IV (rapid)", shape=box, fillcolor="#00BCD4", fontcolor="white"];
    glucose_iv   [label="IV Dextrose\n(D50 if BG <60)", shape=box, fillcolor="#8BC34A", fontcolor="white"];
    vasopressors [label="Vasopressors\n(if refractory)", shape=box, fillcolor="#FF9800", fontcolor="white"];

    // Prevention
    sick_day_rules[label="Sick Day Rules\n(2–3× dose doubling)", shape=box, fillcolor="#FFA000", fontcolor="white"];
    stress_dosing [label="Stress Dosing\nProtocol (HC 50–100mg)", shape=box, fillcolor="#FFB300", fontcolor="white"];
    emergency_kit [label="Emergency HC\nInjection Kit (100mg IM)", shape=box, fillcolor="#FFC107", fontcolor="black"];
    med_alert     [label="Medical Alert\nID/Card", shape=box, fillcolor="#FFD54F", fontcolor="black"];
    education     [label="Patient & Caregiver\nEducation", shape=box, fillcolor="#FFE082", fontcolor="black"];

    crisis_incid  [label="Crisis Incidence\n(5.2/100 pt-years)", fillcolor="#FF5252", fontcolor="white"];
    hospital_admit[label="Hospital\nAdmission Rate", fillcolor="#FF4081", fontcolor="white"];

    infection_t -> crisis_trigger;
    surgery_t -> crisis_trigger;
    GI_t -> crisis_trigger;
    miss_dose -> crisis_trigger;
    psycho_stress -> crisis_trigger;

    crisis_trigger -> crisis_physio [label="cortisol demand\nexceeds supply"];
    crisis_physio -> CO_drop;
    crisis_physio -> vascular_tone;
    CO_drop -> shock;
    vascular_tone -> shock;
    shock -> coma;
    coma -> crisis_death;
    hypotension -> crisis_physio [label="amplifies"];
    hyponatremia -> crisis_physio;
    hypoglycemia -> crisis_physio;

    HC_iv_emerg -> HC_central [label="IV bolus\nemergency",color="#00C853"];
    HC_infusion -> HC_central [label="continuous",color="#00B248"];
    NS_fluid -> plasma_vol [label="volume restore",color="#00BCD4"];
    glucose_iv -> hepatic_glucose [label="glucose supplement"];
    vasopressors -> vascular_tone [label="restore",style=dashed];

    sick_day_rules -> HC_dose [label="dose increase"];
    stress_dosing -> HC_dose;
    emergency_kit -> HC_iv_emerg [label="IM admin"];

    crisis_physio -> crisis_incid;
    crisis_physio -> hospital_admit;
  }

