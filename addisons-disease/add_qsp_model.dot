    CV_death   [label="Cardiovascular\nDeath (excess)", fillcolor="#D50000", fontcolor="white"];
    crisis_death2[label="Adrenal Crisis\nDeath", fillcolor="#FF1744", fontcolor="white"];

    bone_resorb -> BMD_loss [label="GC effect"];
    over_replace -> BMD_loss [label="excess GC"];
    BMD_loss -> fracture_risk;
    fracture_risk -> osteopenia;
    osteopenia -> vertebral_fx;

    over_replace -> CV_risk;
    over_replace -> dyslipid_GC;
    over_replace -> obesity_GC;
    dyslipid_GC -> atheroscler;
    atheroscler -> CV_risk;
    obesity_GC -> CV_risk;

    MR_nuc -> hypertension [label="FC excess",style=dashed];
    hypertension -> CV_risk;

    fatigue_chr -> QOL;
    cognitive -> QOL;
    psychosocial -> QOL;
    sexual_dys -> QOL;

    replace_adeq -> over_replace [label="if excess"];
    replace_adeq -> under_replace [label="if insufficient"];

    assoc_AI -> thyroid_dis;
    assoc_AI -> T1DM_assoc;
    assoc_AI -> vitiligo_a;
    assoc_AI -> hypoparathyroid;
    assoc_AI -> premature_ovarian;
