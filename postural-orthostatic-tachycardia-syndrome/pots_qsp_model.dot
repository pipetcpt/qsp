digraph POTS_QSP {
  graph [rankdir=LR, fontname="Helvetica", fontsize=11, labelloc=t,
         label="Postural Orthostatic Tachycardia Syndrome (POTS, 체위성 기립성 빈맥 증후군) — Integrated QSP Mechanistic Map\nOrthostatic Venous Pooling · Baroreflex Arc · Neuropathic / Hyperadrenergic / Hypovolemic / Autoimmune Subtypes → Excessive Standing Tachycardia\nMidodrine (α1 agonist) · Beta-blockers (propranolol/bisoprolol) · Fludrocortisone · Ivabradine (If blocker) · Pyridostigmine · Droxidopa · Volume/exercise therapy",
         splines=spline, overlap=false, nodesep=0.30, ranksep=0.55,
         bgcolor="#fbfbfd"];
  node  [shape=box, style="rounded,filled", fontname="Helvetica", fontsize=10,
         fillcolor="#ffffff", color="#7d8590"];
  edge  [fontname="Helvetica", fontsize=9, color="#6e7681", arrowsize=0.7];

  /* ───────────────────────── 1. Orthostatic Stress & Venous Physiology ───── */
  subgraph cluster_ortho {
    label="1. Orthostatic Stress & Venous Pooling";
    style="filled,rounded"; color="#5c6370"; fillcolor="#f3f0ff"; fontsize=12;
    UprightPosture   [label="Active standing /\nhead-up tilt"];
    GravityGrad      [label="Gravitational hydrostatic\ncolumn (+ ~500-1000 mL shift)"];
    VenousPoolLeg    [label="Lower-limb venous\npooling"];
    VenousPoolSplan  [label="Splanchnic venous\npooling (capacitance bed)"];
    VenousCapacit    [label="Venous capacitance\n(compliant, low-pressure bed)"];
    CentralBVShift   [label="Central/thoracic\nblood volume ↓"];
    SkelMusclePump   [label="Skeletal-muscle\n(calf) pump"];
    VenousReturn     [label="Venous return to\nright heart ↓"];
    PreloadRV        [label="RV/LV preload ↓"];
    StrokeVolDrop    [label="Stroke volume ↓\n(Frank-Starling)"];
    UprightPosture -> GravityGrad;
    GravityGrad -> VenousPoolLeg;
    GravityGrad -> VenousPoolSplan;
    VenousPoolLeg -> VenousCapacit;
    VenousPoolSplan -> VenousCapacit;
    VenousCapacit -> CentralBVShift;
    CentralBVShift -> VenousReturn;
    SkelMusclePump -> VenousReturn [style=dashed, label="compensatory"];
    VenousReturn -> PreloadRV -> StrokeVolDrop;
  }

  /* ───────────────────────── 2. Baroreflex Arc & Autonomic Control ───────── */
  subgraph cluster_baro {
    label="2. Baroreflex Arc & Central Autonomic Control";
    style="filled,rounded"; color="#5c6370"; fillcolor="#fff4e6"; fontsize=12;
    CarotidBaro      [label="Carotid sinus\nbaroreceptors"];
    AorticBaro       [label="Aortic arch\nbaroreceptors"];
    NTS              [label="Nucleus tractus\nsolitarius (NTS)"];
    CVLM             [label="Caudal ventrolateral\nmedulla (CVLM)"];
    RVLM             [label="Rostral ventrolateral\nmedulla (RVLM)"];
    NucAmbiguus      [label="Nucleus ambiguus /\ndorsal vagal nucleus"];
    VagalEfferent    [label="Cardiac vagal\nefferent tone"];
    PreganglSym      [label="Preganglionic\nsympathetic outflow"];
    ParavertGang     [label="Paravertebral\nsympathetic ganglia"];
    PostganglSym     [label="Postganglionic\nsympathetic (NE release)"];
    BaroreflexGain   [label="Baroreflex gain\n(overall sensitivity)"];
    BRS_HR           [label="Cardiovagal baroreflex\nsensitivity (HR arm)"];
    BRS_Vasomotor    [label="Sympathetic baroreflex\nsensitivity (vasomotor arm)"];
    StrokeVolDrop -> CarotidBaro [style=dashed, label="↓ arterial\npressure/stretch"];
    StrokeVolDrop -> AorticBaro [style=dashed];
    CarotidBaro -> NTS;
    AorticBaro -> NTS;
    NTS -> CVLM -> NucAmbiguus -> VagalEfferent;
    NTS -> RVLM [style=dashed, label="disinhibition"];
    RVLM -> PreganglSym -> ParavertGang -> PostganglSym;
    NTS -> BaroreflexGain;
    BaroreflexGain -> BRS_HR;
    BaroreflexGain -> BRS_Vasomotor;
  }

  /* ───────────────────────── 3. Neuropathic (Denervation) Subtype ────────── */
  subgraph cluster_neuro {
    label="3. Neuropathic Subtype (Partial Sympathetic Denervation)";
    style="filled,rounded"; color="#5c6370"; fillcolor="#e6f7ff"; fontsize=12;
    SmallFiberNeuro  [label="Length-dependent\nsmall-fiber neuropathy"];
    DistalSympDenerv [label="Distal (leg/splanchnic)\nsympathetic denervation"];
    IENFD_Low        [label="Skin biopsy IENFD ↓\n(intraepidermal nerve fiber density)"];
    SudomotorDysf    [label="Sudomotor dysfunction\n(QSART abnormal)"];
    SplanchDenerv    [label="Splanchnic vasoconstrictor\nfailure"];
    LegVenoconImpair [label="Lower-limb venoconstriction\nimpaired on standing"];
    CompensUpperSym  [label="Compensatory upper-body /\ncardiac sympathetic ↑"];
    SmallFiberNeuro -> DistalSympDenerv;
    DistalSympDenerv -> IENFD_Low;
    DistalSympDenerv -> SudomotorDysf;
    DistalSympDenerv -> SplanchDenerv;
    SplanchDenerv -> LegVenoconImpair;
    LegVenoconImpair -> VenousPoolLeg [style=dashed, label="impaired\ncompensation"];
    DistalSympDenerv -> CompensUpperSym [style=dashed, label="baroreflex-driven"];
    CompensUpperSym -> PostganglSym;
  }

  /* ───────────────────────── 4. Hyperadrenergic Subtype ──────────────────── */
  subgraph cluster_hyperad {
    label="4. Hyperadrenergic Subtype";
    style="filled,rounded"; color="#5c6370"; fillcolor="#ffe6ec"; fontsize=12;
    NET_Deficiency   [label="NET (SLC6A2) deficiency /\nloss-of-function variant"];
    ExcessNErelease  [label="Excess synaptic NE\n(reduced reuptake/clearance)"];
    StandNE_High     [label="Standing plasma NE\n> 600 pg/mL"];
    Alpha1_Excess    [label="α1-adrenergic\nvasoconstriction (excess)"];
    Beta1_Excess     [label="β1-adrenergic\nchronotropic drive (excess)"];
    TremorAnxietySx  [label="Tremor / anxiety /\npalpitations phenotype"];
    SupineHTN_Overlap[label="Supine hypertension\noverlap"];
    NET_Deficiency -> ExcessNErelease;
    PostganglSym -> ExcessNErelease;
    ExcessNErelease -> StandNE_High;
    StandNE_High -> Alpha1_Excess;
    StandNE_High -> Beta1_Excess;
    Beta1_Excess -> TremorAnxietySx;
    Alpha1_Excess -> SupineHTN_Overlap;
  }

  /* ───────────────────────── 5. Hypovolemic Subtype ───────────────────────── */
  subgraph cluster_hypovol {
    label="5. Hypovolemic Subtype";
    style="filled,rounded"; color="#5c6370"; fillcolor="#fff9e6"; fontsize=12;
    LowPlasmaVol     [label="Reduced total\nblood/plasma volume"];
    RAAS_Paradox     [label="RAAS paradox\n(inappropriately low renin/\naldosterone for hypovolemia)"];
    AVP_Blunted      [label="Arginine vasopressin\nresponse blunted"];
    NatriureticDysreg[label="Natriuretic peptide\ndysregulation"];
    RenalSaltWasting [label="Relative renal\nsalt wasting"];
    ReducedTotalBV   [label="Reduced RBC mass +\nplasma volume (Daxor/I-131)"];
    LowPlasmaVol -> RAAS_Paradox;
    RAAS_Paradox -> AVP_Blunted;
    NatriureticDysreg -> RenalSaltWasting;
    RenalSaltWasting -> LowPlasmaVol;
    LowPlasmaVol -> ReducedTotalBV;
    ReducedTotalBV -> CentralBVShift [style=dashed, label="baseline\nvolume deficit"];
  }

  /* ───────────────────────── 6. Autoimmune / Post-Infectious Subtype ─────── */
  subgraph cluster_autoimm {
    label="6. Autoimmune / Post-Infectious Subtype & Overlap Syndromes";
    style="filled,rounded"; color="#5c6370"; fillcolor="#e6ffe9"; fontsize=12;
    PostViralTrigger [label="Post-viral trigger\n(incl. post-acute\nSARS-CoV-2 / long-COVID)"];
    MolecularMimicry [label="Molecular mimicry /\nautoantibody generation"];
    AutoabAdrenergic [label="Agonist autoantibodies\nvs β1/β2-adrenoceptor"];
    AutoabMuscarinic [label="Antagonist autoantibodies\nvs M2/M4-muscarinic receptor"];
    GanglionicAChR   [label="Low-titer ganglionic\nα3-nAChR antibody\n(autoimmune autonomic\nganglionopathy spectrum)"];
    MCAS_Overlap     [label="Mast cell activation\nsyndrome (MCAS) overlap"];
    HistamineRelease [label="Histamine / tryptase /\nprostaglandin D2 release"];
    hEDS_Overlap     [label="Hypermobile EDS /\nconnective-tissue laxity\noverlap"];
    PostViralTrigger -> MolecularMimicry;
    MolecularMimicry -> AutoabAdrenergic;
    MolecularMimicry -> AutoabMuscarinic;
    MolecularMimicry -> GanglionicAChR;
    AutoabAdrenergic -> Beta1_Excess [style=dashed, label="agonist\nactivity"];
    AutoabMuscarinic -> VagalEfferent [style=dashed, label="antagonism"];
    GanglionicAChR -> PreganglSym [style=dashed, label="ganglionic\ntransmission ↓"];
    MCAS_Overlap -> HistamineRelease;
    HistamineRelease -> VenousCapacit [style=dashed, label="vasodilation"];
    hEDS_Overlap -> VenousCapacit [style=dashed, label="vessel wall\nlaxity"];
  }

  /* ───────────────────────── 7. Cardiovascular Hemodynamics ──────────────── */
  subgraph cluster_hemo {
    label="7. Cardiovascular Hemodynamics";
    style="filled,rounded"; color="#5c6370"; fillcolor="#f0f5ff"; fontsize=12;
    SupineHR         [label="Supine heart rate\n(baseline)"];
    StandingHR       [label="Standing heart rate\n(peak, within 10 min)"];
    DeltaHR10        [label="ΔHR (10-min stand)\n≥30 bpm adult /\n≥40 bpm adolescent"];
    CardiacOutput    [label="Cardiac output\n(HR × SV)"];
    TPR              [label="Total peripheral\nresistance"];
    SystolicBP       [label="Systolic blood\npressure"];
    DiastolicBP      [label="Diastolic blood\npressure"];
    OrthoBP_Change   [label="Orthostatic BP change\n(minimal by definition,\nexcludes orthostatic\nhypotension)"];
    PulsePressure    [label="Pulse pressure\n(narrowed)"];
    StrokeVolDrop -> CardiacOutput;
    VagalEfferent -> SupineHR [style=dashed, label="vagal\nwithdrawal"];
    PostganglSym -> StandingHR;
    BRS_HR -> StandingHR [style=dashed, label="reflex\ntachycardia"];
    SupineHR -> DeltaHR10;
    StandingHR -> DeltaHR10;
    CardiacOutput -> SystolicBP;
    TPR -> DiastolicBP;
    Alpha1_Excess -> TPR;
    SystolicBP -> OrthoBP_Change;
    SystolicBP -> PulsePressure;
    DiastolicBP -> PulsePressure;
  }

  /* ───────────────────────── 8. Cerebral Blood Flow & Neuro-symptoms ─────── */
  subgraph cluster_cbf {
    label="8. Cerebral Blood Flow & Neuro-symptoms";
    style="filled,rounded"; color="#5c6370"; fillcolor="#f5f0ff"; fontsize=12;
    CerebralAutoreg  [label="Cerebral\nautoregulation"];
    CBFV_TCD         [label="Cerebral blood-flow\nvelocity (TCD)"];
    Presyncope       [label="Presyncope\n(lightheadedness)"];
    Syncope          [label="Syncope\n(occasional)"];
    BrainFog         [label="Brain fog /\ncognitive dysfunction"];
    OrthoHeadache    [label="Orthostatic\nheadache"];
    CardiacOutput -> CerebralAutoreg [style=dashed];
    CerebralAutoreg -> CBFV_TCD;
    CBFV_TCD -> Presyncope;
    CBFV_TCD -> BrainFog;
    Presyncope -> Syncope [style=dashed, label="severe cases"];
    CBFV_TCD -> OrthoHeadache;
  }

  /* ───────────────────────── 9. Deconditioning & Skeletal Muscle ─────────── */
  subgraph cluster_deconditioning {
    label="9. Deconditioning & Skeletal Muscle";
    style="filled,rounded"; color="#5c6370"; fillcolor="#fff0f5"; fontsize=12;
    Deconditioning   [label="Physical\ndeconditioning"];
    CardiacAtrophy   [label="Small, under-filled\nLV chamber"];
    ExerciseIntoler  [label="Exercise intolerance"];
    ReducedPumpCap   [label="Reduced skeletal-muscle\npump capacity"];
    VO2peakLow       [label="VO2peak reduced"];
    Presyncope -> Deconditioning [style=dashed, label="activity\navoidance"];
    Deconditioning -> CardiacAtrophy;
    CardiacAtrophy -> StrokeVolDrop [style=dashed];
    Deconditioning -> ReducedPumpCap;
    ReducedPumpCap -> SkelMusclePump [style=dashed];
    Deconditioning -> ExerciseIntoler;
    ExerciseIntoler -> VO2peakLow;
  }

  /* ───────────────────────── 10. GI / Bladder / Comorbid Dysautonomia ────── */
  subgraph cluster_comorbid {
    label="10. GI / Bladder / Comorbid Dysautonomia";
    style="filled,rounded"; color="#5c6370"; fillcolor="#f0fff5"; fontsize=12;
    GastroparesisCom [label="Gastroparesis\n(comorbid)"];
    IBS_Comorbid     [label="Irritable bowel\nsyndrome (comorbid)"];
    BladderDysf      [label="Bladder dysfunction /\nurinary urgency"];
    ME_CFS_Overlap   [label="ME/CFS fatigue\noverlap"];
    MigraineComorbid [label="Migraine\n(comorbid)"];
    PreganglSym -> GastroparesisCom [style=dashed, label="enteric autonomic\ndysfunction"];
    PreganglSym -> IBS_Comorbid [style=dashed];
    PreganglSym -> BladderDysf [style=dashed];
    Deconditioning -> ME_CFS_Overlap [style=dashed];
    BaroreflexGain -> MigraineComorbid [style=dashed];
  }

  /* ───────────────────────── 11. Drug PK/PD — Midodrine (α1 agonist) ─────── */
  subgraph cluster_midodrine {
    label="11. Drug PK/PD — Midodrine (α1-Agonist Prodrug)";
    style="filled,rounded"; color="#5c6370"; fillcolor="#e6f0ff"; fontsize=12;
    Midodrine_Gut    [label="Oral midodrine\n(GUT compartment)"];
    Midodrine_Plasma [label="Midodrine\nplasma"];
    Desglymidodrine  [label="Desglymidodrine\n(active metabolite)"];
    Alpha1_PD        [label="α1-agonism\n(arteriolar + venous)"];
    VenoArterioConstr[label="Venous & arteriolar\nconstriction"];
    SupineHTN_AE     [label="Supine hypertension\n(AE)"];
    Midodrine_Gut -> Midodrine_Plasma -> Desglymidodrine;
    Desglymidodrine -> Alpha1_PD;
    Alpha1_PD -> VenoArterioConstr;
    VenoArterioConstr -> VenousCapacit [style=dashed, label="↓ pooling"];
    VenoArterioConstr -> TPR;
    Desglymidodrine -> SupineHTN_AE [style=dashed];
  }

  /* ───────────────────────── 12. Drug PK/PD — Beta-blocker ───────────────── */
  subgraph cluster_bb {
    label="12. Drug PK/PD — Beta-blocker (Propranolol / Bisoprolol)";
    style="filled,rounded"; color="#5c6370"; fillcolor="#ffe6f0"; fontsize=12;
    BB_Gut           [label="Oral beta-blocker\n(GUT)"];
    BB_Plasma        [label="Beta-blocker\nplasma"];
    Beta1_Blockade   [label="β1-receptor\nblockade"];
    HR_Reduction_BB  [label="Chronotropic\nreduction"];
    Fatigue_AE_BB    [label="Fatigue / exercise\nlimitation (AE)"];
    BB_Gut -> BB_Plasma -> Beta1_Blockade;
    Beta1_Blockade -> HR_Reduction_BB;
    HR_Reduction_BB -> StandingHR [style=dashed, label="↓"];
    Beta1_Blockade -> Fatigue_AE_BB [style=dashed];
  }

  /* ───────────────────────── 13. Drug PK/PD — Fludrocortisone ────────────── */
  subgraph cluster_fludro {
    label="13. Drug PK/PD — Fludrocortisone";
    style="filled,rounded"; color="#5c6370"; fillcolor="#fff4d6"; fontsize=12;
    Fludro_Gut       [label="Oral fludrocortisone\n(GUT)"];
    Fludro_Plasma    [label="Fludrocortisone\nplasma"];
    MR_Renal         [label="Renal mineralocorticoid\nreceptor activation"];
    RenalNaReab      [label="Distal tubule Na+\nreabsorption ↑"];
    PlasmaVolExp     [label="Plasma volume\nexpansion"];
    Hypokalemia_AE   [label="Hypokalemia\n(AE)"];
    Fludro_Gut -> Fludro_Plasma -> MR_Renal;
    MR_Renal -> RenalNaReab;
    RenalNaReab -> PlasmaVolExp;
    PlasmaVolExp -> LowPlasmaVol [style=dashed, label="↑ (corrective)"];
    RenalNaReab -> Hypokalemia_AE [style=dashed];
  }

  /* ───────────────────────── 14. Drug PK/PD — Ivabradine ─────────────────── */
  subgraph cluster_ivabradine {
    label="14. Drug PK/PD — Ivabradine (If-Channel Blocker)";
    style="filled,rounded"; color="#5c6370"; fillcolor="#e6fff2"; fontsize=12;
    Ivabradine_Gut   [label="Oral ivabradine\n(GUT)"];
    Ivabradine_Plasma[label="Ivabradine\nplasma"];
    If_SAN_Block     [label="If (funny-current)\nblockade at SA node"];
    HR_Reduction_Selective [label="Selective HR reduction\n(BP-sparing)"];
    Phosphenes_AE    [label="Visual phosphenes\n(AE)"];
    Ivabradine_Gut -> Ivabradine_Plasma -> If_SAN_Block;
    If_SAN_Block -> HR_Reduction_Selective;
    HR_Reduction_Selective -> StandingHR [style=dashed, label="↓ w/o\nΔBP"];
    If_SAN_Block -> Phosphenes_AE [style=dashed];
  }

  /* ───────────────────────── 15. Drug PK/PD — Pyridostigmine & Droxidopa ─── */
  subgraph cluster_pyridodroxi {
    label="15. Drug PK/PD — Pyridostigmine & Droxidopa";
    style="filled,rounded"; color="#5c6370"; fillcolor="#f2e6ff"; fontsize=12;
    Pyridostigmine_Gut    [label="Oral pyridostigmine\n(GUT)"];
    Pyridostigmine_Plasma [label="Pyridostigmine\nplasma"];
    AChE_Inhib_Gangl      [label="AChE inhibition at\nautonomic ganglia"];
    SympParasym_Augment   [label="Ganglionic transmission\naugmentation (both limbs)"];
    GI_Cramping_AE        [label="GI cramping /\ndiarrhea (AE)"];
    Droxidopa_Gut         [label="Oral droxidopa\n(GUT)"];
    Droxidopa_Plasma      [label="Droxidopa\nplasma"];
    DOPA_Decarb_NE        [label="Peripheral DOPA-decarboxylase\n→ norepinephrine"];
    NE_Synthesis_Up       [label="De novo NE\nsynthesis ↑"];
    SupineHTN_AE2         [label="Supine hypertension\n(AE)"];
    Pyridostigmine_Gut -> Pyridostigmine_Plasma -> AChE_Inhib_Gangl;
    AChE_Inhib_Gangl -> SympParasym_Augment;
    SympParasym_Augment -> VagalEfferent [style=dashed, label="↑ vagal\nbrake on HR"];
    SympParasym_Augment -> PostganglSym [style=dashed, label="↑ compensatory\nvasoconstriction"];
    AChE_Inhib_Gangl -> GI_Cramping_AE [style=dashed];
    Droxidopa_Gut -> Droxidopa_Plasma -> DOPA_Decarb_NE;
    DOPA_Decarb_NE -> NE_Synthesis_Up;
    NE_Synthesis_Up -> Alpha1_Excess [style=dashed, label="↑ substrate"];
    NE_Synthesis_Up -> SupineHTN_AE2 [style=dashed];
  }

  /* ───────────────────────── 16. Non-pharmacologic Rx, Endpoints & Biomarkers ─ */
  subgraph cluster_endpoints {
    label="16. Non-pharmacologic Therapy, Clinical Endpoints & Biomarkers";
    style="filled,rounded"; color="#5c6370"; fillcolor="#fafafa"; fontsize=12;
    SaltFluidLoad    [label="Salt (10-12 g/day) +\nfluid (2-3 L/day) loading"];
    CompressionGarm  [label="Abdominal/lower-limb\ncompression garments"];
    ExerciseTraining [label="Recumbent/semi-recumbent\nexercise training program"];
    StandTest10min   [label="10-min active\nstand test"];
    TiltTableTest    [label="Head-up tilt-table\ntest"];
    COMPASS31        [label="COMPASS-31 autonomic\nsymptom score"];
    QoLScore         [label="Quality-of-life\nscore (SF-36/EQ-5D)"];
    PlasmaNE_Biomk   [label="Plasma norepinephrine\n(supine/standing) biomarker"];
    PlasmaAldo_Biomk [label="Plasma aldosterone /\nrenin biomarker"];
    PlasmaVol_Biomk  [label="Blood/plasma volume\n(I-131/CO) biomarker"];
    SaltFluidLoad -> LowPlasmaVol [style=dashed, label="↑ (corrective)"];
    CompressionGarm -> VenousCapacit [style=dashed, label="↓ effective\ncapacitance"];
    ExerciseTraining -> Deconditioning [style=dashed, label="reverses"];
    StandingHR -> StandTest10min;
    DeltaHR10 -> StandTest10min;
    StandTest10min -> TiltTableTest [style=dashed, label="confirmatory"];
    BrainFog -> COMPASS31;
    Presyncope -> COMPASS31;
    ExerciseIntoler -> COMPASS31;
    COMPASS31 -> QoLScore;
    StandNE_High -> PlasmaNE_Biomk;
    RAAS_Paradox -> PlasmaAldo_Biomk;
    ReducedTotalBV -> PlasmaVol_Biomk;
  }
}
