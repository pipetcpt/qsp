digraph IgG4RD_QSP {
  graph [
    label="IgG4-Related Disease (IgG4-RD)\nQuantitative Systems Pharmacology Model\nMechanistic Map: Immune Dysregulation, Fibrosis & Drug PK/PD"
    labelloc=t fontsize=22 fontname="Helvetica-Bold"
    bgcolor="#F7F9FB" rankdir=LR
    splines=ortho nodesep=0.45 ranksep=0.9
    pad=0.6
  ]
  node [fontname="Helvetica" fontsize=10 style="filled,rounded" shape=box penwidth=1.4]
  edge [fontname="Helvetica" fontsize=8 penwidth=1.2]

  /* ─────────────────────────────────────────────────────────────────
     CLUSTER 0: Antigen Presentation & Innate Immunity
  ───────────────────────────────────────────────────────────────── */
  subgraph cluster_innate {
    label="Antigen Presentation & Innate Immunity" style=filled fillcolor="#EDF7ED"
    fontname="Helvetica-Bold" fontsize=13 color="#2E7D32"

    APC      [label="Antigen\nPresenting Cell" fillcolor="#A5D6A7"]
    pDC      [label="Plasmacytoid\nDendritic Cell" fillcolor="#C8E6C9"]
    mDC      [label="Myeloid\nDendritic Cell" fillcolor="#C8E6C9"]
    Macro    [label="M1 Macrophage\n(pro-inflammatory)" fillcolor="#FFCDD2"]
    M2       [label="M2 Macrophage\n(anti-inflammatory)" fillcolor="#C8E6C9"]
    ILC2     [label="ILC2\n(Innate Lymphoid Cell 2)" fillcolor="#B2DFDB"]
    Mast     [label="Mast Cell" fillcolor="#FFE0B2"]
    Baso     [label="Basophil" fillcolor="#FFF9C4"]
    Neutro   [label="Neutrophil" fillcolor="#FFCCBC"]
    Eosin    [label="Eosinophil" fillcolor="#FFECB3"]
    pDC_IFN  [label="IFN-α/β\n(Type I IFN)" fillcolor="#E1F5FE"]
    TLR_sig  [label="TLR Signaling\n(PAMPs/DAMPs)" fillcolor="#F3E5F5"]
    NF_kB    [label="NF-κB\nActivation" fillcolor="#EF9A9A"]
    NLRP3    [label="NLRP3\nInflammasome" fillcolor="#FFAB91"]
    ST2      [label="ST2/IL-1RL1\nReceptor" fillcolor="#B2DFDB"]
  }

  /* ─────────────────────────────────────────────────────────────────
     CLUSTER 1: T Cell Activation & Differentiation
  ───────────────────────────────────────────────────────────────── */
  subgraph cluster_tcell {
    label="T Cell Activation & Differentiation" style=filled fillcolor="#E3F2FD"
    fontname="Helvetica-Bold" fontsize=13 color="#1565C0"

    Tnv      [label="Naïve CD4+\nT Cell" fillcolor="#BBDEFB"]
    Th1      [label="Th1 Cell\n(IFN-γ)" fillcolor="#EF9A9A"]
    Th2      [label="Th2 Cell\n(IL-4/IL-13)" fillcolor="#FFF9C4"]
    Th17     [label="Th17 Cell\n(IL-17)" fillcolor="#FFE0B2"]
    Treg     [label="Treg Cell\n(IL-10/TGF-β)" fillcolor="#C8E6C9"]
    Tfh1     [label="Tfh1 Cell\n(PD-1+ CXCR5+)" fillcolor="#FFCDD2"]
    Tfh2     [label="Tfh2 Cell★\n(PD-1+ CXCR5+ IL-4hi)" fillcolor="#FFF176"]
    CTL4     [label="Cytotoxic CD4+ T★\n(SLAMF7+ CD4+)" fillcolor="#F06292"]
    TCR_sig  [label="TCR/MHC-II\nEngagement" fillcolor="#E1F5FE"]
    CD28_co  [label="CD28/B7\nCostimulation" fillcolor="#B3E5FC"]
    CTLA4_T  [label="CTLA-4\nCheckpoint" fillcolor="#F8BBD0"]
    PD1_T    [label="PD-1\nExhaustion" fillcolor="#F8BBD0"]
    IL2_sig  [label="IL-2 Signaling\nT Proliferation" fillcolor="#B3E5FC"]
    CXCR5_T  [label="CXCR5 / PD-1\nGerminal Center Homing" fillcolor="#B2DFDB"]
    ICOS_T   [label="ICOS / ICOS-L\nTfh Differentiation" fillcolor="#B2DFDB"]
    STAT4    [label="STAT4\n(Th1 polarization)" fillcolor="#EF9A9A"]
    STAT6    [label="STAT6\n(Th2/Tfh2 polarization)" fillcolor="#FFF176"]
    RORC     [label="ROR-γt\n(Th17 polarization)" fillcolor="#FFE0B2"]
    FOXP3    [label="FOXP3+\n(Treg lineage)" fillcolor="#C8E6C9"]
  }

  /* ─────────────────────────────────────────────────────────────────
     CLUSTER 2: B Cell Activation & IgG4 Class Switching
  ───────────────────────────────────────────────────────────────── */
  subgraph cluster_bcell {
    label="B Cell Activation & IgG4 Class Switching" style=filled fillcolor="#FFF3E0"
    fontname="Helvetica-Bold" fontsize=13 color="#E65100"

    Bnv      [label="Naïve B Cell\n(IgM+)" fillcolor="#FFE0B2"]
    Bact     [label="Activated B Cell\n(GC-independent)" fillcolor="#FFCC80"]
    GCB      [label="Germinal Center\nB Cell" fillcolor="#FFB74D"]
    MBC      [label="Memory B Cell\n(IgG4+)" fillcolor="#FFA726"]
    PB       [label="Plasmablast★\n(short-lived)" fillcolor="#FF9800"]
    PC       [label="Long-lived\nPlasma Cell★" fillcolor="#F57C00"]
    CD20_B   [label="CD20\nSurface Antigen★" fillcolor="#EF6C00"]
    CD19_B   [label="CD19\nB Cell Marker" fillcolor="#BF360C"]
    BCR_sig  [label="BCR Signaling\n(antigen recognition)" fillcolor="#FFF8E1"]
    CD40_B   [label="CD40 / CD40L\nB-T Interaction" fillcolor="#FFF9C4"]
    BAFF_R   [label="BAFF-R / BCMA\nSurvival Receptor" fillcolor="#DCEDC8"]
    AID_CSR  [label="AID\n(Class Switch Recombination)" fillcolor="#FFE082"]
    IL4R_B   [label="IL-4Rα\nIgG4 Switch Signal★" fillcolor="#FFF176"]
    IL10R_B  [label="IL-10R\nAnti-apoptotic Signal" fillcolor="#F0F4C3"]
    IgM_B    [label="IgM Secretion" fillcolor="#E8F5E9"]
    IgG1_B   [label="IgG1 Secretion" fillcolor="#E8F5E9"]
    IgG4_B   [label="IgG4 Secretion★\n(non-inflammatory)" fillcolor="#FFCA28"]
    IgE_B    [label="IgE Secretion" fillcolor="#FFF9C4"]
  }

  /* ─────────────────────────────────────────────────────────────────
     CLUSTER 3: Cytokine Signaling Network
  ───────────────────────────────────────────────────────────────── */
  subgraph cluster_cytokine {
    label="Cytokine & Chemokine Network" style=filled fillcolor="#F9FBE7"
    fontname="Helvetica-Bold" fontsize=13 color="#558B2F"

    IL4      [label="IL-4★\n(Th2/Tfh2 → IgG4 switch)" fillcolor="#F9A825"]
    IL5      [label="IL-5\n(eosinophil)" fillcolor="#FFF59D"]
    IL6      [label="IL-6\n(plasmablast survival)" fillcolor="#FFF176"]
    IL10     [label="IL-10★\n(immunosuppression)" fillcolor="#AED581"]
    IL13     [label="IL-13★\n(fibrosis/Th2)" fillcolor="#FFCC02"]
    IL17     [label="IL-17A\n(neutrophil recruit)" fillcolor="#FF8F00"]
    IL21     [label="IL-21\n(plasmablast diff.)" fillcolor="#FFD54F"]
    IL33     [label="IL-33★\n(ILC2/Th2 axis)" fillcolor="#80DEEA"]
    IL35     [label="IL-35\n(Treg output)" fillcolor="#A5D6A7"]
    IFNg     [label="IFN-γ\n(Th1/Tfh1 output)" fillcolor="#EF9A9A"]
    TGFb1    [label="TGF-β1★\n(fibrosis driver)" fillcolor="#CE93D8"]
    BAFF     [label="BAFF/BLyS★\n(B cell survival)" fillcolor="#FFAB40"]
    APRIL    [label="APRIL\n(plasma cell survival)" fillcolor="#FFD180"]
    CXCL13   [label="CXCL13\n(GC homing)" fillcolor="#80CBC4"]
    CCL18    [label="CCL18\n(fibroblast activ.)" fillcolor="#CE93D8"]
    PDGF     [label="PDGF-BB\n(fibroblast prolif.)" fillcolor="#EF9A9A"]
    TSLP     [label="TSLP\n(DC activation)" fillcolor="#B2EBF2"]
    M2cyt    [label="M2 Cytokines\n(IL-10, TGF-β, CCL18)" fillcolor="#A5D6A7"]
  }

  /* ─────────────────────────────────────────────────────────────────
     CLUSTER 4: Fibrosis & Tissue Remodeling
  ───────────────────────────────────────────────────────────────── */
  subgraph cluster_fibrosis {
    label="Fibrosis & Tissue Remodeling" style=filled fillcolor="#F3E5F5"
    fontname="Helvetica-Bold" fontsize=13 color="#6A1B9A"

    Fibro    [label="Quiescent\nFibroblast" fillcolor="#E1BEE7"]
    MyoFib   [label="Myofibroblast★\n(α-SMA+)" fillcolor="#CE93D8"]
    Col1     [label="Collagen Type I\nDeposition" fillcolor="#AB47BC"]
    Col3     [label="Collagen Type III\nDeposition" fillcolor="#AB47BC"]
    FN1      [label="Fibronectin\nMatrix" fillcolor="#BA68C8"]
    MMP      [label="MMPs\n(matrix degradation)" fillcolor="#9C27B0"]
    TIMP     [label="TIMPs\n(MMP inhibition)" fillcolor="#7B1FA2"]
    Storiform [label="Storiform\nFibrosis Pattern★" fillcolor="#CE93D8"]
    OblitEbb  [label="Obliterative\nEndophlebitis★" fillcolor="#E1BEE7"]
    ECM_acc  [label="ECM Accumulation\n(fibrosis index)" fillcolor="#D1C4E9"]
    Wnt_fib  [label="Wnt/β-catenin\nFibrosis Signal" fillcolor="#F8BBD0"]
    HIF1a    [label="HIF-1α\nHypoxia Response" fillcolor="#FFCDD2"]
  }

  /* ─────────────────────────────────────────────────────────────────
     CLUSTER 5: Organ Manifestations
  ───────────────────────────────────────────────────────────────── */
  subgraph cluster_organs {
    label="Organ Manifestations" style=filled fillcolor="#E8EAF6"
    fontname="Helvetica-Bold" fontsize=13 color="#283593"

    PancAIP  [label="Autoimmune Pancreatitis\n(Type 1 AIP)★" fillcolor="#9FA8DA"]
    KidTIN   [label="Tubulointerstitial\nNephritis (IgG4-TIN)★" fillcolor="#9FA8DA"]
    SaliKutt [label="Kuttner's Tumor\n(Submandibular Gland)" fillcolor="#C5CAE9"]
    LacGland [label="Lacrimal Gland\nDacryoadenitis" fillcolor="#C5CAE9"]
    OrbPseudo [label="Orbital\nInflammation" fillcolor="#9FA8DA"]
    RetroFib [label="Retroperitoneal\nFibrosis (Ormond)" fillcolor="#7986CB"]
    AortaPeri [label="Periaortitis /\nAortic Aneurismal" fillcolor="#7986CB"]
    ThyRiedel [label="Riedel's\nThyroiditis" fillcolor="#C5CAE9"]
    LungILD  [label="IgG4-ILD\n(Lung Involvement)" fillcolor="#9FA8DA"]
    ProstatIgG4 [label="IgG4-Related\nProstatitis" fillcolor="#C5CAE9"]
    MeningIgG4 [label="IgG4 Pachymeningitis\n(Meningeal)" fillcolor="#7986CB"]
    CholitIgG4 [label="IgG4-Related\nCholangitis (IRC)" fillcolor="#9FA8DA"]
    Comp_dam [label="Composite\nOrgan Damage Score" fillcolor="#5C6BC0"]
  }

  /* ─────────────────────────────────────────────────────────────────
     CLUSTER 6: Serum Biomarkers & Clinical Endpoints
  ───────────────────────────────────────────────────────────────── */
  subgraph cluster_biomarker {
    label="Serum Biomarkers & Clinical Endpoints" style=filled fillcolor="#E0F7FA"
    fontname="Helvetica-Bold" fontsize=13 color="#006064"

    IgG4_S   [label="Serum IgG4★\n(biomarker; >135 mg/dL)" fillcolor="#80DEEA"]
    IgG_T    [label="Total IgG\n(hypergammaglobulinemia)" fillcolor="#B2EBF2"]
    IgE_S    [label="Serum IgE\n(elevated)" fillcolor="#B2EBF2"]
    Eos_C    [label="Peripheral\nEosinophilia" fillcolor="#80CBC4"]
    CRP_S    [label="CRP\n(often normal/low)" fillcolor="#80DEEA"]
    ESR_S    [label="ESR\n(often elevated)" fillcolor="#B2EBF2"]
    Cr_S     [label="Serum Creatinine\n(renal endpoint)" fillcolor="#4DD0E1"]
    Amylase  [label="Amylase/Lipase\n(pancreatic endpoint)" fillcolor="#4DD0E1"]
    IRI_score [label="IgG4-RD\nResponder Index (IRI)★" fillcolor="#00ACC1"]
    Histol   [label="Histopathology Score\n(lympho/fibro/IgG4+PC)" fillcolor="#0097A7"]
    CD4_CD8  [label="CD4:CD8 Ratio\n(reversed in lesions)" fillcolor="#006064"]
    PD_resp  [label="PD: Disease\nActivity Response" fillcolor="#00838F"]
    Relapse  [label="Relapse\nRisk Score" fillcolor="#006064"]
  }

  /* ─────────────────────────────────────────────────────────────────
     CLUSTER 7: Rituximab PK/PD (anti-CD20)
  ───────────────────────────────────────────────────────────────── */
  subgraph cluster_rtx_pk {
    label="Rituximab PK/PD (Anti-CD20)" style=filled fillcolor="#FCE4EC"
    fontname="Helvetica-Bold" fontsize=13 color="#880E4F"

    RTX_inf  [label="Rituximab Infusion\n(IV 1g or 375mg/m²)" fillcolor="#F48FB1"]
    RTX_C    [label="Rituximab\nCentral Compartment" fillcolor="#F06292"]
    RTX_P    [label="Rituximab\nPeripheral Compartment" fillcolor="#F48FB1"]
    RTX_dep  [label="Rituximab Depot\n(tissue distribution)" fillcolor="#FCE4EC"]
    CD20_free [label="CD20 (Free)\nTarget on B cells★" fillcolor="#F06292"]
    RTX_CD20 [label="Rituximab-CD20\nComplex (bound)" fillcolor="#C2185B"]
    ADCC_rtx [label="ADCC\n(NK cell mediated)" fillcolor="#880E4F"]
    CDC_rtx  [label="CDC\n(complement mediated)" fillcolor="#880E4F"]
    Apop_rtx [label="B Cell Apoptosis\nviaRTX binding" fillcolor="#F8BBD0"]
    Beff_rtx [label="B Cell Depletion\n(nadir: ≤5/μL)" fillcolor="#E91E63"]
    CL_rtx   [label="CL_RTX\n(TMDD: dose-dependent)" fillcolor="#F48FB1"]
    infusion_rate [label="k_inf\n(infusion rate)" fillcolor="#FCE4EC"]
  }

  /* ─────────────────────────────────────────────────────────────────
     CLUSTER 8: Prednisone PK/PD
  ───────────────────────────────────────────────────────────────── */
  subgraph cluster_pred_pk {
    label="Glucocorticoid PK/PD (Prednisone)" style=filled fillcolor="#FFF8E1"
    fontname="Helvetica-Bold" fontsize=13 color="#F57F17"

    PRED_gut [label="Prednisone\nGut Absorption" fillcolor="#FFE082"]
    PRED_C   [label="Prednisolone\nPlasma (active)" fillcolor="#FFD54F"]
    GR_cyt   [label="Cytoplasmic\nGlucocorticoid Receptor" fillcolor="#FFC107"]
    GR_nuc   [label="GR Nuclear\nTranslocation" fillcolor="#FFA000"]
    GRE      [label="GRE-mediated\nTransactivation" fillcolor="#FF8F00"]
    GRE_neg  [label="NF-κB Transrepression\n(anti-inflammatory)" fillcolor="#FF6F00"]
    GC_lym   [label="Lymphocyte\nApoptosis (GC)" fillcolor="#FFCCBC"]
    GC_eos   [label="Eosinophil\nSuppression (GC)" fillcolor="#FFE0B2"]
    GC_fib   [label="Fibroblast\nSuppression (GC)" fillcolor="#F3E5F5"]
    GC_SE    [label="Glucocorticoid\nSide Effects" fillcolor="#FFAB91"]
  }

  /* ─────────────────────────────────────────────────────────────────
     CLUSTER 9: Dupilumab PK/PD (anti-IL-4Rα)
  ───────────────────────────────────────────────────────────────── */
  subgraph cluster_dup_pk {
    label="Dupilumab PK/PD (Anti-IL-4Rα)" style=filled fillcolor="#E8F5E9"
    fontname="Helvetica-Bold" fontsize=13 color="#1B5E20"

    DUP_sc   [label="Dupilumab SC\nInjection Depot" fillcolor="#A5D6A7"]
    DUP_C    [label="Dupilumab\nPlasma Concentration" fillcolor="#66BB6A"]
    IL4Ra_free [label="IL-4Rα (Free)\nTarget★" fillcolor="#4CAF50"]
    DUP_IL4Ra [label="Dupilumab-IL-4Rα\nBound Complex" fillcolor="#2E7D32"]
    IL4_blk  [label="IL-4 Signaling\nBlocked" fillcolor="#A5D6A7"]
    IL13_blk [label="IL-13 Signaling\nBlocked" fillcolor="#A5D6A7"]
    STAT6_blk [label="STAT6\nPhosphorylation Blocked" fillcolor="#C8E6C9"]
    IgE_red  [label="IgE\nReduction" fillcolor="#DCEDC8"]
    IgG4_red [label="IgG4\nReduction (indirect)" fillcolor="#DCEDC8"]
  }

  /* ─────────────────────────────────────────────────────────────────
     CLUSTER 10: Disease Genetics & Susceptibility
  ───────────────────────────────────────────────────────────────── */
  subgraph cluster_genetics {
    label="Genetics & Disease Susceptibility" style=filled fillcolor="#ECEFF1"
    fontname="Helvetica-Bold" fontsize=13 color="#37474F"

    HLA_DRB1 [label="HLA-DRB1*0405\nSusceptibility" fillcolor="#CFD8DC"]
    FCGR2B   [label="FcγRIIB\n(inhibitory receptor)" fillcolor="#B0BEC5"]
    IL10_poly [label="IL-10 Promoter\nPolymorphism" fillcolor="#90A4AE"]
    CTLA4_poly [label="CTLA-4 +49A/G\nPolymorphism" fillcolor="#78909C"]
    Microb   [label="Microbial Trigger\n(H. pylori, etc.)" fillcolor="#B0BEC5"]
    Mol_mimicry [label="Molecular\nMimicry" fillcolor="#90A4AE"]
    Epigenetics [label="Epigenetic\nDysregulation" fillcolor="#607D8B"]
  }

  /* ─────────────────────────────────────────────────────────────────
     EDGES — Innate / APC / cytokines
  ───────────────────────────────────────────────────────────────── */
  TLR_sig -> NF_kB [label="activate"]
  TLR_sig -> NLRP3
  NF_kB -> IL6 [label="transcribe"]
  NF_kB -> BAFF [label="transcribe"]
  NLRP3 -> IL33 [label="process IL-18/IL-1β"]
  IL33 -> ST2 [label="bind"]
  ST2 -> ILC2 [label="activate"]
  ILC2 -> IL4 [label="produce"]
  ILC2 -> IL13 [label="produce"]
  ILC2 -> IL5 [label="produce"]
  pDC -> pDC_IFN [label="produce"]
  pDC_IFN -> Th1 [label="promote"]
  mDC -> APC [label="mature to"]
  APC -> TCR_sig [label="MHC-II present"]
  Macro -> M2 [label="IL-4/IL-13 polarize"]
  M2 -> M2cyt [label="secrete"]
  M2cyt -> TGFb1 [label="include"]
  M2cyt -> IL10 [label="include"]
  M2cyt -> CCL18 [label="include"]
  TSLP -> mDC [label="mature"]
  Baso -> IL4 [label="produce"]
  Eosin -> IL4 [label="contribute"]
  Eosin -> TGFb1 [label="produce"]
  Mast -> IL4 [label="produce"]

  /* ─────────────────────────────────────────────────────────────────
     EDGES — T Cell Differentiation
  ───────────────────────────────────────────────────────────────── */
  TCR_sig -> Tnv [label="signal"]
  CD28_co -> Tnv [label="costimulate"]
  Tnv -> Th1 [label="IL-12/STAT4"]
  Tnv -> Th2 [label="IL-4/STAT6"]
  Tnv -> Th17 [label="IL-6/TGF-β/RORγt"]
  Tnv -> Treg [label="TGF-β/FoxP3"]
  Tnv -> Tfh1 [label="IL-12 +ICOS"]
  Tnv -> Tfh2 [label="IL-4 +ICOS★"]
  Tnv -> CTL4 [label="chronic antigen → exhausted"]
  STAT4 -> Th1 [label="drive IFN-γ"]
  STAT6 -> Th2 [label="drive IL-4/13"]
  STAT6 -> Tfh2 [label="drive★"]
  RORC -> Th17 [label="drive"]
  FOXP3 -> Treg [label="lineage"]
  ICOS_T -> Tfh2 [label="differentiate"]
  CXCR5_T -> GCB [label="GC homing"]
  IL4 -> STAT6 [label="phosphorylate"]
  IL12_sig [label="IL-12 Signal" fillcolor="#EF9A9A"]
  IL12_sig -> STAT4 [label="activate"]
  IFNg -> Tfh1 [label="from Th1"]
  PD1_T -> Tfh2 [label="marks"]
  CTLA4_T -> Tnv [label="inhibit"]

  /* ─────────────────────────────────────────────────────────────────
     EDGES — B Cell Activation & Class Switching
  ───────────────────────────────────────────────────────────────── */
  BCR_sig -> Bact [label="activate"]
  CD40_B -> Bact [label="costimulate (CD40L from T)"]
  Bact -> GCB [label="GC reaction"]
  Tfh2 -> GCB [label="IL-21 + CXCL13"]
  Tfh2 -> CD40_B [label="CD40L provide"]
  GCB -> MBC [label="affinity mature"]
  GCB -> PB [label="differentiate"]
  PB -> PC [label="mature to"]
  IL4 -> AID_CSR [label="class switch to IgG4/IgE"]
  IL10 -> AID_CSR [label="switch to IgG4★"]
  IL21 -> PB [label="differentiate"]
  AID_CSR -> IgG4_B [label="produce★"]
  AID_CSR -> IgE_B [label="produce"]
  AID_CSR -> IgG1_B [label="produce"]
  PC -> IgG4_B [label="long-lived secretion"]
  BAFF -> BAFF_R [label="bind"]
  BAFF_R -> Bact [label="survival signal"]
  BAFF_R -> PB [label="survival signal"]
  APRIL -> BAFF_R [label="also bind BCMA"]
  IL4R_B -> AID_CSR [label="signal★"]
  IL10R_B -> PC [label="anti-apoptotic"]
  IL6 -> PB [label="survival + diff."]
  CD20_B -> RTX_CD20 [label="RTX target★"]

  /* ─────────────────────────────────────────────────────────────────
     EDGES — IgG4 & Biomarkers
  ───────────────────────────────────────────────────────────────── */
  IgG4_B -> IgG4_S [label="accumulate in serum"]
  IgG4_S -> Histol [label="tissue IgG4+ PC count"]
  IgG4_S -> IRI_score [label="contributes to"]
  IgE_B -> IgE_S [label="serum IgE"]
  IgG1_B -> IgG_T [label="contributes"]
  PC -> Histol [label="IgG4+ plasma cells"]
  Eos_C -> IRI_score [label="contributes"]

  /* ─────────────────────────────────────────────────────────────────
     EDGES — Fibrosis
  ───────────────────────────────────────────────────────────────── */
  TGFb1 -> MyoFib [label="activate★"]
  CCL18 -> Fibro [label="recruit"]
  PDGF -> Fibro [label="proliferate"]
  Fibro -> MyoFib [label="trans-differentiate"]
  MyoFib -> Col1 [label="synthesize"]
  MyoFib -> Col3 [label="synthesize"]
  MyoFib -> FN1 [label="synthesize"]
  Col1 -> ECM_acc [label="accumulate"]
  Col3 -> ECM_acc [label="accumulate"]
  TIMP -> MMP [label="inhibit"]
  MMP -> ECM_acc [label="degrade (counter)"]
  ECM_acc -> Storiform [label="pattern"]
  ECM_acc -> OblitEbb [label="encase vessels"]
  Wnt_fib -> MyoFib [label="promote"]
  TGFb1 -> TIMP [label="upregulate"]
  HIF1a -> TGFb1 [label="hypoxia-induced"]
  IL13 -> MyoFib [label="alternative fibrosis"]
  IL13 -> TGFb1 [label="induce"]

  /* ─────────────────────────────────────────────────────────────────
     EDGES — Organ Damage
  ───────────────────────────────────────────────────────────────── */
  ECM_acc -> PancAIP [label="pancreatic fibrosis"]
  ECM_acc -> KidTIN [label="interstitial fibrosis"]
  ECM_acc -> SaliKutt [label="salivary fibrosis"]
  ECM_acc -> LacGland [label="lacrimal fibrosis"]
  ECM_acc -> OrbPseudo [label="orbital mass"]
  ECM_acc -> RetroFib [label="retroperitoneal"]
  ECM_acc -> AortaPeri [label="periaortic"]
  ECM_acc -> ThyRiedel [label="thyroid fibrosis"]
  ECM_acc -> LungILD [label="lung ILD"]
  ECM_acc -> CholitIgG4 [label="biliary fibrosis"]
  PancAIP -> Amylase [label="↓ secretion → enzyme leak"]
  KidTIN -> Cr_S [label="↑ creatinine"]
  IgG4_S -> PancAIP [label="IgG4+ PC infiltrate"]
  IgG4_S -> KidTIN [label="IgG4+ PC infiltrate"]
  Storiform -> Histol [label="storiform pattern"]
  OblitEbb -> Histol [label="obliterative phlebitis"]
  PancAIP -> Comp_dam [label="organ score"]
  KidTIN -> Comp_dam [label="organ score"]
  CholitIgG4 -> Comp_dam [label="organ score"]
  OrbPseudo -> Comp_dam [label="organ score"]
  LungILD -> Comp_dam [label="organ score"]
  Comp_dam -> IRI_score [label="composite★"]

  /* ─────────────────────────────────────────────────────────────────
     EDGES — Rituximab PK/PD
  ───────────────────────────────────────────────────────────────── */
  RTX_inf -> infusion_rate [label="IV infusion"]
  infusion_rate -> RTX_C [label="k_inf → C1"]
  RTX_C -> RTX_P [label="CL12 distribution"]
  RTX_P -> RTX_C [label="CL21 redistribution"]
  RTX_C -> RTX_dep [label="tissue"]
  RTX_C -> RTX_CD20 [label="kon × CD20_free"]
  CD20_free -> RTX_CD20 [label="target engagement"]
  RTX_CD20 -> ADCC_rtx [label="Fc-FcγRIII → NK"]
  RTX_CD20 -> CDC_rtx [label="complement C1q"]
  ADCC_rtx -> Apop_rtx [label="kill B cells"]
  CDC_rtx -> Apop_rtx [label="kill B cells"]
  RTX_CD20 -> CL_rtx [label="TMDD: target-mediated CL"]
  Apop_rtx -> Beff_rtx [label="deplete B cells"]
  Beff_rtx -> CD20_B [label="reduce CD20 pool"]
  Beff_rtx -> PB [label="deplete plasmablasts"]
  Beff_rtx -> GCB [label="deplete GC B"]
  Beff_rtx -> Bnv [label="deplete naïve B"]
  Beff_rtx -> IgG4_S [label="→ IgG4 fall"]

  /* ─────────────────────────────────────────────────────────────────
     EDGES — Prednisone PK/PD
  ───────────────────────────────────────────────────────────────── */
  PRED_gut -> PRED_C [label="ka absorption"]
  PRED_C -> GR_cyt [label="bind GR"]
  GR_cyt -> GR_nuc [label="translocate"]
  GR_nuc -> GRE [label="bind GRE"]
  GR_nuc -> GRE_neg [label="repress NF-κB"]
  GRE -> GC_lym [label="apoptosis genes"]
  GRE_neg -> NF_kB [label="suppress"]
  GRE_neg -> IL4 [label="↓ transcription"]
  GRE_neg -> IL13 [label="↓ transcription"]
  GRE_neg -> TGFb1 [label="reduce"]
  GC_lym -> PB [label="deplete plasmablasts"]
  GC_lym -> Th2 [label="deplete"]
  GC_lym -> Tfh2 [label="deplete"]
  GC_eos -> Eosin [label="suppress"]
  GC_fib -> MyoFib [label="inhibit"]
  PRED_C -> GC_SE [label="adverse: DM, osteo, HTN"]

  /* ─────────────────────────────────────────────────────────────────
     EDGES — Dupilumab PK/PD
  ───────────────────────────────────────────────────────────────── */
  DUP_sc -> DUP_C [label="ka SC absorption"]
  DUP_C -> IL4Ra_free [label="kon binding"]
  IL4Ra_free -> DUP_IL4Ra [label="complex"]
  DUP_IL4Ra -> IL4_blk [label="block IL-4 signal"]
  DUP_IL4Ra -> IL13_blk [label="block IL-13 signal"]
  IL4_blk -> STAT6_blk [label="→ no STAT6-P"]
  STAT6_blk -> IgE_red [label="↓ IgE class switch"]
  STAT6_blk -> IgG4_red [label="↓ IgG4 switch★"]
  IL13_blk -> TGFb1 [label="↓ TGF-β induction"]
  IL4_blk -> AID_CSR [label="inhibit switch"]
  IL4 -> IL4Ra_free [label="compete binding"]
  IL13 -> IL4Ra_free [label="also binds type II"]

  /* ─────────────────────────────────────────────────────────────────
     EDGES — Genetics & Susceptibility
  ───────────────────────────────────────────────────────────────── */
  HLA_DRB1 -> TCR_sig [label="HLA-peptide"]
  FCGR2B -> BAFF_R [label="low FcγRIIB → less inhibition"]
  IL10_poly -> IL10 [label="low producer allele"]
  CTLA4_poly -> CTLA4_T [label="reduced inhibition"]
  Microb -> Mol_mimicry [label="molecular mimicry"]
  Mol_mimicry -> BCR_sig [label="cross-reactive B"]
  Mol_mimicry -> TCR_sig [label="cross-reactive T"]
  Epigenetics -> Tfh2 [label="Tfh2 epigenome open"]
  Epigenetics -> IL4 [label="IL4 locus accessible"]

  /* ─────────────────────────────────────────────────────────────────
     EDGES — Cytokine cross-talk
  ───────────────────────────────────────────────────────────────── */
  Tfh2 -> IL4 [label="primary source★"]
  Tfh2 -> IL21 [label="produce"]
  Tfh2 -> IL10 [label="produce"]
  Th2 -> IL4 [label="produce"]
  Th2 -> IL13 [label="produce"]
  Th2 -> IL5 [label="produce"]
  Treg -> IL10 [label="produce"]
  Treg -> IL35 [label="produce"]
  Treg -> TGFb1 [label="produce"]
  CTL4 -> IFNg [label="produce"]
  CTL4 -> TGFb1 [label="produce"]
  IL4 -> IL4R_B [label="activate"]
  IL4 -> Th2 [label="autocrine"]
  IL6 -> PC [label="survival"]
  IL10 -> PC [label="survival/IgG4 switch★"]
  IL21 -> GCB [label="promote"]
  IL21 -> PB [label="terminal diff."]
  BAFF -> GCB [label="support GC"]
  CXCL13 -> CXCR5_T [label="guide Tfh"]
  CXCL13 -> GCB [label="B cell homing"]
  M2 -> PDGF [label="secrete"]
  M2 -> TGFb1 [label="secrete"]

  /* ─────────────────────────────────────────────────────────────────
     EDGES — Clinical Response
  ───────────────────────────────────────────────────────────────── */
  Beff_rtx -> IRI_score [label="B cell depletion → IRI ↓"]
  GC_lym -> IRI_score [label="immune suppression → IRI ↓"]
  IgG4_S -> IRI_score [label="IgG4 component"]
  Comp_dam -> IRI_score [label="organ damage★"]
  IRI_score -> PD_resp [label="CR if IRI=0"]
  IRI_score -> Relapse [label="residual activity → risk"]
  MBC -> Relapse [label="memory B repopulate"]
  PC -> Relapse [label="long-lived PC persist"]
  IgG4_S -> Relapse [label="rising IgG4 = relapse"]

  /* ─────────────────────────────────────────────────────────────────
     Legend
  ───────────────────────────────────────────────────────────────── */
  subgraph cluster_legend {
    label="Legend" style=filled fillcolor="#FAFAFA" color="#BDBDBD"
    fontname="Helvetica-Bold" fontsize=11

    leg_key  [label="★ = Key node / Drug Target" fillcolor="#FFFF99" shape=note]
    leg_act  [label="→ Activation / Upregulation" fillcolor="white" shape=plaintext]
    leg_inh  [label="⊣ Inhibition (dashed)" fillcolor="white" shape=plaintext]
    leg_pk   [label="Shaded clusters = Drug PK/PD" fillcolor="#F8BBD0" shape=note]
  }
}
