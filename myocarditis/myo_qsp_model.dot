digraph Myocarditis_QSP {
  graph [
    label="Myocarditis QSP Model\nViral/Autoimmune Cardiomyocyte Injury, Immune Cascade & Cardiac Remodeling"
    fontsize=22
    fontname="Helvetica"
    rankdir=TB
    splines=polyline
    nodesep=0.35
    ranksep=0.55
    bgcolor="#F8F9FA"
    compound=true
    overlap=false
  ]

  node [fontname="Helvetica" fontsize=9 style="filled,rounded" shape=box margin="0.1,0.05"]
  edge [fontname="Helvetica" fontsize=7 arrowsize=0.7]

  // =============================================
  // Cluster 1: Viral Entry & Replication
  // =============================================
  subgraph cluster_viral {
    label="Viral Entry & Replication"
    style=filled
    fillcolor="#FFECEC"
    color="#CC0000"
    fontcolor="#CC0000"
    fontsize=13
    fontname="Helvetica-Bold"

    CVB3        [label="CVB3\n(Coxsackievirus B3)"  fillcolor="#FF6B6B" fontcolor=white]
    SARS2       [label="SARS-CoV-2\n(COVID-19)"      fillcolor="#FF6B6B" fontcolor=white]
    ADV         [label="Adenovirus\nType 2/5"         fillcolor="#FF6B6B" fontcolor=white]
    HHV6        [label="HHV-6\nParvovirus B19"        fillcolor="#FF6B6B" fontcolor=white]
    CAR_R       [label="CAR Receptor\n(Coxsackie-Adeno)" fillcolor="#FF9999"]
    ACE2        [label="ACE2 Receptor\n(SARS-CoV-2 entry)" fillcolor="#FF9999"]
    DAF         [label="DAF/CD55\nDecay Accelerating Factor" fillcolor="#FFCCCC"]
    V_intern    [label="Viral Internalization\nClathrin-mediated Endocytosis" fillcolor="#FFCCCC"]
    V_uncoat    [label="Viral Uncoating\nRNA/DNA Release into Cytosol" fillcolor="#FFCCCC"]
    V_replicate [label="Viral Replication\nViral RNA Polymerase" fillcolor="#FF9999"]
    V_assemble  [label="Viral Assembly &\nBudding from Host Cell" fillcolor="#FFCCCC"]
    proto_2A    [label="Viral Protease 2A\n(Dystrophin Cleavage)" fillcolor="#FF9999"]
    proto_3C    [label="Viral Protease 3C\n(TIR Domain Disruption)" fillcolor="#FF9999"]
    vDsRNA      [label="Viral dsRNA\n(PAMP - TLR3/MDA5)" fillcolor="#FFB3B3"]
    vSsRNA      [label="Viral ssRNA\n(PAMP - TLR7/RIG-I)" fillcolor="#FFB3B3"]
    vCpG        [label="Viral CpG DNA\n(PAMP - TLR9/cGAS)" fillcolor="#FFB3B3"]
  }

  // =============================================
  // Cluster 2: Pattern Recognition & Innate Signaling
  // =============================================
  subgraph cluster_prr {
    label="Pattern Recognition & Innate Signaling"
    style=filled
    fillcolor="#FFF3CD"
    color="#E67E00"
    fontcolor="#E67E00"
    fontsize=13
    fontname="Helvetica-Bold"

    TLR3    [label="TLR3\nEndosomal (dsRNA)" fillcolor="#FFD700"]
    TLR7    [label="TLR7/TLR8\nEndosomal (ssRNA)" fillcolor="#FFD700"]
    TLR9    [label="TLR9\nEndosomal (CpG DNA)" fillcolor="#FFD700"]
    RIG_I   [label="RIG-I\nCytosolic RNA Helicase" fillcolor="#FFD700"]
    MDA5    [label="MDA5\nLong dsRNA Sensor" fillcolor="#FFD700"]
    cGAS    [label="cGAS\nCytosolic DNA Sensor" fillcolor="#FFD700"]
    NLRP3   [label="NLRP3\nInflammasome Complex" fillcolor="#FFA500"]
    STING   [label="STING\ncGAMP Receptor" fillcolor="#FFA500"]
    MyD88   [label="MyD88\nTLR Adaptor Protein" fillcolor="#FFCC80"]
    TRIF    [label="TRIF/TICAM-1\nTLR3 Adaptor" fillcolor="#FFCC80"]
    MAVS    [label="MAVS\nMitochondrial AV Signaling" fillcolor="#FFCC80"]
    IRF3    [label="IRF3\nIFN Regulatory Factor 3" fillcolor="#FFB347"]
    IRF7    [label="IRF7\nIFN Regulatory Factor 7" fillcolor="#FFB347"]
    NFkB    [label="NF-κB p65/p50\nMaster Inflammatory TF" fillcolor="#E67E00" fontcolor=white]
    AP1     [label="AP-1 (c-Jun/c-Fos)\nInflammatory Transcription" fillcolor="#E67E00" fontcolor=white]
    JAK1    [label="JAK1\n(Janus Kinase 1)" fillcolor="#FFCC80"]
    JAK2    [label="JAK2\n(Janus Kinase 2)" fillcolor="#FFCC80"]
    STAT1   [label="STAT1/STAT2\nIFN Signaling" fillcolor="#FFCC80"]
    STAT3   [label="STAT3\nIL-6 Signaling" fillcolor="#FFCC80"]
    MAPK    [label="MAPK/p38/ERK\nStress Kinase Cascade" fillcolor="#FFCC80"]
    CaN     [label="Calcineurin\nPhosphatase (Ca-dependent)" fillcolor="#FFCC80"]
    NFAT    [label="NFAT\nCalcineurin Target" fillcolor="#FFB347"]
  }

  // =============================================
  // Cluster 3: Innate Immune Effectors & Cytokines
  // =============================================
  subgraph cluster_innate {
    label="Innate Immune Effectors & Cytokines"
    style=filled
    fillcolor="#E8F5E9"
    color="#2E7D32"
    fontcolor="#2E7D32"
    fontsize=13
    fontname="Helvetica-Bold"

    NK      [label="NK Cells\nNatural Killer Lymphocytes" fillcolor="#66BB6A" fontcolor=white]
    M1      [label="M1 Macrophage\nClassical Pro-inflammatory" fillcolor="#43A047" fontcolor=white]
    M2      [label="M2 Macrophage\nAlternative Anti-inflammatory" fillcolor="#81C784"]
    mDC     [label="Myeloid DC\nAntigen Presenting Cell" fillcolor="#A5D6A7"]
    pDC     [label="Plasmacytoid DC\nIFN-α Factory" fillcolor="#A5D6A7"]
    Neutro  [label="Neutrophils\nNETs / ROS Burst" fillcolor="#C8E6C9"]
    Mast    [label="Mast Cells\nHistamine / Tryptase" fillcolor="#C8E6C9"]
    C3      [label="Complement C3\nActivation (Classical/Lectin)" fillcolor="#A5D6A7"]
    C5a     [label="Complement C5a\nAnaphylatoxin" fillcolor="#81C784"]
    MAC     [label="C5b-9 MAC\nMembrane Attack Complex" fillcolor="#66BB6A" fontcolor=white]
    IFNa    [label="IFN-α\nType I Interferon" fillcolor="#66BB6A" fontcolor=white]
    IFNb    [label="IFN-β\nType I Interferon" fillcolor="#66BB6A" fontcolor=white]
    IFNg    [label="IFN-γ\nType II Interferon (NK/Th1)" fillcolor="#43A047" fontcolor=white]
    TNFa    [label="TNF-α\nTumor Necrosis Factor" fillcolor="#388E3C" fontcolor=white]
    IL1b    [label="IL-1β / IL-18\nInflammasome Products" fillcolor="#2E7D32" fontcolor=white]
    IL6     [label="IL-6\ngp130/JAK-STAT Signaling" fillcolor="#388E3C" fontcolor=white]
    IL12    [label="IL-12 / IL-23\nTh1 / Th17 Polarizing" fillcolor="#4CAF50" fontcolor=white]
    IL10    [label="IL-10\nAnti-inflammatory Cytokine" fillcolor="#81C784"]
    ROS     [label="Reactive Oxygen Species\nSuperoxide / H2O2" fillcolor="#C8E6C9"]
    RNS     [label="Reactive Nitrogen Species\niNOS / NO / ONOO-" fillcolor="#C8E6C9"]
    Perforin [label="Perforin / Granzyme B\nNK & CTL Effector Molecules" fillcolor="#66BB6A" fontcolor=white]
    HMGB1   [label="HMGB1 / S100A8\nLate DAMP Signals" fillcolor="#A5D6A7"]
    ATP_D   [label="ATP / Uric Acid\nDanger Signals (DAMP)" fillcolor="#A5D6A7"]
    CCL2    [label="CCL2 / CXCL10\nMonocyte/T Cell Chemoattractant" fillcolor="#C8E6C9"]
  }

  // =============================================
  // Cluster 4: Adaptive Immune Response
  // =============================================
  subgraph cluster_adaptive {
    label="Adaptive Immune Response"
    style=filled
    fillcolor="#E3F2FD"
    color="#1565C0"
    fontcolor="#1565C0"
    fontsize=13
    fontname="Helvetica-Bold"

    nCD4    [label="Naive CD4+ T Cell\n(Th0 Precursor)" fillcolor="#90CAF9"]
    Th1     [label="Th1 Cell\n(IFN-γ, TNF-α, IL-2)" fillcolor="#1E88E5" fontcolor=white]
    Th2     [label="Th2 Cell\n(IL-4, IL-5, IL-13)" fillcolor="#42A5F5"]
    Th17    [label="Th17 Cell\n(IL-17A/F, IL-22)" fillcolor="#1976D2" fontcolor=white]
    Treg    [label="Treg Cell\n(FOXP3+, IL-10, TGF-β)" fillcolor="#64B5F6"]
    Tfh     [label="Tfh Cell\n(IL-21, CXCR5, PD-1+)" fillcolor="#90CAF9"]
    nCD8    [label="Naive CD8+ T Cell\n(CTL Precursor)" fillcolor="#BBDEFB"]
    CTL     [label="CD8+ CTL\nCytotoxic T Lymphocyte" fillcolor="#1565C0" fontcolor=white]
    nB      [label="Naive B Cell\n(IgM+IgD+)" fillcolor="#BBDEFB"]
    GC      [label="Germinal Center\nAffinity Maturation" fillcolor="#90CAF9"]
    PC      [label="Plasma Cell\nAntibody Secretion" fillcolor="#64B5F6"]
    memB    [label="Memory B Cell\nLong-lived Immune Memory" fillcolor="#BBDEFB"]
    memT    [label="Memory T Cell\n(CD4+/CD8+ Memory)" fillcolor="#90CAF9"]
    IL2_T   [label="IL-2\nT Cell Proliferation Factor" fillcolor="#64B5F6"]
    IL4     [label="IL-4\nTh2 / B Cell Switch" fillcolor="#BBDEFB"]
    IL17A   [label="IL-17A / IL-17F\nTissue-destructive Cytokine" fillcolor="#42A5F5"]
    IL21    [label="IL-21\nGerminal Center B Cell Help" fillcolor="#BBDEFB"]
    TGFb    [label="TGF-β\nTreg Induction / Profibrotic" fillcolor="#90CAF9"]
    CTLA4   [label="CTLA-4\nCo-inhibitory Checkpoint" fillcolor="#E3F2FD"]
    PD1     [label="PD-1 / PD-L1\nT Cell Exhaustion Pathway" fillcolor="#E3F2FD"]
    MHC2    [label="MHC-II\nCD4 T Cell Antigen Presentation" fillcolor="#90CAF9"]
    MHC1    [label="MHC-I\nCD8 T Cell Antigen Presentation" fillcolor="#BBDEFB"]
    CXCR3   [label="CXCR3 / CCR5\nEffector T Cell Homing" fillcolor="#BBDEFB"]
  }

  // =============================================
  // Cluster 5: Autoimmunity & Molecular Mimicry
  // =============================================
  subgraph cluster_autoimmune {
    label="Autoimmunity & Molecular Mimicry"
    style=filled
    fillcolor="#F3E5F5"
    color="#6A1B9A"
    fontcolor="#6A1B9A"
    fontsize=13
    fontname="Helvetica-Bold"

    CardMyosin  [label="Cardiac Myosin Heavy\nChain (Self-antigen)" fillcolor="#CE93D8"]
    AntiMyo     [label="Anti-Myosin Abs\n(IgG Anti-cardiac)" fillcolor="#BA68C8"]
    b1AR        [label="β1-Adrenergic Receptor\n(Cardiac Surface)" fillcolor="#AB47BC"]
    Antib1AR    [label="Anti-β1AR Agonistic Abs\n(Functional Autoantibody)" fillcolor="#9C27B0" fontcolor=white]
    ANT         [label="Adenine Nucleotide\nTranslocator (ANT)" fillcolor="#CE93D8"]
    AntiANT     [label="Anti-ANT Antibodies\n(Mitochondrial Autoantigen)" fillcolor="#BA68C8"]
    TroponinI   [label="Cardiac Troponin I\n(Autoantigen after Damage)" fillcolor="#CE93D8"]
    AntiTnI     [label="Anti-Troponin I Abs\n(Autoimmune marker)" fillcolor="#BA68C8"]
    CompFix     [label="Complement Fixation\nAb-antigen Complex" fillcolor="#E1BEE7"]
    ADCC        [label="ADCC\nFc-receptor mediated NK" fillcolor="#CE93D8"]
    MolMim      [label="Molecular Mimicry\nViral-Cardiac Cross-reactivity" fillcolor="#E040FB"]
    EpiSpread   [label="Epitope Spreading\nSelf-antigen Expansion" fillcolor="#CE93D8"]
    RegFail     [label="Peripheral Tolerance\nFailure (Treg dysfunction)" fillcolor="#E1BEE7"]
    CXCL10      [label="CXCL10 / IP-10\nMyocardial T Cell Recruitment" fillcolor="#CE93D8"]
  }

  // =============================================
  // Cluster 6: Cardiomyocyte Injury & Death
  // =============================================
  subgraph cluster_cmc {
    label="Cardiomyocyte Injury & Cell Death"
    style=filled
    fillcolor="#FFF8E1"
    color="#E65100"
    fontcolor="#E65100"
    fontsize=13
    fontname="Helvetica-Bold"

    CMC_H   [label="Healthy Cardiomyocyte\n(Contractile, Resting)" fillcolor="#FFD54F"]
    CMC_I   [label="Virally Infected\nCardiomyocyte" fillcolor="#FF9800" fontcolor=white]
    CMC_J   [label="Immune-injured\nCardiomyocyte" fillcolor="#F57C00" fontcolor=white]
    CMC_Apo [label="Cardiomyocyte\nApoptosis (Programmed)" fillcolor="#E65100" fontcolor=white]
    CMC_Nec [label="Cardiomyocyte Necrosis\nPyroptosis/Necroptosis" fillcolor="#BF360C" fontcolor=white]
    Dystro  [label="Dystrophin Cleavage\nSarcolemma Destabilization" fillcolor="#FFB300"]
    Sarco   [label="Sarcomere Disruption\nActin-Myosin Uncoupling" fillcolor="#FFB300"]
    Mito_D  [label="Mitochondrial Dysfunction\nETC Complex Inhibition" fillcolor="#FFA000"]
    mPTP    [label="mPTP Opening\nPermeability Transition Pore" fillcolor="#FF8F00"]
    CytC    [label="Cytochrome c Release\nIntrinsic Apoptosis" fillcolor="#FF6F00"]
    Casp3   [label="Caspase-3/7 Activation\nApoptosis Execution" fillcolor="#E65100" fontcolor=white]
    GSDMD   [label="Gasdermin-D Pore\nPyroptosis Execution" fillcolor="#BF360C" fontcolor=white]
    Ca_OL   [label="Ca2+ Overload\nExcitation-Contraction Coupling" fillcolor="#FFD54F"]
    ER_ST   [label="ER Stress / UPR\nUnfolded Protein Response" fillcolor="#FFE082"]
    Cx43    [label="Connexin-43 Gap Junction\nDisruption" fillcolor="#FFB300"]
    TnLeak  [label="Troponin I/T Leak\nInto Circulation" fillcolor="#FFA000"]
    BNPrel  [label="BNP / NT-proBNP\nWall Stress-mediated Release" fillcolor="#FFA000"]
    CKleak  [label="CK-MB / LDH Leak\nNon-specific Markers" fillcolor="#FFB300"]
  }

  // =============================================
  // Cluster 7: Cardiac Remodeling & Fibrosis
  // =============================================
  subgraph cluster_remodel {
    label="Cardiac Remodeling & Fibrosis"
    style=filled
    fillcolor="#E8EAF6"
    color="#283593"
    fontcolor="#283593"
    fontsize=13
    fontname="Helvetica-Bold"

    CFib    [label="Cardiac Fibroblast\n(Quiescent)" fillcolor="#9FA8DA"]
    MFib    [label="Myofibroblast\nα-SMA+ Activated" fillcolor="#5C6BC0" fontcolor=white]
    ColI    [label="Collagen I / III\nECM Deposition" fillcolor="#3949AB" fontcolor=white]
    ECM_R   [label="ECM Remodeling\nMMP/TIMP Balance" fillcolor="#7986CB"]
    MMP9    [label="MMP-1/3/9/13\nMatrix Metalloproteinases" fillcolor="#9FA8DA"]
    TIMP    [label="TIMP-1/2/4\nMMP Inhibitors" fillcolor="#9FA8DA"]
    LVdil   [label="LV Dilation\nEccentric Hypertrophy" fillcolor="#1A237E" fontcolor=white]
    LVhyp   [label="LV Hypertrophy\nIncreased Wall Mass" fillcolor="#283593" fontcolor=white]
    IFib    [label="Interstitial Fibrosis\nDiffuse / Replacement" fillcolor="#3F51B5" fontcolor=white]
    RAAS    [label="RAAS Activation\nRenin-ACE Cascade" fillcolor="#5C6BC0" fontcolor=white]
    AngII   [label="Angiotensin II\nVasoconstrictor / Profibrotic" fillcolor="#7986CB"]
    Aldo    [label="Aldosterone\nNa+ Retention / Fibrosis" fillcolor="#9FA8DA"]
    SNS     [label="Sympathetic Activation\nNE / Epinephrine Surge" fillcolor="#9FA8DA"]
    b1_down [label="β1-AR Downregulation\nDesensitization" fillcolor="#7986CB"]
    WMabn   [label="Wall Motion Abnormalities\nRegional/Global" fillcolor="#9FA8DA"]
    DiaDys  [label="Diastolic Dysfunction\nImpaired LV Relaxation" fillcolor="#7986CB"]
    LVEDPup [label="↑LVEDP\nElevated Filling Pressure" fillcolor="#7986CB"]
  }

  // =============================================
  // Cluster 8: Clinical Endpoints & Biomarkers
  // =============================================
  subgraph cluster_clinical {
    label="Clinical Endpoints & Biomarkers"
    style=filled
    fillcolor="#F1F8E9"
    color="#33691E"
    fontcolor="#33691E"
    fontsize=13
    fontname="Helvetica-Bold"

    TnCirc  [label="Circulating Troponin\nI / T (μg/L)" fillcolor="#AED581"]
    BNPcirc [label="BNP / NT-proBNP\n(pg/mL) Heart Failure Marker" fillcolor="#AED581"]
    LVEF    [label="LVEF (%)\nLeft Ventricular Ejection Fraction" fillcolor="#8BC34A" fontcolor=white]
    CMR     [label="Cardiac MRI\nLate Gadolinium Enhancement" fillcolor="#7CB342" fontcolor=white]
    ECG     [label="ECG Abnormalities\nST/T-wave / QRS / QTc" fillcolor="#9CCC65"]
    Echo    [label="Echo Parameters\nE/A, E/e', TAPSE, RVSP" fillcolor="#9CCC65"]
    T2MRI   [label="T2-weighted MRI\nMyocardial Edema Index" fillcolor="#AED581"]
    PEff    [label="Pericardial Effusion\nMyo-pericarditis Overlap" fillcolor="#AED581"]
    VArrhyth [label="Ventricular Arrhythmia\nVT/VF Risk" fillcolor="#F57F17" fontcolor=white]
    CSock   [label="Cardiogenic Shock\nFulminant Myocarditis" fillcolor="#E65100" fontcolor=white]
    Recovery [label="Complete Recovery\nLVEF > 50% at 6 months" fillcolor="#558B2F" fontcolor=white]
    ProgDCM [label="Progression to DCM\nLVEF < 35% Chronic" fillcolor="#E65100" fontcolor=white]
    CRP     [label="CRP / ESR\nAcute Phase Reactants" fillcolor="#C5E1A5"]
    WBC     [label="WBC / Lymphopenia\nDifferential Count" fillcolor="#C5E1A5"]
    CytStorm [label="Cytokine Storm\nHyper-inflammatory State" fillcolor="#FF8F00" fontcolor=white]
    EMB     [label="Endomyocardial Biopsy\nDallas Criteria" fillcolor="#AED581"]
  }

  // =============================================
  // Cluster 9: Pharmacological Interventions
  // =============================================
  subgraph cluster_drugs {
    label="Pharmacological Interventions (Drug PK/PD)"
    style=filled
    fillcolor="#FCE4EC"
    color="#880E4F"
    fontcolor="#880E4F"
    fontsize=13
    fontname="Helvetica-Bold"

    IVIG_d    [label="IVIG\n2 g/kg IV (2-day infusion)" fillcolor="#F48FB1"]
    IVIG_Fc   [label="IVIG→Fc Receptor\nSaturation & Blockade" fillcolor="#F06292"]
    IVIG_neut [label="IVIG→Anti-antibody\nNeutralization" fillcolor="#F06292"]
    PRED      [label="Prednisone\n0.5–1 mg/kg/day oral" fillcolor="#EC407A" fontcolor=white]
    GCR       [label="Glucocorticoid Receptor\nNF-κB / AP-1 Inhibition" fillcolor="#E91E63" fontcolor=white]
    AZA       [label="Azathioprine\n1–3 mg/kg/day oral" fillcolor="#F48FB1"]
    AZA_6MP   [label="6-Mercaptopurine\nPurine Synthesis Inhibition" fillcolor="#F06292"]
    CSA       [label="Cyclosporine A\n2–5 mg/kg/day (divided)" fillcolor="#F48FB1"]
    CSA_CaN   [label="Calcineurin Inhibition\nNFAT/IL-2 Blockade" fillcolor="#F06292"]
    COLC      [label="Colchicine\n0.5 mg BID Anti-pericarditis" fillcolor="#F48FB1"]
    COLC_tub  [label="Tubulin Polymerization\nInflammasome Disruption" fillcolor="#F06292"]
    RTX       [label="Rituximab\nAnti-CD20 B Cell Depletion" fillcolor="#EC407A" fontcolor=white]
    ANAK      [label="Anakinra / Rilonacept\nAnti-IL-1R Antagonist" fillcolor="#F48FB1"]
    RUXO      [label="Ruxolitinib\nJAK1/2 Inhibitor" fillcolor="#F48FB1"]
    HFtx      [label="HF Standard Therapy\nACEi / ARB / ARNI / BB / MRA" fillcolor="#F8BBD9"]
    Anticoag  [label="Anticoagulation\nHeparin / NOAC (LV thrombus)" fillcolor="#F8BBD9"]
    MechSup   [label="Mechanical Support\nIABP / Impella / VA-ECMO" fillcolor="#FCE4EC"]
    SteroidPK [label="Steroid PK\nF=80%, t½=2-3h, CL=3.4L/h" fillcolor="#F8BBD9"]
    IVIGPK    [label="IVIG PK\nCentral/Peripheral, t½=21 days" fillcolor="#F8BBD9"]
  }

  // =============================================
  // Cluster 10: Giant Cell Myocarditis (Special Variant)
  // =============================================
  subgraph cluster_gcm {
    label="Giant Cell Myocarditis (Rare Autoimmune Variant)"
    style=filled
    fillcolor="#FFF9C4"
    color="#F57F17"
    fontcolor="#F57F17"
    fontsize=13
    fontname="Helvetica-Bold"

    GCM      [label="Giant Cell Myocarditis\n(Idiopathic / Autoimmune)" fillcolor="#FFF176"]
    MNG_GC   [label="Multinucleated Giant Cells\n(Fused Macrophages)" fillcolor="#FFEE58"]
    EosiInf  [label="Eosinophil + Lymphocyte\nMyocardial Infiltrate" fillcolor="#FFF176"]
    T_GCM    [label="CD4+/CD8+ T Cell\nMediated Pathology" fillcolor="#FFCA28"]
    NoViral  [label="No Viral Trigger\nPrimary Autoimmune Etiology" fillcolor="#FFF9C4"]
    ThymoAs  [label="Thymoma / MG / IBD\nAssociated Conditions" fillcolor="#FFF176"]
    HBlock   [label="Complete Heart Block\n& Ventricular Tachycardia" fillcolor="#F57F17" fontcolor=white]
    GCMtx    [label="Combined IS Therapy\nPrednisolone + CsA + Azathioprine" fillcolor="#FFB300" fontcolor=white]
    ICD_GCM  [label="ICD Implantation\nSCD Prevention" fillcolor="#FFCC02"]
    HTx_GCM  [label="Heart Transplant\nLast Resort" fillcolor="#FFB300" fontcolor=white]
  }

  // =============================================
  // EDGES: Viral Entry
  // =============================================
  CVB3     -> CAR_R    [label="binds" color="#CC0000" penwidth=1.5]
  SARS2    -> ACE2     [label="binds" color="#CC0000" penwidth=1.5]
  ADV      -> CAR_R    [label="binds" color="#CC0000"]
  HHV6     -> CMC_H    [label="infects directly" color="#CC0000" style=dashed]
  CAR_R    -> V_intern [color="#CC0000"]
  ACE2     -> V_intern [color="#CC0000"]
  DAF      -> CAR_R    [label="co-receptor" color="#CC0000"]
  V_intern -> V_uncoat  [color="#CC0000"]
  V_uncoat -> V_replicate [color="#CC0000"]
  V_replicate -> V_assemble [color="#CC0000"]
  V_assemble -> CVB3   [label="new virions" color="#CC0000" style=dashed]
  V_replicate -> vDsRNA [color="#CC0000"]
  V_replicate -> vSsRNA [color="#CC0000"]
  vCpG     -> cGAS     [color="#CC0000"]
  V_replicate -> proto_2A [label="encodes" color="#CC0000"]
  V_replicate -> proto_3C [label="encodes" color="#CC0000"]
  proto_2A -> Dystro   [label="cleaves" color="#CC0000" penwidth=1.5]
  proto_3C -> TRIF     [label="cleaves" color="#CC0000"]
  V_intern -> CMC_I    [color="#CC0000" penwidth=1.5]
  CMC_H    -> CMC_I    [label="viral entry" color="#CC0000" style=dashed]

  // =============================================
  // EDGES: Pattern Recognition Signaling
  // =============================================
  vDsRNA -> TLR3  [label="activates" color="#E67E00"]
  vSsRNA -> TLR7  [label="activates" color="#E67E00"]
  vCpG   -> TLR9  [label="activates" color="#E67E00"]
  vDsRNA -> RIG_I [label="activates" color="#E67E00"]
  vDsRNA -> MDA5  [label="activates" color="#E67E00"]
  TLR3   -> TRIF  [color="#E67E00"]
  TLR7   -> MyD88 [color="#E67E00"]
  TLR9   -> MyD88 [color="#E67E00"]
  RIG_I  -> MAVS  [color="#E67E00"]
  MDA5   -> MAVS  [color="#E67E00"]
  CMC_Nec -> cGAS [label="dsDNA release" color="#E67E00"]
  cGAS   -> STING [color="#E67E00"]
  MyD88  -> NFkB  [color="#E67E00" penwidth=1.5]
  MyD88  -> IRF7  [color="#E67E00"]
  TRIF   -> NFkB  [color="#E67E00"]
  TRIF   -> IRF3  [color="#E67E00"]
  MAVS   -> NFkB  [color="#E67E00"]
  MAVS   -> IRF3  [color="#E67E00"]
  STING  -> IRF3  [color="#E67E00"]
  STING  -> NFkB  [color="#E67E00"]
  ATP_D  -> NLRP3 [label="primes" color="#E67E00"]
