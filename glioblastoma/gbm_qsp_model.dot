  MGMT_pred   -> PFS_ep      [label="MGMT+: better\nTMZ response" color="#283593"]
  mOS_data    -> OS_ep       [label="clinical\nbenchmark" color="#283593" style=dashed]
  Casp3       -> TumorVol    [label="tumor cell death\n→volume reduction" color="#9C27B0" arrowhead=tee]
  KPS_ep      -> OS_ep       [label="prognostic\ncovariate" color="#283593"]
  TumorVol    -> Seizure_ep  [label="mass effect\n→seizure" color="#5C6BC0"]
