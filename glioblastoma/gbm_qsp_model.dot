  ANG2     -> TIE2    [label="destabilize\nvessels" color="#F44336" arrowhead=tee]
  ANG1     -> TIE2    [label="stabilize\nvessels" color="#4CAF50"]
  PDGF_B   -> Pericyte [label="BB isoform\nrecruit" color="#4CAF50"]
  FGF2     -> EndoCell [label="angiogenic\nRTK" color="#2196F3"]
  PlGF     -> VEGFR1  [label="VEGFR1 decoy\n(reduce VEGFR2)" color="#90CAF9"]

  // --- Bevacizumab ---
  BEV_dose -> BEV_Cp   [label="IV infusion\nPK" color="#4FC3F7"]
  BEV_Cp   -> BEV_Cp2  [label="distribution\n(Q/V)" color="#4FC3F7"]
  BEV_Cp   -> Free_BEV [label="free drug" color="#4FC3F7"]
