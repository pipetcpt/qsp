  // --- GSC Pathways ---
  GSC      -> CD133_m  [label="express\nmarker" color="#FF9800"]
  GSC      -> SOX2_g   [label="express" color="#FF9800"]
  GSC      -> OCT4_g   [label="express" color="#FF9800"]
  GSC      -> Nestin_g [label="express" color="#FF9800"]
  GSC      -> ALDH1_g  [label="express" color="#FF9800"]
  Notch_R  -> HES1_g   [label="NICD γ-secretase\n→nuclear" color="#FF9800"]
  HES1_g   -> GSC      [label="maintain\nstemness" color="#FF9800"]
  SHH_g    -> GLI1_g   [label="SMO→\nGLI activation" color="#FF9800"]
  GLI1_g   -> GSC      [label="stemness\nprogram" color="#FF9800"]
  Wnt_g    -> Beta_cat  [label="β-cat nuclear\ntranslocation" color="#FF9800"]
