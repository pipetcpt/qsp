  TMZ_brain -> MTIC_comp [label="hydrolysis" color="#F57F17"]

  // --- Tumor volume & Endpoints ---
  TumorVol    -> FLAIR_vol   [label="T2 correlate\n(mm³)" color="#5C6BC0"]
  TumorVol    -> Enhance_vol [label="T1+Gd\ncorrelate" color="#5C6BC0"]
  FLAIR_vol   -> RANO_crit   [label="sum longest\ndiam. (SLD)" color="#5C6BC0"]
  Enhance_vol -> RANO_crit   [label="enhancement\nchange" color="#5C6BC0"]
  RANO_crit   -> PseudoP     [label="early↑ (1-3 mo)\nnot true PD" color="#9FA8DA" style=dashed]
  RANO_crit   -> PFS_ep      [label="time to\n25% ↑" color="#283593"]
  RANO_crit   -> OS_ep       [label="survival\nanalysis" color="#283593"]
