  BMP_g    -> GSC      [label="promote\ndifferentiation" color="#4CAF50" arrowhead=tee]
  niche    -> GSC      [label="perivascular\nmaintenance" color="#FF9800"]
  GSC      -> TumorVol [label="post-treatment\nrepopulation" color="#FF5722"]
  GSC      -> VEGFA    [label="secrete\n(tumor niche)" color="#2196F3"]

  // --- BBB ---
  TMZ_Cp   -> BBB_p   [label="passive diffusion" color="#26A69A"]
  BBB_p    -> TMZ_brain [label="Kp,uu=0.28" color="#26A69A"]
  Pgp_p    -> TMZ_brain [label="minor efflux" color="#F44336" arrowhead=tee]
  BCRP_p   -> TMZ_brain [label="efflux" color="#F44336" arrowhead=tee]
  BTB_p    -> TMZ_brain [label="enhanced\npenetration" color="#26A69A"]

  // --- RT ---
  RT_dose   -> LQ_model  [label="SF computation" color="#FF7043"]
