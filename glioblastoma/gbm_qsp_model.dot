  MGMT_prot -> Radiosens [label="MGMT repair\n→ reduce synergy" color="#F44336" arrowhead=tee]
  Fract_p   -> RT_dose   [label="2 Gy/fx schedule" color="#FF7043"]
  SBRT_p    -> RT_dose   [label="SRS 15-24 Gy" color="#FF7043"]
  TTF_p     -> DSB_RT    [label="mitotic\ndisruption" color="#FF7043" style=dashed]
