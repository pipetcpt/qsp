digraph GBM_QSP {
  graph [
    label="Glioblastoma Multiforme (GBM) — QSP Mechanistic Map\nGenomic Alterations · Signaling · DNA Damage · TME · Angiogenesis · GSC · Drug PK/PD · RT · Clinical Endpoints"
    labelloc=t labeljust=c fontname="Helvetica" fontsize=20
    bgcolor="white" compound=true
    ranksep=2.0 nodesep=0.6 splines=ortho
    size="36,28" ratio=fill
  ]
  node [fontname="Helvetica" fontsize=10 style="filled,rounded" shape=box width=1.8 height=0.55]
  edge [fontname="Helvetica" fontsize=8 arrowsize=0.7]

  // ============================================================
  // Cluster 1: Genomic Alterations
  // ============================================================
  subgraph cluster_genetics {
    label="Genomic Alterations (GBM)" style=filled color="#FFE0E0"
    fontsize=14 fontname="Helvetica-Bold"
    node [fillcolor="#FFCDD2"]

    IDH_WT      [label="IDH1/2 Wild-type\n(Primary GBM ~90%)"  fillcolor="#FF8A80"]
    IDH_MUT     [label="IDH1 R132H Mutation\n(Secondary GBM ~10%)" fillcolor="#FFB3BA"]
    MGMT_meth   [label="MGMT Promoter\nMethylation (~45%)" fillcolor="#B9F6CA"]
    MGMT_unmeth [label="MGMT Unmethylated\n(~55%, worse prognosis)" fillcolor="#FF8A80"]
    EGFR_amp    [label="EGFR Amplification\n(~50% GBM)" fillcolor="#FFAB91"]
    EGFRvIII    [label="EGFRvIII\n(deletion mutant ~30%)" fillcolor="#FFAB91"]
    PTEN_loss   [label="PTEN Loss / Mutation\n(~40% GBM)" fillcolor="#FF8A80"]
    TP53_mut    [label="TP53 Mutation\n(~30% GBM)" fillcolor="#FFCDD2"]
    ATRX_mut    [label="ATRX Mutation\n(IDH-mutant assoc.)" fillcolor="#E8EAF6"]
    TERT_mut    [label="TERT Promoter\nMutation (~70%)" fillcolor="#FFAB91"]
    CDK4_amp    [label="CDK4 Amplification\n(~15%)" fillcolor="#FFE0B2"]
    CDKN2A_del  [label="CDKN2A/p16\nDeletion (~60%)" fillcolor="#FF8A80"]
    MDM2_amp    [label="MDM2 Amplification\n(~15%)" fillcolor="#FFE0B2"]
    NF1_mut     [label="NF1 Mutation\n(~10%)" fillcolor="#E8EAF6"]
    RB1_loss    [label="RB1 Loss\n(~11%)" fillcolor="#FFCDD2"]
    Chr7_gain   [label="Chromosome 7 Gain\n(+7, EGFR locus)" fillcolor="#FFE0B2"]
    Chr10_loss  [label="Chromosome 10 Loss\n(-10, PTEN locus)" fillcolor="#FF8A80"]
    PDGFRA_amp  [label="PDGFRA Amplification\n(~15%, Proneural)" fillcolor="#FFE0B2"]
    MET_amp     [label="MET Amplification\n(~4%)" fillcolor="#E8EAF6"]
    FGFR3_fus   [label="FGFR3-TACC3 Fusion\n(~3%)" fillcolor="#E8EAF6"]
  }

  // ============================================================
  // Cluster 2: RTK / RAS-MAPK Signaling
  // ============================================================
  subgraph cluster_rtk {
    label="RTK / RAS-MAPK Pathway" style=filled color="#E3F2FD"
    fontsize=14 fontname="Helvetica-Bold"
    node [fillcolor="#BBDEFB"]

    EGF_L    [label="EGF / Amphiregulin\n(Ligand)" fillcolor="#E3F2FD"]
    EGFR_R   [label="EGFR Receptor\n(activated / dimer)" fillcolor="#64B5F6"]
    PDGFR    [label="PDGFR-α/β\n(growth factor R)" fillcolor="#64B5F6"]
    MET_R    [label="MET / HGF Receptor" fillcolor="#64B5F6"]
    FGFR     [label="FGFR1/2/3" fillcolor="#64B5F6"]
    GRB2     [label="GRB2-SOS\nAdapter Complex" fillcolor="#90CAF9"]
    RAS      [label="RAS (KRAS/NRAS)\nGTP-bound" fillcolor="#42A5F5"]
    RAF      [label="A-RAF/B-RAF/C-RAF\nKinase" fillcolor="#2196F3"]
    MEK      [label="MEK1/2\n(MAP2K1/2)" fillcolor="#1976D2"]
    ERK      [label="ERK1/2\n(MAPK3/1)" fillcolor="#1565C0"]
    RSK      [label="RSK1/2\n(p90RSK)" fillcolor="#BBDEFB"]
    MNK      [label="MNK1/2\n(eIF4E kinase)" fillcolor="#BBDEFB"]
    eIF4E_R  [label="eIF4E\n(cap-dep. translation)" fillcolor="#90CAF9"]
    NF1_prot [label="NF1 Protein\n(RAS-GAP activity)" fillcolor="#FFCDD2"]
  }

  // ============================================================
  // Cluster 3: PI3K/AKT/mTOR Pathway
  // ============================================================
  subgraph cluster_pi3k {
    label="PI3K / AKT / mTOR Pathway" style=filled color="#E8F5E9"
    fontsize=14 fontname="Helvetica-Bold"
    node [fillcolor="#C8E6C9"]

    PI3K    [label="PI3K\n(p110α/β + p85)" fillcolor="#81C784"]
    PIP2    [label="PIP2\n(4,5-bisphosphate)" fillcolor="#A5D6A7"]
    PIP3    [label="PIP3\n(3,4,5-trisphosphate)" fillcolor="#66BB6A"]
    PTEN_p  [label="PTEN Phosphatase\n(PIP3→PIP2)" fillcolor="#EF9A9A"]
    PDK1    [label="PDK1/2\n(Thr308 AKT)" fillcolor="#4CAF50"]
    AKT     [label="AKT1/2/3 (PKB)\nFull activation" fillcolor="#388E3C"]
    TSC12   [label="TSC1/TSC2 Complex\n(Hamartin/Tuberin)" fillcolor="#A5D6A7"]
    RHEB    [label="RHEB-GTP\n(mTORC1 activator)" fillcolor="#C8E6C9"]
    mTORC1  [label="mTORC1\n(mTOR+Raptor+mLST8)" fillcolor="#2E7D32"]
    mTORC2  [label="mTORC2\n(mTOR+Rictor)" fillcolor="#1B5E20"]
    S6K1    [label="p70 S6K1\n(protein synthesis)" fillcolor="#81C784"]
    P4EBP1  [label="4E-BP1\n(translation repressor)" fillcolor="#A5D6A7"]
    FOXO    [label="FOXO1/3a\n(apoptosis TF)" fillcolor="#A5D6A7"]
    GSK3b   [label="GSK3β\n(glycogen synthesis)" fillcolor="#C8E6C9"]
    MDM2_ak [label="MDM2 (AKT-phospho)\nSer166" fillcolor="#FFCC80"]
    BAD_ak  [label="BAD (phospho-Ser136)\n(pro-survival)" fillcolor="#A5D6A7"]
  }

  // ============================================================
  // Cluster 4: Cell Cycle & Apoptosis
  // ============================================================
  subgraph cluster_cellcycle {
    label="Cell Cycle & Apoptosis Pathways" style=filled color="#FFFDE7"
    fontsize=14 fontname="Helvetica-Bold"
    node [fillcolor="#FFF9C4"]

    CycD   [label="Cyclin D1/D2/D3\n(G1 driver)" fillcolor="#FFD54F"]
    CDK46  [label="CDK4/CDK6\n(G1 kinase)" fillcolor="#FFCA28"]
    CycE   [label="Cyclin E1/E2\n(G1/S driver)" fillcolor="#FFD54F"]
    CDK2   [label="CDK2\n(G1/S kinase)" fillcolor="#FFCA28"]
    CycA   [label="Cyclin A1/A2\n(S/G2 driver)" fillcolor="#FFD54F"]
    CDK1   [label="CDK1/CDC2\n(M-phase kinase)" fillcolor="#FFCA28"]
    CycB   [label="Cyclin B1/B2\n(M-phase driver)" fillcolor="#FFD54F"]
    RB_p   [label="pRB Protein\n(E2F repressor)" fillcolor="#FF8F00"]
    E2F    [label="E2F1/2/3\n(Transcription factors)" fillcolor="#FFAB40"]
    p16    [label="p16/INK4a (CDKN2A)\nCDK4/6 inhibitor" fillcolor="#FF6F00"]
    p21    [label="p21/WAF1 (CDKN1A)\nCDK inhibitor" fillcolor="#FF8F00"]
    p27    [label="p27/KIP1 (CDKN1B)\nCDK inhibitor" fillcolor="#FFAB40"]
    TP53_p [label="p53 Tumor Suppressor\n(transcription factor)" fillcolor="#E65100"]
    MDM2_r [label="MDM2 E3 Ligase\n(p53 ubiquitination)" fillcolor="#FFCA28"]
    BCL2   [label="BCL-2\n(anti-apoptotic)" fillcolor="#A5D6A7"]
    BCLXL  [label="BCL-xL\n(anti-apoptotic)" fillcolor="#A5D6A7"]
    MCL1   [label="MCL-1\n(anti-apoptotic)" fillcolor="#A5D6A7"]
    BAX    [label="BAX\n(pro-apoptotic)" fillcolor="#EF9A9A"]
    BAK    [label="BAK\n(pro-apoptotic)" fillcolor="#EF9A9A"]
    NOXA   [label="NOXA / PMAIP1\n(BH3-only)" fillcolor="#FFCDD2"]
    PUMA   [label="PUMA / BBC3\n(BH3-only)" fillcolor="#FFCDD2"]
    CytC   [label="Cytochrome C\n(mitochondrial release)" fillcolor="#CE93D8"]
    APAF1  [label="APAF-1\n(Apoptosome)" fillcolor="#BA68C8"]
    Casp9  [label="Caspase-9\n(Initiator)" fillcolor="#9575CD"]
    Casp3  [label="Caspase-3/7\n(Executioner)" fillcolor="#7E57C2"]
    Casp8  [label="Caspase-8\n(extrinsic path)" fillcolor="#9575CD"]
    IAP    [label="XIAP / Survivin\n(Caspase inhibitor)" fillcolor="#FFAB40"]
  }

  // ============================================================
  // Cluster 5: DNA Damage & Repair (TMZ Mechanism)
  // ============================================================
  subgraph cluster_dna {
    label="DNA Damage & Repair (TMZ Mechanism)" style=filled color="#FCE4EC"
    fontsize=14 fontname="Helvetica-Bold"
    node [fillcolor="#F8BBD0"]

    TMZ_mtic   [label="MTIC\n(TMZ active metabolite)" fillcolor="#F48FB1"]
    O6MeG      [label="O6-MeG Lesion\n(primary cytotoxic)" fillcolor="#EC407A"]
    N7MeG      [label="N7-MeG Lesion\n(minor, ~70%)" fillcolor="#F48FB1"]
    N3MeA      [label="N3-MeA Lesion\n(minor, ~9%)" fillcolor="#F8BBD0"]
    MGMT_prot  [label="MGMT Protein\n(O6-MeG direct reversal)" fillcolor="#AD1457"]
    MMR_sys    [label="DNA Mismatch\nRepair (MMR)" fillcolor="#880E4F"]
    MSH6_p     [label="MSH2/MSH6\n(mismatch sensor)" fillcolor="#E91E63"]
    MLH1_p     [label="MLH1/PMS2\n(repair complex)" fillcolor="#E91E63"]
    DSB_all    [label="DNA Double-Strand\nBreaks (DSBs)" fillcolor="#C62828"]
    ATM_k      [label="ATM Kinase\n(DSB sensor)" fillcolor="#B71C1C"]
    ATR_k      [label="ATR Kinase\n(ssDNA/RPA sensor)" fillcolor="#B71C1C"]
    CHK1_2     [label="CHK1/CHK2\n(checkpoint effectors)" fillcolor="#D32F2F"]
    PARP1_p    [label="PARP1\n(base excision repair)" fillcolor="#EF9A9A"]
    NHEJ_p     [label="NHEJ Pathway\n(error-prone DSB repair)" fillcolor="#FFCDD2"]
    HR_p       [label="Homologous Recomb.\n(S/G2, precise repair)" fillcolor="#FFCDD2"]
    BER_p      [label="Base Excision\nRepair (BER)" fillcolor="#FFCDD2"]
    G2M_check  [label="G2/M Checkpoint\nArrest" fillcolor="#F48FB1"]
    Apop_DNA   [label="Apoptosis Signal\n(catastrophic damage)" fillcolor="#EC407A"]
  }

  // ============================================================
  // Cluster 6: Tumor Microenvironment
  // ============================================================
  subgraph cluster_tme {
    label="Tumor Microenvironment (TME)" style=filled color="#F3E5F5"
    fontsize=14 fontname="Helvetica-Bold"
    node [fillcolor="#E1BEE7"]

    TAM_M1  [label="TAM M1 Phenotype\n(anti-tumor, ~10%)" fillcolor="#CE93D8"]
    TAM_M2  [label="TAM M2 Phenotype\n(pro-tumor, ~90%)" fillcolor="#7B1FA2"]
    Micro   [label="Microglia\n(resident macrophage)" fillcolor="#AB47BC"]
    CSF1R   [label="CSF1R\n(M2 survival/expansion)" fillcolor="#9C27B0"]
    MDSCs   [label="MDSCs\n(myeloid suppressor cells)" fillcolor="#6A1B9A"]
    TAN     [label="Tumor-Assoc. Neutrophils\n(TANs)" fillcolor="#CE93D8"]
    CAF_p   [label="Cancer-Assoc. Fibroblasts\n(CAFs)" fillcolor="#BA68C8"]
    ECM_p   [label="Extracellular Matrix\n(remodeling)" fillcolor="#E1BEE7"]
    MMP_p   [label="MMP-2/9/14\n(matrix metalloprotease)" fillcolor="#9C27B0"]
    TGFb    [label="TGF-β1/2/3\n(immunosuppressive)" fillcolor="#7B1FA2"]
    IL6_c   [label="IL-6\n(STAT3 activator)" fillcolor="#AB47BC"]
    IL10_c  [label="IL-10\n(anti-inflammatory)" fillcolor="#BA68C8"]
    IL4_c   [label="IL-4/IL-13\n(M2 polarization)" fillcolor="#CE93D8"]
    CCL2    [label="CCL2/MCP-1\n(macrophage recruit)" fillcolor="#9C27B0"]
    CXCL12  [label="CXCL12/SDF-1\n(CXCR4 axis)" fillcolor="#AB47BC"]
    IDO1    [label="IDO1\n(Trp→Kynurenine)" fillcolor="#7B1FA2"]
    ARG1    [label="ARG1\n(Arg depletion)" fillcolor="#AB47BC"]
    STAT3   [label="STAT3\n(pro-tumor TF)" fillcolor="#4A148C"]
    TNFa    [label="TNF-α\n(pleiotropic)" fillcolor="#CE93D8"]
    IFNg    [label="IFN-γ\n(anti-tumor)" fillcolor="#C8E6C9"]
    GAL9    [label="Galectin-9\n(TIM-3 ligand)" fillcolor="#CE93D8"]
  }

  // ============================================================
  // Cluster 7: Angiogenesis & VEGF
  // ============================================================
  subgraph cluster_angio {
    label="Angiogenesis & VEGF Pathway" style=filled color="#E8EAF6"
    fontsize=14 fontname="Helvetica-Bold"
    node [fillcolor="#C5CAE9"]

    HIF1a   [label="HIF-1α\n(hypoxia TF)" fillcolor="#FF7043"]
    HIF2a   [label="HIF-2α / EPAS1\n(chronic hypoxia)" fillcolor="#FF8A65"]
    VHL_p   [label="VHL Protein\n(HIF-PHD-VHL axis)" fillcolor="#FFAB91"]
    VEGFA   [label="VEGF-A165/121\n(primary angiogen)" fillcolor="#2196F3"]
    VEGFB   [label="VEGF-B\n(metabolic)" fillcolor="#64B5F6"]
    VEGFC   [label="VEGF-C\n(lymphangiogen)" fillcolor="#64B5F6"]
    VEGFR1  [label="VEGFR1 (Flt-1)\n(decoy receptor)" fillcolor="#1565C0"]
    VEGFR2  [label="VEGFR2 (KDR/Flk-1)\n(main signaling)" fillcolor="#0D47A1"]
    NRP1    [label="Neuropilin-1\n(VEGF co-receptor)" fillcolor="#1976D2"]
    ANG1    [label="Angiopoietin-1\n(vessel stabilization)" fillcolor="#90CAF9"]
    ANG2    [label="Angiopoietin-2\n(vessel destabilize)" fillcolor="#FFCDD2"]
    TIE2    [label="Tie-2 Receptor\n(vascular remodeling)" fillcolor="#1976D2"]
    FGF2    [label="FGF-2 (bFGF)\n(angiogenesis, RTK)" fillcolor="#64B5F6"]
    PDGF_B  [label="PDGF-BB\n(pericyte recruitment)" fillcolor="#90CAF9"]
    Pericyte [label="Pericytes\n(vessel support)" fillcolor="#C5CAE9"]
    EndoCell [label="Endothelial Cell\nProliferation/Migration" fillcolor="#2196F3"]
    NeoVasc  [label="Neovascularization\n(tumor vasculature)" fillcolor="#0D47A1"]
    Hypoxia  [label="Tumor Hypoxia\n(O₂ < 2%, ~30-50% GBM)" fillcolor="#FF5722"]
    PlGF    [label="PlGF\n(placental GF, VEGFR1)" fillcolor="#90CAF9"]
  }

  // ============================================================
  // Cluster 8: Immune Response & Checkpoint
  // ============================================================
  subgraph cluster_immune {
    label="Immune Response & Immune Checkpoint" style=filled color="#E8F5E9"
    fontsize=14 fontname="Helvetica-Bold"
    node [fillcolor="#C8E6C9"]

    CD8_T   [label="CD8+ CTL\n(effector, tumor kill)" fillcolor="#4CAF50"]
    CD4_T   [label="CD4+ Th1 Cells\n(helper)" fillcolor="#66BB6A"]
    Treg_i  [label="Regulatory T Cells\n(FoxP3+)" fillcolor="#FFCDD2"]
    NK_cell [label="NK Cells\n(NKG2D/KIR axis)" fillcolor="#81C784"]
    DC_p    [label="Dendritic Cells\n(antigen present)" fillcolor="#A5D6A7"]
    MHC1    [label="MHC Class I\n(tumor antigen present)" fillcolor="#4CAF50"]
    TCR_p   [label="TCR Complex\n(antigen recognition)" fillcolor="#66BB6A"]
    PD1     [label="PD-1 (CD279)\n(inhibitory receptor)" fillcolor="#EF5350"]
    PDL1    [label="PD-L1 (CD274/B7-H1)\n(checkpoint ligand)" fillcolor="#D32F2F"]
    PDL2    [label="PD-L2 (B7-DC)\n(checkpoint ligand)" fillcolor="#FFCDD2"]
    CTLA4   [label="CTLA-4\n(inhibitory, CD28 comp.)" fillcolor="#C62828"]
    CD28    [label="CD28\n(co-stimulatory)" fillcolor="#A5D6A7"]
    CD80    [label="CD80/CD86 (B7)\n(co-stimulatory ligands)" fillcolor="#C8E6C9"]
    Tim3    [label="TIM-3\n(exhaustion marker)" fillcolor="#FFCDD2"]
    LAG3    [label="LAG-3\n(MHC-II bind, exhaust)" fillcolor="#FFCDD2"]
    TIGIT   [label="TIGIT\n(CD155 bind, exhaust)" fillcolor="#FFCDD2"]
    CD47    [label="CD47\n('don't eat me' signal)" fillcolor="#FFE0B2"]
    SIRPa   [label="SIRPα\n(macrophage brake)" fillcolor="#FFE0B2"]
  }

  // ============================================================
  // Cluster 9: Glioma Stem Cells (GSCs)
  // ============================================================
  subgraph cluster_gsc {
    label="Glioma Stem Cells (GSCs)" style=filled color="#FFF8E1"
    fontsize=14 fontname="Helvetica-Bold"
    node [fillcolor="#FFF9C4"]

    GSC      [label="Glioma Stem Cell\n(CD133+, self-renewing)" fillcolor="#FF8F00"]
    CD133_m  [label="CD133 (Prominin-1)\nGSC surface marker" fillcolor="#FFA726"]
    SOX2_g   [label="SOX2\n(stemness TF)" fillcolor="#FFB74D"]
    OCT4_g   [label="OCT4 / POU5F1\n(pluripotency TF)" fillcolor="#FFCA28"]
    NANOG_g  [label="NANOG\n(self-renewal TF)" fillcolor="#FFD54F"]
    Nestin_g [label="Nestin\n(neural progenitor)" fillcolor="#FFCC80"]
    ALDH1_g  [label="ALDH1A3\n(GSC activity marker)" fillcolor="#FFB74D"]
    Notch_R  [label="Notch1/2 Receptor\n(DLL4/JAG ligands)" fillcolor="#FFA726"]
    HES1_g   [label="HES1/HEY1\n(Notch transcription targets)" fillcolor="#FFCC80"]
    SHH_g    [label="SHH/SMO\n(Hedgehog ligand/receptor)" fillcolor="#FF9800"]
    GLI1_g   [label="GLI1/GLI2\n(Hedgehog TF targets)" fillcolor="#FFA726"]
    Wnt_g    [label="Wnt/Frizzled\n(β-catenin pathway)" fillcolor="#FFB74D"]
    Beta_cat [label="β-catenin (nuclear)\nTCF/LEF targets" fillcolor="#FFCC80"]
    BMI1_g   [label="BMI1\n(PRC1 epigenetic)" fillcolor="#FF9800"]
    EZH2_g   [label="EZH2\n(PRC2, H3K27me3)" fillcolor="#FFA726"]
    BMP_g    [label="BMP2/4\n(GSC differentiation)" fillcolor="#C8E6C9"]
    niche    [label="Perivascular Niche\n(GSC maintenance)" fillcolor="#FFCC80"]
  }

  // ============================================================
  // Cluster 10: Drug Pharmacokinetics (PK)
  // ============================================================
  subgraph cluster_pk {
    label="Drug Pharmacokinetics (PK)" style=filled color="#FFFDE7"
    fontsize=14 fontname="Helvetica-Bold"
    node [fillcolor="#FFF9C4"]

    TMZ_oral   [label="TMZ Oral Dose\n75 mg/m²/d (concurrent)\n150-200 mg/m² (adjuvant)" fillcolor="#FFF176"]
    TMZ_gut    [label="GI Absorption\n(FA ≈ 1.0, Tmax ~1h)" fillcolor="#FFF176"]
    TMZ_Cp     [label="TMZ Plasma\nCentral (Vc=22.5 L)" fillcolor="#FFEE58"]
    TMZ_Cp2    [label="TMZ Peripheral\n(Vp=50 L)" fillcolor="#FDD835"]
    TMZ_brain  [label="TMZ Brain ECF\n(Kp,brain≈0.28)" fillcolor="#F9A825"]
    MTIC_comp  [label="MTIC\n(pH-dep. hydrolysis t½~1.8h)" fillcolor="#F57F17"]
    BEV_dose   [label="Bevacizumab\n10 mg/kg q14d iv" fillcolor="#B3E5FC"]
    BEV_Cp     [label="BEV Plasma Central\n(Vc=2.92 L)" fillcolor="#81D4FA"]
    BEV_Cp2    [label="BEV Peripheral\n(Vp=3.28 L)" fillcolor="#4FC3F7"]
    VEGF_BEV   [label="VEGF:BEV Complex\n(t½ ~7d)" fillcolor="#29B6F6"]
    Free_BEV   [label="Free Bevacizumab\n(active drug)" fillcolor="#B3E5FC"]
    Free_VEGF  [label="Free VEGF\n(biologically active)" fillcolor="#2196F3"]
    APD1_iv    [label="Pembrolizumab\n200 mg q3w iv" fillcolor="#DCEDC8"]
    APD1_Cp    [label="Anti-PD-1 Plasma\n(CL=0.22 L/day)" fillcolor="#C5E1A5"]
    PD1_occ    [label="PD-1 Receptor\nOccupancy" fillcolor="#AED581"]
    TMZ_DEXA   [label="Dexamethasone\n(4-16 mg/day)" fillcolor="#FFE0B2"]
  }

  // ============================================================
  // Cluster 11: Blood-Brain Barrier
  // ============================================================
  subgraph cluster_bbb {
    label="Blood-Brain / Blood-Tumor Barrier" style=filled color="#E0F2F1"
    fontsize=14 fontname="Helvetica-Bold"
    node [fillcolor="#B2DFDB"]

    BBB_p   [label="Blood-Brain Barrier\n(tight junctions)" fillcolor="#26A69A"]
    BTB_p   [label="Blood-Tumor Barrier\n(disrupted, Kp↑)" fillcolor="#F4511E"]
    Pgp_p   [label="P-glycoprotein\n(MDR1/ABCB1 efflux)" fillcolor="#00897B"]
    BCRP_p  [label="BCRP (ABCG2)\nefflux transporter" fillcolor="#00897B"]
    MRP4_p  [label="MRP4 (ABCC4)\nefflux transporter" fillcolor="#00897B"]
    Kpbrain [label="Kp,uu,brain ≈ 0.28\n(TMZ CNS exposure)" fillcolor="#4DB6AC"]
    TJ_p    [label="Tight Junction Proteins\n(Occludin/Claudin-5)" fillcolor="#80CBC4"]
    CSF_p   [label="CSF Drug Concentration\n(≈ brain ECF unbound)" fillcolor="#B2DFDB"]
    EV_p    [label="Extracellular Vesicles\n(drug delivery route)" fillcolor="#B2DFDB"]
  }

  // ============================================================
  // Cluster 12: Radiation Therapy
  // ============================================================
  subgraph cluster_rt {
    label="Radiation Therapy (Standard + SRS/SRT)" style=filled color="#FBE9E7"
    fontsize=14 fontname="Helvetica-Bold"
    node [fillcolor="#FFCCBC"]

    RT_dose    [label="External RT Dose\n2 Gy/fx × 30 fx = 60 Gy" fillcolor="#FF7043"]
    LQ_model   [label="Linear-Quadratic Model\nSF = exp(−αD − βD²)" fillcolor="#F4511E"]
    Alpha_b    [label="α/β Ratio (GBM)\n~10 Gy (α=0.3, β=0.03 Gy⁻¹)" fillcolor="#E64A19"]
    OER_p      [label="Oxygen Enhancement\nRatio (OER≈3.0 in hypoxia)" fillcolor="#BF360C"]
    Radiosens  [label="Radiosensitization\nTMZ+RT synergy (ΔSF)" fillcolor="#FF7043"]
    DSB_RT     [label="RT-induced DSBs\n(lethal+sublethal)" fillcolor="#FFCCBC"]
    RT_repair  [label="Sublethal Damage\nRepair (SLDR)" fillcolor="#FFAB91"]
    Fract_p    [label="Fractionation Schedule\n(3D-CRT / IMRT / VMAT)" fillcolor="#FFCCBC"]
    SBRT_p     [label="SRS / SBRT\n(15-24 Gy × 1-3 fxs)" fillcolor="#FF7043"]
    RT_boost   [label="Dose Boost\n(60 Gy total, GTV)" fillcolor="#FFAB91"]
    TTF_p      [label="Tumor Treating Fields\n(TTF, 200 kHz AC)" fillcolor="#FFE0B2"]
    Temozolomide_RT [label="TMZ + RT\n(Stupp Protocol 2005)" fillcolor="#F4511E"]
  }

  // ============================================================
  // Cluster 13: Clinical Endpoints & Biomarkers
  // ============================================================
  subgraph cluster_endpoints {
    label="Clinical Endpoints & Prognostic Biomarkers" style=filled color="#E8EAF6"
    fontsize=14 fontname="Helvetica-Bold"
    node [fillcolor="#C5CAE9"]

    TumorVol    [label="Tumor Volume (Gompertz)\n[cells × 10⁻⁹ mL]" fillcolor="#5C6BC0"]
    FLAIR_vol   [label="MRI T2/FLAIR Volume\n(T2 hyperintensity)" fillcolor="#7986CB"]
    Enhance_vol [label="MRI T1+Gd Volume\n(enhancement)" fillcolor="#7986CB"]
    RANO_crit   [label="RANO Criteria\n(≥25% ↑ = progression)" fillcolor="#3949AB"]
    PseudoP     [label="Pseudoprogression\n(RT+TMZ effect at 3 mo)" fillcolor="#9FA8DA"]
    PFS_ep      [label="Progression-Free\nSurvival (PFS)" fillcolor="#283593"]
    OS_ep       [label="Overall Survival\n(OS)" fillcolor="#1A237E"]
    KPS_ep      [label="KPS Score\n(performance status)" fillcolor="#5C6BC0"]
    mOS_data    [label="Median OS Reference\nIDH-wt: ~15 mo\nMGMT+/IDH-wt: ~22 mo\nIDH-mut: ~31 mo" fillcolor="#283593"]
    Seizure_ep  [label="Seizure Frequency\n(clinical endpoint)" fillcolor="#9FA8DA"]
    Steroid_ep  [label="Steroid Requirement\n(dexamethasone dose)" fillcolor="#9FA8DA"]
    EOR_ep      [label="Extent of Resection\n(GTR/STR/biopsy)" fillcolor="#7986CB"]
    IDH_prog    [label="IDH Status\n(major prognostic factor)" fillcolor="#5C6BC0"]
    MGMT_pred   [label="MGMT Methylation\n(predictive for TMZ)" fillcolor="#3949AB"]
    TERT_biom   [label="TERT Mutation\n(prognostic biomarker)" fillcolor="#9FA8DA"]
    QoL_ep      [label="Quality of Life\n(EORTC QLQ-C30/BN20)" fillcolor="#9FA8DA"]
    Neurocog    [label="Neurocognitive Function\n(MMSE, MoCA)" fillcolor="#9FA8DA"]
  }

  // ============================================================
  // EDGES
  // ============================================================

  // --- Genomic alterations → downstream ---
  EGFR_amp  -> EGFR_R   [label="overexpression" color="#E91E63"]
  EGFRvIII  -> EGFR_R   [label="constitutive active\n(ligand-independent)" color="#E91E63"]
  PTEN_loss -> PTEN_p   [label="reduced/absent\nphosphatase" color="#E91E63" style=dashed]
  NF1_mut   -> NF1_prot [label="reduced RAS-GAP" color="#E91E63"]
  CDKN2A_del-> p16      [label="homozygous deletion" color="#E91E63" style=dashed]
  MDM2_amp  -> MDM2_r   [label="overexpression→\np53 suppression" color="#E91E63"]
  TP53_mut  -> TP53_p   [label="LOF mutation" color="#E91E63" style=dashed]
  IDH_MUT   -> TGFb     [label="D-2HG epigenetic\nreprogramming" color="#9C27B0"]
  MGMT_meth -> MGMT_prot [label="promoter silencing\n(reduced protein)" color="#4CAF50" style=dashed]
  MGMT_unmeth -> MGMT_prot [label="active MGMT\nexpression" color="#E91E63"]
  Chr10_loss -> PTEN_loss [label="10q23 deletion\n(PTEN locus)" color="#E91E63"]
  Chr7_gain  -> EGFR_amp  [label="7p12 amplification" color="#E91E63"]
  CDK4_amp   -> CDK46     [label="CDK4 overexpression" color="#E91E63"]
  PDGFRA_amp -> PDGFR     [label="overexpression" color="#E91E63"]

  // --- RTK Signaling ---
  EGF_L    -> EGFR_R  [label="receptor\nactivation" color="#2196F3"]
  EGFR_R   -> GRB2    [label="pY adaptor\nbinding" color="#2196F3"]
  EGFR_R   -> PI3K    [label="p85 direct\nactivation" color="#4CAF50"]
  GRB2     -> RAS     [label="SOS→GEF\nnucleotide exchange" color="#2196F3"]
  RAS      -> RAF     [label="cascade" color="#2196F3"]
  RAF      -> MEK     [label="phosphorylate" color="#2196F3"]
  MEK      -> ERK     [label="dual phosph.\n(Thr202/Tyr204)" color="#2196F3"]
  ERK      -> RSK     [label="activate" color="#2196F3"]
  ERK      -> MNK     [label="activate" color="#2196F3"]
  MNK      -> eIF4E_R [label="Ser209 phosph." color="#2196F3"]
  NF1_prot -> RAS     [label="GTPase activation\n(inactivate RAS)" color="#F44336" arrowhead=tee]
  PDGFR    -> PI3K    [label="activate" color="#4CAF50"]
  MET_R    -> PI3K    [label="activate" color="#4CAF50"]

  // --- PI3K/AKT/mTOR ---
  PI3K     -> PIP3    [label="PIP2→PIP3\nkinase" color="#4CAF50"]
  PTEN_p   -> PIP3    [label="PIP3→PIP2\n(inactivation)" color="#F44336" arrowhead=tee]
  PIP3     -> PDK1    [label="recruit/activate" color="#4CAF50"]
  PDK1     -> AKT     [label="Thr308 phosph." color="#4CAF50"]
  mTORC2   -> AKT     [label="Ser473 phosph.\n(full activation)" color="#388E3C"]
  AKT      -> TSC12   [label="phospho→inhibit" color="#F44336" arrowhead=tee]
  AKT      -> MDM2_ak [label="Ser166 phosph." color="#4CAF50"]
  AKT      -> FOXO    [label="Ser256 phosph.\n→nuclear exclusion" color="#F44336" arrowhead=tee]
  AKT      -> GSK3b   [label="Ser9 phosph.\n→inactivate" color="#F44336" arrowhead=tee]
  AKT      -> BAD_ak  [label="Ser136 phosph.\n(pro-survival)" color="#4CAF50"]
  TSC12    -> RHEB    [label="GAP→inactivate\nRHEB" color="#F44336" arrowhead=tee]
  RHEB     -> mTORC1  [label="GTP-RHEB\nactivates mTORC1" color="#4CAF50"]
  mTORC1   -> S6K1    [label="Thr389 phosph." color="#4CAF50"]
  mTORC1   -> P4EBP1  [label="multi-Ser phosph.\n→eIF4E release" color="#4CAF50"]
  MDM2_ak  -> TP53_p  [label="ubiquitinate\n→degrade" color="#F44336" arrowhead=tee]

  // --- Cell Cycle ---
  CycD     -> CDK46   [label="complex\nformation" color="#FFC107"]
  CDK46    -> RB_p    [label="Ser780/795\nphosphorylate" color="#FFC107"]
  p16      -> CDK46   [label="INK4a\ninhibition" color="#F44336" arrowhead=tee]
  RB_p     -> E2F     [label="E2F release\n(hyper-phospho RB)" color="#FFC107"]
  E2F      -> CycE    [label="transcription" color="#FFC107"]
  CycE     -> CDK2    [label="complex" color="#FFC107"]
  CDK2     -> RB_p    [label="hyper-phospho" color="#FFC107"]
  CycA     -> CDK2    [label="S-phase complex" color="#FFC107"]
  CycA     -> CDK1    [label="G2/M complex" color="#FFC107"]
  CycB     -> CDK1    [label="MPF complex\n(M-phase)" color="#FFC107"]
  p21      -> CDK2    [label="CIP/KIP\ninhibit" color="#F44336" arrowhead=tee]
  p21      -> CDK46   [label="inhibit" color="#F44336" arrowhead=tee]
  p27      -> CDK2    [label="inhibit" color="#F44336" arrowhead=tee]
  TP53_p   -> p21     [label="transcription\n(CDKN1A)" color="#FFC107"]
  TP53_p   -> PUMA    [label="transcription\n(BBC3)" color="#FFC107"]
  TP53_p   -> BAX     [label="transcription" color="#FFC107"]
  MDM2_r   -> TP53_p  [label="ubiquitinate\n→proteasomal\ndegradation" color="#F44336" arrowhead=tee]

  // --- Apoptosis ---
  BAX      -> CytC    [label="MOMP\nouter membrane" color="#9C27B0"]
  BAK      -> CytC    [label="MOMP" color="#9C27B0"]
  BCL2     -> BAX     [label="sequester" color="#F44336" arrowhead=tee]
  BCLXL    -> BAX     [label="sequester" color="#F44336" arrowhead=tee]
  MCL1     -> BAK     [label="sequester" color="#F44336" arrowhead=tee]
  PUMA     -> BCL2    [label="BH3: displace\nBAX" color="#9C27B0"]
  NOXA     -> MCL1    [label="BH3: neutralize" color="#9C27B0"]
  CytC     -> APAF1   [label="apoptosome\nformation (+dATP)" color="#9C27B0"]
  APAF1    -> Casp9   [label="activate" color="#9C27B0"]
  Casp9    -> Casp3   [label="cleave/activate" color="#9C27B0"]
  Casp8    -> Casp3   [label="extrinsic\npathway" color="#9C27B0"]
  IAP      -> Casp3   [label="XIAP inhibit" color="#F44336" arrowhead=tee]
  IAP      -> Casp9   [label="XIAP inhibit" color="#F44336" arrowhead=tee]

  // --- DNA Damage (TMZ) ---
  TMZ_brain -> MTIC_comp [label="spontaneous\nhydrolysis (pH 7.4)\nt½≈1.8 h" color="#F57F17"]
  MTIC_comp -> O6MeG     [label="O6-methylation\n(~5-10%)" color="#E91E63"]
  MTIC_comp -> N7MeG     [label="N7-methylation\n(~70%)" color="#E91E63"]
  MTIC_comp -> N3MeA     [label="N3-methylation\n(~9%)" color="#E91E63"]
  O6MeG     -> MGMT_prot [label="substrate\n(direct reversal)" color="#4CAF50"]
  MGMT_prot -> O6MeG     [label="methyl removal\n(MGMT deactivated)" color="#4CAF50" arrowhead=tee]
  O6MeG     -> MMR_sys   [label="triggers\nmismatch" color="#E91E63"]
  MMR_sys   -> MSH6_p    [label="sensor" color="#E91E63"]
  MSH6_p    -> MLH1_p    [label="recruit" color="#E91E63"]
  MMR_sys   -> DSB_all   [label="futile repair\ncycles → DSBs" color="#E91E63"]
  N7MeG     -> BER_p     [label="BER" color="#4CAF50"]
  N3MeA     -> BER_p     [label="BER" color="#4CAF50"]
  PARP1_p   -> BER_p     [label="nick sensing\n& repair" color="#4CAF50"]
  DSB_all   -> ATM_k     [label="Ku70/80 sensor" color="#C62828"]
  DSB_all   -> ATR_k     [label="RPA-ssDNA" color="#C62828"]
  ATM_k     -> CHK1_2    [label="Ser317 (CHK1)\nThr68 (CHK2)" color="#C62828"]
  ATR_k     -> CHK1_2    [label="Ser345 (CHK1)" color="#C62828"]
  CHK1_2    -> TP53_p    [label="Ser15/20 phosph.\n→stabilize" color="#C62828"]
  CHK1_2    -> CDK1      [label="CDC25 degradation\n→G2/M arrest" color="#F44336" arrowhead=tee]
  CHK1_2    -> G2M_check [label="G2/M checkpoint\nactivation" color="#C62828"]
  G2M_check -> Apop_DNA  [label="unrepaired DSBs\n→ mitotic catastrophe" color="#9C27B0"]
  DSB_all   -> NHEJ_p    [label="S/G2 phase\nrepair" color="#4CAF50"]
  DSB_all   -> HR_p      [label="precise S/G2\nrepair" color="#4CAF50"]
  Apop_DNA  -> Casp3     [label="apoptosis\nsignaling" color="#9C27B0"]

  // --- TME ---
  TGFb     -> Treg_i  [label="FoxP3 expand" color="#7B1FA2"]
  TGFb     -> TAM_M2  [label="M2 polarize" color="#7B1FA2"]
  TGFb     -> PDL1    [label="upregulate" color="#7B1FA2"]
  IL6_c    -> STAT3   [label="JAK1/2→\nSTAT3 Tyr705" color="#9C27B0"]
  STAT3    -> PDL1    [label="transcription" color="#9C27B0"]
  STAT3    -> VEGFA   [label="transcription" color="#9C27B0"]
  STAT3    -> BCL2    [label="transcription\n(survival)" color="#9C27B0"]
  IL10_c   -> CD8_T   [label="suppress CTL\nfunction" color="#F44336" arrowhead=tee]
  CCL2     -> TAM_M2  [label="macrophage\nrecruitment" color="#9C27B0"]
  CSF1R    -> TAM_M2  [label="M2 survival\nsignal" color="#9C27B0"]
  IDO1     -> CD8_T   [label="kynurenine\n→T cell suppress" color="#F44336" arrowhead=tee]
  ARG1     -> CD8_T   [label="Arg depletion\n→suppress" color="#F44336" arrowhead=tee]
  TAM_M2   -> IDO1    [label="express" color="#9C27B0"]
  TAM_M2   -> ARG1    [label="express" color="#9C27B0"]
  TAM_M2   -> TGFb    [label="secrete" color="#9C27B0"]
  TAM_M2   -> IL10_c  [label="secrete" color="#9C27B0"]
  TAM_M2   -> VEGFA   [label="secrete" color="#2196F3"]
  TAM_M2   -> CCL2    [label="secrete\n(self-amplify)" color="#9C27B0"]
  Micro    -> TAM_M2  [label="activation/\nreprogramming" color="#9C27B0"]
  MDSCs    -> CD8_T   [label="ROS/NO\nsuppress" color="#F44336" arrowhead=tee]
  MDSCs    -> Treg_i  [label="expand Tregs" color="#9C27B0"]
  MMP_p    -> ECM_p   [label="degrade ECM\n→invasion" color="#9C27B0"]
  TAM_M2   -> MMP_p   [label="secrete" color="#9C27B0"]
  CXCL12   -> MDSCs   [label="CXCR4 recruit" color="#9C27B0"]
  IFNg     -> TAM_M1  [label="M1 polarize" color="#4CAF50"]
  IFNg     -> MHC1    [label="upregulate" color="#4CAF50"]
  CD8_T    -> IFNg    [label="secrete" color="#4CAF50"]
  CD8_T    -> Casp3   [label="perforin/granzyme\n→tumor kill" color="#4CAF50"]
  GAL9     -> Tim3    [label="Tim-3 ligand\n→exhaust" color="#F44336"]

  // --- Immune Checkpoint ---
  PDL1     -> PD1     [label="bind→inhibit CTL\nfeedback" color="#F44336"]
  PDL2     -> PD1     [label="bind" color="#F44336"]
  PD1      -> CD8_T   [label="SHP2→inhibit\nTCR signal" color="#F44336" arrowhead=tee]
  CTLA4    -> CD28    [label="compete for\nCD80/CD86" color="#F44336" arrowhead=tee]
  CD80     -> CD28    [label="co-stimulate\n(B7-CD28)" color="#4CAF50"]
  CD80     -> CTLA4   [label="higher affinity\nbinding" color="#F44336"]
  Tim3     -> CD8_T   [label="exhaustion\nmarker" color="#F44336" arrowhead=tee style=dashed]
  LAG3     -> CD8_T   [label="inhibit" color="#F44336" arrowhead=tee style=dashed]
  TIGIT    -> CD8_T   [label="CD155→\nexhaust" color="#F44336" arrowhead=tee style=dashed]
  CD47     -> SIRPa   [label="bind macrophage\nSIRPα" color="#FFB300"]
  SIRPa    -> TAM_M2  [label="phagocytosis\ninhibit" color="#F44336" arrowhead=tee]
  IFNg     -> PDL1    [label="IFN-γ→JAK/STAT\n→PD-L1 induction" color="#F44336"]

  // --- Anti-PD1 ---
  APD1_iv  -> APD1_Cp [label="IV PK\n(CL=0.22 L/d)" color="#8BC34A"]
  APD1_Cp  -> PD1_occ [label="PD-1 target\nengagement" color="#8BC34A"]
  PD1_occ  -> PD1     [label="block PD-1\n(pembrolizumab\nKD~0.03 nM)" color="#8BC34A" arrowhead=tee]

  // --- Angiogenesis ---
  Hypoxia  -> HIF1a   [label="stabilize\n(PHD inhibited)" color="#FF5722"]
  VHL_p    -> HIF1a   [label="PHD+VHL\n→ubiquitin\n(normoxia)" color="#F44336" arrowhead=tee]
  HIF1a    -> VEGFA   [label="HRE-driven\ntranscription" color="#2196F3"]
  HIF1a    -> VEGFC   [label="transcription" color="#2196F3"]
  HIF2a    -> VEGFA   [label="transcription\n(chronic hypoxia)" color="#2196F3"]
  VEGFA    -> VEGFR2  [label="bind/activate\n(KDR)" color="#2196F3"]
  VEGFB    -> VEGFR1  [label="bind" color="#2196F3"]
  VEGFA    -> NRP1    [label="co-receptor" color="#2196F3"]
  VEGFR2   -> EndoCell [label="EC proliferate\nmigrate" color="#2196F3"]
