digraph DLBCL_QSP {
    graph [
        label="Diffuse Large B-Cell Lymphoma (DLBCL)\nQuantitative Systems Pharmacology Map",
        labelloc=t, fontsize=22, fontname="Helvetica-Bold",
        rankdir=TB, splines=ortho, nodesep=0.35, ranksep=0.6,
        bgcolor="#FAFAFA", pad=0.5
    ]
    node [fontname="Helvetica", fontsize=9, style=filled, shape=ellipse, margin="0.05,0.03"]
    edge [fontname="Helvetica", fontsize=7, arrowsize=0.6]

    /* ================================================================
       CLUSTER 1: BCR SIGNALING
       ================================================================ */
    subgraph cluster_BCR {
        label="BCR / SYK / BTK Signaling"
        style=filled; fillcolor="#EBF5FB"; color="#2980B9"; fontsize=11; fontcolor="#1A5276"

        BCR [label="BCR\n(CD79a/b)", fillcolor="#AED6F1"]
        CD79b [label="CD79b\n(Igβ)", fillcolor="#AED6F1"]
        SYK [label="SYK\n(pY525/526)", fillcolor="#5DADE2"]
        LYN [label="LYN kinase", fillcolor="#AED6F1"]
        BTK [label="BTK\n(pY223)", fillcolor="#2E86C1", fontcolor=white]
        PLCg2 [label="PLCγ2", fillcolor="#5DADE2"]
        DAG [label="DAG", fillcolor="#A9CCE3"]
        IP3 [label="IP3", fillcolor="#A9CCE3"]
        PKCbeta [label="PKCβ", fillcolor="#5DADE2"]
        CARD11 [label="CARD11", fillcolor="#AED6F1"]
        MALT1 [label="MALT1\n(paracaspase)", fillcolor="#AED6F1"]
        BCL10 [label="BCL10", fillcolor="#AED6F1"]
        CBM [label="CBM complex\n(CARD11-BCL10-MALT1)", fillcolor="#85C1E9"]
        Ca2plus [label="Ca²⁺ flux\n→NFAT activation", fillcolor="#A9CCE3"]
        NFAT [label="NFAT\n(dephospho)", fillcolor="#5DADE2"]
        CD19 [label="CD19\n(co-receptor)", fillcolor="#AED6F1"]
        CD21 [label="CD21/CR2", fillcolor="#AED6F1"]
        PIK3CD [label="PI3Kδ\n(BCR-coupled)", fillcolor="#5DADE2"]
    }

    /* ================================================================
       CLUSTER 2: NF-κB PATHWAY
       ================================================================ */
    subgraph cluster_NFkB {
        label="NF-κB / IKK Pathway"
        style=filled; fillcolor="#FDFEFE"; color="#884EA0"; fontsize=11; fontcolor="#6C3483"

        IKKalpha [label="IKKα", fillcolor="#C39BD3"]
        IKKbeta [label="IKKβ", fillcolor="#C39BD3"]
        IKKgamma [label="IKKγ\n(NEMO)", fillcolor="#C39BD3"]
        IKKcomplex [label="IKK Complex", fillcolor="#A569BD", fontcolor=white]
        IkBa [label="IκBα\n(phospho)", fillcolor="#D7BDE2"]
        IkBa_free [label="IκBα\n(free/inactive)", fillcolor="#D7BDE2"]
        p65 [label="p65\n(RelA)", fillcolor="#8E44AD", fontcolor=white]
        p50 [label="p50\n(NF-κB1)", fillcolor="#A569BD", fontcolor=white]
        NFkB_nuclear [label="NF-κB\n(nuclear active)", fillcolor="#6C3483", fontcolor=white, shape=diamond]
        cREL [label="c-REL\n(lymphoma driver)", fillcolor="#C39BD3"]
        REL_amp [label="REL amplification\n(GCB DLBCL)", fillcolor="#D7BDE2"]
        A20 [label="A20\n(TNFAIP3 tumor suppressor)", fillcolor="#E8DAEF"]
        CD40L [label="CD40L-CD40\nNF-κB activation", fillcolor="#C39BD3"]
        TRAF2 [label="TRAF2/3/5/6", fillcolor="#D7BDE2"]
        NIK [label="NIK\n(MAP3K14)\nnon-canonical", fillcolor="#C39BD3"]
        NFkB_targets [label="NF-κB Target Genes\n(BCL2·BCL-XL·MCL1·MYC\nIL-6·IL-10·CXCR4·IRF4)", fillcolor="#6C3483", fontcolor=white, shape=box]
    }

    /* ================================================================
       CLUSTER 3: PI3K / AKT / mTOR PATHWAY
       ================================================================ */
    subgraph cluster_PI3K {
        label="PI3K / AKT / mTOR"
        style=filled; fillcolor="#EAFAF1"; color="#1E8449"; fontsize=11; fontcolor="#145A32"

        PI3K_delta [label="PI3Kδ\n(PIK3CD)", fillcolor="#82E0AA"]
        PI3K_alpha [label="PI3Kα\n(PIK3CA)", fillcolor="#82E0AA"]
        PIP2 [label="PIP2", fillcolor="#A9DFBF"]
        PIP3 [label="PIP3", fillcolor="#58D68D"]
        PTEN [label="PTEN\n(tumor suppressor)", fillcolor="#E8F8F5"]
        PDK1 [label="PDK1", fillcolor="#82E0AA"]
        AKT [label="AKT\n(pT308/S473)", fillcolor="#27AE60", fontcolor=white]
        TSC1 [label="TSC1/2 complex", fillcolor="#A9DFBF"]
        Rheb [label="Rheb", fillcolor="#A9DFBF"]
        mTORC1 [label="mTORC1\n(RAPTOR)", fillcolor="#1E8449", fontcolor=white, shape=diamond]
        mTORC2 [label="mTORC2\n(RICTOR)", fillcolor="#27AE60", fontcolor=white]
        S6K [label="S6K1/2", fillcolor="#82E0AA"]
        fourEBP1 [label="4E-BP1\n(pS65)", fillcolor="#82E0AA"]
        eIF4E [label="eIF4E\n(cap-dependent translation)", fillcolor="#58D68D"]
        FOXO1 [label="FOXO1\n(phospho-inactivated)", fillcolor="#A9DFBF"]
        GSK3b [label="GSK3β\n(phospho-inactive)", fillcolor="#A9DFBF"]
        MDM2 [label="MDM2\n(p53 degradation)", fillcolor="#E8F8F5"]
    }

    /* ================================================================
       CLUSTER 4: JAK / STAT PATHWAY
       ================================================================ */
    subgraph cluster_JAK {
        label="JAK / STAT / Cytokine Signaling"
        style=filled; fillcolor="#FEF9E7"; color="#B7950B"; fontsize=11; fontcolor="#7D6608"

        IL6 [label="IL-6\n(autocrine loop)", fillcolor="#F9E79F"]
        IL10 [label="IL-10\n(ABC subtype)", fillcolor="#F9E79F"]
        IL4 [label="IL-4/IL-13", fillcolor="#F9E79F"]
        IL6R [label="IL-6R\ngp80/gp130", fillcolor="#F7DC6F"]
        IL10R [label="IL-10R\n(IL10RA/B)", fillcolor="#F7DC6F"]
        JAK1 [label="JAK1", fillcolor="#F0B27A"]
        JAK2 [label="JAK2", fillcolor="#F0B27A"]
        TYK2 [label="TYK2", fillcolor="#F0B27A"]
        STAT3 [label="STAT3\n(pY705)", fillcolor="#E67E22", fontcolor=white, shape=diamond]
        STAT6 [label="STAT6\n(pY641)", fillcolor="#F0B27A"]
        SOCS1 [label="SOCS1/3\n(feedback inhibitor)", fillcolor="#F9E79F"]
        PDL1_JAK [label="PD-L1\n(JAK/STAT induction)", fillcolor="#F7DC6F"]
        IRF4 [label="IRF4\n(STAT target)", fillcolor="#F0B27A"]
        MYD88 [label="MYD88 L265P\n(ABC mutation)", fillcolor="#E8D5B7"]
        TLR9 [label="TLR9 signaling\n(chronic BCR)", fillcolor="#F9E79F"]
    }

    /* ================================================================
       CLUSTER 5: MAPK / RAS / ERK
       ================================================================ */
    subgraph cluster_MAPK {
        label="MAPK / RAS / ERK / MYC"
        style=filled; fillcolor="#FDEDEC"; color="#CB4335"; fontsize=11; fontcolor="#922B21"

        RAS [label="RAS\n(KRAS/NRAS)", fillcolor="#F1948A"]
        RAF [label="RAF\n(BRAF)", fillcolor="#EC7063"]
        MEK [label="MEK1/2", fillcolor="#EC7063"]
        ERK [label="ERK1/2\n(pT202/Y204)", fillcolor="#E74C3C", fontcolor=white, shape=diamond]
        MYC [label="MYC\n(c-MYC amplification)", fillcolor="#CB4335", fontcolor=white]
        MAX [label="MAX", fillcolor="#F1948A"]
        MYC_targets [label="MYC Targets\n(CDK4·CCND1·E2F·LDHA\nGLUT1·Tert·Nucleolin)", fillcolor="#922B21", fontcolor=white, shape=box]
        BCL6 [label="BCL6\n(GCB master TF)", fillcolor="#F1948A"]
        BLIMP1 [label="BLIMP1\n(PRDM1 repressor)", fillcolor="#F1948A"]
        AP1 [label="AP-1\n(c-Jun/c-Fos)", fillcolor="#EC7063"]
        JNK [label="JNK1/2", fillcolor="#F1948A"]
        p38 [label="p38 MAPK", fillcolor="#F1948A"]
        SRC [label="SRC kinase", fillcolor="#F1948A"]
        FAK [label="FAK\n(invasion)", fillcolor="#F5CBA7"]
        CXCR4 [label="CXCR4-CXCL12\nhoming/retention", fillcolor="#F5CBA7"]
    }

    /* ================================================================
       CLUSTER 6: APOPTOSIS / CELL DEATH
       ================================================================ */
    subgraph cluster_Apoptosis {
        label="Apoptosis / Cell Survival"
        style=filled; fillcolor="#F5EEF8"; color="#76448A"; fontsize=11; fontcolor="#512E5F"

        BCL2 [label="BCL-2\n(anti-apoptotic)", fillcolor="#BB8FCE"]
        BCLXL [label="BCL-XL\n(anti-apoptotic)", fillcolor="#BB8FCE"]
        MCL1 [label="MCL-1\n(anti-apoptotic)", fillcolor="#BB8FCE"]
        BCL2A1 [label="BCL2A1/BFL-1\n(anti-apoptotic)", fillcolor="#D7BDE2"]
        BIM [label="BIM\n(pro-apoptotic BH3)", fillcolor="#9B59B6", fontcolor=white]
        BAD [label="BAD\n(pro-apoptotic)", fillcolor="#BB8FCE"]
        BAX [label="BAX\n(effector)", fillcolor="#9B59B6", fontcolor=white]
        BAK [label="BAK\n(effector)", fillcolor="#9B59B6", fontcolor=white]
        NOXA [label="NOXA\n(PMAIP1)", fillcolor="#BB8FCE"]
        PUMA [label="PUMA\n(BBC3)", fillcolor="#BB8FCE"]
        cytochrome_c [label="Cytochrome c\nrelease", fillcolor="#D7BDE2"]
        APAF1 [label="APAF-1\napoptosome", fillcolor="#D7BDE2"]
        caspase9 [label="Caspase-9\n(initiator)", fillcolor="#7D3C98", fontcolor=white]
        caspase3 [label="Caspase-3/7\n(executioner)", fillcolor="#6C3483", fontcolor=white, shape=diamond]
        XIAP [label="XIAP\n(IAP inhibitor)", fillcolor="#D7BDE2"]
        SMAC [label="SMAC/Diablo\n(XIAP antagonist)", fillcolor="#D7BDE2"]
        TP53 [label="TP53\n(guardian)", fillcolor="#7D3C98", fontcolor=white]
        MDM2_apop [label="MDM2\n(p53 E3 ligase)", fillcolor="#D7BDE2"]
        p21_apop [label="p21/CDKN1A\n(CDK inhibitor)", fillcolor="#D7BDE2"]
    }

    /* ================================================================
       CLUSTER 7: CELL CYCLE
       ================================================================ */
    subgraph cluster_CellCycle {
        label="Cell Cycle Regulation"
        style=filled; fillcolor="#EBF5FB"; color="#1565C0"; fontsize=11; fontcolor="#0D47A1"

        CyclinD1 [label="Cyclin D1/D2/D3\n(CDK4/6 partner)", fillcolor="#90CAF9"]
        CDK4 [label="CDK4/6", fillcolor="#64B5F6"]
        Rb [label="Rb\n(pS807/T821)", fillcolor="#42A5F5"]
        E2F [label="E2F1/2/3\n(S phase genes)", fillcolor="#1976D2", fontcolor=white, shape=diamond]
        CyclinE [label="Cyclin E\n(CDK2 partner)", fillcolor="#90CAF9"]
        CDK2 [label="CDK2", fillcolor="#64B5F6"]
        CyclinB [label="Cyclin B\n(CDK1 partner)", fillcolor="#90CAF9"]
        CDK1 [label="CDK1\n(G2/M)", fillcolor="#64B5F6"]
        p16 [label="p16/CDKN2A\n(CDK4/6 inhibitor)", fillcolor="#BBDEFB"]
        p21_cc [label="p21/CDKN1A", fillcolor="#BBDEFB"]
        p27 [label="p27/CDKN1B", fillcolor="#BBDEFB"]
        CDC25A [label="CDC25A\n(CDK activator)", fillcolor="#90CAF9"]
        WEE1 [label="WEE1\n(CDK1 inhibitor)", fillcolor="#BBDEFB"]
        CHK1 [label="CHK1/2\n(checkpoint)", fillcolor="#64B5F6"]
        ATM [label="ATM/ATR\n(DNA damage)", fillcolor="#42A5F5"]
    }

    /* ================================================================
       CLUSTER 8: EPIGENETICS / TRANSCRIPTION
       ================================================================ */
    subgraph cluster_Epigenetics {
        label="Epigenetics / Transcription Factors"
        style=filled; fillcolor="#FFF9C4"; color="#F39C12"; fontsize=11; fontcolor="#7E5109"

        EZH2 [label="EZH2\n(Y641 mut GCB)", fillcolor="#F9E79F"]
        PRC2 [label="PRC2 complex\n(EED·SUZ12·EZH2)", fillcolor="#F7DC6F"]
        H3K27me3 [label="H3K27me3\n(repressive mark)", fillcolor="#F0B27A"]
        CREBBP [label="CREBBP/EP300\n(HAT tumor suppressor)", fillcolor="#F9E79F"]
        H3K27ac [label="H3K27ac\n(active mark)", fillcolor="#F7DC6F"]
        KMT2D [label="KMT2D/MLL4\n(H3K4me1/2)", fillcolor="#F9E79F"]
        DNMT3A [label="DNMT3A\n(DNA methylation)", fillcolor="#F5CBA7"]
        BCL6_epi [label="BCL6\n(recruits HDAC/NuRD)", fillcolor="#F0B27A"]
        HDAC [label="HDAC1/2/3\n(deacetylases)", fillcolor="#F7DC6F"]
        IRF4_epi [label="IRF4\n(ABC transcription)", fillcolor="#F0B27A"]
        BLIMP1_epi [label="BLIMP1\n(GCB → PC diff)", fillcolor="#F5CBA7"]
        BCL6_target [label="BCL6 Repressed:\nBLIMP1·p53·CCND2·p21", fillcolor="#E8D5B7", shape=box]
        MYC_amp [label="MYC amplification\n8q24 (30% DLBCL)", fillcolor="#F9E79F"]
        DH_DHL [label="Double-hit\n(MYC + BCL2/BCL6)\nHigh-grade B-cell lymphoma", fillcolor="#E74C3C", fontcolor=white, shape=box]
    }

    /* ================================================================
       CLUSTER 9: TUMOR MICROENVIRONMENT
       ================================================================ */
    subgraph cluster_TME {
        label="Tumor Microenvironment (TME)"
        style=filled; fillcolor="#FDFEFE"; color="#117A65"; fontsize=11; fontcolor="#0E6655"

        DLBCL_cells [label="DLBCL Tumor Cells\n(GCB or ABC)", fillcolor="#A2D9CE"]
        CD4_T [label="CD4+ T cells\n(Th1/Th2/Tfh)", fillcolor="#76D7C4"]
        CD8_T [label="CD8+ CTL\n(cytotoxic)", fillcolor="#45B39D"]
        Treg [label="T regulatory cells\n(FoxP3+)", fillcolor="#A2D9CE"]
        NK_cells [label="NK cells\n(CD56+CD16+)", fillcolor="#76D7C4"]
        Macrophage [label="Tumor-associated\nMacrophage (TAM)", fillcolor="#45B39D"]
        M1_TAM [label="M1 TAM\n(anti-tumor)", fillcolor="#76D7C4"]
        M2_TAM [label="M2 TAM\n(pro-tumor)", fillcolor="#A2D9CE"]
        Neutrophil [label="Tumor-associated\nNeutrophil", fillcolor="#D5F5E3"]
        CAF [label="Cancer-assoc\nFibroblast (CAF)", fillcolor="#D5F5E3"]
        HEV [label="High Endothelial\nVenule (HEV)", fillcolor="#D5F5E3"]
        PDCD1 [label="PD-1\n(CD279)", fillcolor="#A2D9CE"]
        PDL1 [label="PD-L1\n(CD274/B7-H1)", fillcolor="#45B39D"]
        CTLA4 [label="CTLA-4\n(CD152)", fillcolor="#A2D9CE"]
        CD47 [label="CD47\n('don't eat me')", fillcolor="#76D7C4"]
        SIRPalpha [label="SIRPα\n(macrophage receptor)", fillcolor="#A2D9CE"]
        CXCL13 [label="CXCL13-CXCR5\nGC homing", fillcolor="#D5F5E3"]
        IFNg_TME [label="IFN-γ\n(CTL secretion)", fillcolor="#76D7C4"]
        TNFa_TME [label="TNF-α\n(NF-κB induction)", fillcolor="#D5F5E3"]
        TGFb [label="TGF-β\n(immune suppression)", fillcolor="#A2D9CE"]
        VEGF [label="VEGF\n(angiogenesis)", fillcolor="#D5F5E3"]
    }

    /* ================================================================
       CLUSTER 10: DRUG PK (Pharmacokinetics)
       ================================================================ */
    subgraph cluster_DrugPK {
        label="Drug PK / Pharmacokinetics"
        style=filled; fillcolor="#FDFEFE"; color="#1C2833"; fontsize=11; fontcolor="#1C2833"

        Rituximab_central [label="Rituximab\nCentral (C1)", fillcolor="#BDC3C7"]
        Rituximab_periph [label="Rituximab\nPeripheral (C2)", fillcolor="#D5DBDB"]
        Cyclophosphamide [label="Cyclophosphamide\n(prodrug)", fillcolor="#BDC3C7"]
        Cyc_active [label="4-OH-Cyclophosphamide\n(CYP3A4 metabolite)", fillcolor="#95A5A6"]
        Doxorubicin [label="Doxorubicin\nPlasma (Cp)", fillcolor="#BDC3C7"]
        Vincristine [label="Vincristine\n(1-cmt PK)", fillcolor="#BDC3C7"]
        Prednisone [label="Prednisone →\nPrednisolone", fillcolor="#BDC3C7"]
        Pola_central [label="Pola-vedotin\nCentral Ab", fillcolor="#95A5A6"]
        Pola_payload [label="MMAE Payload\nreleased", fillcolor="#7F8C8D"]
        Venetoclax [label="Venetoclax\nPlasma Cp", fillcolor="#BDC3C7"]
        Ibrutinib [label="Ibrutinib\n(BTK inh) PK", fillcolor="#BDC3C7"]
        Tafasitamab [label="Tafasitamab\n(anti-CD19)", fillcolor="#D5DBDB"]
        CART_infusion [label="CAR-T Infusion\n(axi-cel/tisa-cel)", fillcolor="#95A5A6"]
        CART_expand [label="CAR-T Expansion\nin vivo", fillcolor="#7F8C8D"]
    }

    /* ================================================================
       CLUSTER 11: CLINICAL ENDPOINTS
       ================================================================ */
    subgraph cluster_Endpoints {
        label="Clinical Endpoints / Biomarkers"
        style=filled; fillcolor="#FEF9E7"; color="#784212"; fontsize=11; fontcolor="#784212"

        Tumor_burden [label="Tumor Burden\n(TMTV cm³)", fillcolor="#FAD7A0"]
        SPD [label="SPD\n(sum of product diameter)", fillcolor="#FAD7A0"]
        LDH [label="LDH\n(surrogate)", fillcolor="#F0B27A"]
        ctDNA [label="ctDNA\n(cfDNA EBV-cfDNA)", fillcolor="#F0B27A"]
        IPI_score [label="IPI Score\n(0–5)", fillcolor="#FAD7A0"]
        ORR [label="ORR\n(CR + PR)", fillcolor="#E59866", shape=diamond]
        CR_rate [label="CR rate\n(PET-CT Deauville ≤2)", fillcolor="#E59866", shape=diamond]
        PFS [label="PFS\n(progression-free survival)", fillcolor="#CA6F1E", fontcolor=white, shape=diamond]
        OS [label="OS\n(overall survival)", fillcolor="#A04000", fontcolor=white, shape=diamond]
        EFS24 [label="EFS24\n(event-free 24mo)", fillcolor="#E59866", shape=diamond]
        ECOG [label="ECOG PS\n(0–4)", fillcolor="#FAD7A0"]
        BM_involve [label="Bone Marrow\nInvolvement (%)", fillcolor="#FAD7A0"]
        Ferritin [label="Ferritin\n(inflammation)", fillcolor="#F0B27A"]
        Beta2MG [label="β2-microglobulin\n(tumor load)", fillcolor="#F0B27A"]
        CNS_IPI [label="CNS-IPI\n(CNS risk score)", fillcolor="#FAD7A0"]
        COO [label="Cell-of-Origin\n(GCB vs ABC)", fillcolor="#E59866"]
        Deauville [label="Deauville score\n(PET response)", fillcolor="#FAD7A0"]
    }

    /* ================================================================
       CLUSTER 12: DRUG PD (Pharmacodynamics)
       ================================================================ */
    subgraph cluster_DrugPD {
        label="Drug Mechanisms of Action (PD)"
        style=filled; fillcolor="#F4ECF7"; color="#6C3483"; fontsize=11; fontcolor="#4A235A"

        RTX_CD20 [label="Rituximab → CD20\n(ADCC·CDC·apoptosis)", fillcolor="#D7BDE2"]
        RTX_ADCC [label="ADCC\n(NK·macrophage FcγR)", fillcolor="#C39BD3"]
        RTX_CDC [label="CDC\n(C1q→MAC→lysis)", fillcolor="#C39BD3"]
        CYC_DNA [label="Cyclophosphamide\nDNA alkylation", fillcolor="#C39BD3"]
        DOX_Topo [label="Doxorubicin\nTopoII inhibition+ROS", fillcolor="#C39BD3"]
        VCR_MT [label="Vincristine\nmicrotubule disruption", fillcolor="#D7BDE2"]
        PRED_GR [label="Prednisone\nGlucocorticoid receptor", fillcolor="#D7BDE2"]
        POLA_CD79b [label="Pola-vedotin\nCD79b→MMAE→tubulin", fillcolor="#A569BD"]
        VEN_BCL2 [label="Venetoclax\nBCL-2 BH3 mimetic", fillcolor="#A569BD", fontcolor=white]
        IBRU_BTK [label="Ibrutinib\nBTK C481S covalent", fillcolor="#C39BD3"]
        TAFA_CD19 [label="Tafasitamab\nCD19 ADCC+apoptosis", fillcolor="#D7BDE2"]
        CART_CD19 [label="CAR-T\nCD19 scFv cytolysis", fillcolor="#A569BD", fontcolor=white]
        EZHI_EZH2 [label="Tazemetostat\nEZH2 SAM-competitive", fillcolor="#D7BDE2"]
        ICI_PDL1 [label="Anti-PD-1/PD-L1\n(checkpoint blockade)", fillcolor="#D7BDE2"]
    }

    /* ================================================================
       INTER-CLUSTER EDGES
       ================================================================ */

    /* BCR signaling cascade */
    BCR -> LYN [label="Ig crosslink"]
    LYN -> SYK [label="ITAM pY"]
    BCR -> CD19 [label="complex"]
    CD19 -> PIK3CD [label="recruit"]
    SYK -> BTK [label="pY551"]
    SYK -> PLCg2 [label="pY1217"]
    BTK -> PLCg2 [label="pY1217"]
    PLCg2 -> DAG [label="cleaves PIP2"]
    PLCg2 -> IP3 [label="cleaves PIP2"]
    DAG -> PKCbeta [label="activates"]
    IP3 -> Ca2plus [label="ER Ca²⁺ release"]
    Ca2plus -> NFAT [label="calcineurin dephos"]
    PKCbeta -> CARD11 [label="pS657"]
    CARD11 -> CBM [label="forms"]
    BCL10 -> CBM [label="forms"]
    MALT1 -> CBM [label="forms"]
    CBM -> IKKcomplex [label="IKK activation"]
    CD79b -> SYK [label="ITAM"]

    /* NF-κB */
    IKKalpha -> IKKcomplex [label=""]
    IKKbeta -> IKKcomplex [label=""]
    IKKgamma -> IKKcomplex [label=""]
    IKKcomplex -> IkBa [label="pS32/36"]
    IkBa -> IkBa_free [label="proteasome deg"]
    IkBa_free -> p65 [label="releases"]
    IkBa_free -> p50 [label="releases"]
    p65 -> NFkB_nuclear [label="nuclear import"]
    p50 -> NFkB_nuclear [label="nuclear import"]
    cREL -> NFkB_nuclear [label="nuclear import"]
    NFkB_nuclear -> NFkB_targets [label="transcription\nactivation", color="#6C3483", penwidth=2]
    NFkB_targets -> BCL2 [label="↑expression", style=dashed]
    NFkB_targets -> BCLXL [label="↑expression", style=dashed]
    NFkB_targets -> MCL1 [label="↑expression", style=dashed]
    NFkB_targets -> MYC [label="↑expression", style=dashed]
    NFkB_targets -> IL6 [label="↑expression", style=dashed]
    NFkB_targets -> IL10 [label="↑expression", style=dashed]
    A20 -> IKKcomplex [label="deubiquitinates\n(inhibits)", color=red, arrowhead=tee]
    CD40L -> TRAF2 [label=""]
    TRAF2 -> IKKcomplex [label=""]
    NIK -> IKKalpha [label="non-canonical"]
    MYD88 -> IKKcomplex [label="L265P→const. activ", color="#E74C3C"]

    /* PI3K/AKT/mTOR */
    PIK3CD -> PIP2 [label="→PIP3"]
    PI3K_delta -> PIP3 [label="phosphorylates"]
    PIP2 -> PIP3 [label="PI3K"]
    PTEN -> PIP3 [label="dephosphorylates", color=red, arrowhead=tee]
    PIP3 -> PDK1 [label="recruits"]
    PDK1 -> AKT [label="pT308"]
    mTORC2 -> AKT [label="pS473"]
    AKT -> TSC1 [label="phospho-inhibit", color=red, arrowhead=tee]
    TSC1 -> Rheb [label="GAP for"]
    Rheb -> mTORC1 [label="GTP-activates"]
    mTORC1 -> S6K [label="pT389"]
    mTORC1 -> fourEBP1 [label="pS65"]
    fourEBP1 -> eIF4E [label="releases"]
    AKT -> FOXO1 [label="pT24/S256 cytoplasm", color=red, arrowhead=tee]
    AKT -> GSK3b [label="pS9 inactivates", color=red, arrowhead=tee]
    AKT -> MDM2 [label="pS166/186 activates"]
    MDM2 -> TP53 [label="ubiquitin deg", color=red, arrowhead=tee]

    /* JAK/STAT */
    IL6 -> IL6R [label="binds"]
    IL10 -> IL10R [label="binds"]
    IL6R -> JAK1 [label="activates"]
