digraph DLBCL_QSP {
    graph [
        label="Diffuse Large B-Cell Lymphoma (DLBCL) QSP Mechanistic Map\nPK/PD Signaling Network: BCR · PI3K-AKT-mTOR · Apoptosis · GC Biology · TME · Drugs · DNA · Endpoints · Cytokines · Epigenetics",
        labelloc=t,
        fontsize=20,
        fontname="Helvetica-Bold",
        nodesep=0.35,
        pad=0.5,
        overlap=false
    ];
    node [fontname="Helvetica", fontsize=10, style="filled,rounded", shape=ellipse];
    edge [fontsize=8, fontname="Helvetica"];

    // =========================================================
    // CLUSTER 1: BCR Signaling & NF-kB
    // =========================================================
    subgraph cluster_bcr {
        label="BCR Signaling & NF-κB";
        style=filled;
        color="#C62828";
        fillcolor="#FFE4E1";
        fontsize=14;
        fontname="Helvetica-Bold";

        BCR [label="BCR\n(B-Cell Receptor)", fillcolor="#FFCDD2"];
        LYN [label="LYN\n(Src kinase)", fillcolor="#FFCDD2"];
        SYK [label="SYK\n(Spleen tyrosine\nkinase)", fillcolor="#FFCDD2"];
        BTK [label="BTK\n(Bruton tyrosine\nkinase)", fillcolor="#EF9A9A", fontname="Helvetica-Bold"];
        PLCgamma2 [label="PLCγ2\n(Phospholipase Cγ2)", fillcolor="#FFCDD2"];
        PKCbeta [label="PKCβ\n(Protein kinase Cβ)", fillcolor="#FFCDD2"];
        CARMA1 [label="CARMA1\n(CARD11)", fillcolor="#FFCDD2"];
        BCL10 [label="BCL10", fillcolor="#FFCDD2"];
        MALT1 [label="MALT1\n(paracaspase)", fillcolor="#FFCDD2"];
        IKKalpha [label="IKKα", fillcolor="#EF9A9A"];
        IKKbeta [label="IKKβ", fillcolor="#EF9A9A"];
        IKKgamma [label="IKKγ\n(NEMO)", fillcolor="#EF9A9A"];
        IkBa [label="IκBα\n(NF-κB inhibitor)", fillcolor="#FFCDD2"];
        NFkB_p50 [label="NF-κB p50", fillcolor="#B71C1C", fontcolor="white"];
        NFkB_p65 [label="NF-κB p65\n(RELA)", fillcolor="#B71C1C", fontcolor="white"];
        IRF4 [label="IRF4\n(Interferon regulatory\nfactor 4)", fillcolor="#EF9A9A"];
        BLIMP1 [label="BLIMP1\n(PRDM1)", fillcolor="#FFCDD2"];
        MYD88 [label="MYD88\n(L265P mutation)", fillcolor="#EF9A9A", fontname="Helvetica-Bold"];
        IRAK4 [label="IRAK4", fillcolor="#FFCDD2"];
        TRAF6 [label="TRAF6", fillcolor="#FFCDD2"];
        TAK1 [label="TAK1\n(MAP3K7)", fillcolor="#FFCDD2"];
        CD79B [label="CD79B\n(Igβ, ITAMs)", fillcolor="#FFCDD2"];
        CD20 [label="CD20\n(MS4A1)\n[Rituximab target]", fillcolor="#FF5252", fontcolor="white", shape=box];
    }

    // =========================================================
    // CLUSTER 2: PI3K-AKT-mTOR Pathway
    // =========================================================
    subgraph cluster_pi3k {
        label="PI3K-AKT-mTOR Pathway";
        style=filled;
        color="#0277BD";
        fillcolor="#E1F5FE";
        fontsize=14;
        fontname="Helvetica-Bold";

        PI3Kdelta [label="PI3Kδ\n(PIK3CD)", fillcolor="#B3E5FC", fontname="Helvetica-Bold"];
        PIP2 [label="PIP2\n(PI(4,5)P2)", fillcolor="#E1F5FE"];
        PIP3 [label="PIP3\n(PI(3,4,5)P3)", fillcolor="#B3E5FC"];
        PTEN [label="PTEN\n(phosphatase)", fillcolor="#81D4FA"];
        PDK1 [label="PDK1\n(PDPK1)", fillcolor="#B3E5FC"];
        AKT [label="AKT\n(PKB)", fillcolor="#0288D1", fontcolor="white", fontname="Helvetica-Bold"];
        TSC1 [label="TSC1\n(Hamartin)", fillcolor="#E1F5FE"];
        TSC2 [label="TSC2\n(Tuberin)", fillcolor="#E1F5FE"];
        RHEB [label="RHEB\n(Ras homolog)", fillcolor="#B3E5FC"];
        mTORC1 [label="mTORC1\n(mTOR complex 1)", fillcolor="#0277BD", fontcolor="white", fontname="Helvetica-Bold"];
        mTORC2 [label="mTORC2\n(mTOR complex 2)", fillcolor="#0277BD", fontcolor="white"];
        S6K1 [label="S6K1\n(RPS6KB1)", fillcolor="#B3E5FC"];
        S6K2 [label="S6K2\n(RPS6KB2)", fillcolor="#B3E5FC"];
        "4EBP1" [label="4E-BP1\n(EIF4EBP1)", fillcolor="#B3E5FC"];
        eIF4E [label="eIF4E\n(translation init.)", fillcolor="#E1F5FE"];
        FOXO1 [label="FOXO1\n(Forkhead TF)", fillcolor="#81D4FA"];
        GSK3beta [label="GSK3β\n(glycogen synthase\nkinase 3β)", fillcolor="#E1F5FE"];
        RAC1 [label="RAC1\n(Rho GTPase)", fillcolor="#E1F5FE"];
    }

    // =========================================================
    // CLUSTER 3: Cell Survival & Apoptosis
    // =========================================================
    subgraph cluster_apoptosis {
        label="Cell Survival & Apoptosis";
        style=filled;
        color="#6A1B9A";
        fillcolor="#F3E5F5";
        fontsize=14;
        fontname="Helvetica-Bold";

        BCL2 [label="BCL-2\n(anti-apoptotic)", fillcolor="#CE93D8", fontname="Helvetica-Bold"];
        BCL_XL [label="BCL-XL\n(BCL2L1)", fillcolor="#CE93D8"];
        MCL1 [label="MCL-1\n(anti-apoptotic)", fillcolor="#CE93D8"];
        BCL2A1 [label="BCL2A1\n(A1/BFL-1)", fillcolor="#E1BEE7"];
        BAX [label="BAX\n(pro-apoptotic)", fillcolor="#BA68C8"];
        BAK1 [label="BAK1\n(pro-apoptotic)", fillcolor="#BA68C8"];
        BIM [label="BIM\n(BCL2L11, BH3-only)", fillcolor="#AB47BC"];
        BID [label="BID\n(BH3-only)", fillcolor="#AB47BC"];
        PUMA [label="PUMA\n(BBC3, BH3-only)", fillcolor="#AB47BC"];
        NOXA [label="NOXA\n(PMAIP1, BH3-only)", fillcolor="#AB47BC"];
        CytochromeC [label="Cytochrome C\n(CYCS)", fillcolor="#7B1FA2", fontcolor="white"];
        APAF1 [label="APAF1\n(apoptosome)", fillcolor="#8E24AA", fontcolor="white"];
        Caspase9 [label="Caspase-9\n(initiator)", fillcolor="#9C27B0", fontcolor="white"];
        Caspase3 [label="Caspase-3\n(executioner)", fillcolor="#7B1FA2", fontcolor="white"];
        Caspase7 [label="Caspase-7\n(executioner)", fillcolor="#7B1FA2", fontcolor="white"];
        XIAP [label="XIAP\n(IAP family)", fillcolor="#E1BEE7"];
        Survivin [label="Survivin\n(BIRC5)", fillcolor="#E1BEE7"];
        SMAC [label="SMAC/DIABLO\n(IAP antagonist)", fillcolor="#CE93D8"];
        Apoptosis_out [label="APOPTOSIS", fillcolor="#4A148C", fontcolor="white", shape=box, fontsize=12, fontname="Helvetica-Bold"];
    }

    // =========================================================
    // CLUSTER 4: Germinal Center Biology
    // =========================================================
    subgraph cluster_gc {
        label="Germinal Center Biology";
        style=filled;
        color="#2E7D32";
        fillcolor="#E8F5E9";
        fontsize=14;
        fontname="Helvetica-Bold";

        BCL6 [label="BCL6\n(master GC TF)", fillcolor="#A5D6A7", fontname="Helvetica-Bold"];
        MYC [label="MYC\n(c-Myc oncogene)", fillcolor="#66BB6A", fontname="Helvetica-Bold"];
        CD10 [label="CD10\n(MME/CALLA)", fillcolor="#C8E6C9"];
        IRF4_GC [label="IRF4 (GC)\n(plasma cell diff.)", fillcolor="#A5D6A7"];
        FOXO1_GC [label="FOXO1 (GC)\n(GC maintenance)", fillcolor="#C8E6C9"];
        AICDA [label="AID\n(AICDA)\n(somatic hypermutation)", fillcolor="#81C784"];
        SHM [label="SHM\n(Somatic\nHypermutation)", fillcolor="#C8E6C9"];
        CSR [label="CSR\n(Class Switch\nRecombination)", fillcolor="#C8E6C9"];
        GCBC [label="GC B-cell\n(centroblast/centrocyte)", fillcolor="#4CAF50", fontcolor="white"];
        LZB [label="Light Zone B-cell\n(selection)", fillcolor="#81C784"];
        DZB [label="Dark Zone B-cell\n(proliferation)", fillcolor="#81C784"];
        BLIMP1_GC [label="BLIMP1 (GC)\n(plasma cell fate)", fillcolor="#A5D6A7"];
        XBP1 [label="XBP1\n(plasma cell TF)", fillcolor="#C8E6C9"];
        PRDM1 [label="PRDM1\n(BLIMP1 gene)", fillcolor="#C8E6C9"];
        PAX5 [label="PAX5\n(B-cell identity TF)", fillcolor="#A5D6A7"];
        OCT2 [label="OCT2\n(POU2F2)", fillcolor="#C8E6C9"];
        Proliferation [label="TUMOR\nPROLIFERATION", fillcolor="#1B5E20", fontcolor="white", shape=box, fontsize=11, fontname="Helvetica-Bold"];
    }

    // =========================================================
    // CLUSTER 5: Tumor Microenvironment
    // =========================================================
    subgraph cluster_tme {
        label="Tumor Microenvironment (TME)";
        style=filled;
        color="#E65100";
        fillcolor="#FFF8E1";
        fontsize=14;
        fontname="Helvetica-Bold";

        TAM_M1 [label="TAM M1\n(anti-tumor\nmacrophage)", fillcolor="#FFE082"];
        TAM_M2 [label="TAM M2\n(pro-tumor\nmacrophage)", fillcolor="#FFD54F"];
        Treg [label="T-reg\n(immunosuppressive)", fillcolor="#FFD54F"];
        CD8_CTL [label="CD8+ CTL\n(cytotoxic\nT-lymphocyte)", fillcolor="#FFA726", fontname="Helvetica-Bold"];
        NK_cell [label="NK Cell\n(natural killer)", fillcolor="#FFB300"];
        PD1 [label="PD-1\n(PDCD1)", fillcolor="#FF8F00"];
        PDL1 [label="PD-L1\n(CD274)", fillcolor="#FF8F00"];
        LAG3 [label="LAG-3\n(checkpoint)", fillcolor="#FFB300"];
        TIM3 [label="TIM-3\n(HAVCR2\ncheckpoint)", fillcolor="#FFB300"];
        CTLA4 [label="CTLA-4\n(checkpoint)", fillcolor="#FFB300"];
        CXCL13 [label="CXCL13\n(B-cell attractant)", fillcolor="#FFE082"];
        IL10 [label="IL-10\n(TME)", fillcolor="#FFE082"];
        TGFbeta [label="TGF-β\n(immunosuppressive)", fillcolor="#FFD54F"];
        IFNgamma [label="IFN-γ\n(anti-tumor)", fillcolor="#FFE082"];
        TNFalpha [label="TNF-α\n(TME)", fillcolor="#FFE082"];
        IL21 [label="IL-21\n(T-helper)", fillcolor="#FFE082"];
        CXCR5 [label="CXCR5\n(B-cell receptor)", fillcolor="#FFF8E1"];
        CD4_Tfh [label="CD4+ Tfh\n(follicular helper)", fillcolor="#FFD54F"];
        FDC [label="FDC\n(follicular dendritic\ncell)", fillcolor="#FFE082"];
        Stroma [label="Stromal Cells\n(CAF/endothelial)", fillcolor="#FFF3E0"];
        ADCC [label="ADCC\n(Ab-dependent\ncell cytotoxicity)", fillcolor="#E65100", fontcolor="white", shape=box];
    }

    // =========================================================
    // CLUSTER 6: Drug PK Compartments
    // =========================================================
    subgraph cluster_drugs {
        label="Drug PK/PD Compartments";
        style=filled;
        color="#00838F";
        fillcolor="#E0F7FA";
        fontsize=14;
        fontname="Helvetica-Bold";

        Rituximab_central [label="Rituximab\n(Central Cmt)\nanti-CD20 mAb", fillcolor="#80DEEA", shape=box, fontname="Helvetica-Bold"];
        Rituximab_peripheral [label="Rituximab\n(Peripheral Cmt)", fillcolor="#80DEEA", shape=box];
        PolaVedotin_ADC [label="Pola-Vedotin\n(ADC intact)\nanti-CD79B", fillcolor="#80DEEA", shape=box, fontname="Helvetica-Bold"];
        PolaVedotin_payload [label="Pola-Vedotin\n(MMAE payload\nreleased)", fillcolor="#4DD0E1", shape=box];
        Venetoclax_central [label="Venetoclax\n(Central Cmt)\nBCL-2 inhibitor", fillcolor="#80DEEA", shape=box, fontname="Helvetica-Bold"];
        Venetoclax_peripheral [label="Venetoclax\n(Peripheral Cmt)", fillcolor="#80DEEA", shape=box];
        Ibrutinib_plasma [label="Ibrutinib\n(Plasma)\nBTK inhibitor", fillcolor="#80DEEA", shape=box, fontname="Helvetica-Bold"];
        RCHOP_cytotoxic [label="R-CHOP\n(Cytotoxic agents)\nCy+Dox+Vinc+Pred", fillcolor="#00BCD4", shape=box, fontname="Helvetica-Bold", fontcolor="white"];
        Obinutuzumab_central [label="Obinutuzumab\n(Central Cmt)\ntype II anti-CD20", fillcolor="#80DEEA", shape=box];
        Lenalidomide_plasma [label="Lenalidomide\n(Plasma)\nIMiD", fillcolor="#80DEEA", shape=box];
        Tafasitamab_plasma [label="Tafasitamab\n(Plasma)\nanti-CD19 mAb", fillcolor="#80DEEA", shape=box];
        Selinexor_plasma [label="Selinexor\n(Plasma)\nXPO1 inhibitor", fillcolor="#4DD0E1", shape=box];
    }

    // =========================================================
    // CLUSTER 7: DNA Damage & Cell Cycle
    // =========================================================
    subgraph cluster_dna {
        label="DNA Damage Response & Cell Cycle";
        style=filled;
        color="#AD1457";
        fillcolor="#FCE4EC";
        fontsize=14;
        fontname="Helvetica-Bold";

        TP53 [label="TP53\n(tumor suppressor)", fillcolor="#F48FB1", fontname="Helvetica-Bold"];
        ATM [label="ATM\n(DNA damage\nkinase)", fillcolor="#F48FB1"];
        ATR [label="ATR\n(replication stress\nkinase)", fillcolor="#F48FB1"];
        CHK1 [label="CHK1\n(checkpoint kinase)", fillcolor="#F8BBD0"];
        CHK2 [label="CHK2\n(checkpoint kinase)", fillcolor="#F8BBD0"];
        p21 [label="p21\n(CDKN1A)\ncell cycle arrest", fillcolor="#F48FB1"];
        MDM2 [label="MDM2\n(TP53 regulator)", fillcolor="#F06292"];
        CDK4 [label="CDK4\n(cyclin-dependent\nkinase)", fillcolor="#F8BBD0"];
        CDK6 [label="CDK6\n(cyclin-dependent\nkinase)", fillcolor="#F8BBD0"];
        CyclinD1 [label="Cyclin D1\n(CCND1)", fillcolor="#F48FB1"];
        CyclinE [label="Cyclin E\n(CCNE1)", fillcolor="#F8BBD0"];
        RB1 [label="RB1\n(retinoblastoma\nprotein)", fillcolor="#F06292"];
        E2F1 [label="E2F1\n(transcription\nfactor)", fillcolor="#F48FB1"];
        MYC_amp [label="MYC\nAmplification\n(8q24)", fillcolor="#EC407A", fontcolor="white"];
        BCL2_trans [label="BCL2\nTranslocation\nt(14;18)", fillcolor="#E91E63", fontcolor="white"];
        MYC_trans [label="MYC\nTranslocation\nt(8;14)", fillcolor="#E91E63", fontcolor="white"];
        CDKN2A [label="CDKN2A\n(p16/ARF locus)", fillcolor="#F8BBD0"];
        CDKN2B [label="CDKN2B\n(p15)", fillcolor="#F8BBD0"];
        G1_S_checkpoint [label="G1/S\nCheckpoint", fillcolor="#AD1457", fontcolor="white", shape=box];
        DNA_repair [label="DNA Repair\n(NHEJ/HR)", fillcolor="#880E4F", fontcolor="white", shape=box];
    }

    // =========================================================
    // CLUSTER 8: Clinical Endpoints & Biomarkers
    // =========================================================
    subgraph cluster_endpoints {
        label="Clinical Endpoints & Biomarkers";
        style=filled;
        color="#827717";
        fillcolor="#F9FBE7";
        fontsize=14;
        fontname="Helvetica-Bold";

        IPI_score [label="IPI Score\n(0-5)", fillcolor="#F0F4C3", shape=diamond];
        LDH_level [label="LDH Level\n(serum)", fillcolor="#F0F4C3", shape=diamond];
        Ki67 [label="Ki67\n(proliferation %)", fillcolor="#DCE775", shape=diamond];
        PET_CT [label="PET-CT\n(Deauville score)", fillcolor="#DCE775", shape=diamond];
        CR_response [label="CR\n(Complete\nResponse)", fillcolor="#CDDC39", shape=diamond, fontname="Helvetica-Bold"];
        PR_response [label="PR\n(Partial\nResponse)", fillcolor="#D4E157", shape=diamond];
        PD_response [label="PD\n(Progressive\nDisease)", fillcolor="#AFBF00", shape=diamond];
        OS_curve [label="Overall\nSurvival (OS)", fillcolor="#827717", fontcolor="white", shape=diamond, fontname="Helvetica-Bold"];
        PFS_curve [label="Progression-Free\nSurvival (PFS)", fillcolor="#9E9D24", fontcolor="white", shape=diamond, fontname="Helvetica-Bold"];
        ECOG_PS [label="ECOG\nPerformance\nStatus", fillcolor="#F0F4C3", shape=diamond];
        BulkyDisease [label="Bulky Disease\n(>10 cm)", fillcolor="#F0F4C3", shape=diamond];
        Extranodal [label="Extranodal\nSites (>1)", fillcolor="#F0F4C3", shape=diamond];
        BoneMarrow_inv [label="Bone Marrow\nInvolvement", fillcolor="#F0F4C3", shape=diamond];
        COO_subtype [label="COO Subtype\n(GCB/ABC/PMBL)", fillcolor="#DCE775", shape=diamond, fontname="Helvetica-Bold"];
        DH_status [label="Double-Hit\nStatus (DH/TH)", fillcolor="#CDDC39", shape=diamond];
    }

    // =========================================================
    // CLUSTER 9: Cytokine Network
    // =========================================================
    subgraph cluster_cytokines {
        label="Cytokine & Chemokine Network";
        style=filled;
        color="#4527A0";
        fillcolor="#EDE7F6";
        fontsize=14;
        fontname="Helvetica-Bold";

        IL6 [label="IL-6\n(pleiotropic\ncytokine)", fillcolor="#D1C4E9", fontname="Helvetica-Bold"];
        IL10_cyto [label="IL-10\n(immunosuppressive)", fillcolor="#D1C4E9"];
        CXCL13_cyto [label="CXCL13\n(B-cell chemokine)", fillcolor="#C5CAE9"];
        TNFalpha_cyto [label="TNF-α\n(cytokine)", fillcolor="#D1C4E9"];
        IFNgamma_cyto [label="IFN-γ\n(cytokine)", fillcolor="#C5CAE9"];
        IL21_cyto [label="IL-21\n(B-cell factor)", fillcolor="#D1C4E9"];
        IL4 [label="IL-4\n(B-cell growth)", fillcolor="#E8EAF6"];
        IL12 [label="IL-12\n(Th1 inducing)", fillcolor="#C5CAE9"];
        IL17 [label="IL-17\n(inflammatory)", fillcolor="#E8EAF6"];
        BAFF [label="BAFF\n(BLyS/TNFSF13B\nB-cell survival)", fillcolor="#B39DDB", fontname="Helvetica-Bold"];
        APRIL [label="APRIL\n(TNFSF13)\nB-cell factor", fillcolor="#C5CAE9"];
        CCL19 [label="CCL19\n(lymph node\nhoming)", fillcolor="#E8EAF6"];
        CCL21 [label="CCL21\n(lymph node\nhoming)", fillcolor="#E8EAF6"];
        CXCL12 [label="CXCL12\n(SDF-1\nBM homing)", fillcolor="#C5CAE9"];
        CCR7 [label="CCR7\n(lymph node\nhoming receptor)", fillcolor="#D1C4E9"];
        STAT3 [label="STAT3\n(signal transducer)", fillcolor="#9575CD", fontcolor="white", fontname="Helvetica-Bold"];
        JAK1 [label="JAK1\n(Janus kinase)", fillcolor="#D1C4E9"];
        JAK2 [label="JAK2\n(Janus kinase)", fillcolor="#D1C4E9"];
    }

    // =========================================================
    // CLUSTER 10: Epigenetics & Mutations
    // =========================================================
    subgraph cluster_epigenetics {
        label="Epigenetics & Key Mutations";
        style=filled;
        color="#BF360C";
        fillcolor="#FBE9E7";
        fontsize=14;
        fontname="Helvetica-Bold";

        EZH2 [label="EZH2\n(H3K27 methyltransferase\nGCB-DLBCL)", fillcolor="#FFAB91", fontname="Helvetica-Bold"];
        CREBBP [label="CREBBP\n(CBP\nacetyltransferase)", fillcolor="#FFAB91"];
        EP300 [label="EP300\n(p300\nacetyltransferase)", fillcolor="#FFCCBC"];
        KMT2D [label="KMT2D\n(MLL4\nH3K4 methyltransferase)", fillcolor="#FFAB91"];
        DNMT3A [label="DNMT3A\n(DNA methyltransferase)", fillcolor="#FFCCBC"];
        DNMT3B [label="DNMT3B\n(DNA methyltransferase)", fillcolor="#FFCCBC"];
        H3K27me3 [label="H3K27me3\n(repressive mark)", fillcolor="#FF8A65"];
        H3K4me3 [label="H3K4me3\n(active mark)", fillcolor="#FFAB91"];
        H3K27ac [label="H3K27ac\n(active enhancer)", fillcolor="#FFAB91"];
        MYC_mut [label="MYC mutation\n(8q24 trans/amp)", fillcolor="#FF7043", fontcolor="white"];
        TP53_mut [label="TP53 mutation\n(17p del/mut)", fillcolor="#FF7043", fontcolor="white"];
        BCL2_mut [label="BCL2 mutation\n(t(14;18) / amp)", fillcolor="#FF7043", fontcolor="white"];
        NOTCH1_mut [label="NOTCH1\nmutation", fillcolor="#FF8A65"];
        CD79B_mut [label="CD79B\nmutation\n(ABC-DLBCL)", fillcolor="#FF8A65"];
        EZH2_mut [label="EZH2 Y641\nmutation\n(GCB-DLBCL)", fillcolor="#FF7043", fontcolor="white"];
        MYD88_mut [label="MYD88 L265P\nmutation\n(ABC-DLBCL)", fillcolor="#FF7043", fontcolor="white"];
        XPO1 [label="XPO1\n(nuclear export\nprotein)", fillcolor="#FFAB91"];
        PCNA [label="PCNA\n(DNA replication)", fillcolor="#FFCCBC"];
    }

    // =========================================================
    // EDGES: BCR Signaling Cascade
    // =========================================================
    BCR -> LYN [label="activates", color="#C62828"];
    BCR -> SYK [label="recruits", color="#C62828"];
    LYN -> SYK [label="phosphorylates", color="#C62828"];
    SYK -> BTK [label="activates", color="#C62828", penwidth=2];
    SYK -> PLCgamma2 [label="activates", color="#C62828"];
    BTK -> PLCgamma2 [label="activates", color="#C62828", penwidth=2];
    PLCgamma2 -> PKCbeta [label="activates\n(via DAG)", color="#C62828"];
    PKCbeta -> CARMA1 [label="phosphorylates", color="#C62828"];
    CARMA1 -> BCL10 [label="scaffolds", color="#C62828"];
    BCL10 -> MALT1 [label="activates", color="#C62828"];
    MALT1 -> IKKbeta [label="activates", color="#C62828", penwidth=2];
    IKKalpha -> IKKbeta [label="cooperates", color="#C62828", style=dashed];
    IKKgamma -> IKKbeta [label="scaffolds", color="#C62828", style=dashed];
    IKKbeta -> IkBa [label="phosphorylates\n(inhibits)", color="#C62828", arrowhead=tee, penwidth=2];
    IkBa -> NFkB_p65 [label="sequesters", color="#C62828", arrowhead=tee];
    IkBa -> NFkB_p50 [label="sequesters", color="#C62828", arrowhead=tee];
    NFkB_p65 -> IRF4 [label="transcribes", color="#C62828", penwidth=2];
    NFkB_p65 -> BCL2 [label="transcribes\n(survival)", color="#C62828", penwidth=2];
    NFkB_p65 -> MCL1 [label="transcribes", color="#C62828"];
    NFkB_p65 -> BCL2A1 [label="transcribes", color="#C62828"];
    NFkB_p65 -> Proliferation [label="drives", color="#C62828", penwidth=2, style=bold];
    MYD88 -> IRAK4 [label="recruits", color="#C62828", penwidth=2];
    IRAK4 -> TRAF6 [label="activates", color="#C62828"];
    TRAF6 -> TAK1 [label="ubiquitinates/\nactivates", color="#C62828"];
    TAK1 -> IKKbeta [label="activates", color="#C62828", penwidth=2];
    CD79B -> SYK [label="signals via\nITAMs", color="#C62828"];
    NFkB_p65 -> BLIMP1 [label="induces", color="#880000", style=dashed];
    IRF4 -> BLIMP1 [label="cooperates", color="#880000"];

    // =========================================================
    // EDGES: PI3K-AKT-mTOR Pathway
    // =========================================================
    BTK -> PI3Kdelta [label="activates", color="#0277BD", penwidth=2];
    PI3Kdelta -> PIP2 [label="converts", color="#0277BD"];
    PIP2 -> PIP3 [label="→ PIP3\n(catalysis)", color="#0277BD", penwidth=2];
    PTEN -> PIP3 [label="dephosphorylates\n(inhibits)", color="#0277BD", arrowhead=tee, penwidth=2];
    PIP3 -> PDK1 [label="recruits", color="#0277BD"];
    PDK1 -> AKT [label="phosphorylates\n(T308)", color="#0277BD", penwidth=2];
    mTORC2 -> AKT [label="phosphorylates\n(S473)", color="#0277BD"];
    AKT -> TSC1 [label="phosphorylates\n(inhibits)", color="#0277BD", arrowhead=tee];
    AKT -> TSC2 [label="phosphorylates\n(inhibits)", color="#0277BD", arrowhead=tee];
    TSC1 -> TSC2 [label="complex", color="#0277BD", style=dashed];
    TSC2 -> RHEB [label="GAP activity\n(inhibits)", color="#0277BD", arrowhead=tee];
    RHEB -> mTORC1 [label="activates", color="#0277BD", penwidth=2];
    mTORC1 -> S6K1 [label="phosphorylates", color="#0277BD"];
    mTORC1 -> S6K2 [label="phosphorylates", color="#0277BD"];
    mTORC1 -> "4EBP1" [label="phosphorylates\n(inhibits)", color="#0277BD", arrowhead=tee];
    "4EBP1" -> eIF4E [label="releases\n(activates)", color="#0277BD"];
    eIF4E -> Proliferation [label="promotes\ntranslation", color="#0277BD", penwidth=2];
    AKT -> FOXO1 [label="phosphorylates\n(inhibits)", color="#0277BD", arrowhead=tee];
    AKT -> GSK3beta [label="phosphorylates\n(inhibits)", color="#0277BD", arrowhead=tee];
    AKT -> RAC1 [label="activates", color="#0277BD"];
    S6K1 -> Proliferation [label="promotes\ngrowth", color="#0277BD"];

    // =========================================================
    // EDGES: Apoptosis Pathway
    // =========================================================
    BCL2 -> BAX [label="inhibits\n(heterodimerize)", color="#6A1B9A", arrowhead=tee, penwidth=2];
    BCL2 -> BAK1 [label="inhibits", color="#6A1B9A", arrowhead=tee];
    BCL_XL -> BAX [label="inhibits", color="#6A1B9A", arrowhead=tee];
    BCL_XL -> BAK1 [label="inhibits", color="#6A1B9A", arrowhead=tee];
    MCL1 -> BAK1 [label="inhibits", color="#6A1B9A", arrowhead=tee];
    BIM -> BCL2 [label="displaces\n(BH3-only)", color="#6A1B9A", arrowhead=tee];
    BIM -> BCL_XL [label="displaces", color="#6A1B9A", arrowhead=tee];
    PUMA -> BCL2 [label="displaces", color="#6A1B9A", arrowhead=tee];
    NOXA -> MCL1 [label="displaces", color="#6A1B9A", arrowhead=tee];
    BID -> BAX [label="activates", color="#6A1B9A"];
    BAX -> CytochromeC [label="releases\n(MOMP)", color="#6A1B9A", penwidth=2];
    BAK1 -> CytochromeC [label="releases\n(MOMP)", color="#6A1B9A"];
    CytochromeC -> APAF1 [label="recruits", color="#6A1B9A", penwidth=2];
    APAF1 -> Caspase9 [label="activates\n(apoptosome)", color="#6A1B9A", penwidth=2];
    Caspase9 -> Caspase3 [label="cleaves", color="#6A1B9A", penwidth=2];
    Caspase9 -> Caspase7 [label="cleaves", color="#6A1B9A"];
    XIAP -> Caspase3 [label="inhibits", color="#6A1B9A", arrowhead=tee];
    XIAP -> Caspase9 [label="inhibits", color="#6A1B9A", arrowhead=tee];
    SMAC -> XIAP [label="antagonizes", color="#6A1B9A", arrowhead=tee];
    CytochromeC -> SMAC [label="co-releases", color="#6A1B9A", style=dashed];
    Caspase3 -> Apoptosis_out [label="executes", color="#4A148C", penwidth=3];
    Caspase7 -> Apoptosis_out [label="executes", color="#4A148C", penwidth=2];
    Survivin -> Caspase3 [label="inhibits", color="#6A1B9A", arrowhead=tee];

    // =========================================================
    // EDGES: Germinal Center Biology
    // =========================================================
    BCL6 -> IRF4_GC [label="represses\n(master GC TF)", color="#2E7D32", arrowhead=tee, penwidth=2];
    BCL6 -> BLIMP1_GC [label="represses", color="#2E7D32", arrowhead=tee, penwidth=2];
    BCL6 -> PRDM1 [label="represses", color="#2E7D32", arrowhead=tee];
    BCL6 -> AICDA [label="induces", color="#2E7D32"];
    AICDA -> SHM [label="catalyzes", color="#2E7D32", penwidth=2];
    AICDA -> CSR [label="catalyzes", color="#2E7D32"];
    SHM -> GCBC [label="diversifies\nantigen receptor", color="#2E7D32"];
    GCBC -> LZB [label="migrates to", color="#2E7D32"];
    GCBC -> DZB [label="migrates to", color="#2E7D32"];
    LZB -> DZB [label="recycling", color="#2E7D32", style=dashed];
    MYC -> DZB [label="drives\nproliferation", color="#2E7D32", penwidth=2];
    IRF4_GC -> BLIMP1_GC [label="induces\n(high levels)", color="#2E7D32"];
    BLIMP1_GC -> XBP1 [label="induces", color="#2E7D32"];
    BLIMP1_GC -> PAX5 [label="represses", color="#2E7D32", arrowhead=tee];
    PAX5 -> OCT2 [label="cooperates", color="#2E7D32", style=dashed];
    FOXO1_GC -> BCL6 [label="supports GC", color="#2E7D32"];
    MYC -> Proliferation [label="drives\noncogenesis", color="#1B5E20", penwidth=3];
    CD10 -> GCBC [label="marker of", color="#2E7D32", style=dashed];

    // =========================================================
    // EDGES: Tumor Microenvironment
    // =========================================================
    PDL1 -> PD1 [label="binds/\nactivates", color="#E65100", penwidth=2];
    PD1 -> CD8_CTL [label="inhibits\n(exhaustion)", color="#E65100", arrowhead=tee, penwidth=2];
    CTLA4 -> CD8_CTL [label="suppresses\nactivation", color="#E65100", arrowhead=tee];
    LAG3 -> CD8_CTL [label="inhibits", color="#E65100", arrowhead=tee];
    TIM3 -> CD8_CTL [label="inhibits", color="#E65100", arrowhead=tee];
    Treg -> CD8_CTL [label="suppresses", color="#E65100", arrowhead=tee];
    TGFbeta -> Treg [label="induces", color="#E65100"];
    IL10 -> TAM_M2 [label="promotes", color="#E65100"];
    TAM_M2 -> TGFbeta [label="secretes", color="#E65100"];
    TAM_M2 -> IL10 [label="secretes", color="#E65100"];
    TAM_M1 -> IFNgamma [label="secretes", color="#E65100"];
    IFNgamma -> PDL1 [label="upregulates", color="#E65100", penwidth=2];
    NK_cell -> ADCC [label="mediates", color="#E65100", penwidth=2];
    CD4_Tfh -> CXCL13 [label="produces", color="#E65100"];
    CXCL13 -> CXCR5 [label="binds", color="#E65100"];
    CXCR5 -> GCBC [label="homing\nreceptor", color="#E65100"];
    IL21 -> GCBC [label="supports", color="#E65100"];
    CD4_Tfh -> IL21 [label="secretes", color="#E65100"];
    FDC -> GCBC [label="antigen\npresentation", color="#E65100"];
    Stroma -> Proliferation [label="supports\ntumor", color="#E65100", style=dashed];

    // =========================================================
    // EDGES: DNA Damage & Cell Cycle
    // =========================================================
    ATM -> CHK2 [label="activates", color="#AD1457", penwidth=2];
    ATR -> CHK1 [label="activates", color="#AD1457", penwidth=2];
    CHK2 -> TP53 [label="stabilizes", color="#AD1457", penwidth=2];
    CHK1 -> TP53 [label="stabilizes", color="#AD1457"];
    TP53 -> MDM2 [label="transcribes\n(feedback)", color="#AD1457"];
    MDM2 -> TP53 [label="ubiquitinates\n(inhibits)", color="#AD1457", arrowhead=tee, penwidth=2];
    TP53 -> p21 [label="transcribes", color="#AD1457", penwidth=2];
    TP53 -> PUMA [label="transcribes", color="#AD1457", penwidth=2];
    TP53 -> BAX [label="transcribes", color="#AD1457"];
    p21 -> CDK4 [label="inhibits", color="#AD1457", arrowhead=tee];
    p21 -> CDK6 [label="inhibits", color="#AD1457", arrowhead=tee];
    CDKN2A -> CDK4 [label="inhibits\n(p16)", color="#AD1457", arrowhead=tee];
    CDKN2B -> CDK4 [label="inhibits\n(p15)", color="#AD1457", arrowhead=tee];
    CDK4 -> RB1 [label="phosphorylates\n(inactivates)", color="#AD1457", arrowhead=tee, penwidth=2];
    CDK6 -> RB1 [label="phosphorylates", color="#AD1457", arrowhead=tee];
    CyclinD1 -> CDK4 [label="activates", color="#AD1457"];
    CyclinE -> CDK4 [label="activates", color="#AD1457", style=dashed];
    RB1 -> E2F1 [label="represses", color="#AD1457", arrowhead=tee, penwidth=2];
    E2F1 -> Proliferation [label="transcribes\ncell cycle genes", color="#AD1457", penwidth=2];
    MYC_amp -> MYC [label="amplifies", color="#AD1457", penwidth=2];
    BCL2_trans -> BCL2 [label="overexpresses", color="#AD1457", penwidth=2];
    MYC_trans -> MYC [label="overexpresses", color="#AD1457", penwidth=2];
    p21 -> G1_S_checkpoint [label="enforces", color="#AD1457", penwidth=2];
    ATM -> DNA_repair [label="coordinates", color="#AD1457"];

    // =========================================================
    // EDGES: Cytokine Network
    // =========================================================
    IL6 -> JAK1 [label="activates", color="#4527A0", penwidth=2];
    IL6 -> JAK2 [label="activates", color="#4527A0"];
    JAK1 -> STAT3 [label="phosphorylates", color="#4527A0", penwidth=2];
    JAK2 -> STAT3 [label="phosphorylates", color="#4527A0"];
    STAT3 -> BCL2 [label="transcribes", color="#4527A0", penwidth=2];
    STAT3 -> MCL1 [label="transcribes", color="#4527A0"];
    STAT3 -> Proliferation [label="drives", color="#4527A0", penwidth=2];
    BAFF -> BCR [label="co-activates", color="#4527A0", penwidth=2];
    BAFF -> AKT [label="activates\n(BAFF-R)", color="#4527A0"];
    APRIL -> BCR [label="co-activates", color="#4527A0"];
    IL10_cyto -> STAT3 [label="activates\n(autocrine)", color="#4527A0", penwidth=2];
    IL12 -> IFNgamma_cyto [label="induces", color="#4527A0"];
    IFNgamma_cyto -> STAT3 [label="activates", color="#4527A0", style=dashed];
    CCL19 -> CCR7 [label="binds", color="#4527A0"];
    CCL21 -> CCR7 [label="binds", color="#4527A0"];
    CCR7 -> GCBC [label="lymph node\nhoming", color="#4527A0"];
    CXCL12 -> CXCR5 [label="alternative\nligand", color="#4527A0", style=dashed];
    TNFalpha_cyto -> NFkB_p65 [label="activates\n(TNFR)", color="#4527A0", penwidth=2];
    IL21_cyto -> GCBC [label="survival factor", color="#4527A0"];

    // =========================================================
    // EDGES: Epigenetics
    // =========================================================
    EZH2 -> H3K27me3 [label="writes\n(catalyzes)", color="#BF360C", penwidth=2];
    H3K27me3 -> BCL6 [label="represses locus", color="#BF360C", style=dashed];
    CREBBP -> H3K27ac [label="writes\n(acetyltransferase)", color="#BF360C", penwidth=2];
    EP300 -> H3K27ac [label="writes", color="#BF360C"];
    KMT2D -> H3K4me3 [label="writes", color="#BF360C"];
    H3K4me3 -> MYC [label="activates locus", color="#BF360C", style=dashed];
    EZH2_mut -> EZH2 [label="gain-of-function\nmutation", color="#BF360C", penwidth=2];
    EZH2_mut -> H3K27me3 [label="enhances", color="#BF360C", penwidth=2];
    MYD88_mut -> MYD88 [label="constitutive\nactivation", color="#BF360C", penwidth=2];
    CD79B_mut -> CD79B [label="activating\nmutation", color="#BF360C", penwidth=2];
    TP53_mut -> TP53 [label="loss-of-function", color="#BF360C", arrowhead=tee, penwidth=2];
    BCL2_mut -> BCL2 [label="overexpression/\nresistance", color="#BF360C", penwidth=2];
    NOTCH1_mut -> NFkB_p65 [label="activates\n(oncogenic)", color="#BF360C", penwidth=2, style=dashed];
    DNMT3A -> H3K27me3 [label="cooperates\n(DNA methyl.)", color="#BF360C", style=dashed];
    DNMT3B -> H3K4me3 [label="regulates", color="#BF360C", style=dashed];
    XPO1 -> TP53 [label="nuclear export\n(regulates)", color="#BF360C"];
    PCNA -> DNA_repair [label="scaffolds", color="#BF360C", style=dashed];

    // =========================================================
    // DRUG EDGES: PK to PD
    // =========================================================
    Rituximab_central -> Rituximab_peripheral [label="distribution", color="#00838F", style=dashed];
    Rituximab_central -> CD20 [label="targets/binds\n(anti-CD20)", color="#00838F", penwidth=3, arrowhead=tee];
    CD20 -> BCR [label="co-receptor\nmodulation", color="#00838F", arrowhead=tee];
    Rituximab_central -> NK_cell [label="recruits\n(ADCC)", color="#00838F", penwidth=2];
    NK_cell -> ADCC [label="Fc-mediated", color="#00838F", penwidth=2];
    ADCC -> Apoptosis_out [label="induces\ntumor kill", color="#00838F", penwidth=2];
    Obinutuzumab_central -> CD20 [label="type II binding\n(enhanced ADCC)", color="#00838F", penwidth=2, arrowhead=tee];

    Ibrutinib_plasma -> BTK [label="covalent\ninhibition\n(C481S)", color="#0097A7", arrowhead=tee, penwidth=3];

    Venetoclax_central -> Venetoclax_peripheral [label="distribution", color="#00838F", style=dashed];
    Venetoclax_central -> BCL2 [label="BH3-mimetic\ninhibition", color="#0097A7", arrowhead=tee, penwidth=3];

    PolaVedotin_ADC -> CD79B [label="binds CD79B\n(ADC)", color="#00838F", arrowhead=tee, penwidth=2];
    PolaVedotin_ADC -> PolaVedotin_payload [label="internalize/\ncleave", color="#00838F"];
    PolaVedotin_payload -> Proliferation [label="MMAE:\nmicrotubule\npoison", color="#0097A7", arrowhead=tee, penwidth=2];

    RCHOP_cytotoxic -> DNA_repair [label="DNA damage\n(Cy/Dox)", color="#006064", arrowhead=tee, penwidth=3];
    RCHOP_cytotoxic -> Proliferation [label="antiproliferative\n(Vincristine)", color="#006064", arrowhead=tee, penwidth=2];
    RCHOP_cytotoxic -> Apoptosis_out [label="triggers\napoptosis", color="#006064", penwidth=2];

    Lenalidomide_plasma -> IRF4 [label="IKZF1/3\ndegradation\n→ IRF4 loss", color="#00838F", arrowhead=tee, penwidth=2];
    Lenalidomide_plasma -> Proliferation [label="anti-proliferative\n(CRBN-mediated)", color="#00838F", arrowhead=tee];

    Tafasitamab_plasma -> ADCC [label="anti-CD19\nADCC/ADCP", color="#00838F", penwidth=2];
    Selinexor_plasma -> XPO1 [label="XPO1 inhibition\n(SINE)", color="#0097A7", arrowhead=tee, penwidth=2];

    // =========================================================
    // EDGES: Clinical Endpoints & Biomarkers
    // =========================================================
    Proliferation -> Ki67 [label="correlates", color="#827717", style=dashed];
    Proliferation -> LDH_level [label="elevates", color="#827717", style=dashed];
    Apoptosis_out -> CR_response [label="tumor reduction\n→ CR", color="#827717", penwidth=2];
    Apoptosis_out -> PR_response [label="partial\nreduction", color="#827717"];
    G1_S_checkpoint -> PFS_curve [label="mediates\nresponse", color="#827717", style=dashed];
    CR_response -> PFS_curve [label="improves", color="#827717", penwidth=2];
    CR_response -> OS_curve [label="improves", color="#827717", penwidth=2];
    PR_response -> PFS_curve [label="partial benefit", color="#827717"];
    PD_response -> OS_curve [label="worsens", color="#827717", arrowhead=tee];
    IPI_score -> OS_curve [label="predicts", color="#827717", penwidth=2];
    LDH_level -> IPI_score [label="component\nof IPI", color="#827717"];
    BulkyDisease -> IPI_score [label="contributes", color="#827717"];
    Extranodal -> IPI_score [label="contributes", color="#827717"];
    BoneMarrow_inv -> IPI_score [label="contributes", color="#827717"];
    ECOG_PS -> IPI_score [label="component\nof IPI", color="#827717"];
    PET_CT -> CR_response [label="Deauville 1-2\n= CR", color="#827717", penwidth=2];
    PET_CT -> PD_response [label="Deauville 4-5\n= PD", color="#827717"];
    COO_subtype -> IPI_score [label="molecular\nstratification", color="#827717", style=dashed];
    DH_status -> OS_curve [label="poor prognosis\n(DH/TH)", color="#827717", penwidth=2, arrowhead=tee];
    MYC_trans -> DH_status [label="defines\nDH if + BCL2", color="#827717", penwidth=2];
    BCL2_trans -> DH_status [label="defines\nDH", color="#827717", penwidth=2];

    // =========================================================
    // CROSS-CLUSTER KEY EDGES
    // =========================================================
    // BCR → PI3K cross-talk
    BCR -> PI3Kdelta [label="activates\n(via adapters)", color="#555555", style=dashed];
    SYK -> PI3Kdelta [label="activates", color="#555555"];

    // BCR/NFkB → GC
    NFkB_p65 -> BCL6 [label="regulates\n(complex)", color="#555555", style=dashed];
    IRF4 -> MYC [label="transcribes", color="#555555", penwidth=2];
    BCL6 -> MYC [label="represses\n(in GC)", color="#555555", arrowhead=tee];

    // AKT → Apoptosis
    AKT -> BIM [label="phosphorylates\n(degrades)", color="#555555", arrowhead=tee, penwidth=2];
    AKT -> MDM2 [label="activates\n(phospho)", color="#555555", penwidth=2];

    // GC → TME
    GCBC -> PDL1 [label="upregulates", color="#555555", penwidth=2];
    GCBC -> IL10 [label="secretes", color="#555555"];

    // TP53 → Apoptosis
    TP53 -> BIM [label="transcribes", color="#555555"];
    TP53 -> NOXA [label="transcribes", color="#555555"];

    // Cytokines → Survival
    STAT3 -> Survivin [label="transcribes", color="#555555"];
    IL6 -> MCL1 [label="induces via\nSTAT3", color="#555555", style=dashed];

    // Epigenetics → GC
    EZH2 -> GCBC [label="epigenetic\nregulation", color="#555555", style=dashed];
    EZH2_mut -> GCBC [label="GCB-DLBCL\ndrives GC", color="#555555", penwidth=2, style=dashed];
    CREBBP -> BCL6 [label="acetylates\n(modulates)", color="#555555"];

    // MYC → cell cycle
    MYC -> CyclinD1 [label="transcribes", color="#555555", penwidth=2];
    MYC -> CDK4 [label="activates", color="#555555"];

    // NF-kB → DNA repair
    NFkB_p65 -> DNA_repair [label="survival\nsignaling", color="#555555", style=dashed];

    // TME cytokines → NFkB
    TNFalpha -> NFkB_p65 [label="activates", color="#555555", penwidth=2];

    // Drug effects on TME
    Rituximab_central -> PDL1 [label="reduces\n(CD20 loss→PDL1↑)", color="#009688", style=dashed];
    Lenalidomide_plasma -> NK_cell [label="activates\n(immunomodulatory)", color="#009688", penwidth=2];
    Lenalidomide_plasma -> CD8_CTL [label="activates\n(IMiD effect)", color="#009688"];

    // Biomarker links
    BCL2_mut -> COO_subtype [label="GCB subtype\nmarker", color="#827717", style=dashed];
    EZH2_mut -> COO_subtype [label="GCB marker", color="#827717", style=dashed];
    MYD88_mut -> COO_subtype [label="ABC marker", color="#827717", style=dashed];
    CD79B_mut -> COO_subtype [label="ABC marker", color="#827717", style=dashed];

    // XPO1 → TP53 nuclear function
    Selinexor_plasma -> TP53 [label="retains in\nnucleus (via XPO1)", color="#009688", penwidth=2];
}
