// ============================================================
// Peptic Ulcer Disease (PUD) — QSP Mechanistic Map
// Quantitative Systems Pharmacology Model
// Generated: 2026-06-19
// Nodes: 130+  |  Clusters: 9
// ============================================================

digraph PUD_QSP {

    // ── Global graph settings ──────────────────────────────
    rankdir=LR;
    splines=line;
    fontname="Helvetica";
    fontsize=9;
    compound=true;
    nodesep=0.35;
    ranksep=0.8;
    graph [bgcolor="#FAFAFA", pad=0.5];

    // ── Default node style ─────────────────────────────────
    node [shape=box, style=filled, fontsize=8, fontname="Helvetica",
          fillcolor="#FDFEFE", color="#555555", margin="0.08,0.05"];

    // ── Default edge style ─────────────────────────────────
    edge [fontsize=7, fontname="Helvetica", color="#444444",
          arrowsize=0.7];

    // ===========================================================
    // CLUSTER 1 — H. pylori Pathogenesis
    // ===========================================================
    subgraph cluster_hp {
        label="H. pylori Pathogenesis";
        style=filled;
        fillcolor="#FFF5EE";
        color="#C0392B";
        fontsize=10;
        fontcolor="#C0392B";
        fontname="Helvetica-Bold";

        // Bacterial / pathogen nodes — light coral
        HP             [label="H. pylori\n(HP bacteria)", fillcolor="#FDEBD0", shape=box];
        CagA           [label="CagA\n(oncoprotein)", fillcolor="#FDEBD0"];
        VacA           [label="VacA\n(vacuolating cytotoxin)", fillcolor="#FDEBD0"];
        OipA           [label="OipA\n(outer inflammatory protein)", fillcolor="#FDEBD0"];
        BabA           [label="BabA\n(blood group antigen binding)", fillcolor="#FDEBD0"];
        UreaseHP       [label="Urease\n(HP enzyme)", fillcolor="#FDEBD0"];
        LPS_HP         [label="LPS_HP\n(lipopolysaccharide)", fillcolor="#FDEBD0"];
        OMVs           [label="OMVs\n(outer membrane vesicles)", fillcolor="#FDEBD0"];
        HP_colonization [label="HP_colonization", fillcolor="#FDEBD0"];
        HP_biofilm     [label="HP_biofilm", fillcolor="#FDEBD0"];
        NH3_production [label="NH3_production\n(ammonia)", fillcolor="#FDEBD0"];
        CO2_buffering  [label="CO2_buffering", fillcolor="#FDEBD0"];
        HP_motility    [label="HP_motility\n(flagella)", fillcolor="#FDEBD0"];
        HP_adhesion    [label="HP_adhesion\n(mucus penetration)", fillcolor="#FDEBD0"];
        CagPAI         [label="CagPAI\n(Cag pathogenicity island)", fillcolor="#FDEBD0"];
        T4SS           [label="T4SS\n(Type IV secretion system)", fillcolor="#FDEBD0"];
        HP_eradication_status [label="HP_eradication_status", fillcolor="#FDEBD0"];
        BabA_LeB_binding [label="BabA_LeB_binding\n(Lewis b antigen)", fillcolor="#FDEBD0"];
        HP_density     [label="HP_density\n(bacterial load)", fillcolor="#FDEBD0"];
        Apoptosis_epithelial [label="Apoptosis_epithelial", fillcolor="#FDEBD0"];
        Mitochondria_damage  [label="Mitochondria_damage", fillcolor="#FDEBD0"];
    }

    // ===========================================================
    // CLUSTER 2 — Gastric Acid Secretion
    // ===========================================================
    subgraph cluster_acid {
        label="Gastric Acid Secretion";
        style=filled;
        fillcolor="#EAF2FF";
        color="#1A5276";
        fontsize=10;
        fontcolor="#1A5276";
        fontname="Helvetica-Bold";

        ParietalCell   [label="ParietalCell\n(oxyntic cell)", fillcolor="#D7BDE2"];
        H2R            [label="H2R\n(histamine H2 receptor)", fillcolor="#A9DFBF", shape=box];
        M3R            [label="M3R\n(muscarinic M3 receptor)", fillcolor="#A9DFBF"];
        CCK2R          [label="CCK2R\n(gastrin/CCK-B receptor)", fillcolor="#A9DFBF"];
        HKATPase       [label="H+/K+-ATPase\n(proton pump)", fillcolor="#A9DFBF"];
        HCl_secretion  [label="HCl_secretion\n(mEq/hr)", fillcolor="#FAD7A0", shape=ellipse];
        GCell          [label="GCell\n(gastrin G-cell)", fillcolor="#D7BDE2"];
        Gastrin        [label="Gastrin\n(G-17/G-34)", fillcolor="#FAD7A0", shape=ellipse];
        ECLCell        [label="ECLCell\n(enterochromaffin-like)", fillcolor="#D7BDE2"];
        Histamine_ECL  [label="Histamine_ECL\n(paracrine)", fillcolor="#FAD7A0", shape=ellipse];
        D_Cell         [label="D_Cell\n(somatostatin D-cell)", fillcolor="#D7BDE2"];
        Somatostatin   [label="Somatostatin\n(SST-14/28)", fillcolor="#FAD7A0", shape=ellipse];
        ACh_parietal   [label="ACh_parietal\n(vagal stimulation)", fillcolor="#FAD7A0", shape=ellipse];
        pH_lumen       [label="pH_lumen\n(intragastric pH)", fillcolor="#FAD7A0", shape=ellipse];
        Acid_output_total [label="Acid_output_total\n(BAO/MAO mmol/hr)", fillcolor="#FAD7A0", shape=ellipse];
        Pepsin_activation [label="Pepsin_activation\n(pepsinogen→pepsin)", fillcolor="#FAD7A0", shape=ellipse];
        cAMP_parietal  [label="cAMP_parietal\n(2nd messenger)", fillcolor="#FAD7A0", shape=ellipse];
        PKA_parietal   [label="PKA_parietal\n(protein kinase A)", fillcolor="#FAD7A0", shape=ellipse];
        IP3_parietal   [label="IP3_parietal\n(inositol triphosphate)", fillcolor="#FAD7A0", shape=ellipse];
        Ca2_parietal   [label="Ca2+_parietal\n(intracellular Ca2+)", fillcolor="#FAD7A0", shape=ellipse];
        COX2_inflammation [label="COX2_inflammation\n(inducible COX-2)", fillcolor="#FAD7A0", shape=ellipse];
    }

    // ===========================================================
    // CLUSTER 3 — Mucosal Defense
    // ===========================================================
    subgraph cluster_mucosa {
        label="Mucosal Defense Mechanisms";
        style=filled;
        fillcolor="#EAFAF1";
        color="#1E8449";
        fontsize=10;
        fontcolor="#1E8449";
        fontname="Helvetica-Bold";

        MucusLayer     [label="MucusLayer\n(gel-forming)", fillcolor="#A9DFBF"];
        MUC5AC         [label="MUC5AC\n(gastric mucin)", fillcolor="#A9DFBF"];
        MUC5B          [label="MUC5B\n(mucin glycoprotein)", fillcolor="#A9DFBF"];
        Bicarbonate_secretion [label="Bicarbonate_secretion\n(HCO3- mmol/hr)", fillcolor="#A9DFBF"];
        TrefoilFactor1 [label="TrefoilFactor1\n(TFF1)", fillcolor="#FAD7A0", shape=ellipse];
        TrefoilFactor2 [label="TrefoilFactor2\n(TFF2)", fillcolor="#FAD7A0", shape=ellipse];
        EGF_mucosa     [label="EGF_mucosa\n(epidermal growth factor)", fillcolor="#FAD7A0", shape=ellipse];
        EGFR_mucosa    [label="EGFR_mucosa\n(EGF receptor)", fillcolor="#A9DFBF"];
        PGE2_mucosa    [label="PGE2_mucosa\n(prostaglandin E2)", fillcolor="#FAD7A0", shape=ellipse];
        PGI2_mucosa    [label="PGI2_mucosa\n(prostacyclin)", fillcolor="#FAD7A0", shape=ellipse];
        COX1_constitutive [label="COX1_constitutive\n(housekeeping COX-1)", fillcolor="#A9DFBF"];
        EP2R           [label="EP2R\n(PGE2 receptor EP2)", fillcolor="#A9DFBF"];
        EP4R           [label="EP4R\n(PGE2 receptor EP4)", fillcolor="#A9DFBF"];
        MucosalBloodFlow [label="MucosalBloodFlow\n(submucosal BF)", fillcolor="#FAD7A0", shape=ellipse];
        EpithelialTurnover [label="EpithelialTurnover\n(cell renewal rate)", fillcolor="#A9DFBF"];
        TightJunctions [label="TightJunctions\n(barrier integrity)", fillcolor="#A9DFBF"];
        Restitution_rapid [label="Restitution_rapid\n(cell migration)", fillcolor="#A9DFBF"];
        MucusThickness [label="MucusThickness\n(μm gel layer)", fillcolor="#A9DFBF"];
        AquaporinChannel [label="AquaporinChannel\n(AQP3/AQP4)", fillcolor="#A9DFBF"];
        SurfactantPhospholipids [label="SurfactantPhospholipids\n(luminal surface coat)", fillcolor="#A9DFBF"];
    }

    // ===========================================================
    // CLUSTER 4 — Inflammation & Immune Response
    // ===========================================================
    subgraph cluster_inflammation {
        label="Inflammation & Immune Response";
        style=filled;
        fillcolor="#FEF9E7";
        color="#7D6608";
        fontsize=10;
        fontcolor="#7D6608";
        fontname="Helvetica-Bold";

        IL1beta        [label="IL-1β\n(pro-inflammatory)", fillcolor="#FAD7A0", shape=ellipse];
        IL6            [label="IL-6\n(acute phase)", fillcolor="#FAD7A0", shape=ellipse];
        IL8            [label="IL-8 / CXCL8\n(neutrophil chemoattractant)", fillcolor="#FAD7A0", shape=ellipse];
        IL10           [label="IL-10\n(anti-inflammatory)", fillcolor="#FAD7A0", shape=ellipse];
        IL17A          [label="IL-17A\n(mucosal immunity)", fillcolor="#FAD7A0", shape=ellipse];
        TNFalpha       [label="TNF-α\n(necrosis factor)", fillcolor="#FAD7A0", shape=ellipse];
        IFNgamma       [label="IFN-γ\n(type II interferon)", fillcolor="#FAD7A0", shape=ellipse];
        NFkB_signaling [label="NF-κB signaling\n(master regulator)", fillcolor="#FAD7A0", shape=ellipse];
        Neutrophil_infiltration [label="Neutrophil_infiltration\n(PMN recruitment)", fillcolor="#D7BDE2"];
        Macrophage_M1  [label="Macrophage_M1\n(pro-inflammatory)", fillcolor="#D7BDE2"];
        Macrophage_M2  [label="Macrophage_M2\n(anti-inflammatory)", fillcolor="#D7BDE2"];
        Th1_response   [label="Th1_response\n(cell-mediated immunity)", fillcolor="#D7BDE2"];
        Th17_response  [label="Th17_response\n(mucosal defense)", fillcolor="#D7BDE2"];
        Treg_cells     [label="Treg_cells\n(immune tolerance)", fillcolor="#D7BDE2"];
        ROS_production [label="ROS_production\n(oxidative burst)", fillcolor="#FAD7A0", shape=ellipse];
        iNOS_activity  [label="iNOS_activity\n(inducible NOS)", fillcolor="#FAD7A0", shape=ellipse];
        NO_toxic       [label="NO_toxic\n(peroxynitrite)", fillcolor="#FAD7A0", shape=ellipse];
        NLRP3_inflammasome [label="NLRP3_inflammasome\n(IL-1β processing)", fillcolor="#FAD7A0", shape=ellipse];
        Mast_cell_degranulation [label="Mast_cell_degranulation\n(histamine release)", fillcolor="#D7BDE2"];
        LTB4           [label="LTB4\n(leukotriene B4)", fillcolor="#FAD7A0", shape=ellipse];
        MMP3           [label="MMP-3\n(matrix metalloproteinase)", fillcolor="#FAD7A0", shape=ellipse];
        CXCL1          [label="CXCL1\n(KC/GRO-α chemokine)", fillcolor="#FAD7A0", shape=ellipse];
        HP_specific_IgA [label="HP_specific_IgA\n(mucosal antibody)", fillcolor="#D7BDE2"];
        HP_specific_IgG [label="HP_specific_IgG\n(systemic antibody)", fillcolor="#D7BDE2"];
    }

    // ===========================================================
    // CLUSTER 5 — Ulcer Formation & Healing
    // ===========================================================
    subgraph cluster_ulcer {
        label="Ulcer Formation & Healing";
        style=filled;
        fillcolor="#FDEDEC";
        color="#922B21";
        fontsize=10;
        fontcolor="#922B21";
        fontname="Helvetica-Bold";

        MucosalDamage_score  [label="MucosalDamage_score\n(modified Lanza score)", fillcolor="#FAD7A0", shape=ellipse];
        ErosionDepth         [label="ErosionDepth\n(mucosal layer loss)", fillcolor="#FAD7A0", shape=ellipse];
        UlcerArea            [label="UlcerArea\n(mm² planimetry)", fillcolor="#FAD7A0", shape=ellipse];
        UlcerDepth           [label="UlcerDepth\n(muscularis invasion)", fillcolor="#FAD7A0", shape=ellipse];
        GranulationTissue_formation [label="GranulationTissue\n_formation", fillcolor="#A9DFBF"];
        Fibroblast_proliferation    [label="Fibroblast_proliferation\n(stromal repair)", fillcolor="#D7BDE2"];
        Collagen_deposition  [label="Collagen_deposition\n(type I/III ECM)", fillcolor="#A9DFBF"];
        VEGF_angiogenesis    [label="VEGF_angiogenesis\n(neovascularization)", fillcolor="#FAD7A0", shape=ellipse];
        EGF_healing          [label="EGF_healing\n(ulcer margin EGF)", fillcolor="#FAD7A0", shape=ellipse];
        TGFbeta1_healing     [label="TGF-β1_healing\n(anti-inflammatory repair)", fillcolor="#FAD7A0", shape=ellipse];
        UlcerHealing_rate    [label="UlcerHealing_rate\n(mm²/week)", fillcolor="#FAD7A0", shape=ellipse];
        UlcerRecurrence_risk [label="UlcerRecurrence_risk\n(%/year)", fillcolor="#F1948A", shape=diamond];
        Bleeding_risk        [label="Bleeding_risk\n(Forrest classification)", fillcolor="#F1948A", shape=diamond];
        Perforation_risk     [label="Perforation_risk\n(catastrophic)", fillcolor="#F1948A", shape=diamond];
        HGF_healing          [label="HGF_healing\n(hepatocyte GF)", fillcolor="#FAD7A0", shape=ellipse];
        FGF2_healing         [label="FGF2_healing\n(fibroblast GF basic)", fillcolor="#FAD7A0", shape=ellipse];
        Reepithelialization  [label="Reepithelialization\n(surface coverage)", fillcolor="#A9DFBF"];
    }

    // ===========================================================
    // CLUSTER 6 — Neural & Hormonal Regulation
    // ===========================================================
    subgraph cluster_neural {
        label="Neural & Hormonal Regulation";
        style=filled;
        fillcolor="#F4ECF7";
        color="#6C3483";
        fontsize=10;
        fontcolor="#6C3483";
        fontname="Helvetica-Bold";

        VagusNerve_stimulation [label="VagusNerve\n(cephalic phase)", fillcolor="#D7BDE2"];
        ACh_neural             [label="ACh_neural\n(myenteric plexus)", fillcolor="#FAD7A0", shape=ellipse];
        GRP                    [label="GRP\n(gastrin-releasing peptide)", fillcolor="#FAD7A0", shape=ellipse];
        VIP                    [label="VIP\n(vasoactive intestinal peptide)", fillcolor="#FAD7A0", shape=ellipse];
        SubstanceP             [label="Substance P\n(nociceptive peptide)", fillcolor="#FAD7A0", shape=ellipse];
        CGRP                   [label="CGRP\n(calcitonin gene-related)", fillcolor="#FAD7A0", shape=ellipse];
        Serotonin_5HT          [label="Serotonin_5HT\n(5-HT mucosal)", fillcolor="#FAD7A0", shape=ellipse];
        NPY                    [label="NPY\n(neuropeptide Y)", fillcolor="#FAD7A0", shape=ellipse];
        EnterochromaffinCell   [label="EnterochromaffinCell\n(5-HT producing)", fillcolor="#D7BDE2"];
        CCK                    [label="CCK\n(cholecystokinin)", fillcolor="#FAD7A0", shape=ellipse];
        Motilin                [label="Motilin\n(gastric motility)", fillcolor="#FAD7A0", shape=ellipse];
        GLP1                   [label="GLP-1\n(incretin hormone)", fillcolor="#FAD7A0", shape=ellipse];
        Ghrelin                [label="Ghrelin\n(hunger hormone)", fillcolor="#FAD7A0", shape=ellipse];
        SecretinHormone        [label="Secretin\n(S-cell hormone)", fillcolor="#FAD7A0", shape=ellipse];
        SomatostatinNeural     [label="Somatostatin_Neural\n(enteric inhibition)", fillcolor="#FAD7A0", shape=ellipse];
    }

    // ===========================================================
    // CLUSTER 7 — Drug Pharmacokinetics
    // ===========================================================
    subgraph cluster_drug_pk {
        label="Drug Pharmacokinetics";
        style=filled;
        fillcolor="#EBF5FB";
        color="#1F618D";
        fontsize=10;
        fontcolor="#1F618D";
        fontname="Helvetica-Bold";

        // PPI — light blue drug nodes
        PPI_dose              [label="PPI_dose\n(omeprazole 20–40 mg\nesomeprazole 20–40 mg)", fillcolor="#AED6F1"];
        PPI_gut_absorption    [label="PPI_gut_absorption\n(enteric-coated F~50%)", fillcolor="#AED6F1"];
        PPI_plasma_C          [label="PPI_plasma_C\n(Cmax μg/mL)", fillcolor="#AED6F1"];
        PPI_peripheral_dist   [label="PPI_peripheral_dist\n(Vd ~0.3 L/kg)", fillcolor="#AED6F1"];
        PPI_CYP2C19_metabolism [label="PPI_CYP2C19\n(major CYP pathway)", fillcolor="#AED6F1"];
        PPI_CYP3A4_metabolism  [label="PPI_CYP3A4\n(minor CYP pathway)", fillcolor="#AED6F1"];
        PPI_active_form       [label="PPI_active_form\n(sulfenamide/sulfenic acid)", fillcolor="#AED6F1"];

        // H2 blocker
        H2B_dose              [label="H2B_dose\n(famotidine 20–40 mg\nranitidine 150–300 mg)", fillcolor="#AED6F1"];
        H2B_plasma_C          [label="H2B_plasma_C\n(Cmax ng/mL)", fillcolor="#AED6F1"];
        H2B_renal_clearance   [label="H2B_renal_clearance\n(CLr mL/min/kg)", fillcolor="#AED6F1"];

        // Antibiotics
        AMX_dose              [label="AMX_dose\n(amoxicillin 1g BID)", fillcolor="#AED6F1"];
        AMX_plasma_C          [label="AMX_plasma_C\n(Cmax μg/mL)", fillcolor="#AED6F1"];
        CLR_dose              [label="CLR_dose\n(clarithromycin 500mg BID)", fillcolor="#AED6F1"];
        CLR_plasma_C          [label="CLR_plasma_C\n(Cmax μg/mL)", fillcolor="#AED6F1"];
        MTZ_dose              [label="MTZ_dose\n(metronidazole 500mg TID)", fillcolor="#AED6F1"];
        MTZ_plasma_C          [label="MTZ_plasma_C\n(Cmax μg/mL)", fillcolor="#AED6F1"];
        MTZ_active_metabolite [label="MTZ_active_metabolite\n(hydroxyl-MTZ)", fillcolor="#AED6F1"];

        // NSAIDs
        NSAID_dose            [label="NSAID_dose\n(ibuprofen/naproxen/ASA)", fillcolor="#AED6F1"];
        NSAID_plasma_C        [label="NSAID_plasma_C\n(free fraction Cmax)", fillcolor="#AED6F1"];
        NSAID_enterohepatic_recirculation [label="NSAID_enterohepatic\n_recirculation", fillcolor="#AED6F1"];

        // Gastroprotectives
        Antacid_dose          [label="Antacid_dose\n(Al/Mg hydroxide)", fillcolor="#AED6F1"];
        Sucralfate_dose       [label="Sucralfate_dose\n(Al sucrose sulfate 1g QID)", fillcolor="#AED6F1"];
        Bismuth_dose          [label="Bismuth_dose\n(bismuth subcitrate 120mg QID)", fillcolor="#AED6F1"];
    }

    // ===========================================================
    // CLUSTER 8 — Drug Pharmacodynamics
    // ===========================================================
    subgraph cluster_drug_pd {
        label="Drug Pharmacodynamics";
        style=filled;
        fillcolor="#FDFEFE";
        color="#117A65";
        fontsize=10;
        fontcolor="#117A65";
        fontname="Helvetica-Bold";

        PPI_acidActivation        [label="PPI_acidActivation\n(pH<4 activation req.)", fillcolor="#AED6F1"];
        PPI_pump_covalent_binding [label="PPI_pump_covalent\n_binding (Cys813/822)", fillcolor="#AED6F1"];
        PPI_inhibition_pct        [label="PPI_inhibition_pct\n(Emax ~95% @ 40mg)", fillcolor="#AED6F1"];
        PPI_new_pump_synthesis    [label="PPI_new_pump_synthesis\n(de novo turnover ~18h)", fillcolor="#AED6F1"];
        H2B_H2R_competitive_binding [label="H2B_H2R_competitive\n_binding (Ki nM)", fillcolor="#AED6F1"];
        H2B_inhibition_pct        [label="H2B_inhibition_pct\n(max ~70% suppression)", fillcolor="#AED6F1"];
        AMX_HP_kill_rate          [label="AMX_HP_kill_rate\n(MIC 0.06–0.12 μg/mL)", fillcolor="#AED6F1"];
        CLR_HP_kill_rate          [label="CLR_HP_kill_rate\n(MIC 0.03–0.5 μg/mL)", fillcolor="#AED6F1"];
        HP_resistance_CLR         [label="HP_resistance_CLR\n(23S rRNA mutation)", fillcolor="#FDEBD0"];
        HP_resistance_MTZ         [label="HP_resistance_MTZ\n(rdxA/frxA mutation)", fillcolor="#FDEBD0"];
        NSAID_COX1_inhibition     [label="NSAID_COX1_inhibition\n(IC50 μM)", fillcolor="#AED6F1"];
        NSAID_COX2_inhibition     [label="NSAID_COX2_inhibition\n(COX-2 selectivity)", fillcolor="#AED6F1"];
        NSAID_PG_reduction        [label="NSAID_PG_reduction\n(PGE2 ↓ 60–80%)", fillcolor="#AED6F1"];
        Antacid_neutralization_capacity [label="Antacid_neutralization\n_capacity (mEq/dose)", fillcolor="#AED6F1"];
        Sucralfate_binding_ulcer   [label="Sucralfate_binding_ulcer\n(cytoprotective coat)", fillcolor="#AED6F1"];
        Bismuth_HP_suppression    [label="Bismuth_HP_suppression\n(urease inhibition)", fillcolor="#AED6F1"];
        Bismuth_cytoprotective    [label="Bismuth_cytoprotective\n(mucus ↑, PG ↑)", fillcolor="#AED6F1"];
        Misoprostol_EP_activation [label="Misoprostol_EP\n_activation (PGE1 analog)", fillcolor="#AED6F1"];
    }

    // ===========================================================
    // CLUSTER 9 — Clinical Endpoints
    // ===========================================================
    subgraph cluster_clinical {
        label="Clinical Endpoints & Outcomes";
        style=filled;
        fillcolor="#FDEDEC";
        color="#78281F";
        fontsize=10;
        fontcolor="#78281F";
        fontname="Helvetica-Bold";

        EpigastricPain_VAS    [label="EpigastricPain_VAS\n(0–10 NRS)", fillcolor="#F1948A", shape=diamond];
        Dyspepsia_score       [label="Dyspepsia_score\n(GSRS subscale)", fillcolor="#F1948A", shape=diamond];
        NauseaVomiting_score  [label="NauseaVomiting_score\n(NVSS)", fillcolor="#F1948A", shape=diamond];
        GI_Bleeding_episode   [label="GI_Bleeding_episode\n(hematemesis/melena)", fillcolor="#F1948A", shape=diamond];
        Hemoglobin_level      [label="Hemoglobin_level\n(g/dL)", fillcolor="#F1948A", shape=diamond];
        Endoscopy_UlcerSize   [label="Endoscopy_UlcerSize\n(mm longest diameter)", fillcolor="#F1948A", shape=diamond];
        HP_eradication_rate   [label="HP_eradication_rate\n(UBT/stool Ag %)", fillcolor="#F1948A", shape=diamond];
        UlcerRecurrence_12mo  [label="UlcerRecurrence_12mo\n(%)", fillcolor="#F1948A", shape=diamond];
        QoL_SF36              [label="QoL_SF36\n(health-related QoL)", fillcolor="#F1948A", shape=diamond];
        NSAID_gastropathy_risk [label="NSAID_gastropathy_risk\n(modified ARAMIS)", fillcolor="#F1948A", shape=diamond];
        AnemiaSeverity        [label="AnemiaSeverity\n(WHO grading)", fillcolor="#F1948A", shape=diamond];
        Hospitalization_risk  [label="Hospitalization_risk\n(per 1000 PY)", fillcolor="#F1948A", shape=diamond];
    }

    // ===========================================================
    // EDGES — H. pylori Pathogenesis (cluster_hp internal)
    // ===========================================================

    // HP main virulence factor outputs
    HP -> CagA        [label="secretes", color="#C0392B"];
    HP -> VacA        [label="secretes", color="#C0392B"];
    HP -> OipA        [label="expresses", color="#C0392B"];
    HP -> BabA        [label="expresses", color="#C0392B"];
    HP -> UreaseHP    [label="produces", color="#C0392B"];
    HP -> LPS_HP      [label="displays", color="#C0392B"];
    HP -> HP_motility [label="flagella", color="#C0392B"];
    HP -> OMVs        [label="releases", color="#C0392B"];
    HP -> HP_colonization [label="establishes", color="#C0392B"];
    HP -> HP_biofilm  [label="forms", color="#C0392B"];

    CagPAI -> T4SS    [label="encodes"];
    T4SS -> CagA      [label="injects into host", style=bold, color="#922B21"];
    BabA -> BabA_LeB_binding [label="mediates"];
    BabA_LeB_binding -> HP_adhesion [label="enables"];
    HP_adhesion -> HP_colonization [label="stabilizes"];
    HP_motility -> HP_adhesion [label="supports"];
    HP_colonization -> HP_density [label="determines"];
    HP_density -> HP_eradication_status [label="drives"];
    HP_biofilm -> HP_density [label="protects", style=dashed];

    UreaseHP -> NH3_production [label="catalyzes"];
    UreaseHP -> CO2_buffering  [label="CO2+H2O"];
    NH3_production -> pH_lumen [label="raises local pH", color="#1A5276", style=dashed];

    // HP virulence → inflammation
    CagA -> NFkB_signaling [label="activates", color="#7D6608", style=bold];
    CagA -> IL8            [label="induces", color="#7D6608"];
    CagA -> IL1beta        [label="promotes", color="#7D6608"];
    OipA -> IL8            [label="upregulates", color="#7D6608"];
    LPS_HP -> NFkB_signaling [label="TLR4/TLR2", color="#7D6608"];
    OMVs -> NFkB_signaling   [label="TLR activation", color="#7D6608"];
    VacA -> Apoptosis_epithelial [label="induces pores", color="#922B21"];
    VacA -> TightJunctions   [label="disrupts", color="#922B21", arrowhead=tee];
    VacA -> Mitochondria_damage [label="depolarizes", color="#922B21"];
    Mitochondria_damage -> ROS_production [label="mitochondrial ROS", color="#7D6608"];
    Apoptosis_epithelial -> MucosalDamage_score [label="cell loss", color="#922B21"];
    Mitochondria_damage -> MucosalDamage_score  [label="contributes", color="#922B21"];

    // Immune feedback on HP
    HP_specific_IgA -> HP_colonization [label="opsonization", arrowhead=tee, style=dashed, color="#1E8449"];
    HP_specific_IgG -> HP_colonization [label="ADCC/complement", arrowhead=tee, style=dashed, color="#1E8449"];
    HP_specific_IgA -> HP_eradication_status [label="marker"];
    HP_specific_IgG -> HP_eradication_status [label="serology marker"];

    // ===========================================================
    // EDGES — Gastric Acid Secretion
    // ===========================================================

    // Stimulatory signaling cascade
    GCell -> Gastrin           [label="secretes"];
    Gastrin -> ECLCell         [label="CCK2R stimulation", style=bold];
    Gastrin -> CCK2R           [label="binds"];
    CCK2R -> HKATPase          [label="IP3/Ca2+ pathway"];
    ECLCell -> Histamine_ECL   [label="releases"];
    Histamine_ECL -> H2R       [label="binds", style=bold];
    H2R -> cAMP_parietal       [label="Gs/adenylyl cyclase"];
    cAMP_parietal -> PKA_parietal [label="activates"];
    PKA_parietal -> HKATPase   [label="phosphorylates/\ntraffics to canaliculus", style=bold];
    HKATPase -> HCl_secretion  [label="H+ secretion\n(Vmax Km kinetics)", style=bold, color="#1A5276"];
    HCl_secretion -> pH_lumen  [label="lowers pH", style=bold, color="#1A5276"];
    pH_lumen -> Acid_output_total [label="determines BAO/MAO"];
    pH_lumen -> Pepsin_activation [label="pH<4 activates pepsinogen"];

    // Muscarinic pathway
    ACh_parietal -> M3R        [label="binds"];
    M3R -> IP3_parietal        [label="Gq/PLC pathway"];
    M3R -> Ca2_parietal        [label="releases ER Ca2+"];
    IP3_parietal -> Ca2_parietal [label="releases"];
    Ca2_parietal -> HKATPase   [label="CaM kinase II"];

    // Neural → GCell → Gastrin
    VagusNerve_stimulation -> ACh_neural [label="cephalic phase"];
    ACh_neural -> GRP          [label="co-release"];
    GRP -> GCell               [label="paracrine stimulation", style=bold];
    ACh_neural -> ACh_parietal [label="direct innervation"];

    // Somatostatin inhibitory feedback
    D_Cell -> Somatostatin     [label="secretes"];
    Somatostatin -> GCell      [label="inhibits via SSTR2", arrowhead=tee, color="#922B21"];
    Somatostatin -> ECLCell    [label="inhibits", arrowhead=tee, color="#922B21"];
    Somatostatin -> ParietalCell [label="inhibits directly", arrowhead=tee, color="#922B21"];
    pH_lumen -> D_Cell         [label="low pH triggers SST", style=dashed, color="#922B21"];

    // PGE2 inhibition of acid
    PGE2_mucosa -> ParietalCell [label="EP3R inhibits\ncAMP ↓", arrowhead=tee, color="#1E8449", style=dashed];

    // COX-2 inducible
    NFkB_signaling -> COX2_inflammation [label="transcription"];
    COX2_inflammation -> PGE2_mucosa    [label="produces (inducible)", style=dashed];

    // ===========================================================
    // EDGES — Mucosal Defense
    // ===========================================================

    MucusLayer -> MUC5AC       [label="composed of"];
    MucusLayer -> MUC5B        [label="composed of"];
    MUC5AC -> MucusThickness   [label="determines"];
    MUC5B -> MucusThickness    [label="contributes"];
    MucusThickness -> TightJunctions [label="supports barrier", color="#1E8449"];
    Bicarbonate_secretion -> MucusLayer [label="neutralizes H+ in\ngel layer", color="#1E8449"];

    COX1_constitutive -> PGE2_mucosa [label="constitutive synthesis", color="#1E8449", style=bold];
    COX1_constitutive -> PGI2_mucosa [label="constitutive synthesis", color="#1E8449"];
    PGE2_mucosa -> EP2R        [label="activates"];
    PGE2_mucosa -> EP4R        [label="activates"];
    EP2R -> MucosalBloodFlow   [label="vasodilation", color="#1E8449"];
    EP2R -> Bicarbonate_secretion [label="stimulates HCO3-", color="#1E8449"];
    EP4R -> MucusThickness     [label="mucus secretion ↑", color="#1E8449"];
    EP4R -> MucosalBloodFlow   [label="vasodilation", color="#1E8449"];
    PGI2_mucosa -> MucosalBloodFlow [label="prostacyclin\nvasodilation", color="#1E8449"];

    EGF_mucosa -> EGFR_mucosa  [label="ligand binding"];
    EGFR_mucosa -> EpithelialTurnover [label="MAPK/PI3K", color="#1E8449"];
    EGFR_mucosa -> Restitution_rapid  [label="cell migration ↑", color="#1E8449"];
    TrefoilFactor1 -> MucusLayer      [label="stabilizes gel"];
    TrefoilFactor2 -> MucusLayer      [label="stabilizes gel"];
    TrefoilFactor1 -> Restitution_rapid [label="motogenic"];
    SurfactantPhospholipids -> MucusLayer [label="hydrophobic coat"];
    AquaporinChannel -> MucosalBloodFlow  [label="water flux regulation"];

    // ===========================================================
    // EDGES — Inflammation
    // ===========================================================

    NFkB_signaling -> IL1beta  [label="transcribes", color="#7D6608"];
    NFkB_signaling -> IL6      [label="transcribes", color="#7D6608"];
    NFkB_signaling -> IL8      [label="transcribes", color="#7D6608", style=bold];
    NFkB_signaling -> TNFalpha [label="transcribes", color="#7D6608"];
    NFkB_signaling -> IL17A    [label="promotes", color="#7D6608"];
    NFkB_signaling -> iNOS_activity [label="transcribes", color="#7D6608"];

    IL8 -> Neutrophil_infiltration [label="recruits PMN", color="#7D6608", style=bold];
    CXCL1 -> Neutrophil_infiltration [label="recruits PMN", color="#7D6608"];
    Neutrophil_infiltration -> ROS_production [label="respiratory burst", color="#7D6608"];
    Neutrophil_infiltration -> LTB4 [label="5-LOX product"];
    LTB4 -> Neutrophil_infiltration [label="amplifies recruitment", style=dashed];

    iNOS_activity -> NO_toxic  [label="excess NO"];
    NO_toxic -> MucosalDamage_score [label="oxidative damage", color="#922B21"];
    ROS_production -> MucosalDamage_score [label="oxidative damage", color="#922B21", style=bold];
    ROS_production -> MMP3     [label="activates zymogen"];
    MMP3 -> MucosalDamage_score [label="ECM degradation", color="#922B21"];

    IL1beta -> Somatostatin    [label="inhibits D-cell SST", arrowhead=tee, style=dashed, color="#C0392B"];
    IL1beta -> HKATPase        [label="inhibits pump\n(direct)", arrowhead=tee, style=dashed];
    IL6 -> Macrophage_M1       [label="polarizes"];
    TNFalpha -> NFkB_signaling [label="autocrine amplification", style=dashed, color="#7D6608"];
    TNFalpha -> Apoptosis_epithelial [label="TNFR1 signaling"];
    IFNgamma -> Macrophage_M1  [label="activates"];
    IFNgamma -> Th1_response   [label="amplifies"];
    IL10 -> Macrophage_M2      [label="polarizes"];
    IL10 -> NFkB_signaling     [label="suppresses", arrowhead=tee, color="#1E8449"];
    IL17A -> Th17_response     [label="amplifies"];
    IL17A -> CXCL1             [label="induces"];
    Treg_cells -> IL10         [label="secretes", color="#1E8449"];
    Treg_cells -> TGFbeta1_healing [label="secretes", color="#1E8449"];
    Macrophage_M2 -> IL10      [label="secretes", color="#1E8449"];
    Macrophage_M2 -> TGFbeta1_healing [label="secretes", color="#1E8449"];
    Macrophage_M2 -> VEGF_angiogenesis [label="secretes", color="#1E8449"];
    NLRP3_inflammasome -> IL1beta [label="cleaves pro-IL1β", style=bold];
    Mast_cell_degranulation -> Histamine_ECL [label="amplifies histamine pool", style=dashed];
    Mast_cell_degranulation -> LTB4 [label="releases"];
    Th1_response -> IFNgamma   [label="produces"];
    Th17_response -> IL17A     [label="produces"];
    HP_specific_IgA -> Th1_response  [label="coordinates"];
    HP_specific_IgG -> Macrophage_M1 [label="FcγR activation"];

    // ===========================================================
    // EDGES — Ulcer Formation & Healing
    // ===========================================================

    // Damage cascade
    NH3_production -> MucosalDamage_score [label="alkaline disruption", color="#922B21"];
    Pepsin_activation -> MucosalDamage_score [label="proteolysis", color="#922B21", style=bold];
    HCl_secretion -> MucosalDamage_score    [label="acid attack", color="#922B21", style=bold];
    TightJunctions -> MucosalDamage_score   [label="barrier failure → damage", arrowhead=tee, style=dashed, color="#922B21"];
    MucosalDamage_score -> ErosionDepth     [label="progresses to", style=bold];
    ErosionDepth -> UlcerDepth              [label="deepens", style=bold];
    UlcerDepth -> UlcerArea                 [label="expands", style=bold];
    UlcerDepth -> Bleeding_risk             [label="vessel erosion", color="#C0392B"];
    UlcerDepth -> Perforation_risk          [label="full-thickness", color="#C0392B"];
    UlcerArea -> GranulationTissue_formation [label="wound repair trigger"];
    UlcerArea -> UlcerRecurrence_risk       [label="large ulcer → recurrence risk"];

    // Healing cascade
    GranulationTissue_formation -> Fibroblast_proliferation [label="scaffolds", color="#1E8449"];
    GranulationTissue_formation -> VEGF_angiogenesis        [label="hypoxia-driven", color="#1E8449"];
    Fibroblast_proliferation -> Collagen_deposition         [label="ECM synthesis", color="#1E8449"];
    Collagen_deposition -> UlcerHealing_rate                [label="scar formation", color="#1E8449"];
    VEGF_angiogenesis -> MucosalBloodFlow                   [label="angiogenesis ↑", color="#1E8449"];
    MucosalBloodFlow -> UlcerHealing_rate                   [label="O2/nutrient supply", color="#1E8449"];
    EGF_healing -> EGFR_mucosa                              [label="binds receptor"];
    EGFR_mucosa -> Reepithelialization                      [label="drives cell migration"];
    Reepithelialization -> UlcerHealing_rate                [label="surface coverage", color="#1E8449", style=bold];
    TGFbeta1_healing -> Fibroblast_proliferation            [label="TGF-βRI/II signaling"];
    TGFbeta1_healing -> Collagen_deposition                 [label="upregulates Col1A1"];
    HGF_healing -> EGFR_mucosa                              [label="c-Met pathway → EGFR crosstalk"];
    HGF_healing -> Restitution_rapid                        [label="scatter factor", constraint=false];
    FGF2_healing -> Fibroblast_proliferation                [label="FGFR1 mitogenic"];
    FGF2_healing -> VEGF_angiogenesis                       [label="angiogenic synergy"];
    UlcerHealing_rate -> UlcerRecurrence_risk               [label="incomplete healing ↑ risk", arrowhead=tee, color="#1E8449"];

    // ===========================================================
    // EDGES — Neural & Hormonal
    // ===========================================================

    VagusNerve_stimulation -> ACh_neural [label="efferent signal"];
    VagusNerve_stimulation -> SubstanceP [label="co-transmitter"];
    VagusNerve_stimulation -> CGRP       [label="sensory afferent reflex"];
    SubstanceP -> Mast_cell_degranulation [label="NK1R activation", constraint=false];
    SubstanceP -> EpigastricPain_VAS     [label="nociception"];
    CGRP -> MucosalBloodFlow             [label="potent vasodilator", color="#1E8449"];
    CGRP -> EpigastricPain_VAS           [label="pain sensitization"];
    VIP -> MucosalBloodFlow              [label="vasodilation", color="#1E8449"];
    VIP -> Bicarbonate_secretion         [label="stimulates", color="#1E8449"];
    NPY -> MucosalBloodFlow              [label="vasoconstriction", arrowhead=tee];
    EnterochromaffinCell -> Serotonin_5HT [label="releases 5-HT"];
    Serotonin_5HT -> VagusNerve_stimulation [label="5-HT3R activation\n(nausea reflex)", style=dashed];
    Serotonin_5HT -> NauseaVomiting_score   [label="emesis pathway"];
    CCK -> GCell                         [label="gastrin-independent\nIGF signaling", style=dashed];
    CCK -> D_Cell                        [label="stimulates SST release"];
    Ghrelin -> GCell                     [label="GHSR stimulates gastrin"];
    Ghrelin -> VagusNerve_stimulation    [label="orexigenic → vagal tone"];
    Motilin -> Ghrelin                   [label="phase III MMC synergy"];
    GLP1 -> D_Cell                       [label="stimulates SST"];
    GLP1 -> GCell                        [label="inhibits gastrin", arrowhead=tee];
    SecretinHormone -> Bicarbonate_secretion [label="pancreatic/duodenal\nHCO3-"];
    SecretinHormone -> D_Cell            [label="SST co-stimulation"];
    SomatostatinNeural -> GCell          [label="enteric inhibition", arrowhead=tee];
    SomatostatinNeural -> VagusNerve_stimulation [label="presynaptic inhibit", arrowhead=tee, style=dashed];

    // ===========================================================
    // EDGES — Drug PK (within cluster)
    // ===========================================================

    PPI_dose -> PPI_gut_absorption     [label="enteric-coated\nrelease"];
    PPI_gut_absorption -> PPI_plasma_C [label="first-pass ~50%"];
    PPI_plasma_C -> PPI_peripheral_dist [label="Vd distribution"];
    PPI_plasma_C -> PPI_CYP2C19_metabolism [label="primary CYP"];
    PPI_plasma_C -> PPI_CYP3A4_metabolism  [label="minor CYP"];
    PPI_CYP2C19_metabolism -> PPI_active_form [label="protonation\nat pH<4"];
    PPI_active_form -> PPI_acidActivation [label="requires acid"];

    H2B_dose -> H2B_plasma_C          [label="oral bioavailability\n~50%"];
    H2B_plasma_C -> H2B_renal_clearance [label="renal elim."];
    H2B_plasma_C -> H2B_H2R_competitive_binding [label="drives binding"];

    AMX_dose -> AMX_plasma_C          [label="oral F>80%"];
    CLR_dose -> CLR_plasma_C          [label="oral F~50%"];
    MTZ_dose -> MTZ_plasma_C          [label="oral F~100%"];
    MTZ_plasma_C -> MTZ_active_metabolite [label="hepatic reduction"];

    NSAID_dose -> NSAID_plasma_C      [label="GI absorption"];
    NSAID_plasma_C -> NSAID_enterohepatic_recirculation [label="biliary excretion"];
    NSAID_enterohepatic_recirculation -> NSAID_plasma_C [label="reabsorption loop", style=dashed];

    Antacid_dose -> Antacid_neutralization_capacity [label="dose-response"];
    Sucralfate_dose -> Sucralfate_binding_ulcer     [label="acid-activated"];
    Bismuth_dose -> Bismuth_HP_suppression          [label="luminal activity"];
    Bismuth_dose -> Bismuth_cytoprotective          [label="mucus stimulation"];

    // ===========================================================
    // EDGES — Drug PD → Targets
    // ===========================================================

    // PPI mechanism
    PPI_acidActivation -> PPI_pump_covalent_binding [label="sulfenamide forms", style=bold, color="#1F618D"];
    PPI_pump_covalent_binding -> PPI_inhibition_pct [label="irreversible\nCys813/Cys822", style=bold, color="#1F618D"];
    PPI_inhibition_pct -> HKATPase [label="blocks >90%", arrowhead=tee, style=bold, color="#1F618D"];
    PPI_new_pump_synthesis -> HKATPase [label="de novo pump\nreduces inhibition", style=dashed, color="#922B21"];
    HKATPase -> PPI_new_pump_synthesis [label="turnover feedback", style=dashed];

    // H2 blocker mechanism
    H2B_H2R_competitive_binding -> H2B_inhibition_pct [label="occupancy Hill eq."];
    H2B_inhibition_pct -> H2R [label="blocks 60–70%", arrowhead=tee, color="#1F618D"];

    // Antibiotic mechanisms
    AMX_plasma_C -> AMX_HP_kill_rate  [label="T>MIC drives\nbactericidal"];
    CLR_plasma_C -> CLR_HP_kill_rate  [label="AUC/MIC ratio"];
    MTZ_active_metabolite -> HP_density [label="DNA strand break\n→ HP kill", arrowhead=tee, color="#1F618D"];
    AMX_HP_kill_rate -> HP_density    [label="reduces load", arrowhead=tee, style=bold, color="#1F618D"];
    CLR_HP_kill_rate -> HP_density    [label="reduces load", arrowhead=tee, style=bold, color="#1F618D"];
    HP_resistance_CLR -> CLR_HP_kill_rate [label="reduces efficacy", arrowhead=tee, color="#922B21"];
    HP_resistance_MTZ -> MTZ_active_metabolite [label="reduces activation", arrowhead=tee, color="#922B21"];

    // NSAID mechanism
    NSAID_plasma_C -> NSAID_COX1_inhibition [label="topical+systemic\nIC50"];
    NSAID_plasma_C -> NSAID_COX2_inhibition [label="selectivity ratio"];
    NSAID_COX1_inhibition -> COX1_constitutive [label="inhibits", arrowhead=tee, style=bold, color="#922B21"];
    COX1_constitutive -> PGE2_mucosa [label="reduced synthesis", color="#922B21"];
    NSAID_COX1_inhibition -> NSAID_PG_reduction [label="drives"];
    NSAID_PG_reduction -> MucusThickness [label="PG ↓ → mucus ↓", arrowhead=tee, color="#922B21"];
    NSAID_PG_reduction -> Bicarbonate_secretion [label="PG ↓ → HCO3- ↓", arrowhead=tee, color="#922B21"];
    NSAID_PG_reduction -> MucosalBloodFlow [label="PG ↓ → BF ↓", arrowhead=tee, color="#922B21"];

    // Gastroprotective PD
    Antacid_neutralization_capacity -> pH_lumen [label="direct neutralization\n+1–2 pH units", color="#1F618D"];
    Sucralfate_binding_ulcer -> MucusLayer [label="physical barrier\naugments", color="#1F618D"];
    Sucralfate_binding_ulcer -> EGF_healing [label="binds & concentrates\nEGF at ulcer", color="#1F618D"];
    Bismuth_HP_suppression -> HP_density [label="urease inhibition\n→ reduced colonization", arrowhead=tee, color="#1F618D"];
    Bismuth_cytoprotective -> MucusThickness [label="↑ mucus glycoprotein", color="#1F618D"];
    Bismuth_cytoprotective -> PGE2_mucosa    [label="stimulates PGE2", color="#1F618D"];
    Misoprostol_EP_activation -> EP2R        [label="PGE1 agonist", style=bold, color="#1F618D"];
    Misoprostol_EP_activation -> EP4R        [label="PGE1 agonist", style=bold, color="#1F618D"];

    // ===========================================================
    // EDGES — Clinical Outcomes
    // ===========================================================

    EpigastricPain_VAS -> QoL_SF36       [label="major driver"];
    Dyspepsia_score -> QoL_SF36          [label="GI symptom domain"];
    NauseaVomiting_score -> QoL_SF36     [label="symptom burden"];
    pH_lumen -> EpigastricPain_VAS       [label="acid-contact pain"];
    UlcerArea -> EpigastricPain_VAS      [label="ulcer nerve exposure"];
    UlcerArea -> Endoscopy_UlcerSize     [label="endoscopic measure", style=bold];
    Endoscopy_UlcerSize -> HP_eradication_rate [label="baseline size\naffects eradication outcome"];
    HP_eradication_status -> HP_eradication_rate [label="defines success", style=bold];
    HP_density -> HP_eradication_rate    [label="bacterial burden", style=dashed];
    UlcerRecurrence_risk -> UlcerRecurrence_12mo [label="annualized rate"];
    HP_eradication_status -> UlcerRecurrence_risk [label="eradication reduces risk", arrowhead=tee, color="#1E8449", style=bold];
    NSAID_dose -> NSAID_gastropathy_risk [label="dose × duration", style=bold];
    NSAID_PG_reduction -> NSAID_gastropathy_risk [label="PG deficit"];
    Bleeding_risk -> GI_Bleeding_episode [label="risk materializes", style=bold];
    GI_Bleeding_episode -> Hemoglobin_level [label="blood loss ↓ Hb"];
    Hemoglobin_level -> AnemiaSeverity   [label="WHO grade"];
    GI_Bleeding_episode -> Hospitalization_risk [label="major complication"];
    Perforation_risk -> Hospitalization_risk [label="surgical emergency"];
    UlcerDepth -> Bleeding_risk          [label="vessel erosion depth", style=bold];
    NSAID_gastropathy_risk -> Bleeding_risk [label="gastropathy complications"];
    MucosalDamage_score -> Dyspepsia_score [label="symptom correlation"];
    MucosalDamage_score -> NauseaVomiting_score [label="mucosal irritation"];
    UlcerHealing_rate -> Endoscopy_UlcerSize [label="size reduction\nat follow-up endoscopy", arrowhead=tee, color="#1E8449"];
    QoL_SF36 -> Hospitalization_risk     [label="low QoL → care-seeking", style=dashed];

    // ===========================================================
    // CROSS-CLUSTER CONNECTING EDGES
    // ===========================================================

    // HP → Acid: HP suppresses somatostatin → more acid
    HP -> D_Cell [label="suppresses SST\nvia CagA/VacA", arrowhead=tee, color="#C0392B", style=bold];
    IL1beta -> GCell [label="IL-1β inhibits\ngastrin secretion", arrowhead=tee, style=dashed, color="#7D6608"];

    // Acid → Ulcer
    Pepsin_activation -> ErosionDepth [label="enzymatic\nproteolysis", color="#922B21"];

    // Inflammation → Mucosa
    TNFalpha -> EpithelialTurnover [label="increases apoptosis", arrowhead=tee, color="#C0392B"];
    ROS_production -> TightJunctions [label="oxidative\nbarrier damage", arrowhead=tee, color="#C0392B"];
    IL1beta -> COX1_constitutive [label="downregulates", arrowhead=tee, style=dashed];
    IFNgamma -> TightJunctions   [label="JAK-STAT\nclaudin modulation", arrowhead=tee, style=dashed];

    // Mucosa → Ulcer (protection)
    MucusThickness -> MucosalDamage_score [label="mucus barrier\nprotects against", arrowhead=tee, color="#1E8449"];
    Bicarbonate_secretion -> MucosalDamage_score [label="pH neutralization\nprotects", arrowhead=tee, color="#1E8449"];
    MucosalBloodFlow -> MucosalDamage_score [label="O2 supply protects", arrowhead=tee, color="#1E8449"];
    SurfactantPhospholipids -> MucosalDamage_score [label="hydrophobic coat\nprotects", arrowhead=tee, color="#1E8449"];

    // HP → Ulcer (direct)
    HP_density -> MucosalDamage_score [label="bacterial products\ndirect damage", color="#C0392B", style=bold];

    // Neural → Clinical
    SubstanceP -> EpigastricPain_VAS [label="central sensitization"];
    Serotonin_5HT -> Dyspepsia_score [label="motility dysregulation"];

    // Drug PD → Outcomes (efficacy signals)
    PPI_inhibition_pct -> pH_lumen [label="acid suppression\n→ pH raise", color="#1F618D", style=bold];
    H2B_inhibition_pct -> HCl_secretion [label="reduces HCl", arrowhead=tee, color="#1F618D"];
    HP_density -> HP_eradication_status [label="determines\neradication outcome"];
    HP_eradication_status -> UlcerRecurrence_risk [label="primary prevention", arrowhead=tee, style=bold, color="#1F618D"];

    // Ulcer → Neural (pain)
    UlcerArea -> SubstanceP [label="tissue damage\n→ SP release"];
    Bleeding_risk -> SubstanceP [label="hemorrhage pain"];

    // PK → PD cross-links
    CLR_plasma_C -> HP_resistance_CLR [label="sub-MIC exposure\nselects resistant", style=dashed, color="#922B21"];
    MTZ_plasma_C -> HP_resistance_MTZ [label="incomplete exposure\nselects resistant", style=dashed, color="#922B21"];

    // Ulcer healing growth factors → neural
    EGF_mucosa -> EGF_healing [label="systemic + local\nEGF pools"];
    CGRP -> MucosalBloodFlow  [label="sensory nerve\nvasodilation"];

    // Mast cell → Acid amplification
    Mast_cell_degranulation -> Histamine_ECL [label="non-ECL histamine\naugments acid", style=dashed];

    // Correction: NSAID also directly damages mucosa topically
    NSAID_plasma_C -> MucosalDamage_score [label="topical acid\nback-diffusion", style=dashed, color="#922B21"];

}
