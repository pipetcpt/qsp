digraph AS_QSP {
  graph [fontname="Helvetica" fontsize=10 rankdir=TB overlap=prism splines=true
         bgcolor="#FAFAFA" label="Ankylosing Spondylitis (AS) — QSP Mechanistic Map\nTNFi · IL-17Ai · IL-23i · JAKi"
         labelloc=t labeljust=c fontsize=14]
  node  [fontname="Helvetica" fontsize=9 shape=box style="filled,rounded" margin="0.15,0.05"]
  edge  [fontname="Helvetica" fontsize=8 arrowsize=0.7]

  /* ================================================================
     CLUSTER 1: Genetic & Environmental Triggers
  ================================================================ */
  subgraph cluster_genetics {
    label="1. Genetic & Environmental Triggers"
    style=filled fillcolor="#EBF5FB" color="#1A5276"
    fontcolor="#1A5276" fontsize=11 fontname="Helvetica-Bold"

    HLA_B27        [label="HLA-B27\nAllele (risk)" fillcolor="#AED6F1"]
    ERAP1          [label="ERAP1\nPolymorphism" fillcolor="#AED6F1"]
    IL23R_gene     [label="IL-23R\nVariant" fillcolor="#AED6F1"]
    CARD9_gene     [label="CARD9\nVariant" fillcolor="#AED6F1"]
    RUNX3_gene     [label="RUNX3\nVariant" fillcolor="#AED6F1"]
    MechStress     [label="Mechanical\nStress / Micro-trauma" fillcolor="#D5E8D4" shape=diamond]
    MicrobialTrig  [label="Gut / Mucosal\nMicrobial Trigger" fillcolor="#D5E8D4" shape=diamond]
    HLA_homodimer  [label="HLA-B27\nHomodimers (β2m-free)" fillcolor="#85C1E9"]
    ER_stress      [label="ER Stress /\nUPR Activation" fillcolor="#85C1E9"]
    UPR_IL23       [label="UPR → IL-23\nInduction" fillcolor="#85C1E9"]

    HLA_B27       -> ER_stress      [label="misfolding\n(heavy chain)"]
    HLA_B27       -> HLA_homodimer  [label="β2m-free\nhomodimer"]
    ER_stress     -> UPR_IL23       [label="IRE1α/\nXBP1s"]
    ERAP1         -> HLA_B27        [label="peptide\ntrimming"]
    IL23R_gene    -> UPR_IL23       [style=dashed label="risk allele"]
    CARD9_gene    -> MicrobialTrig  [style=dashed]
    RUNX3_gene    -> HLA_B27        [style=dashed label="chromatin\nregulation"]
  }

  /* ================================================================
     CLUSTER 2: Innate Immunity & Enthesis Pathobiology
  ================================================================ */
  subgraph cluster_innate {
    label="2. Innate Immunity & Enthesis Pathobiology"
    style=filled fillcolor="#FEF9E7" color="#B7950B"
    fontcolor="#B7950B" fontsize=11 fontname="Helvetica-Bold"

    Enthesis      [label="Enthesis\n(Primary Lesion Site)" fillcolor="#FAD7A0" shape=octagon]
    FibroCrtlg    [label="Fibrocartilage\n(enthesis)" fillcolor="#FAD7A0"]
    MechDamage    [label="Microdamage /\nFibrocartilage Stress" fillcolor="#FAD7A0"]
    DAMPs         [label="DAMPs\n(HSP60, HMGB1, S100A8/9)" fillcolor="#FDEBD0"]
    TLR_signal    [label="TLR2 / TLR4 / TLR9\nSignaling" fillcolor="#FDEBD0"]
    NF_kB_innate  [label="NF-κB\n(Innate Cell)" fillcolor="#F0B27A"]
    Macrophage    [label="Macrophage\n(M1 activated)" fillcolor="#E59866"]
    DendriticCell [label="Dendritic Cell\n(pDC / cDC1/2)" fillcolor="#E59866"]
    Neutrophil    [label="Neutrophil\nInflux" fillcolor="#E59866"]
    MastCell      [label="Mast Cell\nDegranulation" fillcolor="#E59866"]
    ILC3_innate   [label="ILC3\n(RORγt+ innate lymphoid)" fillcolor="#FDEBD0"]
    IL22_ILC      [label="IL-22\n(ILC3 source)" fillcolor="#FDEBD0"]
    ResidentT     [label="Enthesis-Resident\nγδ / MAIT T cells" fillcolor="#FAD7A0"]
    TNF_innate    [label="TNF-α\n(innate source)" fillcolor="#F1948A"]
    IL1b          [label="IL-1β\n(NLRP3)" fillcolor="#F1948A"]
    IL6_innate    [label="IL-6\n(innate source)" fillcolor="#F1948A"]
    IL23_innate   [label="IL-23\n(DC / macrophage)" fillcolor="#F1948A"]
    NLRP3         [label="NLRP3\nInflammasome" fillcolor="#FDEBD0"]
    ROS           [label="ROS / NET\n(neutrophil)" fillcolor="#FDEBD0"]
    IL18          [label="IL-18\n(co-stimulator)" fillcolor="#F1948A"]

    MechDamage    -> DAMPs
    DAMPs         -> TLR_signal
    TLR_signal    -> NF_kB_innate
    NF_kB_innate  -> TNF_innate
    NF_kB_innate  -> IL6_innate
    NF_kB_innate  -> IL23_innate
    NF_kB_innate  -> NLRP3
    NLRP3         -> IL1b
    NLRP3         -> IL18
    Macrophage    -> TNF_innate    [label="produces"]
    Macrophage    -> IL23_innate   [label="produces"]
    Macrophage    -> IL1b          [label="produces"]
    DendriticCell -> IL23_innate   [label="key source"]
    DendriticCell -> IL12_innate   [label="produces"]
    Neutrophil    -> ROS           [label="respiratory\nburst"]
    MastCell      -> IL1b          [label="degranulation"]
    ILC3_innate   -> IL22_ILC      [label="IL-23 driven"]
    IL23_innate   -> ILC3_innate   [label="activates"]
    ResidentT     -> TNF_innate    [label="produces"]
    ResidentT     -> IL17A_innate  [label="rapid IL-17\nresponse"]
    HLA_homodimer -> ResidentT     [label="KIR3DL2\nactivation" style=dashed]
    UPR_IL23      -> IL23_innate   [label="augments"]
    Enthesis      -> MechDamage    [label="site of\nlesion"]
    FibroCrtlg    -> Enthesis
    MicrobialTrig -> TLR_signal    [label="PAMP"]
    MicrobialTrig -> DendriticCell [label="antigen\npresentation"]

    IL12_innate   [label="IL-12\n(innate source)" fillcolor="#F1948A"]
    IL17A_innate  [label="IL-17A\n(γδ T, fast)" fillcolor="#F1948A"]
  }

  /* ================================================================
     CLUSTER 3: Adaptive Immunity (Th17 / Th1 Axis)
  ================================================================ */
  subgraph cluster_adaptive {
    label="3. Adaptive Immunity — Th17 / Th1 / Treg Axis"
    style=filled fillcolor="#EAF2FF" color="#1F618D"
    fontcolor="#1F618D" fontsize=11 fontname="Helvetica-Bold"

    NaiveCD4      [label="Naive CD4+\nT Cell" fillcolor="#AED6F1"]
    Th17          [label="Th17 Cell\n(RORγt+)" fillcolor="#2E86C1" fontcolor=white]
    Th1           [label="Th1 Cell\n(T-bet+)" fillcolor="#2E86C1" fontcolor=white]
    Treg          [label="Regulatory T Cell\n(Foxp3+)" fillcolor="#85C1E9"]
    CD8_T         [label="CD8+ T Cell\n(HLA-B27 restricted)" fillcolor="#85C1E9"]
    NKcell        [label="NK / NKT Cell\n(activated)" fillcolor="#85C1E9"]
    IL23_adap     [label="IL-23\n(adaptive driver)" fillcolor="#AED6F1"]
    IL12_adap     [label="IL-12\n(Th1 driver)" fillcolor="#AED6F1"]
    IL17A         [label="IL-17A\n★ Key Cytokine" fillcolor="#1B4F72" fontcolor=white]
    IL17F         [label="IL-17F" fillcolor="#2E86C1" fontcolor=white]
    IL22_adap     [label="IL-22\n(barrier / bone)" fillcolor="#2E86C1" fontcolor=white]
    IFNg          [label="IFN-γ\n(Th1 / CD8+)" fillcolor="#7FB3D3"]
    TNF_adap      [label="TNF-α\n(Th1 / CD8+ source)" fillcolor="#F1948A"]
    IL17_receptor [label="IL-17RA / RC\nReceptor Complex" fillcolor="#D6EAF8"]
    JAK_STAT3adap [label="JAK1/2 – STAT3\n(IL-6 / IL-23 signal)" fillcolor="#AED6F1"]
    RORC          [label="RORγt\nTranscription Factor" fillcolor="#AED6F1"]
    Tbet          [label="T-bet\nTranscription Factor" fillcolor="#AED6F1"]
    STAT4         [label="STAT4\n(IL-12 signal)" fillcolor="#AED6F1"]
    TGFb_adap     [label="TGF-β\n(Treg / Th17 driver)" fillcolor="#AED6F1"]
    IL4           [label="IL-4 / IL-13\n(Th2, minor)" fillcolor="#BDC3C7"]

    IL23_adap     -> JAK_STAT3adap [label="STAT3\nphospho"]
    IL12_adap     -> STAT4
    JAK_STAT3adap -> RORC          [label="induces"]
    STAT4         -> Tbet          [label="induces"]
    RORC          -> Th17          [label="differentiates"]
    Tbet          -> Th1           [label="differentiates"]
    NaiveCD4      -> Th17          [label="IL-23 +\nTGFβ + IL-6"]
    NaiveCD4      -> Th1           [label="IL-12"]
    NaiveCD4      -> Treg          [label="TGFβ"]
    TGFb_adap     -> Treg          [label="drives"]
    TGFb_adap     -> Th17          [label="co-driver\n(low conc)"]
    Th17          -> IL17A         [label="secretes"]
    Th17          -> IL17F         [label="secretes"]
    Th17          -> IL22_adap     [label="secretes"]
    Th17          -> TNF_adap      [label="secretes"]
    Th1           -> IFNg          [label="secretes"]
    Th1           -> TNF_adap      [label="secretes"]
    CD8_T         -> IFNg          [label="secretes"]
    CD8_T         -> TNF_adap      [label="secretes"]
    IL17A         -> IL17_receptor [label="binds"]
    IL17F         -> IL17_receptor [label="binds"]
    HLA_B27       -> CD8_T         [label="peptide\npresentation"]
    IL23_adap     -> IL23_innate   [style=invis]
    IL12_adap     -> IL12_innate   [style=invis]
  }

  /* ================================================================
     CLUSTER 4: Inflammatory Mediators & Downstream Signaling
  ================================================================ */
  subgraph cluster_signaling {
    label="4. Inflammatory Mediators & Cell Signaling"
    style=filled fillcolor="#FDEDEC" color="#922B21"
    fontcolor="#922B21" fontsize=11 fontname="Helvetica-Bold"

    TNF_total     [label="TNF-α\n(Total pool)" fillcolor="#E74C3C" fontcolor=white]
    TNFR1         [label="TNFR1 (p55)\nDeath domain" fillcolor="#F1948A"]
    TNFR2         [label="TNFR2 (p80)\nImmune regulation" fillcolor="#F1948A"]
    NF_kB_sig     [label="NF-κB\nSignaling Hub" fillcolor="#C0392B" fontcolor=white]
    AP1           [label="AP-1\n(c-Fos / c-Jun)" fillcolor="#F1948A"]
    MAPK_p38      [label="MAPK / p38\nSignaling" fillcolor="#F1948A"]
    JAK_total     [label="JAK1 / JAK2 / JAK3\nTyrosine Kinases" fillcolor="#F1948A"]
    STAT1_sig     [label="STAT1\n(IFN-γ signal)" fillcolor="#F1948A"]
    STAT3_sig     [label="STAT3\n(IL-6 / IL-23)" fillcolor="#F1948A"]
    IL6_total     [label="IL-6\n(Total pool)" fillcolor="#E74C3C" fontcolor=white]
    IL6R_sig      [label="IL-6R\n(mIL-6R / sIL-6R)" fillcolor="#F1948A"]
    gp130         [label="gp130\nSignal Transducer" fillcolor="#F1948A"]
    CRP_sig       [label="CRP\n(Acute Phase Reactant)" fillcolor="#FADBD8"]
    SAA           [label="SAA\n(Serum Amyloid A)" fillcolor="#FADBD8"]
    Fibrinogen    [label="Fibrinogen\n(ESR driver)" fillcolor="#FADBD8"]
    MMP3          [label="MMP-3\n(Stromelysin-1)" fillcolor="#FADBD8"]
    MMP9          [label="MMP-9\n(Gelatinase B)" fillcolor="#FADBD8"]
    COX2          [label="COX-2\n(Prostaglandin synthesis)" fillcolor="#FADBD8"]
    PGE2          [label="PGE2\n(Pain / fever mediator)" fillcolor="#FADBD8"]
    Bradykinin    [label="Bradykinin /\nSubstance P" fillcolor="#FADBD8"]
    IL8_CXCL8    [label="IL-8 / CXCL8\n(Neutrophil chemo)" fillcolor="#FADBD8"]

    TNF_total     -> TNFR1
    TNF_total     -> TNFR2
    TNFR1         -> NF_kB_sig     [label="activates"]
    TNFR1         -> MAPK_p38      [label="activates"]
    TNFR2         -> NF_kB_sig     [style=dashed]
    NF_kB_sig     -> COX2          [label="induces"]
    NF_kB_sig     -> MMP3          [label="induces"]
    NF_kB_sig     -> IL6_total     [label="induces"]
    NF_kB_sig     -> IL8_CXCL8    [label="induces"]
    IL17_receptor -> NF_kB_sig     [label="via TRAF6\nACT1"]
    IL17_receptor -> MAPK_p38      [label="activates"]
    IL6_total     -> IL6R_sig
    IL6R_sig      -> gp130
    gp130         -> JAK_total     [label="gp130\nactivation"]
    JAK_total     -> STAT3_sig     [label="phosphorylates"]
    JAK_total     -> STAT1_sig     [label="(IFN-γ)"]
    STAT3_sig     -> CRP_sig       [label="liver\nproduction"]
    STAT3_sig     -> SAA           [label="liver\nproduction"]
    STAT3_sig     -> Fibrinogen    [label="liver\nproduction"]
    COX2          -> PGE2          [label="catalyzes"]
    PGE2          -> Bradykinin    [label="synergizes"]
    MAPK_p38      -> AP1           [label="activates"]
    AP1           -> MMP3          [label="induces"]
    AP1           -> MMP9          [label="induces"]
    NF_kB_sig     -> IL8_CXCL8    [label="chemokine\ninduction"]
    IL8_CXCL8    -> Neutrophil    [label="recruits" style=dashed]
    TNF_innate    -> TNF_total     [label="contributes"]
    TNF_adap      -> TNF_total     [label="contributes"]
    IL6_innate    -> IL6_total     [label="contributes"]
    IL23_innate   -> IL23_adap     [label="pool"]
    IL12_innate   -> IL12_adap     [label="pool"]
  }

  /* ================================================================
     CLUSTER 5: Bone Remodeling (Dual Pathology)
  ================================================================ */
  subgraph cluster_bone {
    label="5. Bone Remodeling — Erosion & Pathological New Bone Formation"
    style=filled fillcolor="#E8F8F5" color="#1E8449"
    fontcolor="#1E8449" fontsize=11 fontname="Helvetica-Bold"

    Osteoclast    [label="Osteoclast\n(Bone Resorption)" fillcolor="#E74C3C" fontcolor=white]
    Osteoblast    [label="Osteoblast\n(Bone Formation)" fillcolor="#27AE60" fontcolor=white]
    Osteocyte     [label="Osteocyte\n(Mechanosensor)" fillcolor="#82E0AA"]
    PreOsteoclast [label="Pre-Osteoclast\n(Monocyte lineage)" fillcolor="#F1948A"]
    RANKL_bone    [label="RANKL\n(TNFSF11)" fillcolor="#FADBD8"]
    RANK_bone     [label="RANK\nReceptor" fillcolor="#FADBD8"]
    OPG_bone      [label="OPG\n(Osteoprotegerin,\ndecoy receptor)" fillcolor="#ABEBC6"]
    RANKL_OPG     [label="RANKL:OPG\nRatio ★" fillcolor="#F9E79F" shape=diamond]
    M_CSF         [label="M-CSF\n(Macrophage CSF)" fillcolor="#FADBD8"]
    Wnt_path      [label="Wnt / β-catenin\n(Canonical)" fillcolor="#82E0AA"]
    LRP5_6        [label="LRP5/6\nCo-receptor" fillcolor="#82E0AA"]
    DKK1          [label="DKK1\n(Wnt inhibitor)" fillcolor="#FADBD8"]
    Sclerostin    [label="Sclerostin (SOST)\n(Wnt inhibitor)" fillcolor="#FADBD8"]
    BMP_path      [label="BMP-2 / 4 / 7\nSignaling" fillcolor="#82E0AA"]
    Smad_path     [label="Smad1/5/8\nTranscriptional" fillcolor="#82E0AA"]
    Hedgehog      [label="Hedgehog\n(Ihh / Shh)" fillcolor="#82E0AA"]
    TGFb_bone     [label="TGF-β1\n(bifunctional)" fillcolor="#F9E79F"]
    IGF1          [label="IGF-1\n(anabolic)" fillcolor="#82E0AA"]
    Syndesmo      [label="Syndesmophyte\nFormation" fillcolor="#27AE60" fontcolor=white shape=octagon]
    BoneErosion   [label="Bone Erosion\n(Vertebral / SIJ)" fillcolor="#E74C3C" fontcolor=white shape=octagon]
    Ankylosis     [label="Spinal\nAnkylosis" fillcolor="#1E8449" fontcolor=white shape=octagon]
    mSASSS_bone   [label="mSASSS\n(Structural Score)" fillcolor="#A9DFBF" shape=doubleoctagon]
    IL17_bone     [label="IL-17 →\nNew Bone Pathway" fillcolor="#AED6F1"]
    IL22_bone     [label="IL-22 →\nPeriosteal Reaction" fillcolor="#AED6F1"]
    OsteocalcMkr  [label="Osteocalcin / P1NP\n(bone formation mkr)" fillcolor="#A9DFBF"]
    CTX           [label="CTX / TRAP5b\n(bone resorption mkr)" fillcolor="#FADBD8"]
    FGF23         [label="FGF-23\n(Bone–kidney axis)" fillcolor="#82E0AA"]

    TNF_total     -> RANKL_bone    [label="upregulates"]
    TNF_total     -> OPG_bone      [label="downregulates" color=red]
    TNF_total     -> PreOsteoclast [label="activates"]
    IL17A         -> RANKL_bone    [label="induces"]
    IL17A         -> IL17_bone
    IL22_adap     -> IL22_bone
    RANKL_bone    -> RANK_bone     [label="binds"]
    RANK_bone     -> Osteoclast    [label="drives\ndifferentiation"]
    OPG_bone      -> RANKL_OPG    [label="inhibits\nRANKL"]
    RANKL_bone    -> RANKL_OPG    [label="promotes"]
    RANKL_OPG    -> Osteoclast    [label="net\nactivation"]
    M_CSF         -> PreOsteoclast [label="survival\nfactor"]
    PreOsteoclast -> Osteoclast    [label="matures"]
    Osteoclast    -> BoneErosion   [label="causes"]
    Osteoclast    -> CTX           [label="releases"]
    DKK1          -> Wnt_path      [label="inhibits" color=red]
    Sclerostin    -> Wnt_path      [label="inhibits" color=red]
    Sclerostin    -> LRP5_6        [label="blocks" color=red]
    TNF_total     -> DKK1          [label="induces\n(acute)"]
    Wnt_path      -> LRP5_6        [label="signals\nvia"]
    LRP5_6        -> Osteoblast    [label="activates"]
    Wnt_path      -> Osteoblast    [label="activates"]
    BMP_path      -> Smad_path
    Smad_path     -> Osteoblast    [label="drives"]
    Hedgehog      -> Osteoblast    [label="promotes"]
    IL17_bone     -> Wnt_path      [label="promotes\nnew bone"]
    IL22_bone     -> Osteoblast    [label="promotes"]
    TGFb_bone     -> Osteoblast    [label="anabolic\n(local)"]
    IGF1          -> Osteoblast    [label="anabolic"]
    Osteoblast    -> Syndesmo      [label="forms"]
    Osteoblast    -> OPG_bone      [label="produces"]
    Osteoblast    -> OsteocalcMkr  [label="releases"]
    Syndesmo      -> Ankylosis     [label="leads to"]
    Osteocyte     -> Sclerostin    [label="produces"]
    Osteocyte     -> FGF23         [label="produces"]
    BoneErosion   -> mSASSS_bone   [label="contributes"]
    Syndesmo      -> mSASSS_bone   [label="main driver"]
    BMP_path      -> Syndesmo      [label="promotes"]
    IL22_bone     -> Syndesmo      [label="promotes"]
  }

  /* ================================================================
     CLUSTER 6: Target Organs & Clinical Manifestations
  ================================================================ */
  subgraph cluster_clinical {
    label="6. Target Organs & Clinical Manifestations"
    style=filled fillcolor="#F4F6F7" color="#555555"
    fontcolor="#555555" fontsize=11 fontname="Helvetica-Bold"

    SIJ           [label="Sacroiliac Joint\n(primary site)" fillcolor="#D5D8DC" shape=octagon]
    Spine_vert    [label="Spine\n(thoracolumbar)" fillcolor="#D5D8DC" shape=octagon]
    Hip_joint     [label="Hip Joint\n(large joint)" fillcolor="#D5D8DC"]
    PeriphJoint   [label="Peripheral Joints\n(asymmetric, <30%)" fillcolor="#D5D8DC"]
    Uveitis_EIM   [label="Anterior Uveitis\n(EIM, 27–40%)" fillcolor="#FADBD8"]
    Psoriasis_EIM [label="Psoriasis\n(EIM, 10%)" fillcolor="#FADBD8"]
    IBD_EIM       [label="Inflammatory\nBowel Disease (EIM)" fillcolor="#FADBD8"]
    Fatigue       [label="Fatigue /\nSleep Disturbance" fillcolor="#D5D8DC"]
    MornStiff     [label="Morning\nStiffness >45 min" fillcolor="#D5D8DC"]
    SpinalPain    [label="Inflammatory\nBack Pain" fillcolor="#D5D8DC"]
    NightPain     [label="Night Pain /\n2nd-half awakening" fillcolor="#D5D8DC"]
    CardioRisk    [label="Cardiovascular\nRisk ↑ (IMT)" fillcolor="#FADBD8"]
    OsteoporosisAS[label="Osteoporosis\n(in AS, 25%)" fillcolor="#FADBD8"]
    RestrictMob   [label="Restricted Spinal\nMobility" fillcolor="#D5D8DC"]
    BASDAI_clin   [label="BASDAI\n(0–10)" fillcolor="#A9CCE3" shape=doubleoctagon]
    ASDAS_clin    [label="ASDAS-CRP\n(Disease Activity)" fillcolor="#A9CCE3" shape=doubleoctagon]
    BASFI_clin    [label="BASFI\n(Function 0–10)" fillcolor="#A9CCE3" shape=doubleoctagon]
    BASMI_clin    [label="BASMI\n(Metrology)" fillcolor="#A9CCE3" shape=doubleoctagon]
    ASAS_resp     [label="ASAS 20/40\nResponse Criteria" fillcolor="#27AE60" fontcolor=white shape=doubleoctagon]

    BoneErosion   -> SIJ           [label="affects"]
    Syndesmo      -> Spine_vert    [label="forms in"]
    Ankylosis     -> Spine_vert    [label="causes"]
    Ankylosis     -> RestrictMob   [label="causes"]
    TNF_total     -> SIJ           [label="drives\ninflam."]
    IL17A         -> SIJ           [label="drives\ninflam."]
    PGE2          -> SpinalPain    [label="causes"]
    Bradykinin    -> SpinalPain    [label="causes"]
    SpinalPain    -> NightPain
    SpinalPain    -> MornStiff
    SIJ           -> SpinalPain    [label="source"]
    Spine_vert    -> SpinalPain    [label="source"]
    TNF_total     -> Uveitis_EIM   [label="contributes"]
    IL17A         -> Uveitis_EIM   [label="contributes"]
    IBD_EIM       -> IL23_adap     [label="shared\nIL-23 path" style=dashed]
    MornStiff     -> BASDAI_clin   [label="Q2/Q3"]
    SpinalPain    -> BASDAI_clin   [label="Q1/Q4"]
    Fatigue       -> BASDAI_clin   [label="Q5/Q6"]
    CRP_sig       -> ASDAS_clin    [label="CRP\ncomponent"]
    BASDAI_clin   -> ASDAS_clin    [label="BAS\ncomponent"]
    SpinalPain    -> ASDAS_clin    [label="global\nAS pain"]
    BoneErosion   -> OsteoporosisAS[label="contributes"]
    TNF_total     -> CardioRisk    [label="systemic\neffect"]
    BASDAI_clin   -> ASAS_resp     [label="BASDAI50"]
    mSASSS_bone   -> BASMI_clin    [label="correlates"]
    RestrictMob   -> BASMI_clin    [label="measured"]
    BASFI_clin    -> ASAS_resp     [label="component"]
  }

  /* ================================================================
     CLUSTER 7: Drug Pharmacokinetics
  ================================================================ */
  subgraph cluster_pk {
    label="7. Drug Pharmacokinetics"
    style=filled fillcolor="#F5EEF8" color="#6C3483"
    fontcolor="#6C3483" fontsize=11 fontname="Helvetica-Bold"

    ADA_dose  [label="Adalimumab\n40 mg SC q2w" fillcolor="#D7BDE2"]
    ETA_dose  [label="Etanercept\n50 mg SC qw" fillcolor="#D7BDE2"]
    IFX_dose  [label="Infliximab\n5 mg/kg IV q6–8 w" fillcolor="#D7BDE2"]
    CZP_dose  [label="Certolizumab Pegol\n200 mg SC q2w" fillcolor="#D7BDE2"]
    GLM_dose  [label="Golimumab\n50 mg SC q4w" fillcolor="#D7BDE2"]
    SEC_dose  [label="Secukinumab\n150/300 mg SC" fillcolor="#C39BD3"]
    IXE_dose  [label="Ixekizumab\n80 mg SC q4w" fillcolor="#C39BD3"]
    BIME_dose [label="Bimekizumab\n160 mg SC q4w" fillcolor="#C39BD3"]
    GUS_dose  [label="Guselkumab\n100 mg SC q8w" fillcolor="#A569BD"]
    RIS_dose  [label="Risankizumab\n150 mg SC q12w" fillcolor="#A569BD"]
    TOF_dose  [label="Tofacitinib\n5 mg BID oral" fillcolor="#F9E79F"]
    UPA_dose  [label="Upadacitinib\n15 mg QD oral" fillcolor="#F9E79F"]
    NSAID_dose[label="NSAIDs\n(naproxen / celecoxib)" fillcolor="#FAD7A0"]

    ADA_Cp    [label="Adalimumab Cp\n(μg/mL)\nt½≈14 d, F=0.64" fillcolor="#D7BDE2"]
