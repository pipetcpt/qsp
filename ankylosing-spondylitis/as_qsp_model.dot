    GUS_Cp    [label="Guselkumab Cp\n(μg/mL)\nt½≈17 d" fillcolor="#A569BD"]
    RIS_Cp    [label="Risankizumab Cp\n(μg/mL)\nt½≈28 d" fillcolor="#A569BD"]
