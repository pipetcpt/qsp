    ASAS40_out    [label="ASAS40 Response\n(%)" fillcolor="#27AE60" fontcolor=white]
    ASAS_PR_out   [label="ASAS Partial\nRemission (%)" fillcolor="#27AE60" fontcolor=white]
    BASDAI50_out  [label="BASDAI50\nResponse (%)" fillcolor="#27AE60" fontcolor=white]
    MEASURE1_ref  [label="MEASURE 1/2\n(Secukinumab AS)" fillcolor="#D6EAF8"]
    ATLAS_ref     [label="ATLAS Trial\n(Adalimumab AS)" fillcolor="#D6EAF8"]
    GORAISE_ref   [label="GO-RAISE Trial\n(Golimumab AS)" fillcolor="#D6EAF8"]
    SELECTAXIS_ref[label="SELECT-AXIS 1/2\n(Upadacitinib)" fillcolor="#D6EAF8"]
    COAST_V_ref   [label="COAST-V Trial\n(Ixekizumab)" fillcolor="#D6EAF8"]
    GUIDE_ref     [label="GUIDE Trial\n(Guselkumab)" fillcolor="#D6EAF8"]

    TNFi_eff      -> TNF_free      [label="reduces"]
    IL17i_eff     -> IL17_free     [label="reduces"]
    IL23i_eff     -> IL23_free     [label="reduces"]
    TNF_free      -> DiseaseAct    [label="drives"]
    IL17_free     -> DiseaseAct    [label="drives"]
    IL23_free     -> DiseaseAct    [label="drives"]
    JAKi_eff      -> DiseaseAct    [label="reduces\n(multi-cyt.)"]
    COX_inh       -> DiseaseAct    [label="reduces\n(pain/CRP)"]
    DiseaseAct    -> BASDAIsim     [label="maps to"]
    CRP_sig       -> ASDASsim      [label="CRP component"]
    DiseaseAct    -> ASDASsim      [label="maps to"]
    DiseaseAct    -> ASAS20_out    [label="Emax model"]
    DiseaseAct    -> ASAS40_out    [label="Emax model"]
    BASDAIsim     -> ASAS_PR_out   [label="<2.0\nthreshold"]
    ASDASsim      -> ASAS_PR_out   [label="<1.3\nthreshold"]
    BASDAIsim     -> BASDAI50_out  [label="50% reduction"]
    BoneProgr     -> mSASSS_bone   [label="tracks"]
    MEASURE1_ref  -> ASAS20_out    [label="calibrates\nSEC model"]
    ATLAS_ref     -> ASAS20_out    [label="calibrates\nADA model"]
    GORAISE_ref   -> ASAS20_out    [label="calibrates\nGLM model"]
    SELECTAXIS_ref-> ASAS20_out    [label="calibrates\nUPA model"]
    COAST_V_ref   -> ASAS20_out    [label="calibrates\nIXE model"]
    GUIDE_ref     -> ASAS20_out    [label="calibrates\nGUS model"]
  }

  /* ================================================================
     Cross-cluster edges
  ================================================================ */
  MechStress    -> Enthesis       [label="primary\ntrigger"]
