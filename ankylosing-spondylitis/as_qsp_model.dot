  /* ================================================================
     CLUSTER 8: Drug Pharmacodynamics (Mechanisms)
  ================================================================ */
  subgraph cluster_pd {
    label="8. Drug Pharmacodynamics — Mechanism of Action"
    style=filled fillcolor="#EAFAF1" color="#1E8449"
    fontcolor="#1E8449" fontsize=11 fontname="Helvetica-Bold"

    TNFi_PD   [label="TNFi\n(TNF neutralization)" fillcolor="#ABEBC6"]
    IL17Ai_PD [label="IL-17Ai\n(IL-17A blockade)" fillcolor="#ABEBC6"]
    BIME_PD   [label="Bimekizumab PD\n(IL-17A + IL-17F)" fillcolor="#ABEBC6"]
    IL23i_PD  [label="IL-23i\n(p19 subunit block)" fillcolor="#ABEBC6"]
    JAKi_PD   [label="JAKi\n(JAK1 selective)" fillcolor="#ABEBC6"]
    NSAID_PD  [label="NSAID\n(COX-1/2 inhibition)" fillcolor="#D5F5E3"]
    SSZ_PD    [label="Sulfasalazine\n(5-ASA + sulfapyridine)" fillcolor="#D5F5E3"]

    TNFi_eff  [label="↓ Free TNF-α" fillcolor="#82E0AA"]
    IL17i_eff [label="↓ Free IL-17A\n(± IL-17F)" fillcolor="#82E0AA"]
    IL23i_eff [label="↓ IL-23 →\n↓ Th17 driver" fillcolor="#82E0AA"]
    JAKi_eff  [label="↓ JAK/STAT\n↓ IL-6/IL-23/IFN-γ" fillcolor="#82E0AA"]
    COX_inh   [label="↓ PGE2\n↓ Pain / inflammation" fillcolor="#D5F5E3"]

    TNFi_PD   -> TNFi_eff
    IL17Ai_PD -> IL17i_eff
    BIME_PD   -> IL17i_eff  [label="dual\nIL-17A+F"]
    IL23i_PD  -> IL23i_eff
    JAKi_PD   -> JAKi_eff
    NSAID_PD  -> COX_inh
    SSZ_PD    -> NF_kB_sig  [label="inhibits\n(partial)" style=dashed color=red]

    ADA_Cp    -> TNFi_PD    [label="drives\nPD effect"]
    ETA_Cp    -> TNFi_PD    [label="drives\nPD effect"]
    IFX_Cp    -> TNFi_PD    [label="drives\nPD effect"]
    CZP_Cp    -> TNFi_PD    [label="drives\nPD effect"]
    GLM_Cp    -> TNFi_PD    [label="drives\nPD effect"]
    SEC_Cp    -> IL17Ai_PD  [label="Emax\noccupancy"]
    IXE_Cp    -> IL17Ai_PD  [label="Emax\noccupancy"]
    BIME_Cp   -> BIME_PD    [label="drives"]
    GUS_Cp    -> IL23i_PD   [label="drives"]
    RIS_Cp    -> IL23i_PD   [label="drives"]
    TOF_Cp    -> JAKi_PD    [label="IC50-based\noccupancy"]
    UPA_Cp    -> JAKi_PD    [label="JAK1\nselective"]
    NSAID_Cp  -> NSAID_PD   [label="IC50-based"]

    TNFi_eff  -> TNF_total  [label="neutralizes\nfree TNF" color=red style=bold]
    IL17i_eff -> IL17A      [label="neutralizes" color=red style=bold]
    IL23i_eff -> IL23_adap  [label="reduces IL-23" color=red style=bold]
    JAKi_eff  -> JAK_total  [label="blocks JAK" color=red style=bold]
    COX_inh   -> COX2       [label="inhibits" color=red style=bold]
  }

  /* ================================================================
     CLUSTER 9: Gut–Joint Axis & Microbiome
  ================================================================ */
  subgraph cluster_gut {
    label="9. Gut–Joint Axis & Microbiome"
    style=filled fillcolor="#FEF9E7" color="#7D6608"
    fontcolor="#7D6608" fontsize=11 fontname="Helvetica-Bold"

    GutMicro     [label="Gut Microbiome\n(dysbiosis in AS)" fillcolor="#FAD7A0"]
    GutEpith     [label="Gut Epithelial\nBarrier (leaky)" fillcolor="#FAD7A0"]
    GutDC        [label="Gut DC /\nMacrophage" fillcolor="#FAD7A0"]
    SubclinIBD   [label="Subclinical Gut\nInflammation (60%)" fillcolor="#FAD7A0" shape=octagon]
    GutILC3      [label="Gut ILC3\n(IL-22 / IL-17 source)" fillcolor="#FAD7A0"]
    BacterialAg  [label="Bacterial Antigens\n(Klebsiella, Prevotella)" fillcolor="#FDEBD0"]
    MolMimicry   [label="Molecular Mimicry\n(HLA-B27 / bacteria)" fillcolor="#FDEBD0"]
    GutIL17pool  [label="Gut IL-17\nAmplification" fillcolor="#FAD7A0"]
    PortalCirc   [label="Portal Circulation\n(bacterial LPS)" fillcolor="#FDEBD0"]
    Lachnospira  [label="↓ Lachnospiraceae\n(anti-inflam. depleted)" fillcolor="#FDEBD0"]
    Prevotella   [label="↑ Prevotella /\nBacteroidetes" fillcolor="#FAD7A0"]

    GutMicro     -> BacterialAg    [label="produces"]
    GutMicro     -> GutEpith       [label="dysbiosis\n↑ permeability"]
    GutEpith     -> PortalCirc     [label="bacterial\nleak"]
    BacterialAg  -> MolMimicry     [label="cross-reacts"]
    MolMimicry   -> HLA_B27        [label="mimics\nHLA-B27 pep." style=dashed]
    GutDC        -> IL23_innate    [label="IL-23\nproduction"]
    GutILC3      -> GutIL17pool    [label="via IL-23"]
    GutIL17pool  -> IL17A          [label="systemic\npool"]
    SubclinIBD   -> GutMicro       [label="promotes\ndysbiosis"]
    PortalCirc   -> Macrophage     [label="activates\nperipheral Mφ"]
    IBD_EIM      -> SubclinIBD     [label="macroscopic"]
    IL23i_eff    -> SubclinIBD     [label="may improve" style=dashed color=green]
    Lachnospira  -> GutMicro       [label="depleted"]
    Prevotella   -> GutMicro       [label="enriched"]
  }

