    TNF_free      [label="Free TNF-α\n(pM, drug-inhibited)" fillcolor="#AED6F1"]
    IL17_free     [label="Free IL-17A\n(pM, drug-inhibited)" fillcolor="#AED6F1"]
    IL23_free     [label="Free IL-23\n(pM)" fillcolor="#AED6F1"]
