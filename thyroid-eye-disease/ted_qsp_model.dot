digraph TED_QSP {
  graph [rankdir=LR, fontname="Helvetica", fontsize=11, labelloc=t,
         label="Thyroid Eye Disease (TED / Graves' Orbitopathy, 갑상선眼병증) — Integrated QSP Mechanistic Map\nTSHR-IGF-1R Autoimmune Crosstalk → Orbital Fibroblast Activation → GAG/Hyaluronan Edema, Adipogenesis & Fibrosis → Proptosis, Diplopia, DON\nTeprotumumab (IGF-1R mAb) · IV Methylprednisolone/Prednisone · Rituximab (anti-CD20) · Tocilizumab (anti-IL-6R) · Selenium · Orbital Decompression/RT",
         splines=spline, overlap=false, nodesep=0.28, ranksep=0.55,
         bgcolor="#fbfbfd"];
  node  [shape=box, style="rounded,filled", fontname="Helvetica", fontsize=10,
         fillcolor="#ffffff", color="#7d8590"];
  edge  [fontname="Helvetica", fontsize=9, color="#6e7681", arrowsize=0.7];

  /* ───────────────────────── 1. Systemic Autoimmunity: Graves'/TSHR-TRAb Axis ── */
  subgraph cluster_systemic {
    label="1. Systemic Autoimmunity — TSHR-TRAb Axis";
    style="filled,rounded"; color="#5c6370"; fillcolor="#f3f0ff"; fontsize=12;
    GeneticRisk    [label="HLA-DR3, CTLA-4,\nPTPN22 risk alleles"];
    LossOfTolerance[label="Loss of self-tolerance\nto TSHR"];
    BCellAutoRx    [label="Autoreactive B cells\n(thyroid + orbit-homing)"];
    PlasmaCell     [label="Plasma cells\n(intrathyroidal + orbital)"];
    TRAb           [label="TSHR-stimulating\nautoantibody (TRAb/TSI)"];
    ThyroidTSHR    [label="Thyroid follicular\nTSH receptor"];
    ThyroidHormone [label="Thyroid hormone\nexcess (Graves' hyperthyroidism)"];
    ATD            [label="Antithyroid drugs\n(methimazole/PTU)"];
    RAI            [label="Radioactive iodine\n(¹³¹I) ablation"];
    Thyroidectomy  [label="Total thyroidectomy"];
    ThyroidAgFlare [label="Post-RAI thyroid\nantigen release/flare"];
    Smoking        [label="Cigarette smoking"];
    GeneticRisk -> LossOfTolerance -> BCellAutoRx -> PlasmaCell -> TRAb;
    TRAb -> ThyroidTSHR -> ThyroidHormone;
    ATD -> ThyroidHormone [style=dashed, label="control"];
    RAI -> ThyroidAgFlare [style=dashed];
    ThyroidAgFlare -> BCellAutoRx [style=dashed, label="transient\nTRAb rise"];
    Thyroidectomy -> ThyroidHormone [style=dashed, label="removes\nsource"];
    Smoking -> BCellAutoRx [style=dashed, label="↑ autoimmunity"];
  }

  /* ───────────────────────── 2. Orbital Immune Infiltration ─────────────── */
  subgraph cluster_immune {
    label="2. Orbital Immune Cell Infiltration";
    style="filled,rounded"; color="#5c6370"; fillcolor="#fff4e6"; fontsize=12;
    OrbitHoming    [label="Lymphocyte homing to\norbital connective tissue"];
    ThCell         [label="CD4+ T cells\n(Th1/Th17 skewed)"];
    Th17           [label="Th17 subset\n(IL-17 producer)"];
    Treg           [label="Treg (relative\ndeficiency)"];
    CD8Tcell       [label="CD8+ cytotoxic\nT cells"];
    OrbitBcell     [label="Orbital B cells\n& plasma cells"];
    Macrophage     [label="M1-polarized\nmacrophages"];
    MastCell       [label="Mast cells"];
    IL1b           [label="IL-1β"];
    IL6            [label="IL-6"];
    TNFa           [label="TNF-α"];
    IFNg           [label="IFN-γ"];
    IL16           [label="IL-16 / RANTES\n(chemokines)"];
    CD40L          [label="CD40-CD40L\nco-stimulation"];
    OrbitHoming -> ThCell; OrbitHoming -> OrbitBcell; OrbitHoming -> Macrophage;
    ThCell -> Th17; ThCell -> Treg [style=dashed, label="counter-\nregulation"];
    ThCell -> CD8Tcell;
    Th17 -> IL1b; Th17 -> IL6;
    Macrophage -> IL1b; Macrophage -> TNFa; Macrophage -> IL6;
    CD8Tcell -> IFNg; ThCell -> IFNg;
    OrbitBcell -> CD40L;
    MastCell -> IL16;
    Smoking -> Macrophage [style=dashed, label="↑ IL-1β\nresponse"];
  }

  /* ───────────────────────── 3. TSHR-IGF-1R Crosstalk on Fibroblasts ─────── */
  subgraph cluster_crosstalk {
    label="3. TSHR-IGF-1R Crosstalk on Orbital Fibroblasts";
    style="filled,rounded"; color="#5c6370"; fillcolor="#e6f7ff"; fontsize=12;
    CD34Fibrocyte  [label="CD34+ bone-marrow\nderived fibrocyte"];
    OrbitFibro     [label="Orbital fibroblast\n(resident + fibrocyte-derived)"];
    FbTSHR         [label="Fibroblast TSH\nreceptor (functional)"];
    FbIGF1R        [label="Fibroblast IGF-1\nreceptor"];
    TSHRIGF1RCplx  [label="TSHR-IGF-1R\nsignaling complex"];
    IGF1Ligand     [label="Local IGF-1 /\nautocrine loop"];
    PI3KAKT        [label="PI3K-AKT\npathway"];
    ERK            [label="ERK1/2 MAPK\npathway"];
    NFkB           [label="NF-κB\nactivation"];
    CREB           [label="CREB / cAMP-PKA\n(TSHR Gs arm)"];
    TRAb -> FbTSHR [label="cross-reactive\nbinding"];
    FbTSHR -> TSHRIGF1RCplx; FbIGF1R -> TSHRIGF1RCplx;
    IGF1Ligand -> FbIGF1R;
    TSHRIGF1RCplx -> PI3KAKT; TSHRIGF1RCplx -> ERK; TSHRIGF1RCplx -> NFkB;
    FbTSHR -> CREB;
    IL1b -> NFkB [label="synergy"]; TNFa -> NFkB; IFNg -> ERK;
    CD40L -> OrbitFibro [label="co-stimulates"];
    CD34Fibrocyte -> OrbitFibro [label="differentiation"];
  }

  /* ───────────────────────── 4. Fibroblast Fate: Adipogenic vs Myofibroblast ── */
  subgraph cluster_fate {
    label="4. Orbital Fibroblast Fate Decision";
    style="filled,rounded"; color="#5c6370"; fillcolor="#e8f5e9"; fontsize=12;
    FibActivation [label="Activated orbital\nfibroblast pool (FIBACT)"];
    PPARg         [label="PPAR-γ induction"];
    Preadipocyte  [label="Orbital preadipocyte\ndifferentiation"];
    MatureAdipo   [label="Mature orbital\nadipocyte"];
    Myofibroblast [label="α-SMA+\nmyofibroblast"];
    TGFb          [label="TGF-β1"];
    CTGF          [label="Connective tissue\ngrowth factor (CTGF)"];
    PI3KAKT -> PPARg -> Preadipocyte -> MatureAdipo;
    NFkB -> FibActivation; ERK -> FibActivation; PI3KAKT -> FibActivation;
    FibActivation -> Preadipocyte;
    FibActivation -> Myofibroblast [label="alternate fate\n(fibrotic-prone)"];
    TGFb -> Myofibroblast; TGFb -> CTGF;
    Myofibroblast -> TGFb [label="autocrine\namplification"];
    OrbitFibro -> FibActivation;
  }

  /* ───────────────────────── 5. GAG / Hyaluronan & ECM Dynamics ──────────── */
  subgraph cluster_ecm {
    label="5. Glycosaminoglycan / Hyaluronan / ECM Dynamics";
    style="filled,rounded"; color="#5c6370"; fillcolor="#fff0f6"; fontsize=12;
    HASynthase    [label="Hyaluronan synthase\n(HAS1/2/3) upregulation"];
    HyaluronanPool[label="Orbital hyaluronan (HA)\naccumulation"];
    Hyaluronidase [label="Hyaluronidase\nturnover"];
    Osmotic       [label="Osmotic water\nbinding by HA"];
    Collagen      [label="Collagen I/III\ndeposition"];
    ECMremodel    [label="ECM remodeling /\nfibrotic scarring"];
    FibActivation -> HASynthase -> HyaluronanPool;
    IL1b -> HASynthase [style=dashed]; IL6 -> HASynthase [style=dashed];
    Hyaluronidase -> HyaluronanPool [style=dashed, label="degrades"];
    HyaluronanPool -> Osmotic;
    Myofibroblast -> Collagen -> ECMremodel;
    CTGF -> ECMremodel;
  }

  /* ───────────────────────── 6. Tissue Remodeling (Fat, Muscle, Fibrosis) ── */
  subgraph cluster_remodel {
    label="6. Orbital Tissue Remodeling";
    style="filled,rounded"; color="#5c6370"; fillcolor="#fff9e6"; fontsize=12;
    OrbitFatVol   [label="Orbital fat\ncompartment volume (FATVOL)"];
    EOMVol        [label="Extraocular muscle\nvolume/edema (MUSVOL)"];
    OrbitFibrosis [label="Late-phase orbital\nfibrosis (FIBROSIS)"];
    OrbitSeptum   [label="Orbital septum\nintegrity"];
    ConjEdema     [label="Conjunctival/eyelid\nedema (chemosis)"];
    MatureAdipo -> OrbitFatVol;
    Osmotic -> EOMVol; Osmotic -> ConjEdema;
    ECMremodel -> OrbitFibrosis;
    OrbitFatVol -> OrbitSeptum [style=dashed, label="weakens\n(prolapse)"];
    OrbitFibrosis -> EOMVol [label="restrictive\nmyopathy"];
  }

  /* ───────────────────────── 7. Mechanical / Compressive Consequences ────── */
  subgraph cluster_mech {
    label="7. Mechanical & Compressive Consequences";
    style="filled,rounded"; color="#5c6370"; fillcolor="#f0f4ff"; fontsize=12;
    OrbitVolIncr  [label="Total intraorbital\nvolume increase"];
    BonyOrbitLimit[label="Fixed bony orbit\n(non-expansile)"];
    IntraorbitalP [label="Intraorbital\npressure ↑"];
    Proptosis     [label="Proptosis / exophthalmos\n(Hertel, mm)"];
    EOMRestrict   [label="EOM restriction /\nfibrotic tethering"];
    Diplopia      [label="Diplopia"];
    LidRetraction [label="Eyelid retraction\n(sympathetic Müller\nmuscle overactivity)"];
    ApexCrowding  [label="Orbital apex\ncrowding"];
    OpticNerveComp[label="Optic nerve\ncompression"];
    DON           [label="Dysthyroid optic\nneuropathy (DON)"];
    CornealExpo   [label="Corneal exposure /\nkeratopathy"];
    OrbitFatVol -> OrbitVolIncr; EOMVol -> OrbitVolIncr;
    BonyOrbitLimit -> IntraorbitalP [style=dashed];
    OrbitVolIncr -> IntraorbitalP -> Proptosis;
    ThyroidHormone -> LidRetraction [style=dashed, label="sympathetic\ntone"];
    Proptosis -> CornealExpo; LidRetraction -> CornealExpo;
    EOMVol -> EOMRestrict; OrbitFibrosis -> EOMRestrict -> Diplopia;
    OrbitVolIncr -> ApexCrowding -> OpticNerveComp -> DON;
    IntraorbitalP -> OpticNerveComp;
  }

  /* ───────────────────────── 8. Clinical Scoring & PRO Endpoints ─────────── */
  subgraph cluster_clin {
    label="8. Clinical Activity, Severity & PRO Endpoints";
    style="filled,rounded"; color="#5c6370"; fillcolor="#f5f0ff"; fontsize=12;
    CAS7          [label="Clinical Activity Score\n(CAS, 0-7, Mourits 1997)"];
    EUGOGOSev     [label="EUGOGO severity class\n(mild/mod-sev/sight-threat.)"];
    GOQOL         [label="GO-QoL\n(visual function + appearance)"];
    NOSPECS       [label="NOSPECS legacy\nclassification"];
    VisualAcuity  [label="Visual acuity /\ncontrast sensitivity"];
    VisualField   [label="Visual field\ndefect"];
    ResponderRate [label="Composite responder\n(proptosis ≥2mm + no\nCAS worsening)"];
    Pain          [label="Retrobulbar pain /\npain on eye movement"];
    OrbitVolIncr -> CAS7; ConjEdema -> CAS7; Pain -> CAS7;
    Proptosis -> EUGOGOSev; DON -> EUGOGOSev; Diplopia -> EUGOGOSev;
    DON -> VisualAcuity -> VisualField;
    Proptosis -> ResponderRate; CAS7 -> ResponderRate;
    Proptosis -> GOQOL; Diplopia -> GOQOL; LidRetraction -> GOQOL;
    EUGOGOSev -> GOQOL;
  }

  /* ───────────────────────── 9. Drug PK — Teprotumumab (anti-IGF-1R) ──────── */
  subgraph cluster_pk_tep {
    label="9. Drug PK/PD — Teprotumumab (IGF-1R mAb)";
    style="filled,rounded"; color="#5c6370"; fillcolor="#e6fff2"; fontsize=12;
    TepIVinfusion [label="Teprotumumab IV\ninfusion (q3w x8)"];
    TepCentral    [label="Teprotumumab\ncentral compartment"];
    TepPeripheral [label="Teprotumumab\nperipheral compartment"];
    TepOccupancy  [label="IGF-1R receptor\noccupancy (RO)"];
    TepIVinfusion -> TepCentral;
    TepCentral -> TepPeripheral [dir=both, label="Q distribution"];
    TepCentral -> TepOccupancy;
    TepOccupancy -> FbIGF1R [label="blocks", color="#c0392b", fontcolor="#c0392b"];
    TepOccupancy -> TSHRIGF1RCplx [label="disrupts\ncomplex", color="#c0392b", fontcolor="#c0392b"];
  }

  /* ───────────────────────── 10. Drug PK — Glucocorticoid / B-/IL-6-targeted ── */
  subgraph cluster_pk_other {
    label="10. Drug PK/PD — Glucocorticoid, Rituximab, Tocilizumab, Selenium";
    style="filled,rounded"; color="#5c6370"; fillcolor="#fef6e0"; fontsize=12;
    IVMP          [label="IV methylprednisolone\npulse (EUGOGO regimen)"];
    OralPred      [label="Oral prednisone\n(taper)"];
    GCcentral     [label="Systemic glucocorticoid\nexposure (GC_C)"];
    GRcomplex     [label="Glucocorticoid receptor\n(GR) complex"];
    RtxIV         [label="Rituximab IV\ninfusion"];
    RtxPK         [label="Rituximab PK\n(2-cmpt)"];
    BcellDeplete  [label="Peripheral/orbital\nB-cell depletion"];
    TczIV         [label="Tocilizumab IV\ninfusion"];
    TczPK         [label="Tocilizumab PK"];
    IL6Rocc       [label="IL-6 receptor\noccupancy"];
    Selenium      [label="Selenium\nsupplementation"];
    AntioxEffect  [label="Antioxidant / ROS\nscavenging"];
    IVMP -> GCcentral; OralPred -> GCcentral;
    GCcentral -> GRcomplex -> NFkB [label="transrepression", color="#c0392b", fontcolor="#c0392b"];
    GRcomplex -> IL1b [style=dashed, color="#c0392b"]; GRcomplex -> IL6 [style=dashed, color="#c0392b"];
    RtxIV -> RtxPK -> BcellDeplete;
    BcellDeplete -> OrbitBcell [label="depletes", color="#c0392b", fontcolor="#c0392b"];
    BcellDeplete -> TRAb [label="↓ production", color="#c0392b", fontcolor="#c0392b"];
    TczIV -> TczPK -> IL6Rocc;
    IL6Rocc -> IL6 [label="blocks\nsignaling", color="#c0392b", fontcolor="#c0392b"];
    Selenium -> AntioxEffect -> Macrophage [style=dashed, label="↓ ROS-driven\nactivation", color="#c0392b", fontcolor="#c0392b"];
  }

  /* ───────────────────────── 11. Non-Pharmacologic & Procedural Therapy ──── */
  subgraph cluster_proc {
    label="11. Non-Pharmacologic / Procedural Therapy";
    style="filled,rounded"; color="#5c6370"; fillcolor="#f2f2f2"; fontsize=12;
    SmokingCessation [label="Smoking cessation\ncounseling"];
    OrbitalRT       [label="Orbital external-beam\nradiotherapy (20 Gy)"];
    OrbitalDecompr  [label="Surgical orbital\ndecompression"];
    StraboSurg      [label="Strabismus\nsurgery"];
    LidSurg         [label="Eyelid\nsurgery"];
    EuthyroidCtrl   [label="Strict euthyroid\ncontrol (TSH normal)"];
    SmokingCessation -> Macrophage [style=dashed, label="↓ over months", color="#c0392b", fontcolor="#c0392b"];
    OrbitalRT -> ThCell [style=dashed, label="anti-inflammatory\n(radiosensitive\nlymphocytes)", color="#c0392b", fontcolor="#c0392b"];
    OrbitalDecompr -> IntraorbitalP [label="mechanical\ndecompression", color="#c0392b", fontcolor="#c0392b"];
    StraboSurg -> Diplopia [label="corrects\n(inactive phase)", color="#c0392b", fontcolor="#c0392b"];
    LidSurg -> LidRetraction [label="corrects\n(inactive phase)", color="#c0392b", fontcolor="#c0392b"];
    EuthyroidCtrl -> ThyroidHormone [label="normalizes", color="#c0392b", fontcolor="#c0392b"];
  }

  /* ───────────────────────── 12. Adverse Effects & Safety ─────────────────── */
  subgraph cluster_ae {
    label="12. Adverse Effects & Safety Monitoring";
    style="filled,rounded"; color="#5c6370"; fillcolor="#ffecec"; fontsize=12;
    TepAUC        [label="Cumulative teprotumumab\nexposure (AUC)"];
    HearingLoss   [label="Sensorineural hearing\nimpairment / tinnitus"];
    Hyperglycemia [label="Hyperglycemia /\nnew-onset diabetes"];
    IGF1RSyst     [label="Systemic IGF-1R\nblockade (muscle, growth\nplate, cochlea)"];
    CumGCdose     [label="Cumulative\nglucocorticoid dose"];
    Cushingoid    [label="Cushingoid features /\nosteoporosis / myopathy"];
    HepatotoxRisk [label="Hepatotoxicity risk\n(high-cumulative-dose IVMP)"];
    InfusionRxn   [label="Infusion-related\nreactions (mAbs)"];
    IBDflare      [label="IBD exacerbation\n(teprotumumab signal)"];
    TepCentral -> TepAUC;
    TepAUC -> IGF1RSyst -> HearingLoss;
    IGF1RSyst -> Hyperglycemia;
    TepAUC -> IBDflare [style=dashed];
    GCcentral -> CumGCdose -> Cushingoid;
    CumGCdose -> HepatotoxRisk [style=dashed];
    CumGCdose -> Hyperglycemia [style=dashed];
    TepIVinfusion -> InfusionRxn [style=dashed]; RtxIV -> InfusionRxn [style=dashed]; TczIV -> InfusionRxn [style=dashed];
  }

  /* ───────────────────────── Cross-cluster master cascade ─────────────────── */
  Th17 -> IL6 [style=dashed];
  IFNg -> Macrophage [style=dashed, label="primes"];
  IL6 -> FibActivation [label="paracrine\ndrive"];
  TNFa -> FibActivation [label="paracrine\ndrive"];
  IL1b -> FibActivation [label="paracrine\ndrive"];
  HyaluronanPool -> EOMVol [label="GAG-driven\nedema"];
  HyaluronanPool -> ConjEdema;
  FbTSHR -> HASynthase [label="direct TSHR\ndrive"];
}
