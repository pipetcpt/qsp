digraph BronchialAsthma_QSP {
  graph [
    rankdir=LR,
    splines=ortho,
    nodesep=0.45,
    ranksep=1.2,
    bgcolor="#F8F9FA",
    fontname="Helvetica",
    fontsize=12,
    label="Bronchial Asthma — Quantitative Systems Pharmacology Map\n≥110 components · Type-2 inflammation · Airway remodeling · Biologics & small-molecule PK/PD",
    labelloc=t,
    labeljust=c
  ]
  node [shape=box, style="rounded,filled", fontname="Helvetica", fontsize=8, height=0.28, width=1.1]
  edge [fontname="Helvetica", fontsize=7, arrowsize=0.65]

  /* ══════════════════════════════════════════════
     CLUSTER 1 – ENVIRONMENTAL TRIGGERS
  ══════════════════════════════════════════════ */
  subgraph cluster_triggers {
    label="Environmental & Host Triggers"
    style=filled; color="#D7F0D7"; fillcolor="#D7F0D7"
    node [fillcolor="#81C784"]

    ALLERGEN     [label="Allergen\n(HDM/Pollen/\nCat/Mold)"]
    VIRUS        [label="Viral Infection\n(RV/RSV/hMPV)"]
    POLLUTANT    [label="Air Pollutant\n(PM2.5 / O3)"]
    COLD_AIR     [label="Cold Air /\nExercise"]
    ASPIRIN_T    [label="NSAID /\nAspirin"]
    STRESS_T     [label="Psychological\nStress"]
    SMOKE_T      [label="Tobacco /\nBiomass Smoke"]
    OCCUPATIONAL [label="Occupational\nExposures"]
  }

  /* ══════════════════════════════════════════════
     CLUSTER 2 – AIRWAY EPITHELIUM & INNATE BARRIER
  ══════════════════════════════════════════════ */
  subgraph cluster_epi {
    label="Airway Epithelium & Innate Barrier"
    style=filled; color="#BBDEFB"; fillcolor="#BBDEFB"
    node [fillcolor="#64B5F6"]

    EPITHELIUM   [label="Bronchial\nEpithelium"]
    PROTEASE_E   [label="Protease\n(Der p1 / mold)"]
    TJ_BARRIER   [label="Tight Junction\n(claudin/occludin)"]
    TSLP         [label="TSLP"]
    IL25         [label="IL-25 (IL-17E)"]
    IL33         [label="IL-33"]
    ST2R         [label="ST2 / IL-1RL1\n(IL-33 receptor)"]
    TSLPR        [label="TSLPR"]
    AMPs         [label="AMPs\n(β-defensins)"]
    HRV_TLR      [label="TLR3 / TLR7\n(RV sensing)"]
    IFN_LAM      [label="IFN-λ\n(type III IFN)"]
    EGFR_EPI     [label="EGFR\nsignaling"]
    ROS_EPI      [label="ROS /\nOxidative Stress"]
    MUC5AC_EPI   [label="MUC5AC\n(epithelial)"]
    PGE2_EPI     [label="PGE2\n(epithelial)"]
  }

  /* ══════════════════════════════════════════════
     CLUSTER 3 – ILC2 & INNATE LYMPHOID
  ══════════════════════════════════════════════ */
  subgraph cluster_ilc2 {
    label="ILC2 & Innate Lymphoid Cells"
    style=filled; color="#FFE0B2"; fillcolor="#FFE0B2"
    node [fillcolor="#FFB74D"]

    ILC2         [label="ILC2\n(resting)"]
    ILC2_ACT     [label="ILC2\n(activated)"]
    GATA3_ILC2   [label="GATA3\n(ILC2 TF)"]
    PGD2_ILC2    [label="PGD2\n(CRTH2 signal)"]
    CRTH2        [label="CRTH2 / DP2\nreceptor"]
    KLRG1        [label="KLRG1\n(ILC2 inhibitor)"]
    IL4_I        [label="IL-4\n(ILC2-derived)"]
    IL5_I        [label="IL-5\n(ILC2-derived)"]
    IL13_I       [label="IL-13\n(ILC2-derived)"]
  }

  /* ══════════════════════════════════════════════
     CLUSTER 4 – DENDRITIC CELLS
  ══════════════════════════════════════════════ */
  subgraph cluster_dc {
    label="Dendritic Cells & Antigen Presentation"
    style=filled; color="#E8D5F0"; fillcolor="#E8D5F0"
    node [fillcolor="#CE93D8"]

    DC_IMM       [label="Immature DC"]
    DC_MAT       [label="Mature DC\n(CD80+/CD86+)"]
    MHCII        [label="MHC-II +\nAg-peptide"]
    OX40L_DC     [label="OX40L\n(Th2 polarizer)"]
    PDC          [label="Plasmacytoid DC\n(pDC)"]
    THYMIC_S     [label="Thymic stromal\nfactor (TSLP-DC)"]
  }

  /* ══════════════════════════════════════════════
     CLUSTER 5 – Th2 / ADAPTIVE IMMUNITY
  ══════════════════════════════════════════════ */
  subgraph cluster_th2 {
    label="Th2 / Adaptive Immune Response"
    style=filled; color="#FCE4EC"; fillcolor="#FCE4EC"
    node [fillcolor="#F48FB1"]

    NAIVE_T      [label="Naive CD4+\nT cell"]
    TH2          [label="Th2 cell"]
    TH1          [label="Th1 cell"]
    TH17         [label="Th17 cell\n(severe/neutrophilic)"]
    TREG         [label="Treg\n(immunoregulatory)"]
    GATA3_T      [label="GATA3\n(Th2 master TF)"]
    TBET_T       [label="T-bet\n(Th1 TF)"]
    RORC_T       [label="RORγt\n(Th17 TF)"]
    TCR_ACT      [label="TCR activation"]
    IL4_T        [label="IL-4 (Th2)"]
    IL5_T        [label="IL-5 (Th2)"]
    IL13_T       [label="IL-13 (Th2)"]
    IL9_T        [label="IL-9\n(mast cell growth)"]
    IL10_T       [label="IL-10 (Treg)"]
    IL17A_T      [label="IL-17A\n(neutrophilic)"]
    IL21_T       [label="IL-21\n(IgE class-switch)"]
    STAT6_T      [label="STAT6\n(IL-4/13 signaling)"]
    STAT5_T      [label="STAT5\n(IL-5 signaling)"]
    OX40_T       [label="OX40\n(T cell costim)"]
    ICOS_T       [label="ICOS\n(costimulation)"]
    NFkB_T       [label="NF-κB\n(T cell)"]
    NFAT_T       [label="NFAT\n(T cell)"]
  }

  /* ══════════════════════════════════════════════
     CLUSTER 6 – B CELL & IgE
  ══════════════════════════════════════════════ */
  subgraph cluster_ige {
    label="B Cell & IgE Biology"
    style=filled; color="#E0F7FA"; fillcolor="#E0F7FA"
    node [fillcolor="#4DD0E1"]

    BCELL        [label="B cell"]
    GC_REACT     [label="Germinal Center\nReaction"]
    PLASMA_C     [label="Plasma Cell\n(IgE-secreting)"]
    IgE_TOTAL    [label="Total IgE\n(serum, kU/L)"]
    IgE_FREE     [label="Free IgE\n(unbound)"]
    IgE_BOUND    [label="IgE : FcεRI\n(mast cell-bound)"]
    FceRI        [label="FcεRI\n(high-affinity IgE R)"]
    FceRII_CD23  [label="FcεRII / CD23\n(low-affinity)"]
    AID_CSR      [label="AID\n(class-switch)"]
    BAFF_B       [label="BAFF\n(B cell survival)"]
    APRIL_B      [label="APRIL\n(plasma cell)"]
  }

  /* ══════════════════════════════════════════════
     CLUSTER 7 – MAST CELL & BASOPHIL
  ══════════════════════════════════════════════ */
  subgraph cluster_mast {
    label="Mast Cell & Basophil"
    style=filled; color="#FFF9C4"; fillcolor="#FFF9C4"
    node [fillcolor="#FFF176"]

    MAST_REST    [label="Resting\nMast Cell"]
    MAST_ACT     [label="Activated\nMast Cell"]
    BASOPHIL     [label="Basophil"]
    FceRI_XL     [label="FcεRI\nCross-linking"]
    SYK_M        [label="Syk kinase\n(FcεRI downstream)"]
    PLCG_M       [label="PLCγ → IP3/DAG\n→ Ca2+"]
    PI3K_M       [label="PI3K / Akt\n(mast cell)"]
    HISTAMINE    [label="Histamine\n(bronchospasm)"]
    PGD2_M       [label="PGD2\n(mast cell)"]
    LTC4_M       [label="LTC4/D4/E4\n(cysteinyl LTs)"]
    TRYPTASE_M   [label="Tryptase\n(marker)"]
    TNFa_M       [label="TNF-α\n(mast cell)"]
    IL6_M        [label="IL-6\n(mast cell)"]
    SCF_M        [label="SCF / c-Kit\n(mast cell growth)"]
  }

  /* ══════════════════════════════════════════════
     CLUSTER 8 – EOSINOPHIL
  ══════════════════════════════════════════════ */
  subgraph cluster_eos {
    label="Eosinophil Biology"
    style=filled; color="#E8EAF6"; fillcolor="#E8EAF6"
    node [fillcolor="#7986CB"]

    EOS_BM       [label="Eosinophil\nProgenitor (BM)"]
    EOS_BLOOD    [label="Blood Eosinophil\n(cells/μL)"]
    EOS_TISSUE   [label="Tissue Eosinophil\n(airway wall)"]
    EOS_ACT      [label="Activated\nEosinophil"]
    EOS_APOP     [label="Eosinophil\nApoptosis"]
    IL5R_E       [label="IL-5Rα\n(eosinophil)"]
    SIGLEC8_E    [label="Siglec-8\n(apoptosis signal)"]
    MBP_ECP      [label="MBP / ECP / EDN\n(granule proteins)"]
    EOTAXIN_E    [label="Eotaxin-1/2/3\n(CCL11/24/26)"]
    CCR3_E       [label="CCR3\n(eosinophil chemo-R)"]
    VCAM1_E      [label="VCAM-1 / VLA-4\n(adhesion)"]
    LTC4_E       [label="LTC4\n(eosinophil)"]
    PAF_E        [label="PAF\n(platelet activ. factor)"]
    GATA1_E      [label="GATA-1 / C/EBPα\n(eos TF)"]
  }

  /* ══════════════════════════════════════════════
     CLUSTER 9 – AIRWAY SMOOTH MUSCLE
  ══════════════════════════════════════════════ */
  subgraph cluster_asm {
    label="Airway Smooth Muscle & Bronchoconstriction"
    style=filled; color="#EFEBE9"; fillcolor="#EFEBE9"
    node [fillcolor="#A1887F"]

    ASM          [label="Airway Smooth\nMuscle (ASM)"]
    ASM_CONT     [label="ASM Contraction\n(bronchoconstriction)"]
    ASM_RELX     [label="ASM Relaxation\n(bronchodilation)"]
    ASM_HYPER    [label="ASM Hypertrophy\n(remodeling)"]
    CA_ASM       [label="[Ca2+]i\n(ASM)"]
    MLCK_A       [label="MLCK\n(myosin light-chain K)"]
    MLC_P        [label="MLC\nphosphorylation"]
    ROCK_A       [label="RhoA / ROCK\n(Ca2+ sensitization)"]
    cAMP_A       [label="cAMP\n(bronchodilation)"]
    PKA_A        [label="PKA\n(MLCK inhibition)"]
    B2AR_A       [label="β2-adrenergic R"]
    M3R_A        [label="M3 muscarinic R"]
    H1R_A        [label="H1 receptor\n(histamine)"]
    CysLT_R      [label="CysLT1/2\nreceptors"]
    DP_R         [label="DP1/DP2\nreceptors"]
    TRPA1_A      [label="TRPA1 / TRPV1\n(irritant sensor)"]
    AHR_A        [label="Airway\nHyperresponsiveness\n(AHR)"]
  }

  /* ══════════════════════════════════════════════
     CLUSTER 10 – MUCUS & GOBLET CELL
  ══════════════════════════════════════════════ */
  subgraph cluster_mucus {
    label="Mucus Hypersecretion & Goblet Cell Metaplasia"
    style=filled; color="#F1F8E9"; fillcolor="#F1F8E9"
    node [fillcolor="#AED581"]

    GOBLET_C     [label="Goblet Cell\n(hyperplasia)"]
    MUC5AC_G     [label="MUC5AC\n(major mucin)"]
    MUC5B_G      [label="MUC5B\n(minor mucin)"]
    MUCUS_PLUG   [label="Mucus Plugging\n(airway obstruction)"]
    SAM_G        [label="Submucosal Gland\nHypertrophy"]
    SPDEF_G      [label="SPDEF\n(goblet cell TF)"]
    FOXA2_G      [label="FOXA2\n(club cell TF,\ninhibitor)"]
    CLCA1_G      [label="CLCA1\n(Cl- channel / mucus)"]
  }

  /* ══════════════════════════════════════════════
     CLUSTER 11 – AIRWAY REMODELING
  ══════════════════════════════════════════════ */
  subgraph cluster_remodel {
    label="Structural Airway Remodeling"
    style=filled; color="#E0F2F1"; fillcolor="#E0F2F1"
    node [fillcolor="#4DB6AC"]

    FIBRO_R      [label="Airway\nFibroblast"]
    MYOFIB_R     [label="Myofibroblast\n(α-SMA+)"]
    TGFB_R       [label="TGF-β1\n(fibrogenic)"]
    SMAD23_R     [label="SMAD2/3\n(TGF-β signal)"]
    COLLAGEN_R   [label="Subepithelial\nCollagen Deposition"]
    BM_THICK     [label="Basement Membrane\nThickening"]
    VEGF_R       [label="VEGF\n(angiogenesis)"]
    FGF2_R       [label="FGF-2\n(ASM proliferat)"]
    PERIOSTIN_R  [label="Periostin\n(ECM marker)"]
    MMP29_R      [label="MMP-2/9\n(ECM remodeling)"]
    TIMP_R       [label="TIMP-1/2\n(MMP inhibitor)"]
    ASM_MASS_R   [label="ASM Mass\nIncrease"]
    SENSORY_N    [label="Sensory Nerve\n(neuroplasticity)"]
  }

  /* ══════════════════════════════════════════════
     CLUSTER 12 – NEUROGENIC INFLAMMATION
  ══════════════════════════════════════════════ */
  subgraph cluster_neuro {
    label="Neurogenic Inflammation & Autonomic Reflex"
    style=filled; color="#FBE9E7"; fillcolor="#FBE9E7"
    node [fillcolor="#FF8A65"]

    VAGAL_N      [label="Vagal Afferent"]
    SP_N         [label="Substance P (SP)"]
    CGRP_N       [label="CGRP\n(vasodilation)"]
    NK1R_N       [label="NK1 receptor\n(SP)"]
    PARA_N       [label="Parasympathetic\nActivation"]
    ACh_N        [label="Acetylcholine\n(bronchoconstrict)"]
    NE_N         [label="Norepinephrine\n(bronchodilation)"]
    VIP_N        [label="VIP\n(bronchodilator)"]
    NGF_N        [label="NGF\n(neuroplasticity)"]
  }

  /* ══════════════════════════════════════════════
     CLUSTER 13 – LUNG FUNCTION & CLINICAL
  ══════════════════════════════════════════════ */
  subgraph cluster_clinical {
    label="Lung Function & Clinical Endpoints"
    style=filled; color="#F9FBE7"; fillcolor="#F9FBE7"
    node [fillcolor="#AFB42B"]

    FEV1_C       [label="FEV1\n(% predicted)"]
    FVC_C        [label="FVC"]
    FEV1FVC_C    [label="FEV1/FVC ratio"]
    PEF_C        [label="PEF\n(peak expiratory\nflow)"]
    EXACERB_C    [label="Exacerbation\nRate (annualized)"]
    SABA_USE_C   [label="Rescue SABA\nuse/week"]
    ACQ_C        [label="ACQ-5/7\n(asthma control\nquestionnaire)"]
    AQLQ_C       [label="AQLQ\n(quality of life)"]
    SYMSCORE_C   [label="Symptom Score\n(daytime/night)"]
    FeNO_C       [label="FeNO (ppb)\n(type-2 marker)"]
    PC20_C       [label="PC20\n(methacholine\nchallenge)"]
    SPUTEOS_C    [label="Sputum\nEosinophil %"]
  }

  /* ══════════════════════════════════════════════
     CLUSTER 14 – BIOMARKERS
  ══════════════════════════════════════════════ */
  subgraph cluster_biom {
    label="Biomarkers & Type-2 Endotype"
    style=filled; color="#EDE7F6"; fillcolor="#EDE7F6"
    node [fillcolor="#9575CD"]

    BLD_EOS_B    [label="Blood Eosinophil\n(cells/μL)"]
    FENO_B       [label="FeNO\n(ppb)"]
    SERUM_IgE_B  [label="Serum Total IgE\n(kU/L)"]
    PERIOSTIN_B  [label="Serum Periostin\n(ng/mL)"]
    TRYPTASE_B   [label="Serum Tryptase\n(μg/L)"]
    IL6_B        [label="Serum IL-6\n(pg/mL)"]
    CRP_B        [label="CRP\n(asthma severity)"]
    T2HIGH_B     [label="Type-2 High\nEndotype\n(BldEos≥300 or\nFeNO≥25)"]
    T2LOW_B      [label="Type-2 Low\nEndotype\n(neutrophilic/\npaucigranulocytic)"]
    GALECTIN_B   [label="Galectin-3\n(eosinophil recruit)"]
  }

  /* ══════════════════════════════════════════════
     CLUSTER 15 – DRUG PK
  ══════════════════════════════════════════════ */
  subgraph cluster_pk {
    label="Drug Pharmacokinetics"
    style=filled; color="#F5F5F5"; fillcolor="#F5F5F5"
    node [fillcolor="#BDBDBD"]

    OMAL_SC_PK   [label="Omalizumab\nSC depot"]
    OMAL_C_PK    [label="Omalizumab\nCentral"]
    MEPO_SC_PK   [label="Mepolizumab\nSC depot"]
    MEPO_C_PK    [label="Mepolizumab\nCentral"]
    BENZ_SC_PK   [label="Benralizumab\nSC depot"]
    BENZ_C_PK    [label="Benralizumab\nCentral"]
    DUPIL_SC_PK  [label="Dupilumab\nSC depot"]
    DUPIL_C_PK   [label="Dupilumab\nCentral"]
    TEZE_SC_PK   [label="Tezepelumab\nSC depot"]
    TEZE_C_PK    [label="Tezepelumab\nCentral"]
    ICS_LUNG_PK  [label="ICS\n(lung deposition)"]
    ICS_SYS_PK   [label="ICS\n(systemic)"]
    LABA_PK      [label="LABA\n(lung)"]
    LAMA_PK      [label="LAMA\n(lung)"]
    MONT_PK      [label="Montelukast\n(systemic)"]
    GR_PK        [label="Glucocorticoid R\n(GR)"]
  }

  /* ══════════════════════════════════════════════
     CLUSTER 16 – DRUG MECHANISMS
  ══════════════════════════════════════════════ */
  subgraph cluster_mech {
    label="Drug Mechanisms & PD Effects"
    style=filled; color="#EEEEEE"; fillcolor="#EEEEEE"
    node [fillcolor="#757575", fontcolor="white"]

    OMAL_PD   [label="Omalizumab →\nFree IgE ↓\n(TMDD)"]
    MEPO_PD   [label="Mepolizumab →\nIL-5 neutralize"]
    BENZ_PD   [label="Benralizumab →\nIL-5Rα ADCC →\nEos near-depletion"]
    DUPIL_PD  [label="Dupilumab →\nIL-4Rα block\n(IL-4+IL-13↓)"]
    TEZE_PD   [label="Tezepelumab →\nTSLP neutralize\n(T2+T3↓)"]
    ICS_PD    [label="ICS → GR →\ncytokine suppress\n(IL-5/IL-13/eotaxin↓)"]
    LABA_PD   [label="LABA → β2AR →\ncAMP↑ → ASM relax"]
    LAMA_PD   [label="LAMA → M3R block\n→ ACh effect↓"]
    SABA_PD   [label="SABA → β2AR →\nrapid ASM relax\n(rescue)"]
    MONT_PD   [label="Montelukast →\nCysLT1 block →\nbronchoprotect"]
    AZITH_PD  [label="Azithromycin →\nanti-inflam\n(neutrophilic)"]
    THEOPH_PD [label="Theophylline →\nPDE inhib\n→ cAMP/cGMP↑"]
  }

  /* ══════════════════════════════════════════════
     EDGES – TRIGGERS → EPITHELIUM
  ══════════════════════════════════════════════ */
  ALLERGEN    -> PROTEASE_E  [label="activates"]
  ALLERGEN    -> EPITHELIUM  [label="damages"]
  VIRUS       -> HRV_TLR     [label="senses"]
  HRV_TLR     -> IFN_LAM
  HRV_TLR     -> IL33        [label="releases"]
  POLLUTANT   -> ROS_EPI
  COLD_AIR    -> TRPA1_A     [label="activates"]
  SMOKE_T     -> ROS_EPI
  STRESS_T    -> PARA_N      [label="↑"]
  ASPIRIN_T   -> CysLT_R     [label="LT shunt →\n↑CysLT"]
  OCCUPATIONAL-> EPITHELIUM
  PROTEASE_E  -> TJ_BARRIER  [label="disrupts", style=dashed, color=red]
  PROTEASE_E  -> TSLP        [label="induces"]
  PROTEASE_E  -> IL33        [label="releases"]
  PROTEASE_E  -> IL25        [label="induces"]
  EPITHELIUM  -> TSLP        [label="produces"]
  EPITHELIUM  -> IL25        [label="produces"]
  EPITHELIUM  -> IL33        [label="produces"]
  EPITHELIUM  -> PGE2_EPI
  EPITHELIUM  -> AMPs
  EPITHELIUM  -> MUC5AC_EPI
  ROS_EPI     -> EGFR_EPI    [label="activates"]
  EGFR_EPI    -> TSLP        [label="→"]
  IL33        -> ST2R        [label="binds"]
  TSLP        -> TSLPR       [label="binds"]

  /* EPITHELIUM → ILC2 */
  TSLP        -> ILC2        [label="activates"]
  IL25        -> ILC2        [label="activates"]
  ST2R        -> ILC2_ACT   [label="→"]
  PGD2_M      -> CRTH2       [label="binds"]
  CRTH2       -> ILC2_ACT   [label="activates"]
  ILC2        -> ILC2_ACT   [label="differentiates"]
  GATA3_ILC2  -> ILC2_ACT
  ILC2_ACT   -> IL4_I
  ILC2_ACT   -> IL5_I
  ILC2_ACT   -> IL13_I
  KLRG1       -> ILC2_ACT   [label="inhibits", style=dashed, color=red]

  /* DENDRITIC CELLS */
  TSLP        -> DC_IMM      [label="matures/Th2\npolarizes"]
  ALLERGEN    -> DC_IMM      [label="antigen\nuptake"]
  DC_IMM      -> DC_MAT
  DC_MAT      -> MHCII
  TSLP        -> THYMIC_S
  THYMIC_S    -> OX40L_DC   [label="upregulates"]
  DC_MAT      -> OX40L_DC   [label="expresses"]

  /* Th2 DIFFERENTIATION */
  MHCII       -> TCR_ACT    [label="presentation"]
  TCR_ACT     -> NAIVE_T    [label="activates"]
  IL4_I       -> GATA3_T    [label="drives Th2"]
  OX40L_DC    -> TH2        [label="promotes"]
  NAIVE_T     -> TH2        [label="→ Th2\n(IL-4+OX40L)"]
  NAIVE_T     -> TH1        [label="→ Th1\n(IFN-γ)"]
  NAIVE_T     -> TH17       [label="→ Th17\n(IL-6+TGFβ)"]
  NAIVE_T     -> TREG       [label="→ Treg\n(TGFβ)"]
  GATA3_T     -> TH2
  TBET_T      -> TH1
  RORC_T      -> TH17
  TH2         -> IL4_T
  TH2         -> IL5_T
  TH2         -> IL13_T
  TH2         -> IL9_T
  TH2         -> IL21_T
  TREG        -> IL10_T
  TH17        -> IL17A_T
  IL4_T       -> STAT6_T
  IL13_T      -> STAT6_T
  IL5_T       -> STAT5_T
  OX40_T      -> TH2
  ICOS_T      -> TH2
  NFkB_T      -> TH2
  NFAT_T      -> TH2

  /* B CELL / IgE */
  IL4_T       -> AID_CSR    [label="IgE class-switch"]
  IL21_T      -> GC_REACT   [label="promotes"]
  BCELL       -> GC_REACT
  GC_REACT    -> PLASMA_C
  AID_CSR     -> PLASMA_C   [label="IgE CSR"]
  BAFF_B      -> BCELL      [label="survival"]
  APRIL_B     -> PLASMA_C   [label="survival"]
  PLASMA_C    -> IgE_TOTAL  [label="secretes"]
  IgE_TOTAL   -> IgE_FREE
  IgE_FREE    -> IgE_BOUND  [label="binds FcεRI"]
  IgE_FREE    -> FceRII_CD23[label="binds CD23"]
  FceRI       -> IgE_BOUND

  /* MAST CELL */
  IgE_BOUND   -> FceRI_XL  [label="allergen\ncross-links"]
  FceRI_XL    -> SYK_M     [label="activates"]
  SYK_M       -> PLCG_M
