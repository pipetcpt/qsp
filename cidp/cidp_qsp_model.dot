digraph CIDP_QSP {
  graph [
    label="CIDP — Chronic Inflammatory Demyelinating Polyneuropathy\nComprehensive QSP Mechanistic Map",
    labelloc=t, fontsize=22, fontname="Helvetica-Bold",
    rankdir=LR, splines=curved,
    nodesep=0.3, ranksep=0.7,
    bgcolor="#F8F9FA",
    compound=true
  ];
  node [fontname="Helvetica", fontsize=9, style="filled,rounded", shape=box, margin="0.1,0.05"];
  edge [fontname="Helvetica", fontsize=7, arrowsize=0.55];

  // =========================================================
  // CLUSTER 1: Genetic & Environmental Risk Factors
  // =========================================================
  subgraph cluster_01_genetics {
    label="Genetic & Environmental Risk\nFactors"; style=filled; color="#E8EAF6";
    fontcolor="#283593"; fontsize=12;

    HLA_DR    [label="HLA-DRB1*15\nrisk allele",    fillcolor="#9FA8DA"];
    HLA_A     [label="HLA-A*02:01\nprotective?",    fillcolor="#9FA8DA"];
    PTPN22    [label="PTPN22 variant\nT/B hyperact.", fillcolor="#7986CB"];
    CTLA4_gene[label="CTLA4 polymorphism\ncheckpoint loss", fillcolor="#5C6BC0", fontcolor=white];
    IRF5_gene [label="IRF5 variant\nIFN pathway",   fillcolor="#3F51B5", fontcolor=white];
    Campylo   [label="Campylobacter\npreceding infect.", fillcolor="#C5CAE9"];
    CMV_EBV   [label="CMV / EBV\nviral trigger",   fillcolor="#C5CAE9"];
    Mol_mim   [label="Molecular\nMimicry",          fillcolor="#9FA8DA"];
    Vaccine   [label="Vaccination\nrare trigger",   fillcolor="#C5CAE9"];
    Surgery   [label="Surgery / Trauma\ntrigger",   fillcolor="#C5CAE9"];
    Env_trigger[label="Environmental\nTriggers",    fillcolor="#E8EAF6"];
  }

  // =========================================================
  // CLUSTER 2: Innate Immunity
  // =========================================================
  subgraph cluster_02_innate {
    label="Innate Immunity & Antigen Presentation"; style=filled; color="#FFF3E0";
    fontcolor="#E65100"; fontsize=12;

    pDC      [label="Plasmacytoid DC\nIFN-a/b",       fillcolor="#FFCC80"];
    mDC      [label="Myeloid DC\nantigen present.",    fillcolor="#FFB74D"];
    M0_Mac   [label="M0 Macrophage\nresting",          fillcolor="#FFA726"];
    M1_Mac   [label="M1 Macrophage\npro-inflam.",      fillcolor="#F57C00", fontcolor=white];
    M2_Mac   [label="M2 Macrophage\nanti-inflam.",     fillcolor="#8BC34A", fontcolor=white];
    NK_cell  [label="NK Cell\nADCC",                   fillcolor="#FFAB40"];
    Neutrophil[label="Neutrophil\nacute inflam.",      fillcolor="#FFCC02"];
    IFN_ab   [label="IFN-a/b\ntype I interferon",      fillcolor="#FFECB3"];
    TLR_inn  [label="TLR2/4/9\ninnate PAMP sensor",    fillcolor="#FFE082"];
    NLRP3    [label="NLRP3\nInflammasome",             fillcolor="#FF8F00", fontcolor=white];
    TNFa     [label="TNF-a\ninflam. master",           fillcolor="#FF6F00", fontcolor=white];
    IL1B     [label="IL-1b\ninflammasome",             fillcolor="#BF360C", fontcolor=white];
    IL6_inn  [label="IL-6\nacute / Th17",             fillcolor="#FF7043", fontcolor=white];
    IL18     [label="IL-18\nNK/Th1",                  fillcolor="#FFAB40"];
    FcgR_inn [label="FcgRIIA/III\nIgG-IC sensor",      fillcolor="#FF8F00", fontcolor=white];
    DAMP     [label="DAMPs\nalarmins/HMGB1",           fillcolor="#FFECB3"];
  }

  // =========================================================
  // CLUSTER 3: T Cell Immunity
  // =========================================================
  subgraph cluster_03_tcell {
    label="Adaptive T Cell Immunity"; style=filled; color="#E3F2FD";
    fontcolor="#0D47A1"; fontsize=12;

    APC_main [label="Antigen-Presenting\nCell (APC)",     fillcolor="#90CAF9"];
    MHC2     [label="MHC-II Antigen\nComplex",           fillcolor="#64B5F6"];
    TCR      [label="TCR / CD3\nComplex",                fillcolor="#42A5F5"];
    CD28     [label="CD28\ncostimulation",               fillcolor="#2196F3", fontcolor=white];
    CD4_T    [label="CD4+ T Cell\nhelper naive",          fillcolor="#1E88E5", fontcolor=white];
    Th1      [label="Th1 Cell\nIFN-g / TNF-a",          fillcolor="#1565C0", fontcolor=white];
    Th17     [label="Th17 Cell\nIL-17A / IL-17F",        fillcolor="#0D47A1", fontcolor=white];
    Tfh      [label="T Follicular Helper\nIL-21 CXCR5",  fillcolor="#1976D2", fontcolor=white];
    Treg     [label="Treg\nFoxP3 IL-10 TGF-b",          fillcolor="#43A047", fontcolor=white];
    CD8_T    [label="CD8+ CTL\nnerve infiltrate",         fillcolor="#5C6BC0", fontcolor=white];
    IL12     [label="IL-12\nTh1 polarizer",              fillcolor="#BBDEFB"];
    IL21     [label="IL-21\nGC B-cell help",             fillcolor="#BBDEFB"];
    TGFb_T   [label="TGF-b\nTreg / Th17",               fillcolor="#C8E6C9"];
    IL10_T   [label="IL-10\nanti-inflam.",               fillcolor="#C8E6C9"];
    CXCR3    [label="CXCR3\nT-cell homing",              fillcolor="#90CAF9"];
    CD40L    [label="CD40L (CD154)\nT-B cooperation",     fillcolor="#64B5F6"];
    CTLA4    [label="CTLA-4\ncheckpoint",                fillcolor="#9FA8DA"];
    PD1      [label="PD-1/PD-L1\nexhaustion",            fillcolor="#9FA8DA"];
  }

  // =========================================================
  // CLUSTER 4: B Cell & Autoantibodies
  // =========================================================
  subgraph cluster_04_bcell {
    label="B Cell Activation & Autoantibody Production"; style=filled; color="#FFF8E1";
    fontcolor="#F57F17"; fontsize=12;

    BCR      [label="BCR\nantigen recog.",               fillcolor="#FFF9C4"];
    Naive_B  [label="Naive B Cell\nIgM+IgD+",           fillcolor="#FFF176"];
    GC       [label="Germinal Center\naffinity matur.",  fillcolor="#FFEE58"];
    MemB     [label="Memory B Cell\nlong-lived",          fillcolor="#FDD835"];
    PlasmaB  [label="Plasmablast\nshort-lived",          fillcolor="#F9A825", fontcolor=white];
    LLPlasma [label="Long-lived\nPlasma Cell (LLPC)",    fillcolor="#F57F17", fontcolor=white];
    IgG_tot  [label="Total IgG\nserum ~12 g/L",         fillcolor="#E65100", fontcolor=white];
    IgG4_tot [label="IgG4 Subclass\n<5% total",         fillcolor="#BF360C", fontcolor=white];
    AntiNF155[label="Anti-NF155\nIgG4 paranodal",        fillcolor="#7B1FA2", fontcolor=white];
    AntiCNTN1[label="Anti-CNTN1\nIgG4 paranodal",        fillcolor="#6A1B9A", fontcolor=white];
    AntiCASPR[label="Anti-CASPR1\nIgG1 nodal",          fillcolor="#4A148C", fontcolor=white];
    AntiNF186[label="Anti-NF186\npan-NF nodal",         fillcolor="#311B92", fontcolor=white];
    BAFF     [label="BAFF/BLyS\nB-cell survival",        fillcolor="#FFF9C4"];
    APRIL    [label="APRIL\nLLPC survival",              fillcolor="#FFF9C4"];
    FcRn_B   [label="FcRn\nIgG homeostasis",            fillcolor="#FFCC02"];
    PI3Kd    [label="PI3Kd\nBCR signaling",             fillcolor="#FFF176"];
    IL21_B   [label="IL-21\nGC expansion",              fillcolor="#FFF176"];
    IL4      [label="IL-4\nIgG4 class switch",          fillcolor="#BBDEFB"];
  }

  // =========================================================
  // CLUSTER 5: Complement System
  // =========================================================
  subgraph cluster_05_complement {
    label="Complement Cascade"; style=filled; color="#FFEBEE";
    fontcolor="#B71C1C"; fontsize=12;

    Comp_classic[label="Classical Pathway\nAb-C1qrs",  fillcolor="#EF9A9A"];
    Comp_lectin [label="Lectin Pathway\nMBL",          fillcolor="#EF9A9A"];
    Comp_alt    [label="Alternative Pathway\nC3b",     fillcolor="#EF9A9A"];
    C1q         [label="C1q\nIgG1/3 sensing",          fillcolor="#EF5350", fontcolor=white];
    C4b2a       [label="C3 Convertase\nC4b2a",         fillcolor="#E53935", fontcolor=white];
    C3          [label="C3\npivotal comp.",             fillcolor="#C62828", fontcolor=white];
    C3b         [label="C3b\nopsonin",                  fillcolor="#B71C1C", fontcolor=white];
    C3a         [label="C3a\nanaphylatoxin",            fillcolor="#FFCDD2"];
    C5conv      [label="C5 Convertase\nC3bBbC3b",       fillcolor="#E53935", fontcolor=white];
    C5          [label="C5\nterminal",                  fillcolor="#C62828", fontcolor=white];
    C5a         [label="C5a\nchemoattractant",          fillcolor="#FFCDD2"];
    MAC         [label="C5b-9 / MAC\nmembrane attack",  fillcolor="#B71C1C", fontcolor=white];
    CD59_prot   [label="CD59\nMAC inhibitor",           fillcolor="#A5D6A7"];
    C1INH       [label="C1-INH\nserpin regulator",      fillcolor="#A5D6A7"];
    Factor_H    [label="Factor H\nAltPath regulator",   fillcolor="#A5D6A7"];
    Factor_I    [label="Factor I\nC3b cleavage",        fillcolor="#A5D6A7"];
  }

  // =========================================================
  // CLUSTER 6: Blood-Nerve Barrier
  // =========================================================
  subgraph cluster_06_BNB {
    label="Blood-Nerve Barrier (BNB)"; style=filled; color="#F0F4C3";
    fontcolor="#33691E"; fontsize=12;

    TJ_BNB        [label="Tight Junctions\nclaudin-5 ZO-1", fillcolor="#AED581"];
    MMP9          [label="MMP-9\ngelatinase B",         fillcolor="#8D6E63"];
    MMP2          [label="MMP-2\ngelatinase A",         fillcolor="#8D6E63"];
    VEGF          [label="VEGF-A\nvasopermeability",    fillcolor="#CDDC39"];
    VCAM1         [label="VCAM-1\nadhesion",            fillcolor="#FFAB40"];
    ICAM1         [label="ICAM-1\nadhesion",            fillcolor="#FFAB40"];
    E_Selectin    [label="E/P-Selectin\nrolling",       fillcolor="#FFD54F"];
    Integrin_a4   [label="a4b1-Integrin\nT-cell bind.", fillcolor="#FFE082"];
    BNB_perm      [label="BNB Permeability\nincreased", fillcolor="#FF8F00", fontcolor=white];
    IgG_entry     [label="IgG Entry\ninto Endoneurium", fillcolor="#FFB300"];
    T_entry       [label="T Cell Entry\ninto Nerve",    fillcolor="#FF6F00", fontcolor=white];
    Edema         [label="Endoneurial\nEdema",          fillcolor="#FFF3E0"];
    ECM_rmdl      [label="ECM\nRemodeling",             fillcolor="#D7CCC8"];
    T_BNB_cross   [label="T Cell\nTransmigration",      fillcolor="#FF6F00", fontcolor=white];
  }

  // =========================================================
  // CLUSTER 7: Peripheral Nerve Anatomy
  // =========================================================
  subgraph cluster_07_nerve_anat {
    label="Peripheral Nerve Anatomy & Nodal Proteins"; style=filled; color="#E8F5E9";
    fontcolor="#1B5E20"; fontsize=12;

    Node_Rv   [label="Node of Ranvier\nsaltatory conduct.", fillcolor="#66BB6A"];
    Paranode  [label="Paranodal\nJunction",             fillcolor="#43A047", fontcolor=white];
    Juxtapar  [label="Juxtaparanodal\nRegion",          fillcolor="#388E3C", fontcolor=white];
    Internode [label="Internode\ncompact myelin",        fillcolor="#2E7D32", fontcolor=white];
    NF155_pr  [label="NF155\nSchwann paranodal",         fillcolor="#1B5E20", fontcolor=white];
    CNTN1_pr  [label="CNTN1\naxon paranodal",           fillcolor="#1B5E20", fontcolor=white];
    CASPR1_pr [label="CASPR1\naxon paranodal",          fillcolor="#1B5E20", fontcolor=white];
    NF186_pr  [label="NF186\naxon nodal",               fillcolor="#1B5E20", fontcolor=white];
    Gliomedin [label="Gliomedin\nnodal anchor",          fillcolor="#4CAF50", fontcolor=white];
    Nav16     [label="Nav1.6\nNa+ channel node",         fillcolor="#81C784"];
    Kv11_12   [label="Kv1.1/Kv1.2\nK+ juxtapara.",      fillcolor="#81C784"];
    MBP_pr    [label="MBP\nmyelin basic prot.",          fillcolor="#A5D6A7"];
    P0_pr     [label="P0/MPZ\ncompact myelin",           fillcolor="#A5D6A7"];
    PMP22     [label="PMP22\ncompact myelin",            fillcolor="#A5D6A7"];
    Cx32_pr   [label="Connexin-32\nincisure gap jnct.",  fillcolor="#A5D6A7"];
    Schwann_c [label="Schwann Cell\nmyelinating",         fillcolor="#388E3C", fontcolor=white];
    Axon_pr   [label="Axon\nsignal propagation",          fillcolor="#66BB6A"];
    DRG_cell  [label="Dorsal Root Ganglion\nsensory neuron", fillcolor="#AED6F1"];
    NfL_pr    [label="Neurofilament\nLight (NfL)",        fillcolor="#43A047", fontcolor=white];
    NfH_pr    [label="Neurofilament\nHeavy (NfH)",        fillcolor="#43A047", fontcolor=white];
  }

  // =========================================================
  // CLUSTER 8: Demyelination & Axonal Injury
  // =========================================================
  subgraph cluster_08_demyelin {
    label="Demyelination, Axonal Injury & Repair"; style=filled; color="#ECEFF1";
    fontcolor="#263238"; fontsize=12;

    Myelin_sh    [label="Myelin Sheath\ncompact+non-compact", fillcolor="#CFD8DC"];
    Demyelin     [label="Segmental\nDemyelination",           fillcolor="#B0BEC5", shape=ellipse];
    Paranodal_dis[label="Paranodal\nDisruption",              fillcolor="#B0BEC5"];
    Onion_bulb   [label="Onion Bulb\nFormation",              fillcolor="#90A4AE"];
    Slowed_NCV   [label="Slowed NCV\ncond. vel. decreased",   fillcolor="#78909C", fontcolor=white];
    Cond_block   [label="Conduction\nBlock focal",            fillcolor="#607D8B", fontcolor=white];
    Axonal_loss  [label="Secondary\nAxonal Loss",             fillcolor="#546E7A", fontcolor=white];
    Wallerian    [label="Wallerian\nDegeneration",            fillcolor="#455A64", fontcolor=white];
    SARM1        [label="SARM1\nprogrammed axon death",       fillcolor="#37474F", fontcolor=white];
    Remyelin     [label="Remyelination\nSchwann cell",         fillcolor="#66BB6A"];
    Nerve_repair [label="Functional\nRecovery",               fillcolor="#43A047", fontcolor=white];
  }

  // =========================================================
  // CLUSTER 9: Electrophysiology & Biomarkers
  // =========================================================
  subgraph cluster_09_biom {
    label="Electrophysiology & Clinical Biomarkers"; style=filled; color="#EDE7F6";
    fontcolor="#311B92"; fontsize=12;

    CMAP_amp [label="CMAP Amplitude\nmotor mV",          fillcolor="#CE93D8"];
    CNAP_amp [label="CNAP Amplitude\nsensory uV",        fillcolor="#CE93D8"];
    DML      [label="Distal Motor\nLatency ms increased", fillcolor="#BA68C8"];
    NCV_mot  [label="Motor NCV\nm/s decreased",          fillcolor="#AB47BC", fontcolor=white];
    NCV_sens [label="Sensory NCV\nm/s decreased",        fillcolor="#9C27B0", fontcolor=white];
    F_wave   [label="F-wave Latency\nms increased",      fillcolor="#8E24AA", fontcolor=white];
    H_reflex [label="H-reflex\nabsent in CIDP",          fillcolor="#7B1FA2", fontcolor=white];
    NfL_serum[label="Serum NfL\naxon damage marker",     fillcolor="#4A148C", fontcolor=white];
    NfH_serum[label="Serum pNfH\naxonal loss",           fillcolor="#4A148C", fontcolor=white];
    CSF_prot [label="CSF Protein\n>0.45 g/L elevated",  fillcolor="#D1C4E9"];
    CSF_IgG  [label="CSF IgG\nintrathecal synth.",       fillcolor="#D1C4E9"];
    AntiNF155_t[label="Anti-NF155\nIgG4 serum titer",   fillcolor="#7B1FA2", fontcolor=white];
    AntiCNTN1_t[label="Anti-CNTN1\nIgG4 serum titer",   fillcolor="#6A1B9A", fontcolor=white];
    INCAT    [label="INCAT Score\n0-10 disability",      fillcolor="#311B92", fontcolor=white];
    ONLS     [label="ONLS\n0-12 limitation",             fillcolor="#311B92", fontcolor=white];
    MRC_sum  [label="MRC Sum Score\n0-60 strength",      fillcolor="#311B92", fontcolor=white];
    I_RODS   [label="I-RODS\nRasch 0-48",               fillcolor="#4527A0", fontcolor=white];
    PGA      [label="Patient Global\nAssessment",        fillcolor="#D1C4E9"];
    Grip_str [label="Grip Strength\nkg Jamar",           fillcolor="#D1C4E9"];
    MRI_nerve[label="Nerve MRI\nSTIR hypertrophy",       fillcolor="#D1C4E9"];
    US_nerve [label="Nerve Ultrasound\nCSA enlargement", fillcolor="#D1C4E9"];
  }

  // =========================================================
  // CLUSTER 10: Drug PK - IVIG / SCIG
  // =========================================================
  subgraph cluster_10_IVIG {
    label="Drug PK: IVIG / SCIG"; style=filled; color="#FFF8E1";
    fontcolor="#F57F17"; fontsize=12;

    IVIG_dose    [label="IVIG\n2 g/kg IV q4w",           fillcolor="#FFF59D", shape=hexagon];
    SCIG_dose    [label="SCIG\n0.2 g/kg/wk SC",          fillcolor="#FFF176", shape=hexagon];
    IVIG_C1      [label="IVIG Central\nCompartment C1",  fillcolor="#FFEE58"];
    IVIG_C2      [label="IVIG Peripheral\nCompartment C2", fillcolor="#FDD835"];
    FcRn_free    [label="Free FcRn\nrecycling capacity", fillcolor="#FFB300"];
    FcRn_sat_d   [label="FcRn Saturation\ncatabolism x2-4", fillcolor="#FF8F00", fontcolor=white];
    IgG_catab    [label="IgG Catabolism\nFcRn-mediated", fillcolor="#E65100", fontcolor=white];
    IVIG_comp_sc [label="Complement\nScavenging",         fillcolor="#FFCC80"];
    IVIG_FcgR_bl [label="FcgR Blockade\nMac deactiv.",   fillcolor="#FFCC80"];
    IVIG_Treg_ex [label="Treg Expansion\nsialylated IgG", fillcolor="#C8E6C9"];
    IVIG_AntiIg  [label="Anti-Idiotype Ab\nneutralizes", fillcolor="#FFCC80"];
    IVIG_Sialyl  [label="Sialylated IgG\nDC-SIGN IL-33", fillcolor="#FFCC80"];
  }

  // =========================================================
  // CLUSTER 11: Drug PK - Steroids & PLEX
  // =========================================================
  subgraph cluster_11_CS_PLEX {
    label="Drug PK: Corticosteroids & Plasma Exchange (PLEX)"; style=filled;
    color="#FFEBEE"; fontcolor="#B71C1C"; fontsize=12;

    Pred_dose  [label="Prednisolone\n1 mg/kg/d PO",      fillcolor="#FFCDD2", shape=hexagon];
    Dex_dose   [label="Dexamethasone\n40 mg/d x4d IV",   fillcolor="#FFCDD2", shape=hexagon];
    PLEX_dose  [label="Plasma Exchange\n5x200 mL q2wk",  fillcolor="#E53935", shape=hexagon, fontcolor=white];
    CS_plasma  [label="CS Plasma\nConcentration",         fillcolor="#EF9A9A"];
    GR_rec     [label="GR Receptor\nGlucocorticoid",      fillcolor="#EF5350", fontcolor=white];
    NFkB_CS    [label="NF-kB Inhibition\ntransrepression", fillcolor="#C62828", fontcolor=white];
    AP1_CS     [label="AP-1 Inhibition\ntransrepression", fillcolor="#C62828", fontcolor=white];
    Annexin1   [label="Annexin-1\nanti-inflam.",          fillcolor="#FFCDD2"];
    CS_Th_inh  [label="Th1/Th17\nSuppression",            fillcolor="#FFAB40"];
    CS_IL10    [label="IL-10 increased\nGRE-mediated",    fillcolor="#C8E6C9"];
    PLEX_IgG   [label="IgG Removal\nPLEX 60%/session",   fillcolor="#E53935", fontcolor=white];
    PLEX_Comp  [label="Complement\nRemoval PLEX",         fillcolor="#E53935", fontcolor=white];
    CS_BMD_se  [label="Bone Density\nLoss side effect",   fillcolor="#CFD8DC"];
    CS_Gluc_se [label="Glucose\nIntolerance SE",          fillcolor="#CFD8DC"];
  }

  // =========================================================
  // CLUSTER 12: Drug PK - Biologics & Novel Agents
  // =========================================================
  subgraph cluster_12_biologics {
    label="Drug PK: Biologics & Novel FcRn / B-cell Agents"; style=filled;
    color="#E8F5E9"; fontcolor="#1B5E20"; fontsize=12;

    RTX_dose   [label="Rituximab\n1000 mg x2 IV q6mo",  fillcolor="#A5D6A7", shape=hexagon];
    Efc_dose   [label="Efgartigimod\n10 mg/kg IV q1w",  fillcolor="#81C784", shape=hexagon];
    Roz_dose   [label="Rozanolixizumab\n7 mg/kg SC qwk", fillcolor="#66BB6A", shape=hexagon, fontcolor=white];
    Bat_dose   [label="Batoclimab\n680 mg SC q4w",       fillcolor="#4CAF50", shape=hexagon, fontcolor=white];
    Ava_dose   [label="Avacopan\n30 mg BID PO",          fillcolor="#43A047", shape=hexagon, fontcolor=white];
    Cp_RTX     [label="Rituximab\nPlasma Conc.",         fillcolor="#A5D6A7"];
    Cp_Efc     [label="Efgartigimod\nPlasma Conc.",      fillcolor="#81C784"];
    RTX_TMDD   [label="TMDD CD20\ntarget-mediated disp.", fillcolor="#4CAF50", fontcolor=white];
    CD20_B     [label="CD20\nB-cell marker",             fillcolor="#388E3C", fontcolor=white];
    B_depl     [label="B-cell Depletion\n6+ months",     fillcolor="#2E7D32", fontcolor=white];
    RTX_ADCC   [label="ADCC / CDC\nNK complement lysis", fillcolor="#1B5E20", fontcolor=white];
    FcRn_blk_b [label="FcRn Blockade\nEfc/Roz/Bat",     fillcolor="#66BB6A", fontcolor=white];
    IgG_clr_b  [label="Accelerated IgG\nClearance 80%", fillcolor="#43A047", fontcolor=white];
    C5a_blk    [label="C5a Receptor\nBlock Avacopan",    fillcolor="#FF8A65"];
    Plasma_inh [label="Plasma Cell\nInhibition RTX",     fillcolor="#2E7D32", fontcolor=white];
  }

  // =========================================================
  // INTRA-CLUSTER EDGES
  // =========================================================

  // Cluster 1 internal
  Campylo -> Mol_mim; CMV_EBV -> Mol_mim;
  HLA_DR -> Mol_mim; HLA_A -> Mol_mim;
  Vaccine -> Env_trigger; Surgery -> Env_trigger;
  Campylo -> Env_trigger; CMV_EBV -> Env_trigger;

  // Cluster 2 internal
  TLR_inn -> M1_Mac; TLR_inn -> pDC;
  pDC -> IFN_ab; IFN_ab -> M1_Mac;
  FcgR_inn -> M1_Mac; FcgR_inn -> Neutrophil;
  DAMP -> NLRP3; M1_Mac -> NLRP3;
  NLRP3 -> IL1B; NLRP3 -> IL18;
  M1_Mac -> TNFa; M1_Mac -> IL1B; M1_Mac -> IL6_inn;
  M0_Mac -> M1_Mac [label="M1 polar."]; M0_Mac -> M2_Mac [label="M2 polar."];
  mDC -> M1_Mac; IL18 -> NK_cell; NK_cell -> M1_Mac [label="IFN-g"];
  IRF5_gene -> IFN_ab;

  // Cluster 3 internal
  APC_main -> MHC2; MHC2 -> TCR; TCR -> CD28; CD28 -> CD4_T;
  CD4_T -> Th1; IL12 -> Th1; CD4_T -> Th17;
  CD4_T -> Tfh; IL21 -> Tfh; CD4_T -> Treg; TGFb_T -> Treg;
  Treg -> IL10_T; Treg -> TGFb_T;
  IL10_T -> Th1 [label="suppresses"]; IL10_T -> M1_Mac [label="suppresses"];
  CD4_T -> CD40L; CD4_T -> CD8_T; CD4_T -> CXCR3; CD4_T -> PD1;
  CTLA4 -> Treg; PD1 -> CD4_T [label="brake"]; PD1 -> CD8_T [label="brake"];
  Th1 -> IL12 [label="autoamp."]; Th17 -> IL21;

  // Cluster 4 internal
  BCR -> Naive_B; BAFF -> Naive_B; CD40L -> Naive_B;
  IL21_B -> GC; Tfh -> GC; Naive_B -> GC;
  GC -> MemB; GC -> PlasmaB; GC -> LLPlasma;
  MemB -> PlasmaB; APRIL -> LLPlasma;
  PlasmaB -> IgG_tot; LLPlasma -> IgG_tot;
  IgG_tot -> IgG4_tot;
  IgG4_tot -> AntiNF155; IgG4_tot -> AntiCNTN1;
  IgG_tot -> AntiCASPR; IgG_tot -> AntiNF186;
  FcRn_B -> IgG_tot [label="recycles"]; IgG_tot -> FcRn_B [label="binds pH6"];
  PI3Kd -> Naive_B; BCR -> PI3Kd;
  IL4 -> GC [label="IgG4 class sw."]; IL21_B -> IL21;
  BAFF -> GC;

  // Cluster 5 internal
