digraph ATTR_QSP {
    graph [
        label="Transthyretin Amyloidosis (ATTR) QSP Model\nProtein Misfolding · Organ Damage · Pharmacological Interventions\n(TTR Stabilizers · siRNA · Antisense Oligonucleotides)",
        labelloc=t,
        fontname="Helvetica",
        fontsize=16,
        rankdir=TB,
        splines=ortho,
        nodesep=0.45,
        ranksep=0.85,
        compound=true
    ];
    node [fontname="Helvetica", fontsize=9, shape=box, style="rounded,filled", width=1.6];
    edge [fontname="Helvetica", fontsize=7];

    /* ─────────────────────────────────────────────
       Cluster 1: TTR Gene Expression & Protein Synthesis (Liver)
    ───────────────────────────────────────────── */
    subgraph cluster_synthesis {
        label="① TTR Synthesis & Processing (Liver Hepatocytes)";
        color="#1a5276"; style=filled; fillcolor="#d6eaf8"; fontsize=11;

        TTR_gene       [label="TTR Gene\n(Chromosome 18q12.1)", fillcolor="#85c1e9"];
        ATTRv_mutation [label="ATTRv Mutations\n(V30M, T60A, V122I\nS77Y, H110D, E89Q)", fillcolor="#f1948a"];
        ATTRwt         [label="Wild-type ATTR\n(Age-related ≥60yr\nMale predominance)", fillcolor="#f0b27a"];
        TTR_mRNA       [label="TTR mRNA\n(Hepatocytes, ~48h t½)", shape=ellipse, fillcolor="#a9dfbf"];
        pre_TTR        [label="pre-TTR Protein\n(Signal peptide, 147aa)", fillcolor="#d7bde2"];
        mature_TTR     [label="Mature TTR Monomer\n(127 aa, ~14 kDa)", fillcolor="#d7bde2"];
        TTR_folding    [label="Protein Folding\n(Native β-sheet conformation)", fillcolor="#a9dfbf"];
        TTR_tetramer   [label="TTR Tetramer\n(55 kDa, ~10 μg/mL plasma)", shape=diamond, fillcolor="#82e0aa"];
        T4_binding     [label="Thyroxine (T4)\nBinding Sites (2/tetramer)", fillcolor="#fad7a0"];
        retinol_bind   [label="Retinol-Binding Protein\n(RBP4) Complex", fillcolor="#fad7a0"];
        TTR_secretion  [label="TTR Secretion\n(~10 μg/mL normal plasma)", fillcolor="#85c1e9"];
        TTR_CSF        [label="TTR in CSF\n(Choroid plexus, 25%)", fillcolor="#aed6f1"];
    }

    /* ─────────────────────────────────────────────
       Cluster 2: Protein Misfolding & Aggregation Cascade
    ───────────────────────────────────────────── */
    subgraph cluster_misfolding {
        label="② Protein Misfolding & Amyloid Formation Cascade";
        color="#7d3c98"; style=filled; fillcolor="#f4ecf7"; fontsize=11;

        tet_dissoc     [label="Tetramer Dissociation\n(Rate-limiting step!)", shape=diamond, fillcolor="#c39bd3"];
        misfolded_mono [label="Misfolded Monomer\n(Partially unfolded)", fillcolor="#e8daef"];
        nucleation     [label="Nucleation\n(Thermodynamically\nunfavorable, slow)", fillcolor="#d2b4de"];
        oligomers      [label="Soluble Oligomers\n(Toxic intermediates!)", shape=diamond, fillcolor="#af7ac5"];
        protofibrils   [label="Protofibrils\n(β-sheet rich, ~50 nm)", fillcolor="#9b59b6"];
        amyloid_fibrils[label="Mature Amyloid Fibrils\n(Congo red+, Thioflavin S+)", shape=diamond, fillcolor="#7d3c98", fontcolor=white];

        serum_SAP      [label="Serum Amyloid P (SAP)\nFibril Stabilizer/Shield", fillcolor="#d5dbdb"];
        GAGs           [label="Glycosaminoglycans\n(Heparan sulfate, HS-PG)", fillcolor="#d5dbdb"];
        RAGE_path      [label="RAGE Receptor\nActivation", fillcolor="#e74c3c", fontcolor=white];

        proteostasis   [label="Proteostasis Network\n(Quality control)", fillcolor="#a9cce3"];
        HSP_system     [label="HSP70/HSP90/BiP\nChaperone System", fillcolor="#a9cce3"];
        UPS_deg        [label="Ubiquitin-Proteasome\nSystem (UPS)", fillcolor="#a9cce3"];
        ALP_deg        [label="Autophagy-Lysosomal\nPathway (ALP)", fillcolor="#a9cce3"];
        ERAD           [label="ER-Associated\nDegradation (ERAD)", fillcolor="#a9cce3"];
    }

    /* ─────────────────────────────────────────────
       Cluster 3: Cardiac Amyloidosis
    ───────────────────────────────────────────── */
    subgraph cluster_cardiac {
        label="③ Cardiac Amyloidosis — ATTRwt-CM >> ATTRv-CM";
        color="#c0392b"; style=filled; fillcolor="#fdedec"; fontsize=11;

        FIB_HRT        [label="Cardiac Amyloid Load\n(FIB_HRT, AU)", shape=diamond, fillcolor="#f1948a"];
        interstitial   [label="Interstitial\nInfiltration", fillcolor="#f5b7b1"];
        LV_wall_thick  [label="LV Wall Thickening\n(Biventricular, restrictive)", fillcolor="#e74c3c", fontcolor=white];
        diastolic_dysfx[label="Diastolic Dysfunction\n(Grade I→III, E/e'↑)", fillcolor="#f1948a"];
        systolic_dysfx [label="Systolic Dysfunction\n(LVEF decline)", fillcolor="#ec7063"];
        conduction_abn [label="Conduction Abnormalities\n(AV block, BBB, low voltage)", fillcolor="#e74c3c", fontcolor=white];
        AF_ATTR        [label="Atrial Fibrillation\n(High prevalence ~40%)", fillcolor="#f5b7b1"];
        SCD_risk       [label="Sudden Cardiac Death\n(Malignant arrhythmia)", fillcolor="#922b21", fontcolor=white];
        cardiac_inflam [label="Cardiac Inflammation\n(Macrophage M1 activation)", fillcolor="#f0b27a"];
        NLRP3_card     [label="NLRP3 Inflammasome\nActivation", fillcolor="#f0b27a"];
        IL1B_card      [label="IL-1β Cardiac\n(pro-inflammatory)", fillcolor="#f0b27a"];
        TNF_card       [label="TNF-α Cardiac\n(cardiomyocyte apoptosis)", fillcolor="#f0b27a"];
        CM_death       [label="Cardiomyocyte Apoptosis\n(Toxic oligomers mediated)", fillcolor="#e74c3c", fontcolor=white];
        cardiac_fib    [label="Cardiac Fibrosis\n(TGF-β, collagen↑)", fillcolor="#c0392b", fontcolor=white];
        HF_ATTR        [label="Heart Failure\n(HFpEF → HFrEF)", shape=diamond, fillcolor="#922b21", fontcolor=white];
        pericardial_eff[label="Pericardial Effusion\n(Elevated filling pressure)", fillcolor="#f5b7b1"];
    }

    /* ─────────────────────────────────────────────
       Cluster 4: Peripheral & Autonomic Neuropathy
    ───────────────────────────────────────────── */
    subgraph cluster_neuropathy {
        label="④ Peripheral & Autonomic Neuropathy — ATTRv >> ATTRwt";
        color="#1a5276"; style=filled; fillcolor="#eaf2fb"; fontsize=11;

        FIB_NRV        [label="Peripheral Nerve Amyloid\n(FIB_NRV, AU)", shape=diamond, fillcolor="#5dade2"];
        schwann_comp   [label="Schwann Cell\nCompression/Injury", fillcolor="#85c1e9"];
        axonal_degen   [label="Axonal Degeneration\n(Length-dependent, dying-back)", fillcolor="#3498db", fontcolor=white];
        small_fiber    [label="Small Fiber Neuropathy\n(Temperature, pain first)", fillcolor="#85c1e9"];
        large_fiber    [label="Large Fiber Neuropathy\n(Motor, vibration, later)", fillcolor="#5dade2"];
        DRG_comp       [label="Dorsal Root Ganglion\nCompression", fillcolor="#aed6f1"];
        CTS_early      [label="Carpal Tunnel Syndrome\n(Early manifestation 10-15yr prior)", fillcolor="#aed6f1"];
        autonomic_NP   [label="Autonomic Neuropathy\n(ANS dysfunction)", fillcolor="#2980b9", fontcolor=white];
        ortho_hypo     [label="Orthostatic Hypotension\n(Syncope, falls)", fillcolor="#85c1e9"];
        GI_dysmot      [label="GI Dysmotility\n(Diarrhea↔constipation)", fillcolor="#85c1e9"];
        bladder_dysfx  [label="Neurogenic Bladder\n(Incontinence, retention)", fillcolor="#aed6f1"];
        erectile_dysfx [label="Erectile Dysfunction\n(Pudendal nerve)", fillcolor="#aed6f1"];
        weight_loss    [label="Weight Loss\n& Malnutrition", fillcolor="#1a5276", fontcolor=white];
    }

    /* ─────────────────────────────────────────────
       Cluster 5: Extra-cardiac & Systemic Manifestations
    ───────────────────────────────────────────── */
    subgraph cluster_extracardiac {
        label="⑤ Extra-cardiac & Systemic Manifestations";
        color="#186a3b"; style=filled; fillcolor="#e9f7ef"; fontsize=11;

        ocular_ATTR    [label="Ocular Amyloidosis\n(Vitreous opacities, glaucoma)", fillcolor="#82e0aa"];
        leptomening    [label="Leptomeningeal\nAmyloidosis (CNS, ATTRv)", fillcolor="#52be80"];
        renal_ATTR     [label="Renal Amyloid\n(Mesangial → Proteinuria)", fillcolor="#27ae60", fontcolor=white];
        thyroid_ATTR   [label="Thyroid Involvement\n(Decreased T4 transport)", fillcolor="#a9dfbf"];
        retinol_def    [label="Retinol Deficiency\n(RBP4 disruption)", fillcolor="#a9dfbf"];
        spinal_stenosis[label="Spinal Canal Stenosis\n(Epidural deposition)", fillcolor="#82e0aa"];
        tendon_deposit [label="Tendon Deposits\n(Biceps tendon rupture)", fillcolor="#a9dfbf"];
        mBMI_decline   [label="Modified BMI Decline\n(mBMI = BMI×albumin g/m²)", fillcolor="#27ae60", fontcolor=white];
        FIB_SYS        [label="Systemic Amyloid\n(FIB_SYS, other organs)", shape=diamond, fillcolor="#58d68d"];
    }

    /* ─────────────────────────────────────────────
       Cluster 6: TTR Stabilizer PK/PD
    ───────────────────────────────────────────── */
    subgraph cluster_stabilizers {
        label="⑥ TTR Stabilizer PK/PD (Oral)";
        color="#7e5109"; style=filled; fillcolor="#fef9e7"; fontsize=11;

        tafamidis_dose [label="Tafamidis\n61mg QD (oral)\n[ATTR-ACT trial]", shape=pentagon, fillcolor="#f9e79f"];
        A_TAF_GUT      [label="Tafamidis Gut\n(A_TAF_GUT)", fillcolor="#f7dc6f"];
        A_TAF_C        [label="Tafamidis Central\n(C_TAF, t½~50-60h)", fillcolor="#f4d03f"];
        A_TAF_P        [label="Tafamidis Peripheral\n(A_TAF_P)", fillcolor="#f4d03f"];
        TAF_binding    [label="TTR T4-site Binding\n(Kd ~1 nM, 2 sites/tetramer)", fillcolor="#d4e6f1"];
        TAF_mechanism  [label="Tetramer Kinetic\nStabilization (Emax 80%)", fillcolor="#d4e6f1"];

        diflunisal_dose[label="Diflunisal\n250mg BID (oral)\n[non-TTR-specific NSAID]", shape=pentagon, fillcolor="#f9e79f"];
        DIF_C          [label="Diflunisal Central\n(C_DIF, t½~8-12h)", fillcolor="#f7dc6f"];

        acoramidis_dose[label="Acoramidis\n800mg BID (oral)\n[ATTRv-CM; ATTRiBUTE-CM]", shape=pentagon, fillcolor="#f9e79f"];
        ACO_C          [label="Acoramidis Central\n(Highly selective TTR binder)", fillcolor="#f7dc6f"];
    }

    /* ─────────────────────────────────────────────
       Cluster 7: RNA-Based Therapeutics PK/PD
    ───────────────────────────────────────────── */
    subgraph cluster_rna {
        label="⑦ RNA-Based Therapeutics PK/PD (Hepatocyte-targeted)";
        color="#145a32"; style=filled; fillcolor="#d5f5e3"; fontsize=11;

        patisiran_dose [label="Patisiran\n0.3 mg/kg IV Q3W\n[APOLLO trial]", shape=pentagon, fillcolor="#7fb3d3"];
        A_PAT_C        [label="Patisiran Central\n(A_PAT_C, LNP-siRNA)", fillcolor="#5dade2"];
        A_PAT_P        [label="Patisiran Peripheral\n(A_PAT_P)", fillcolor="#5dade2"];
        PAT_liver      [label="Hepatic LNP Uptake\n(ApoE-LDLR mediated)", fillcolor="#3498db", fontcolor=white];
        RISC_complex   [label="RISC Complex\n(siRNA-Ago2 loading)", fillcolor="#2980b9", fontcolor=white];
        mRNA_cleavage  [label="TTR mRNA Cleavage\n(Ago2-mediated, IC50~0.015nM)", fillcolor="#1a5276", fontcolor=white];

        vutrisiran_dose[label="Vutrisiran\n25 mg SC Q3M\n[HELIOS-A trial]", shape=pentagon, fillcolor="#7fb3d3"];
        A_VUT_SC       [label="Vutrisiran SC Depot\n(A_VUT_SC, GalNAc-siRNA)", fillcolor="#85c1e9"];
        A_VUT_C        [label="Vutrisiran Central\n(A_VUT_C, t½~5d)", fillcolor="#5dade2"];
        GalNAc_ASGR1   [label="GalNAc-ASGR1\nTargeted Delivery", fillcolor="#27ae60", fontcolor=white];

        inotersen_dose [label="Inotersen\n300 mg SC QW\n[NEURO-TTR trial]", shape=pentagon, fillcolor="#7fb3d3"];
        A_INO_SC       [label="Inotersen SC Depot\n(A_INO_SC, 2'-MOE ASO)", fillcolor="#85c1e9"];
        A_INO_C        [label="Inotersen Central\n(A_INO_C, t½~30d)", fillcolor="#5dade2"];
        RNaseH1_act    [label="RNase H1\nActivation → mRNA cleavage", fillcolor="#2980b9", fontcolor=white];

        eplontersen_dose[label="Eplontersen\n45 mg SC QM\n[GalNAc-ASO, NEURO-TTRansform]", shape=pentagon, fillcolor="#7fb3d3"];
    }

    /* ─────────────────────────────────────────────
       Cluster 8: Cardiac Biomarkers & Clinical Endpoints
    ───────────────────────────────────────────── */
    subgraph cluster_cardiac_endpoints {
        label="⑧ Cardiac Biomarkers & Clinical Endpoints";
        color="#922b21"; style=filled; fillcolor="#f9ebea"; fontsize=11;

        NT_proBNP_nd   [label="NT-proBNP\n(>300 ng/L = elevated)\n[Biomarker ODE]", shape=ellipse, fillcolor="#e74c3c", fontcolor=white];
        troponin_nd    [label="High-Sensitivity\nTroponin I/T (hsTnT)\n[Myocyte injury marker]", shape=ellipse, fillcolor="#e74c3c", fontcolor=white];
        LVEF_nd        [label="LVEF (%)\n(<50% = systolic HF)\n[Echo, CMR]", shape=ellipse, fillcolor="#e74c3c", fontcolor=white];
        LVMi_nd        [label="LV Mass Index\n(g/m² , wall thickness)", shape=ellipse, fillcolor="#f1948a"];
        E_e_ratio      [label="E/e' Ratio\n(Diastolic filling pressure)", shape=ellipse, fillcolor="#f1948a"];
        GLS_nd         [label="Global Longitudinal\nStrain (GLS, %)", shape=ellipse, fillcolor="#f1948a"];
        sixMWT_nd      [label="6-Minute Walk Test\n(6MWT, meters)", shape=ellipse, fillcolor="#f5b7b1"];
        KCCQ_nd        [label="Kansas City CM\nQuestionnaire (KCCQ)", shape=ellipse, fillcolor="#f5b7b1"];
        NYHA_nd        [label="NYHA Class\n(I–IV functional)", shape=ellipse, fillcolor="#f5b7b1"];
        cv_death       [label="Cardiovascular Death\n[Primary endpoint ATTR-ACT]", shape=diamond, fillcolor="#922b21", fontcolor=white];
        HF_hosp        [label="HF Hospitalization\n[Composite endpoint]", shape=diamond, fillcolor="#922b21", fontcolor=white];
    }

    /* ─────────────────────────────────────────────
       Cluster 9: Neurological Biomarkers & Endpoints
    ───────────────────────────────────────────── */
    subgraph cluster_neuro_endpoints {
        label="⑨ Neurological Biomarkers & Clinical Endpoints";
        color="#1a5276"; style=filled; fillcolor="#eaf2fb"; fontsize=11;

        NIS_nd         [label="Neuropathy Impairment\nScore (NIS, 0–244)\n[Biomarker ODE]", shape=ellipse, fillcolor="#2e86c1", fontcolor=white];
        mNIS_PLUS      [label="mNIS+7\n(Modified NIS, 0–304)\n[APOLLO primary endpoint]", shape=ellipse, fillcolor="#3498db", fontcolor=white];
        Norfolk_QoL    [label="Norfolk QoL-DN\n(Quality of Life, 0–136)", shape=ellipse, fillcolor="#5dade2"];
        FAP_stage      [label="FAP Stage\n(Stage 0/1/2/3)", shape=ellipse, fillcolor="#5dade2"];
        NCV_nd         [label="Nerve Conduction\nVelocity (NCV, m/s)", shape=ellipse, fillcolor="#85c1e9"];
        IENFD_nd       [label="Intraepidermal Nerve\nFiber Density (IENFD)", shape=ellipse, fillcolor="#85c1e9"];
        mBMI_nd        [label="Modified BMI\n(mBMI = BMI×albumin g/m²)\n[Nutritional status]", shape=ellipse, fillcolor="#1a5276", fontcolor=white];
        PND_stage      [label="Polyneuropathy\nDisability (PND) Score", shape=ellipse, fillcolor="#5dade2"];
        R_ODS          [label="Rasch-built Overall\nDisability Scale (R-ODS)", shape=ellipse, fillcolor="#85c1e9"];
    }

    /* ─────────────────────────────────────────────
       Cluster 10: Systemic Diagnostics & Safety Monitoring
    ───────────────────────────────────────────── */
    subgraph cluster_monitoring {
        label="⑩ Systemic Diagnostics & Safety Monitoring";
        color="#1b4f72"; style=filled; fillcolor="#d6eaf8"; fontsize=11;

        serum_TTR_nd   [label="Serum TTR Level\n(~10 μg/mL normal)\n[↓80% with siRNA/ASO]", shape=ellipse, fillcolor="#3498db", fontcolor=white];
        TTR_stab_assay [label="TTR Stability Assay\n(Tetramer:monomer ratio)", shape=ellipse, fillcolor="#5dade2"];
        Tc_PYP_scan    [label="⁹⁹ᵐTc-PYP / DPD Scan\n(Cardiac scintigraphy Gr 0–3)", shape=ellipse, fillcolor="#3498db", fontcolor=white];
        cardiac_CMR    [label="Cardiac MRI\n(LGE, ECV, T1/T2 mapping)", shape=ellipse, fillcolor="#3498db", fontcolor=white];
        echo_nd        [label="Echocardiography\n(Strain, speckle tracking)", shape=ellipse, fillcolor="#5dade2"];
        fat_biopsy_nd  [label="Fat Pad Biopsy\n(Congo red, mass spectrometry)", shape=ellipse, fillcolor="#85c1e9"];
        eGFR_nd        [label="eGFR / Creatinine\n[Biomarker ODE]", shape=ellipse, fillcolor="#85c1e9"];
        urine_prot     [label="Urine Protein\n(Proteinuria monitoring)", shape=ellipse, fillcolor="#85c1e9"];
        PLT_monitor    [label="Platelet Count\n(Inotersen: weekly CBC)", shape=ellipse, fillcolor="#f1948a"];
        renal_monitor  [label="Renal Function\n(Inotersen GN risk)", shape=ellipse, fillcolor="#f1948a"];
        LFT_monitor    [label="Liver Function Tests\n(Baseline & periodic)", shape=ellipse, fillcolor="#a9dfbf"];
    }

    /* ═══════════════════════════════════════════
       EDGES
    ═══════════════════════════════════════════ */

    /* Synthesis Edges */
    TTR_gene       -> TTR_mRNA       [label="transcription\n(~48h t½)"];
    ATTRv_mutation -> TTR_gene       [label="missense\nmutation", color="#e74c3c", style=bold];
    ATTRwt         -> TTR_mRNA       [label="aging/epigenetics\n(age ≥60)", color="#7f8c8d", style=dashed];
    TTR_mRNA       -> pre_TTR        [label="translation\n(ribosome)"];
    pre_TTR        -> mature_TTR     [label="signal peptide\ncleavage (ER)"];
    mature_TTR     -> TTR_folding    [label="folding\n(BiP/calnexin)"];
    TTR_folding    -> TTR_tetramer   [label="dimerization×2\n(homotetramer)"];
    TTR_tetramer   -> T4_binding     [label="T4 transport\n(3-4 μg/mL T4)"];
    TTR_tetramer   -> retinol_bind   [label="RBP4 complex\n(vitamin A)"];
    TTR_tetramer   -> TTR_secretion  [label="hepatic secretion"];
    TTR_tetramer   -> TTR_CSF        [label="choroid plexus\nsynthesis"];

    /* Misfolding Edges */
    TTR_tetramer   -> tet_dissoc     [label="thermal/pH stress\nrate-limiting!", color="#7d3c98", style=bold];
    ATTRv_mutation -> tet_dissoc     [label="destabilizes\ntetramer", color="#e74c3c"];
    tet_dissoc     -> misfolded_mono [label="partial unfolding\n(off-pathway)"];
    misfolded_mono -> nucleation     [label="critical nucleus\n(sigmoidal kinetics)"];
    nucleation     -> oligomers      [label="seeding\n(template-directed)"];
    oligomers      -> protofibrils   [label="elongation\n(fibril growth)"];
    protofibrils   -> amyloid_fibrils[label="maturation\n(cross-β sheet)"];
    serum_SAP      -> amyloid_fibrils[label="stabilizes\n(calcium-binding)", color="#7f8c8d", style=dashed];
    GAGs           -> oligomers      [label="promotes\naggregation", color="#7f8c8d", style=dashed];
    amyloid_fibrils-> RAGE_path      [label="activates", color="#e74c3c"];
    misfolded_mono -> proteostasis   [label="clearance\nattempt"];
    proteostasis   -> HSP_system     [style=dashed];
    proteostasis   -> UPS_deg        [style=dashed];
    proteostasis   -> ALP_deg        [style=dashed];
    proteostasis   -> ERAD           [style=dashed];

    /* Cardiac Edges */
    amyloid_fibrils-> FIB_HRT        [label="cardiac tropism\n(ATTRwt>>ATTRv)", color="#c0392b", style=bold];
    FIB_HRT        -> interstitial   [label="progressive\ndeposition"];
    interstitial   -> LV_wall_thick  [label="biventricular\nthickening"];
    LV_wall_thick  -> diastolic_dysfx[label="impaired\nrelaxation"];
    diastolic_dysfx-> systolic_dysfx [label="HFpEF→HFrEF\nprogression"];
    systolic_dysfx -> HF_ATTR        [label="end-stage\nheart failure"];
    FIB_HRT        -> conduction_abn [label="conduction system\ninvolvement"];
    conduction_abn -> AF_ATTR        [label="AF trigger\n(re-entry circuits)"];
    conduction_abn -> SCD_risk       [label="malignant\narrhythmia", color="#922b21", style=bold];
    oligomers      -> cardiac_inflam [label="toxic oligomers\n→ inflammasome", color="#e74c3c"];
    cardiac_inflam -> NLRP3_card     [label="activates"];
    NLRP3_card     -> IL1B_card      [label="caspase-1\ncleavage"];
    NLRP3_card     -> TNF_card       [label="NF-κB\ninduction"];
    IL1B_card      -> CM_death       [label="apoptosis\nsignaling", color="#e74c3c"];
    TNF_card       -> CM_death       [label="apoptosis\npath"];
    FIB_HRT        -> cardiac_fib    [label="TGF-β\ncardiac fibrosis"];
    cardiac_fib    -> HF_ATTR        [label="contributes\nto HF"];
    HF_ATTR        -> pericardial_eff[label="elevated filling\npressure"];
    HF_ATTR        -> cv_death       [label="fatal HF", color="#922b21", style=bold];
    HF_ATTR        -> HF_hosp        [label="acute\ndecompensation"];

    /* Neuropathy Edges */
    amyloid_fibrils-> FIB_NRV        [label="endoneurial\ndeposition", color="#1a5276", style=bold];
    FIB_NRV        -> schwann_comp   [label="mechanical\npressure"];
    schwann_comp   -> axonal_degen   [label="Wallerian\ndegeneration"];
    axonal_degen   -> small_fiber    [label="small fibers\nfirst"];
    axonal_degen   -> large_fiber    [label="later\ninvolvement"];
    FIB_NRV        -> DRG_comp       [label="ganglion\ninfiltration"];
    FIB_NRV        -> CTS_early      [label="early sign\n10-15yr prior", color="#7f8c8d", style=dashed];
    axonal_degen   -> autonomic_NP   [label="ANS\ninvolvement"];
    autonomic_NP   -> ortho_hypo     [label="sympathetic\ndysfunction"];
    autonomic_NP   -> GI_dysmot      [label="enteric\nnerves"];
    autonomic_NP   -> bladder_dysfx  [label="pelvic\nnerves"];
    autonomic_NP   -> erectile_dysfx [label="pudendal\nnerves"];
    GI_dysmot      -> weight_loss    [label="malabsorption"];
    small_fiber    -> weight_loss    [label="anorexia/\nnausea", color="#7f8c8d", style=dashed];

    /* Extra-cardiac Edges */
    amyloid_fibrils-> FIB_SYS        [label="systemic\ndeposition"];
    amyloid_fibrils-> ocular_ATTR    [label="vitreous humor\ndeposition"];
    amyloid_fibrils-> leptomening    [label="CNS (ATTRv\nspecific)", color="#7f8c8d", style=dashed];
    FIB_SYS        -> renal_ATTR     [label="mesangial\ndeposition"];
    amyloid_fibrils-> spinal_stenosis[label="epidural\ndeposit"];
    amyloid_fibrils-> tendon_deposit [label="tendon\ninfiltration"];
    TTR_tetramer   -> thyroid_ATTR   [label="T4 transport\ndisruption", style=dashed];
    TTR_tetramer   -> retinol_def    [label="RBP4 binding\nloss", style=dashed];
    weight_loss    -> mBMI_decline   [label="BMI×albumin↓\nmalnutrition"];

    /* Stabilizer PK Edges */
    tafamidis_dose -> A_TAF_GUT     [label="oral (F~99%\nka=0.42/h)"];
    A_TAF_GUT      -> A_TAF_C       [label="absorption\n(ka)"];
    A_TAF_C        -> A_TAF_P       [label="distribution\n(Q=1.2 L/h)"];
    A_TAF_C        -> TAF_binding   [label=">99% plasma\nprotein bound"];
    TAF_binding    -> TAF_mechanism [label="T4-site\noccupancy"];
    TAF_mechanism  -> tet_dissoc    [label="INHIBITS ↓\n(Emax=80%)", color="#2e86c1", arrowhead=tee, style=bold];
    diflunisal_dose-> DIF_C         [label="oral (rapid\nabsorption)"];
    DIF_C          -> TAF_binding   [label="T4-site binding\n(less selective)", style=dashed];
    acoramidis_dose-> ACO_C         [label="oral\n(BID dosing)"];
    ACO_C          -> TAF_mechanism [label="highly selective\nstabilizer", style=dashed];

    /* RNA Therapy PK Edges */
    patisiran_dose -> A_PAT_C       [label="IV infusion\n60min, wt-based"];
    A_PAT_C        -> A_PAT_P       [label="distribution\n(Q=0.96 L/h)"];
    A_PAT_C        -> PAT_liver     [label="LNP ApoE\n→ LDLR uptake"];
    PAT_liver      -> RISC_complex  [label="endosomal\nescape"];
    RISC_complex   -> mRNA_cleavage [label="Ago2-mediated\ncleavage"];
    mRNA_cleavage  -> TTR_mRNA      [label="INHIBITS ↓\n(Imax=80%)", color="#1a5276", arrowhead=tee, style=bold];

    vutrisiran_dose-> A_VUT_SC      [label="SC inject\n(abdomen/thigh)"];
    A_VUT_SC       -> A_VUT_C       [label="absorption\n(F~82%, ka=0.08/h)"];
    A_VUT_C        -> GalNAc_ASGR1  [label="ASGR1 receptor\ntargeting"];
    GalNAc_ASGR1   -> RISC_complex  [label="hepatocyte\ndelivery", style=dashed];

    inotersen_dose -> A_INO_SC      [label="SC inject\n(300mg QW)"];
    A_INO_SC       -> A_INO_C       [label="absorption\n(F~70%)"];
    A_INO_C        -> RNaseH1_act   [label="nuclear\nASO-mRNA hybrid"];
    RNaseH1_act    -> TTR_mRNA      [label="INHIBITS ↓\n(Imax=70%)", color="#1a5276", arrowhead=tee, style=bold];
    eplontersen_dose -> GalNAc_ASGR1[label="GalNAc-ASO\nhigh specificity", style=dashed];

    /* mRNA → protein feedback */
    TTR_mRNA       -> TTR_tetramer  [label="protein\nsynthesis\n(ksyn)"];

    /* Biomarker output edges */
    FIB_HRT        -> NT_proBNP_nd  [label="wall stress\n→ BNP↑", color="#922b21"];
    CM_death       -> troponin_nd   [label="myocyte leak\n(cTnT↑)", color="#922b21"];
    systolic_dysfx -> LVEF_nd       [label="EF decline", color="#922b21"];
    LV_wall_thick  -> LVMi_nd       [label="mass increase"];
    diastolic_dysfx-> E_e_ratio     [label="filling\npressure↑"];
    systolic_dysfx -> GLS_nd        [label="strain\nimpairment"];
    HF_ATTR        -> sixMWT_nd     [label="exercise\nintolerance"];
    HF_ATTR        -> KCCQ_nd       [label="QoL decline"];
    HF_ATTR        -> NYHA_nd       [label="symptom\nclass↑"];

    FIB_NRV        -> NIS_nd        [label="nerve damage\nquantification", color="#1a5276"];
    axonal_degen   -> mNIS_PLUS     [label="comprehensive\nNIS scoring"];
    autonomic_NP   -> Norfolk_QoL   [label="QoL impact\n(autonomic sx)"];
    axonal_degen   -> NCV_nd        [label="NCS slowing"];
    small_fiber    -> IENFD_nd      [label="IENFD↓"];
    axonal_degen   -> FAP_stage     [label="clinical\nstaging"];
    mBMI_decline   -> mBMI_nd       [label="nutritional\nstatus"];
    axonal_degen   -> PND_stage     [label="disability\nscale"];
    large_fiber    -> R_ODS         [label="functional\nlimitation"];

    /* Monitoring edges */
    TTR_secretion  -> serum_TTR_nd  [label="plasma level\nmeasurement"];
    TAF_mechanism  -> TTR_stab_assay[label="kinetic stab.\nassay", style=dashed, color="#7e5109"];
    FIB_HRT        -> Tc_PYP_scan   [label="Ca²⁺ binding\n→ ⁹⁹ᵐTc uptake", style=dashed, color="#2e86c1"];
    FIB_HRT        -> cardiac_CMR   [label="LGE/ECV\npattern (diffuse)"];
    LV_wall_thick  -> echo_nd       [label="echo findings\n(granular sparkling)"];
    amyloid_fibrils-> fat_biopsy_nd [label="biopsy\ndiagnosis"];
    renal_ATTR     -> eGFR_nd       [label="GFR decline"];
    renal_ATTR     -> urine_prot    [label="proteinuria"];
    A_INO_C        -> PLT_monitor   [label="platelet↓\n(weekly CBC!)", color="#e74c3c"];
    A_INO_C        -> renal_monitor [label="GN risk\n(rare, monitor)", color="#e74c3c"];
    TTR_folding    -> LFT_monitor   [label="liver origin\n(AST/ALT baseline)"];

    /* Legend */
    subgraph cluster_legend {
        label="Legend / 범례";
        color="#7f8c8d"; style=filled; fillcolor="#f8f9fa"; fontsize=10;
        leg1 [label="Diamond = Key biomarker/\npathophysiology node", shape=diamond, fillcolor="#f0e6ff"];
        leg2 [label="Pentagon = Drug dose\n(treatment input)", shape=pentagon, fillcolor="#fff8dc"];
        leg3 [label="Red bold arrow = Toxic/\npathological process", fillcolor="#fadbd8"];
        leg4 [label="Blue arrowhead=tee =\nDrug inhibitory effect", fillcolor="#d6eaf8"];
    }
}
