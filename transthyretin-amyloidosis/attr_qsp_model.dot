digraph ATTR_QSP {
  graph [fontname="Helvetica" bgcolor="#F8FAFF" rankdir=LR compound=true
         label="Transthyretin Amyloidosis (ATTR)\nComprehensive QSP Mechanistic Map"
         labelloc=t fontsize=20 splines=ortho nodesep=0.35 ranksep=0.9]
  node [fontname="Helvetica" fontsize=9 style="filled,rounded" shape=box]
  edge [fontname="Helvetica" fontsize=7]

  // =====================================================
  // Cluster 1: TTR Genetics & Hepatic Production
  // =====================================================
  subgraph cluster_genetics {
    label="1. TTR 유전학 및 간 생산 (Genetics & Hepatic Production)"
    style=filled fillcolor="#E8F4FD" color="#1A5276" penwidth=2

    TTR_gene       [label="TTR 유전자\n(Chr18q12.1)" fillcolor="#AED6F1" shape=cylinder]
    TTR_wt         [label="야생형 TTR\n(ATTRwt ≥60세)" fillcolor="#D6EAF8"]
    TTR_val30m     [label="Val30M (V30M)\n다발신경병증형" fillcolor="#F1948A"]
    TTR_val122i    [label="Val122I (V122I)\n심근병증형\n(아프리카계 3.4%)" fillcolor="#F1948A"]
    TTR_other_mut  [label="기타 변이 120+종\n(T60A, I68L, S77Y...)" fillcolor="#F1948A"]
    TTR_mRNA       [label="TTR mRNA\n(간세포)" fillcolor="#85C1E9"]
    TTR_preprotein [label="TTR 전구단백질\n(18aa 신호 펩타이드)" fillcolor="#AED6F1"]
    TTR_mono_synth [label="TTR 단량체 합성\n(간세포 소포체)" fillcolor="#AED6F1"]
    TTR_tet_assem  [label="사량체 조립\n(소포체/골지체)" fillcolor="#85C1E9"]
    TTR_secreted   [label="TTR 분비\n혈장 20-40 mg/dL" fillcolor="#5DADE2" fontcolor=white]
    Choroid_plexus [label="맥락막총\n(CNS TTR, 5%)" fillcolor="#A9DFBF"]
    Retinal_PE     [label="망막 색소상피\n(국소 TTR 생산)" fillcolor="#A9DFBF"]
    T4_function    [label="T4 수송 기능\n(혈중 T4의 15%)" fillcolor="#F9E79F"]
    RBP_function   [label="레티놀-RBP\n복합체 형성" fillcolor="#F9E79F"]
    Aging_factor   [label="노화 위험인자\n(60세 이후↑)" fillcolor="#FAD7A0"]
    Liver_sinusoid [label="간 동양혈관\n(주요 생산 부위)" fillcolor="#D6EAF8"]
    TTR_hepatic_pct[label="간 생산 비율\n~95%" fillcolor="#AED6F1"]
    siRNA_mRNA_tgt [label="siRNA/ASO 표적\n(mRNA 분해)" fillcolor="#D7BDE2" shape=diamond]

    TTR_gene -> TTR_mRNA [label="전사"]
    TTR_wt -> TTR_gene [style=dashed label="야생형 서열"]
    TTR_val30m -> TTR_gene [style=dashed label="점돌연변이"]
    TTR_val122i -> TTR_gene [style=dashed label="점돌연변이"]
    TTR_other_mut -> TTR_gene [style=dashed label="120+종 변이"]
    TTR_mRNA -> TTR_preprotein [label="리보솜 번역"]
    TTR_preprotein -> TTR_mono_synth [label="신호 펩타이드 절단"]
    TTR_mono_synth -> TTR_tet_assem [label="폴딩·조립"]
    TTR_tet_assem -> TTR_secreted [label="혈장 분비"]
    Choroid_plexus -> TTR_secreted [label="CNS 분비 5%"]
    Retinal_PE -> TTR_secreted [label="안구 분비"]
    TTR_secreted -> T4_function
    TTR_secreted -> RBP_function
    Aging_factor -> TTR_wt [label="ATTRwt 위험↑"]
    Liver_sinusoid -> TTR_hepatic_pct
    TTR_hepatic_pct -> TTR_secreted [label="간 기여 95%"]
    siRNA_mRNA_tgt -> TTR_mRNA [label="⊣ mRNA 분해" style=bold color=red arrowhead=tee]
  }

  // =====================================================
  // Cluster 2: TTR Aggregation Cascade
  // =====================================================
  subgraph cluster_aggregation {
    label="2. TTR 응집 연쇄반응 (Aggregation Cascade)"
    style=filled fillcolor="#FDEDEC" color="#C0392B" penwidth=2

    TTR_tetramer    [label="TTR 사량체\n(4×14 kDa, 안정 구조)\n혈장 정상 농도" fillcolor="#F5B7B1" shape=octagon]
    Tafamidis_bind  [label="타파미디스 결합\n(T4 결합부위 점유\nKD≈2 nM)" fillcolor="#ABEBC6" shape=diamond]
    AG10_Acoram     [label="아코라미디스(AG10)\n결합 안정화" fillcolor="#ABEBC6" shape=diamond]
    Native_T4_bind  [label="천연 T4 결합\n(사량체 안정화 기여)" fillcolor="#F9E79F"]

    Tet_dissociation [label="사량체 해리\n(속도제한 단계)\nkdiss≈1×10⁻³/h" fillcolor="#E74C3C" fontcolor=white]
    TTR_dimer       [label="TTR 이량체\n(불안정 중간체)" fillcolor="#F1948A"]
    Dim_dissociation [label="이량체→단량체 해리" fillcolor="#E59866"]

    TTR_native_mono [label="천연 TTR 단량체\n(정상 폴딩·안정)" fillcolor="#F0B27A"]
    Partial_unfolding [label="부분 구조 변형\n(Partial Unfolding\nΔG 감소)" fillcolor="#E74C3C" fontcolor=white]
    TTR_misfolded   [label="잘못 폴딩된 단량체\n(아밀로이드 전구체)" fillcolor="#C0392B" fontcolor=white]

    Nucleation      [label="핵형성 단계\n(느린 개시 반응)" fillcolor="#922B21" fontcolor=white]
    TTR_oligomers   [label="가용성 TTR 올리고머\n(2~16 mer, ★세포독성)" fillcolor="#7B241C" fontcolor=white]
    Protofibril_form [label="프로토피브릴 형성\n(불용성 개시)" fillcolor="#6E2C00" fontcolor=white]
    TTR_protofibril [label="TTR 프로토피브릴\n(신장·분지)" fillcolor="#5E221A" fontcolor=white]
    Fibril_elongation [label="아밀로이드 피브릴\n연장·성숙" fillcolor="#4A235A" fontcolor=white]
    TTR_amyloid     [label="성숙 아밀로이드 피브릴\n(불용성, 침착형)" fillcolor="#3B1F50" fontcolor=white shape=cylinder]

    GAG_heparan     [label="헤파란황산\n(GAG 가속)" fillcolor="#D5DBDB"]
    SAP_stabilize   [label="혈청 아밀로이드 P(SAP)\n침착 안정화" fillcolor="#D5DBDB"]
    ApoE4_risk      [label="ApoE4\n(침착 위험 증가)" fillcolor="#FAD7A0"]
    Metal_ions      [label="Cu²⁺/Zn²⁺ 이온\n미스폴딩 촉진" fillcolor="#FAD7A0"]
    Acidic_pH       [label="산성 pH 환경\n(조직 산증 → 촉진)" fillcolor="#FAD7A0"]
    Oxidative_ROS   [label="산화 스트레스(ROS)\n단백질 산화 → 촉진" fillcolor="#F1948A"]
    Heat_shock      [label="열충격 단백질\n(Hsp70/90 샤페론)" fillcolor="#AED6F1"]
    Proteasome_deg  [label="프로테아솜 분해\n(단백질 품질관리)" fillcolor="#AED6F1"]

    TTR_tetramer -> Native_T4_bind [label="T4 결합"]
    Tafamidis_bind -> Tet_dissociation [label="⊣ 동력학적 안정화" style=bold color=darkgreen arrowhead=tee]
    AG10_Acoram -> Tet_dissociation [label="⊣ 안정화" color=darkgreen arrowhead=tee]
    Native_T4_bind -> Tet_dissociation [label="약한 안정화" color=darkgreen]
    TTR_tetramer -> Tet_dissociation [label="열역학적 해리"]
    Tet_dissociation -> TTR_dimer
    TTR_dimer -> Dim_dissociation
    Dim_dissociation -> TTR_native_mono
    TTR_native_mono -> Partial_unfolding
    Acidic_pH -> Partial_unfolding [label="촉진"]
    Oxidative_ROS -> Partial_unfolding [label="촉진"]
    Metal_ions -> Partial_unfolding [label="촉진"]
    Partial_unfolding -> TTR_misfolded
    TTR_misfolded -> Nucleation
    Nucleation -> TTR_oligomers
    TTR_oligomers -> Protofibril_form
    Protofibril_form -> TTR_protofibril
    TTR_protofibril -> Fibril_elongation
    Fibril_elongation -> TTR_amyloid
    GAG_heparan -> Fibril_elongation [label="가속·주형"]
    SAP_stabilize -> TTR_amyloid [label="침착 안정화"]
    ApoE4_risk -> Fibril_elongation [label="촉진"]
    Heat_shock -> Partial_unfolding [label="⊣ 보호" arrowhead=tee color=green]
    Proteasome_deg -> TTR_misfolded [label="⊣ 분해" arrowhead=tee color=green]
  }

  // =====================================================
  // Cluster 3: Cardiac ATTR Pathology
  // =====================================================
  subgraph cluster_cardiac {
    label="3. 심장 ATTR 병리 (Cardiac Amyloidosis)"
    style=filled fillcolor="#EBF5FB" color="#154360" penwidth=2

    Cardiac_dep     [label="심장 아밀로이드 침착\n(점진적 축적)" fillcolor="#AED6F1" shape=octagon]
    Interstitial_dep [label="간질성 침착\n(심근세포 사이)" fillcolor="#85C1E9"]
    Vascular_dep    [label="혈관 침착\n(소관상동맥)" fillcolor="#85C1E9"]
    Atrial_dep      [label="심방·판막 침착\n(AF 기질)" fillcolor="#85C1E9"]

    LV_wall_thick   [label="LV 벽 두께 증가\n(위성 LVH >12mm)" fillcolor="#5DADE2" fontcolor=white]
    RV_involvement  [label="우심실 침범\n(양심실 확장형)" fillcolor="#5DADE2" fontcolor=white]
    Biventricular   [label="양심실 기능 저하\n(말기 양상)" fillcolor="#2E86C1" fontcolor=white]

    Diastolic_dysfxn [label="이완 기능 장애\n(제한성·침윤성)" fillcolor="#2E86C1" fontcolor=white]
    Filling_press_up [label="충만압 상승\n(E/e' >15, PCWP↑)" fillcolor="#2E86C1" fontcolor=white]
    HFpEF_phenotype [label="HFpEF 표현형\n(초기 EF 보존)" fillcolor="#1A5276" fontcolor=white]

    Oligomer_CTox   [label="올리고머 심근세포\n직접독성" fillcolor="#E74C3C" fontcolor=white]
    CM_apoptosis    [label="심근세포 사멸\n(아폽토시스↑)" fillcolor="#C0392B" fontcolor=white]
    Secondary_fibros [label="이차성 심근 섬유화\n(반응성)" fillcolor="#E74C3C" fontcolor=white]

    Conduction_abnorm [label="전도계 이상\n(HV 간격↑, AV 블록)" fillcolor="#8E44AD" fontcolor=white]
    AFib_ATTR       [label="심방세동\n(유병률 ~40%)" fillcolor="#8E44AD" fontcolor=white]
    SCD_risk        [label="심실 부정맥\n(돌연심장사 위험)" fillcolor="#7D3C98" fontcolor=white]

    LVEF_state      [label="LVEF 상태\n초기≥50%→말기↓" fillcolor="#2980B9" fontcolor=white]
    CO_reduction    [label="심박출량↓\n(말기 수축기능저하)" fillcolor="#1F618D" fontcolor=white]
    Exercise_intol  [label="운동 불내성\n(6MWT 거리↓)" fillcolor="#1A5276" fontcolor=white]

    BNP_biomarker   [label="NT-proBNP↑\n(핵심 바이오마커)" fillcolor="#F9E79F"]
    Troponin_bio    [label="고감도 트로포닌T/I↑\n(심근 손상 지표)" fillcolor="#F9E79F"]

    DPD_scan_card   [label="Tc-99m DPD/PYP\n신티그래피 흡수↑" fillcolor="#A9DFBF"]
    Echo_granular   [label="심초음파\n(반짝·과립 패턴)" fillcolor="#A9DFBF"]
    Apical_sparing  [label="심첨부 보존 패턴\n(GLS 특이 소견)" fillcolor="#A9DFBF"]
    CMR_ECV         [label="심장 MRI\nECV분율↑(>0.4)" fillcolor="#A9DFBF"]

    KCCQ_score_c    [label="KCCQ 점수\n(심장 삶의 질)" fillcolor="#FAD7A0"]
    NYHA_class_c    [label="NYHA 기능분류\n(I→IV 단계)" fillcolor="#FAD7A0"]
    SixMWT_dist     [label="6분보행거리\n(m, 주요 결과)" fillcolor="#FAD7A0"]

    Cardiac_dep -> Interstitial_dep
    Cardiac_dep -> Vascular_dep
    Cardiac_dep -> Atrial_dep
    Interstitial_dep -> LV_wall_thick
    LV_wall_thick -> RV_involvement
    RV_involvement -> Biventricular
    Interstitial_dep -> Diastolic_dysfxn
    Diastolic_dysfxn -> Filling_press_up
    Filling_press_up -> HFpEF_phenotype
    Filling_press_up -> BNP_biomarker
    Atrial_dep -> AFib_ATTR
    Conduction_abnorm -> AFib_ATTR
    Conduction_abnorm -> SCD_risk
    Oligomer_CTox -> CM_apoptosis
    Oligomer_CTox -> Secondary_fibros
    Secondary_fibros -> Diastolic_dysfxn [label="악화"]
    HFpEF_phenotype -> LVEF_state
    LVEF_state -> CO_reduction [label="후기 EF↓"]
    CO_reduction -> Exercise_intol
    Exercise_intol -> NYHA_class_c
    Exercise_intol -> SixMWT_dist
    KCCQ_score_c -> SixMWT_dist [style=invis]
    DPD_scan_card -> Echo_granular [style=invis]
    Echo_granular -> Apical_sparing [style=invis]
    Troponin_bio -> BNP_biomarker [style=invis]
  }

  // =====================================================
  // Cluster 4: Neurological ATTR Pathology
  // =====================================================
  subgraph cluster_neuro {
    label="4. 신경계 ATTR 병리 (Familial Amyloid Polyneuropathy)"
    style=filled fillcolor="#FEF9E7" color="#7D6608" penwidth=2

    PNS_dep         [label="말초신경 아밀로이드\n침착 (발끝부터)" fillcolor="#F9E79F" shape=octagon]
    DRG_infiltr     [label="후근신경절(DRG)\n침윤·손상" fillcolor="#F0B27A"]
    Schwann_damage  [label="슈반 세포 손상\n(탈수초화·축삭 손상)" fillcolor="#E59866"]
    Axonal_degen    [label="축삭 변성\n(길이 의존적 손실)" fillcolor="#E59866"]

    Small_fiber_NP  [label="소섬유 신경병증\n(통증·온도감각 먼저)" fillcolor="#E74C3C" fontcolor=white]
    Large_fiber_NP  [label="대섬유 신경병증\n(고유감각·진동감각↓)" fillcolor="#E74C3C" fontcolor=white]

    Autonomic_NP    [label="자율신경 병증\n(ANS 기능이상)" fillcolor="#C0392B" fontcolor=white]
    Orthostatic_HT  [label="기립성 저혈압\n(SBP↓≥20mmHg)" fillcolor="#E74C3C" fontcolor=white]
    GI_dysmotility  [label="위장관 운동 이상\n(설사·변비 교대)" fillcolor="#F0B27A"]
    Neurogenic_BLD  [label="신경인성 방광" fillcolor="#F0B27A"]

    Carpal_tunnel   [label="수근관 증후군\n(ATTRwt 선행 증상)" fillcolor="#F9E79F"]
    Bilateral_CTS   [label="양측성 CTS\n→ ATTR 진단 트리거" fillcolor="#FDEBD0" shape=diamond]
    Biceps_rupture  [label="이두근 건 파열\n(인대 침착 결과)" fillcolor="#F9E79F"]

    NIS_score_n     [label="NIS 점수\n(신경병증 장애 지수)" fillcolor="#D5DBDB"]
    mNIS7_score     [label="mNIS+7 점수\n(FAP 1차 임상 결과)" fillcolor="#AED6F1"]
    PND_grade       [label="PND 등급\n(0-3c, 보행능력)" fillcolor="#AED6F1"]
    R_ODS_scale     [label="Rasch-ODS\n(자기보고 결과)" fillcolor="#D5DBDB"]

    Leptomeningeal  [label="연수막 아밀로이드\n(CNS 침범, 드묾)" fillcolor="#A9DFBF"]
    Vitreous_dep    [label="유리체 침착\n(시력 장애)" fillcolor="#A9DFBF"]

    PNS_dep -> DRG_infiltr
    DRG_infiltr -> Schwann_damage
    Schwann_damage -> Axonal_degen
    Axonal_degen -> Small_fiber_NP
    Axonal_degen -> Large_fiber_NP
    Schwann_damage -> Autonomic_NP
    Autonomic_NP -> Orthostatic_HT
    Autonomic_NP -> GI_dysmotility
    Autonomic_NP -> Neurogenic_BLD
    Small_fiber_NP -> NIS_score_n
    Large_fiber_NP -> NIS_score_n
    NIS_score_n -> mNIS7_score
    Carpal_tunnel -> Bilateral_CTS [label="선행 증상 수 년"]
    Bilateral_CTS -> PNS_dep [label="의심 단서" style=dashed color=blue]
    PNS_dep -> PND_grade
    PND_grade -> R_ODS_scale
    mNIS7_score -> R_ODS_scale [style=invis]
    Leptomeningeal -> Vitreous_dep [style=invis]
  }

  // =====================================================
  // Cluster 5: Multi-organ Involvement
  // =====================================================
  subgraph cluster_other_organs {
    label="5. 다장기 침범 (Multi-organ Amyloid)"
    style=filled fillcolor="#F0FFF0" color="#1E8449" penwidth=2

    Renal_dep       [label="신장 아밀로이드\n(단백뇨·CKD 진행)" fillcolor="#A9DFBF"]
    Glomerular_dep  [label="사구체 기저막 침착\n(메산지움)" fillcolor="#82E0AA"]
    Tubular_damage  [label="세뇨관 손상\n(기능 감소)" fillcolor="#82E0AA"]
    Proteinuria_r   [label="단백뇨\n(1차 신장 결과)" fillcolor="#58D68D"]

    GI_submucosal   [label="위장관 점막하\n아밀로이드" fillcolor="#A9DFBF"]
    Gastric_dep     [label="위 아밀로이드\n(조기 포만감)" fillcolor="#82E0AA"]
    Intestinal_dep  [label="소·대장 아밀로이드\n(흡수 장애)" fillcolor="#82E0AA"]

    Liver_dep       [label="간 아밀로이드\n(일부 변이형)" fillcolor="#A9DFBF"]
    Hepatomegaly    [label="간비종대\n(비특이적 소견)" fillcolor="#82E0AA"]

    Soft_tissue     [label="연조직 침착\n('견갑대' 비후 징후)" fillcolor="#D5DBDB"]
    Tendon_dep      [label="이두근건·수근관\n인대 침착" fillcolor="#D5DBDB"]

    Bone_marrow_dep [label="골수 침착\n(경미한 빈혈)" fillcolor="#FAFAD2"]
    Thyroid_dep     [label="갑상선 침착\n(기능 감소 드묾)" fillcolor="#FAFAD2"]

    Renal_dep -> Glomerular_dep
    Glomerular_dep -> Tubular_damage
    Tubular_damage -> Proteinuria_r
    GI_submucosal -> Gastric_dep
    GI_submucosal -> Intestinal_dep
    Liver_dep -> Hepatomegaly
    Soft_tissue -> Tendon_dep
    Bone_marrow_dep -> Thyroid_dep [style=invis]
  }

  // =====================================================
  // Cluster 6: Tafamidis PK/PD (Kinetic Stabilizer)
  // =====================================================
  subgraph cluster_tafamidis {
    label="6. 타파미디스 PK/PD (Tafamidis — 동력학적 안정제)"
    style=filled fillcolor="#E8F8F5" color="#148F77" penwidth=2

    TAF_61mg_dose   [label="타파미디스 61mg QD\n(메글루민 염)\n= 자유산 ~20mg 상당" fillcolor="#ABEBC6"]
    TAF_oral_abs    [label="경구 흡수\n(F≈100%, Tmax≈4h)" fillcolor="#76D7C4"]
    TAF_plasma_Cp   [label="혈장 농도\n(Cmax≈7 μg/mL)" fillcolor="#45B39D" fontcolor=white]
    TAF_protein_bd  [label="고단백 결합\n(>99%, 알부민·TTR)" fillcolor="#1ABC9C" fontcolor=white]
    TAF_Vd          [label="분포용적\n(Vd≈18L)" fillcolor="#45B39D" fontcolor=white]
    TAF_glucuronide [label="글루쿠론산 포합\n(CYP 독립 대사)" fillcolor="#27AE60" fontcolor=white]
    TAF_renal_elim  [label="신장 배설\n(t½≈59h 반감기)" fillcolor="#1E8449" fontcolor=white]

    TAF_TTR_complex [label="타파미디스-TTR\n결합체 형성\n(KD≈2 nM)" fillcolor="#ABEBC6"]
    TTR_stab_PD     [label="TTR 사량체\n동력학적 안정화" fillcolor="#76D7C4"]
    Dissoc_inhibit  [label="해리 속도 억제\n(Emax 기반 PD)" fillcolor="#45B39D" fontcolor=white]
    Aggregation_inh [label="응집 억제\n(↓ 아밀로이드 형성)" fillcolor="#1ABC9C" fontcolor=white]

    ATTR_ACT_trial  [label="ATTR-ACT 임상시험\n(Maurer 2018 NEJM)\n사망률↓30%, 입원↓32%\n6MWT 거리 개선" fillcolor="#D5F5E3"]
    Tafamidis_PD_EC50 [label="EC50 추정값\n(TTR 안정화 농도-효과)" fillcolor="#A9DFBF"]

    TAF_61mg_dose -> TAF_oral_abs
    TAF_oral_abs -> TAF_plasma_Cp
    TAF_plasma_Cp -> TAF_protein_bd
    TAF_protein_bd -> TAF_Vd
    TAF_plasma_Cp -> TAF_glucuronide
    TAF_glucuronide -> TAF_renal_elim
    TAF_plasma_Cp -> TAF_TTR_complex
    TAF_TTR_complex -> TTR_stab_PD
    TTR_stab_PD -> Dissoc_inhibit
    Dissoc_inhibit -> Aggregation_inh
    ATTR_ACT_trial -> ATTR_ACT_trial [style=invis]
    Tafamidis_PD_EC50 -> TTR_stab_PD [style=dashed label="PD 관계"]
  }

  // =====================================================
  // Cluster 7: Gene-Silencing Therapies (siRNA/ASO)
  // =====================================================
  subgraph cluster_gene_silencing {
    label="7. 유전자 침묵 치료제 — siRNA/ASO"
    style=filled fillcolor="#FEF5FB" color="#7D3C98" penwidth=2

    // Patisiran
    PAT_dose        [label="파티시란\n0.3mg/kg IV Q3W\n(LNP 제형)" fillcolor="#D7BDE2"]
    PAT_LNP_del     [label="LNP 간세포\n내재화·탈봉입" fillcolor="#C39BD3"]
    PAT_RISC_load   [label="RISC 복합체 로딩\n(Ago2-siRNA)" fillcolor="#A569BD" fontcolor=white]
    PAT_mRNA_cleave [label="TTR mRNA 절단\n(3'UTR 표적)" fillcolor="#8E44AD" fontcolor=white]
    PAT_TTR_80      [label="혈청 TTR↓80%\n(APOLLO 24개월)" fillcolor="#6C3483" fontcolor=white]
    APOLLO_outcome  [label="APOLLO 임상시험\n(Adams 2018 NEJM)\nmNIS+7 개선\nQoL · V30M 효과" fillcolor="#E8DAEF"]

    // Vutrisiran
    VUT_dose        [label="뷔트리시란 25mg\nSC Q3M\n(GalNAc-siRNA)" fillcolor="#D7BDE2"]
    VUT_GalNAc_del  [label="GalNAc-ASGPR\n수용체 표적 전달" fillcolor="#C39BD3"]
    VUT_RISC_enh    [label="강화된 RISC\n(내구성↑ ESC 화학)" fillcolor="#A569BD" fontcolor=white]
    VUT_TTR_87      [label="혈청 TTR↓87%\n(HELIOS-A 9개월)" fillcolor="#6C3483" fontcolor=white]
    HELIOS_A_outcome [label="HELIOS-A 임상시험\n(Solomon 2022 NEJM)\nmNIS+7 개선\n심장 결과 포함" fillcolor="#E8DAEF"]

    // Inotersen
    INO_dose        [label="이노테르센 284mg\nSC QW\n(2'-MOE-ASO)" fillcolor="#D7BDE2"]
    INO_ASO_mech    [label="RNase H 의존적\nmRNA 분해" fillcolor="#C39BD3"]
    INO_TTR_75      [label="혈청 TTR↓75%\n(NEURO-TTR 15개월)" fillcolor="#6C3483" fontcolor=white]
    INO_platelet_se [label="혈소판감소증 부작용\n(5% 중증, 모니터링 필요)" fillcolor="#F1948A"]
    NEURO_TTR_outcome [label="NEURO-TTR 임상시험\n(Benson 2018 NEJM)\nmNIS+7 개선" fillcolor="#E8DAEF"]

    // Eplontersen
    EPL_dose        [label="에플론테르센 45mg\nSC Q4W\n(GalNAc-ASO)" fillcolor="#D7BDE2"]
    EPL_GalNAc_ASO  [label="GalNAc-ASO 결합자\n(배월간 피하주사)" fillcolor="#C39BD3"]
    EPL_TTR_82      [label="혈청 TTR↓82%\n(NEURO-TTRansform)" fillcolor="#6C3483" fontcolor=white]

    siRNA_net_TTR   [label="혈청 TTR 단백질↓\n(공급원 차단 효과)" fillcolor="#7D3C98" fontcolor=white shape=octagon]

    PAT_dose -> PAT_LNP_del
    PAT_LNP_del -> PAT_RISC_load
    PAT_RISC_load -> PAT_mRNA_cleave
    PAT_mRNA_cleave -> PAT_TTR_80
    PAT_TTR_80 -> siRNA_net_TTR
    APOLLO_outcome -> PAT_TTR_80 [style=dashed label="임상 검증"]

    VUT_dose -> VUT_GalNAc_del
    VUT_GalNAc_del -> VUT_RISC_enh
    VUT_RISC_enh -> VUT_TTR_87
    VUT_TTR_87 -> siRNA_net_TTR
    HELIOS_A_outcome -> VUT_TTR_87 [style=dashed label="임상 검증"]

    INO_dose -> INO_ASO_mech
    INO_ASO_mech -> INO_TTR_75
    INO_TTR_75 -> siRNA_net_TTR
    INO_ASO_mech -> INO_platelet_se [label="오프타겟"]
    NEURO_TTR_outcome -> INO_TTR_75 [style=dashed label="임상 검증"]

    EPL_dose -> EPL_GalNAc_ASO
    EPL_GalNAc_ASO -> EPL_TTR_82
    EPL_TTR_82 -> siRNA_net_TTR
  }

  // =====================================================
  // Cluster 8: Clinical Staging & Outcomes
  // =====================================================
  subgraph cluster_staging {
    label="8. 임상 병기 분류 및 결과 (Clinical Staging & Outcomes)"
    style=filled fillcolor="#FEF9E7" color="#784212" penwidth=2

    NAC_staging     [label="NAC/Mayo 심장 병기분류\n(ATTRwt 심근병증)" fillcolor="#F9E79F" shape=octagon]
    Stage1_card     [label="1기: NT-proBNP<3000 pg/mL\n& 트로포닌I<0.1 ng/mL" fillcolor="#A9DFBF"]
    Stage2_card     [label="2기: 한 기준만 초과\n(중간 예후)" fillcolor="#F0B27A"]
    Stage3_card     [label="3기: 두 기준 모두 초과\n(불량 예후, 중앙 생존<2.5년)" fillcolor="#F1948A"]

    DFM_staging     [label="DFM 신경병증 병기분류\n(FAP·ATTRv)" fillcolor="#F9E79F"]
    Neuro_Stage1    [label="신경 1기\n(보조기구 없이 보행)" fillcolor="#A9DFBF"]
    Neuro_Stage2    [label="신경 2기\n(보조기구 필요)" fillcolor="#F0B27A"]
    Neuro_Stage3    [label="신경 3기\n(휠체어·침상 의존)" fillcolor="#F1948A"]

    Overall_surv    [label="전체 생존율\n(심장형 중앙 2.5-5년\n신경형 더 긴 경과)" fillcolor="#E74C3C" fontcolor=white]
    CV_mortality    [label="심혈관 사망\n(주요 사인)" fillcolor="#C0392B" fontcolor=white]
    HF_hospit       [label="심부전 입원\n(복합 주요 결과)" fillcolor="#E59866"]
    CV_hospit       [label="심혈관 입원\n(반복 입원 횟수)" fillcolor="#E59866"]
    Functional_dec  [label="기능 저하\n(NYHA, 6MWT)" fillcolor="#F0B27A"]
    QoL_outcome     [label="삶의 질 결과\n(KCCQ, SF-36)" fillcolor="#F9E79F"]

    Mortality_rate  [label="사망률 감소\n(타파미디스 30%↓)" fillcolor="#A9DFBF"]
    NIS_stabilize   [label="신경병증 안정화\n(mNIS+7 ≤0)" fillcolor="#A9DFBF"]

    NAC_staging -> Stage1_card
    NAC_staging -> Stage2_card
    NAC_staging -> Stage3_card
    Stage3_card -> Overall_surv [label="최고 위험군"]
    Stage1_card -> Overall_surv
    Stage2_card -> Overall_surv
    DFM_staging -> Neuro_Stage1
    DFM_staging -> Neuro_Stage2
    DFM_staging -> Neuro_Stage3
    Overall_surv -> CV_mortality
    HF_hospit -> Overall_surv [label="사망 예측인자"]
    CV_hospit -> HF_hospit
    Functional_dec -> QoL_outcome
    Mortality_rate -> Overall_surv [style=dashed color=green]
    NIS_stabilize -> QoL_outcome [style=dashed color=green]
  }

  // =====================================================
  // Cluster 9: Cellular Stress & Inflammation
  // =====================================================
  subgraph cluster_stress {
    label="9. 세포 스트레스 및 염증 경로 (Cellular Stress)"
    style=filled fillcolor="#FDEDEC" color="#922B21" penwidth=2

    Oligomer_tox_s  [label="TTR 올리고머\n세포독성 기전" fillcolor="#F1948A" shape=octagon]
    Pore_formation  [label="세포막 구멍 형성\n(Pore-forming)" fillcolor="#E74C3C" fontcolor=white]
    Ca2_overload    [label="세포 내 Ca²⁺ 과부하\n(항상성 붕괴)" fillcolor="#E74C3C" fontcolor=white]
    Mito_dysfunction [label="미토콘드리아 기능 이상\nROS 생성↑" fillcolor="#C0392B" fontcolor=white]

    NLRP3_inflamm   [label="NLRP3 인플라마솜\n활성화 (IL-1β↑)" fillcolor="#F1948A"]
    Caspase_1       [label="카스파제-1 활성\n(피롭토시스)" fillcolor="#E74C3C" fontcolor=white]
    IL1b_rel        [label="IL-1β 방출\n(전신 염증 증폭)" fillcolor="#E59866"]
    TNF_pathway_s   [label="TNF-α/NF-κB\n심근 스트레스" fillcolor="#F0B27A"]

    ER_stress_s     [label="소포체 스트레스\n(UPR 활성화)" fillcolor="#F0B27A"]
    PERK_IRE1       [label="PERK/IRE1α\nATF6 신호" fillcolor="#E59866"]
    CHOP_pathway    [label="CHOP 경로\n→ 미접힘 단백질 사멸" fillcolor="#E74C3C" fontcolor=white]

    Macrophage_amyl [label="대식세포 탐식\n(아밀로이드 제거 시도)" fillcolor="#D5DBDB"]
    SAP_complement  [label="보체계 활성화\n(C1q·C3·SAP)" fillcolor="#D5DBDB"]
    Lysosome_fail   [label="리소좀 기능 부전\n(소화 불가)" fillcolor="#D5DBDB"]

    Autophagy_s     [label="자가포식\n(부분적 제거 시도)" fillcolor="#AED6F1"]
    Aggresome       [label="응집소체 형성\n(HDAC6 경로)" fillcolor="#AED6F1"]

    Oligomer_tox_s -> Pore_formation
    Pore_formation -> Ca2_overload
    Ca2_overload -> Mito_dysfunction
    Mito_dysfunction -> NLRP3_inflamm
    NLRP3_inflamm -> Caspase_1
    Caspase_1 -> IL1b_rel
    IL1b_rel -> TNF_pathway_s
    ER_stress_s -> PERK_IRE1
    PERK_IRE1 -> CHOP_pathway
    Macrophage_amyl -> SAP_complement
    Macrophage_amyl -> Lysosome_fail [label="소화 실패"]
    Autophagy_s -> Aggresome
  }

  // =====================================================
  // Cluster 10: Diagnosis & Monitoring
  // =====================================================
  subgraph cluster_diagnosis {
    label="10. 진단 및 모니터링 (Diagnosis & Monitoring)"
    style=filled fillcolor="#F4ECF7" color="#6C3483" penwidth=2

    Clinical_suspi  [label="임상적 의심\n(노인 HFpEF·CTS·\n다발신경병증·신장병)" fillcolor="#D7BDE2" shape=diamond]

    Serum_TTR_meas  [label="혈청 TTR 농도\n(질량분석 정량)" fillcolor="#C39BD3"]
    TTR_genotype    [label="TTR 유전자형 검사\n(NGS 패널 시퀀싱)" fillcolor="#C39BD3"]
    SPEP_UPEP       [label="혈청·소변 단백전기\n(M단백 감별)" fillcolor="#C39BD3"]

    Congo_red_bx    [label="콩고 레드 생검\n(사과색 이중굴절)" fillcolor="#A569BD" fontcolor=white]
    Fat_pad_bx      [label="복부 피하지방 생검\n(외래 가능)" fillcolor="#A569BD" fontcolor=white]
    Endomyocardial  [label="심내막심근 생검\n(Gold Standard)" fillcolor="#8E44AD" fontcolor=white]
    Mass_spec_bx    [label="레이저 미세절제+\n질량분석 (아밀로이드 유형)" fillcolor="#8E44AD" fontcolor=white]

    DPD_PYP_scan    [label="Tc-99m DPD/PYP\n신티그래피" fillcolor="#D7BDE2"]
    Perugini_grade  [label="Perugini 등급 0-3\n(Grade 2-3 = 비생검 진단)" fillcolor="#C39BD3"]

    Echo_workup     [label="심초음파\n(벽두께·GLS·E/e')" fillcolor="#D7BDE2"]
    GLS_pattern     [label="심첨부 보존 패턴\n(GLS ATTR 특이 패턴)" fillcolor="#C39BD3"]

    CMR_workup      [label="심장 MRI\n(LGE·ECV·T1 맵핑)" fillcolor="#D7BDE2"]
    ECV_elevated    [label="ECV 분율↑\n(아밀로이드 부담 반영)" fillcolor="#C39BD3"]

    NCS_EMG_workup  [label="신경전도·근전도\n(축삭 탈수초 패턴)" fillcolor="#D7BDE2"]
    Skin_biopsy_NP  [label="피부 생검\n(표피 내 신경섬유 밀도)" fillcolor="#C39BD3"]

    Lab_serial      [label="추적 검사\nNT-proBNP·Trop·TTR\n(치료 반응 평가)" fillcolor="#E8DAEF"]

    Clinical_suspi -> Serum_TTR_meas
    Clinical_suspi -> TTR_genotype
    Clinical_suspi -> DPD_PYP_scan
    Clinical_suspi -> Echo_workup
    Clinical_suspi -> CMR_workup
    Clinical_suspi -> SPEP_UPEP [label="M단백 감별"]
    Congo_red_bx -> Fat_pad_bx
    Congo_red_bx -> Endomyocardial
    Endomyocardial -> Mass_spec_bx [label="유형 결정"]
    DPD_PYP_scan -> Perugini_grade
    Echo_workup -> GLS_pattern
    CMR_workup -> ECV_elevated
    NCS_EMG_workup -> Skin_biopsy_NP
    Lab_serial -> Serum_TTR_meas [style=invis]
  }

  // =====================================================
  // Cross-subgraph connections
  // =====================================================

  // Production → Aggregation
  TTR_secreted -> TTR_tetramer [label="혈장 내 사량체로\n존재 (정상)" lhead=cluster_aggregation ltail=cluster_genetics style=bold]

  // Aggregation → Cardiac
  TTR_amyloid -> Cardiac_dep [label="심장 침착" ltail=cluster_aggregation lhead=cluster_cardiac style=bold color="#1A5276"]

  // Aggregation → Neuro
  TTR_amyloid -> PNS_dep [label="신경 침착" ltail=cluster_aggregation lhead=cluster_neuro style=bold color="#7D6608"]

  // Aggregation → Other organs
  TTR_amyloid -> Renal_dep [label="신장 침착" ltail=cluster_aggregation lhead=cluster_other_organs style=bold color="#1E8449"]
  TTR_amyloid -> GI_submucosal [ltail=cluster_aggregation lhead=cluster_other_organs label="위장관 침착"]

  // Oligomers → Cardiac toxicity
  TTR_oligomers -> Oligomer_CTox [ltail=cluster_aggregation lhead=cluster_cardiac label="직접 독성"]

  // Oligomers → Stress
  TTR_oligomers -> Oligomer_tox_s [ltail=cluster_aggregation lhead=cluster_stress label="독성 기전"]

  // Tafamidis PD → Aggregation
  Dissoc_inhibit -> Tet_dissociation [ltail=cluster_tafamidis lhead=cluster_aggregation label="⊣ 해리 억제" style=bold color=darkgreen arrowhead=tee]

  // siRNA/ASO → Production (mRNA)
  siRNA_net_TTR -> TTR_mRNA [ltail=cluster_gene_silencing lhead=cluster_genetics label="TTR mRNA↓" style=bold color=red arrowhead=tee]

  // BNP/Troponin → Staging
  BNP_biomarker -> NAC_staging [ltail=cluster_cardiac lhead=cluster_staging label="병기 결정"]
  Troponin_bio -> NAC_staging [ltail=cluster_cardiac lhead=cluster_staging]

  // mNIS+7 → Staging
  mNIS7_score -> DFM_staging [ltail=cluster_neuro lhead=cluster_staging label="신경 병기"]

  // Diagnosis connects to amyloid burden
  ECV_elevated -> Cardiac_dep [ltail=cluster_diagnosis lhead=cluster_cardiac style=dashed label="반영"]
  Perugini_grade -> Cardiac_dep [ltail=cluster_diagnosis lhead=cluster_cardiac style=dashed]

  // Exercise → Staging outcomes
  SixMWT_dist -> Functional_dec [ltail=cluster_cardiac lhead=cluster_staging]
  KCCQ_score_c -> QoL_outcome [ltail=cluster_cardiac lhead=cluster_staging]
}
