digraph achalasia_qsp_model {
  /* =========================================================================
     QSP Mechanistic Map — Primary Idiopathic Achalasia (식도이완불능증)
     Chicago Classification v4.0 (Type I/II/III) · Eckardt · IRP · TBE
     Pharmacology: Isosorbide Dinitrate · Nifedipine · Sildenafil · Botox
     Procedures: Pneumatic Dilation · Heller Myotomy · POEM
     ========================================================================= */
  graph [rankdir=LR, fontsize=12, splines=spline, overlap=false,
         nodesep=0.30, ranksep=0.55, compound=true, bgcolor="white",
         label="Achalasia · Quantitative Systems Pharmacology Map\nMyenteric Plexus Loss → NO/VIP Deficit → LES Non-relaxation + Esophageal Aperistalsis",
         labelloc="t", fontname="Helvetica-Bold"];
  node  [shape=box, style="rounded,filled", fontname="Helvetica", fontsize=10,
         margin="0.08,0.04", penwidth=1.1];
  edge  [fontname="Helvetica", fontsize=8, color="#444444", arrowsize=0.7];

  /* ============================== 1. ETIOLOGY ============================== */
  subgraph cluster_etiology {
    label="① Etiology & Triggers (idiopathic primary achalasia)";
    style="rounded,filled"; fillcolor="#FFF4E6"; color="#E8A33D"; fontcolor="#7A5200";
    HLA_DQA1   [label="HLA-DQA1*0103\nDQB1*0603\nAutoimmune risk", fillcolor="#FFE4B5"];
    HSV1_ANT   [label="HSV-1 antigen\n(myenteric)", fillcolor="#FFE4B5"];
    VZV_REACT  [label="VZV / HHV-6\nreactivation hypothesis", fillcolor="#FFE4B5"];
    MEAS_PARA  [label="Measles · paramyxo\nepidemiologic link", fillcolor="#FFE4B5"];
    TRYPANO    [label="T. cruzi infection\n→ Chagas megaesophagus\n(secondary, exclude)", fillcolor="#FFDAB9"];
    AAGS       [label="Allgrove (AAA)\nAAAS · ALADIN", fillcolor="#FFDAB9"];
    DOWN_SYN   [label="Down syndrome\n+ Trisomy 21", fillcolor="#FFDAB9"];
    FAMILIAL   [label="Familial achalasia\n<5% · sibling RR ~10", fillcolor="#FFDAB9"];
    ENV_TRIGGER[label="Environmental viral\n+ HLA permissive", fillcolor="#FFE4B5"];
    AGE_INC    [label="Bimodal incidence\n30–60 yr · 1.6/100k/y", fillcolor="#FFE4B5"];
    PSEUDOACH  [label="Pseudoachalasia\n(cancer · GEJ stricture)\nexclude with EGD", fillcolor="#FFDAB9"];
  }

  /* ============================== 2. AUTOIMMUNE NEURITIS =================== */
  subgraph cluster_autoimmune {
    label="② Autoimmune ganglionitis (myenteric plexus)";
    style="rounded,filled"; fillcolor="#FFE9E9"; color="#D9534F"; fontcolor="#7A2020";
    APCA       [label="Anti-myenteric\nplexus IgG", fillcolor="#FFC1C1"];
    CD8_T      [label="CD8⁺ cytotoxic T-cell\nperforin/granzyme", fillcolor="#FFC1C1"];
    TH17       [label="Th17 · IL-17/IL-23", fillcolor="#FFC1C1"];
    TREG_LOSS  [label="Treg dysfunction\n↓Foxp3", fillcolor="#FFC1C1"];
    MAST_CELL  [label="Mast cell tryptase\n+ eosinophils", fillcolor="#FFD0D0"];
    LIN_FIB    [label="Lymphocytic fibrosis\nin LES wall", fillcolor="#FFD0D0"];
    GAD65_AB   [label="Anti-GAD65 / SOX1\nparaneoplastic mimic", fillcolor="#FFD0D0"];
    GFAP_GLIA  [label="Enteric glia ↓\nGFAP+ S100B+", fillcolor="#FFD0D0"];
    NEURON_LOSS[label="Inhibitory neuron loss\n→ ICCs ↓\n→ NO/VIP deficit", fillcolor="#FF6B6B", fontcolor="white"];
    GANG_DENS  [label="Ganglion density\n<5/cm² LES (Csendes)", fillcolor="#FFC1C1"];
  }

  /* ============================== 3. NEUROCHEMISTRY ======================== */
  subgraph cluster_neurochem {
    label="③ Neurochemistry of LES (inhibitory vs excitatory imbalance)";
    style="rounded,filled"; fillcolor="#E6F3FF"; color="#4A90E2"; fontcolor="#1F3F66";
    NNOS       [label="nNOS\n(neuronal NO synthase)", fillcolor="#B7DBFF"];
    NO_TONE    [label="NO local diffusion\n→ sGC → cGMP", fillcolor="#B7DBFF"];
    SGC        [label="Soluble guanylyl\ncyclase (sGC)", fillcolor="#B7DBFF"];
    CGMP       [label="cGMP\nPKG → MLCP", fillcolor="#B7DBFF"];
    PDE5       [label="PDE5\n(cGMP hydrolysis)", fillcolor="#B7DBFF"];
    VIP_NEURO  [label="VIP / PACAP\n→ VPAC1 → AC → cAMP", fillcolor="#B7DBFF"];
    CAMP_LES   [label="cAMP\nPKA → MLCK ↓", fillcolor="#B7DBFF"];
    ACH_EX     [label="ACh\n(M2/M3 muscarinic)", fillcolor="#D6E9FF"];
    SP_EX      [label="Substance P\nNK1", fillcolor="#D6E9FF"];
    GABA_INH   [label="GABA / Glycine\nco-transmitter", fillcolor="#D6E9FF"];
    ICC_LOSS   [label="Interstitial cells of\nCajal (ICC) loss\n→ slow-wave failure", fillcolor="#B7DBFF"];
  }

  /* ============================== 4. LES SMOOTH MUSCLE ===================== */
  subgraph cluster_les {
    label="④ Lower esophageal sphincter (LES) smooth muscle";
    style="rounded,filled"; fillcolor="#E6FFE6"; color="#5BA85B"; fontcolor="#1F4F1F";
    LES_TONE   [label="Resting LES pressure\n(target 10–35 mmHg)\n→ Achalasia >35 mmHg", fillcolor="#A0D6A0"];
    MLC        [label="Myosin light chain\nphosphorylation", fillcolor="#A0D6A0"];
    MLCK       [label="MLCK\n(Ca²⁺/calmodulin)", fillcolor="#A0D6A0"];
    MLCP       [label="MLCP\n(cGMP/cAMP ↑)", fillcolor="#A0D6A0"];
    CA_CYTO    [label="Cytosolic Ca²⁺\nL-type Cav1.2 + RyR + IP3R", fillcolor="#A0D6A0"];
    CAV12      [label="L-type Ca²⁺ channel\n(Cav1.2 · α1C)\n(target: nifedipine)", fillcolor="#A0D6A0"];
    KATP       [label="K-ATP / KCa channels\nresting hyperpolarization", fillcolor="#C8E6C8"];
    RHOA_ROCK  [label="RhoA / ROCK\nCa²⁺-sensitization", fillcolor="#C8E6C8"];
    EGJ_NR     [label="EGJ failed relaxation\n(IRP > 15 mmHg)", fillcolor="#7FBF7F", fontcolor="white"];
    HYPERTROPH [label="LES muscle hypertrophy\n(chronic stage)", fillcolor="#C8E6C8"];
  }

  /* ============================== 5. ESOPHAGEAL BODY ======================= */
  subgraph cluster_body {
    label="⑤ Esophageal body — aperistalsis & pressurization";
    style="rounded,filled"; fillcolor="#FFF8E6"; color="#D4AC0D"; fontcolor="#7A6500";
    SWALLOW    [label="Swallow initiation\n(pharyngeal phase)", fillcolor="#F5E6A8"];
    PROP_PER   [label="Propulsive peristalsis\n(longitudinal then\ncircular)", fillcolor="#F5E6A8"];
    DEGLUTITIVE[label="Deglutitive inhibition\n→ LES relaxation\n(absent in achalasia)", fillcolor="#F5E6A8"];
    APER_T1    [label="Type I (classic):\n100% failed contraction\nlow pressurization", fillcolor="#F0DC7A"];
    APER_T2    [label="Type II:\npan-esophageal\npressurization ≥20%", fillcolor="#F0DC7A"];
    APER_T3    [label="Type III (spastic):\npremature/spastic\ncontractions ≥20%", fillcolor="#F0DC7A"];
    DCI        [label="Distal contractile\nintegral (DCI)\n(Type III >8000)", fillcolor="#F5E6A8"];
    ESO_BODY_P [label="Intraluminal pressure\n(stasis · stasis column)", fillcolor="#F5E6A8"];
    DILATE     [label="Esophageal dilatation\nØ >4cm → sigmoid", fillcolor="#F5E6A8"];
    FOOD_STASIS[label="Food/saliva stasis\n→ Candida overgrowth", fillcolor="#F5E6A8"];
    BARRETT_RISK[label="Stasis chronic inflammation\n→ ↑SCC 16× / ↑EAC", fillcolor="#F5E6A8"];
  }

  /* ============================== 6. CHICAGO CLASSIFICATION ================ */
  subgraph cluster_chicago {
    label="⑥ Chicago Classification v4.0 (HRM phenotyping)";
    style="rounded,filled"; fillcolor="#F0E6FF"; color="#8E5BD9"; fontcolor="#3F1F66";
    HRM        [label="High-resolution\nmanometry (HRM)\n+ EGJ provocative", fillcolor="#D6B7FF"];
    IRP_PARAM  [label="Integrated relaxation\npressure (IRP, 4s nadir)\n>15 mmHg = abnormal", fillcolor="#D6B7FF"];
    PRES_LES   [label="LES residual pressure\n(target post-Tx <10)", fillcolor="#D6B7FF"];
    EGJ_OUTFL  [label="EGJ outflow\nobstruction (EGJOO)\n(Tx-responsive subtype)", fillcolor="#D6B7FF"];
    FLIP_PANEL [label="EndoFLIP\n(distensibility <2.8\nmm²/mmHg)", fillcolor="#D6B7FF"];
    TBE        [label="Timed Barium\nEsophagram (TBE)\ncolumn 1/2/5 min", fillcolor="#D6B7FF"];
    EGD_FIND   [label="EGD: birdbeak GEJ\nresidual food\nopens to push", fillcolor="#D6B7FF"];
    PROVOCATIVE[label="Rapid drink\nstanding swallows\nSolid swallows", fillcolor="#D6B7FF"];
  }

  /* ============================== 7. DRUG PK ============================== */
  subgraph cluster_drug_pk {
    label="⑦ Drug pharmacokinetics (oral / sublingual / topical)";
    style="rounded,filled"; fillcolor="#FFE6F2"; color="#D9479C"; fontcolor="#6E1F4D";
    ISDN_PO    [label="Isosorbide dinitrate\n5 mg SL / 10–40 mg PO\nF=0.22 PO · F=1 SL · t½ 1h", fillcolor="#FFB7DD"];
    ISDN_ABS   [label="ISDN absorption\nka 1.4 /h", fillcolor="#FFB7DD"];
    ISDN_GST   [label="Gut/liver GST\n→ ISMN (active)\nt½ 5h", fillcolor="#FFB7DD"];
    NIFED_PO   [label="Nifedipine IR 10–20 mg SL\nF=0.5 · CL 30 L/h · t½ 2h\nCYP3A4", fillcolor="#FFB7DD"];
    SILD_PO    [label="Sildenafil 25–50 mg PO\nF=0.41 · CL 41 L/h · t½ 4h\nCYP3A4/2C9", fillcolor="#FFB7DD"];
    BOTOX_INJ  [label="Botulinum toxin A\n100 U intra-LES\n(4 × 25 U quadrant)\nlocal action", fillcolor="#FFB7DD"];
    BOTOX_DIFF [label="Botox diffusion\n(~3 mm)·local Kd", fillcolor="#FFB7DD"];
    PNEUMA_DIL [label="Pneumatic dilation\n30/35/40 mm balloon\n(graded protocol)", fillcolor="#FFB7DD"];
    LHM_PROC   [label="Laparoscopic Heller\nmyotomy + Dor/Toupet", fillcolor="#FFB7DD"];
    POEM_PROC  [label="POEM\nperoral endoscopic\nmyotomy", fillcolor="#FFB7DD"];
    TADAL_PO   [label="Tadalafil 20 mg\n(off-label, t½ 17h)", fillcolor="#FFD0E5"];
    THEO_PO    [label="Theophylline\n(weak PDE inh)\nadjunct", fillcolor="#FFD0E5"];
  }

  /* ============================== 8. DRUG PD ============================== */
  subgraph cluster_drug_pd {
    label="⑧ Drug pharmacodynamics on LES tone";
    style="rounded,filled"; fillcolor="#E6F8FF"; color="#3FA9D9"; fontcolor="#1F506E";
    NO_DONOR   [label="ISDN → NO\nexogenous donor", fillcolor="#B7E4FF"];
    SGC_ACT    [label="sGC ↑\nbypass nNOS loss", fillcolor="#B7E4FF"];
    CGMP_ELEV  [label="cGMP ↑\nLES tone ↓", fillcolor="#B7E4FF"];
    PDE5_INH   [label="Sildenafil → PDE5⁻¹\n→ cGMP preserved", fillcolor="#B7E4FF"];
    CCB_BLK    [label="Nifedipine → Cav1.2⁻¹\n→ Ca²⁺ influx ↓", fillcolor="#B7E4FF"];
    SNAP25_CLV [label="Botox SNAP-25 cleavage\n→ ACh exocytosis ↓\nin excitatory nerves", fillcolor="#B7E4FF"];
    BOTOX_DUR  [label="Botox duration\nmean 6 mo · re-dose 12 mo", fillcolor="#B7E4FF"];
    LES_PRESS_D[label="ΔLES pressure\n(ISDN −30%; Nifed −25%;\nSild −30%; Botox −50%)", fillcolor="#B7E4FF"];
    IRP_DROP   [label="ΔIRP after Tx", fillcolor="#B7E4FF"];
    HEADACHE   [label="Nitrate/PDE5 vasodilation\n→ headache · flushing\n(50–80%)", fillcolor="#D0EEFF"];
    POSTURAL   [label="Postural hypotension\nnifedipine·ISDN", fillcolor="#D0EEFF"];
    TOLERANCE  [label="Nitrate tolerance\n(thiol depletion)", fillcolor="#D0EEFF"];
  }

  /* ============================== 9. PROCEDURES =========================== */
  subgraph cluster_proc {
    label="⑨ Mechanical / surgical disruption of LES";
    style="rounded,filled"; fillcolor="#FFEFE6"; color="#D97C3F"; fontcolor="#7A3D1A";
    PD_TEAR    [label="PD: balloon tear\nof LES muscle\n(graded 30→35→40)", fillcolor="#FFC9A8"];
    PD_PERF    [label="Perforation risk\n1–3%", fillcolor="#FFC9A8"];
    LHM_CUT    [label="Heller myotomy\n6 cm esophagus +\n2 cm gastric", fillcolor="#FFC9A8"];
    LHM_DOR    [label="+ Dor (180° anterior)\nor Toupet (270° post)\nfundoplication", fillcolor="#FFC9A8"];
    POEM_TUNNEL[label="POEM submucosal\ntunnel + myotomy\n(typically 8–12 cm)", fillcolor="#FFC9A8"];
    POEM_LEN   [label="Longer myotomy\nadvantage in Type III\n(spastic)", fillcolor="#FFC9A8"];
    POST_PROC_GERD[label="Post-Tx GERD\n(POEM 30–50%, LHM 10–20%)", fillcolor="#FFC9A8"];
    PROC_DUR   [label="Durable remission\nLHM/POEM ~90% @ 2 y\nPD 60–80% @ 2 y", fillcolor="#FFC9A8"];
    PPI_AFTER  [label="PPI prophylaxis\nafter POEM (often\nlife-long)", fillcolor="#FFD9C0"];
    ESOPHAGECT [label="End-stage sigmoid\nesophagus → esophagectomy\nlast resort", fillcolor="#FFD9C0"];
  }

  /* ============================== 10. SYMPTOMS & ENDPOINTS ================ */
  subgraph cluster_clinical {
    label="⑩ Clinical endpoints (Eckardt · TBE · QoL)";
    style="rounded,filled"; fillcolor="#F8E6FF"; color="#A85BD9"; fontcolor="#4D1F66";
    DYSPHAGIA  [label="Dysphagia\n(solids + liquids)", fillcolor="#E2B7FF"];
    REGURGIT   [label="Regurgitation\nundigested food", fillcolor="#E2B7FF"];
    CHEST_PAIN [label="Retrosternal chest pain\n(Type III prominent)", fillcolor="#E2B7FF"];
    WEIGHT_LOSS[label="Weight loss\n(% body wt)", fillcolor="#E2B7FF"];
    ASPIRATION [label="Aspiration / pneumonia\nnocturnal cough", fillcolor="#E2B7FF"];
    HALITOSIS  [label="Halitosis · saliva\nregurgitation", fillcolor="#EBD2FF"];
    ECKARDT    [label="Eckardt symptom score\n0–12 · success ≤ 3", fillcolor="#A85BD9", fontcolor="white"];
    TBE_RES    [label="TBE column ht\nminute 5 (cm)\nsuccess: emptying ≥50%", fillcolor="#E2B7FF"];
    IRP_RES    [label="Residual IRP\n<10 mmHg (success)", fillcolor="#E2B7FF"];
    QOL_GERD   [label="GERD-HRQL · 36-Item\nachalasia-specific QoL", fillcolor="#E2B7FF"];
    SF36_ACH   [label="SF-36 · EQ-5D\ngeneral HRQoL", fillcolor="#EBD2FF"];
  }

  /* ============================== 11. COMPLICATIONS ======================= */
  subgraph cluster_comp {
    label="⑪ Long-term complications";
    style="rounded,filled"; fillcolor="#FFE6E6"; color="#B22222"; fontcolor="#660000";
    SIGMOID_E  [label="Sigmoid (end-stage)\nmegaesophagus\nØ >6 cm", fillcolor="#FFB7B7"];
    ESO_SCC    [label="Esophageal SCC\n16-fold risk\n(10–15 y latency)", fillcolor="#FFB7B7"];
    ESO_EAC    [label="Esophageal adenocarcinoma\n(if reflux post-Tx)", fillcolor="#FFB7B7"];
    PNEUMONIA  [label="Aspiration pneumonia\n· lung abscess", fillcolor="#FFB7B7"];
    MALNUTR    [label="Malnutrition\n· protein-energy\n· vit B12 ↓", fillcolor="#FFB7B7"];
    HYPER_CALC [label="Vitamin K/D loss\nbone health", fillcolor="#FFCFCF"];
    CANDIDA_E  [label="Esophageal candidiasis\n(stasis)", fillcolor="#FFCFCF"];
    MENTAL_HEALTH[label="Anxiety · depression\nfear of eating", fillcolor="#FFCFCF"];
  }

  /* ============================== 12. PATIENT COVARIATES =================== */
  subgraph cluster_covar {
    label="⑫ Patient covariates & modifiers";
    style="rounded,filled"; fillcolor="#EFEFEF"; color="#777777"; fontcolor="#333333";
    AGE_PT     [label="Age\n(elderly: surg risk)", fillcolor="#D9D9D9"];
    SEX_PT     [label="Sex (M:F 1:1)", fillcolor="#D9D9D9"];
    BMI_PT     [label="BMI / nutrition\nbaseline", fillcolor="#D9D9D9"];
    CYP3A4_PT  [label="CYP3A4 phenotype\n(nifed, sild)", fillcolor="#D9D9D9"];
    HEART_PT   [label="Cardiac history\nMI, hypotension", fillcolor="#D9D9D9"];
    DURATION   [label="Disease duration\n(years)\n→ neuron irreversible", fillcolor="#D9D9D9"];
    SUBTYPE_PT [label="Chicago subtype\n(I/II/III response)", fillcolor="#D9D9D9"];
    ETHNICITY  [label="Ethnic background\n(Chagas if endemic)", fillcolor="#D9D9D9"];
    SURGICAL_C [label="Surgical candidacy\nASA · BMI · age", fillcolor="#D9D9D9"];
    PSYCH_PT   [label="Anxiety/depression\nPRO modifier", fillcolor="#D9D9D9"];
  }

  /* ============================== 13. TRIALS & GUIDELINES ================= */
  subgraph cluster_trials {
    label="⑬ Pivotal trials & guidelines (calibration anchors)";
    style="rounded,filled"; fillcolor="#E6FFEF"; color="#1F8F4F"; fontcolor="#0F4F2F";
    EUROPEAN_TR[label="European Achalasia Trial\nBoeckxstaens 2011 NEJM\nPD vs LHM 2y · 86% vs 90%", fillcolor="#B7E8C9"];
    POEM_LHM   [label="POEM vs LHM\nWerner 2019 NEJM (Hannover)\n2y 83% vs 81%", fillcolor="#B7E8C9"];
    POEM_PD_RCT[label="POEM vs PD\nPonds 2019 JAMA\n2y 92% vs 54%", fillcolor="#B7E8C9"];
    CHICAGO_4  [label="Chicago Classification 4.0\nYadlapati 2021 NGM", fillcolor="#B7E8C9"];
    ACG_2020   [label="ACG Vaezi 2020\nguideline", fillcolor="#B7E8C9"];
    ISDE_2018  [label="ISDE guidelines\nZaninotto 2018", fillcolor="#B7E8C9"];
    BOTOX_PASR [label="Pasricha 1995/1996\nBotox 200 U pilot/RCT", fillcolor="#B7E8C9"];
    NIFED_TRIA [label="Triadafilopoulos 1991\nnifedipine SL trial", fillcolor="#B7E8C9"];
    SILD_BORTO [label="Bortolotti 2000\nsildenafil 50 mg study", fillcolor="#B7E8C9"];
    PD_VAEZI   [label="Vaezi/Richter\nPD long-term cohort", fillcolor="#B7E8C9"];
  }

  /* ============================== 14. SAFETY & AE ========================= */
  subgraph cluster_safety {
    label="⑭ Drug & procedure safety / AE";
    style="rounded,filled"; fillcolor="#FFF0F0"; color="#A0522D"; fontcolor="#4B2010";
    NITRATE_AE [label="Nitrate AE\nheadache·flushing·\nhypotension·tolerance", fillcolor="#FFCFCF"];
    CCB_AE     [label="CCB AE\npedal edema·hypotension·\nreflex tachycardia", fillcolor="#FFCFCF"];
    PDE5_AE    [label="PDE5 AE\nflushing·hypotension·\nNAION rare", fillcolor="#FFCFCF"];
    BOTOX_AE   [label="Botox AE\nchest pain·heartburn·\n(rare) mediastinitis", fillcolor="#FFCFCF"];
    PD_AE      [label="PD AE\nperforation 1-3%·\nreflux post 15-35%", fillcolor="#FFCFCF"];
    LHM_AE     [label="LHM AE\nperforation 5-7%·\ndysphagia recurr 5-10%", fillcolor="#FFCFCF"];
    POEM_AE    [label="POEM AE\ncapnoperitoneum·\nmucosal injury 5%·\nreflux 30-50%", fillcolor="#FFCFCF"];
    PPI_LONG   [label="PPI long-term\nrenal/bone/B12 risks", fillcolor="#FFCFCF"];
  }

  /* ===================== INTRA-CLUSTER EDGES (mechanisms) ===================== */
  HLA_DQA1 -> APCA;  HSV1_ANT -> CD8_T;  VZV_REACT -> CD8_T;
  MEAS_PARA -> CD8_T;  ENV_TRIGGER -> APCA;  ENV_TRIGGER -> CD8_T;
  HLA_DQA1 -> TH17;  CD8_T -> NEURON_LOSS [color="#D9534F", penwidth=1.3];
  APCA -> NEURON_LOSS [color="#D9534F"];  TH17 -> NEURON_LOSS;
  TREG_LOSS -> CD8_T;  MAST_CELL -> LIN_FIB;  LIN_FIB -> GANG_DENS;
  GFAP_GLIA -> NEURON_LOSS;  GANG_DENS -> NEURON_LOSS;
  GAD65_AB -> PSEUDOACH;  TRYPANO -> NEURON_LOSS;  AAGS -> NEURON_LOSS;
  DOWN_SYN -> NEURON_LOSS;  FAMILIAL -> NEURON_LOSS;

  NEURON_LOSS -> NNOS    [label="↓nNOS expression", color="#1F5BB8"];
  NEURON_LOSS -> VIP_NEURO [label="↓VIP",            color="#1F5BB8"];
  NEURON_LOSS -> ICC_LOSS;
  NNOS -> NO_TONE -> SGC -> CGMP;
  CGMP -> MLCP [label="PKG act"];
  PDE5 -> CGMP [label="hydrolysis", arrowhead=tee];
  VIP_NEURO -> CAMP_LES;  CAMP_LES -> MLCP;
  ACH_EX -> CA_CYTO [label="M2/M3"];
  SP_EX -> CA_CYTO;
  GABA_INH -> NEURON_LOSS [arrowhead=tee];

  CAV12 -> CA_CYTO;  CA_CYTO -> MLCK -> MLC -> LES_TONE;
  MLCP -> MLC [arrowhead=tee];
  RHOA_ROCK -> MLCP [arrowhead=tee];
  KATP -> CA_CYTO [arrowhead=tee];
  LES_TONE -> EGJ_NR;  HYPERTROPH -> LES_TONE;

  ICC_LOSS -> PROP_PER [arrowhead=tee, color="#888888"];
  DEGLUTITIVE -> EGJ_NR [arrowhead=tee];
  NEURON_LOSS -> DEGLUTITIVE [arrowhead=tee, color="#D9534F"];
  SWALLOW -> PROP_PER;
  PROP_PER -> ESO_BODY_P [arrowhead=tee];
  APER_T1 -> ESO_BODY_P;  APER_T2 -> ESO_BODY_P;  APER_T3 -> ESO_BODY_P;
  ESO_BODY_P -> DILATE -> FOOD_STASIS -> BARRETT_RISK;
  DCI -> APER_T3;

  HRM -> IRP_PARAM;  HRM -> PRES_LES;  HRM -> DCI;
  IRP_PARAM -> EGJ_NR;  EGJ_NR -> EGJ_OUTFL;  FLIP_PANEL -> EGJ_NR;
  TBE -> DILATE;  EGD_FIND -> PSEUDOACH;  PROVOCATIVE -> IRP_PARAM;

  /* ===================== DRUG PK → PD → BIOLOGY ============================== */
  ISDN_PO -> ISDN_ABS -> ISDN_GST -> NO_DONOR -> SGC_ACT -> CGMP_ELEV -> LES_PRESS_D;
  NIFED_PO -> CCB_BLK -> CA_CYTO [arrowhead=tee];
  CCB_BLK -> LES_PRESS_D;
  SILD_PO -> PDE5_INH;  PDE5_INH -> CGMP_ELEV;
  TADAL_PO -> PDE5_INH;  THEO_PO -> PDE5_INH;
  BOTOX_INJ -> BOTOX_DIFF -> SNAP25_CLV;  SNAP25_CLV -> ACH_EX [arrowhead=tee];
  SNAP25_CLV -> LES_PRESS_D;  BOTOX_DUR -> LES_PRESS_D [label="wanes"];
  LES_PRESS_D -> IRP_DROP;  IRP_DROP -> EGJ_NR [arrowhead=tee, color="#3FA9D9"];

  /* Procedures */
  PNEUMA_DIL -> PD_TEAR -> LES_PRESS_D;  PD_TEAR -> PD_PERF;  PD_TEAR -> POST_PROC_GERD;
  LHM_PROC -> LHM_CUT -> LES_PRESS_D;  LHM_CUT -> LHM_DOR;  LHM_DOR -> POST_PROC_GERD [arrowhead=tee];
  POEM_PROC -> POEM_TUNNEL -> LES_PRESS_D;  POEM_TUNNEL -> POEM_LEN;
  POEM_LEN -> APER_T3 [arrowhead=tee];  POEM_TUNNEL -> POST_PROC_GERD;
  POST_PROC_GERD -> PPI_AFTER;  PROC_DUR -> ECKARDT;  ESOPHAGECT -> SIGMOID_E [arrowhead=tee];

  /* Endpoint integration */
  EGJ_NR -> DYSPHAGIA;  DILATE -> REGURGIT;  APER_T3 -> CHEST_PAIN;
  FOOD_STASIS -> ASPIRATION -> PNEUMONIA;  FOOD_STASIS -> HALITOSIS;
  REGURGIT -> ASPIRATION;  DYSPHAGIA -> WEIGHT_LOSS -> MALNUTR;
  DYSPHAGIA -> ECKARDT;  REGURGIT -> ECKARDT;  CHEST_PAIN -> ECKARDT;  WEIGHT_LOSS -> ECKARDT;
  TBE -> TBE_RES;  IRP_PARAM -> IRP_RES;
  ECKARDT -> QOL_GERD;  QOL_GERD -> SF36_ACH;
  MENTAL_HEALTH -> QOL_GERD [arrowhead=tee];

  /* Long-term complications */
  SIGMOID_E -> ESOPHAGECT;  DILATE -> SIGMOID_E;
  FOOD_STASIS -> CANDIDA_E;  BARRETT_RISK -> ESO_SCC;
  POST_PROC_GERD -> ESO_EAC;  MALNUTR -> HYPER_CALC;

  /* Patient covariates */
  AGE_PT -> SURGICAL_C [arrowhead=tee];  BMI_PT -> SURGICAL_C;
  CYP3A4_PT -> NIFED_PO [color="#777777"];  CYP3A4_PT -> SILD_PO [color="#777777"];
  HEART_PT -> NITRATE_AE;  HEART_PT -> CCB_AE;  HEART_PT -> PDE5_AE;
  DURATION -> NEURON_LOSS;  SUBTYPE_PT -> PROC_DUR;
  SUBTYPE_PT -> POEM_LEN;  PSYCH_PT -> MENTAL_HEALTH;
  ETHNICITY -> TRYPANO;  AGE_INC -> AGE_PT;

  /* Trials → endpoints */
  EUROPEAN_TR -> PROC_DUR;  POEM_LHM -> PROC_DUR;  POEM_PD_RCT -> PROC_DUR;
  CHICAGO_4 -> HRM;  CHICAGO_4 -> SUBTYPE_PT;
  ACG_2020 -> ECKARDT;  ISDE_2018 -> ECKARDT;
  BOTOX_PASR -> BOTOX_INJ;  NIFED_TRIA -> NIFED_PO;  SILD_BORTO -> SILD_PO;
  PD_VAEZI -> PNEUMA_DIL;

  /* AE */
  ISDN_PO -> NITRATE_AE;  ISDN_PO -> TOLERANCE;  TOLERANCE -> LES_PRESS_D [arrowhead=tee];
  NIFED_PO -> CCB_AE;  SILD_PO -> PDE5_AE;  TADAL_PO -> PDE5_AE;
  BOTOX_INJ -> BOTOX_AE;  PNEUMA_DIL -> PD_AE;
  LHM_PROC -> LHM_AE;  POEM_PROC -> POEM_AE;  PPI_AFTER -> PPI_LONG;
  NITRATE_AE -> HEADACHE;  NITRATE_AE -> POSTURAL;
  PDE5_AE -> HEADACHE;  CCB_AE -> POSTURAL;

  /* Some cross-cluster style highlights */
  EGJ_NR [penwidth=2, color="#3FA9D9"];
  ECKARDT [penwidth=2, color="#A85BD9"];
  NEURON_LOSS [penwidth=2, color="#D9534F"];

  /* Legend */
  subgraph cluster_legend {
    label="Legend"; style="rounded,filled"; fillcolor="#FAFAFA"; color="#666666";
    L_E [label="Etiology", fillcolor="#FFE4B5"];
    L_I [label="Immune injury", fillcolor="#FFC1C1"];
    L_N [label="Neurochemistry", fillcolor="#B7DBFF"];
    L_M [label="LES muscle", fillcolor="#A0D6A0"];
    L_B [label="Esophageal body", fillcolor="#F5E6A8"];
    L_C [label="Chicago/HRM", fillcolor="#D6B7FF"];
    L_PK[label="Drug PK", fillcolor="#FFB7DD"];
    L_PD[label="Drug PD", fillcolor="#B7E4FF"];
    L_P [label="Procedures", fillcolor="#FFC9A8"];
    L_CE[label="Endpoints", fillcolor="#E2B7FF"];
    L_CO[label="Complications", fillcolor="#FFB7B7"];
    L_CV[label="Covariate", fillcolor="#D9D9D9"];
    L_TR[label="Trials/Guidelines", fillcolor="#B7E8C9"];
    L_AE[label="Safety/AE", fillcolor="#FFCFCF"];
    L_E -> L_I -> L_N -> L_M -> L_B -> L_C -> L_PK -> L_PD -> L_P -> L_CE -> L_CO -> L_CV -> L_TR -> L_AE
       [style=invis];
  }
}
