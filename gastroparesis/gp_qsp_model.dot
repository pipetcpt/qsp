digraph GastroparesisQSP {
  graph [
    label="Gastroparesis (위마비) — Quantitative Systems Pharmacology Model\nGastric Dysmotility · Enteric Neural Degeneration · ICC Loss · Drug PK/PD"
    labelloc=t
    fontsize=22
    fontname="Helvetica-Bold"
    rankdir=TB
    splines=ortho
    nodesep=0.4
    ranksep=0.6
    bgcolor="#FAFAFA"
    compound=true
  ]
  node [shape=box style="filled,rounded" fontname=Helvetica fontsize=10 margin="0.15,0.05"]
  edge [fontname=Helvetica fontsize=9 arrowsize=0.7]

  // =========================================================
  // CLUSTER 1: CNS & Vomiting Control
  // =========================================================
  subgraph cluster_CNS {
    label="CNS & Vomiting Control"
    style="filled,rounded"
    color="#C62828"
    fillcolor="#FFEBEE"
    fontsize=14
    fontcolor="#C62828"

    CNS_vomiting_center [label="Vomiting Centre\n(NTS/DVC)" fillcolor="#EF9A9A"]
    Area_postrema [label="Area Postrema\n(CTZ)" fillcolor="#EF9A9A"]
    NTS [label="Nucleus Tractus\nSolitarius (NTS)" fillcolor="#FFCDD2"]
    DMV [label="Dorsal Motor\nNucleus of Vagus" fillcolor="#FFCDD2"]
    Hypothalamus [label="Hypothalamus\n(CRF/Stress axis)" fillcolor="#FFCDD2"]
    CTZ_D2 [label="CTZ D2 Receptor\n(Antiemetic target)" fillcolor="#EF9A9A"]
    CTZ_5HT3 [label="CTZ 5-HT3 Receptor\n(Antiemetic target)" fillcolor="#EF9A9A"]
    Stress_CRF [label="CRF/Stress\nPathway" fillcolor="#FFCDD2"]
    CNS_5HT4 [label="CNS 5-HT4\nReceptor" fillcolor="#FFCDD2"]
    Vagal_output [label="Efferent Vagal\nOutput" fillcolor="#FFCDD2"]
  }

  // =========================================================
  // CLUSTER 2: Autonomic Nervous System
  // =========================================================
  subgraph cluster_ANS {
    label="Autonomic Nervous System (ANS)"
    style="filled,rounded"
    color="#1565C0"
    fillcolor="#E3F2FD"
    fontsize=14
    fontcolor="#1565C0"

    Vagal_efferents [label="Vagal Efferent\nFibers (CN X)" fillcolor="#90CAF9"]
    Vagal_afferents [label="Vagal Afferent\nFibers (CN X)" fillcolor="#90CAF9"]
    Vagal_neuropathy [label="Vagal Neuropathy\n(DM-induced)" fillcolor="#42A5F5" fontcolor=white]
    Sympathetic_innervation [label="Sympathetic\nInnervation (T6-T10)" fillcolor="#BBDEFB"]
    Adrenergic_alpha2 [label="α2-Adrenergic\nReceptor" fillcolor="#BBDEFB"]
    Adrenergic_beta2 [label="β2-Adrenergic\nReceptor" fillcolor="#BBDEFB"]
    nNOS_neurons_ANS [label="nNOS Neurons\n(NO inhibitory)" fillcolor="#90CAF9"]
    NO_production_ANS [label="Nitric Oxide (NO)\nProduction" fillcolor="#90CAF9"]
    VIP_neurons [label="VIP Neurons\n(Inhibitory)" fillcolor="#BBDEFB"]
    ACh_parasympathetic [label="ACh Release\n(Parasympathetic)" fillcolor="#BBDEFB"]
    Sympathetic_suppression [label="Sympathetic\nGI Suppression" fillcolor="#BBDEFB"]
  }

  // =========================================================
  // CLUSTER 3: Enteric Nervous System & ICC
  // =========================================================
  subgraph cluster_ENS {
    label="Enteric Nervous System (ENS) & Interstitial Cells of Cajal (ICC)"
    style="filled,rounded"
    color="#2E7D32"
    fillcolor="#E8F5E9"
    fontsize=14
    fontcolor="#2E7D32"

    Myenteric_plexus [label="Myenteric Plexus\n(Auerbach's)" fillcolor="#A5D6A7"]
    Submucosal_plexus [label="Submucosal Plexus\n(Meissner's)" fillcolor="#A5D6A7"]
    ICC_density [label="ICC Density\n(c-Kit+ cells)" fillcolor="#66BB6A" fontcolor=white]
    ICC_loss [label="ICC Loss\n(Pathological)" fillcolor="#EF5350" fontcolor=white]
    SCF_cKit [label="SCF/c-Kit\nSignaling" fillcolor="#C8E6C9"]
    Pacemaker_activity [label="Pacemaker\nActivity (3 cpm)" fillcolor="#A5D6A7"]
    Slow_waves [label="Gastric Slow\nWaves" fillcolor="#A5D6A7"]
    ENS_nNOS [label="ENS nNOS\n(Inhibitory motor)" fillcolor="#C8E6C9"]
    ENS_ACh [label="ENS ACh\n(Excitatory motor)" fillcolor="#C8E6C9"]
    ENS_5HT [label="ENS 5-HT\n(Mucosal signal)" fillcolor="#C8E6C9"]
    ENS_SP [label="Substance P (SP)\nNK1 signaling" fillcolor="#C8E6C9"]
    ENS_VIP [label="ENS VIP\n(Relaxant)" fillcolor="#C8E6C9"]
  }

  // =========================================================
  // CLUSTER 4: Neurotransmitter Signaling
  // =========================================================
  subgraph cluster_NT {
    label="Neurotransmitter & Receptor Signaling"
    style="filled,rounded"
    color="#4527A0"
    fillcolor="#EDE7F6"
    fontsize=14
    fontcolor="#4527A0"

    Dopamine_D2 [label="Dopamine D2\nReceptor" fillcolor="#CE93D8"]
    Dopamine_levels [label="Dopamine\nConcentration" fillcolor="#E1BEE7"]
    Serotonin_5HT [label="Serotonin (5-HT)\nENS release" fillcolor="#CE93D8"]
    Receptor_5HT3 [label="5-HT3 Receptor\n(Nausea/emesis)" fillcolor="#CE93D8"]
    Receptor_5HT4 [label="5-HT4 Receptor\n(Prokinetic)" fillcolor="#CE93D8"]
    Motilin_receptor [label="Motilin Receptor\n(Duodenal hormone)" fillcolor="#E1BEE7"]
    Motilin_levels [label="Plasma Motilin\nLevels" fillcolor="#E1BEE7"]
    Ghrelin_GHSR [label="Ghrelin / GHSR\n(Orexigenic+prokinetic)" fillcolor="#CE93D8"]
    Ghrelin_levels [label="Plasma Ghrelin\nConcentration" fillcolor="#E1BEE7"]
    ACh_muscarinic [label="Muscarinic M2/M3\nReceptor" fillcolor="#E1BEE7"]
    Histamine_H2 [label="Histamine H2\nReceptor (acid)" fillcolor="#EDE7F6"]
    NK1_receptor [label="Neurokinin-1 (NK1)\nReceptor" fillcolor="#E1BEE7"]
  }

  // =========================================================
  // CLUSTER 5: Gastric Motor Function
  // =========================================================
  subgraph cluster_motor {
    label="Gastric Motor Function"
    style="filled,rounded"
    color="#E65100"
    fillcolor="#FFF3E0"
    fontsize=14
    fontcolor="#E65100"

    Gastric_fundus [label="Gastric Fundus\nAccommodation" fillcolor="#FFCC80"]
    Fundic_relaxation [label="Fundic\nReceptive Relaxation" fillcolor="#FFCC80"]
    Antrum_contractions [label="Antral Peristaltic\nContractions (3/min)" fillcolor="#FFA726"]
    Pyloric_tone [label="Pyloric Tone\n(Resistance)" fillcolor="#FFCC80"]
    Pylorus_relaxation [label="Pyloric\nRelaxation" fillcolor="#FFE0B2"]
    Gastroduodenal_coord [label="Gastroduodenal\nCoordination" fillcolor="#FFE0B2"]
    Gastric_emptying_rate [label="Gastric Emptying\nRate (GER)" fillcolor="#FF7043" fontcolor=white]
    Gastric_retention_4h [label="4h Gastric\nRetention (%)" fillcolor="#FF7043" fontcolor=white]
    Intragastric_pressure [label="Intragastric\nPressure" fillcolor="#FFCC80"]
    Antral_grinding [label="Antral Trituration\n(Grinding)" fillcolor="#FFE0B2"]
    Peristalsis [label="Gastric\nPeristalsis" fillcolor="#FFE0B2"]
    Food_particle_size [label="Food Particle\nSize Reduction" fillcolor="#FFE0B2"]
  }

  // =========================================================
  // CLUSTER 6: Pathophysiology
  // =========================================================
  subgraph cluster_path {
    label="Core Pathophysiology"
    style="filled,rounded"
    color="#37474F"
    fillcolor="#ECEFF1"
    fontsize=14
    fontcolor="#37474F"

    Oxidative_stress [label="Oxidative Stress\n(ROS excess)" fillcolor="#B0BEC5"]
    ROS_production [label="Superoxide / H2O2\nProduction" fillcolor="#B0BEC5"]
    iNOS_overactivation [label="iNOS\nOveractivation" fillcolor="#90A4AE"]
    nNOS_deficiency [label="nNOS Activity\nDeficiency" fillcolor="#EF5350" fontcolor=white]
    HO1_induction [label="Heme Oxygenase-1\n(HO-1) Induction" fillcolor="#B0BEC5"]
    Macrophage_M2 [label="Macrophage M2\n(Anti-inflam polariz.)" fillcolor="#CFD8DC"]
    Macrophage_M1 [label="Macrophage M1\n(Pro-inflam)" fillcolor="#CFD8DC"]
    Smooth_muscle_injury [label="Gastric Smooth\nMuscle Injury" fillcolor="#90A4AE"]
    Neural_degeneration [label="Enteric Neural\nDegeneration" fillcolor="#90A4AE"]
    Inflammation_ENS [label="ENS\nInflammation" fillcolor="#90A4AE"]
    Myopathy_gastric [label="Gastric\nMyopathy" fillcolor="#90A4AE"]
    Gastric_fibrosis [label="Gastric Wall\nFibrosis" fillcolor="#90A4AE"]
  }

  // =========================================================
  // CLUSTER 7: Diabetic Mechanisms
  // =========================================================
  subgraph cluster_DM {
    label="Diabetic Gastroparesis Mechanisms"
    style="filled,rounded"
    color="#AD1457"
    fillcolor="#FCE4EC"
    fontsize=14
    fontcolor="#AD1457"

    Hyperglycemia [label="Acute\nHyperglycemia" fillcolor="#F48FB1"]
    HbA1c [label="HbA1c\n(Chronic glycemia)" fillcolor="#F48FB1"]
    Insulin_deficiency [label="Insulin Deficiency\n(T1DM/T2DM)" fillcolor="#F48FB1"]
    Autonomic_neuropathy_DM [label="Diabetic Autonomic\nNeuropathy" fillcolor="#F06292"]
    AGE_RAGE [label="AGE-RAGE\nSignaling" fillcolor="#FCE4EC"]
    Microvascular_disease [label="Gastric\nMicrovascular Disease" fillcolor="#FCE4EC"]
    GLP1_signaling [label="GLP-1\nSignaling" fillcolor="#FCE4EC"]
    GIP_signaling [label="GIP\nSignaling" fillcolor="#FCE4EC"]
    Hyperglycemia_GER [label="Hyperglycemia→\nGER Slowing" fillcolor="#F48FB1"]
    Insulin_GER [label="Insulin→\nGER Acceleration" fillcolor="#FCE4EC"]
    DM_nNOS_loss [label="DM-induced\nnNOS Loss" fillcolor="#F06292"]
  }

  // =========================================================
  // CLUSTER 8: Drug PK (Pharmacokinetics)
  // =========================================================
  subgraph cluster_PK {
    label="Drug Pharmacokinetics"
    style="filled,rounded"
    color="#006064"
    fillcolor="#E0F7FA"
    fontsize=14
    fontcolor="#006064"

    MCP_dose [label="Metoclopramide\nDose (10mg QID)" fillcolor="#80DEEA"]
    MCP_GI [label="Metoclopramide\nGI Absorption" fillcolor="#80DEEA"]
    MCP_plasma [label="Metoclopramide\nPlasma Conc." fillcolor="#00BCD4" fontcolor=white]
    MCP_CNS [label="Metoclopramide\nCNS Concentration" fillcolor="#80DEEA"]
    DOM_dose [label="Domperidone\nDose (10mg TID)" fillcolor="#B2EBF2"]
    DOM_plasma [label="Domperidone\nPlasma Conc." fillcolor="#00BCD4" fontcolor=white]
    ERY_dose [label="Erythromycin\nDose (250mg TID)" fillcolor="#B2EBF2"]
    ERY_plasma [label="Erythromycin\nPlasma Conc." fillcolor="#00BCD4" fontcolor=white]
    PRU_dose [label="Prucalopride\nDose (2mg QD)" fillcolor="#B2EBF2"]
    PRU_plasma [label="Prucalopride\nPlasma Conc." fillcolor="#00BCD4" fontcolor=white]
    REL_dose [label="Relamorelin\nDose (100mcg BID)" fillcolor="#B2EBF2"]
    REL_plasma [label="Relamorelin\nPlasma Conc." fillcolor="#00BCD4" fontcolor=white]
    OND_dose [label="Ondansetron\nDose (8mg TID)" fillcolor="#B2EBF2"]
    OND_plasma [label="Ondansetron\nPlasma Conc." fillcolor="#00BCD4" fontcolor=white]
  }

  // =========================================================
  // CLUSTER 9: Drug PD (Pharmacodynamics)
  // =========================================================
  subgraph cluster_PD {
    label="Drug Pharmacodynamics (Receptor Effects)"
    style="filled,rounded"
    color="#558B2F"
    fillcolor="#F1F8E9"
    fontsize=14
    fontcolor="#558B2F"

    MCP_D2_block [label="MCP: D2 Block\n(GI+CNS)" fillcolor="#AED581"]
    MCP_5HT4_stim [label="MCP: 5-HT4\nStimulation" fillcolor="#AED581"]
    MCP_5HT3_block [label="MCP: 5-HT3\nBlock (antiemetic)" fillcolor="#AED581"]
    DOM_D2_periph [label="DOM: Peripheral\nD2 Block" fillcolor="#C5E1A5"]
    ERY_motilin [label="ERY: Motilin\nReceptor Agonist" fillcolor="#AED581"]
    PRU_5HT4 [label="PRU: High-affinity\n5-HT4 Agonist" fillcolor="#AED581"]
    REL_GHSR [label="REL: GHSR\nAgonist (ghrelin)" fillcolor="#AED581"]
    OND_5HT3_block [label="OND: 5-HT3 Block\n(CTZ+ENS)" fillcolor="#C5E1A5"]
    Prokinetic_effect [label="Prokinetic\nNet Effect" fillcolor="#8BC34A" fontcolor=white]
    Antiemetic_effect [label="Antiemetic\nNet Effect" fillcolor="#8BC34A" fontcolor=white]
    Pyloric_inhibition [label="Pyloric Tone\nInhibition" fillcolor="#C5E1A5"]
    Antral_stimulation [label="Antral\nStimulation" fillcolor="#C5E1A5"]
  }

  // =========================================================
  // CLUSTER 10: Clinical Outcomes
  // =========================================================
  subgraph cluster_outcomes {
    label="Clinical Outcomes & Endpoints"
    style="filled,rounded"
    color="#BF360C"
    fillcolor="#FBE9E7"
    fontsize=14
    fontcolor="#BF360C"

    GCSI_score [label="GCSI Score\n(0-5 composite)" fillcolor="#FFAB91"]
    Nausea_VAS [label="Nausea VAS\n(0-100mm)" fillcolor="#FFAB91"]
    Vomiting_freq [label="Vomiting\nFrequency (/day)" fillcolor="#FFAB91"]
    Early_satiety [label="Early\nSatiety Score" fillcolor="#FF8A65"]
    Bloating_score [label="Bloating/\nDistension Score" fillcolor="#FF8A65"]
    Postprandial_pain [label="Postprandial\nPain/Fullness" fillcolor="#FF8A65"]
    Weight_loss [label="Weight Loss\n(kg/month)" fillcolor="#FFAB91"]
    Nutritional_status [label="Nutritional Status\n(albumin, pre-alb)" fillcolor="#FF8A65"]
    GES_T50 [label="Gastric Emptying\nT50 (min)" fillcolor="#E64A19" fontcolor=white]
    Retention_4h [label="4h Gastric\nRetention (>10%=delayed)" fillcolor="#E64A19" fontcolor=white]
    QoL_score [label="Quality of Life\n(PAGI-QoL)" fillcolor="#FF8A65"]
    Hospitalization [label="Hospitalization\nRate (per year)" fillcolor="#FF8A65"]
  }

  // =========================================================
  // EDGES: CNS → ANS
  // =========================================================
  DMV -> Vagal_efferents [label="vagal outflow" color="#1565C0"]
  Hypothalamus -> Stress_CRF [label="CRF release" color="#C62828"]
  Stress_CRF -> CNS_vomiting_center [label="emesis signal" color="#C62828"]
  Area_postrema -> CTZ_D2 [label="D2 expresses" color="#C62828"]
  Area_postrema -> CTZ_5HT3 [label="5HT3 expresses" color="#C62828"]
  NTS -> CNS_vomiting_center [label="integrates afferents" color="#C62828"]
  Vagal_output -> Vagal_efferents [label="descending signal" color="#1565C0" lhead=cluster_ANS]

  // =========================================================
  // EDGES: ANS ↔ ENS
  // =========================================================
  Vagal_efferents -> Myenteric_plexus [label="excitatory" color="#2E7D32"]
  Vagal_efferents -> nNOS_neurons_ANS [label="activates" color="#2E7D32"]
  Vagal_neuropathy -> nNOS_neurons_ANS [label="impairs" color="red" style=dashed]
  Vagal_neuropathy -> ACh_parasympathetic [label="reduces" color="red" style=dashed]
  nNOS_neurons_ANS -> NO_production_ANS [label="catalyzes" color="#1565C0"]
  NO_production_ANS -> Pyloric_tone [label="relaxes pylorus" color="#1565C0"]
  ACh_parasympathetic -> Antrum_contractions [label="stimulates" color="#1565C0"]
  Sympathetic_innervation -> Sympathetic_suppression [label="inhibits motility" color="#37474F"]
  VIP_neurons -> Fundic_relaxation [label="mediates" color="#1565C0"]
  Vagal_afferents -> NTS [label="transmits GI signals" color="#C62828"]

  // =========================================================
  // EDGES: ENS Internal
  // =========================================================
  Myenteric_plexus -> ENS_ACh [label="releases" color="#2E7D32"]
  Myenteric_plexus -> ENS_nNOS [label="releases" color="#2E7D32"]
  Myenteric_plexus -> ENS_VIP [label="releases" color="#2E7D32"]
  ENS_nNOS -> Pyloric_tone [label="inhibits (relaxes)" color="#2E7D32"]
  ENS_ACh -> Antrum_contractions [label="drives" color="#2E7D32"]
  ENS_ACh -> ACh_muscarinic [label="binds M2/M3" color="#4527A0"]
  Submucosal_plexus -> ENS_5HT [label="5-HT release" color="#2E7D32"]
  ENS_5HT -> Receptor_5HT3 [label="activates" color="#4527A0"]
  ENS_5HT -> Receptor_5HT4 [label="activates" color="#4527A0"]
  ENS_SP -> NK1_receptor [label="binds NK1" color="#4527A0"]
  ICC_density -> Pacemaker_activity [label="drives" color="#2E7D32"]
  Pacemaker_activity -> Slow_waves [label="generates 3cpm" color="#2E7D32"]
  Slow_waves -> Antrum_contractions [label="phase-locks" color="#2E7D32"]
  SCF_cKit -> ICC_density [label="maintains" color="#2E7D32"]
  ICC_loss -> ICC_density [label="reduces" color="red"]

  // =========================================================
  // EDGES: Pathophysiology
  // =========================================================
  Oxidative_stress -> iNOS_overactivation [label="activates" color="#37474F"]
  iNOS_overactivation -> nNOS_deficiency [label="competitive inhibit." color="red"]
  nNOS_deficiency -> Pyloric_tone [label="increases (constricts)" color="red"]
  nNOS_deficiency -> ENS_nNOS [label="depletes" color="red"]
  ROS_production -> Oxidative_stress [label="causes" color="#37474F"]
  Oxidative_stress -> HO1_induction [label="induces cytoprotective" color="#37474F"]
  Macrophage_M1 -> Inflammation_ENS [label="promotes" color="red"]
  Macrophage_M2 -> HO1_induction [label="expresses" color="#37474F"]
  Inflammation_ENS -> Neural_degeneration [label="causes" color="red"]
  Neural_degeneration -> nNOS_deficiency [label="depletes nNOS neurons" color="red"]
  Neural_degeneration -> ICC_loss [label="ICC-ANS crosstalk loss" color="red"]
  Smooth_muscle_injury -> Myopathy_gastric [label="progresses to" color="#37474F"]
  Myopathy_gastric -> Antrum_contractions [label="impairs" color="red" style=dashed]
  Gastric_fibrosis -> Smooth_muscle_injury [label="results from" color="#37474F"]

  // =========================================================
  // EDGES: Diabetic Mechanisms
  // =========================================================
  Hyperglycemia -> Oxidative_stress [label="drives" color="#AD1457"]
  Hyperglycemia -> Vagal_neuropathy [label="accelerates" color="red"]
  Hyperglycemia -> Hyperglycemia_GER [label="directly slows" color="red"]
  HbA1c -> Autonomic_neuropathy_DM [label="chronic hyperglycemia" color="#AD1457"]
  HbA1c -> DM_nNOS_loss [label="drives" color="red"]
  Autonomic_neuropathy_DM -> Vagal_neuropathy [label="includes" color="#AD1457"]
  AGE_RAGE -> Oxidative_stress [label="promotes" color="#AD1457"]
  AGE_RAGE -> Inflammation_ENS [label="activates" color="#AD1457"]
  Microvascular_disease -> Ischemia_ENS [label="causes ENS ischemia" color="red"]
  GLP1_signaling -> Gastric_emptying_rate [label="slows GER (GLP-1RA)" color="red" style=dashed]
  Hyperglycemia_GER -> Gastric_emptying_rate [label="inhibits" color="red"]
  DM_nNOS_loss -> nNOS_deficiency [label="contributes" color="red"]
  Insulin_GER -> Gastric_emptying_rate [label="accelerates" color="#2E7D32"]
  Insulin_deficiency -> Insulin_GER [label="lacks" color="red" style=dashed]

  // =========================================================
  // EDGES: Drug PK
  // =========================================================
  MCP_dose -> MCP_GI [label="oral absorption\nka=1.2/h" color="#006064"]
  MCP_GI -> MCP_plasma [label="F=0.75 CL=70L/h" color="#006064"]
  MCP_plasma -> MCP_CNS [label="BBB penetration" color="#006064"]
  DOM_dose -> DOM_plasma [label="ka=0.8/h F=0.15" color="#006064"]
  ERY_dose -> ERY_plasma [label="ka=0.6/h F=0.35" color="#006064"]
  PRU_dose -> PRU_plasma [label="ka=0.9/h F=0.90" color="#006064"]
  REL_dose -> REL_plasma [label="SC ka=0.5/h" color="#006064"]
  OND_dose -> OND_plasma [label="ka=1.0/h F=0.60" color="#006064"]

  // =========================================================
  // EDGES: Drug PD
  // =========================================================
  MCP_plasma -> MCP_D2_block [label="IC50=5ng/mL" color="#558B2F"]
  MCP_CNS -> MCP_D2_block [label="CNS D2 block" color="#558B2F"]
  MCP_plasma -> MCP_5HT4_stim [label="EC50=50ng/mL" color="#558B2F"]
  MCP_plasma -> MCP_5HT3_block [label="IC50=30ng/mL" color="#558B2F"]
  DOM_plasma -> DOM_D2_periph [label="peripheral D2 block" color="#558B2F"]
  ERY_plasma -> ERY_motilin [label="motilin agonist\nEC50=0.5mg/L" color="#558B2F"]
  PRU_plasma -> PRU_5HT4 [label="high-affinity 5HT4\nEC50=3ng/mL" color="#558B2F"]
  REL_plasma -> REL_GHSR [label="GHSR agonist" color="#558B2F"]
  OND_plasma -> OND_5HT3_block [label="5-HT3 block\nIC50=8ng/mL" color="#558B2F"]

  MCP_D2_block -> Prokinetic_effect [label="D2 block →\nACh release" color="#558B2F"]
  MCP_5HT4_stim -> Prokinetic_effect [label="5HT4 →\nACh ↑" color="#558B2F"]
  MCP_5HT3_block -> Antiemetic_effect [label="5HT3 block\n→ antiemetic" color="#558B2F"]
  DOM_D2_periph -> Prokinetic_effect [label="D2 block\nGI prokinetic" color="#558B2F"]
  ERY_motilin -> Antral_stimulation [label="antral motor\nactivity ↑" color="#558B2F"]
  PRU_5HT4 -> Prokinetic_effect [label="potent prokinetic" color="#558B2F"]
  REL_GHSR -> Antral_stimulation [label="antral contractility\n↑ (ghrelin mimic)" color="#558B2F"]
  OND_5HT3_block -> Antiemetic_effect [label="CTZ 5HT3 block" color="#558B2F"]
  Prokinetic_effect -> Antral_stimulation [label="drives" color="#558B2F"]
  Prokinetic_effect -> Pyloric_inhibition [label="reduces pyloric\nresistance" color="#558B2F"]
  Antral_stimulation -> Antrum_contractions [label="enhances" color="#2E7D32"]
  Pyloric_inhibition -> Pyloric_tone [label="reduces" color="#2E7D32"]

  // =========================================================
  // EDGES: Motor Function → Outcomes
  // =========================================================
  Antrum_contractions -> Antral_grinding [label="propels" color="#E65100"]
  Antral_grinding -> Food_particle_size [label="reduces" color="#E65100"]
  Antrum_contractions -> Peristalsis [label="propulsive waves" color="#E65100"]
  Peristalsis -> Gastric_emptying_rate [label="drives" color="#E65100"]
  Pyloric_tone -> Gastric_retention_4h [label="increases retention" color="red"]
  Pyloric_tone -> Pylorus_relaxation [label="opposes" color="#E65100"]
  Pylorus_relaxation -> Gastric_emptying_rate [label="permits emptying" color="#2E7D32"]
  Gastric_fundus -> Intragastric_pressure [label="generates" color="#E65100"]
  Fundic_relaxation -> Intragastric_pressure [label="reduces" color="#E65100"]
  Intragastric_pressure -> Gastric_emptying_rate [label="gradient drives" color="#E65100"]
  Gastroduodenal_coord -> Gastric_emptying_rate [label="coordinates" color="#E65100"]
  Slow_waves -> Peristalsis [label="phase-locks" color="#2E7D32"]
  Gastric_emptying_rate -> GES_T50 [label="determines" color="#BF360C"]
  Gastric_emptying_rate -> Retention_4h [label="inverse" color="#BF360C"]
  Gastric_retention_4h -> Retention_4h [label="measures" color="#BF360C"]

  // =========================================================
  // EDGES: Outcomes
  // =========================================================
