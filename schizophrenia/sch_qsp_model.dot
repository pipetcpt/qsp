digraph SchizophreniaQSP {
  graph [
    rankdir=TB
    fontname="Helvetica"
    fontsize=11
    label="Schizophrenia (SCZ) QSP Model\nDopamine · Glutamate · GABA · Serotonin Pathways + Antipsychotic PK/PD + Clinical Endpoints"
    labelloc=t
    bgcolor="#f5f5f5"
    pad=0.6
    nodesep=0.35
    ranksep=0.55
    splines=ortho
    compound=true
  ]
  node [
    shape=box style="rounded,filled"
    fontname="Helvetica" fontsize=8
    margin="0.08,0.04" width=1.5
  ]
  edge [fontname="Helvetica" fontsize=7 arrowsize=0.6]

  // ============================================================
  // CLUSTER 1: NEURODEVELOPMENTAL RISK FACTORS
  // ============================================================
  subgraph cluster_neurodevel {
    label="① Neurodevelopmental Risk Factors"
    style=filled color="#cba4e8" fillcolor="#f0e6fc"
    fontcolor="#4a0080" fontsize=11 fontname="Helvetica-Bold"
    node [fillcolor="#dbb6f5" color="#7b2fbe"]

    DISC1     [label="DISC1\n(Disrupted in SCZ 1)"]
    NRG1      [label="NRG1\n(Neuregulin-1)"]
    DTNBP1    [label="DTNBP1\n(Dysbindin-1)"]
    COMT_gene [label="COMT Val158Met\n(DA catabolism gene)"]
    CACNA1C   [label="CACNA1C\n(L-type Ca²⁺ channel)"]
    DRD2_gene [label="DRD2 Gene\n(D2 receptor gene)"]
    GRM3_gene [label="GRM3\n(mGluR3 gene)"]
    CNTNAP2   [label="CNTNAP2\n(GABAergic circuit)"]
    C4A_gene  [label="C4A\n(Complement, pruning)"]

    EnvStress   [label="Prenatal/Perinatal Stress\n(HPA dysregulation)"]
    ChildTrauma [label="Childhood Trauma\n(Adverse events)"]
    UrbanBirth  [label="Urban Birth/Upbringing\n(Epidemiological factor)"]
    Cannabis_exp [label="Cannabis Exposure\n(THC, adolescent)"]

    CortexDevel     [label="Cortical Development\nDisruption (in utero)"]
    SynapticPruning [label="Excessive Synaptic\nPruning (adolescence)"]
    NeuronMigration [label="Neuronal Migration\nDefects"]
    DopamineDevel   [label="Dopamine System\nMaturational Deficit"]
    GlutamateDevel  [label="Glutamate System\nDevelopmental Dysregulation"]
  }

  // ============================================================
  // CLUSTER 2: DOPAMINERGIC SYSTEM
  // ============================================================
  subgraph cluster_dopamine {
    label="② Dopaminergic Pathways"
    style=filled color="#8bbee8" fillcolor="#e8f4fb"
    fontcolor="#0b3d6e" fontsize=11 fontname="Helvetica-Bold"
    node [fillcolor="#aed6f1" color="#1a5276"]

    Tyrosine [label="Tyrosine\n(Dietary AA)"]
    TH       [label="Tyrosine Hydroxylase (TH)\n(Rate-limiting step)"]
    LDOPA    [label="L-DOPA\n(Intermediate)"]
    DDC      [label="DOPA Decarboxylase\n(DDC/AADC)"]
    DA_synth [label="Dopamine (DA)\nSynthesized"]
    VMAT2    [label="VMAT2\n(Vesicular storage)"]

    VTA   [label="Ventral Tegmental\nArea (VTA)"]
    NAc   [label="Nucleus Accumbens\n(NAc)"]
    MesolimbicDA    [label="Mesolimbic DA\n▲ Hyperactive in SCZ"]
    AberrantSalience [label="Aberrant Salience\nSignaling"]

    PFC_DA [label="PFC Dopamine\n▼ Hypoactive in SCZ"]
    DLPFC  [label="DLPFC\n(Dorsolateral PFC)"]

    SNc          [label="Substantia Nigra\ncompacta (SNc)"]
    DorsalStriatum [label="Dorsal Striatum\n(Caudate/Putamen)"]
    NigrostriatalDA [label="Nigrostriatal DA\n(Motor control)"]

    ArcNucleus [label="Arcuate Nucleus\n(Hypothalamus)"]
    PituitaryDA [label="Tuberoinfundibular\nDA Pathway"]
    PRLlevel    [label="Prolactin\n(Pituitary)"]

    D1R    [label="D1 Receptor\n(Gs-coupled, excitatory)"]
    D2R    [label="D2 Receptor\n(Gi-coupled, inhibitory)"]
    D3R    [label="D3 Receptor\n(Limbic system)"]
    D2auto [label="D2 Autoreceptor\n(Presynaptic feedback)"]

    DAT      [label="DAT\n(Dopamine Transporter)"]
    MAOB     [label="MAO-B\n(DA degradation)"]
    COMT_enz [label="COMT Enzyme\n(PFC DA catabolism)"]
    DOPAC    [label="DOPAC\n(Intermediate metabolite)"]
    HVA      [label="HVA\n(Urine/CSF biomarker)"]
  }

  // ============================================================
  // CLUSTER 3: GLUTAMATERGIC / NMDA SYSTEM
  // ============================================================
  subgraph cluster_glutamate {
    label="③ Glutamatergic / NMDA System"
    style=filled color="#7dce8b" fillcolor="#e8faf0"
    fontcolor="#0d5e33" fontsize=11 fontname="Helvetica-Bold"
    node [fillcolor="#a9dfbf" color="#145a32"]

    Glu    [label="Glutamate (Glu)\n(Main excitatory NT)"]
    VGluT  [label="VGluT1/2\n(Vesicular transporter)"]
    NMDAR  [label="NMDA Receptor\n(GluN1+GluN2A/2B)"]
    AMPAR  [label="AMPA Receptor\n(Fast excitation)"]
    mGluR1_5 [label="mGluR1/5\n(Group I, Gq-coupled)"]
    mGluR2_3 [label="mGluR2/3\n(Group II, presynaptic)"]
    mGluR4_7 [label="mGluR4/7/8\n(Group III)"]

    EAAT1 [label="EAAT1/GLAST\n(Astrocyte uptake)"]
    EAAT2 [label="EAAT2/GLT-1\n(90% glial uptake)"]

    Glycine_site [label="Glycine Site\n(NMDA co-agonist)"]
    Dserine      [label="D-Serine\n(NMDA co-agonist)"]
    SRase        [label="Serine Racemase\n(D-Ser synthesis)"]

    NMDAhypo     [label="NMDA Hypofunction\n(Core SCZ mechanism)"]
    PV_disinhibit [label="PV Interneuron\nHypofunction/Disinhibition"]
    SubcortGluExc [label="Subcortical Glu\nExcitotoxicity"]
    CortDisinhibit [label="Cortical Dis-\ninhibition"]

    Thalamus      [label="Thalamus\n(Sensory gating)"]
    ThalamoCortic [label="Thalamocortical\nTransmission"]
    GRIN2A_var    [label="GRIN2A Variant\n(GWAS hit)"]
    GRIN2B_var    [label="GRIN2B Variant\n(GWAS hit)"]
  }

  // ============================================================
  // CLUSTER 4: SEROTONERGIC SYSTEM
  // ============================================================
  subgraph cluster_serotonin {
    label="④ Serotonergic System"
    style=filled color="#f0d060" fillcolor="#fefdf5"
    fontcolor="#7d6608" fontsize=11 fontname="Helvetica-Bold"
    node [fillcolor="#f9e79f" color="#b7950b"]

    DRN   [label="Dorsal Raphe\nNucleus (DRN)"]
    Trp   [label="Tryptophan\n(Dietary precursor)"]
    TPH2  [label="TPH2\n(Tryptophan Hydroxylase)"]
    FiveHT [label="5-HT (Serotonin)\n"]
    SERT  [label="SERT\n(5-HT Transporter)"]
    MAOA  [label="MAO-A\n(5-HT degradation)"]

    HT1AR [label="5-HT1A\n(Autoreceptor/PFC)"]
    HT2AR [label="5-HT2A Receptor\n(Cortical pyramidal cells)"]
    HT2CR [label="5-HT2C Receptor\n(Mesolimbic DA mod)"]
    HT3R  [label="5-HT3 Receptor\n(Ionotropic)"]
    HT6R  [label="5-HT6 Receptor\n(Striatum)"]
    HT7R  [label="5-HT7 Receptor\n(Thalamus)"]

    HT2AR_VTA [label="5-HT2A on VTA\n(DA release ↑)"]
    HT2AR_PFC [label="5-HT2A on PFC\n(Mesocortical DA ↑)"]
    HT2CR_NAc [label="5-HT2C on NAc\n(Mesolimbic DA ↓)"]
    HT2AR_SNc [label="5-HT2A on SNc\n(Nigrostr. DA mod)"]

    IDO1    [label="IDO1\n(Indoleamine Dioxygenase)"]
    KYNA    [label="Kynurenic Acid\n(Endogenous NMDA Antag)"]
    KP_path [label="Kynurenine Pathway\n(IL-1β induced)"]
    Melatonin [label="Melatonin\n(Pineal output)"]
  }

  // ============================================================
  // CLUSTER 5: GABAERGIC INTERNEURONS
  // ============================================================
  subgraph cluster_gaba {
    label="⑤ GABAergic Interneurons & Microcircuits"
    style=filled color="#f08080" fillcolor="#fff0f0"
    fontcolor="#7b241c" fontsize=11 fontname="Helvetica-Bold"
    node [fillcolor="#f1948a" color="#922b21"]

    GABA_NT [label="GABA\n(Main inhibitory NT)"]
    GAD67   [label="GAD67\n(GABA synthesis; ▼ 25-50% SCZ)"]
    GAD65   [label="GAD65\n(Synaptic terminal)"]

    PV_cells  [label="PV+ Interneurons\n(Fast-spiking; ▼ in SCZ)"]
    SST_cells [label="SST+ Interneurons\n(Dendrite-targeting)"]
    VIP_cells [label="VIP+ Interneurons\n(Disinhibitory circuit)"]
    CR_cells  [label="CR+ Interneurons\n(Calretinin)"]

    GABAaR     [label="GABA-A Receptor\n(Cl⁻ channel)"]
    GABAbR     [label="GABA-B Receptor\n(Gi-coupled)"]
    alpha1_GABA [label="α1 GABA-A\n(Thalamus / sedation)"]
    alpha2_GABA [label="α2 GABA-A\n(PFC / anxiolytic)"]

    GammaOsc   [label="Gamma Oscillation (~40Hz)\n(Enabled by PV cells)"]
    ThetaOsc   [label="Theta Rhythm\n(Hippocampus)"]
    WMcircuit  [label="Working Memory Circuit\n(PFC Layer III)"]
    HippocampAct [label="Hippocampal\nHyperactivity"]
    PatternComplete [label="Aberrant Pattern\nCompletion"]
    PVdeficit  [label="PV Interneuron\nDeficiency (SCZ core)"]
    NKCC1_KCC2 [label="NKCC1/KCC2\n(Cl⁻ cotransporters)"]
  }

  // ============================================================
  // CLUSTER 6: NEUROINFLAMMATION & OXIDATIVE STRESS
  // ============================================================
  subgraph cluster_neuroinflamm {
    label="⑥ Neuroinflammation & Oxidative Stress"
    style=filled color="#a0a0a0" fillcolor="#f2f2f2"
    fontcolor="#2c2c2c" fontsize=11 fontname="Helvetica-Bold"
    node [fillcolor="#d7dbdd" color="#626567"]

    Microglia [label="Microglia\n(Activated M1 state)"]
    Astrocyte [label="Astrocytes\n(Reactive A1)"]
    IL6   [label="IL-6\n(Elevated in SCZ)"]
    IL1b  [label="IL-1β\n(Pro-inflammatory)"]
    TNFa  [label="TNF-α\n(Pro-inflammatory)"]
    CRP   [label="CRP\n(Systemic marker ↑)"]
    NF_kB [label="NF-κB\n(Inflammatory pathway)"]
    C4A   [label="C4A Complement\n(Synaptic pruning)"]
    CompPruning [label="Complement-Mediated\nSynaptic Elimination"]
    BBB_integ   [label="BBB Integrity\n(Disrupted in SCZ)"]
    ROS         [label="ROS\n(Oxidative stress)"]
    GSH_def     [label="Glutathione Deficit\n(Antioxidant ▼)"]
    MitoFunc    [label="Mitochondrial\nDysfunction"]
    OxidStress  [label="Oxidative Stress\nIndex"]
    BDNF         [label="BDNF\n(▼ in SCZ)"]
    BDNFval66met [label="BDNF Val66Met\nPolymorphism"]
    GDNF         [label="GDNF\n(Neuroprotective factor)"]
    Neurogenesis [label="Hippocampal\nNeurogenesis (▼)"]
    S100B  [label="S100B\n(Astrocyte biomarker ↑)"]
    PLA2   [label="PLA2\n(Phospholipid metabolism)"]
  }

  // ============================================================
  // CLUSTER 7: ANTIPSYCHOTIC DRUG PK
  // ============================================================
  subgraph cluster_pk {
    label="⑦ Antipsychotic Drug Pharmacokinetics"
    style=filled color="#76d7c4" fillcolor="#e8f8f5"
    fontcolor="#0e6251" fontsize=11 fontname="Helvetica-Bold"
    node [fillcolor="#a2d9ce" color="#117a65"]

    HAL_dose [label="Haloperidol\nDose (mg/day)\n[FGA]"]
    HAL_gut  [label="HAL: GI Compartment\nka=0.8 h⁻¹, F=65%"]
    HAL_central [label="HAL: Central (Cp)\nVd=18 L/kg"]
    HAL_periph  [label="HAL: Peripheral\n(Tissue binding)"]
    HAL_brain   [label="HAL: Brain Conc\nKp,brain=10–15"]
    HAL_elim    [label="HAL Elimination\nCYP3A4/CYP2D6\nt½=18–24 h"]

    RIS_dose    [label="Risperidone\nDose (mg/day)\n[SGA]"]
    RIS_gut     [label="RIS: GI Compartment\nka=1.0 h⁻¹, F=74%"]
    RIS_central [label="RIS: Central (Cp)\nVd=1–2 L/kg"]
    RIS_periph  [label="RIS: Peripheral\n(Tissue binding)"]
    RIS_brain   [label="RIS: Brain Conc\nKp,brain=5–10"]
    PALI_central [label="Paliperidone\n(9-OH-RIS active metabolite)"]
    RIS_elim    [label="RIS Elimination\nCYP2D6 (major)\nt½=3h(RIS)/21h(PALI)"]

    CLZ_dose    [label="Clozapine\nDose (mg/day)\n[TRS SGA]"]
    CLZ_central [label="CLZ: Central (Cp)\nCYP1A2 substrate"]
    CLZ_brain   [label="CLZ: Brain Conc\nKp,brain=4–8"]
    CLZ_elim    [label="CLZ Elimination\nCYP1A2 (major)\nt½=12 h"]

    ARI_dose    [label="Aripiprazole\nDose (mg/day)\n[Partial D2 agonist]"]
    ARI_central [label="ARI: Central (Cp)\nF>99%, Vd=4.9 L/kg"]
    ARI_brain   [label="ARI: Brain Conc\nKp,brain=high"]
    DehydroARI  [label="Dehydro-ARI\n(Active; t½=94 h)"]
    ARI_elim    [label="ARI Elimination\nCYP2D6/CYP3A4\nt½=75 h (ARI)"]
  }

  // ============================================================
  // CLUSTER 8: PHARMACODYNAMICS — RECEPTOR OCCUPANCY
  // ============================================================
  subgraph cluster_pd {
    label="⑧ Pharmacodynamics: Receptor Occupancy & Signaling"
    style=filled color="#f0b27a" fillcolor="#fef5e7"
    fontcolor="#7e5109" fontsize=11 fontname="Helvetica-Bold"
    node [fillcolor="#f5cba7" color="#9c640c"]

    D2_occ       [label="D2 Receptor Occupancy (%)\n(PET measurement)"]
    D2_threshold [label="D2 Occupancy Threshold\n<65%: no AP effect\n>80%: EPS risk"]
    HT2A_occ     [label="5-HT2A Occ (%)\n(SGA: >90%)"]
    HT1A_occ     [label="5-HT1A Occ (%)\n(ARI partial agonist)"]

    cAMP    [label="↓ cAMP Pathway\n(D2→Gi→↓AC)"]
    PKA     [label="PKA→CREB\nTranscription"]
    DARPP32 [label="DARPP-32\n(Phosphoprotein regulator)"]
    DeltaFosB [label="ΔFosB\n(Chronic AP effect)"]
    AktGSK3   [label="Akt/GSK-3β\n(Mood stabilizer target)"]
    ERK12     [label="ERK1/2\n(Neuroprotective)"]

    PartialD2  [label="Partial D2 Agonism\n(Aripiprazole mechanism)"]
    DopStab    [label="Dopamine Stabilization\n(DA-dependent D2 mod)"]

    H1_block   [label="H1 Blockade\n(Sedation, weight ↑)"]
    M1_block   [label="M1 Blockade\n(Anticholinergic)"]
    Alpha1_block [label="α1 Blockade\n(Orthostasis)"]
    hERG_block [label="hERG K⁺ Blockade\n(QTc prolongation)"]
    D4_block   [label="D4 Blockade\n(Frontal lobe)"]
    HT2C_block [label="5-HT2C Blockade\n(Weight ↑, glucose ↑)"]

    AntipsychEff  [label="Antipsychotic Effect\n(D2-mediated)"]
    TreatResponse [label="Treatment Response\n(≥20% PANSS reduction)"]
    TreatResist   [label="Treatment-Resistant\nSCZ (TRS)"]
  }

  // ============================================================
  // CLUSTER 9: CLINICAL ENDPOINTS
  // ============================================================
  subgraph cluster_endpoints {
    label="⑨ Clinical Endpoints & Outcome Measures"
    style=filled color="#9b59b6" fillcolor="#f5eef8"
    fontcolor="#4a0080" fontsize=11 fontname="Helvetica-Bold"
    node [fillcolor="#d2b4de" color="#7d3c98"]

    PosSymp  [label="Positive Symptoms\n(Hallucinations, Delusions,\nDisorganized thought)"]
    NegSymp  [label="Negative Symptoms\n(Avolition, Alogia,\nAnhedonia, Asociality)"]
    CognSymp [label="Cognitive Symptoms\n(Working memory, Attention,\nProcessing speed)"]
    GenSymp  [label="General Psychopathology\n(Anxiety, Depression,\nMotor retardation)"]

    PANSS_pos   [label="PANSS Positive\nScore (7–49)"]
    PANSS_neg   [label="PANSS Negative\nScore (7–49)"]
    PANSS_gen   [label="PANSS General\n(16–112)"]
    PANSS_total [label="PANSS Total\n(30–210)"]
    CGI_S   [label="CGI-S\n(Severity)"]
    CGI_I   [label="CGI-I\n(Improvement)"]
    GAF     [label="GAF\n(Functional assessment)"]
    RBANS   [label="RBANS\n(Cognitive battery)"]
    AIMS    [label="AIMS\n(Involuntary movements)"]
    SAS_scale [label="SAS\n(EPS rating)"]
    QoL_SCZ   [label="Quality of Life\n(SQLS/QLS)"]
    Relapse   [label="Relapse Rate\n(Rehospitalization)"]
    FuncOutcome [label="Functional Outcome\n(Employment, Social)"]
    Remission   [label="Remission\n(PANSS ≤3 on 8 items)"]
    Recovery    [label="Recovery\n(Sustained remission)"]
  }

  // ============================================================
  // CLUSTER 10: ADVERSE EFFECTS
  // ============================================================
  subgraph cluster_adverse {
    label="⑩ Adverse Effects & Safety Monitoring"
    style=filled color="#e74c3c" fillcolor="#fdf0ef"
    fontcolor="#7b241c" fontsize=11 fontname="Helvetica-Bold"
    node [fillcolor="#f5b7b1" color="#cb4335"]

    EPS_symps    [label="EPS\n(Nigrostriatal D2 >80%)"]
    Akathisia    [label="Akathisia\n(Restlessness)"]
    TardDysk     [label="Tardive Dyskinesia\n(Long-term, ↑ DA receptor)"]
    NMS_risk     [label="Neuroleptic Malignant\nSyndrome (NMS)"]
    WeightGain   [label="Weight Gain\n(Olanzapine/Clozapine)"]
    MetabSynd    [label="Metabolic Syndrome\n(Waist/BP/Glucose/TG)"]
    T2DM_risk    [label="T2DM Risk\n(Insulin resistance)"]
    Dyslipid     [label="Dyslipidemia\n(TG↑, HDL↓)"]
    Hyperprolact [label="Hyperprolactinemia\n(RIS/HAL)"]
    SexDysfunc   [label="Sexual Dysfunction\n(Galactorrhea, Amenorrhea)"]
    QTc_prol     [label="QTc Prolongation\n(Ziprasidone, HAL)"]
    Sedation     [label="Sedation\n(H1 blockade)"]
    AnticholinEff [label="Anticholinergic Effects\n(Constipation, Dry mouth)"]
    Agranulocyt  [label="Agranulocytosis\n(Clozapine ~1%)"]
    SeizRisk     [label="Seizure Risk\n(Clozapine dose-dep)"]
    OrthoHypo    [label="Orthostatic\nHypotension"]
    CLZ_myocarditis [label="Myocarditis\n(Clozapine wks 1–8)"]
  }

  // ============================================================
  // EDGES: NEURODEVELOPMENTAL → PATHWAYS
  // ============================================================
  DISC1      -> CortexDevel    [label="disrupts cortical\narchitecture"]
  NRG1       -> PVdeficit      [label="ErbB4/PV axon\ndefects"]
  DTNBP1     -> DopamineDevel  [label="VMAT2 trafficking\ndeficit"]
  COMT_gene  -> PFC_DA         [label="Val: ↑ catabolism\n→ ↓ PFC DA"]
  CACNA1C    -> CortexDevel    [label="Ca²⁺ signaling\ndisruption"]
  DRD2_gene  -> D2R            [label="expression\nvariant"]
  GRM3_gene  -> mGluR2_3       [label="glutamate\nmodulation"]
  CNTNAP2    -> PVdeficit      [label="interneuron\narborization ↓"]
  C4A_gene   -> CompPruning    [label="↑ synaptic\npruning"]
  EnvStress  -> NeuronMigration [label="HPA axis\ndysregulation"]
  ChildTrauma -> DopamineDevel  [label="stress\nsensitization"]
  UrbanBirth  -> EnvStress      [label="social stress\nfactor"]
  Cannabis_exp -> MesolimbicDA  [label="THC → ↑ DA\nrelease"]
  Cannabis_exp -> NMDAR         [label="CB1 receptor\nmodulation"]
  CortexDevel    -> SynapticPruning [label="abnormal"]
  SynapticPruning -> PVdeficit      [label="GABAergic\nloss"]
  SynapticPruning -> NMDAhypo       [label="NMDAR\ndownregulation"]
  NeuronMigration -> CortexDevel    [label="→"]
  DopamineDevel   -> MesolimbicDA   [label="sensitization"]
  GlutamateDevel  -> NMDAhypo       [label="→"]

  // ============================================================
  // EDGES: DOPAMINERGIC SYNTHESIS & RELEASE
  // ============================================================
  Tyrosine -> TH    [label="substrate"]
  TH       -> LDOPA [label="hydroxylation"]
  LDOPA    -> DDC   [label="decarboxylation"]
  DDC      -> DA_synth [label="produces DA"]
  DA_synth -> VMAT2    [label="vesicle\npackaging"]
  VMAT2 -> VTA         [label="mesolimbic\nterm."]
  VMAT2 -> SNc         [label="nigrostr.\nterm."]
  VMAT2 -> ArcNucleus  [label="TI term."]
  VTA -> NAc           [label="mesolimbic\nprojection"]
  VTA -> DLPFC         [label="mesocortical\nprojection"]
  NAc  -> MesolimbicDA  [label="hyperactive"]
  DLPFC -> PFC_DA       [label="hypoactive"]
  SNc   -> DorsalStriatum [label="nigrostriatal\nprojection"]
  DorsalStriatum -> NigrostriatalDA [label="motor\ncontrol DA"]
  ArcNucleus -> PituitaryDA         [label="inhibitory\nprojection"]
  PituitaryDA -> PRLlevel           [label="inhibits\nPRL release"]
  MesolimbicDA -> AberrantSalience   [label="↑ DA drive"]
  AberrantSalience -> PosSymp        [label="psychosis"]
  PFC_DA -> NegSymp   [label="D1R hypo →\nneg Sx"]
  PFC_DA -> CognSymp  [label="↓ WM &\nattention"]
  D2auto -> DA_synth  [label="neg. feedback\n↓ synthesis"]
  DAT    -> DA_synth  [label="reuptake &\nrecycling"]
  MAOB   -> DOPAC     [label="oxidative\ndeamination"]
  DOPAC  -> HVA       [label="COMT\nconversion"]
  COMT_enz -> HVA     [label="O-methylation\n(PFC)"]
  DA_synth -> D1R     [label="activates"]
  DA_synth -> D2R     [label="activates"]
  DA_synth -> D3R     [label="activates"]
  DA_synth -> D2auto  [label="feedback\nloop"]
  D2R -> cAMP         [label="Gi → ↓ AC\n→ ↓ cAMP"]
  D1R -> cAMP         [label="Gs → ↑ AC\n→ ↑ cAMP"]

  // ============================================================
  // EDGES: GLUTAMATE / NMDA
  // ============================================================
  Glu    -> VGluT    [label="vesicular\npackaging"]
  VGluT  -> NMDAR    [label="synaptic\nrelease"]
  Glu    -> AMPAR    [label="fast excit."]
  Glu    -> mGluR1_5 [label="metabotropic\nGq"]
  Glu    -> mGluR2_3 [label="presynaptic\nautoreceptor"]
  NMDAR  -> Glycine_site [label="requires\nco-agonist"]
  NMDAR  -> Dserine      [label="requires\nco-agonist"]
  SRase  -> Dserine      [label="synthesizes"]
  Astrocyte -> SRase     [label="astrocyte\nexpresses"]
  EAAT1  -> Glu [label="astrocyte\nreuptake"]
  EAAT2  -> Glu [label="glial uptake\n(90%)"]
  NMDAhypo -> PV_disinhibit  [label="PV NMDAR\nhypofunction"]
  PV_disinhibit -> CortDisinhibit [label="↑ pyramidal\ncell firing"]
  CortDisinhibit -> SubcortGluExc  [label="↑ subcortical\nGlu release"]
  SubcortGluExc -> MesolimbicDA    [label="↑ mesolimbic\nDA"]
  NMDAhypo -> GlutamateDevel       [label="dev. link"]
  GRIN2A_var -> NMDAR [label="altered\nfunction"]
  GRIN2B_var -> NMDAR [label="altered\nfunction"]
