digraph DN_QSP {
  graph [
    label="Diabetic Nephropathy QSP Model\nQuantitative Systems Pharmacology — Mechanistic Map"
    labelloc=t fontsize=22 fontname="Helvetica Bold"
    bgcolor="#F8F9FA" pad=1.2 nodesep=0.5 ranksep=0.8
    splines=ortho rankdir=TB
  ]
  node [shape=box style="filled,rounded" fontname="Helvetica" fontsize=10 margin="0.15,0.08"]
  edge [fontname="Helvetica" fontsize=8 arrowsize=0.7]

  /* ================================================================
     CLUSTER 1: Hyperglycemia & Glucose Metabolism
  ================================================================ */
  subgraph cluster_glucose {
    label="Hyperglycemia & Glucose Metabolism"
    style=filled fillcolor="#FFF3CD" color="#F0A500" penwidth=2 fontsize=13

    Dietary_Glucose    [label="Dietary\nGlucose" fillcolor="#FFE082"]
    Blood_Glucose      [label="Blood\nGlucose (BG)" fillcolor="#FFD54F" penwidth=2]
    HbA1c              [label="HbA1c\n(Glycemic Index)" fillcolor="#FFB300"]
    Insulin_Secretion  [label="Insulin\nSecretion (β-cell)" fillcolor="#FFCC80"]
    Insulin_Resistance [label="Insulin\nResistance" fillcolor="#FF8F00"]
    Glucotoxicity      [label="Glucotoxicity\n(Chronic Hypergly.)" fillcolor="#FF6F00"]
    Sorbitol_Pathway   [label="Polyol / Sorbitol\nPathway (AR/SDH)" fillcolor="#FFA000"]
    Hexosamine_Path    [label="Hexosamine\nBiosynthetic\nPathway" fillcolor="#E65100"]
    PKC_Activation     [label="Protein Kinase C\n(PKC-β, PKC-δ)" fillcolor="#BF360C" fontcolor=white]
    mTOR_S6K           [label="mTOR / S6K1\n(nutrient sensor)" fillcolor="#FF7043"]
    AMPK               [label="AMPK\n(energy sensor)" fillcolor="#FF8A65"]
    FFA_Lipotoxicity   [label="Free Fatty Acids /\nLipotoxicity" fillcolor="#FFAB40"]
    RAAS_Glucose       [label="AngII→Insulin\nResistance (link)" fillcolor="#FFC107" style="dashed,rounded"]
  }

  /* ================================================================
     CLUSTER 2: Advanced Glycation End-products (AGE) / RAGE
  ================================================================ */
  subgraph cluster_age {
    label="AGE / RAGE Axis & Oxidative Stress"
    style=filled fillcolor="#FCE4EC" color="#C62828" penwidth=2 fontsize=13

    AGE_Formation      [label="AGE Formation\n(Maillard Rxn)" fillcolor="#F48FB1"]
    RAGE               [label="RAGE\n(Receptor for AGE)" fillcolor="#E91E63" fontcolor=white penwidth=2]
    CML                [label="Nε-CML\n(Carboxymethyllysine)" fillcolor="#F06292"]
    MG                 [label="Methylglyoxal\n(MG)" fillcolor="#EC407A"]
    ROS_Mitochon       [label="Mitochondrial ROS\n(ETC uncoupling)" fillcolor="#C2185B" fontcolor=white]
    NADPH_Oxidase      [label="NADPH Oxidase\n(Nox4 dominant)" fillcolor="#B71C1C" fontcolor=white]
    Nox4               [label="Nox4\n(TGF-β induced)" fillcolor="#D32F2F" fontcolor=white]
    Superoxide         [label="Superoxide (O₂⁻)\n→ H₂O₂" fillcolor="#EF5350"]
    Peroxynitrite      [label="ONOO⁻\n(Peroxynitrite)" fillcolor="#E53935" fontcolor=white]
    Nrf2               [label="Nrf2\n(Antioxidant TF)" fillcolor="#880E4F" fontcolor=white]
    HO1                [label="HO-1 / NQO1\n(Nrf2 targets)" fillcolor="#AD1457" fontcolor=white]
    SOD_CAT            [label="SOD / Catalase\n(Antioxidant enzymes)" fillcolor="#C2185B" fontcolor=white]
    Lipid_Peroxidation [label="Lipid Peroxidation\n(MDA, 4-HNE)" fillcolor="#F44336"]
  }

  /* ================================================================
     CLUSTER 3: Renal Hemodynamics & RAAS
  ================================================================ */
  subgraph cluster_raas {
    label="Renal Hemodynamics & RAAS"
    style=filled fillcolor="#E3F2FD" color="#1565C0" penwidth=2 fontsize=13

    Angiotensinogen    [label="Angiotensinogen\n(liver)" fillcolor="#BBDEFB"]
    Renin              [label="Renin\n(juxtaglomerular)" fillcolor="#90CAF9"]
    ACE                [label="ACE\n(lung/kidney)" fillcolor="#64B5F6"]
    AngI               [label="Ang I" fillcolor="#42A5F5"]
    AngII              [label="Ang II\n(vasoactive)" fillcolor="#1E88E5" fontcolor=white penwidth=2]
    AT1R               [label="AT1R\n(GPCR)" fillcolor="#1565C0" fontcolor=white]
    AT2R               [label="AT2R\n(counter-regul.)" fillcolor="#0D47A1" fontcolor=white]
    Aldosterone        [label="Aldosterone\n(adrenal cortex)" fillcolor="#1976D2" fontcolor=white]
    MR                 [label="Mineralocorticoid\nReceptor (MR)" fillcolor="#1565C0" fontcolor=white]
    ACE2               [label="ACE2\n(Ang 1-7 axis)" fillcolor="#2196F3"]
    Ang17              [label="Ang (1-7)\n(MasR)" fillcolor="#42A5F5"]
    Afferent_Art       [label="Afferent\nArteriole\n(vasodilation)" fillcolor="#81D4FA"]
    Efferent_Art       [label="Efferent\nArteriole\n(vasoconstriction)" fillcolor="#4FC3F7"]
    Hyperfiltration    [label="Glomerular\nHyperfiltration\n(early DN)" fillcolor="#039BE5" fontcolor=white]
    Intraglom_Press    [label="Intraglomerular\nPressure (PGLO)" fillcolor="#0277BD" fontcolor=white penwidth=2]
    TGF_Renal          [label="Tubuloglomerular\nFeedback (TGF)" fillcolor="#01579B" fontcolor=white]
    Macula_Densa       [label="Macula Densa\n(NaCl sensing)" fillcolor="#0288D1" fontcolor=white]
    ENaC               [label="ENaC\n(Na+ retention)" fillcolor="#29B6F6"]
    Aldosterone_Kidney [label="Aldosterone→\nFibrosis (MR)" fillcolor="#039BE5" fontcolor=white]
  }

  /* ================================================================
     CLUSTER 4: TGF-β / Fibrosis Pathway
  ================================================================ */
  subgraph cluster_tgfb {
    label="TGF-β Signaling & Glomerulosclerosis"
    style=filled fillcolor="#E8F5E9" color="#2E7D32" penwidth=2 fontsize=13

    TGFbeta1           [label="TGF-β1\n(master fibrosis)" fillcolor="#A5D6A7" penwidth=2]
    TGFbeta_R1         [label="TβRI (ALK5)\nType I receptor" fillcolor="#81C784"]
    TGFbeta_R2         [label="TβRII\nType II receptor" fillcolor="#66BB6A"]
    Smad2_3            [label="pSmad2/3\n(R-Smad)" fillcolor="#43A047" fontcolor=white]
    Smad4              [label="Smad4\n(co-Smad)" fillcolor="#388E3C" fontcolor=white]
    Smad7              [label="Smad7\n(inhibitory)" fillcolor="#2E7D32" fontcolor=white]
    CTGF               [label="CTGF / CCN2\n(pro-fibrotic)" fillcolor="#558B2F" fontcolor=white]
    Fibronectin        [label="Fibronectin\n(ECM)" fillcolor="#689F38" fontcolor=white]
    Collagen_IV        [label="Collagen IV\n(GBM thickening)" fillcolor="#33691E" fontcolor=white]
    Collagen_I_III     [label="Collagen I/III\n(interstitial)" fillcolor="#1B5E20" fontcolor=white]
    Laminin            [label="Laminin β2\n(slit diaphragm)" fillcolor="#76A946"]
    MMP_1_9            [label="MMP-1/9\n(ECM degradation)" fillcolor="#9CCC65"]
    TIMP1              [label="TIMP-1\n(MMP inhibitor)" fillcolor="#8BC34A"]
    ECM_Accumulation   [label="ECM Accumulation\n→ Glomerulosclerosis" fillcolor="#C8E6C9" penwidth=2]
    NonSmad_TGF        [label="Non-Smad TGF-β\n(MAPK, PI3K)" fillcolor="#AED581"]
    Wnt_Beta_Cat       [label="Wnt/β-Catenin\n(fibrosis amplifier)" fillcolor="#DCEDC8"]
    Notch_Path         [label="Notch Signaling\n(EMT driver)" fillcolor="#F1F8E9"]
  }

  /* ================================================================
     CLUSTER 5: Inflammatory Cascade
  ================================================================ */
  subgraph cluster_inflam {
    label="Renal Inflammation"
    style=filled fillcolor="#FFF8E1" color="#F57F17" penwidth=2 fontsize=13

    NFkB               [label="NF-κB\n(master inflam. TF)" fillcolor="#FFE082" penwidth=2]
    TNFalpha           [label="TNF-α\n(pro-inflammatory)" fillcolor="#FFD54F"]
    IL1beta            [label="IL-1β\n(NLRP3 output)" fillcolor="#FFCA28"]
    IL6                [label="IL-6\n(pleiotropic)" fillcolor="#FFB300"]
    IL18               [label="IL-18\n(NLRP3 output)" fillcolor="#FFA000"]
    MCP1               [label="MCP-1 / CCL2\n(monocyte recruit)" fillcolor="#FF8F00"]
    ICAM1              [label="ICAM-1\n(adhesion)" fillcolor="#FF6F00"]
    VCAM1              [label="VCAM-1\n(adhesion)" fillcolor="#E65100"]
    NLRP3              [label="NLRP3\nInflammasome" fillcolor="#FFC107"]
    Caspase1           [label="Caspase-1\n(pyroptosis)" fillcolor="#FFB300"]
    Macrophage_M1      [label="M1 Macrophage\n(pro-inflam.)" fillcolor="#FF7043"]
    Macrophage_M2      [label="M2 Macrophage\n(anti-inflam.)" fillcolor="#FF8A65"]
    Complement_C3      [label="Complement\nC3a / C5a" fillcolor="#FFAB40"]
    Galectin3          [label="Galectin-3\n(fibrosis marker)" fillcolor="#FFC870"]
    JAK_STAT3          [label="JAK/STAT3\n(IL-6 signaling)" fillcolor="#FFD0A0"]
    VEGF_Infl          [label="VEGF-A\n(permeability↑)" fillcolor="#FFE0B2"]
  }

  /* ================================================================
     CLUSTER 6: Podocyte Pathobiology
  ================================================================ */
  subgraph cluster_podocyte {
    label="Podocyte Pathobiology & Glomerular Barrier"
    style=filled fillcolor="#EDE7F6" color="#4527A0" penwidth=2 fontsize=13

    Nephrin            [label="Nephrin\n(NPHS1)" fillcolor="#CE93D8" penwidth=2]
    Podocin            [label="Podocin\n(NPHS2)" fillcolor="#BA68C8"]
    WT1                [label="WT1\n(transcription factor)" fillcolor="#AB47BC"]
    Synaptopodin       [label="Synaptopodin\n(actin stress fiber)" fillcolor="#9C27B0" fontcolor=white]
    Alpha_Actinin4     [label="α-Actinin-4\n(ACTN4)" fillcolor="#8E24AA" fontcolor=white]
    Slit_Diaphragm     [label="Slit Diaphragm\n(filtration barrier)" fillcolor="#7B1FA2" fontcolor=white penwidth=2]
    Foot_Process       [label="Foot Process\nEffacement" fillcolor="#6A1B9A" fontcolor=white]
    Podocyte_Detach    [label="Podocyte\nDetachment" fillcolor="#4A148C" fontcolor=white]
    Podocyte_Apop      [label="Podocyte\nApoptosis" fillcolor="#38006B" fontcolor=white]
    VEGF_Podocyte      [label="VEGF-A\n(podocyte-GEC cross)" fillcolor="#CE93D8"]
    Angiopoietin1      [label="Angiopoietin-1\n(Tie2 stabilizer)" fillcolor="#E1BEE7"]
    Angiopoietin2      [label="Angiopoietin-2\n(Tie2 destabilizer)" fillcolor="#D1C4E9"]
    GEC_Dysfunction    [label="Glomerular Endothelial\nCell Dysfunction" fillcolor="#B39DDB"]
    GBM_Thickness      [label="GBM Thickening\n(collagen IV↑)" fillcolor="#9575CD" fontcolor=white]
    Proteinuria        [label="Proteinuria\n/ Albuminuria" fillcolor="#7E57C2" fontcolor=white penwidth=2]
    Mesangial_Exp      [label="Mesangial\nExpansion" fillcolor="#673AB7" fontcolor=white]
    Mesangial_TGFb     [label="Mesangial Cell\nTGF-β secretion" fillcolor="#5E35B1" fontcolor=white]
  }

  /* ================================================================
     CLUSTER 7: Tubular Compartment & CKD Progression
  ================================================================ */
  subgraph cluster_tubular {
    label="Tubular Compartment & CKD Progression"
    style=filled fillcolor="#E0F2F1" color="#00695C" penwidth=2 fontsize=13

    Proximal_Tubule    [label="Proximal Tubule\nCells (PTC)" fillcolor="#B2DFDB" penwidth=2]
    SGLT2_Expr         [label="SGLT2\n(SLC5A2)" fillcolor="#80CBC4"]
    Glucose_Reabsorp   [label="Glucose\nReabsorption\n(~180g/day)" fillcolor="#4DB6AC"]
    SGLT1_Expr         [label="SGLT1\n(SLC5A1)" fillcolor="#26A69A"]
    Tubular_Hypertro   [label="Tubular\nHypertrophy\n(early DN)" fillcolor="#00897B" fontcolor=white]
    HIF1alpha          [label="HIF-1α\n(hypoxia TF)" fillcolor="#00796B" fontcolor=white]
    Tubular_Hypoxia    [label="Tubular Hypoxia\n(O₂ demand↑)" fillcolor="#00695C" fontcolor=white]
    EPO_Kidney         [label="EPO\n(erythropoietin)" fillcolor="#004D40" fontcolor=white]
    EMT_Tubular        [label="Tubular EMT\n(E-cad→Vimentin)" fillcolor="#1B5E20" fontcolor=white style="filled,rounded,dashed"]
    Tubular_Atrophy    [label="Tubular\nAtrophy" fillcolor="#37474F" fontcolor=white]
    Interstitial_Fib   [label="Interstitial\nFibrosis" fillcolor="#263238" fontcolor=white penwidth=2]
    Klotho             [label="α-Klotho\n(anti-aging, AKI protect)" fillcolor="#00ACC1" fontcolor=white]
    FGF23              [label="FGF-23\n(phosphate regul.)" fillcolor="#0097A7" fontcolor=white]
    PTH_CKD            [label="PTH↑\n(secondary HPT)" fillcolor="#00838F" fontcolor=white]
    Uremia_Toxins      [label="Uremia Toxins\n(IS, pCS)" fillcolor="#006064" fontcolor=white]
    KIM1               [label="KIM-1\n(tubular injury mkr)" fillcolor="#006064" fontcolor=white]
    NGAL_Marker        [label="NGAL\n(tubular mkr)" fillcolor="#004D40" fontcolor=white]
  }

  /* ================================================================
     CLUSTER 8: Drug PK/PD
  ================================================================ */
  subgraph cluster_drugs {
    label="Drug PK / PD Mechanisms"
    style=filled fillcolor="#F3E5F5" color="#6A1B9A" penwidth=2 fontsize=13

    /* ACE Inhibitor */
    ACEi_Dose          [label="ACE Inhibitor\nDose (e.g. Enalapril)" fillcolor="#CE93D8" shape=oval]
    ACEi_GI            [label="ACEi GI\nAbsorption" fillcolor="#BA68C8"]
    ACEi_Plasma        [label="ACEi Plasma\nConcentration" fillcolor="#AB47BC"]
    ACEi_Effect        [label="ACEi→ACE\nInhibition (↓AngII)" fillcolor="#9C27B0" fontcolor=white]

    /* ARB */
    ARB_Dose           [label="ARB Dose\n(e.g. Losartan)" fillcolor="#80DEEA" shape=oval]
    ARB_GI             [label="ARB GI\nAbsorption" fillcolor="#4DD0E1"]
    ARB_Plasma         [label="ARB Plasma\nConcentration" fillcolor="#26C6DA"]
    ARB_Effect         [label="ARB→AT1R\nBlockade" fillcolor="#00BCD4" fontcolor=white]

    /* SGLT2 Inhibitor */
    SGLT2i_Dose        [label="SGLT2i Dose\n(e.g. Empagliflozin)" fillcolor="#A5D6A7" shape=oval]
    SGLT2i_GI          [label="SGLT2i GI\nAbsorption" fillcolor="#81C784"]
    SGLT2i_Plasma      [label="SGLT2i Plasma\nConcentration" fillcolor="#66BB6A"]
    SGLT2i_Effect      [label="SGLT2i→SGLT2\nBlockade (glucosuria)" fillcolor="#43A047" fontcolor=white]
    SGLT2i_Tubular     [label="SGLT2i→Tubular\nHypoxia Relief" fillcolor="#388E3C" fontcolor=white]
    SGLT2i_TGF        [label="SGLT2i→TGF-β↓\n(renoprotection)" fillcolor="#2E7D32" fontcolor=white]

    /* Finerenone (MRA) */
    Fine_Dose          [label="Finerenone\n(non-steroidal MRA)" fillcolor="#FFE0B2" shape=oval]
    Fine_GI            [label="Finerenone GI\nAbsorption" fillcolor="#FFCC80"]
    Fine_Plasma        [label="Finerenone Plasma\nConcentration" fillcolor="#FFB74D"]
    Fine_Effect        [label="Finerenone→MR\nBlockade (↓fibrosis)" fillcolor="#FFA726" fontcolor=white]

    /* GLP-1 RA */
    GLP1_Dose          [label="GLP-1 RA Dose\n(e.g. Semaglutide)" fillcolor="#F8BBD9" shape=oval]
    GLP1_SC            [label="GLP-1 RA\nSC Absorption" fillcolor="#F48FB1"]
    GLP1_Plasma        [label="GLP-1 RA Plasma\nConc." fillcolor="#F06292"]
    GLP1_Effect_Glc    [label="GLP-1 RA→\nGlucose Lowering" fillcolor="#E91E63" fontcolor=white]
    GLP1_Effect_Renal  [label="GLP-1 RA→\nRenal protection\n(GLP1R renal)" fillcolor="#C2185B" fontcolor=white]
  }

  /* ================================================================
     CLUSTER 9: Clinical Endpoints & Biomarkers
  ================================================================ */
  subgraph cluster_endpoints {
    label="Clinical Endpoints & Biomarkers"
    style=filled fillcolor="#EFEBE9" color="#3E2723" penwidth=2 fontsize=13

    eGFR               [label="eGFR\n(mL/min/1.73m²)" fillcolor="#BCAAA4" penwidth=3]
    UACR               [label="UACR\n(mg/g)" fillcolor="#A1887F" fontcolor=white penwidth=3]
    Serum_Creatinine   [label="Serum Creatinine\n(µmol/L)" fillcolor="#8D6E63" fontcolor=white]
    Serum_Cystatin     [label="Cystatin C\n(GFR marker)" fillcolor="#795548" fontcolor=white]
    Blood_Pressure     [label="Blood Pressure\n(SBP/DBP)" fillcolor="#6D4C41" fontcolor=white]
    Sodium_Balance     [label="Sodium Balance\n(volume)" fillcolor="#5D4037" fontcolor=white]
    CKD_Stage          [label="CKD Stage\n(G1-G5)" fillcolor="#4E342E" fontcolor=white penwidth=2]
    ESKD               [label="ESKD\n(dialysis/transplant)" fillcolor="#3E2723" fontcolor=white penwidth=3]
    CV_Risk            [label="Cardiovascular\nRisk (MACE)" fillcolor="#BF360C" fontcolor=white]
    Anemia_CKD         [label="Anemia\n(EPO deficiency)" fillcolor="#E64A19" fontcolor=white]
    Hyperkalemia       [label="Hyperkalemia\n(K+↑ risk)" fillcolor="#D84315" fontcolor=white]
    Acidosis           [label="Metabolic\nAcidosis" fillcolor="#FF5722" fontcolor=white]
    Phosphate_Disorder [label="Phosphate\nDisorder" fillcolor="#FF7043"]
    Edema              [label="Edema\n(fluid retention)" fillcolor="#FF8A65"]
    GFR_Decline_Rate   [label="GFR Decline\nRate (ml/yr)" fillcolor="#FFAB91" penwidth=2]
  }

  /* ================================================================
     EDGES — Cluster 1: Glucose Metabolism
  ================================================================ */
  Dietary_Glucose -> Blood_Glucose [label="absorption" color="#F0A500"]
  Blood_Glucose -> HbA1c [label="glycation" color="#F0A500"]
  Blood_Glucose -> Glucotoxicity [label="chronic exposure" color="#E65100"]
  Blood_Glucose -> Sorbitol_Pathway [label="aldose reductase" color="#E65100"]
  Blood_Glucose -> Hexosamine_Path [label="GFAT" color="#E65100"]
  Blood_Glucose -> PKC_Activation [label="DAG↑" color="#E65100"]
  Blood_Glucose -> ROS_Mitochon [label="ETC overload" color="#C62828"]
  Blood_Glucose -> AGE_Formation [label="non-enzymatic" color="#C62828"]
  Insulin_Secretion -> Blood_Glucose [label="uptake→glucose↓" color="#2E7D32" arrowhead=tee]
  Insulin_Resistance -> Blood_Glucose [label="glucose intolerance" color="#F0A500"]
  Glucotoxicity -> Insulin_Resistance [label="amplifies" color="#E65100"]
  mTOR_S6K -> Insulin_Resistance [label="IRS-1 Ser307" color="#E65100"]
  AMPK -> mTOR_S6K [label="inhibits" color="#2E7D32" arrowhead=tee]
  FFA_Lipotoxicity -> Insulin_Resistance [label="ceramide/DAG" color="#E65100"]
  RAAS_Glucose -> Insulin_Resistance [label="AngII-IRS-1 pSer" color="#E65100"]

  /* ================================================================
     EDGES — Cluster 2: AGE/RAGE/ROS
  ================================================================ */
  AGE_Formation -> CML [label="Amadori→CML" color="#C62828"]
  AGE_Formation -> MG [label="glycolysis" color="#C62828"]
  CML -> RAGE [label="binds" color="#C62828"]
  MG -> RAGE [label="binds" color="#C62828"]
  RAGE -> NFkB [label="NF-κB activation" color="#C62828"]
  RAGE -> ROS_Mitochon [label="mitochondria↓" color="#C62828"]
  RAGE -> TGFbeta1 [label="fibrosis trigger" color="#C62828"]
  ROS_Mitochon -> NADPH_Oxidase [label="superoxide burst" color="#C62828"]
  NADPH_Oxidase -> Nox4 [label="Nox4 induction" color="#C62828"]
  Nox4 -> Superoxide [label="O₂⁻ generation" color="#C62828"]
  Superoxide -> Peroxynitrite [label="+ NO → ONOO⁻" color="#C62828"]
  Peroxynitrite -> Lipid_Peroxidation [label="oxidative damage" color="#C62828"]
  Peroxynitrite -> GEC_Dysfunction [label="eNOS uncoupling" color="#C62828"]
  Nrf2 -> HO1 [label="transcribes" color="#388E3C"]
  Nrf2 -> SOD_CAT [label="transcribes" color="#388E3C"]
  HO1 -> Superoxide [label="quenches" color="#388E3C" arrowhead=tee]
  SOD_CAT -> Superoxide [label="dismutase" color="#388E3C" arrowhead=tee]
  PKC_Activation -> NADPH_Oxidase [label="activates" color="#C62828"]
  Hexosamine_Path -> Nox4 [label="O-GlcNAc mod" color="#C62828"]

  /* ================================================================
     EDGES — Cluster 3: RAAS / Hemodynamics
  ================================================================ */
  Angiotensinogen -> AngI [label="renin (rate-limit)" color="#1565C0"]
  Renin -> AngI [label="cleaves" color="#1565C0"]
  AngI -> AngII [label="ACE" color="#1565C0"]
  AngII -> AT1R [label="binds" color="#1565C0"]
  AngII -> AT2R [label="binds" color="#1565C0"]
  AngII -> ACE2 [label="ACE2 substrate" color="#1565C0"]
  ACE2 -> Ang17 [label="cleaves Ang II" color="#2196F3"]
  AT1R -> Aldosterone [label="adrenal stim." color="#1565C0"]
  AT1R -> Efferent_Art [label="vasoconstriction" color="#1565C0"]
  AT1R -> TGFbeta1 [label="fibrosis" color="#1565C0"]
  AT1R -> NFkB [label="inflammation" color="#1565C0"]
  AT1R -> ROS_Mitochon [label="ROS" color="#1565C0"]
  AT2R -> Efferent_Art [label="vasodilation" color="#2196F3" arrowhead=tee]
  Aldosterone -> MR [label="binds" color="#1565C0"]
  MR -> ENaC [label="transcribes" color="#1565C0"]
  MR -> TGFbeta1 [label="fibrosis" color="#1565C0"]
  MR -> NFkB [label="inflammation" color="#1565C0"]
  ENaC -> Sodium_Balance [label="Na+ retention" color="#1565C0"]
  Efferent_Art -> Intraglom_Press [label="↑PGLO" color="#1565C0"]
  Afferent_Art -> Intraglom_Press [label="↑PGLO (early)" color="#1565C0"]
  Intraglom_Press -> Hyperfiltration [label="early DN" color="#0277BD"]
  Hyperfiltration -> Proteinuria [label="mechanical stress" color="#0277BD"]
  Hyperfiltration -> Mesangial_Exp [label="stretch" color="#0277BD"]
  Macula_Densa -> Renin [label="TGF → renin↓" color="#0288D1" arrowhead=tee]
  SGLT2_Expr -> Macula_Densa [label="NaCl load" color="#0288D1"]
  TGF_Renal -> Afferent_Art [label="autoregulation" color="#0288D1" arrowhead=tee]
  Aldosterone_Kidney -> Interstitial_Fib [label="MR-mediated" color="#1565C0"]

  /* ================================================================
     EDGES — Cluster 4: TGF-β / Fibrosis
  ================================================================ */
  TGFbeta1 -> TGFbeta_R1 [label="binds" color="#2E7D32"]
  TGFbeta1 -> TGFbeta_R2 [label="binds" color="#2E7D32"]
  TGFbeta_R1 -> Smad2_3 [label="phosphorylates" color="#2E7D32"]
  TGFbeta_R2 -> TGFbeta_R1 [label="trans-phosph." color="#2E7D32"]
  Smad2_3 -> Smad4 [label="complex" color="#2E7D32"]
  Smad4 -> CTGF [label="transcribes" color="#2E7D32"]
  Smad4 -> Collagen_IV [label="transcribes" color="#2E7D32"]
  Smad4 -> Collagen_I_III [label="transcribes" color="#2E7D32"]
  Smad4 -> Fibronectin [label="transcribes" color="#2E7D32"]
  Smad7 -> TGFbeta_R1 [label="inhibits" color="#2E7D32" arrowhead=tee]
  CTGF -> ECM_Accumulation [label="ECM stim." color="#2E7D32"]
  Collagen_IV -> GBM_Thickness [label="GBM expansion" color="#2E7D32"]
  Collagen_I_III -> Interstitial_Fib [label="fibrosis" color="#2E7D32"]
  Fibronectin -> ECM_Accumulation [label="ECM" color="#2E7D32"]
