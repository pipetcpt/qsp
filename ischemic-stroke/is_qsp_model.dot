digraph IS_QSP {
  graph [layout=fdp, fontname="Helvetica", fontsize=10,
         label="Ischemic Stroke — QSP Mechanistic Map\n(허혈성 뇌졸중 정량적 시스템 약리학 지도)",
         labelloc="t", labeljust="c",
         bgcolor="#fafafa", margin=0.6, splines=true,
         compound=true, overlap=false, sep="+8"];
  node [fontname="Helvetica", fontsize=9, style="filled,rounded", shape=box, margin="0.12,0.06"];
  edge [fontname="Helvetica", fontsize=8, arrowsize=0.7];

  /* ===================================================================
     SUBGRAPH 1 — Risk Factors & Comorbidities
  =================================================================== */
  subgraph cluster_risk {
    label="Risk Factors & Comorbidities\n(위험인자 및 동반질환)";
    style=filled; color="#cce5ff"; fontcolor="#0d3b6e"; fontsize=10;
    node [fillcolor="#ddeeff"];
    HTN        [label="Hypertension\n(고혈압)"];
    DM2        [label="Type 2 Diabetes\n(제2형 당뇨)"];
    AFIB       [label="Atrial Fibrillation\n(심방세동)"];
    HLD        [label="Dyslipidemia\n(이상지질혈증)"];
    SMOK       [label="Smoking\n(흡연)"];
    OBESE      [label="Obesity\n(비만)"];
    AGE        [label="Age > 65\n(고령)"];
    PREV_TIA   [label="Prior TIA/Stroke\n(선행 TIA)"];
    COAG_DIS   [label="Coagulopathy\n(응고장애)"];
    CARD_EMB   [label="Cardiac Embolism\n(심인성 색전)"];
    CAD        [label="Coronary Artery\nDisease (CAD)"];
    CKD_RISK   [label="Chronic Kidney\nDisease (CKD)"];
  }

  /* ===================================================================
     SUBGRAPH 2 — Vascular Pathology & Thrombosis
  =================================================================== */
  subgraph cluster_vascular {
    label="Vascular Pathology & Thrombosis\n(혈관 병변 및 혈전 형성)";
    style=filled; color="#fde8c8"; fontcolor="#6e3000"; fontsize=10;
    node [fillcolor="#fef5e7"];
    ATHEROSCL      [label="Atherosclerosis\n(죽상동맥경화)"];
    ENDO_DYSFX     [label="Endothelial\nDysfunction"];
    PLAQUE_RUPTURE [label="Plaque Rupture\n(플라크 파열)"];
    TF_EXP         [label="Tissue Factor\nExposure (TF)"];
    PLATELET_ACTIV [label="Platelet Activation\n(혈소판 활성화)"];
    PLATELET_AGG   [label="Platelet Aggregation\n(혈소판 응집)"];
    TXA2           [label="TXA₂\n(Thromboxane A2)"];
    ADP_PATH       [label="ADP / P2Y12\nPathway"];
    COAG_CASCADE   [label="Coagulation\nCascade"];
    FACTOR_Xa      [label="Factor Xa\n(FXa)"];
    THROMBIN       [label="Thrombin (FIIa)"];
    FIBRIN         [label="Fibrin Clot"];
    THROMBUS       [label="Thrombus\n(혈전)"];
    EMBOLUS        [label="Cerebral\nEmbolus"];
    STENOSIS       [label="Arterial\nStenosis / Occlusion"];
    CBF_REDUCE     [label="↓ Cerebral\nBlood Flow (CBF)"];
  }

  /* ===================================================================
     SUBGRAPH 3 — Acute Drug PK/PD (tPA & EVT)
  =================================================================== */
  subgraph cluster_acute_rx {
    label="Acute Treatment — PK/PD\n(급성기 치료 약동/약력학)";
    style=filled; color="#d5f5e3"; fontcolor="#145a32"; fontsize=10;
    node [fillcolor="#eafaf1"];
    TPA_DOSE   [label="IV tPA (Alteplase)\n0.9 mg/kg\n(NINDS/ECASS protocol)",
                shape=diamond, fillcolor="#a9dfbf"];
    TPA_CENT   [label="tPA\nCentral Compartment (V1)"];
    TPA_PERI   [label="tPA\nPeripheral Compartment (V2)"];
    TPA_CONC   [label="tPA Plasma Conc\n(Cp, ng/mL)"];
    TPA_FIBRIN [label="tPA–Fibrin\nBinding & Activation"];
    PLASMINOGEN[label="Plasminogen\n(Plasma)"];
    PLASMIN    [label="Plasmin\n(Active)"];
    PAI1       [label="PAI-1\n(Plasminogen Activator Inhibitor-1)"];
    FIBRINOLYSIS[label="Fibrinolysis\n(혈전 용해)"];
    ALPHA2AP   [label="α₂-Antiplasmin\n(Plasmin Inhibitor)"];
    EVT        [label="Endovascular\nThrombectomy (EVT)\n(기계적 혈전 제거)",
                shape=diamond, fillcolor="#a9dfbf"];
    RECANAL    [label="Recanalization\n(혈관 재개통)"];
    REPERFUSION[label="Reperfusion\n(혈류 재관류)"];
  }

  /* ===================================================================
     SUBGRAPH 4 — Ischemic Core & Penumbra
  =================================================================== */
  subgraph cluster_ischemia {
    label="Ischemic Core & Penumbra\n(허혈 핵심부 및 주변부)";
    style=filled; color="#fff3cd"; fontcolor="#6e4c00"; fontsize=10;
    node [fillcolor="#fffaed"];
    CBF_NORM   [label="Normal CBF\n(~55 mL/100g/min)"];
    CBF_CORE   [label="Core CBF\n(<10 mL/100g/min)"];
    CBF_PEN    [label="Penumbra CBF\n(10–20 mL/100g/min)"];
    ATP_CORE   [label="ATP Depletion\n(Core)"];
    ATP_PEN    [label="ATP Reduction\n(Penumbra)"];
    ION_PUMP   [label="Na⁺/K⁺-ATPase\nFailure"];
    DEPOL      [label="Terminal\nDepolarization (Core)"];
    PERI_DEPOL [label="Peri-infarct\nDepolarizations (PIDs)"];
    LACTATE    [label="Lactate / Acidosis\n(pH < 6.8)"];
    INFARCT_VOL[label="Infarct Core\nVolume (mL)"];
    PENUMBRA_V [label="Penumbra Volume\n(Salvageable tissue, mL)"];
    DWI_PWI    [label="DWI/PWI Mismatch\n(Imaging Target)"];
    COLLATERAL [label="Collateral\nCirculation"];
  }

  /* ===================================================================
     SUBGRAPH 5 — Excitotoxicity & Ion Dysregulation
  =================================================================== */
  subgraph cluster_excitotox {
    label="Excitotoxicity & Ion Dysregulation\n(흥분독성 및 이온 항상성 파괴)";
    style=filled; color="#fde8d8"; fontcolor="#6e2f1a"; fontsize=10;
    node [fillcolor="#fef3ec"];
    GLUT_REL   [label="Glutamate Release\n(Pre-synaptic)"];
    GLUT_CONC  [label="Extracellular\nGlutamate ↑ (>100×)"];
    NMDA_ACT   [label="NMDA Receptor\nActivation"];
    AMPA_ACT   [label="AMPA Receptor\nActivation"];
    KAIN_R     [label="Kainate Receptor\nActivation"];
    CA2_INFL   [label="Ca²⁺ Influx\n(Intracellular ↑)"];
    NA_INFL    [label="Na⁺/H₂O Influx\n(Cell Swelling)"];
    VOLT_CA    [label="Voltage-Gated\nCa²⁺ Channels (VGCC)"];
    NOS_NEU    [label="nNOS Activation\n(Neuronal NOS)"];
    NO_EX      [label="Excess NO\n(Neuronal)"];
    MITOCHON   [label="Mitochondrial\nDysfunction"];
    CYTO_C     [label="Cytochrome C\nRelease"];
    CASP9      [label="Caspase-9\nActivation"];
    CASP3      [label="Caspase-3\nExecution"];
    APOPTOSIS  [label="Apoptosis\n(Penumbra)"];
    NECROSIS   [label="Necrosis\n(Core)"];
    NEU_DEATH  [label="Neuronal\nDeath"];
  }

  /* ===================================================================
     SUBGRAPH 6 — Oxidative Stress & NO Pathways
  =================================================================== */
  subgraph cluster_oxidative {
    label="Oxidative Stress & NO\n(산화 스트레스 및 산화질소 경로)";
    style=filled; color="#ead1f5"; fontcolor="#4a235a"; fontsize=10;
    node [fillcolor="#f5ebfa"];
    ROS_PROD   [label="ROS Production\n(O₂⁻, H₂O₂)"];
    XO_ACT     [label="Xanthine Oxidase\nActivation"];
    NADPH_OX   [label="NADPH Oxidase\nActivation (NOX2)"];
    MITO_ROS   [label="Mitochondrial\nROS Leak (Complex I/III)"];
    SOD_ENZ    [label="SOD\n(Superoxide Dismutase)"];
    CAT_GPX    [label="Catalase / GPx\n(Antioxidants)"];
    RNS        [label="Peroxynitrite\n(ONOO⁻, RNS)"];
    ENOS       [label="eNOS → NO\n(Vasodilation, Protective)"];
    INOS       [label="iNOS → NO\n(Inflammatory, Toxic)"];
    LIPID_PEROX[label="Lipid\nPeroxidation (4-HNE)"];
    DNA_DAM    [label="DNA Strand\nBreaks (8-OHdG)"];
    PARP       [label="PARP Activation\n(NAD⁺ Depletion)"];
    HO1        [label="HO-1 / Nrf2\n(Cytoprotective)"];
  }

  /* ===================================================================
     SUBGRAPH 7 — Neuroinflammation & BBB Disruption
  =================================================================== */
  subgraph cluster_neuroinflamm {
    label="Neuroinflammation & BBB Disruption\n(신경 염증 및 혈뇌장벽 손상)";
    style=filled; color="#d5f5e3"; fontcolor="#1a5632"; fontsize=10;
    node [fillcolor="#e8f8f0"];
    DAMPS      [label="DAMPs Release\n(HMGB1, ATP, DNA)"];
    TLR4_SIG   [label="TLR4 / TLR2\nSignaling"];
    NFKB       [label="NF-κB Activation\n(Transcription Factor)"];
    NLRP3      [label="NLRP3\nInflammasome"];
    MICROGLIA  [label="Microglial Activation\n(M1 Phenotype)"];
    ASTRO      [label="Reactive Astrogliosis\n(A1 Phenotype)"];
    NEUTRO     [label="Neutrophil\nInfiltration (6–24h)"];
    MONO_MAC   [label="Monocyte/Macrophage\nInfiltration (24–72h)"];
    NK_T       [label="NK / T-Cell\nInfiltration (3–7d)"];
    IL1B       [label="IL-1β ↑\n(Pyrogenic)"];
    IL6        [label="IL-6 ↑\n(Acute Phase)"];
    TNF_A      [label="TNF-α ↑\n(Pro-inflammatory)"];
    IL17       [label="IL-17 ↑\n(Neutrophil chemo)"];
    IL10       [label="IL-10 ↑\n(Anti-inflammatory)"];
    TGF_B1     [label="TGF-β1 ↑\n(Repair/M2 shift)"];
    ICAM1      [label="ICAM-1 / VCAM-1\nUpregulation"];
    MMP9       [label="MMP-9\n(Tight-junction Cleavage)"];
    MMP2       [label="MMP-2\n(Basement membrane)"];
    BBB_INTEG  [label="BBB Integrity ↓\n(혈뇌장벽 파괴)"];
    VASOGENIC  [label="Vasogenic Edema\n(단백 삼출)"];
    CYTOTOX_ED [label="Cytotoxic Edema\n(이온 축적)"];
    EDEMA      [label="Cerebral Edema\n(ICP ↑)"];
    HEM_TRANSF [label="Hemorrhagic\nTransformation (HT)"];
    COMP_ACT   [label="Complement\nActivation (C3, MAC)"];
  }

  /* ===================================================================
     SUBGRAPH 8 — Reperfusion Injury
  =================================================================== */
  subgraph cluster_reperfusion_inj {
    label="Reperfusion Injury\n(재관류 손상)";
    style=filled; color="#fce5cd"; fontcolor="#6e2f00"; fontsize=10;
    node [fillcolor="#fef3e9"];
    REPF_ROS   [label="Reperfusion\nROS Burst"];
    CA2_OVL    [label="Ca²⁺ Overload\n(Reperfusion)"];
    MITO_MPTP  [label="mPTP Opening\n(Mitochondrial)"];
    NEUTRO_BRK [label="Neutrophil\nBurst (O₂⁻)"];
    COMPL_MAC  [label="MAC Formation\n(C5b-9)"];
    NO_BURST   [label="iNOS NO\nBurst"];
    BENE_RECAL [label="Recanalization Benefit\n(Penumbra Salvage)"];
    HEM_RISK   [label="Hemorrhage Risk ↑\n(Large Core / Late)"];
    NO_REFLOW  [label="No-Reflow\nPhenomenon"];
  }

  /* ===================================================================
     SUBGRAPH 9 — Secondary Prevention Drug PK/PD
  =================================================================== */
  subgraph cluster_secondary {
    label="Secondary Prevention — Drug PK/PD\n(2차 예방 약동/약력학)";
    style=filled; color="#d6eaf8"; fontcolor="#1a3a6e"; fontsize=10;
    node [fillcolor="#eaf4fb"];
    ASP_DOSE   [label="Aspirin 81–325 mg QD\n(COX-1 inhibitor)",
                shape=diamond, fillcolor="#aed6f1"];
    ASP_GUT    [label="Aspirin\nGut Depot"];
    ASP_CENT2  [label="Aspirin\nCentral Compartment"];
    ASP_COX    [label="COX-1\nIrreversible Inhibition"];
    CLOP_DOSE  [label="Clopidogrel 75 mg QD\n(P2Y12 inhibitor)",
                shape=diamond, fillcolor="#aed6f1"];
    CLOP_MET   [label="Clopidogrel\nActive Metabolite (CYP2C19)"];
    CLOP_P2Y12 [label="P2Y12\nIrreversible Inhibition"];
    NOAC_DOSE  [label="NOAC (Apixaban 5 mg BID)\n(Factor Xa inhibitor)",
                shape=diamond, fillcolor="#aed6f1"];
    NOAC_GUT   [label="NOAC\nGut Depot"];
    NOAC_CENT2 [label="NOAC\nCentral Compartment (V1)"];
    NOAC_PERI2 [label="NOAC\nPeripheral Compartment (V2)"];
    NOAC_XA    [label="Factor Xa\nInhibition (reversible)"];
    STATIN_DOSE[label="Statin\n(Rosuvastatin/Atorvastatin)",
                shape=diamond, fillcolor="#aed6f1"];
    HMGCOA     [label="HMG-CoA Reductase\nInhibition"];
    LDL_RED    [label="↓ LDL-C +\nPleiotropic Effects"];
    ANTIHTN    [label="Antihypertensive\n(ACEi / ARB / CCB)",
                shape=diamond, fillcolor="#aed6f1"];
    BP_CTL     [label="BP Control +\nEndothelial Protection"];
  }

  /* ===================================================================
     SUBGRAPH 10 — Neuroprotective & Emerging Targets
  =================================================================== */
  subgraph cluster_neuroprotect {
    label="Neuroprotective & Emerging Targets\n(신경보호 및 신규 표적)";
    style=filled; color="#f0f0f0"; fontcolor="#333333"; fontsize=10;
    node [fillcolor="#fafafa"];
    NMDAi      [label="NMDA Antagonists\n(Neuroprotective, failed trials)"];
    FREE_RAD_SC[label="Free Radical\nScavengers (Edaravone)"];
    STEM_CELL  [label="Stem Cell /\nNeurotrophic Therapy"];
    BDNF       [label="BDNF / VEGF\n(Neuroplasticity)"];
    REHAB_THR  [label="Rehabilitation\n(Physical/Speech Therapy)"];
    NEUROPL    [label="Neuroplasticity\n(Cortical Remapping)"];
    IL6R_INH   [label="Anti-IL-6R\n(Tocilizumab, investigational)"];
    NLRP3_INH  [label="NLRP3 Inhibitor\n(MCC950, investigational)"];
    SHH        [label="Sonic Hedgehog\nSignaling (BBB repair)"];
    ANGIO      [label="Angiogenesis\n(VEGF, HIF-1α)"];
  }

  /* ===================================================================
     SUBGRAPH 11 — Clinical Outcomes
  =================================================================== */
  subgraph cluster_outcomes {
    label="Clinical Outcomes\n(임상 결과)";
    style=filled; color="#fadbd8"; fontcolor="#7b241c"; fontsize=10;
    node [fillcolor="#fdedec"];
    NIHSS      [label="NIHSS Score\n(Stroke Severity, 0–42)"];
    MRS        [label="Modified Rankin Scale\n(mRS, Functional Outcome 0–6)"];
    BARTHEL    [label="Barthel Index\n(Activities of Daily Living)"];
    RECOV      [label="Neurological\nRecovery"];
    MORT       [label="30-day / 90-day\nMortality"];
    RECUR_STRK [label="Recurrent Stroke\n(Annual Risk ~10%)"];
    LT_DISAB   [label="Long-term\nDisability"];
    POST_STROKE[label="Post-stroke\nDepression / Dementia"];
    QALY       [label="Quality-Adjusted\nLife Years (QALY)"];
  }

  /* ===================================================================
     SUBGRAPH 12 — Biomarkers
  =================================================================== */
  subgraph cluster_biomarkers {
    label="Biomarkers\n(바이오마커)";
    style=filled; color="#d1f2eb"; fontcolor="#117a65"; fontsize=10;
    node [fillcolor="#e8f8f5"];
    GFAP_BM    [label="GFAP ↑\n(Astrocyte injury, h-FABP)"];
    UCH_L1     [label="UCH-L1 ↑\n(Neuronal damage)"];
    NSE_BM     [label="NSE ↑\n(Neuronal death)"];
    S100B      [label="S100β ↑\n(Glial/BBB injury)"];
    CRP_BM     [label="hsCRP / CRP ↑\n(Systemic inflammation)"];
    IL6_BM     [label="Serum IL-6 ↑"];
    D_DIMER    [label="D-Dimer ↑\n(Coagulation activation)"];
    FIBRINOGEN [label="Fibrinogen ↑"];
    LDL_BM     [label="LDL-C (mg/dL)\n(Treatment target <70)"];
    HBA1C_BM   [label="HbA1c\n(Glycemic control)"];
    INR_BM     [label="INR / aPTT\n(Anticoag monitoring)"];
    IMAGING_BM [label="MRI DWI/PWI\nInfarct Volume (mL)"];
    CTA_CTP    [label="CT Perfusion\n(CBF / CBV / MTT / Tmax)"];
  }

  /* ===================================================================
     EDGES: Risk Factors → Vascular
  =================================================================== */
  HTN        -> ATHEROSCL      [label="accelerates"];
  HTN        -> ENDO_DYSFX     [label="shear stress"];
  HTN        -> COAG_CASCADE   [label="activates"];
  DM2        -> ATHEROSCL      [label="glycation/oxidation"];
  DM2        -> PLATELET_ACTIV [label="↑ platelet reactivity"];
  DM2        -> ENDO_DYSFX;
  AFIB       -> CARD_EMB       [label="stasis → thrombus"];
  AFIB       -> EMBOLUS        [label="LA thrombus embolizes"];
  HLD        -> ATHEROSCL      [label="↑ LDL oxidation"];
  HLD        -> PLAQUE_RUPTURE [label="unstable plaque"];
  SMOK       -> ATHEROSCL      [label="endothelial damage"];
  SMOK       -> PLATELET_ACTIV [label="activates"];
  SMOK       -> ENDO_DYSFX;
  OBESE      -> PLATELET_ACTIV;
  OBESE      -> ATHEROSCL;
  AGE        -> ATHEROSCL      [label="vessel aging"];
  AGE        -> COLLATERAL     [label="↓ collateral reserve", color="red", arrowhead=tee];
  CAD        -> CARD_EMB       [label="LV thrombus"];
  CKD_RISK   -> COAG_CASCADE   [label="uremic platelet dysfx"];
  COAG_DIS   -> COAG_CASCADE   [label="dysregulates"];
  PREV_TIA   -> RECUR_STRK     [style=dashed, label="prior event"];

  ENDO_DYSFX -> PLATELET_ACTIV [label="exposes collagen"];
  ATHEROSCL  -> PLAQUE_RUPTURE [label="plaque vulnerability"];
  ATHEROSCL  -> STENOSIS       [label="lumen narrowing"];
  PLAQUE_RUPTURE -> TF_EXP    [label="exposes TF"];
  PLAQUE_RUPTURE -> PLATELET_ACTIV [label="collagen exposure"];
  TF_EXP     -> COAG_CASCADE  [label="initiates extrinsic"];
  PLATELET_ACTIV -> TXA2      [label="releases TXA₂"];
  PLATELET_ACTIV -> ADP_PATH  [label="releases ADP"];
  TXA2       -> PLATELET_AGG  [label="amplifies"];
  ADP_PATH   -> PLATELET_AGG  [label="P2Y12 pathway"];
  PLATELET_AGG -> COAG_CASCADE [label="phospholipid surface"];
  COAG_CASCADE -> FACTOR_Xa   [label="generates FXa"];
  FACTOR_Xa  -> THROMBIN       [label="cleaves prothrombin"];
  THROMBIN   -> FIBRIN         [label="cleaves fibrinogen"];
  FIBRIN     -> THROMBUS       [label="stabilizes clot"];
  PLATELET_AGG -> THROMBUS    [label="platelet-rich core"];
  THROMBUS   -> STENOSIS      [label="occludes vessel"];
  EMBOLUS    -> CBF_REDUCE    [label="embolic occlusion"];
  STENOSIS   -> CBF_REDUCE    [label="thrombotic occlusion"];
  CARD_EMB   -> EMBOLUS       [label="releases"];
  COLLATERAL -> CBF_PEN       [label="partially sustains", color="green"];

  /* ===================================================================
     EDGES: Acute Drug PK/PD
  =================================================================== */
  TPA_DOSE   -> TPA_CENT      [label="IV bolus + infusion"];
  TPA_CENT   -> TPA_PERI      [label="distribution (Q)"];
  TPA_CENT   -> TPA_CONC      [label="Cp = Amt/V1"];
  TPA_CONC   -> TPA_FIBRIN    [label="fibrin-specific\nbinding"];
  TPA_FIBRIN -> PLASMINOGEN   [label="activates"];
  PLASMINOGEN -> PLASMIN      [label="→ active plasmin"];
  PAI1       -> TPA_FIBRIN    [label="inhibits (⊣)", color="red", arrowhead=tee];
  ALPHA2AP   -> PLASMIN       [label="neutralizes (⊣)", color="red", arrowhead=tee];
  PLASMIN    -> FIBRINOLYSIS  [label="cleaves fibrin"];
  FIBRINOLYSIS -> THROMBUS    [label="dissolves", color="blue"];
  FIBRINOLYSIS -> RECANAL     [label="→ recanalization"];
  EVT        -> RECANAL       [label="mechanical removal"];
  RECANAL    -> REPERFUSION   [label="restores flow"];

  /* ===================================================================
     EDGES: Ischemic Cascade
  =================================================================== */
  CBF_REDUCE -> CBF_CORE      [label="severe (core)"];
  CBF_REDUCE -> CBF_PEN       [label="moderate (penumbra)"];
  CBF_NORM   -> CBF_PEN       [label="collateral partial supply"];
  CBF_CORE   -> ATP_CORE      [label="→ energy failure"];
  CBF_PEN    -> ATP_PEN       [label="partial ATP depletion"];
  ATP_CORE   -> ION_PUMP      [label="pump failure"];
  ION_PUMP   -> DEPOL         [label="rapid terminal\ndepolarization"];
  DEPOL      -> GLUT_REL      [label="massive\nglutamate release"];
  ATP_CORE   -> LACTATE       [label="anaerobic glycolysis"];
  ATP_PEN    -> PERI_DEPOL    [label="spreading CSD"];
  PERI_DEPOL -> ATP_PEN       [label="↑ demand (⊣)", color="red", arrowhead=tee, constraint=false];
  CBF_CORE   -> INFARCT_VOL   [label="→ irreversible damage"];
  CBF_PEN    -> PENUMBRA_V    [label="defines penumbra"];
  PENUMBRA_V -> DWI_PWI       [label="MRI imaging target"];
  INFARCT_VOL -> DWI_PWI      [label="DWI lesion"];

  /* ===================================================================
     EDGES: Excitotoxicity
  =================================================================== */
  GLUT_REL   -> GLUT_CONC    [label="↑ extracellular 100×"];
  GLUT_CONC  -> NMDA_ACT     [label="activates"];
  GLUT_CONC  -> AMPA_ACT     [label="activates"];
  GLUT_CONC  -> KAIN_R       [label="activates"];
  NMDA_ACT   -> CA2_INFL     [label="Ca²⁺ influx"];
  AMPA_ACT   -> NA_INFL      [label="Na⁺/H₂O influx"];
  KAIN_R     -> CA2_INFL;
  CA2_INFL   -> VOLT_CA      [label="opens VGCC"];
  VOLT_CA    -> CA2_INFL     [label="amplifies (↑)", constraint=false];
  CA2_INFL   -> NOS_NEU      [label="calmodulin → nNOS"];
  NOS_NEU    -> NO_EX        [label="excess NO"];
  NA_INFL    -> CYTOTOX_ED   [label="osmotic swelling"];
  CA2_INFL   -> MITOCHON     [label="Ca²⁺ overload"];
  MITOCHON   -> CYTO_C       [label="cytochrome C release"];
  CYTO_C     -> CASP9        [label="apoptosome → casp9"];
  CASP9      -> CASP3        [label="caspase cascade"];
  CASP3      -> APOPTOSIS    [label="executes"];
  ATP_CORE   -> NECROSIS     [label="energy-independent"];
  APOPTOSIS  -> NEU_DEATH;
  NECROSIS   -> NEU_DEATH;
  NEU_DEATH  -> INFARCT_VOL  [label="↑ infarct"];

  /* ===================================================================
     EDGES: Oxidative Stress
  =================================================================== */
  CA2_INFL   -> XO_ACT       [label="activates (proteolysis)"];
  XO_ACT     -> ROS_PROD     [label="superoxide burst"];
  MITOCHON   -> MITO_ROS     [label="electron chain leak"];
  MITO_ROS   -> ROS_PROD;
  NEUTRO     -> NADPH_OX     [label="respiratory burst"];
  NADPH_OX   -> ROS_PROD;
  ROS_PROD   -> SOD_ENZ      [label="scavenged"];
  ROS_PROD   -> CAT_GPX      [label="scavenged"];
  ROS_PROD   -> LIPID_PEROX  [label="→ 4-HNE"];
  ROS_PROD   -> DNA_DAM      [label="strand breaks"];
  DNA_DAM    -> PARP         [label="PARP activation"];
  PARP       -> ATP_CORE     [label="↓ NAD⁺/ATP (⊣)", color="red", arrowhead=tee, constraint=false];
  NO_EX      -> RNS          [label="+ O₂⁻ → ONOO⁻"];
  ROS_PROD   -> RNS;
  RNS        -> NEU_DEATH    [label="protein nitration → death"];
  ENOS       -> CBF_PEN      [label="vasodilation ↑CBF", color="green"];
  INOS       -> RNS          [label="excess NO"];
  ROS_PROD   -> HO1          [label="Nrf2 antioxidant\nresponse", color="green"];
  HO1        -> ROS_PROD     [label="⊣ (cytoprotective)", color="green", arrowhead=tee, constraint=false];

  /* ===================================================================
     EDGES: Neuroinflammation
  =================================================================== */
  NEU_DEATH  -> DAMPS        [label="cell lysis releases DAMPs"];
  DAMPS      -> TLR4_SIG     [label="HMGB1/DNA → TLR4/2"];
  TLR4_SIG   -> NFKB         [label="→ NF-κB"];
  TLR4_SIG   -> NLRP3        [label="priming signal"];
  ROS_PROD   -> NLRP3        [label="activates"];
  NFKB       -> IL1B         [label="transcription"];
  NFKB       -> IL6          [label="transcription"];
  NFKB       -> TNF_A        [label="transcription"];
  NFKB       -> MMP9         [label="transcription"];
  NFKB       -> ICAM1        [label="transcription"];
  NFKB       -> INOS         [label="induces iNOS"];
  NLRP3      -> IL1B         [label="IL-1β maturation"];
  MICROGLIA  -> NFKB         [label="amplification loop", constraint=false];
  ASTRO      -> IL6          [label="secretes"];
  ASTRO      -> MMP2         [label="secretes"];
  IL1B       -> MICROGLIA    [label="autocrine activation", constraint=false];
  TNF_A      -> MICROGLIA    [label="activates", constraint=false];
  IL6        -> ASTRO        [label="activates"];
  ICAM1      -> NEUTRO       [label="neutrophil rolling/adhesion"];
  ICAM1      -> MONO_MAC     [label="monocyte recruitment"];
  NEUTRO     -> MMP9         [label="secretes (early)"];
  MONO_MAC   -> MMP9         [label="secretes (delayed)"];
  NK_T       -> IL17         [label="produces"];
  IL17       -> NEUTRO       [label="chemoattractant"];
  MMP9       -> BBB_INTEG    [label="cleaves ZO-1/claudin (⊣)", color="red", arrowhead=tee];
  MMP2       -> BBB_INTEG    [label="degrades BM (⊣)", color="red", arrowhead=tee];
  BBB_INTEG  -> VASOGENIC    [label="↓ tight junctions → edema"];
  CYTOTOX_ED -> EDEMA        [label="cell swelling"];
  VASOGENIC  -> EDEMA        [label="plasma extravasation"];
  EDEMA      -> INFARCT_VOL  [label="↑ secondary injury"];
  BBB_INTEG  -> HEM_TRANSF   [label="↑ hemorrhage risk"];
  COMP_ACT   -> BBB_INTEG    [label="MAC → endothelial damage (⊣)", color="red", arrowhead=tee];
  IL10       -> IL1B         [label="⊣ anti-inflammatory", color="green", arrowhead=tee];
  IL10       -> TNF_A        [label="⊣", color="green", arrowhead=tee];
  TGF_B1     -> MICROGLIA    [label="M1→M2 shift", color="green"];
  TGF_B1     -> BBB_INTEG    [label="↑ TJ protein expression", color="green"];

  /* ===================================================================
     EDGES: Reperfusion Injury
  =================================================================== */
  REPERFUSION -> REPF_ROS    [label="sudden O₂ reintroduction"];
  REPERFUSION -> CA2_OVL     [label="Ca²⁺ surge"];
  REPERFUSION -> NEUTRO_BRK  [label="leukocyte activation"];
  REPERFUSION -> COMPL_MAC   [label="complement burst"];
  REPF_ROS    -> ROS_PROD;
  CA2_OVL     -> MITO_MPTP   [label="opens mPTP"];
  MITO_MPTP   -> CYTO_C;
  NEUTRO_BRK  -> NADPH_OX;
  COMPL_MAC   -> COMP_ACT;
  REPERFUSION -> NO_BURST    [label="iNOS induction"];
  NO_BURST    -> RNS;
  REPERFUSION -> BENE_RECAL  [label="salvages penumbra (net benefit)"];
  BENE_RECAL  -> PENUMBRA_V  [label="rescues tissue"];
  REPERFUSION -> HEM_RISK    [label="large core + late reperfusion"];
  HEM_RISK    -> HEM_TRANSF;
  REPERFUSION -> NO_REFLOW   [label="microvascular\ncompression"];
  NO_REFLOW   -> CBF_CORE    [label="limits restoration", color="red", arrowhead=tee];

  /* ===================================================================
     EDGES: Secondary Prevention
  =================================================================== */
  ASP_DOSE   -> ASP_GUT      [label="oral, F~70%"];
  ASP_GUT    -> ASP_CENT2    [label="absorption (ka)"];
  ASP_CENT2  -> ASP_COX      [label="acetylates COX-1"];
  ASP_COX    -> TXA2         [label="↓ TXA₂ (⊣)", color="red", arrowhead=tee];
  ASP_COX    -> PLATELET_AGG [label="⊣ antiplatelet", color="red", arrowhead=tee];
  CLOP_DOSE  -> CLOP_MET     [label="CYP2C19 activation"];
  CLOP_MET   -> CLOP_P2Y12   [label="irreversible binding"];
  CLOP_P2Y12 -> ADP_PATH     [label="⊣ P2Y12 blockade", color="red", arrowhead=tee];
  NOAC_DOSE  -> NOAC_GUT     [label="oral, F~50%"];
  NOAC_GUT   -> NOAC_CENT2   [label="absorption (ka)"];
  NOAC_CENT2 -> NOAC_PERI2   [label="distribution"];
  NOAC_CENT2 -> NOAC_XA      [label="plasma → Xa inhibition"];
  NOAC_XA    -> FACTOR_Xa    [label="⊣ reversible", color="red", arrowhead=tee];
  NOAC_XA    -> THROMBIN     [label="⊣ (dabigatran IIa)", color="red", arrowhead=tee];
  STATIN_DOSE -> HMGCOA      [label="HMG-CoA inhibition"];
  HMGCOA     -> LDL_RED      [label="↓ LDL synthesis"];
  LDL_RED    -> ATHEROSCL    [label="plaque stabilization (⊣)", color="green", arrowhead=tee];
  LDL_RED    -> ENDO_DYSFX   [label="improve eNOS (⊣)", color="green", arrowhead=tee];
  LDL_RED    -> BBB_INTEG    [label="protective", color="green"];
  ANTIHTN    -> BP_CTL       [label="BP ↓"];
  BP_CTL     -> ATHEROSCL    [label="slows (⊣)", color="green", arrowhead=tee];
  BP_CTL     -> ENOS         [label="↑ eNOS activity", color="green"];
  IL6R_INH   -> IL6          [label="⊣ (investigational)", color="red", arrowhead=tee, style=dashed];
  NLRP3_INH  -> NLRP3        [label="⊣ MCC950", color="red", arrowhead=tee, style=dashed];
  NMDAi      -> NMDA_ACT     [label="⊣ (failed Phase III)", color="red", arrowhead=tee, style=dashed];
  FREE_RAD_SC -> ROS_PROD    [label="⊣ edaravone", color="green", arrowhead=tee, style=dashed];
  SHH        -> BBB_INTEG    [label="BBB repair", color="green", style=dashed];
  ANGIO      -> COLLATERAL   [label="new vessel growth", color="green"];

  /* ===================================================================
     EDGES: Outcomes
  =================================================================== */
  INFARCT_VOL -> NIHSS       [label="↑ deficit"];
  PENUMBRA_V  -> NIHSS       [label="if infarcted → ↑ deficit", style=dashed];
  EDEMA       -> NIHSS       [label="worsens"];
  HEM_TRANSF  -> NIHSS       [label="worsens acutely"];
  NIHSS       -> MRS         [label="determines function"];
  MRS         -> BARTHEL     [label="correlates"];
  NIHSS       -> RECOV       [label="improves with treatment"];
  NEUROPL     -> RECOV       [label="promotes recovery", color="green"];
  REHAB_THR   -> NEUROPL     [label="stimulates", color="green"];
  BDNF        -> NEUROPL     [label="neurotrophic support", color="green"];
  STEM_CELL   -> NEUROPL     [label="regenerative", color="green", style=dashed];
  ANGIO       -> NEUROPL     [label="VEGF pathway", color="green"];
  MRS         -> LT_DISAB    [label="poor mRS → disability"];
  MRS         -> MORT        [label="mRS 5–6"];
  RECUR_STRK  -> INFARCT_VOL [label="cumulative injury"];
  RECOV       -> QALY        [label="→ improved QoL"];
  POST_STROKE -> LT_DISAB    [label="complicates recovery"];
  LT_DISAB    -> POST_STROKE [label="contributes to depression"];

  /* ===================================================================
     EDGES: Biomarkers
  =================================================================== */
  NEU_DEATH   -> UCH_L1      [label="↑ release"];
  NEU_DEATH   -> NSE_BM      [label="↑ release"];
  ASTRO       -> GFAP_BM     [label="↑ blood GFAP"];
  ASTRO       -> S100B       [label="↑ S100β"];
  IL6         -> IL6_BM      [label="serum elevation"];
  IL1B        -> CRP_BM      [label="acute phase response"];
  TNF_A       -> CRP_BM;
  THROMBUS    -> D_DIMER     [label="fibrin degradation → D-Dimer"];
  FIBRIN      -> FIBRINOGEN  [label="fibrinogen consumed"];
  LDL_RED     -> LDL_BM      [label="treatment target <70 mg/dL"];
  DM2         -> HBA1C_BM    [label="metabolic marker"];
  NOAC_CENT2  -> INR_BM      [label="coagulation monitoring"];
  INFARCT_VOL -> IMAGING_BM  [label="DWI volume"];
  PENUMBRA_V  -> IMAGING_BM  [label="PWI–DWI mismatch"];
  CBF_CORE    -> CTA_CTP     [label="CT-perfusion maps"];
  CBF_PEN     -> CTA_CTP;
}
