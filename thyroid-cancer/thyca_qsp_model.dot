/* Thyroid Cancer (ThyCa) QSP Mechanistic Map
   Papillary / Follicular / Medullary / Anaplastic subtypes
   Nodes: 130+, Clusters: 11
   Drug classes: TKIs (sorafenib/lenvatinib/vandetanib/cabozantinib),
                 RETi (selpercatinib/pralsetinib), BRAFi+MEKi,
                 Radioiodine (RAI), TSH suppression
*/
digraph ThyCa_QSP {
  graph [fontname="Helvetica", fontsize=11, rankdir=TB,
         label="Thyroid Cancer QSP Model\nPapillary · Follicular · Medullary · Anaplastic",
         labelloc=t, labelfontsize=16, labelfontname="Helvetica-Bold",
         nodesep=0.4, ranksep=0.6, bgcolor="#FAFAFA"];
  node  [fontname="Helvetica", fontsize=9, shape=box, style="filled,rounded",
         fillcolor=white, color="#666666", margin="0.12,0.06"];
  edge  [fontname="Helvetica", fontsize=8, color="#444444", arrowsize=0.7];

  /* ══════════════════════════════════════════════
     CLUSTER 1: Normal Thyroid Physiology
  ══════════════════════════════════════════════ */
  subgraph cluster_normal_thyroid {
    label="Normal Thyroid Physiology";
    style="filled,rounded"; fillcolor="#EFF6FF"; color="#2563EB";

    TRH         [label="TRH\n(Hypothalamus)", fillcolor="#BFDBFE"];
    TSH         [label="TSH\n(Pituitary)", fillcolor="#93C5FD"];
    TSHR        [label="TSH Receptor\n(TSHR / Gs-coupled)", fillcolor="#60A5FA"];
    cAMP_norm   [label="cAMP\n(normal signaling)", fillcolor="#DBEAFE"];
    T3_T4       [label="T3 / T4\n(Thyroid Hormones)", fillcolor="#BFDBFE"];
    NIS         [label="NIS\n(Na+/I- Symporter)\n[iodide uptake]", fillcolor="#E0F2FE"];
    TPO         [label="Thyroid Peroxidase\n(TPO)\n[T3/T4 synthesis]", fillcolor="#E0F2FE"];
    TG          [label="Thyroglobulin (Tg)\n[tumor biomarker]", fillcolor="#FEF3C7", color="#B45309"];
    Feedback    [label="T3/T4 Neg. Feedback\non TRH/TSH", fillcolor="#D1FAE5", color="#059669"];
  }

  /* ══════════════════════════════════════════════
     CLUSTER 2: Oncogenic Drivers — DTC (PTC/FTC)
  ══════════════════════════════════════════════ */
  subgraph cluster_dtc_drivers {
    label="Oncogenic Drivers — DTC (PTC/FTC)";
    style="filled,rounded"; fillcolor="#FFF1F2"; color="#BE123C";

    BRAF_V600E  [label="BRAF V600E\n(~60% PTC)", fillcolor="#FECACA", color="#BE123C"];
    RET_PTC     [label="RET/PTC\nRearrangement\n(~20% PTC)", fillcolor="#FECACA"];
    RAS_mut     [label="RAS Mutations\n(NRAS/KRAS/HRAS)\n(~15% FTC)", fillcolor="#FECACA"];
    TERT_prom   [label="TERT Promoter\nMutation\n(dedifferentiation)", fillcolor="#FEE2E2"];
    TP53        [label="TP53 Mutation\n(ATC driver)", fillcolor="#DC2626", fontcolor="white"];
    PTEN_loss   [label="PTEN Loss\n(PI3K activation)", fillcolor="#FEE2E2"];
    PIK3CA      [label="PIK3CA Mutation\n(FTC/ATC)", fillcolor="#FEE2E2"];
    CTNNB1      [label="CTNNB1 (β-catenin)\nATC mutation", fillcolor="#FEE2E2"];
  }

  /* ══════════════════════════════════════════════
     CLUSTER 3: Oncogenic Drivers — MTC
  ══════════════════════════════════════════════ */
  subgraph cluster_mtc_drivers {
    label="Oncogenic Drivers — MTC";
    style="filled,rounded"; fillcolor="#FAF5FF"; color="#7C3AED";

    RET_mut     [label="RET Mutation\n(M918T: sporadic MTC)\n(C634R: MEN2A)", fillcolor="#DDD6FE", color="#7C3AED"];
    RET_germline[label="Germline RET\nMutation\n(MEN2A/2B, FMTC)", fillcolor="#EDE9FE"];
    RET_kinase  [label="RET Kinase\nDomain Activation", fillcolor="#C4B5FD"];
    Calcitonin  [label="Calcitonin\n(MTC biomarker)", fillcolor="#FEF9C3", color="#B45309"];
    CEA_mtc     [label="CEA\n(MTC biomarker)", fillcolor="#FEF9C3"];
  }

  /* ══════════════════════════════════════════════
     CLUSTER 4: MAPK / RAS-RAF-MEK-ERK Pathway
  ══════════════════════════════════════════════ */
  subgraph cluster_MAPK {
    label="MAPK / RAS-RAF-MEK-ERK Pathway";
    style="filled,rounded"; fillcolor="#FFF7ED"; color="#C2410C";

    EGFR        [label="EGFR / FGFR\n(RTK activation)", fillcolor="#FEE2E2"];
    VEGFR_cell  [label="VEGFR1-3\n(tumor cell VEGFR)", fillcolor="#FEE2E2"];
    RAS         [label="RAS (KRAS/NRAS)\nGDP → GTP", fillcolor="#FECACA"];
    RAF         [label="BRAF / CRAF\nSerine Kinase", fillcolor="#FECACA", color="#C2410C"];
    MEK         [label="MEK1/2\n(MAP2K1/2)", fillcolor="#FED7AA"];
    ERK         [label="ERK1/2\n(MAPK3/1)", fillcolor="#FDBA74"];
    RSK         [label="RSK\n(RPS6KA)", fillcolor="#FEF3C7"];
    MYC         [label="c-MYC\n(transcription)", fillcolor="#FEE2E2"];
    CyclinD1    [label="Cyclin D1\n(cell cycle entry)", fillcolor="#FEE2E2"];
    p27         [label="p27 (CDKN1B)\n↓ in cancer", fillcolor="#D1FAE5", color="#059669"];
  }

  /* ══════════════════════════════════════════════
     CLUSTER 5: PI3K / AKT / mTOR Pathway
  ══════════════════════════════════════════════ */
  subgraph cluster_PI3K {
    label="PI3K / AKT / mTOR Pathway";
    style="filled,rounded"; fillcolor="#F0FDF4"; color="#15803D";

    PI3K        [label="PI3K (p110α)\nPhospholipid Kinase", fillcolor="#BBF7D0"];
    PTEN        [label="PTEN\n(Tumor Suppressor)", fillcolor="#D1FAE5", color="#15803D"];
    PIP3        [label="PIP3\n(Phosphoinositide)", fillcolor="#A7F3D0"];
    AKT         [label="AKT / PKB\nSer/Thr Kinase", fillcolor="#6EE7B7"];
    TSC1_2      [label="TSC1/2 Complex\n(mTOR inhibitor)", fillcolor="#D1FAE5"];
    mTORC1      [label="mTORC1\n(S6K1/4E-BP1)", fillcolor="#34D399"];
    mTORC2      [label="mTORC2\n(AKT activation)", fillcolor="#34D399"];
    S6K         [label="S6K1\n(Translation)", fillcolor="#A7F3D0"];
    EIF4E       [label="eIF4E\n(Protein Synthesis)", fillcolor="#A7F3D0"];
    HIF1a       [label="HIF-1α\n(Hypoxia Response)", fillcolor="#FEE2E2"];
  }

  /* ══════════════════════════════════════════════
     CLUSTER 6: Tumor Biology & Microenvironment
  ══════════════════════════════════════════════ */
  subgraph cluster_tumor_biology {
    label="Tumor Biology & Microenvironment";
    style="filled,rounded"; fillcolor="#FFFBEB"; color="#92400E";

    Tumor_cells [label="Thyroid Tumor Cells\n(proliferation)", fillcolor="#FEF3C7", color="#92400E"];
    Cancer_stem [label="Cancer Stem Cells\n(dedifferentiation)", fillcolor="#FEE2E2"];
    EMT         [label="Epithelial-Mesenchymal\nTransition (EMT)", fillcolor="#FEE2E2"];
    Apoptosis   [label="Apoptosis\n(Bcl-2/Bax balance)", fillcolor="#D1FAE5", color="#059669"];
    Autophagy   [label="Autophagy\n(survival mechanism)", fillcolor="#FEF9C3"];
    Angiogenesis[label="Tumor\nAngiogenesis", fillcolor="#FECACA", color="#BE123C"];
    VEGF        [label="VEGF-A/B/C\n(angiogenic factor)", fillcolor="#FEE2E2"];
    Stroma      [label="Tumor Stroma\n(CAFs, ECM)", fillcolor="#FEF9C3"];
    MDM2        [label="MDM2\n(p53 inhibitor)", fillcolor="#FEE2E2"];
    Bcl2        [label="Bcl-2 / Bcl-XL\n(anti-apoptotic)", fillcolor="#FEE2E2"];
  }

  /* ══════════════════════════════════════════════
     CLUSTER 7: Drug PK — Compartmental
  ══════════════════════════════════════════════ */
  subgraph cluster_PK {
    label="Drug PK (Oral / IV)";
    style="filled,rounded"; fillcolor="#EFF6FF"; color="#1D4ED8";

    // Sorafenib (multi-kinase TKI)
    SORA_gut    [label="Sorafenib Oral\n400 mg BID", fillcolor="#BFDBFE"];
    SORA_C      [label="Sorafenib Central\nCp (μg/mL)", fillcolor="#93C5FD"];
    SORA_P      [label="Sorafenib\nPeripheral", fillcolor="#DBEAFE"];

    // Lenvatinib (VEGFR/FGFR/RET TKI)
    LENV_gut    [label="Lenvatinib Oral\n24 mg QD", fillcolor="#BFDBFE"];
    LENV_C      [label="Lenvatinib Central\nCp (ng/mL)", fillcolor="#93C5FD"];
    LENV_P      [label="Lenvatinib\nPeripheral", fillcolor="#DBEAFE"];

    // Vandetanib / Cabozantinib (MTC)
    VAND_gut    [label="Vandetanib Oral\n300 mg QD", fillcolor="#BFDBFE"];
    VAND_C      [label="Vandetanib Central\nCp (ng/mL)", fillcolor="#93C5FD"];
    CABO_gut    [label="Cabozantinib Oral\n60 mg QD", fillcolor="#BFDBFE"];
    CABO_C      [label="Cabozantinib Central\nCp (ng/mL)", fillcolor="#93C5FD"];

    // Selpercatinib (selective RETi)
    SELP_gut    [label="Selpercatinib Oral\n160 mg BID", fillcolor="#BFDBFE"];
    SELP_C      [label="Selpercatinib Central\nCp (ng/mL)", fillcolor="#93C5FD"];

    // RAI (Radioiodine)
    RAI_dose    [label="Radioiodine (¹³¹I)\nNominal Activity (mCi)", fillcolor="#FEF9C3"];
    RAI_thyroid [label="¹³¹I Thyroid\nUptake (% ID)", fillcolor="#FDE68A"];

    // TSH suppression
    Levothyrox  [label="Levothyroxine\nTSH Suppression", fillcolor="#D1FAE5"];
  }

  /* ══════════════════════════════════════════════
     CLUSTER 8: Drug PD — Mechanisms of Action
  ══════════════════════════════════════════════ */
  subgraph cluster_PD {
    label="Drug PD — Mechanisms of Action";
    style="filled,rounded"; fillcolor="#F0FDF4"; color="#14532D";

    SORA_PD     [label="Sorafenib PD:\nBRAF/CRAF/VEGFR2\nRET kinase inhibition", fillcolor="#BBF7D0"];
    LENV_PD     [label="Lenvatinib PD:\nVEGFR1-3/FGFR1-4\nPDGFR/RET inhibition", fillcolor="#BBF7D0"];
    VAND_PD     [label="Vandetanib PD:\nRET/VEGFR2/EGFR\ninhibition (MTC)", fillcolor="#BBF7D0"];
    CABO_PD     [label="Cabozantinib PD:\nMET/VEGFR2/RET/AXL\n(MTC 2nd line)", fillcolor="#BBF7D0"];
    SELP_PD     [label="Selpercatinib PD:\nSelective RET kinase\ninhibitor", fillcolor="#BBF7D0"];
    RAI_PD      [label="RAI PD:\nDNA damage in\nNIS+ thyroid cells", fillcolor="#FEF3C7", color="#92400E"];
    TSH_PD      [label="TSH Suppression PD:\nL-T4→↓ TSH→\n↓ TSHR signaling", fillcolor="#BBF7D0"];
  }

  /* ══════════════════════════════════════════════
     CLUSTER 9: Clinical Outcomes & Biomarkers
  ══════════════════════════════════════════════ */
  subgraph cluster_outcomes {
    label="Clinical Outcomes & Biomarkers";
    style="filled,rounded"; fillcolor="#FAF5FF"; color="#6D28D9";

    TumorVol    [label="Tumor Volume\n(sum of target lesions, mm)", fillcolor="#EDE9FE"];
    ORR         [label="Objective Response Rate\n(RECIST 1.1)", fillcolor="#DDD6FE"];
    PFS         [label="Progression-Free\nSurvival (PFS)", fillcolor="#C4B5FD"];
    OS          [label="Overall Survival (OS)", fillcolor="#A78BFA"];
    RAI_refract [label="RAI-Refractory\nDisease Status", fillcolor="#FEE2E2"];
    Tg_level    [label="Serum Tg / Anti-Tg\n(DTC surveillance)", fillcolor="#FEF9C3", color="#B45309"];
    Calc_level  [label="Calcitonin / CEA\n(MTC surveillance)", fillcolor="#FEF9C3"];
    CR          [label="Complete Response (CR)\nTg <0.1 ng/mL", fillcolor="#D1FAE5", color="#059669"];
    PR          [label="Partial Response (PR)\n≥30% decrease", fillcolor="#D1FAE5"];
    PD          [label="Progressive Disease (PD)\n≥20% increase", fillcolor="#FECACA", color="#DC2626"];
    RECIST      [label="RECIST 1.1\nResponse Evaluation", fillcolor="#EDE9FE"];
    TNM         [label="TNM Staging\n(AJCC 8th ed.)", fillcolor="#EDE9FE"];
  }

  /* ══════════════════════════════════════════════
     CLUSTER 10: Safety & Adverse Effects
  ══════════════════════════════════════════════ */
  subgraph cluster_safety {
    label="Safety & Adverse Effects";
    style="filled,rounded"; fillcolor="#FFF1F2"; color="#9F1239";

    HFSR        [label="Hand-Foot Skin\nReaction (HFSR)", fillcolor="#FECACA"];
    HTN_drug    [label="Hypertension\n(anti-VEGFR effect)", fillcolor="#FEE2E2", color="#9F1239"];
    Proteinuria [label="Proteinuria\n(VEGFR inhibition)", fillcolor="#FEE2E2"];
    Diarrhea    [label="Diarrhea / Fatigue\n(TKI class effect)", fillcolor="#F3F4F6"];
    QT_prolong  [label="QTc Prolongation\n(Vandetanib)", fillcolor="#FEE2E2"];
    Hepatotox   [label="Hepatotoxicity\n(LFT monitoring)", fillcolor="#FEE2E2"];
    Hypothyroid_drug [label="Hypothyroidism\n(lenvatinib/sorafenib)", fillcolor="#FEF9C3"];
    Hemorrhage  [label="Fistula /\nHemorrhage Risk", fillcolor="#FEE2E2"];
    Hypocalcemia[label="Hypocalcemia\n(post-thyroidectomy)", fillcolor="#FEF9C3"];
    Salivary    [label="Salivary Gland\nDamage (RAI)", fillcolor="#FEE2E2"];
    Pneumonitis [label="Pneumonitis /\nILD Risk", fillcolor="#FEE2E2"];
  }

  /* ══════════════════════════════════════════════
     CLUSTER 11: Resistance & Redifferentiation
  ══════════════════════════════════════════════ */
  subgraph cluster_resistance {
    label="Resistance & Redifferentiation";
    style="filled,rounded"; fillcolor="#FFFBEB"; color="#B45309";

    TKI_resist  [label="TKI Resistance\n(acquired mutations)", fillcolor="#FEF3C7"];
    MAPK_bypass [label="MAPK Bypass\n(RAS activation)", fillcolor="#FEE2E2"];
    PI3K_escape [label="PI3K/mTOR\nEscape Pathway", fillcolor="#FEE2E2"];
    Dediff      [label="Tumor\nDedifferentiation\n(NIS↓, Tg↓)", fillcolor="#FEE2E2", color="#DC2626"];
    Rediff      [label="Redifferentiation\n(MEKi/BRAFi + RAI)", fillcolor="#D1FAE5", color="#059669"];
    Selumetinib [label="Selumetinib (MEKi)\n+ RAI Rediff. Trial", fillcolor="#BFDBFE"];
    MAPK_inhib  [label="MAPK Inhibition →\n↑ NIS Expression", fillcolor="#D1FAE5"];
    Vemuraf     [label="Vemurafenib +\nRAI Rediff.", fillcolor="#BFDBFE"];
  }

  /* ══════════════════════════════════════════════
     EDGES — Normal Thyroid Physiology
  ══════════════════════════════════════════════ */
  TRH      -> TSH      [label="stimulates"];
  TSH      -> TSHR     [label="binds"];
  TSHR     -> cAMP_norm [label="Gs-cAMP signal"];
  TSHR     -> PI3K     [label="PI3K activation"];
  cAMP_norm-> NIS      [label="↑NIS expression"];
  NIS      -> RAI_thyroid [label="iodide uptake"];
  cAMP_norm-> TPO      [label="hormone synth."];
  TPO      -> T3_T4    [label="oxidation/coupling"];
  T3_T4    -> Feedback [label="negative fb"];
  Feedback -> TRH      [arrowhead=tee, color="#059669"];
  Feedback -> TSH      [arrowhead=tee, color="#059669"];
  TG       -> T3_T4    [label="stored Tg"];

  /* Oncogenic drivers → pathway activation */
  BRAF_V600E -> RAF    [label="constitutive activ.", color="#DC2626", style=bold];
  RET_PTC    -> RAS    [label="oncogenic RAS activ.", color="#DC2626"];
  RET_PTC    -> PI3K   [label="PI3K activation", color="#DC2626"];
  RET_mut    -> RET_kinase [label="autophosphorylation", color="#7C3AED", style=bold];
  RET_germline -> RET_kinase [label="familial"];
  RAS_mut    -> RAS    [label="constitutive RAS", color="#DC2626", style=bold];
  PTEN_loss  -> PTEN   [arrowhead=tee, label="loss", color="#DC2626"];
  PIK3CA     -> PI3K   [label="gain-of-function", color="#DC2626"];
  TERT_prom  -> Cancer_stem [label="proliferation", color="#DC2626"];
  TP53       -> Apoptosis [arrowhead=tee, label="p53 loss", color="#DC2626"];
  CTNNB1     -> MYC    [label="Wnt-MYC", color="#DC2626"];

  /* MAPK cascade */
  EGFR       -> RAS    [label="RTK→RAS"];
  RAS        -> RAF    [label="→BRAF/CRAF"];
  RAF        -> MEK    [label="→MEK1/2"];
  MEK        -> ERK    [label="→ERK1/2"];
  ERK        -> RSK    [label="→RSK"];
  ERK        -> MYC    [label="→MYC", color="#DC2626"];
  ERK        -> CyclinD1 [label="→Cyclin D1", color="#DC2626"];
  CyclinD1   -> Tumor_cells [label="G1→S transition", color="#DC2626"];
  p27        -> CyclinD1 [arrowhead=tee, label="inhibit", color="#059669"];
  ERK        -> p27    [arrowhead=tee, label="phosph/degrade", color="#DC2626"];
  ERK        -> NIS    [arrowhead=tee, label="↓NIS (MAPK)", color="#DC2626", style=dashed];

  /* PI3K cascade */
  PTEN       -> PIP3   [arrowhead=tee, label="PIP3 dephospho", color="#059669"];
  PI3K       -> PIP3   [label="PIP2→PIP3"];
  PIP3       -> AKT    [label="membrane recruit"];
  mTORC2     -> AKT    [label="phospho Ser473"];
  AKT        -> TSC1_2 [arrowhead=tee, label="phospho/inhibit"];
  TSC1_2     -> mTORC1 [arrowhead=tee, label="Rheb-GAP"];
  AKT        -> mTORC1 [label="→ Raptor", style=dashed];
  mTORC1     -> S6K    [label="→S6K1"];
  mTORC1     -> EIF4E  [label="→eIF4E"];
  mTORC1     -> HIF1a  [label="→HIF-1α syn."];
  AKT        -> Bcl2   [label="→ Bcl-XL↑", color="#DC2626"];
  AKT        -> MDM2   [label="phospho MDM2"];
  MDM2       -> TP53   [arrowhead=tee, label="ubiquitin/degrade"];

  /* Tumor biology */
  RET_kinase -> RAS    [label="Grb2/SOS"];
  RET_kinase -> PI3K   [label="pY1062"];
  VEGFR_cell -> PI3K   [label="VEGFR→PI3K"];
  VEGFR_cell -> ERK    [label="VEGFR→MAPK"];
  HIF1a      -> VEGF   [label="transcription"];
  VEGF       -> Angiogenesis [label="autocrine/paracrine"];
  Angiogenesis -> Tumor_cells [label="nutrient supply", color="#DC2626"];
  EMT        -> Cancer_stem [label="mesenchymal", color="#DC2626"];
  MAPK_bypass -> RAF   [label="→ BRAF bypass"];
  MAPK_bypass -> Tumor_cells [label="resistance growth"];
  PI3K_escape -> AKT   [label="TKI resistance"];
  Dediff     -> NIS    [arrowhead=tee, label="NIS lost", color="#DC2626"];
  Dediff     -> TG     [arrowhead=tee, label="Tg lost", color="#DC2626"];
  Dediff     -> RAI_refract [label="RAI failure", color="#DC2626"];

  /* MTC specific */
  RET_kinase -> MEK    [label="RET→MEK", color="#7C3AED"];
  RET_kinase -> AKT    [label="RET→AKT", color="#7C3AED"];
  RET_kinase -> Calcitonin [label="C-cell → Calcitonin", color="#7C3AED"];
  RET_kinase -> CEA_mtc [label="C-cell → CEA", color="#7C3AED"];
  Calcitonin -> Calc_level [label="serum marker"];
  CEA_mtc    -> Calc_level [label="serum marker"];

  /* TSH → tumor promotion */
  TSHR       -> cAMP_norm [label="normal"];
  cAMP_norm  -> Tumor_cells [label="TSH growth stim.", style=dashed, color="#B45309"];
  TSH        -> Tg_level [label="Tg stimulation"];
  TG         -> Tg_level [label="tumor secretion"];

  /* Biomarkers → clinical */
  Tumor_cells -> TumorVol [label="growth"];
  TumorVol   -> ORR    [label="RECIST"];
  TumorVol   -> PFS    [label="time to PD"];
  Tg_level   -> CR     [label="Tg<0.1 → CR", color="#059669"];
  RECIST     -> PR     [color="#059669"];
  RECIST     -> PD     [color="#DC2626"];
  PFS        -> OS     [label="proxy", style=dashed];

  /* ══════════════════════════════════════════════
     DRUG PK FLOWS
  ══════════════════════════════════════════════ */
  SORA_gut  -> SORA_C  [label="ka, F~38%", color="#1D4ED8", style=bold];
  SORA_C    -> SORA_P  [label="k12", color="#1D4ED8"];
  SORA_P    -> SORA_C  [label="k21", color="#1D4ED8"];

  LENV_gut  -> LENV_C  [label="ka, F~85%", color="#1D4ED8", style=bold];
  LENV_C    -> LENV_P  [label="k12", color="#1D4ED8"];
  LENV_P    -> LENV_C  [label="k21", color="#1D4ED8"];

  VAND_gut  -> VAND_C  [label="ka, F~70%", color="#1D4ED8", style=bold];
  CABO_gut  -> CABO_C  [label="ka, F~80%", color="#1D4ED8", style=bold];
  SELP_gut  -> SELP_C  [label="ka, F~73%", color="#1D4ED8", style=bold];

  RAI_dose  -> RAI_thyroid [label="NIS-mediated\nuptake"];
  Levothyrox -> T3_T4  [label="exogenous T4", color="#059669"];
  T3_T4     -> TSH     [arrowhead=tee, label="feedback", color="#059669"];

  /* ══════════════════════════════════════════════
     DRUG PD CONNECTIONS
  ══════════════════════════════════════════════ */
  SORA_C    -> SORA_PD  [color="#14532D", style=bold];
  SORA_PD   -> RAF      [arrowhead=tee, label="BRAF/CRAF inh.", color="#14532D"];
  SORA_PD   -> VEGFR_cell [arrowhead=tee, label="VEGFR2 inh.", color="#14532D"];
  SORA_PD   -> RET_kinase [arrowhead=tee, label="RET inh.", color="#14532D"];

  LENV_C    -> LENV_PD  [color="#14532D", style=bold];
  LENV_PD   -> VEGFR_cell [arrowhead=tee, label="VEGFR1-3 inh.", color="#14532D"];
  LENV_PD   -> MEK      [arrowhead=tee, label="FGFR/RET inh.", color="#14532D"];
  LENV_PD   -> PI3K     [arrowhead=tee, label="PDGFRα/β inh.", color="#14532D"];
  LENV_PD   -> Angiogenesis [arrowhead=tee, label="anti-angiogenic", color="#14532D"];

  VAND_C    -> VAND_PD  [color="#14532D", style=bold];
  VAND_PD   -> RET_kinase [arrowhead=tee, label="RET inh.", color="#14532D"];
  VAND_PD   -> VEGFR_cell [arrowhead=tee, label="VEGFR2 inh.", color="#14532D"];
  VAND_PD   -> EGFR    [arrowhead=tee, label="EGFR inh.", color="#14532D"];

  CABO_C    -> CABO_PD  [color="#14532D", style=bold];
  CABO_PD   -> RET_kinase [arrowhead=tee, label="RET inh.", color="#14532D"];
  CABO_PD   -> VEGFR_cell [arrowhead=tee, label="VEGFR2 inh.", color="#14532D"];
  CABO_PD   -> AKT      [arrowhead=tee, label="MET/AXL inh.", color="#14532D"];

  SELP_C    -> SELP_PD  [color="#14532D", style=bold];
  SELP_PD   -> RET_kinase [arrowhead=tee, label="selective RET inh.", color="#14532D", style=bold];
  SELP_PD   -> Calcitonin [arrowhead=tee, label="↓ calcitonin", color="#14532D", style=dashed];

  RAI_thyroid -> RAI_PD [color="#14532D"];
  RAI_PD    -> Tumor_cells [arrowhead=tee, label="DNA damage/kill", color="#14532D", style=bold];
  RAI_PD    -> TG       [arrowhead=tee, label="ablation", color="#14532D"];

  TSH_PD    -> TSHR     [arrowhead=tee, label="TSH suppressed", color="#059669"];
  TSH_PD    -> Tumor_cells [arrowhead=tee, label="↓ TSH-driven growth", color="#059669"];

  /* ══════════════════════════════════════════════
     SAFETY CONNECTIONS
  ══════════════════════════════════════════════ */
  LENV_PD   -> HTN_drug     [label="VEGFR → BP↑", color="#9F1239", style=dashed];
  LENV_PD   -> Proteinuria  [label="VEGFR → kidney", color="#9F1239", style=dashed];
  LENV_PD   -> HFSR         [label="TKI skin", color="#9F1239", style=dashed];
  LENV_PD   -> Hypothyroid_drug [label="thyroid suppression", color="#9F1239", style=dashed];
  SORA_PD   -> HFSR         [label="BRAF skin", color="#9F1239", style=dashed];
  VAND_PD   -> QT_prolong   [label="QT risk", color="#9F1239", style=dashed];
  RAI_PD    -> Salivary     [label="salivary gland", color="#9F1239", style=dashed];

  /* Resistance */
  TKI_resist -> MAPK_bypass [label="acquired"];
  TKI_resist -> PI3K_escape [label="acquired"];
  BRAF_V600E -> Dediff      [label="long-term", style=dashed];
  MAPK_inhib -> NIS         [label="rediff → ↑NIS", color="#059669"];
  MAPK_inhib -> Rediff      [label="NIS restored", color="#059669"];
  Selumetinib -> MAPK_inhib [label="MEKi mechanism", color="#2563EB"];
  Vemuraf    -> RAF         [arrowhead=tee, label="BRAFi", color="#2563EB"];
  Rediff     -> RAI_thyroid [label="↑RAI uptake", color="#059669"];
  Rediff     -> CR          [label="improved response", color="#059669", style=dashed];

  /* Treatment effects on tumor */
  SORA_PD   -> Tumor_cells [arrowhead=tee, label="PFS benefit", color="#14532D"];
  LENV_PD   -> Tumor_cells [arrowhead=tee, label="PFS benefit", color="#14532D"];
  VAND_PD   -> Tumor_cells [arrowhead=tee, label="PFS MTC", color="#14532D"];
  CABO_PD   -> Tumor_cells [arrowhead=tee, label="PFS MTC 2L", color="#14532D"];
  SELP_PD   -> Tumor_cells [arrowhead=tee, label="ORR RET+", color="#14532D"];
}
