digraph ChronicPancreatitis_QSP {
    graph [
        label="Chronic Pancreatitis QSP Model\nMechanistic Map v1.0"
        labelloc=t
        fontsize=22
        fontname="Helvetica-Bold"
        bgcolor="#FAFAFA"
        rankdir=TB
        splines=ortho
        nodesep=0.4
        ranksep=0.7
        compound=true
    ]
    node [fontname="Helvetica" fontsize=10 style="filled,rounded" shape=box]
    edge [fontname="Helvetica" fontsize=8]

    // =====================================================================
    // SUBGRAPH 1: Etiology & Risk Factors
    // =====================================================================
    subgraph cluster_etiology {
        label="Etiology & Risk Factors"
        style=filled fillcolor="#FFF3E0" color="#E65100" penwidth=2
        fontsize=13 fontcolor="#E65100"

        ALCOHOL [label="Chronic Alcohol\nExposure" fillcolor="#FFCC80" color="#E65100"]
        SMOKING [label="Smoking" fillcolor="#FFCC80" color="#E65100"]
        GENETIC [label="Genetic Factors\n(PRSS1, SPINK1,\nCFTR, CTRC)" fillcolor="#FFCC80" color="#E65100"]
        AUTOIMMUNE [label="Autoimmune\nPancreatitis (AIP)" fillcolor="#FFCC80" color="#E65100"]
        OBSTRUCTION [label="Ductal Obstruction\n(Stones/Strictures)" fillcolor="#FFCC80" color="#E65100"]
        HYPERLIPID [label="Hypertriglyceridemia" fillcolor="#FFCC80" color="#E65100"]
        HYPERCALC [label="Hypercalcemia" fillcolor="#FFCC80" color="#E65100"]
        RECURRENT_AP [label="Recurrent Acute\nPancreatitis" fillcolor="#FFCC80" color="#E65100"]
        IDIOPATHIC [label="Idiopathic\nEtiology" fillcolor="#FFCC80" color="#E65100"]
    }

    // =====================================================================
    // SUBGRAPH 2: Acinar Cell Pathology
    // =====================================================================
    subgraph cluster_acinar {
        label="Acinar Cell Pathology"
        style=filled fillcolor="#E8F5E9" color="#2E7D32" penwidth=2
        fontsize=13 fontcolor="#2E7D32"

        ACINAR [label="Pancreatic\nAcinar Cell" fillcolor="#A5D6A7" color="#2E7D32"]
        ZYMOGEN [label="Zymogen\nGranule" fillcolor="#C8E6C9" color="#2E7D32"]
        TRYP_ACTIVATION [label="Premature\nTrypsinogen\nActivation" fillcolor="#EF9A9A" color="#C62828"]
        ACINAR_DEATH [label="Acinar Cell\nNecrosis/Apoptosis" fillcolor="#EF9A9A" color="#C62828"]
        Ca2_SIGNAL [label="Intracellular\nCa²⁺ Overload" fillcolor="#FFCDD2" color="#C62828"]
        ER_STRESS [label="ER Stress /\nUnfolded Protein\nResponse" fillcolor="#FFCDD2" color="#C62828"]
        MITOCHON [label="Mitochondrial\nDysfunction" fillcolor="#FFCDD2" color="#C62828"]
        AUTOPHAGY [label="Impaired\nAutophagy" fillcolor="#FFCDD2" color="#C62828"]
        OXIDATIVE [label="Oxidative Stress\nROS Production" fillcolor="#FFCDD2" color="#C62828"]
        LIPOTOXIC [label="Lipotoxicity\n(Fatty Acid)" fillcolor="#FFCDD2" color="#C62828"]
    }

    // =====================================================================
    // SUBGRAPH 3: Ductal Cell Pathology
    // =====================================================================
    subgraph cluster_ductal {
        label="Ductal Cell Pathology"
        style=filled fillcolor="#E3F2FD" color="#1565C0" penwidth=2
        fontsize=13 fontcolor="#1565C0"

        DUCTAL [label="Pancreatic\nDuctal Cell" fillcolor="#90CAF9" color="#1565C0"]
        CFTR [label="CFTR Channel\n(Cl⁻/HCO₃⁻\nTransporter)" fillcolor="#64B5F6" color="#1565C0"]
        BICARB [label="Bicarbonate\nSecretion ↓" fillcolor="#BBDEFB" color="#1565C0"]
        DUCT_FLUID [label="Duct Fluid\nVolume ↓" fillcolor="#BBDEFB" color="#1565C0"]
        PROTEIN_PLUG [label="Protein Plug\nFormation" fillcolor="#EF9A9A" color="#C62828"]
        DUCT_PRESS [label="Ductal\nHypertension" fillcolor="#EF9A9A" color="#C62828"]
        CALCIFICATION [label="Ductal\nCalcifications" fillcolor="#BDBDBD" color="#424242"]
        DUCT_STRIC [label="Ductal Strictures\n& Dilation" fillcolor="#EF9A9A" color="#C62828"]
    }

    // =====================================================================
    // SUBGRAPH 4: Inflammatory Cascade
    // =====================================================================
    subgraph cluster_inflammation {
        label="Inflammatory Cascade"
        style=filled fillcolor="#FCE4EC" color="#880E4F" penwidth=2
        fontsize=13 fontcolor="#880E4F"

        MACRO [label="Macrophage\nRecruitment\n(M1/M2)" fillcolor="#F48FB1" color="#880E4F"]
        NEUTRO [label="Neutrophil\nInflux" fillcolor="#F48FB1" color="#880E4F"]
        Th1 [label="Th1 Cells\n(IFN-γ, TNF-α)" fillcolor="#F48FB1" color="#880E4F"]
        Th2 [label="Th2 Cells\n(IL-4, IL-13)" fillcolor="#F48FB1" color="#880E4F"]
        Th17 [label="Th17 Cells\n(IL-17, IL-22)" fillcolor="#F48FB1" color="#880E4F"]
        TREG [label="Regulatory T\nCells (Tregs)" fillcolor="#CE93D8" color="#6A1B9A"]
        TNFa [label="TNF-α" fillcolor="#EF9A9A" color="#C62828"]
        IL1B [label="IL-1β" fillcolor="#EF9A9A" color="#C62828"]
        IL6 [label="IL-6" fillcolor="#EF9A9A" color="#C62828"]
        IL8 [label="IL-8/CXCL8" fillcolor="#EF9A9A" color="#C62828"]
        IL10 [label="IL-10\n(Anti-inflammatory)" fillcolor="#A5D6A7" color="#2E7D32"]
        TGFb [label="TGF-β1\n(Pro-fibrotic)" fillcolor="#FFAB91" color="#BF360C"]
        NFKB [label="NF-κB\nSignaling" fillcolor="#FFCC02" color="#E65100"]
        NLRP3 [label="NLRP3\nInflammasome" fillcolor="#FFCC02" color="#E65100"]
        PDAC_RISK [label="PDAC Risk\n(K-Ras mutation)" fillcolor="#EF5350" color="#B71C1C" style="filled,rounded,bold"]
    }

    // =====================================================================
    // SUBGRAPH 5: Pancreatic Stellate Cell Activation & Fibrosis
    // =====================================================================
    subgraph cluster_fibrosis {
        label="Pancreatic Stellate Cells & Fibrosis"
        style=filled fillcolor="#EDE7F6" color="#4527A0" penwidth=2
        fontsize=13 fontcolor="#4527A0"

        PSC_QUIESC [label="Quiescent\nPSC (Lipid-rich)" fillcolor="#CE93D8" color="#4527A0"]
        PSC_ACTIV [label="Activated PSC\n(Myofibroblast)" fillcolor="#AB47BC" color="#4527A0" style="filled,rounded,bold"]
        ALPHA_SMA [label="α-SMA\nExpression" fillcolor="#CE93D8" color="#4527A0"]
        COL1A1 [label="Collagen I/III\nSynthesis" fillcolor="#CE93D8" color="#4527A0"]
        FIBRONECTIN [label="Fibronectin\nDeposition" fillcolor="#CE93D8" color="#4527A0"]
        MMP [label="MMP-2/9\n(Matrix Remodeling)" fillcolor="#CE93D8" color="#4527A0"]
        TIMP [label="TIMP-1/2\n(MMP Inhibitor)" fillcolor="#CE93D8" color="#4527A0"]
        ECM [label="Extracellular Matrix\nAccumulation" fillcolor="#7E57C2" color="#4527A0" fontcolor=white]
        FIBROSIS [label="PANCREATIC\nFIBROSIS" fillcolor="#4527A0" color="#311B92" fontcolor=white style="filled,rounded,bold"]
        PDGF [label="PDGF\n(PSC Proliferation)" fillcolor="#CE93D8" color="#4527A0"]
        CTGF [label="CTGF/CCN2\n(Fibrosis)" fillcolor="#CE93D8" color="#4527A0"]
        VEGF [label="VEGF\n(Angiogenesis)" fillcolor="#CE93D8" color="#4527A0"]
        ANGII [label="Angiotensin II\n(PSC Activation)" fillcolor="#FFAB91" color="#BF360C"]
        STELLATE_SENESC [label="PSC Senescence\n(SASP)" fillcolor="#BDBDBD" color="#424242"]
    }

    // =====================================================================
    // SUBGRAPH 6: Exocrine Dysfunction
    // =====================================================================
    subgraph cluster_exocrine {
        label="Exocrine Pancreatic Insufficiency (EPI)"
        style=filled fillcolor="#F3E5F5" color="#6A1B9A" penwidth=2
        fontsize=13 fontcolor="#6A1B9A"

        LIPASE [label="Lipase Secretion ↓" fillcolor="#CE93D8" color="#6A1B9A"]
        AMYLASE [label="Amylase Secretion ↓" fillcolor="#CE93D8" color="#6A1B9A"]
        PROTEASE [label="Protease Secretion ↓" fillcolor="#CE93D8" color="#6A1B9A"]
        FAT_MALAB [label="Fat Malabsorption\n(Steatorrhea)" fillcolor="#EF9A9A" color="#C62828"]
        PROTEIN_MALAB [label="Protein Malabsorption" fillcolor="#EF9A9A" color="#C62828"]
        CARB_MALAB [label="Carbohydrate\nMalabsorption" fillcolor="#FFCDD2" color="#C62828"]
        MALNUTRITION [label="Malnutrition &\nWeight Loss" fillcolor="#EF9A9A" color="#C62828" style="filled,rounded,bold"]
        VIT_DEF [label="Fat-Soluble Vitamin\nDeficiency (A,D,E,K)" fillcolor="#FFCDD2" color="#C62828"]
        SIBO [label="SIBO (Small Intestinal\nBacterial Overgrowth)" fillcolor="#FFCDD2" color="#C62828"]
        FECAL_ELASTASE [label="Fecal Elastase-1 ↓\n(Biomarker)" fillcolor="#B39DDB" color="#6A1B9A"]
        CCK [label="CCK Release\n(Duodenum)" fillcolor="#CE93D8" color="#6A1B9A"]
        SECRETIN [label="Secretin\n(Ductal Stimulus)" fillcolor="#CE93D8" color="#6A1B9A"]
    }

    // =====================================================================
    // SUBGRAPH 7: Endocrine Dysfunction
    // =====================================================================
    subgraph cluster_endocrine {
        label="Endocrine Dysfunction (Type 3c Diabetes)"
        style=filled fillcolor="#E8EAF6" color="#283593" penwidth=2
        fontsize=13 fontcolor="#283593"

        BETA_LOSS [label="β-Cell Loss\n(Insulin ↓)" fillcolor="#9FA8DA" color="#283593"]
        ALPHA_LOSS [label="α-Cell Loss\n(Glucagon ↓)" fillcolor="#9FA8DA" color="#283593"]
        PP_LOSS [label="PP-Cell Loss\n(Pancreatic\nPolypeptide ↓)" fillcolor="#9FA8DA" color="#283593"]
        INSULIN_SEC [label="Insulin Secretion ↓" fillcolor="#EF9A9A" color="#C62828"]
        GLUCAGON_SEC [label="Glucagon\nDysregulation" fillcolor="#EF9A9A" color="#C62828"]
        GLYC_CONTROL [label="Glycemic Control\nImpairment" fillcolor="#EF9A9A" color="#C62828"]
        T3cDM [label="Type 3c Diabetes\n(Pancreatogenic)" fillcolor="#3949AB" color="#283593" fontcolor=white style="filled,rounded,bold"]
        HYPOGLYCEMIA [label="Hypoglycemia Risk\n(Brittle Diabetes)" fillcolor="#FFCDD2" color="#C62828"]
        INSULIN_RESIST [label="Insulin\nResistance" fillcolor="#FFCDD2" color="#C62828"]
        GLP1 [label="GLP-1 Axis\n(Incretin Effect)" fillcolor="#9FA8DA" color="#283593"]
    }

    // =====================================================================
    // SUBGRAPH 8: Pain Pathways
    // =====================================================================
    subgraph cluster_pain {
        label="Pain Pathways (Nociception)"
        style=filled fillcolor="#FFF8E1" color="#F57F17" penwidth=2
        fontsize=13 fontcolor="#F57F17"

        PERIPH_SENS [label="Peripheral\nSensitization\n(Nociceptor)" fillcolor="#FFE082" color="#F57F17"]
        CENTRAL_SENS [label="Central\nSensitization\n(Wind-up)" fillcolor="#FFE082" color="#F57F17"]
        DORSAL_HORN [label="Spinal Dorsal\nHorn (C-fibers)" fillcolor="#FFD54F" color="#F57F17"]
        BRAIN_PAIN [label="Supraspinal Pain\nProcessing" fillcolor="#FFD54F" color="#F57F17"]
        NGF [label="NGF\n(Nerve Growth Factor)" fillcolor="#FFE082" color="#F57F17"]
        SP_CGRP [label="SP / CGRP\nRelease" fillcolor="#FFE082" color="#F57F17"]
        TRPV1 [label="TRPV1 Receptor\nActivation" fillcolor="#FFE082" color="#F57F17"]
        NEURAL_REMO [label="Neural Remodeling\n(Perineural Invasion)" fillcolor="#EF9A9A" color="#C62828"]
        NMDAR [label="NMDA Receptor\nActivation (Glutamate)" fillcolor="#FFD54F" color="#F57F17"]
        OPIOID_REC [label="Opioid Receptors\n(μ, κ, δ)" fillcolor="#A5D6A7" color="#2E7D32"]
        GABA_INHIB [label="GABAergic\nInhibition" fillcolor="#A5D6A7" color="#2E7D32"]
        DESCEND_INHIB [label="Descending Pain\nInhibition (PAG→RVM)" fillcolor="#A5D6A7" color="#2E7D32"]
        PSYCH [label="Psychological\nComponents\n(Anxiety/Depression)" fillcolor="#CE93D8" color="#6A1B9A"]
        PAIN_CHRONIC [label="CHRONIC ABDOMINAL\nPAIN" fillcolor="#F57F17" color="#BF360C" fontcolor=white style="filled,rounded,bold"]
    }

    // =====================================================================
    // SUBGRAPH 9: Drug PK/PD
    // =====================================================================
    subgraph cluster_pkpd {
        label="Drug PK/PD Mechanisms"
        style=filled fillcolor="#E0F7FA" color="#006064" penwidth=2
        fontsize=13 fontcolor="#006064"

        // PERT
        PERT_DOSE [label="Pancreatic Enzyme\nReplacement Therapy\n(PERT)\nLipase/Amylase/\nProtease" fillcolor="#80DEEA" color="#006064"]
        PERT_ACT [label="PERT Activity in\nDuodenum/Jejunum" fillcolor="#4DD0E1" color="#006064"]
        PERT_PK [label="PERT PK\n(Gastric pH,\nCoating Dissolution)" fillcolor="#80DEEA" color="#006064"]

        // Pain medications
        OPIOID_DRUG [label="Opioids\n(Tramadol/Oxycodone)\nPO/Patch" fillcolor="#80DEEA" color="#006064"]
        OPIOID_PK [label="Opioid PK\n(Vd, CL, t½)" fillcolor="#80DEEA" color="#006064"]
        NSAID_DRUG [label="NSAIDs / COX-2\nInhibitors" fillcolor="#80DEEA" color="#006064"]
        GABAPENTIN [label="Gabapentin/\nPregabalin\n(α2δ subunit)" fillcolor="#80DEEA" color="#006064"]
        ANTIDEPRES [label="Antidepressants\n(TCA/SNRI)" fillcolor="#80DEEA" color="#006064"]
        CELIAC_BLOCK [label="Celiac Plexus\nBlock/Neurolysis" fillcolor="#80DEEA" color="#006064"]

        // Antifibrotics
        PIRFENIDONE [label="Pirfenidone\n(TGF-β inhibitor)" fillcolor="#80DEEA" color="#006064"]
        NINTEDANIB [label="Nintedanib\n(RTK inhibitor)" fillcolor="#80DEEA" color="#006064"]
        LOSARTAN [label="Losartan/ACEi\n(RAAS blockade)" fillcolor="#80DEEA" color="#006064"]

        // CFTR modulators
        CFTR_MOD [label="CFTR Modulators\n(Lumacaftor/\nIvacaftor)" fillcolor="#80DEEA" color="#006064"]

        // Antioxidants
        ANTIOXID [label="Antioxidants\n(NAC, Vit C/E,\nSelenium)" fillcolor="#80DEEA" color="#006064"]

        // Insulin
        INSULIN_TX [label="Insulin Therapy\n(T3cDM Management)" fillcolor="#80DEEA" color="#006064"]

        // Proton pump inhibitor
        PPI [label="PPI\n(Gastric pH ↑\nfor PERT)" fillcolor="#80DEEA" color="#006064"]

        // Octreotide
        OCTREOTIDE [label="Octreotide\n(Somatostatin\nAnalogue)" fillcolor="#80DEEA" color="#006064"]
    }

    // =====================================================================
    // SUBGRAPH 10: Clinical Endpoints
    // =====================================================================
    subgraph cluster_endpoints {
        label="Clinical Endpoints & Outcomes"
        style=filled fillcolor="#F1F8E9" color="#33691E" penwidth=2
        fontsize=13 fontcolor="#33691E"

        PAIN_SCORE [label="Pain Score\n(VAS/NRS)" fillcolor="#AED581" color="#33691E"]
        QUALITY_LIFE [label="Quality of Life\n(QoL: PANQOLI)" fillcolor="#AED581" color="#33691E"]
        BODY_WEIGHT [label="Body Weight\n& BMI" fillcolor="#AED581" color="#33691E"]
        HOSP_RATE [label="Hospitalization Rate\n& Emergency Visits" fillcolor="#AED581" color="#33691E"]
        ENZYME_DOSE [label="PERT Dose\nAdequacy" fillcolor="#AED581" color="#33691E"]
        HBA1C [label="HbA1c\n(Glycemic Control)" fillcolor="#AED581" color="#33691E"]
        IMAGING [label="Imaging Endpoints\n(CT/MRI Calcif.,\nDuctal Dilation)" fillcolor="#AED581" color="#33691E"]
        MORTALITY [label="Mortality &\nSurvival" fillcolor="#EF9A9A" color="#C62828" style="filled,rounded,bold"]
        PANCREATIC_FX [label="Pancreatic Function\nTests (FET, Secretin\nStimulation)" fillcolor="#AED581" color="#33691E"]
        OPIOID_DEPEND [label="Opioid Dependence\nRisk" fillcolor="#FFCDD2" color="#C62828"]
    }

    // =====================================================================
    // SUBGRAPH 11: Biomarkers
    // =====================================================================
    subgraph cluster_biomarkers {
        label="Biomarkers & Diagnostics"
        style=filled fillcolor="#ECEFF1" color="#37474F" penwidth=2
        fontsize=13 fontcolor="#37474F"

        SERUM_AMYLASE [label="Serum Amylase\n(Acute Flares)" fillcolor="#B0BEC5" color="#37474F"]
        SERUM_LIPASE [label="Serum Lipase\n(Acute Flares)" fillcolor="#B0BEC5" color="#37474F"]
        CRP [label="CRP / ESR\n(Inflammation)" fillcolor="#B0BEC5" color="#37474F"]
        IL6_SERUM [label="Serum IL-6\n(Inflammatory)" fillcolor="#B0BEC5" color="#37474F"]
        CA19_9 [label="CA 19-9\n(PDAC Surveillance)" fillcolor="#EF9A9A" color="#C62828"]
        FECAL_FAT [label="Fecal Fat\n(72h collection)" fillcolor="#B0BEC5" color="#37474F"]
        FECAL_ELAS1 [label="Fecal Elastase-1\n(<100μg/g = EPI)" fillcolor="#B0BEC5" color="#37474F"]
        GLUCOSE_FAST [label="Fasting Glucose\n& OGTT" fillcolor="#B0BEC5" color="#37474F"]
        IgG4_SERUM [label="Serum IgG4\n(AIP Diagnosis)" fillcolor="#B0BEC5" color="#37474F"]
        GENETIC_TEST [label="Genetic Testing\n(PRSS1/SPINK1/\nCFTR/CTRC)" fillcolor="#B0BEC5" color="#37474F"]
        MICROBIOME [label="Gut Microbiome\n(Dysbiosis Marker)" fillcolor="#B0BEC5" color="#37474F"]
        ELASTOGRAPHY [label="Elastography\n(Fibrosis Score)" fillcolor="#B0BEC5" color="#37474F"]
    }

    // =====================================================================
    // SUBGRAPH 12: Complications
    // =====================================================================
    subgraph cluster_complications {
        label="Complications"
        style=filled fillcolor="#FFEBEE" color="#B71C1C" penwidth=2
        fontsize=13 fontcolor="#B71C1C"

        PSEUDOCYST [label="Pancreatic\nPseudocyst" fillcolor="#FFCDD2" color="#B71C1C"]
        FISTULA [label="Pancreatic Fistula" fillcolor="#FFCDD2" color="#B71C1C"]
        PORTALHTN [label="Portal Hypertension\n(Splenic Vein)" fillcolor="#FFCDD2" color="#B71C1C"]
        BILE_DUCT [label="Bile Duct\nCompression" fillcolor="#FFCDD2" color="#B71C1C"]
        PDAC [label="Pancreatic\nAdenocarcinoma\n(PDAC)" fillcolor="#EF5350" color="#B71C1C" fontcolor=white style="filled,rounded,bold"]
        BLEED [label="Gastrointestinal\nBleeding" fillcolor="#FFCDD2" color="#B71C1C"]
        INFECTION [label="Infected\nNecrosis/Abscess" fillcolor="#FFCDD2" color="#B71C1C"]
        DUODENAL_OB [label="Duodenal\nObstruction" fillcolor="#FFCDD2" color="#B71C1C"]
        PANCR_ASCITES [label="Pancreatic\nAscites" fillcolor="#FFCDD2" color="#B71C1C"]
    }

    // =====================================================================
    // EDGES
    // =====================================================================

    // Etiology → Acinar Pathology
    ALCOHOL -> Ca2_SIGNAL [label="↑Ca²⁺ release" color="#E65100"]
    ALCOHOL -> OXIDATIVE [label="ROS, acetaldehyde" color="#E65100"]
    ALCOHOL -> ER_STRESS [label="misfolded proteins" color="#E65100"]
    SMOKING -> OXIDATIVE [label="oxidative burden" color="#E65100"]
    SMOKING -> TRYP_ACTIVATION [label="sensitizes" color="#E65100"]
    GENETIC -> TRYP_ACTIVATION [label="PRSS1 gain-of-function" color="#E65100"]
    GENETIC -> CFTR [label="CFTR mutation" color="#1565C0"]
    GENETIC -> PROTEIN_PLUG [label="SPINK1 loss" color="#E65100"]
    HYPERLIPID -> LIPOTOXIC [color="#E65100"]
    HYPERCALC -> Ca2_SIGNAL [color="#E65100"]
    OBSTRUCTION -> DUCT_PRESS [color="#E65100"]
    RECURRENT_AP -> ACINAR_DEATH [color="#C62828"]
    AUTOIMMUNE -> MACRO [label="IgG4+ plasma cells" color="#880E4F"]

    // Acinar Pathology
    Ca2_SIGNAL -> TRYP_ACTIVATION [color="#C62828"]
    Ca2_SIGNAL -> MITOCHON [color="#C62828"]
    ER_STRESS -> ACINAR_DEATH [color="#C62828"]
    TRYP_ACTIVATION -> ACINAR_DEATH [color="#C62828"]
    TRYP_ACTIVATION -> ZYMOGEN [style=dashed color="#C62828" label="auto-digestion"]
    OXIDATIVE -> MITOCHON [color="#C62828"]
    OXIDATIVE -> ER_STRESS [color="#C62828"]
    AUTOPHAGY -> TRYP_ACTIVATION [style=dashed label="impaired clearance" color="#C62828"]
    MITOCHON -> ACINAR_DEATH [color="#C62828"]
    LIPOTOXIC -> MITOCHON [color="#C62828"]

    // Ductal Pathology
    CFTR -> BICARB [label="CFTR dysfunction" color="#1565C0"]
    BICARB -> DUCT_FLUID [color="#1565C0"]
    DUCT_FLUID -> PROTEIN_PLUG [color="#1565C0"]
    PROTEIN_PLUG -> CALCIFICATION [color="#424242"]
    PROTEIN_PLUG -> OBSTRUCTION [color="#E65100"]
    DUCT_PRESS -> DUCT_STRIC [color="#C62828"]
    DUCT_PRESS -> ACINAR_DEATH [color="#C62828"]
    OBSTRUCTION -> DUCT_STRIC [color="#E65100"]
    CALCIFICATION -> DUCT_STRIC [color="#424242"]

    // Acinar Death → Inflammation
    ACINAR_DEATH -> MACRO [label="DAMP release" color="#880E4F"]
    ACINAR_DEATH -> NEUTRO [color="#880E4F"]
    ACINAR_DEATH -> NFKB [color="#880E4F"]

    // Inflammation cascade
    MACRO -> TNFa [color="#C62828"]
    MACRO -> IL1B [color="#C62828"]
    MACRO -> IL6 [color="#C62828"]
    MACRO -> TGFb [color="#BF360C"]
    NEUTRO -> IL8 [color="#C62828"]
    NEUTRO -> OXIDATIVE [label="NETosis, MPO" color="#C62828"]
    Th1 -> TNFa [color="#C62828"]
    Th2 -> TGFb [color="#BF360C"]
    Th17 -> IL6 [color="#C62828"]
    NFKB -> TNFa [color="#C62828"]
    NFKB -> IL1B [color="#C62828"]
    NFKB -> IL6 [color="#C62828"]
    NLRP3 -> IL1B [label="caspase-1" color="#C62828"]
    IL1B -> NLRP3 [label="priming" color="#E65100"]
    TNFa -> NFKB [label="feed-forward" color="#E65100"]
    IL6 -> Th17 [color="#880E4F"]
    TREG -> Th1 [style=dashed label="suppress" color="#2E7D32"]
    TREG -> Th17 [style=dashed label="suppress" color="#2E7D32"]
    IL10 -> NFKB [style=dashed label="inhibit" color="#2E7D32"]
    IL10 -> TNFa [style=dashed label="inhibit" color="#2E7D32"]
    PDAC_RISK -> PDAC [label="malignant transformation" color="#B71C1C"]

    // Inflammation → PSC Activation
    TGFb -> PSC_ACTIV [label="key driver" color="#4527A0"]
    TNFa -> PSC_ACTIV [color="#4527A0"]
    IL1B -> PSC_ACTIV [color="#4527A0"]
    PDGF -> PSC_ACTIV [label="proliferation" color="#4527A0"]
    ANGII -> PSC_ACTIV [color="#4527A0"]
    OXIDATIVE -> PSC_ACTIV [label="lipid peroxidation" color="#4527A0"]
    PSC_QUIESC -> PSC_ACTIV [label="activation" color="#4527A0"]

    // PSC Activation → Fibrosis
    PSC_ACTIV -> ALPHA_SMA [color="#4527A0"]
    PSC_ACTIV -> COL1A1 [color="#4527A0"]
    PSC_ACTIV -> FIBRONECTIN [color="#4527A0"]
    PSC_ACTIV -> CTGF [color="#4527A0"]
    PSC_ACTIV -> VEGF [color="#4527A0"]
    PSC_ACTIV -> MMP [color="#4527A0"]
    PSC_ACTIV -> TIMP [color="#4527A0"]
    COL1A1 -> ECM [color="#4527A0"]
    FIBRONECTIN -> ECM [color="#4527A0"]
    MMP -> ECM [style=dashed label="degrade" color="#2E7D32"]
    TIMP -> MMP [style=dashed label="inhibit" color="#C62828"]
