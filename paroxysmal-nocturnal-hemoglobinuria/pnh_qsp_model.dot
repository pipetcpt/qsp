digraph PNH_QSP_Model {

  graph [
    rankdir=TB
    label="Paroxysmal Nocturnal Hemoglobinuria (PNH)\nQuantitative Systems Pharmacology Model\nGPI Anchor Deficiency · Complement · Hemolysis · Drug PK/PD"
    labelloc=t
    fontsize=22
    fontname="Helvetica-Bold"
    fontcolor="#1a1a2e"
    bgcolor="#f8f9fa"
    splines=ortho
    nodesep=0.4
    ranksep=0.6
    compound=true
    pad=0.5
  ]

  node [
    shape=box
    style="filled,rounded"
    fontsize=10
    fontname="Helvetica"
    margin="0.15,0.08"
  ]

  edge [
    fontsize=8
    fontname="Helvetica"
    arrowsize=0.7
  ]

  // ============================================================
  // CLUSTER 1: GPI Anchor Biosynthesis & PIG-A Mutation
  // ============================================================
  subgraph cluster_GPI {
    label="1. GPI Anchor Biosynthesis & PIGA Mutation"
    style="filled,rounded"
    fillcolor="#fff3e0"
    color="#e65100"
    fontsize=13
    fontname="Helvetica-Bold"

    PIGA [label="PIGA Gene\n(X-linked)" fillcolor="#ef6c00" fontcolor=white]
    PIGB [label="PIGB" fillcolor="#ffa726"]
    PIGC [label="PIGC" fillcolor="#ffa726"]
    PIGD [label="PIGD" fillcolor="#ffa726"]
    PIGE [label="PIGE" fillcolor="#ffa726"]
    PIGG [label="PIGG" fillcolor="#ffa726"]
    PIGH [label="PIGH" fillcolor="#ffa726"]
    PIGK [label="PIGK" fillcolor="#ffa726"]
    PIGL [label="PIGL" fillcolor="#ffa726"]
    PIGM [label="PIGM\n(mannosylation)" fillcolor="#ffa726"]
    PIGN [label="PIGN" fillcolor="#ffa726"]
    PIGO [label="PIGO" fillcolor="#ffa726"]
    PIGP [label="PIGP" fillcolor="#ffa726"]
    GPAA1 [label="GPAA1\n(GPI transamidase)" fillcolor="#fb8c00"]
    GPI_precursor [label="GPI Precursor\n(ER lumen)" fillcolor="#ffcc02" fontcolor="#333"]
    GPI_anchor [label="Complete\nGPI Anchor" fillcolor="#ff9800" fontcolor=white]
    GPI_transfer [label="GPI Transfer\nto Proteins" fillcolor="#f57c00" fontcolor=white]
    PIGA_mut [label="PIGA Somatic\nMutation\n(HSPC)" shape=octagon fillcolor="#b71c1c" fontcolor=white]
    GPI_deficient [label="GPI-deficient\nMembrane" fillcolor="#c62828" fontcolor=white]
    PNH_I [label="PNH Type I\n(Normal GPI)" fillcolor="#a5d6a7"]
    PNH_II [label="PNH Type II\n(Partial GPI)" fillcolor="#ffcc80"]
    PNH_III [label="PNH Type III\n(No GPI)" fillcolor="#ef9a9a"]
  }

  // ============================================================
  // CLUSTER 2: Hematopoiesis & Clone Dynamics
  // ============================================================
  subgraph cluster_HSC {
    label="2. Hematopoiesis & PNH Clone Dynamics"
    style="filled,rounded"
    fillcolor="#e8f5e9"
    color="#2e7d32"
    fontsize=13
    fontname="Helvetica-Bold"

    NL_HSC [label="Normal HSC\n(GPI+)" fillcolor="#43a047" fontcolor=white]
    PNH_HSC [label="PNH HSC\n(PIGA−)" fillcolor="#e53935" fontcolor=white]
    T_autoreact [label="Autoreactive\nCD8+ T Cells" fillcolor="#7b1fa2" fontcolor=white]
    IFNgamma [label="IFN-γ\n(HSC apoptosis)" fillcolor="#9c27b0" fontcolor=white]
    TNFa_heme [label="TNF-α\n(Bone Marrow)" fillcolor="#9c27b0" fontcolor=white]
    NL_myeloid [label="Normal Myeloid\nProgenitor" fillcolor="#66bb6a"]
    PNH_myeloid [label="PNH Myeloid\nProgenitor" fillcolor="#ef5350" fontcolor=white]
    NL_RBC_precursor [label="Normal\nErythroblast" fillcolor="#80cbc4"]
    PNH_RBC_precursor [label="PNH\nErythroblast" fillcolor="#ef9a9a"]
    NL_Ret [label="Normal\nReticulocyte" fillcolor="#4db6ac"]
    PNH_Ret [label="PNH\nReticulocyte" fillcolor="#e57373"]
    Clone_expand [label="Clone Expansion\n(Immune Advantage)" shape=diamond fillcolor="#ff5722" fontcolor=white]
    AA_background [label="Aplastic Anemia\n(Background)" shape=ellipse fillcolor="#795548" fontcolor=white]
    EPO [label="Erythropoietin\n(EPO)" fillcolor="#1565c0" fontcolor=white]
    BM_niche [label="Bone Marrow\nMicroenvironment" fillcolor="#a5d6a7"]
  }

  // ============================================================
  // CLUSTER 3: Complement Alternative Pathway
  // ============================================================
  subgraph cluster_AP {
    label="3. Complement Alternative Pathway"
    style="filled,rounded"
    fillcolor="#e3f2fd"
    color="#1565c0"
    fontsize=13
    fontname="Helvetica-Bold"

    C3_native [label="C3\n(Native, 75 μg/mL)" fillcolor="#1976d2" fontcolor=white]
    C3_H2O [label="C3(H₂O)\n(Tick-over)" fillcolor="#42a5f5"]
    Factor_B [label="Factor B\n(FB, ~200 μg/mL)" fillcolor="#1565c0" fontcolor=white]
    Factor_D [label="Factor D\n(FD, 2 μg/mL)" fillcolor="#1565c0" fontcolor=white]
    Properdin [label="Properdin\n(CFP)" fillcolor="#0d47a1" fontcolor=white]
    C3b_fluid [label="C3b\n(Fluid Phase)" fillcolor="#64b5f6"]
    Ba_fragment [label="Ba\n(Factor B fragment)" fillcolor="#bbdefb"]
    Bb_fragment [label="Bb\n(Serine protease)" fillcolor="#42a5f5"]
    C3conv_AP [label="C3 Convertase AP\n(C3bBb)" shape=hexagon fillcolor="#0288d1" fontcolor=white]
    C3conv_AP_stab [label="C3bBbP\n(Properdin-stabilized)" shape=hexagon fillcolor="#0277bd" fontcolor=white]
    C3b_amp [label="C3b\n(Amplification Loop)" fillcolor="#1e88e5" fontcolor=white]
    C3a [label="C3a\n(Anaphylatoxin)" fillcolor="#90caf9"]
    C3aR [label="C3aR\n(Mast cell, immune)" fillcolor="#bbdefb"]
    C3b_surface [label="C3b Deposited\non PNH RBC\n(Opsonin)" fillcolor="#e53935" fontcolor=white]
    iC3b [label="iC3b\n(Inactive, CR3 ligand)" fillcolor="#b0bec5"]
    C3d [label="C3d\n(B cell activation)" fillcolor="#90a4ae"]
    CFH [label="CFH\n(Complement Factor H)" fillcolor="#00897b" fontcolor=white]
    CFI [label="Complement\nFactor I (CFI)" fillcolor="#00695c" fontcolor=white]
    CFHR1 [label="CFHR1\n(Factor H-related 1)" fillcolor="#26a69a"]
    CFHR3 [label="CFHR3\n(Factor H-related 3)" fillcolor="#26a69a"]
    C5conv_AP [label="C5 Convertase AP\n(C3bBbC3b)" shape=hexagon fillcolor="#0d47a1" fontcolor=white]
  }

  // ============================================================
  // CLUSTER 4: Terminal Complement & MAC Formation
  // ============================================================
  subgraph cluster_terminal {
    label="4. Terminal Complement Pathway & MAC"
    style="filled,rounded"
    fillcolor="#fce4ec"
    color="#c62828"
    fontsize=13
    fontname="Helvetica-Bold"

    C5 [label="C5\n(~75 μg/mL)" fillcolor="#c62828" fontcolor=white]
    C5a [label="C5a\n(Anaphylatoxin)" fillcolor="#ef9a9a"]
    C5b [label="C5b\n(Initiates MAC)" fillcolor="#e53935" fontcolor=white]
    C5aR1 [label="C5aR1\n(Neutrophil, Mast)" fillcolor="#f48fb1"]
    C5aR2 [label="C5aR2\n(Decoy receptor)" fillcolor="#f8bbd9"]
    C6 [label="C6" fillcolor="#e57373"]
    C7 [label="C7" fillcolor="#e57373"]
    C8 [label="C8" fillcolor="#ef5350" fontcolor=white]
    C9 [label="C9\n(polymerizes x18)" fillcolor="#c62828" fontcolor=white]
    MAC [label="MAC\n(C5b-9 Pore)\n💀 LYSIS" shape=octagon fillcolor="#b71c1c" fontcolor=white]
    Vitronectin [label="Vitronectin\n(S-protein, inhibits)" fillcolor="#a5d6a7"]
    Clusterin [label="Clusterin\n(SP-40,40, inhibits)" fillcolor="#a5d6a7"]
    CD59_normal [label="CD59 (MIRL)\nNormal RBC\n→ Blocks C9" fillcolor="#43a047" fontcolor=white]
    CD59_PNH [label="CD59 ABSENT\nPNH RBC\n→ MAC proceeds" shape=octagon fillcolor="#b71c1c" fontcolor=white]
    Sublytic_MAC [label="Sublytic MAC\nPlatelet activation\nEryptosis" fillcolor="#e91e63" fontcolor=white]
  }

  // ============================================================
  // CLUSTER 5: GPI-Anchored Proteins & Complement Regulation
  // ============================================================
  subgraph cluster_GPI_APs {
    label="5. GPI-Anchored Complement Regulators"
    style="filled,rounded"
    fillcolor="#f3e5f5"
    color="#6a1b9a"
    fontsize=13
    fontname="Helvetica-Bold"

    CD55_normal [label="CD55 (DAF)\nNormal RBC\n→ Decays C3 conv" fillcolor="#7b1fa2" fontcolor=white]
    CD55_PNH [label="CD55 ABSENT\nPNH RBC\n→ C3bBb unchecked" shape=octagon fillcolor="#b71c1c" fontcolor=white]
    CD16b [label="CD16b (FcγRIIIb)\nGPI-linked\nNeutrophil" fillcolor="#ab47bc"]
    CD14_GPI [label="CD14\nGPI-linked\nMonocyte" fillcolor="#ab47bc"]
    CD24 [label="CD24\nGPI-linked" fillcolor="#ce93d8"]
    CD58 [label="CD58 (LFA-3)\nGPI-linked" fillcolor="#ce93d8"]
    CD108 [label="CD108\n(Semaphorin 7A)" fillcolor="#ce93d8"]
    CD157 [label="CD157 (BST-1)\nGPI-linked" fillcolor="#ce93d8"]
    uPAR [label="uPAR\n(urokinase receptor)" fillcolor="#ce93d8"]
    PrPC [label="PrPC\n(prion protein)" fillcolor="#ce93d8"]
    GPI_Cleavage [label="PI-PLC Cleavage\nof GPI anchors" fillcolor="#8e24aa" fontcolor=white]
  }

  // ============================================================
  // CLUSTER 6: Hemolysis & Free Hemoglobin Consequences
  // ============================================================
  subgraph cluster_hemolysis {
    label="6. Hemolysis, Free Hemoglobin & Downstream Effects"
    style="filled,rounded"
    fillcolor="#fff8e1"
    color="#f57f17"
    fontsize=13
    fontname="Helvetica-Bold"

    PNH_RBC [label="PNH RBCs\n(GPI-deficient)" fillcolor="#e53935" fontcolor=white]
    NL_RBC [label="Normal RBCs\n(GPI-replete)" fillcolor="#43a047" fontcolor=white]
    IVH [label="Intravascular\nHemolysis (IVH)\nMAC-mediated" shape=ellipse fillcolor="#b71c1c" fontcolor=white]
    EVH [label="Extravascular\nHemolysis (EVH)\nC3b/iC3b-mediated\n(Spleen/Liver)" shape=ellipse fillcolor="#e65100" fontcolor=white]
    Free_Hgb [label="Free Plasma\nHemoglobin\n(↑ in PNH)" fillcolor="#ff6f00" fontcolor=white]
    Haptoglobin [label="Haptoglobin\n(Hgb scavenger)\n→ depleted" fillcolor="#ffb300"]
    Hemopexin [label="Hemopexin\n(Heme scavenger)\n→ depleted" fillcolor="#ffd54f" fontcolor="#333"]
    Free_heme [label="Free Heme\n(toxic)" fillcolor="#ff8f00" fontcolor=white]
    LDH_plasma [label="LDH\n(≥1.5× ULN = IVH)\nPrimary biomarker" shape=parallelogram fillcolor="#f57f17" fontcolor=white]
    LDH_5x [label="LDH > 5× ULN\nSevere IVH" fillcolor="#e65100" fontcolor=white]
    Tbili [label="Total Bilirubin\n(↑ indirect)" fillcolor="#ffc107" fontcolor="#333"]
    Hemoglobinuria [label="Hemoglobinuria\n(morning urine)" fillcolor="#8d6e63" fontcolor=white]
    Hemosiderinuria [label="Hemosiderinuria\n(iron loss)" fillcolor="#795548" fontcolor=white]
    Reticulocytosis [label="Reticulocytosis\n(compensatory)" fillcolor="#a5d6a7"]
    Anemia_severity [label="Hemolytic\nAnemia\n(Hgb < 10 g/dL)" shape=ellipse fillcolor="#d32f2f" fontcolor=white]
    EPO_response [label="Compensatory\nEPO Rise" fillcolor="#42a5f5"]
    Iron_deficiency [label="Iron Deficiency\n(urine loss)" fillcolor="#8d6e63" fontcolor=white]
    Spleen_EVH [label="Splenic\nPhagocytosis\n(C3b-opsonized)" fillcolor="#bf360c" fontcolor=white]
    Hepatic_EVH [label="Hepatic\nKupffer Cells\n(C3b-opsonized)" fillcolor="#bf360c" fontcolor=white]
  }

  // ============================================================
  // CLUSTER 7: Thrombosis & Vascular Biology
  // ============================================================
  subgraph cluster_thrombo {
    label="7. Thrombosis, NO Biology & Vascular Complications"
    style="filled,rounded"
    fillcolor="#e8eaf6"
    color="#283593"
    fontsize=13
    fontname="Helvetica-Bold"

    NO [label="Nitric Oxide\n(NO)\n↓ in PNH" fillcolor="#283593" fontcolor=white]
    eNOS [label="eNOS\n(Endothelial)" fillcolor="#3949ab" fontcolor=white]
    sGC [label="Soluble Guanylyl\nCyclase (sGC)" fillcolor="#5c6bc0"]
    cGMP [label="cGMP\n(Vasodilation)" fillcolor="#7986cb"]
    Hgb_NO_scav [label="Hgb + NO →\nNitrosylhemoglobin\n(NO scavenging)" fillcolor="#c62828" fontcolor=white]
    ET1 [label="Endothelin-1\n(↑ vasoconstriction)" fillcolor="#b71c1c" fontcolor=white]
    PNH_plt [label="PNH Platelets\n(CD59-deficient)" fillcolor="#e53935" fontcolor=white]
    MAC_plt_act [label="MAC on PNH Plt\n→ Microparticles\n→ Activation" fillcolor="#c62828" fontcolor=white]
    P_selectin [label="P-selectin\n(Plt surface)" fillcolor="#ef5350" fontcolor=white]
    TF_expr [label="Tissue Factor\nExpression↑" fillcolor="#d32f2f" fontcolor=white]
    Thrombin [label="Thrombin\n(↑ generation)" fillcolor="#b71c1c" fontcolor=white]
    Fibrin [label="Fibrin Clot" fillcolor="#c62828" fontcolor=white]
    PAI1 [label="PAI-1\n(fibrinolysis↓)" fillcolor="#d50000" fontcolor=white]
    DVT [label="DVT / PE\n(30-40% lifetime)" shape=ellipse fillcolor="#880e4f" fontcolor=white]
    BuddChiari [label="Budd-Chiari\nSyndrome\n(Hepatic vein)" shape=ellipse fillcolor="#880e4f" fontcolor=white]
    Mesenteric_T [label="Mesenteric\nVein Thrombosis" shape=ellipse fillcolor="#880e4f" fontcolor=white]
    Cerebral_T [label="Cerebral Sinus\nThrombosis\n(CVST)" shape=ellipse fillcolor="#880e4f" fontcolor=white]
    Pulm_HTN [label="Pulmonary\nHypertension\n(NO depletion)" shape=ellipse fillcolor="#4a148c" fontcolor=white]
    SmoothM_dyston [label="Smooth Muscle\nDystonias\n(esophageal, ED)" shape=ellipse fillcolor="#4a148c" fontcolor=white]
  }

  // ============================================================
  // CLUSTER 8: Clinical Endpoints & Quality of Life
  // ============================================================
  subgraph cluster_clinical {
    label="8. Clinical Endpoints & Patient-Reported Outcomes"
    style="filled,rounded"
    fillcolor="#fafafa"
    color="#424242"
    fontsize=13
    fontname="Helvetica-Bold"

    FACIT_score [label="FACIT-Fatigue\nScore\n(0–52, ↑ = better)" shape=parallelogram fillcolor="#424242" fontcolor=white]
    Transfusion_req [label="Transfusion\nRequirement\n(RBC units/year)" shape=parallelogram fillcolor="#616161" fontcolor=white]
    Breakthrough_hem [label="Breakthrough\nHemolysis\n(on C5i therapy)" shape=parallelogram fillcolor="#757575" fontcolor=white]
    Hgb_level [label="Hemoglobin\n(g/dL)\nPrimary endpoint" shape=parallelogram fillcolor="#37474f" fontcolor=white]
    TI_status [label="Transfusion\nIndependence (TI)\nKey efficacy endpoint" shape=diamond fillcolor="#1b5e20" fontcolor=white]
    PGIS_score [label="PGI-S\n(Patient Global\nImpression of Severity)" shape=parallelogram fillcolor="#546e7a" fontcolor=white]
    Renal_function [label="eGFR / Creatinine\n(Renal impairment)" shape=parallelogram fillcolor="#455a64" fontcolor=white]
    AKI_risk [label="Acute Kidney\nInjury Risk\n(hemolytic crisis)" shape=ellipse fillcolor="#b71c1c" fontcolor=white]
    Dysphagia [label="Dysphagia\n(esophageal spasm)" shape=parallelogram fillcolor="#546e7a" fontcolor=white]
    Erectile_dysfn [label="Erectile\nDysfunction\n(NO depletion)" shape=parallelogram fillcolor="#546e7a" fontcolor=white]
    MortalityRisk [label="Mortality Risk\n(thrombosis,\ninfection)" shape=ellipse fillcolor="#b71c1c" fontcolor=white]
    FlowCyt_PNH [label="Flow Cytometry\n(FLAER/CD59)\n% PNH clone" shape=parallelogram fillcolor="#1565c0" fontcolor=white]
  }

  // ============================================================
  // CLUSTER 9: Drug PK/PD – C5 Inhibitors
  // ============================================================
  subgraph cluster_C5i {
    label="9. Drug PK/PD — C5 Inhibitors (Eculizumab · Ravulizumab · Crovalimab)"
    style="filled,rounded"
    fillcolor="#e0f2f1"
    color="#00695c"
    fontsize=13
    fontname="Helvetica-Bold"

    ECU_dose [label="Eculizumab\n600mg q1w×4\nthen 900mg q2w IV" shape=house fillcolor="#00897b" fontcolor=white]
    ECU_central [label="Eculizumab\nCentral (V1=5.5L)" fillcolor="#26a69a" fontcolor=white]
    ECU_periph [label="Eculizumab\nPeripheral (V2=7.3L)" fillcolor="#4db6ac"]
    ECU_C5bound [label="Eculizumab:C5\nBound Complex" fillcolor="#00796b" fontcolor=white]
    ECU_FcRn [label="FcRn Recycling\n(IgG salvage)" fillcolor="#80cbc4"]
    RAV_dose [label="Ravulizumab\n2700-3300mg IV\nthen q8w maint" shape=house fillcolor="#00695c" fontcolor=white]
    RAV_central [label="Ravulizumab\nCentral (V1=4.1L)" fillcolor="#26a69a" fontcolor=white]
    RAV_C5bound [label="Ravulizumab:C5\nBound Complex\n(t½ ~49d)" fillcolor="#004d40" fontcolor=white]
    CRO_dose [label="Crovalimab\n(anti-C5)\n340mg SQ q4w" shape=house fillcolor="#00bfa5" fontcolor=white]
    CRO_SC [label="Crovalimab\nSC absorption\n(F~50%)" fillcolor="#b2dfdb"]
    CRO_plasma [label="Crovalimab\nPlasma" fillcolor="#4db6ac"]
    POZ_dose [label="Pozelimab\n(anti-C5)\nSQ maintenance" shape=house fillcolor="#009688" fontcolor=white]
    C5_inhibited [label="C5 Inhibited\n(>99% required)" shape=diamond fillcolor="#1b5e20" fontcolor=white]
    C5_breakthrough [label="C5 Breakthrough\n(insufficient trough)\n→ hemolytic crisis" shape=octagon fillcolor="#b71c1c" fontcolor=white]
    Meningococcal_risk [label="N. meningitidis\nInfection Risk\n(1000× baseline)" shape=ellipse fillcolor="#880e4f" fontcolor=white]
  }

  // ============================================================
  // CLUSTER 10: Drug PK/PD – Proximal Complement Inhibitors
  // ============================================================
  subgraph cluster_prox {
    label="10. Drug PK/PD — Proximal Complement Inhibitors (Iptacopan · Danicopan · Pegcetacoplan)"
    style="filled,rounded"
    fillcolor="#f9fbe7"
    color="#558b2f"
    fontsize=13
    fontname="Helvetica-Bold"

    IPC_dose [label="Iptacopan\n(LNP023)\n200mg PO BID" shape=house fillcolor="#558b2f" fontcolor=white]
    IPC_gut [label="Iptacopan\nGut (absorption)" fillcolor="#aed581"]
    IPC_plasma [label="Iptacopan\nPlasma (t½~14h)" fillcolor="#8bc34a"]
    IPC_FBbound [label="Iptacopan:FB\nBound\n(FB inhibited)" fillcolor="#689f38" fontcolor=white]
    IPC_effect [label="Factor B\nInhibition\n→ ↓C3b, ↓MAC" shape=diamond fillcolor="#33691e" fontcolor=white]
    DAN_dose [label="Danicopan\n(ACH-4471)\n150mg PO TID\n(add-on to C5i)" shape=house fillcolor="#827717" fontcolor=white]
    DAN_plasma [label="Danicopan\nPlasma (t½~8h)" fillcolor="#f9a825"]
    DAN_FDbound [label="Danicopan:FD\nBound\n(Factor D inhibited)" fillcolor="#f57f17" fontcolor=white]
    DAN_effect [label="Factor D\nInhibition\n→ ↓C3b deposition\n→ ↓EVH" shape=diamond fillcolor="#e65100" fontcolor=white]
    PEG_dose [label="Pegcetacoplan\n(APL-2)\n1080mg SQ\n2×/week" shape=house fillcolor="#4e342e" fontcolor=white]
    PEG_SC [label="Pegcetacoplan\nSC depot" fillcolor="#a1887f"]
    PEG_plasma [label="Pegcetacoplan\nPlasma\n(PEGylated C3 inhib)" fillcolor="#8d6e63" fontcolor=white]
    PEG_C3bound [label="Pegcetacoplan:C3\nBound → C3 inhib\n(ALL complement)" fillcolor="#5d4037" fontcolor=white]
    PEG_EVH_risk [label="EVH Risk\nWith C3 Inhibition\n(C3b on surface)" fillcolor="#ff8f00" fontcolor=white]
    Avacopan_dose [label="Avacopan\n(C5aR1 inhib)\n30mg PO BID" shape=house fillcolor="#263238" fontcolor=white]
    Avacopan_plasma [label="Avacopan\nPlasma" fillcolor="#546e7a"]
    C5aR1_blocked [label="C5aR1\nBlocked\n(↓ inflammation)" shape=diamond fillcolor="#37474f" fontcolor=white]
  }

  // ============================================================
  // CLUSTER 11: Monitoring & Laboratory Parameters
  // ============================================================
  subgraph cluster_monitor {
    label="11. Laboratory Monitoring & Biomarkers"
    style="filled,rounded"
    fillcolor="#e8eaf6"
    color="#1a237e"
    fontsize=13
    fontname="Helvetica-Bold"

    FlowFLAER [label="FLAER Assay\n(GPI-AP detection)\nGold standard" fillcolor="#283593" fontcolor=white]
    Clone_RBC_pct [label="PNH Clone %\n(RBC by flow)" shape=parallelogram fillcolor="#3949ab" fontcolor=white]
    Clone_WBC_pct [label="PNH Clone %\n(WBC by flow)" shape=parallelogram fillcolor="#3949ab" fontcolor=white]
    Clone_Plt_pct [label="PNH Clone %\n(Plt by flow)" shape=parallelogram fillcolor="#3949ab" fontcolor=white]
    LDH_monitor [label="LDH\n(ULN = 250 U/L)" shape=parallelogram fillcolor="#5c6bc0" fontcolor=white]
    fHgb_monitor [label="Free Hgb\n(plasma)" shape=parallelogram fillcolor="#7986cb"]
    Haptoglobin_lvl [label="Haptoglobin\n(<10 mg/dL = depleted)" shape=parallelogram fillcolor="#7986cb"]
    Retic_count [label="Reticulocyte\nCount (↑)" shape=parallelogram fillcolor="#7986cb"]
    CH50_assay [label="CH50\n(Total Complement)" shape=parallelogram fillcolor="#5c6bc0" fontcolor=white]
    C3_level [label="C3 Level\n(normal or ↓)" shape=parallelogram fillcolor="#5c6bc0" fontcolor=white]
    ECU_trough [label="Eculizumab\nTrough Level\n(target >35 μg/mL)" shape=parallelogram fillcolor="#26a69a" fontcolor=white]
    FreeC5_level [label="Free C5\n(target < 0.5 μg/mL)" shape=parallelogram fillcolor="#26a69a" fontcolor=white]
    Coombs_neg [label="Direct Coombs\nNEGATIVE\n(IVH vs. AIHA)" shape=parallelogram fillcolor="#78909c"]
    Ham_test [label="Ham Test\n(historical, acid lysis)" shape=parallelogram fillcolor="#90a4ae"]
    D_dimer [label="D-dimer\n(thrombosis risk)" shape=parallelogram fillcolor="#5c6bc0" fontcolor=white]
    Creatinine [label="Serum Creatinine\n(renal function)" shape=parallelogram fillcolor="#7986cb"]
  }

  // ============================================================
  // CLUSTER 12: Infection & Vaccine Safety
  // ============================================================
  subgraph cluster_infect {
    label="12. Infection Risk & Vaccine Safety (C5 Inhibitor)"
    style="filled,rounded"
    fillcolor="#fbe9e7"
    color="#bf360c"
    fontsize=13
    fontname="Helvetica-Bold"

    Neisseria_risk [label="Neisseria meningitidis\nEncapsulated bacteria\n(MAC-dependent killing)" fillcolor="#bf360c" fontcolor=white]
