    Pirf_Dose -> Pirf_Plasma [color="#A0522D" label="ka=2.0/h"]
    Pirf_Plasma -> Pirf_Effect [color="#CD853F"]
    Pirf_Effect -> TGFb [color="#FF0000" arrowhead=tee label="inhibit"]
