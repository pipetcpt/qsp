    TIMP1 -> MMP2_9 [color="#8FB8E0" arrowhead=tee]
    Lymphocyte -> Fibroblast [color="#4682B4" style=dashed]
    Neutrophil -> ROS [color="#FFD700"]
    IL8_CXCL8 -> Neutrophil [color="#B0C4DE"]
    MCP1 -> Monocyte_Recruit [color="#7CFC00"]
    CXCL1_2 -> Neutrophil [color="#B0C4DE"]

    // --- Adaptive Immunity ---
    CD4_Th -> Th1 [color="#20B2AA"]
    CD4_Th -> Th2 [color="#48D1CC"]
    CD4_Th -> Th17 [color="#40E0D0"]
    CD4_Th -> Treg [color="#7FFFD4"]
