    Treg -> TGFb [color="#FF0000" label="immunosuppressive"]
    B_Cell -> Complement [color="#ADD8E6"]
    Complement -> AM_M1 [color="#32CD32"]
    NK_Cell -> AM_M1 [color="#32CD32" style=dashed]

    // --- Clinical Endpoints ---
    PMF -> FVC [color="#DC143C" penwidth=3 arrowhead=tee]
    Alveolar_Thick -> FVC [color="#DC143C" arrowhead=tee]
    Alveolar_Thick -> DLCO [color="#8B0000" arrowhead=tee penwidth=2]
    PMF -> FEV1 [color="#B22222" arrowhead=tee]
    PMF -> TLC [color="#A52A2A" arrowhead=tee]
    FVC -> Dyspnea [color="#D2691E"]
    DLCO -> Dyspnea [color="#D2691E"]
    FVC -> Walk_6Min [color="#CD853F"]
    Collagen_I -> KL6 [color="#696969"]
    AT2_Injury -> KL6 [color="#696969"]
    AT2_Injury -> SP_D [color="#808080"]
    AT2_Injury -> SP_A [color="#A9A9A9"]
    Nodular_Fibrosis -> CXR_Category [color="#8B4513"]
    PMF -> CT_Score [color="#A0522D"]
    Dyspnea -> QoL_SF36 [color="#C0C0C0"]
    Walk_6Min -> QoL_SF36 [color="#C0C0C0"]
    PMF -> Mortality [color="#000000" penwidth=3]
    Cor_Pulmonale -> Mortality [color="#000000" penwidth=3]

    // --- Pulmonary Hypertension ---
    PMF -> Pulm_Vasc_Remodel [color="#FF6347"]
    Hypoxemia -> Pulm_Vasc_Remodel [color="#FF6347" label="hypoxic vasoconstriction"]
    VEGF -> Pulm_Vasc_Remodel [color="#FF7F50" style=dashed]
    TGFb -> Pulm_Vasc_Remodel [color="#FF0000"]
    Pulm_Vasc_Remodel -> PH [color="#FF4500" penwidth=2]
    PH -> RV_Hypertrophy [color="#FF8C00"]
    RV_Hypertrophy -> Cor_Pulmonale [color="#FF0000" penwidth=2]
