    Tetra_Effect -> NLRP3 [color="#FF4500" arrowhead=tee]

    Silym_Dose -> Silym_Effect [color="#008000"]
    Silym_Effect -> ROS [color="#FFD700" arrowhead=tee]
    Silym_Effect -> TNFa [color="#8A2BE2" arrowhead=tee]

    // --- Feedback ---
    GSH -> NRF2 [color="#ADFF2F" style=dashed label="Nrf2 activation"]
    ROS -> NFkB [color="#C71585" label="oxidative NF-κB"]
    IL10 -> Smad7 [color="#DB7093" label="upregulate"]
    TGFb -> IL10 [color="#7CFC00" style=dashed]
    Collagen_I -> YAP_TAZ [color="#E6E6FA" label="stiffness"]
    Alveolar_Thick -> ROCK [color="#B0C4DE" label="mechanosensing"]
}
