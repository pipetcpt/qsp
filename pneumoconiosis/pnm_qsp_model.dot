    Hypoxemia -> SDB [color="#CD5C5C"]
    SDB -> Cardiac_Mortality [color="#8B0000"]
    Cor_Pulmonale -> Cardiac_Mortality [color="#8B0000" penwidth=2]

    // --- Drug Effects ---
    NAC_Dose -> NAC_Plasma [color="#228B22" label="ka=1.5/h"]
    NAC_Plasma -> NAC_Lung [color="#2E8B57"]
    NAC_Lung -> NAC_Effect [color="#3CB371"]
    NAC_Effect -> GSH [color="#32CD32" label="replenish"]
    NAC_Effect -> ROS [color="#FFD700" arrowhead=tee]
