digraph Pneumoconiosis_QSP {

    graph [
        label = "Pneumoconiosis (진폐증) — Quantitative Systems Pharmacology Model\nMechanistic Map: Dust-Induced Pulmonary Fibrosis Pathways"
        labelloc = "t"
        fontname = "Helvetica-Bold"
        fontsize = 18
        bgcolor = "#FAFAFA"
        rankdir = "LR"
        compound = true
        nodesep = 0.4
        ranksep = 0.7
        splines = "ortho"
    ]

    node [
        fontname = "Helvetica"
        fontsize = 10
        style = "filled,rounded"
        shape = "box"
        penwidth = 1.5
    ]

    edge [
        fontname = "Helvetica"
        fontsize = 9
        penwidth = 1.2
        arrowsize = 0.8
    ]

    // =====================================================================
    // CLUSTER 1: Mineral Dust Exposure & Particle Dynamics
    // =====================================================================
    subgraph cluster_dust {
        label = "1. Mineral Dust Exposure & Kinetics"
        style = "filled"
        fillcolor = "#F5E6CC"
        color = "#D4A017"
        fontsize = 13
        fontname = "Helvetica-Bold"

        Silica_SiO2 [label="Silica (SiO₂)\nCrystalline" fillcolor="#F4A460" shape=ellipse]
        Coal_Dust [label="Coal Dust\n(CWP)" fillcolor="#696969" fontcolor=white shape=ellipse]
        Asbestos [label="Asbestos\nFibers" fillcolor="#CD5C5C" shape=ellipse]
        Mixed_Dust [label="Mixed Mineral\nDust" fillcolor="#DEB887"]
        Respirable_Fraction [label="Respirable\nFraction (<5μm)" fillcolor="#F0E68C"]
        Inhalation_Rate [label="Inhalation\nRate (Qin)" fillcolor="#FFDEAD" shape=diamond]
        Particle_Size [label="Particle Size\nDistribution" fillcolor="#FFE4B5"]
        Alveolar_Deposit [label="Alveolar\nDeposition (D_alv)" fillcolor="#FFA500" penwidth=2.5]
        Mucociliary [label="Mucociliary\nClearance" fillcolor="#90EE90"]
        Macrophage_Clearance [label="Macrophage\nPhagocytic Clearance" fillcolor="#98FB98"]
        Dust_Overload [label="Dust Overload\n(Impaired Clearance)" fillcolor="#FF6347"]
        Cumulative_Exposure [label="Cumulative\nDust Exposure (mg/m³·yr)" fillcolor="#FF8C00" penwidth=2]
        Surface_Area [label="Particle Surface\nArea (Reactivity)" fillcolor="#FFDAB9"]
    }

    // =====================================================================
    // CLUSTER 2: Alveolar Macrophage Biology
    // =====================================================================
    subgraph cluster_macrophage {
        label = "2. Alveolar Macrophage Activation"
        style = "filled"
        fillcolor = "#E8F4E8"
        color = "#228B22"
        fontsize = 13
        fontname = "Helvetica-Bold"

        AM_Resting [label="Resting Alveolar\nMacrophage (AM₀)" fillcolor="#90EE90" penwidth=2]
        AM_M1 [label="Activated Macrophage\n(M1 Phenotype)" fillcolor="#32CD32" penwidth=2]
        AM_M2 [label="Anti-inflammatory\nMacrophage (M2)" fillcolor="#3CB371"]
        Phagosome [label="Phagosome\nFormation" fillcolor="#228B22" fontcolor=white]
        Frustrated_Phago [label="Frustrated\nPhagocytosis" fillcolor="#8B0000" fontcolor=white]
        AM_Pyroptosis [label="Macrophage\nPyroptosis" fillcolor="#DC143C"]
        AM_Apoptosis [label="Macrophage\nApoptosis" fillcolor="#CD5C5C"]
        AM_Necrosis [label="Macrophage\nNecrosis (Secondary)" fillcolor="#B22222"]
        Efferocytosis [label="Efferocytosis\n(Debris Clearance)" fillcolor="#66CDAA"]
        Monocyte_Recruit [label="Blood Monocyte\nRecruitment" fillcolor="#7CFC00"]
        Interstitial_Mac [label="Interstitial\nMacrophage" fillcolor="#ADFF2F"]
        DC_Activation [label="Dendritic Cell\nActivation" fillcolor="#9ACD32"]
        AM_Polarization [label="AM Polarization\nSwitch (M1→M2)" fillcolor="#6B8E23"]
        NLRP3_Priming [label="NLRP3\nPriming Signal (NF-κB)" fillcolor="#556B2F" fontcolor=white]
    }

    // =====================================================================
    // CLUSTER 3: Inflammasome & IL-1β Pathway
    // =====================================================================
    subgraph cluster_inflammasome {
        label = "3. Inflammasome Activation & Cytokine Release"
        style = "filled"
        fillcolor = "#FFE8E8"
        color = "#B22222"
        fontsize = 13
        fontname = "Helvetica-Bold"

        NLRP3 [label="NLRP3\nInflammasome" fillcolor="#FF4500" fontcolor=white penwidth=2.5]
        ASC_Speck [label="ASC Speck\nAssembly" fillcolor="#FF6347"]
        Caspase1 [label="Caspase-1\nActivation" fillcolor="#FF0000" fontcolor=white]
        Pro_IL1b [label="Pro-IL-1β\n(Inactive)" fillcolor="#FFB6C1"]
        IL1b [label="Mature IL-1β\n(Active)" fillcolor="#FF1493" penwidth=2.5]
        IL18 [label="Mature IL-18\n(Active)" fillcolor="#C71585"]
        Gasdermin_D [label="Gasdermin-D\nPore Formation" fillcolor="#8B0000" fontcolor=white]
        Lysosomal_Rupture [label="Lysosomal\nRupture" fillcolor="#A0522D"]
        P2X7_Receptor [label="P2X7 Receptor\n(ATP-gated)" fillcolor="#CD853F"]
        AIM2_Inflammasome [label="AIM2\nInflammasome (DNA)" fillcolor="#D2691E"]
        Cathepsin_B [label="Cathepsin B\nRelease" fillcolor="#BC8F8F"]
        Potassium_Efflux [label="K⁺ Efflux\n(NLRP3 trigger)" fillcolor="#F4A460"]
    }

    // =====================================================================
    // CLUSTER 4: Oxidative Stress & Antioxidant Defense
    // =====================================================================
    subgraph cluster_oxidative {
        label = "4. Oxidative Stress & ROS Dynamics"
        style = "filled"
        fillcolor = "#FFFACD"
        color = "#DAA520"
        fontsize = 13
        fontname = "Helvetica-Bold"

        ROS [label="Reactive Oxygen\nSpecies (ROS)" fillcolor="#FFD700" penwidth=2.5]
        Superoxide [label="Superoxide\n(O₂·⁻)" fillcolor="#FFA500"]
        H2O2 [label="Hydrogen\nPeroxide (H₂O₂)" fillcolor="#FF8C00"]
        Hydroxyl [label="Hydroxyl\nRadical (·OH)" fillcolor="#FF7F50"]
        NOX2 [label="NADPH Oxidase\n(NOX2)" fillcolor="#FF6347"]
        Mitochondrial_ROS [label="Mitochondrial\nROS (mROS)" fillcolor="#FF4500"]
        GSH [label="Glutathione\n(GSH) Pool" fillcolor="#32CD32" penwidth=2]
        SOD [label="Superoxide\nDismutase (SOD)" fillcolor="#90EE90"]
        Catalase [label="Catalase\nActivity" fillcolor="#98FB98"]
        NRF2 [label="NRF2/HO-1\nAntioxidant Response" fillcolor="#ADFF2F"]
        Oxidative_DNA [label="Oxidative DNA\nDamage (8-OHdG)" fillcolor="#CD5C5C"]
        Lipid_Perox [label="Lipid\nPeroxidation (MDA)" fillcolor="#DC143C"]
        ER_Stress [label="ER Stress\n(UPR Activation)" fillcolor="#FF69B4"]
    }

    // =====================================================================
    // CLUSTER 5: Cytokine Network
    // =====================================================================
    subgraph cluster_cytokines {
        label = "5. Pro/Anti-inflammatory Cytokine Network"
        style = "filled"
        fillcolor = "#E6E6FA"
        color = "#7B68EE"
        fontsize = 13
        fontname = "Helvetica-Bold"

        TNFa [label="TNF-α\n(Tumor Necrosis Factor)" fillcolor="#8A2BE2" fontcolor=white penwidth=2]
        IL6 [label="IL-6\n(STAT3 activator)" fillcolor="#9400D3" fontcolor=white]
        IL8_CXCL8 [label="IL-8/CXCL8\n(Neutrophil chemoattractant)" fillcolor="#BA55D3"]
        CXCL1_2 [label="CXCL1/2\n(Chemokines)" fillcolor="#DDA0DD"]
        MCP1 [label="MCP-1/CCL2\n(Macrophage chemoattractant)" fillcolor="#DA70D6"]
        IL12 [label="IL-12\n(Th1 polarization)" fillcolor="#EE82EE"]
        IL17 [label="IL-17\n(Th17)" fillcolor="#9932CC"]
        IFNg [label="IFN-γ\n(M1 polarization)" fillcolor="#8B008B" fontcolor=white]
        IL10 [label="IL-10\n(Anti-inflammatory)" fillcolor="#7CFC00" penwidth=2]
        TGFb [label="TGF-β1\n(Key fibrotic driver)" fillcolor="#FF0000" fontcolor=white penwidth=3]
        PDGF [label="PDGF-BB\n(Fibroblast mitogen)" fillcolor="#FF4500"]
        FGF [label="FGF-2\n(Fibroblast growth)" fillcolor="#FF6347"]
        VEGF [label="VEGF-A\n(Angiogenesis)" fillcolor="#FF7F50"]
        MIF [label="MIF\n(Macrophage inhibitory factor)" fillcolor="#FF8C00"]
        Osteopontin [label="Osteopontin\n(SPP1)" fillcolor="#FFB6C1"]
    }

    // =====================================================================
    // CLUSTER 6: Fibrotic Signaling Pathways
    // =====================================================================
    subgraph cluster_fibrosig {
        label = "6. Fibrotic Intracellular Signaling"
        style = "filled"
        fillcolor = "#FFF0F5"
        color = "#FF69B4"
        fontsize = 13
        fontname = "Helvetica-Bold"

        Smad2_3 [label="Smad2/3\nPhosphorylation" fillcolor="#FF69B4" penwidth=2]
        Smad4 [label="Smad4\nCo-mediator" fillcolor="#FF1493"]
        Smad7 [label="Smad7\n(Inhibitory)" fillcolor="#DB7093"]
        NFkB [label="NF-κB\nTranscription" fillcolor="#C71585" fontcolor=white penwidth=2]
        PI3K_AKT [label="PI3K/AKT\nSurvival Pathway" fillcolor="#FF00FF"]
        mTOR [label="mTOR\nPathway" fillcolor="#DA70D6"]
        MAPK_ERK [label="MAPK/ERK\nProliferation" fillcolor="#DDA0DD"]
        Wnt_Bcatenin [label="Wnt/β-catenin\nSignaling" fillcolor="#D8BFD8"]
        YAP_TAZ [label="YAP/TAZ\nMechanotransduction" fillcolor="#E6E6FA"]
        ROCK [label="ROCK\nCytoskeleton" fillcolor="#B0C4DE"]
        HIF1a [label="HIF-1α\n(Hypoxia response)" fillcolor="#4169E1" fontcolor=white]
        Hedgehog [label="Hedgehog\nSignaling (Shh)" fillcolor="#6495ED"]
        AP1 [label="AP-1\n(c-Jun/c-Fos)" fillcolor="#87CEEB"]
    }

    // =====================================================================
    // CLUSTER 7: Cellular & Structural Remodeling
    // =====================================================================
    subgraph cluster_remodel {
        label = "7. Cellular & Structural Lung Remodeling"
        style = "filled"
        fillcolor = "#F0F8FF"
        color = "#4682B4"
        fontsize = 13
        fontname = "Helvetica-Bold"

        Fibroblast [label="Fibroblast\nProliferation" fillcolor="#4682B4" fontcolor=white penwidth=2]
        Myofibroblast [label="Myofibroblast\nDifferentiation (α-SMA+)" fillcolor="#1E90FF" fontcolor=white penwidth=2.5]
        EMT [label="Epithelial-Mesenchymal\nTransition (EMT)" fillcolor="#00BFFF"]
        AT2_Injury [label="Type-II Pneumocyte\nInjury/Loss" fillcolor="#87CEEB"]
        AT2_Repair [label="Type-II Pneumocyte\nSelf-Renewal" fillcolor="#ADD8E6"]
        Collagen_I [label="Collagen I/III\nDeposition" fillcolor="#B0C4DE" penwidth=2.5]
        Fibronectin [label="Fibronectin\nMatrix" fillcolor="#C0D0E0"]
        MMP2_9 [label="MMP-2/MMP-9\n(Matrix metalloproteinases)" fillcolor="#7B9DBF"]
        TIMP1 [label="TIMP-1/2\n(MMP inhibitors)" fillcolor="#8FB8E0"]
        Alveolar_Thick [label="Alveolar Wall\nThickening" fillcolor="#5B8DB8" penwidth=2]
        Nodular_Fibrosis [label="Nodular\nFibrosis (Silicotic)" fillcolor="#36648B" fontcolor=white]
        PMF [label="Progressive Massive\nFibrosis (PMF)" fillcolor="#00008B" fontcolor=white penwidth=3]
        Lymphocyte [label="Lymphocyte\nInfiltration" fillcolor="#6495ED"]
        Neutrophil [label="Neutrophil\nRecruitment" fillcolor="#B0C4DE"]
    }

    // =====================================================================
    // CLUSTER 8: Clinical Endpoints & Biomarkers
    // =====================================================================
    subgraph cluster_clinical {
        label = "8. Pulmonary Function & Clinical Endpoints"
        style = "filled"
        fillcolor = "#F5F5F5"
        color = "#696969"
        fontsize = 13
        fontname = "Helvetica-Bold"

        FVC [label="FVC Decline\n(% predicted)" fillcolor="#DC143C" fontcolor=white penwidth=2.5]
        FEV1 [label="FEV1 Decline\n(% predicted)" fillcolor="#B22222" fontcolor=white]
        DLCO [label="DLCO Decline\n(Diffusing capacity)" fillcolor="#8B0000" fontcolor=white penwidth=2]
        TLC [label="TLC Reduction\n(Total lung capacity)" fillcolor="#A52A2A" fontcolor=white]
        Dyspnea [label="Dyspnea Score\n(mMRC/Borg)" fillcolor="#D2691E"]
        Walk_6Min [label="6-Min Walk\nTest (6MWT)" fillcolor="#CD853F"]
        CXR_Category [label="Chest X-ray\nILO Category (0-3)" fillcolor="#8B4513"]
        CT_Score [label="HRCT Opacity\nScore" fillcolor="#A0522D"]
        KL6 [label="KL-6\n(Serum biomarker)" fillcolor="#696969" fontcolor=white]
        SP_D [label="SP-D\n(Surfactant protein-D)" fillcolor="#808080" fontcolor=white]
        SP_A [label="SP-A\n(Surfactant protein-A)" fillcolor="#A9A9A9"]
        QoL_SF36 [label="Quality of Life\n(SF-36 Score)" fillcolor="#C0C0C0"]
        Mortality [label="Mortality Risk\n(10-year)" fillcolor="#000000" fontcolor=white penwidth=3]
    }

    // =====================================================================
    // CLUSTER 9: Drug PK/PD (Treatment Interventions)
    // =====================================================================
    subgraph cluster_drugs {
        label = "9. Drug PK/PD — Treatment Interventions"
        style = "filled"
        fillcolor = "#E8FFE8"
        color = "#006400"
        fontsize = 13
        fontname = "Helvetica-Bold"

        // N-Acetylcysteine
        NAC_Dose [label="N-Acetylcysteine\n(NAC) Dose" fillcolor="#006400" fontcolor=white shape=diamond]
        NAC_Plasma [label="NAC Plasma\nConc (C_NAC)" fillcolor="#228B22" fontcolor=white]
        NAC_Lung [label="NAC Lung\nTissue Conc" fillcolor="#2E8B57"]
        NAC_Effect [label="NAC: GSH\nReplenishment & ROS↓" fillcolor="#3CB371"]

        // Pirfenidone
        Pirf_Dose [label="Pirfenidone\nDose (2403mg/d)" fillcolor="#8B4513" fontcolor=white shape=diamond]
        Pirf_Plasma [label="Pirfenidone\nPlasma Conc" fillcolor="#A0522D" fontcolor=white]
        Pirf_Effect [label="Pirfenidone:\nTGF-β↓, Collagen↓, Fibroblast↓" fillcolor="#CD853F"]

        // Nintedanib
        Nint_Dose [label="Nintedanib\nDose (300mg/d)" fillcolor="#00008B" fontcolor=white shape=diamond]
        Nint_Plasma [label="Nintedanib\nPlasma Conc" fillcolor="#0000CD" fontcolor=white]
        Nint_Effect [label="Nintedanib:\nFGFR/PDGFR/VEGFR↓" fillcolor="#4169E1"]

        // Tetrandrine
        Tetra_Dose [label="Tetrandrine\nDose (Traditional)" fillcolor="#8B008B" fontcolor=white shape=diamond]
        Tetra_Plasma [label="Tetrandrine\nPlasma Conc" fillcolor="#9400D3" fontcolor=white]
        Tetra_Effect [label="Tetrandrine:\nNF-κB↓, Inflammation↓" fillcolor="#BA55D3"]

        // Silymarin
        Silym_Dose [label="Silymarin\n(Milk Thistle)" fillcolor="#006400" fontcolor=white shape=diamond]
        Silym_Effect [label="Silymarin:\nAntioxidant, Hepatoprotection" fillcolor="#008000"]

        // General effects
        Anti_Oxidant_Fx [label="Anti-Oxidant\nEffect (Emax)" fillcolor="#90EE90"]
        Anti_Fibro_Fx [label="Anti-Fibrotic\nEffect (Emax)" fillcolor="#98FB98"]
    }

    // =====================================================================
    // CLUSTER 10: Cardiovascular & Systemic Complications
    // =====================================================================
    subgraph cluster_cardiac {
        label = "10. Cardiovascular & Systemic Complications"
        style = "filled"
        fillcolor = "#FFE8D5"
        color = "#FF4500"
        fontsize = 13
        fontname = "Helvetica-Bold"

        Pulm_Vasc_Remodel [label="Pulmonary Vascular\nRemodeling" fillcolor="#FF6347" penwidth=2]
        PH [label="Pulmonary\nHypertension (mPAP>25)" fillcolor="#FF4500" fontcolor=white penwidth=2.5]
        RV_Hypertrophy [label="Right Ventricular\nHypertrophy" fillcolor="#FF8C00"]
        Cor_Pulmonale [label="Cor Pulmonale\n(RV Failure)" fillcolor="#FF0000" fontcolor=white penwidth=2.5]
        Hypoxemia [label="Systemic\nHypoxemia (SpO₂↓)" fillcolor="#DC143C"]
        Polycythemia [label="Secondary\nPolycythemia (Hb↑)" fillcolor="#B22222" fontcolor=white]
        SDB [label="Sleep-Disordered\nBreathing" fillcolor="#CD5C5C"]
        Cardiac_Mortality [label="Cardiorespiratory\nMortality" fillcolor="#8B0000" fontcolor=white penwidth=3]
    }

    // =====================================================================
    // CLUSTER 11: Immunological Responses (Adaptive Immunity)
    // =====================================================================
    subgraph cluster_immune {
        label = "11. Adaptive Immune Responses"
        style = "filled"
        fillcolor = "#F0FFFF"
        color = "#008B8B"
        fontsize = 13
        fontname = "Helvetica-Bold"

        CD4_Th [label="CD4+ T Helper\nActivation" fillcolor="#008B8B" fontcolor=white]
        Th1 [label="Th1 Response\n(IFN-γ dominant)" fillcolor="#20B2AA"]
        Th2 [label="Th2 Response\n(IL-4/IL-13)" fillcolor="#48D1CC"]
        Th17 [label="Th17 Response\n(IL-17 dominant)" fillcolor="#40E0D0"]
        Treg [label="Regulatory T-cell\n(Treg, IL-10/TGF-β)" fillcolor="#7FFFD4"]
        CD8_CTL [label="CD8+ Cytotoxic\nT Lymphocyte" fillcolor="#00CED1"]
        NK_Cell [label="NK Cell\nActivation" fillcolor="#00BFFF"]
        B_Cell [label="B-Cell / Antibody\nResponse" fillcolor="#87CEFA"]
        Complement [label="Complement\nActivation (C3, C5)" fillcolor="#ADD8E6"]
    }

    // =========================================================================
    // INTER-CLUSTER EDGES
    // =========================================================================

    // --- Dust Exposure → Macrophage ---
    Silica_SiO2 -> Respirable_Fraction [color="#D4A017"]
    Coal_Dust -> Respirable_Fraction [color="#696969"]
    Asbestos -> Respirable_Fraction [color="#CD5C5C"]
    Mixed_Dust -> Respirable_Fraction [color="#DEB887"]
    Inhalation_Rate -> Alveolar_Deposit [color="#D4A017" label="k_dep" style=dashed]
    Respirable_Fraction -> Alveolar_Deposit [color="#D4A017"]
    Particle_Size -> Alveolar_Deposit [color="#D4A017" style=dashed]
    Alveolar_Deposit -> Mucociliary [color="#90EE90" label="k_clear"]
    Alveolar_Deposit -> Macrophage_Clearance [color="#228B22" label="k_phag"]
    Alveolar_Deposit -> Dust_Overload [color="#FF6347" label="threshold"]
    Cumulative_Exposure -> Alveolar_Deposit [color="#FF8C00"]
    Surface_Area -> ROS [color="#FFD700" style=dashed]

    // --- Dust → Macrophage Activation ---
    Alveolar_Deposit -> AM_Resting [color="#228B22" label="phagocytosis"]
    Alveolar_Deposit -> Phagosome [color="#228B22"]
    Asbestos -> Frustrated_Phago [color="#CD5C5C" label="fiber-length"]
    Silica_SiO2 -> Frustrated_Phago [color="#D4A017"]
    Dust_Overload -> Frustrated_Phago [color="#FF6347"]
    AM_Resting -> AM_M1 [color="#32CD32" label="activation" penwidth=2]
    AM_M1 -> AM_Pyroptosis [color="#DC143C"]
    AM_M1 -> AM_Apoptosis [color="#CD5C5C"]
    AM_M1 -> AM_Necrosis [color="#B22222"]
    AM_Pyroptosis -> Efferocytosis [color="#66CDAA" style=dashed]
    Monocyte_Recruit -> AM_Resting [color="#7CFC00" label="differentiate"]
    Monocyte_Recruit -> Interstitial_Mac [color="#ADFF2F"]
    DC_Activation -> CD4_Th [color="#9ACD32" lhead=cluster_immune]
    AM_M1 -> AM_M2 [color="#6B8E23" label="M1→M2 switch"]
    AM_M2 -> IL10 [color="#7CFC00"]
    NLRP3_Priming -> NLRP3 [color="#556B2F"]

    // --- Macrophage → Oxidative Stress ---
    AM_M1 -> ROS [color="#FFD700" label="NOX2" penwidth=2]
    Frustrated_Phago -> ROS [color="#FFD700" penwidth=2.5]
    Phagosome -> Mitochondrial_ROS [color="#FF4500"]
    AM_Pyroptosis -> ROS [color="#FF6347"]
    ROS -> Superoxide [color="#FFA500"]
    Superoxide -> H2O2 [color="#FF8C00" label="SOD"]
    H2O2 -> Hydroxyl [color="#FF7F50" label="Fenton"]
    NOX2 -> Superoxide [color="#FF6347"]
    Mitochondrial_ROS -> ROS [color="#FF4500"]
    ROS -> GSH [color="#32CD32" arrowhead=tee label="depletes"]
    SOD -> Superoxide [color="#90EE90" arrowhead=tee]
    Catalase -> H2O2 [color="#98FB98" arrowhead=tee]
    NRF2 -> SOD [color="#ADFF2F"]
    NRF2 -> Catalase [color="#ADFF2F"]
    NRF2 -> GSH [color="#ADFF2F"]
    ROS -> Oxidative_DNA [color="#CD5C5C"]
    ROS -> Lipid_Perox [color="#DC143C"]
    ROS -> ER_Stress [color="#FF69B4"]

    // --- Macrophage → Inflammasome → Cytokines ---
    AM_M1 -> NLRP3_Priming [color="#556B2F" label="NF-κB signal"]
    Silica_SiO2 -> Lysosomal_Rupture [color="#A0522D"]
    Lysosomal_Rupture -> Cathepsin_B [color="#BC8F8F"]
    Cathepsin_B -> NLRP3 [color="#FF4500"]
    Potassium_Efflux -> NLRP3 [color="#F4A460"]
    P2X7_Receptor -> NLRP3 [color="#CD853F"]
    ROS -> NLRP3 [color="#FFD700" label="oxidative trigger"]
    NLRP3 -> ASC_Speck [color="#FF6347"]
    ASC_Speck -> Caspase1 [color="#FF0000"]
    Caspase1 -> Pro_IL1b [color="#FF1493" arrowhead=normal label="cleaves"]
    Pro_IL1b -> IL1b [color="#FF1493" label="mature form"]
    Caspase1 -> IL18 [color="#C71585"]
    Caspase1 -> Gasdermin_D [color="#8B0000"]
    Gasdermin_D -> AM_Pyroptosis [color="#DC143C"]

    // --- Inflammasome → Cytokine network ---
    IL1b -> TNFa [color="#8A2BE2"]
    IL1b -> IL6 [color="#9400D3"]
    IL1b -> IL8_CXCL8 [color="#BA55D3"]
    TNFa -> IL6 [color="#9400D3"]
    TNFa -> NFkB [color="#C71585"]
    IL6 -> PI3K_AKT [color="#FF00FF"]
    AM_M1 -> TNFa [color="#8A2BE2" penwidth=2]
    AM_M1 -> MCP1 [color="#DA70D6"]
    AM_M1 -> CXCL1_2 [color="#DDA0DD"]
    IL18 -> IFNg [color="#8B008B"]
    IFNg -> AM_M1 [color="#8B008B" label="M1 reinforce" style=bold]
    IL10 -> TNFa [color="#7CFC00" arrowhead=tee]
    IL10 -> NLRP3 [color="#7CFC00" arrowhead=tee]
    IL17 -> IL8_CXCL8 [color="#9932CC"]
    IL12 -> Th1 [color="#EE82EE"]

    // --- Cytokines → Fibrotic Signaling ---
    TGFb -> Smad2_3 [color="#FF69B4" penwidth=3]
    TGFb -> PI3K_AKT [color="#FF00FF"]
    TGFb -> MAPK_ERK [color="#DDA0DD"]
    Smad2_3 -> Smad4 [color="#FF1493"]
    Smad4 -> Collagen_I [color="#B0C4DE" penwidth=2]
    Smad4 -> Myofibroblast [color="#1E90FF" penwidth=2]
    Smad7 -> Smad2_3 [color="#DB7093" arrowhead=tee label="inhibits"]
    NFkB -> TGFb [color="#FF0000"]
    NFkB -> TNFa [color="#8A2BE2"]
    NFkB -> IL6 [color="#9400D3"]
    NFkB -> MCP1 [color="#DA70D6"]
    PDGF -> PI3K_AKT [color="#FF00FF"]
    PDGF -> MAPK_ERK [color="#DDA0DD"]
    FGF -> MAPK_ERK [color="#DDA0DD"]
    PI3K_AKT -> mTOR [color="#DA70D6"]
    mTOR -> Fibroblast [color="#4682B4"]
    MAPK_ERK -> Fibroblast [color="#4682B4"]
    Wnt_Bcatenin -> Myofibroblast [color="#1E90FF"]
    YAP_TAZ -> Fibroblast [color="#4682B4"]
    ROCK -> Myofibroblast [color="#1E90FF"]
    HIF1a -> VEGF [color="#FF7F50"]
    HIF1a -> TGFb [color="#FF0000"]

    // --- Cellular Remodeling ---
    Fibroblast -> Myofibroblast [color="#1E90FF" label="TGF-β driven" penwidth=2.5]
    AT2_Injury -> EMT [color="#00BFFF"]
    EMT -> Myofibroblast [color="#1E90FF"]
    Myofibroblast -> Collagen_I [color="#B0C4DE" penwidth=3]
    Myofibroblast -> Fibronectin [color="#C0D0E0"]
