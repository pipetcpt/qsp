digraph IC_BPS_QSP {
    graph [
        rankdir=LR,
        fontname="Helvetica",
        fontsize=11,
        label="Interstitial Cystitis / Bladder Pain Syndrome (IC/BPS) — QSP Mechanistic Map\nv1.0 · 2026-06-26 · CCR/Claude",
        labelloc=t,
        labeljust=c,
        nodesep=0.35,
        ranksep=0.7,
        splines=ortho,
        bgcolor="#FAFAFA"
    ];
    node [fontname="Helvetica", fontsize=9, style=filled, shape=box, margin="0.12,0.06"];
    edge [fontname="Helvetica", fontsize=8, color="#555555"];

    /* ===== CLUSTER 1: Triggering Factors ===== */
    subgraph cluster_triggers {
        label="Trigger Factors";
        style=filled; color="#FFF3E0"; fontsize=10; fontcolor="#E65100";

        stress   [label="Psychological\nStress", fillcolor="#FFCC80"];
        infection [label="Recurrent UTI /\nUrothelial Injury", fillcolor="#FFCC80"];
        autoimmune [label="Autoimmune\nDysregulation", fillcolor="#FFCC80"];
        genetics [label="Genetic\nSusceptibility\n(TP53, PTEN)", fillcolor="#FFCC80"];
        hormones [label="Estrogen / Androgens\n(hormonal imbalance)", fillcolor="#FFCC80"];
        trauma [label="Pelvic Trauma /\nSurgical History", fillcolor="#FFCC80"];
        microbiome [label="Bladder Microbiome\nDysbiosis", fillcolor="#FFCC80"];
        allergens [label="Food Allergens /\nEnvironmental", fillcolor="#FFCC80"];
    }

    /* ===== CLUSTER 2: Urothelial Barrier Dysfunction ===== */
    subgraph cluster_urothelium {
        label="Urothelial Barrier (Lumen → Submucosa)";
        style=filled; color="#E8F5E9"; fontsize=10; fontcolor="#1B5E20";

        GAG_layer  [label="GAG Layer\n(Glycosaminoglycans)", fillcolor="#C8E6C9", shape=ellipse];
        heparan    [label="Heparan Sulfate", fillcolor="#A5D6A7"];
        chondroitin [label="Chondroitin Sulfate", fillcolor="#A5D6A7"];
        hyaluronic [label="Hyaluronic Acid", fillcolor="#A5D6A7"];
        uroplakin  [label="Uroplakin Ia/Ib/II\n(umbrella cells)", fillcolor="#A5D6A7"];
        TJ_ZO1     [label="Tight Junctions\n(ZO-1, Claudin-4)", fillcolor="#81C784"];
        TJ_occludin [label="Occludin /\nJunctional Adhesion", fillcolor="#81C784"];
        urotelium  [label="Urothelial Cells\n(transitional epithelium)", fillcolor="#66BB6A"];
        umbrella   [label="Umbrella Cell\nLayer (facet cells)", fillcolor="#66BB6A"];
        intermediate [label="Intermediate\nUrothelial Layer", fillcolor="#66BB6A"];
        basal      [label="Basal Urothelial\nLayer", fillcolor="#43A047"];
        permeability [label="Urothelial\nPermeability↑", fillcolor="#EF9A9A", shape=diamond];
        K_leak     [label="Urinary K+\nLeak → Depolarization", fillcolor="#EF5350"];
        APF        [label="Antiproliferative\nFactor (APF)", fillcolor="#E57373"];
        EGF_def    [label="Epidermal Growth Factor↓\n(EGF deficiency)", fillcolor="#EF9A9A"];
        HB_EGF_def [label="Heparin-Binding EGF↓\n(HB-EGF deficiency)", fillcolor="#EF9A9A"];
    }

    /* ===== CLUSTER 3: Mast Cell Activation ===== */
    subgraph cluster_mast {
        label="Mast Cell Activation / Degranulation";
        style=filled; color="#F3E5F5"; fontsize=10; fontcolor="#4A148C";

        mast_cell  [label="Bladder Mast Cell\n(tryptase+, chymase+)", fillcolor="#CE93D8", shape=ellipse];
        SCF_cKit   [label="SCF / c-Kit\nSignaling", fillcolor="#BA68C8"];
        IgE_FcεRI  [label="IgE / FceRI\nCross-linking", fillcolor="#AB47BC"];
        CRH_mast   [label="CRH / Urocortin\n(stress-mast link)", fillcolor="#AB47BC"];
        tryptase   [label="Tryptase\n(PAR2 activator)", fillcolor="#9C27B0"];
        histamine  [label="Histamine\n(H1/H2/H4 receptors)", fillcolor="#7B1FA2"];
        prostaglandin [label="PGE2 / PGI2\n(COX-2 dependent)", fillcolor="#7B1FA2"];
        LTC4_LTD4  [label="Leukotriene C4/D4\n(CysLT1/2)", fillcolor="#7B1FA2"];
        SP_mast    [label="Substance P\n(NK1R on mast cells)", fillcolor="#7B1FA2"];
        heparin_mc [label="Heparin\n(anti-inflammatory)", fillcolor="#CE93D8"];
        serotonin_mc [label="Serotonin (5-HT)\nfrom mast cells", fillcolor="#AB47BC"];
        TNF_mc     [label="TNF-α\n(mast cell derived)", fillcolor="#EF5350"];
        IL4_mc     [label="IL-4\n(Th2 polarization)", fillcolor="#EF5350"];
        IL5_mc     [label="IL-5\n(eosinophil activation)", fillcolor="#EF5350"];
        chymase    [label="Chymase\n(tissue remodeling)", fillcolor="#9C27B0"];
    }

    /* ===== CLUSTER 4: Neurogenic Inflammation / Sensory Nerves ===== */
    subgraph cluster_neuro {
        label="Neurogenic Inflammation / Sensory Afferents";
        style=filled; color="#E3F2FD"; fontsize=10; fontcolor="#0D47A1";

        Cfiber     [label="C-fiber (Aδ)\nAfferents (TRPV1+)", fillcolor="#90CAF9", shape=ellipse];
        TRPV1      [label="TRPV1\n(capsaicin receptor)", fillcolor="#64B5F6"];
        TRPV4      [label="TRPV4\n(stretch sensor)", fillcolor="#64B5F6"];
        TRPA1      [label="TRPA1\n(irritant sensor)", fillcolor="#42A5F5"];
        P2X3       [label="P2X3 / P2X2/3\n(ATP receptor)", fillcolor="#42A5F5"];
        ATP_uro    [label="ATP Release\n(urothelial distension)", fillcolor="#90CAF9"];
        SP_neuro   [label="Substance P (SP)\n(antidromic release)", fillcolor="#1E88E5"];
        CGRP       [label="CGRP\n(calcitonin gene-related)", fillcolor="#1E88E5"];
        bradykinin [label="Bradykinin\n(B1/B2 receptors)", fillcolor="#1976D2"];
        NGF        [label="Nerve Growth Factor\n(TrkA sensitization)", fillcolor="#1565C0"];
        BDNF       [label="BDNF\n(central sensitization)", fillcolor="#1565C0"];
        VEGF_neuro [label="VEGF\n(neurogenic angiogenesis)", fillcolor="#0D47A1", fontcolor=white];
        neuropeptides [label="Neuropeptide Y /\nVIP / Galanin", fillcolor="#42A5F5"];
        sym_efferent [label="Sympathetic Efferents\n(norepinephrine)", fillcolor="#64B5F6"];
        para_efferent [label="Parasympathetic\n(muscarinic ACh)", fillcolor="#64B5F6"];
    }

    /* ===== CLUSTER 5: Immune Dysregulation ===== */
    subgraph cluster_immune {
        label="Immune Dysregulation (Bladder Wall)";
        style=filled; color="#FFF9C4"; fontsize=10; fontcolor="#F57F17";

        Th2_cell   [label="Th2 CD4+ T cell\n(bladder submucosa)", fillcolor="#FFF176", shape=ellipse];
        Th1_cell   [label="Th1 CD4+ T cell\n(Hunner type)", fillcolor="#FFF176"];
        Treg       [label="Regulatory T cell\n(Treg, FoxP3+)", fillcolor="#FFF176"];
        Th17_cell  [label="Th17 CD4+ T cell\n(IL-17A/F)", fillcolor="#FFF176"];
        CD8_T      [label="CD8+ Cytotoxic T\n(Hunner lesion)", fillcolor="#FFD54F"];
        macrophage [label="M1/M2 Macrophage\n(bladder wall)", fillcolor="#FFD54F"];
        eosinophil [label="Eosinophil\n(tissue)", fillcolor="#FFD54F"];
        plasma_B   [label="Plasma B Cell\n(autoantibody prod.)", fillcolor="#FFC107"];
        IL6        [label="IL-6\n(acute phase)", fillcolor="#FF8F00"];
        IL1b       [label="IL-1β\n(inflammasome)", fillcolor="#FF8F00"];
        IL17       [label="IL-17A\n(Th17 effector)", fillcolor="#FF8F00"];
        IL13       [label="IL-13\n(Th2 effector)", fillcolor="#FF8F00"];
        NLRP3      [label="NLRP3\nInflammasome", fillcolor="#F57F17", fontcolor=white];
        TLR4_imm   [label="TLR4 / MyD88\n(innate immunity)", fillcolor="#FFB300"];
        autoAb     [label="Anti-uroplakin Abs\nAnti-basal lamina Abs", fillcolor="#FF6F00", fontcolor=white];
        complement [label="C3a / C5a\n(complement activation)", fillcolor="#E65100", fontcolor=white];
        IFNg       [label="IFN-γ\n(Th1/NK effector)", fillcolor="#FF8F00"];
        MCP1       [label="MCP-1/CCL2\n(monocyte chemotaxis)", fillcolor="#FFB300"];
    }

    /* ===== CLUSTER 6: Bladder Wall Remodeling ===== */
    subgraph cluster_remodeling {
        label="Bladder Wall Remodeling / Structural Changes";
        style=filled; color="#FCE4EC"; fontsize=10; fontcolor="#880E4F";

        TGFb       [label="TGF-β1\n(fibrosis driver)", fillcolor="#F48FB1"];
        fibrosis   [label="Submucosal\nFibrosis", fillcolor="#F06292"];
        mast_dens  [label="Mast Cell\nDensity↑", fillcolor="#EC407A"];
        nerve_dens [label="Nerve Fiber\nDensity↑ (NGF driven)", fillcolor="#E91E63"];
        angiogen   [label="Pathologic\nAngiogenesis", fillcolor="#C2185B"];
        Hunner     [label="Hunner Lesion\n(Hunner subtype)", fillcolor="#AD1457", fontcolor=white];
        non_Hunner [label="Non-Hunner\n(most patients)", fillcolor="#F48FB1"];
        edema      [label="Submucosal\nEdema", fillcolor="#F06292"];
        MMP9       [label="MMP-9 / MMP-2\n(matrix remodeling)", fillcolor="#E91E63"];
        collagen   [label="Collagen I/III\nDeposition", fillcolor="#C2185B", fontcolor=white];
    }

    /* ===== CLUSTER 7: Spinal & Central Processing ===== */
    subgraph cluster_CNS {
        label="Spinal / Supraspinal Pain Processing";
        style=filled; color="#E8EAF6"; fontsize=10; fontcolor="#1A237E";

        dorsal_horn [label="Dorsal Horn\n(Lamina I/II/V)", fillcolor="#C5CAE9", shape=ellipse];
        WDR        [label="Wide Dynamic Range\nNeurons (WDR)", fillcolor="#9FA8DA"];
        NMDA_sp    [label="NMDA Receptor\n(glutamate/glycine)", fillcolor="#7986CB"];
        wind_up    [label="Wind-Up\n(temporal summation)", fillcolor="#5C6BC0"];
        central_sens [label="Central Sensitization\n(allodynia, hyperalgesia)", fillcolor="#3F51B5", fontcolor=white];
        PAG        [label="Periaqueductal Gray\n(PAG — descending)", fillcolor="#303F9F", fontcolor=white];
        DNIC       [label="DNIC\n(descending inhibition ↓)", fillcolor="#283593", fontcolor=white];
        thalamus   [label="Thalamus\n(VPL, mediodorsal)", fillcolor="#1A237E", fontcolor=white];
        ACC        [label="Anterior Cingulate\nCortex (ACC)", fillcolor="#9FA8DA"];
        insula     [label="Insula\n(interoception)", fillcolor="#9FA8DA"];
        prefrontal [label="Prefrontal Cortex\n(cognitive modulation)", fillcolor="#9FA8DA"];
        amygdala   [label="Amygdala\n(fear/anxiety)", fillcolor="#C5CAE9"];
        HPA_axis   [label="HPA Axis\n(cortisol ↑)", fillcolor="#C5CAE9"];
        serotonin_CNS [label="Spinal 5-HT\n(descending serotoninergic)", fillcolor="#7986CB"];
        NE_CNS     [label="Norepinephrine\n(descending adrenergic)", fillcolor="#7986CB"];
        opioid_CNS [label="Endogenous Opioid\nSystem (μ/κ/δ)", fillcolor="#7986CB"];
        glial_CNS  [label="Spinal Glia\n(microglia, astrocytes)", fillcolor="#9FA8DA"];
        SP_cord    [label="Spinal Substance P\n(NK1R up-regulation)", fillcolor="#5C6BC0"];
        BDNF_cord  [label="BDNF → TrkB\n(spinal LTP)", fillcolor="#5C6BC0"];
    }

    /* ===== CLUSTER 8: Clinical Outcomes ===== */
    subgraph cluster_outcomes {
        label="Clinical Outcomes / Endpoints";
        style=filled; color="#E0F7FA"; fontsize=10; fontcolor="#006064";

        OLS_pain   [label="O'Leary-Sant\nPain Score (0-20)", fillcolor="#80DEEA", shape=diamond];
        OLS_urge   [label="O'Leary-Sant\nUrgency Score (0-20)", fillcolor="#80DEEA", shape=diamond];
        VAS_pain   [label="VAS Pain\n(0-100 mm)", fillcolor="#4DD0E1", shape=diamond];
        bladder_cap [label="Functional Bladder\nCapacity (mL)", fillcolor="#26C6DA", shape=diamond];
        frequency  [label="Voiding Frequency\n(voids/24h)", fillcolor="#00BCD4", shape=diamond];
        urgency    [label="Urgency Episodes\n(/24h)", fillcolor="#00ACC1", shape=diamond];
        nocturia   [label="Nocturia\n(nocturnal voids)", fillcolor="#0097A7", shape=diamond];
        dyspareunia [label="Dyspareunia\n(pelvic pain)", fillcolor="#00838F", shape=diamond];
        QoL        [label="Quality of Life\n(IC-QoL, SF-36)", fillcolor="#006064", fontcolor=white, shape=diamond];
        UPOINT     [label="UPOINT Domain\nScore", fillcolor="#26C6DA", shape=diamond];
        pelvic_floor [label="Pelvic Floor\nDysfunction", fillcolor="#4DD0E1"];
        psychosocial [label="Depression /\nAnxiety (PHQ-9)", fillcolor="#80DEEA", shape=diamond];
        sexual_function [label="Sexual Function\n(FSFI/IIEF)", fillcolor="#80DEEA", shape=diamond];
    }

    /* ===== CLUSTER 9: Drug PK/PD ===== */
    subgraph cluster_drugs {
        label="Pharmacotherapy — PK/PD";
        style=filled; color="#ECEFF1"; fontsize=10; fontcolor="#263238";

        /* PPS */
        PPS_gut    [label="PPS GI\n(pentosan polysulfate)", fillcolor="#B0BEC5"];
        PPS_plasma [label="PPS Plasma\n(low bioavail. ~6%)", fillcolor="#90A4AE"];
        PPS_urine  [label="PPS Urine\n(GAG-replenishing)", fillcolor="#78909C"];
        PPS_effect [label="GAG Layer\nRestoration (PPS)", fillcolor="#546E7A", fontcolor=white];

        /* Intravesical Treatments */
        DMSO_dose  [label="Intravesical DMSO\n(50% 50mL q2wk)", fillcolor="#CFD8DC"];
        DMSO_effect [label="DMSO: Anti-inflam\nMast cell stabilization", fillcolor="#90A4AE"];
        heparin_iv [label="Intravesical Heparin\n(10,000 IU/instill)", fillcolor="#CFD8DC"];
        heparin_effect [label="Heparin: GAG mimic\nAnti-inflammatory", fillcolor="#90A4AE"];
        lidocaine_iv [label="Intravesical Lidocaine\n(200mg alkalinized)", fillcolor="#CFD8DC"];
        BCG_iv     [label="Intravesical BCG\n(immunomodulation)", fillcolor="#CFD8DC"];

        /* Oral medications */
        HYD_gut    [label="Hydroxyzine GI\n(H1 antihistamine)", fillcolor="#B0BEC5"];
        HYD_plasma [label="Hydroxyzine\nPlasma", fillcolor="#90A4AE"];
        HYD_effect [label="Hydroxyzine:\nMast cell↓ H1↓", fillcolor="#78909C"];

        AMI_gut    [label="Amitriptyline GI\n(TCA, 25-75mg QD)", fillcolor="#B0BEC5"];
        AMI_plasma [label="Amitriptyline\nPlasma", fillcolor="#90A4AE"];
        AMI_effect [label="Amitriptyline:\nH1↓ mACh↓ pain↓", fillcolor="#78909C"];

        CsA_gut    [label="Cyclosporin A GI\n(3mg/kg/day)", fillcolor="#B0BEC5"];
        CsA_plasma [label="CsA Plasma\n(calcineurin inhibitor)", fillcolor="#90A4AE"];
        CsA_effect [label="CsA: T cell↓\n(Hunner type)", fillcolor="#78909C"];

        BoNTA_bld  [label="BoNTA Bladder\n(100-200U intravesical)", fillcolor="#CFD8DC"];
        BoNTA_effect [label="BoNTA: SP↓ CGRP↓\nSNAP-25 cleavage", fillcolor="#90A4AE"];

        Elmi_gut   [label="Elmiron (PPS)\n100mg TID oral", fillcolor="#B0BEC5"];
        SNM        [label="Sacral Neuromod.\n(InterStim, S3)", fillcolor="#CFD8DC"];
        SNM_effect [label="SNM: Afferent\nmodulation ↓ pain", fillcolor="#90A4AE"];
        PTNs       [label="Percutaneous Tibial\nNerve Stimulation", fillcolor="#CFD8DC"];

        /* Novel/Investigational */
        anti_NGF   [label="Anti-NGF Ab\n(tanezumab — invest.)", fillcolor="#ECEFF1"];
        JAK_inh    [label="JAK Inhibitor\n(baricitinib — invest.)", fillcolor="#ECEFF1"];
        TRPV1_ant  [label="TRPV1 Antagonist\n(invest.)", fillcolor="#ECEFF1"];
        P2X3_ant   [label="P2X3 Antagonist\n(gefapixant — invest.)", fillcolor="#ECEFF1"];
        suvorex    [label="Suvorexant\n(orexin antagonist)", fillcolor="#ECEFF1"];
    }

    /* ===== EDGES: Trigger → Urothelial barrier ===== */
    stress -> mast_cell [label="CRH/SP release"];
    infection -> GAG_layer [label="GAG depletion", color=red];
    autoimmune -> autoAb [label="Ab production"];
    genetics -> APF [label="overexpression"];
    hormones -> GAG_layer [label="estrogen protects"];
    trauma -> permeability [label="direct injury", color=red];
    microbiome -> TLR4_imm [label="LPS/PAMP"];
    allergens -> IgE_FcεRI [label="IgE sensitization"];

    /* Urothelial architecture */
    GAG_layer -> heparan;
    GAG_layer -> chondroitin;
    GAG_layer -> hyaluronic;
    uroplakin -> umbrella;
    umbrella -> TJ_ZO1;
    TJ_ZO1 -> TJ_occludin;
    TJ_occludin -> intermediate;
    intermediate -> basal;

    /* Barrier breach */
    GAG_layer -> permeability [label="GAG↓ → perm↑", color=red, dir=back];
    TJ_ZO1 -> permeability [label="TJ disruption", color=red, dir=back];
    APF -> EGF_def [label="inhibits"];
    APF -> HB_EGF_def;
    EGF_def -> GAG_layer [label="↓ GAG synthesis", color=red];
    permeability -> K_leak [label="potassium leak"];

    /* K leak triggers */
    K_leak -> Cfiber [label="depolarization", color=red];
    K_leak -> mast_cell [label="activation", color=red];

    /* Mast cell signaling */
    IgE_FcεRI -> mast_cell [label="degranulation trigger"];
    SCF_cKit -> mast_cell [label="survival/proliferation"];
    CRH_mast -> mast_cell [label="stress activation"];
    SP_neuro -> SP_mast;
    mast_cell -> tryptase;
    mast_cell -> histamine;
    mast_cell -> prostaglandin;
    mast_cell -> LTC4_LTD4;
    mast_cell -> TNF_mc;
    mast_cell -> IL4_mc;
    mast_cell -> IL5_mc;
    mast_cell -> serotonin_mc;
    mast_cell -> heparin_mc;
    tryptase -> permeability [label="PAR2 → barrier↓", color=red];
    tryptase -> Cfiber [label="PAR2 sensitization", color=red];
    histamine -> Cfiber [label="H1 sensitization"];
    prostaglandin -> Cfiber [label="EP1/EP3 sensitization"];
    TNF_mc -> IL6;
    IL4_mc -> Th2_cell;
    IL5_mc -> eosinophil;

    /* C-fiber / TRPV signaling */
    Cfiber -> TRPV1;
    Cfiber -> TRPV4;
    Cfiber -> TRPA1;
    Cfiber -> P2X3;
    ATP_uro -> P2X3 [label="distension-evoked"];
    TRPV1 -> SP_neuro [label="antidromic release"];
    TRPV1 -> CGRP [label="antidromic release"];
    SP_neuro -> NK1R [label="NK1R agonist"];
    CGRP -> angiogen [label="vasodilation"];
    bradykinin -> TRPV1 [label="sensitization"];
    bradykinin -> Cfiber;
    NGF -> TRPV1 [label="TrkA→TRPV1↑"];
    NGF -> Cfiber [label="sprouting"];
    BDNF -> central_sens [label="TrkB"];
    SP_neuro -> mast_cell [label="NK1R activation"];
    neuropeptides -> sym_efferent;
    sym_efferent -> mast_cell [label="β-adrenergic modulation"];

    /* Immune dysregulation */
    TLR4_imm -> NLRP3 [label="priming"];
    NLRP3 -> IL1b [label="cleavage"];
    IL1b -> IL6 [label="amplification"];
    IL6 -> Th2_cell [label="Th2 skewing"];
    Th2_cell -> IL4_mc;
    Th2_cell -> IL13;
    Th1_cell -> IFNg;
    IFNg -> macrophage [label="M1 polarization"];
    macrophage -> MCP1;
    macrophage -> TNF_mc;
    Th17_cell -> IL17;
    IL17 -> MMP9 [label="→ matrix loss"];
    CD8_T -> Hunner [label="tissue destruction"];
    plasma_B -> autoAb;
    autoAb -> complement [label="C1q binding"];
    complement -> permeability [label="MAC attack", color=red];
    Treg -> Th17_cell [label="regulatory ↓", style=dashed];

    /* NK1R node */
    NK1R [label="NK1R\n(tachykinin receptor 1)", fillcolor="#E3F2FD"];
    NK1R -> mast_cell [label="degranulation"];
    NK1R -> Cfiber [label="sensitization"];

    /* Remodeling */
    TGFb -> fibrosis;
    TGFb -> collagen;
    IL13 -> TGFb [label="activation"];
    MMP9 -> collagen [label="paradoxical remod."];
    fibrosis -> bladder_cap [label="↓ capacity", color=red];
    nerve_dens -> Cfiber [label="amplification"];
    NGF -> nerve_dens;
    angiogen -> edema;
    edema -> permeability [label="pressure", color=red];
    Hunner -> nerve_dens [label="Hunner→dense innervation"];
    Hunner -> mast_dens;
    non_Hunner -> mast_dens [label="widespread mast cells"];
    mast_dens -> mast_cell [label="↑ pool size"];
    chymase -> MMP9;

    /* Spinal processing */
    Cfiber -> dorsal_horn [label="Aδ/C afferent input"];
    dorsal_horn -> WDR;
    WDR -> NMDA_sp [label="glutamate release"];
    NMDA_sp -> wind_up [label="Mg2+ unblock"];
    wind_up -> central_sens;
    SP_cord -> NMDA_sp [label="coactivation"];
    BDNF_cord -> NMDA_sp [label="phosphorylation"];
    glial_CNS -> SP_cord [label="glia→SP release"];
    glial_CNS -> BDNF_cord;
    central_sens -> PAG [label="descending control↓"];
    PAG -> DNIC [label="inhibitory →↓"];
    DNIC -> dorsal_horn [label="descending inhibition↓", color=red, style=dashed];
    central_sens -> thalamus;
    thalamus -> ACC;
    thalamus -> insula;
    ACC -> prefrontal;
    insula -> psychosocial [label="pain unpleasantness"];
    amygdala -> HPA_axis [label="fear/stress"];
    HPA_axis -> stress [label="cortisol → sensitizes", style=dashed];
    NE_CNS -> dorsal_horn [label="descending NE ↓ pain", style=dashed];
    serotonin_CNS -> dorsal_horn [label="descending 5-HT", style=dashed];
    opioid_CNS -> dorsal_horn [label="μ-opioid inhibit"];

    /* Symptom generation */
    central_sens -> OLS_pain;
    central_sens -> VAS_pain;
    central_sens -> dyspareunia;
    bladder_cap -> frequency [label="↓ cap → ↑ freq", color=red];
    bladder_cap -> OLS_urge;
    Cfiber -> urgency [label="afferent signals"];
    urgency -> frequency;
    urgency -> OLS_urge;
    frequency -> nocturia;
    VAS_pain -> QoL [label="impact"];
    OLS_pain -> UPOINT;
    OLS_urge -> UPOINT;
    pelvic_floor -> dyspareunia;
    psychosocial -> QoL;
    sexual_function -> QoL;

    /* PK/PD drug edges */
    Elmi_gut -> PPS_gut;
    PPS_gut -> PPS_plasma [label="~6% bioavail"];
    PPS_plasma -> PPS_urine [label="renal excretion"];
    PPS_urine -> PPS_effect [label="urine concentration"];
    PPS_effect -> GAG_layer [label="GAG replenishment", color="#2E7D32"];
    PPS_effect -> permeability [label="↓ permeability", color="#2E7D32"];

    DMSO_dose -> DMSO_effect;
    DMSO_effect -> mast_cell [label="stabilization ↓", color="#2E7D32"];
    DMSO_effect -> TNF_mc [label="↓ TNF", color="#2E7D32"];
    DMSO_effect -> prostaglandin [label="↓ PG synthesis", color="#2E7D32"];

    heparin_iv -> heparin_effect;
    heparin_effect -> GAG_layer [label="heparin mimics GAG", color="#2E7D32"];
    heparin_effect -> permeability [color="#2E7D32"];

    lidocaine_iv -> Cfiber [label="Na+ channel block", color="#2E7D32"];

    HYD_gut -> HYD_plasma [label="oral absorption"];
    HYD_plasma -> HYD_effect;
    HYD_effect -> histamine [label="H1 block", color="#2E7D32"];
    HYD_effect -> mast_cell [label="stabilization", color="#2E7D32"];

    AMI_gut -> AMI_plasma;
    AMI_plasma -> AMI_effect;
    AMI_effect -> histamine [label="H1 block", color="#2E7D32"];
    AMI_effect -> serotonin_CNS [label="5-HT reuptake↓", color="#2E7D32"];
    AMI_effect -> NE_CNS [label="NE reuptake↓", color="#2E7D32"];
