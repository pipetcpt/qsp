digraph HH_QSP_Model {
    graph [
        label="Hereditary Hemochromatosis (HH) — QSP Mechanistic Map\nHFE Gene Mutation → Iron Overload → Multi-Organ Damage",
        labelloc=t, fontsize=22, fontname="Arial",
        bgcolor="#FAFAFA", rankdir=TB,
        splines=true, nodesep=0.35, ranksep=0.55,
        pad=0.5
    ]
    node [fontname="Arial", fontsize=10, style=filled, shape=box, margin="0.12,0.06"]
    edge [fontname="Arial", fontsize=8]

    /* ================================================================
       CLUSTER 1: GENETIC & MOLECULAR BASIS
    ================================================================ */
    subgraph cluster_genetics {
        label="① Genetic & Molecular Drivers"
        style=filled; fillcolor="#FFF3E0"; color="#E65100"; fontcolor="#BF360C"; fontsize=13

        HFE_gene     [label="HFE Gene\n(chr 6p21.3)", fillcolor="#FF8F00", fontcolor=white]
        C282Y        [label="C282Y Mutation\n(p.Cys282Tyr)", fillcolor="#FF6F00", fontcolor=white]
        H63D         [label="H63D Mutation\n(p.His63Asp)", fillcolor="#FFA726"]
        S65C         [label="S65C Mutation\n(rare)", fillcolor="#FFB74D"]
        HFE_TfR1     [label="HFE–TfR1\nComplex", fillcolor="#FFE0B2"]
        HFE_TfR2     [label="HFE–TfR2\nComplex (normal)", fillcolor="#FFE0B2"]
        BMP_co_recep [label="HJV (Hemojuvelin)\nBMP Co-Receptor", fillcolor="#FFD54F"]
        TMPRSS6      [label="TMPRSS6\n(Matriptase-2)", fillcolor="#FFCC02"]
        homozygous   [label="Homozygous C282Y\n(~85% Type 1 HH)", fillcolor="#FF6F00", fontcolor=white]
        compound_het [label="Compound Het\nC282Y/H63D (~4%)", fillcolor="#FFA726"]
        penetrance   [label="Variable Penetrance\n(15–50% biochemical)", fillcolor="#FFF9C4"]
        HH_type2     [label="Juvenile HH\n(HJV/HAMP mut)", fillcolor="#FFAB40"]
        HH_type3     [label="Type 3 HH\n(TfR2 mut)", fillcolor="#FFAB40"]
        HH_type4     [label="Type 4 HH\n(SLC40A1/FPN)", fillcolor="#FFAB40"]

        HFE_gene -> C282Y [label="mutation"]
        HFE_gene -> H63D  [label="mutation"]
        HFE_gene -> S65C  [label="mutation"]
        C282Y -> homozygous [label="homozygous"]
        C282Y -> compound_het [label="+ H63D"]
        homozygous -> HFE_TfR1 [label="lost binding"]
        HFE_TfR1 -> HFE_TfR2 [label="→ BMP sensing"]
        HFE_TfR2 -> BMP_co_recep [label="activates"]
        TMPRSS6 -> BMP_co_recep [label="cleaves HJV ↓"]
        penetrance -> compound_het
        HFE_gene -> HH_type2 [style=dashed, label="other genes"]
        HFE_gene -> HH_type3 [style=dashed]
        HFE_gene -> HH_type4 [style=dashed]
    }

    /* ================================================================
       CLUSTER 2: HEPCIDIN REGULATION PATHWAY
    ================================================================ */
    subgraph cluster_hepcidin {
        label="② Hepcidin Regulatory Pathway (BMP-SMAD)"
        style=filled; fillcolor="#E8F5E9"; color="#1B5E20"; fontcolor="#1B5E20"; fontsize=13

        HAMP_gene    [label="HAMP Gene\n(Hepcidin Antimicrobial Peptide)", fillcolor="#43A047", fontcolor=white]
        hepcidin_mrna[label="Hepcidin mRNA\n(Hepatocyte)", fillcolor="#66BB6A", fontcolor=white]
        hepcidin_pro [label="Prohepcidin\n(84 aa)", fillcolor="#81C784"]
        hepcidin_25  [label="Mature Hepcidin-25\n(active form, ng/mL)", fillcolor="#4CAF50", fontcolor=white]
        BMP2         [label="BMP2/4/6/9\n(Iron Sensors)", fillcolor="#A5D6A7"]
        BMPR1        [label="BMPR-I\n(ALK2/ALK3)", fillcolor="#C8E6C9"]
        BMPR2        [label="BMPR-II", fillcolor="#C8E6C9"]
        SMAD1_5      [label="SMAD1/5/8\nPhosphorylation", fillcolor="#80CBC4"]
        SMAD4        [label="SMAD4\nCo-activator", fillcolor="#80CBC4"]
        SMAD_complex [label="SMAD1/5/8 – SMAD4\nNuclear Complex", fillcolor="#4DB6AC"]
        IL6_STAT3    [label="IL-6 → STAT3\n(Inflammation signal)", fillcolor="#FFC107"]
        EPO_ERFE     [label="Erythropoietin →\nErythroferrone (ERFE)", fillcolor="#EF9A9A"]
        ERFE_suppress[label="ERFE Suppresses\nHepcidin (BMP inhibition)", fillcolor="#EF9A9A"]
        hepcidin_urine[label="Urinary Hepcidin\n(excretion)", fillcolor="#DCEDC8"]
        hepcidin_low [label="↓ Hepcidin in HH\n(relative deficiency)", fillcolor="#E53935", fontcolor=white]

        BMP2 -> BMPR1 [label="binds"]
        BMPR1 -> SMAD1_5 [label="phosphorylates"]
        BMPR2 -> SMAD1_5
        SMAD1_5 -> SMAD_complex [label="+ SMAD4"]
        SMAD_complex -> HAMP_gene [label="transcription ↑"]
        HAMP_gene -> hepcidin_mrna
        hepcidin_mrna -> hepcidin_pro [label="translation"]
        hepcidin_pro -> hepcidin_25 [label="furin cleavage"]
        IL6_STAT3 -> HAMP_gene [label="acute phase ↑"]
        EPO_ERFE -> ERFE_suppress [label="erythroid demand"]
        hepcidin_25 -> hepcidin_urine [label="renal excretion"]
        hepcidin_25 -> hepcidin_low [label="mutant HFE → loss"]
    }

    /* ================================================================
       CLUSTER 3: IRON ABSORPTION & TRANSPORT
    ================================================================ */
    subgraph cluster_iron_absorption {
        label="③ Iron Absorption & Transport"
        style=filled; fillcolor="#E3F2FD"; color="#0D47A1"; fontcolor="#0D47A1"; fontsize=13

        dietary_Fe   [label="Dietary Iron\n(10–20 mg/day)", fillcolor="#1565C0", fontcolor=white]
        heme_Fe      [label="Heme Iron\n(HCP1/SLC46A1)", fillcolor="#1976D2", fontcolor=white]
        nonheme_Fe3  [label="Non-Heme Fe³⁺", fillcolor="#1976D2", fontcolor=white]
        DCYTB        [label="Duodenal Cytochrome B\n(Fe³⁺ → Fe²⁺)", fillcolor="#2196F3"]
        nonheme_Fe2  [label="Non-Heme Fe²⁺\n(reduced)", fillcolor="#42A5F5"]
        DMT1         [label="DMT1 (SLC11A2)\nApical Enterocyte\nTransporter", fillcolor="#1E88E5", fontcolor=white]
        enterocyte   [label="Duodenal Enterocyte\nIron Pool", fillcolor="#90CAF9"]
        ferroportin  [label="Ferroportin (FPN1)\nSLC40A1\nBasolateral Export", fillcolor="#0D47A1", fontcolor=white]
        hephaestin   [label="Hephaestin\n(Fe²⁺ → Fe³⁺)", fillcolor="#64B5F6"]
        hepcidin_fpn [label="Hepcidin-FPN\nDegradation Signal", fillcolor="#E53935", fontcolor=white]
        transferrin  [label="Transferrin (Tf)\nBlood Transport\n(2 Fe³⁺ sites)", fillcolor="#1565C0", fontcolor=white]
        TfR1_cell    [label="TfR1 (Cellular Uptake)\nEndocytosis", fillcolor="#1976D2", fontcolor=white]
        NTBI         [label="Non-Transferrin\nBound Iron (NTBI)\n(toxic, elevated in HH)", fillcolor="#B71C1C", fontcolor=white]
        LPI          [label="Labile Plasma Iron (LPI)\n(NTBI subset, redox-active)", fillcolor="#C62828", fontcolor=white]
        serum_iron   [label="Serum Iron\n(μg/dL, nmol/L)", fillcolor="#42A5F5"]
        TSAT         [label="Transferrin Saturation\n(TS %, normal <45%)", fillcolor="#29B6F6"]
        plasma_Tf    [label="Total Iron Binding\nCapacity (TIBC)", fillcolor="#81D4FA"]
        UIBC         [label="Unsaturated IBC\n(UIBC = TIBC − Serum Fe)", fillcolor="#B3E5FC"]

        dietary_Fe -> heme_Fe
        dietary_Fe -> nonheme_Fe3
        nonheme_Fe3 -> DCYTB [label="reduction"]
        DCYTB -> nonheme_Fe2
        nonheme_Fe2 -> DMT1 [label="import"]
        heme_Fe -> enterocyte [label="HCP1"]
        DMT1 -> enterocyte
        enterocyte -> ferroportin [label="export ↑ in HH"]
        hepcidin_fpn -> ferroportin [label="degrades ↓"]
        ferroportin -> hephaestin [label="oxidation"]
        hephaestin -> transferrin [label="Fe³⁺ loading"]
        transferrin -> serum_iron
        transferrin -> TSAT [label="(Fe/Tf capacity)×100"]
        transferrin -> plasma_Tf [label="TIBC"]
        plasma_Tf -> UIBC
        serum_iron -> NTBI [label="Tf saturation >75%\n→ NTBI spills"]
        NTBI -> LPI [label="labile fraction"]
        transferrin -> TfR1_cell [label="receptor-mediated"]
    }

    /* ================================================================
       CLUSTER 4: CELLULAR IRON STORAGE & HOMEOSTASIS
    ================================================================ */
    subgraph cluster_storage {
        label="④ Cellular Iron Storage & Homeostasis"
        style=filled; fillcolor="#F3E5F5"; color="#4A148C"; fontcolor="#4A148C"; fontsize=13

        ferritin_H   [label="Ferritin H-chain\n(ferroxidase activity)", fillcolor="#7B1FA2", fontcolor=white]
        ferritin_L   [label="Ferritin L-chain\n(nucleation)", fillcolor="#8E24AA", fontcolor=white]
        ferritin_core[label="Ferritin Nanocage\n(up to 4500 Fe atoms)", fillcolor="#9C27B0", fontcolor=white]
        serum_ferritin[label="Serum Ferritin\n(ng/mL)\n[Biomarker]", fillcolor="#AB47BC"]
        hemosiderin  [label="Hemosiderin\n(degraded ferritin\naggregate)", fillcolor="#CE93D8"]
        IRP1         [label="IRP1\n(cytosolic aconitase)", fillcolor="#BA68C8"]
        IRP2         [label="IRP2\n(ubiquitin-mediated\ndeg at high Fe)", fillcolor="#BA68C8"]
        IRE_ferritin [label="IRE in Ferritin mRNA\n(5' UTR)\n(IRP binding → ↓ translation)", fillcolor="#E1BEE7"]
        IRE_TfR      [label="IRE in TfR1 mRNA\n(3' UTR)\n(IRP binding → ↑ stability)", fillcolor="#E1BEE7"]
        LIP          [label="Labile Iron Pool (LIP)\nCytosol (Fe²⁺)\n(chelatable, redox-active)", fillcolor="#C62828", fontcolor=white]
        PCBP1        [label="PCBP1/2\nIron Chaperones", fillcolor="#D7CCC8"]
        mitoferrin   [label="Mitoferrin\n(SLC25A37/A28)\nMitochondrial Import", fillcolor="#795548", fontcolor=white]
        mito_Fe      [label="Mitochondrial Iron\n(heme/Fe-S synthesis)", fillcolor="#6D4C41", fontcolor=white]
        FTH_export   [label="Lysosomal FTH Release\n(ferritinophagy)", fillcolor="#BCAAA4"]

        ferritin_H -> ferritin_core [label="assembles"]
        ferritin_L -> ferritin_core
        ferritin_core -> serum_ferritin [label="released to plasma"]
        ferritin_core -> hemosiderin [label="degradation"]
        LIP -> IRP1 [label="high Fe → oxidizes\nIRP1 4Fe-4S cluster"]
        LIP -> IRP2 [label="high Fe → degrades"]
        IRP1 -> IRE_ferritin [label="low Fe → binds"]
        IRP1 -> IRE_TfR [label="low Fe → stabilizes"]
        IRE_ferritin -> ferritin_H [label="regulates\ntranslation"]
        IRE_TfR -> TfR1_cell [label="regulates\nmRNA stability"]
        LIP -> mitoferrin [label="Fe²⁺ transport"]
        mitoferrin -> mito_Fe
        LIP -> PCBP1 [label="chaperones"]
        PCBP1 -> ferritin_core [label="delivery"]
        ferritin_core -> FTH_export [label="ferritinophagy"]
        FTH_export -> LIP [label="iron recycling"]
        NTBI -> LIP [label="NTBI uptake\n(ZIP8/ZIP14)"]
    }

    /* ================================================================
       CLUSTER 5: ERYTHROPOIESIS & IRON RECYCLING
    ================================================================ */
    subgraph cluster_erythro {
        label="⑤ Erythropoiesis & Iron Recycling (RES)"
        style=filled; fillcolor="#FFF8E1"; color="#F57F17"; fontcolor="#F57F17"; fontsize=13

        EPO_kidney   [label="Erythropoietin (EPO)\nKidney (hypoxia-driven)", fillcolor="#FF8F00", fontcolor=white]
        BFU_E        [label="BFU-E\n(Burst-Forming Unit)", fillcolor="#FFB300"]
        CFU_E        [label="CFU-E\n(Colony-Forming Unit)", fillcolor="#FFC107"]
        erythroblast [label="Erythroblast\n(reticulocyte precursor)", fillcolor="#FFD54F"]
        reticulocyte [label="Reticulocyte\nRBC precursor", fillcolor="#FFE082"]
        mature_RBC   [label="Mature RBC\n(Hemoglobin 280 mg)\n120-day lifespan", fillcolor="#FFB300"]
        hemoglobin   [label="Hemoglobin\n(Hb, g/dL)", fillcolor="#FF6F00", fontcolor=white]
        heme_synth   [label="Heme Synthesis\n(ALA → Heme)\nMitochondria", fillcolor="#EF6C00"]
        globin_chain [label="α/β Globin Chains\n(Hb tetramer)", fillcolor="#F57C00"]
        senescent_RBC[label="Senescent RBC\n(eryptosis signals)", fillcolor="#FFCCBC"]
        macrophage_RE[label="RES Macrophage\n(spleen/liver Kupffer)\nErythrophagocytosis", fillcolor="#BF360C", fontcolor=white]
        recycled_Fe  [label="Recycled Iron\n(25–30 mg/day)", fillcolor="#E64A19", fontcolor=white]
        FPN_macro    [label="Macrophage Ferroportin\n(iron export to plasma)", fillcolor="#FF7043"]
        erfe_prod    [label="Erythroferrone (ERFE)\nProduced by Erythroblasts", fillcolor="#FFAB40"]

        EPO_kidney -> BFU_E [label="proliferation"]
        BFU_E -> CFU_E
        CFU_E -> erythroblast [label="differentiation"]
        erythroblast -> reticulocyte
        reticulocyte -> mature_RBC
        mito_Fe -> heme_synth [label="Fe²⁺ substrate"]
        heme_synth -> hemoglobin [label="heme + globin"]
        globin_chain -> hemoglobin
        hemoglobin -> mature_RBC [label="Hb 32 pg/cell"]
        mature_RBC -> senescent_RBC [label="120 days"]
        senescent_RBC -> macrophage_RE [label="phagocytosis"]
        macrophage_RE -> recycled_Fe [label="Fe recovery"]
        recycled_Fe -> FPN_macro [label="export"]
        FPN_macro -> transferrin [label="Fe³⁺ loading"]
        erythroblast -> erfe_prod [label="high EPO"]
        erfe_prod -> ERFE_suppress [label="ERFE signal"]
        hepcidin_25 -> FPN_macro [label="inhibits export"]
    }

    /* ================================================================
       CLUSTER 6: LIVER IRON LOADING & DAMAGE
    ================================================================ */
    subgraph cluster_liver {
        label="⑥ Liver Iron Loading & Damage"
        style=filled; fillcolor="#FFEBEE"; color="#B71C1C"; fontcolor="#B71C1C"; fontsize=13

        hepatocyte   [label="Hepatocyte Iron Uptake\n(TfR1, TfR2, ZIP14)", fillcolor="#C62828", fontcolor=white]
        LIC          [label="Liver Iron Concentration\n(LIC, mg Fe/g dry wt)\n[Key Biomarker]", fillcolor="#D32F2F", fontcolor=white]
        liver_ferritin[label="Hepatic Ferritin\nStorage", fillcolor="#EF5350"]
        ROS_liver    [label="ROS / Oxidative Stress\n(Fenton reaction: Fe²⁺+H₂O₂→•OH)", fillcolor="#B71C1C", fontcolor=white]
        lipid_perox  [label="Lipid Peroxidation\n(4-HNE, MDA)", fillcolor="#C62828", fontcolor=white]
        HSC_act      [label="Hepatic Stellate Cell\nActivation (TGF-β1)", fillcolor="#E53935"]
        liver_fibrosis[label="Liver Fibrosis\n(collagen I/III, Metavir)", fillcolor="#EF5350"]
        liver_cirrhosis_hh[label="Cirrhosis\n(irreversible)", fillcolor="#B71C1C", fontcolor=white]
        HCC_risk     [label="HCC Risk ↑\n(30× vs general pop)", fillcolor="#880E4F", fontcolor=white]
        ALT          [label="Serum ALT\n(liver injury marker)", fillcolor="#FFCDD2"]
        AST          [label="Serum AST", fillcolor="#FFCDD2"]
        GGT_hh       [label="GGT (γ-GT)\n(biliary marker)", fillcolor="#FFCDD2"]
        ferritin_liver[label="Hepatic Ferritin\nEnzyme Activity", fillcolor="#EF9A9A"]
        TfR2_liver   [label="Hepatic TfR2\n(iron sensor)", fillcolor="#EF9A9A"]
        MRI_LIC      [label="MRI R2/R2*\n(LIC non-invasive)", fillcolor="#FFCDD2"]

        NTBI -> hepatocyte [label="ZIP14 uptake\n(high NTBI → ↑)"]
        LPI -> hepatocyte [label="redox-active"]
        TfR1_cell -> hepatocyte [label="Tf-bound iron"]
        TfR2_liver -> hepatocyte [label="iron sensing"]
        hepatocyte -> LIC [label="iron accumulation"]
        LIC -> liver_ferritin [label="storage"]
        liver_ferritin -> serum_ferritin [label="leakage"]
        LIC -> ROS_liver [label="Fenton reaction"]
        ROS_liver -> lipid_perox [label="peroxidation"]
        lipid_perox -> HSC_act [label="paracrine TGF-β1"]
        ROS_liver -> HSC_act [label="direct activation"]
        HSC_act -> liver_fibrosis [label="collagen synthesis"]
        liver_fibrosis -> liver_cirrhosis_hh [label="advanced (F4)"]
        liver_cirrhosis_hh -> HCC_risk [label="major risk"]
        ROS_liver -> ALT [label="hepatocyte damage"]
        ALT -> AST
        LIC -> MRI_LIC [label="R2* ∝ LIC"]
        liver_ferritin -> ferritin_liver
    }

    /* ================================================================
       CLUSTER 7: EXTRA-HEPATIC ORGAN DAMAGE
    ================================================================ */
    subgraph cluster_extrahepatic {
        label="⑦ Extra-Hepatic Iron Deposition & Organ Damage"
        style=filled; fillcolor="#E8EAF6"; color="#1A237E"; fontcolor="#1A237E"; fontsize=13

        /* Heart */
        cardiac_Fe   [label="Cardiac Iron Loading\n(NTBI, ZIP14)", fillcolor="#283593", fontcolor=white]
        cardiac_T2star[label="Cardiac T2* MRI\n(ms)\n[<20ms = overload]", fillcolor="#3949AB", fontcolor=white]
        cardiomyopathy[label="Restrictive/Dilated\nCardiomyopathy", fillcolor="#3F51B5", fontcolor=white]
        arrhythmia   [label="Arrhythmia\n(QTc prolongation)", fillcolor="#5C6BC0"]
        EF_decline   [label="↓ Ejection Fraction\n(<50%)", fillcolor="#7986CB"]

        /* Pancreas */
        pancreas_Fe  [label="Pancreatic Iron\nDeposition (exocrine + β-cell)", fillcolor="#4527A0", fontcolor=white]
        beta_cell_dam[label="β-Cell Oxidative\nDamage", fillcolor="#512DA8", fontcolor=white]
        insulin_def  [label="↓ Insulin Secretion\n(bronze diabetes)", fillcolor="#673AB7", fontcolor=white]
        HbA1c_hh     [label="HbA1c\n(diabetes biomarker)", fillcolor="#9575CD"]

        /* Joints */
        joint_Fe     [label="Synovial Iron\nDeposition", fillcolor="#6A1B9A", fontcolor=white]
        chondrocalc  [label="Chondrocalcinosis\n(CPPD crystal deposition)", fillcolor="#7B1FA2", fontcolor=white]
        arthropathy  [label="HH Arthropathy\n(2nd/3rd MCP joints)", fillcolor="#8E24AA", fontcolor=white]

        /* Pituitary/Gonads */
        pituitary_Fe [label="Anterior Pituitary\nIron Deposition", fillcolor="#AD1457", fontcolor=white]
        hypogonadism [label="Hypogonadotropic\nHypogonadism\n(↓LH/FSH)", fillcolor="#C2185B", fontcolor=white]
        amenorrhea   [label="Amenorrhea\n(women)", fillcolor="#E91E63"]
        testicular_atrophy[label="Testicular Atrophy\n(men)", fillcolor="#E91E63"]

        /* Skin */
        skin_Fe      [label="Skin Melanocyte\n+ Dermal Iron", fillcolor="#78909C"]
        bronze_skin  [label="Bronze Skin\nDiscoloration", fillcolor="#6D4C41", fontcolor=white]

        NTBI -> cardiac_Fe [label="ZIP14 uptake"]
        cardiac_Fe -> cardiac_T2star [label="MRI signal"]
        cardiac_Fe -> cardiomyopathy [label="ROS damage"]
        cardiomyopathy -> EF_decline
        cardiac_Fe -> arrhythmia [label="conduction abnorm"]

        NTBI -> pancreas_Fe [label="NTBI uptake"]
        pancreas_Fe -> beta_cell_dam [label="oxidative stress"]
        beta_cell_dam -> insulin_def
        insulin_def -> HbA1c_hh [label="hyperglycemia"]

        NTBI -> joint_Fe [label="synovial uptake"]
        joint_Fe -> chondrocalc [label="crystal nucleation"]
        chondrocalc -> arthropathy

        NTBI -> pituitary_Fe [label="NTBI uptake"]
        pituitary_Fe -> hypogonadism [label="gonadotrope damage"]
        hypogonadism -> amenorrhea
        hypogonadism -> testicular_atrophy

        NTBI -> skin_Fe [label="melanin interaction"]
        skin_Fe -> bronze_skin [label="pigmentation"]
    }

    /* ================================================================
       CLUSTER 8: IRON CHELATION THERAPY PK/PD
    ================================================================ */
    subgraph cluster_chelation {
        label="⑧ Iron Chelation Therapy — PK/PD"
        style=filled; fillcolor="#E0F7FA"; color="#006064"; fontcolor="#006064"; fontsize=13

        /* Deferoxamine (DFO) */
        DFO_dose     [label="Deferoxamine (DFO)\n40–50 mg/kg/day SC/IV\n(Desferal®)", fillcolor="#00838F", fontcolor=white]
        DFO_C        [label="DFO Plasma\nConcentration", fillcolor="#00ACC1"]
        DFO_dist     [label="DFO Distribution\n(Vd ~0.8 L/kg)", fillcolor="#26C6DA"]
        DFO_Fe_complex[label="DFO–Fe Ferrioxamine\n(urine/feces excretion)", fillcolor="#00BCD4"]
        DFO_PD       [label="DFO Efficacy:\n↓ Urinary Fe ↑\n(reflects LIP chelation)", fillcolor="#80DEEA"]

        /* Deferasirox (DFX) */
        DFX_dose     [label="Deferasirox (DFX)\n7–40 mg/kg/day oral\n(Exjade®/Jadenu®)", fillcolor="#006064", fontcolor=white]
        DFX_abs      [label="DFX Oral Absorption\nF ~70%", fillcolor="#00838F"]
        DFX_C        [label="DFX Plasma\nConcentration", fillcolor="#00ACC1"]
        DFX_prot_bind[label="DFX Protein Binding\n(~99%, albumin)", fillcolor="#26C6DA"]
        DFX_met      [label="DFX Metabolism\n(glucuronidation, UGT1A1)\nt½ ~8–16h", fillcolor="#4DD0E1"]
        DFX_Fe_complex[label="DFX–Fe Complex\n(fecal excretion ~84%)", fillcolor="#80DEEA"]

        /* Deferiprone (DFP) */
        DFP_dose     [label="Deferiprone (DFP)\n25 mg/kg TID oral\n(Ferriprox®)", fillcolor="#00695C", fontcolor=white]
        DFP_abs      [label="DFP Oral Absorption\nRapid, F ~70%", fillcolor="#00897B"]
        DFP_C        [label="DFP Plasma\nConcentration", fillcolor="#26A69A"]
        DFP_met      [label="DFP Glucuronidation\nt½ ~2–3h", fillcolor="#4DB6AC"]
        DFP_Fe_complex[label="DFP–Fe³⁺ Complex\n(urine excretion)", fillcolor="#80CBC4"]
        DFP_cardiac  [label="DFP Cardiac Iron\nChelation (↑ T2*)", fillcolor="#A7FFEB"]

        /* Hepcidin agonists (experimental) */
        mini_hepcidin[label="Mini-Hepcidin / TMPRSS6\nsiRNA (experimental)", fillcolor="#00838F"]
        hepcidin_agon[label="Hepcidin Agonist\n→ FPN Degradation ↑", fillcolor="#00ACC1"]

        DFO_dose -> DFO_C [label="SC/IV infusion"]
        DFO_C -> DFO_dist [label="distribution"]
        DFO_dist -> DFO_Fe_complex [label="chelates LIP/NTBI"]
        LIP -> DFO_Fe_complex [label="chelation"]
        DFO_Fe_complex -> DFO_PD

        DFX_dose -> DFX_abs [label="oral dose"]
        DFX_abs -> DFX_C [label="Tmax ~1.5–4h"]
        DFX_C -> DFX_prot_bind [label="binding"]
        DFX_C -> DFX_met [label="metabolism"]
        DFX_met -> DFX_Fe_complex [label="chelates Fe"]
        LIP -> DFX_Fe_complex [label="chelation"]

        DFP_dose -> DFP_abs [label="oral dose"]
        DFP_abs -> DFP_C [label="Tmax ~45 min"]
        DFP_C -> DFP_met
        DFP_met -> DFP_Fe_complex [label="chelates Fe"]
        cardiac_Fe -> DFP_cardiac [label="DFP penetrates\nmyocyte"]
        DFP_cardiac -> cardiac_T2star [label="↑ T2* (iron ↓)"]

        mini_hepcidin -> hepcidin_agon [label="mimics hepcidin"]
        hepcidin_agon -> ferroportin [label="degrades FPN"]
    }

    /* ================================================================
       CLUSTER 9: PHLEBOTOMY & CLINICAL MANAGEMENT
    ================================================================ */
    subgraph cluster_phlebotomy {
        label="⑨ Phlebotomy & Clinical Management"
        style=filled; fillcolor="#F9FBE7"; color="#558B2F"; fontcolor="#558B2F"; fontsize=13

        phlebotomy   [label="Phlebotomy\n(500 mL = ~250 mg Fe)\n[Gold Standard]", fillcolor="#558B2F", fontcolor=white]
        phlebotomy_freq[label="Induction Phase\n1–2×/week until\nferritin <50 ng/mL", fillcolor="#7CB342"]
        maintenance  [label="Maintenance Phase\n2–4×/year (ferritin\n50–100 ng/mL)", fillcolor="#9CCC65"]
        RBC_loss     [label="RBC Iron Removal\n(250 mg Fe/500 mL)", fillcolor="#CDDC39"]
        erythroid_stim[label="Erythroid Stimulation\n(↑ EPO → erythropoiesis)", fillcolor="#DCE775"]
        dietary_restr[label="Dietary Iron Restriction\n(avoid red meat, vitamin C\nwith meals)", fillcolor="#E6EE9C"]
        alcohol_avoid [label="Alcohol Avoidance\n(↑ iron absorption)", fillcolor="#E6EE9C"]
        HIC_target   [label="Treatment Target:\nLIC <3 mg/g\nFerritin <50 ng/mL", fillcolor="#F0F4C3"]
        venesection_Hb[label="Monitor Hb ≥11 g/dL\n(contra if anemia)", fillcolor="#DCEDC8"]
        liver_regress[label="Liver Fibrosis\nRegression\n(early stages)", fillcolor="#AED581"]
        cardiomyop_regr[label="Cardiac Function\nImprovement\n(if early)", fillcolor="#8BC34A"]
        symptom_improve[label="Symptom Improvement:\n↓ fatigue, HF, DM", fillcolor="#7CB342"]

        phlebotomy -> phlebotomy_freq [label="protocol"]
        phlebotomy_freq -> maintenance [label="once targets met"]
        phlebotomy -> RBC_loss [label="per session"]
        RBC_loss -> mature_RBC [label="removes from body"]
        RBC_loss -> erythroid_stim [label="↑ iron demand"]
        erythroid_stim -> EPO_kidney [label="↑ EPO"]
        phlebotomy -> serum_ferritin [label="↓ ferritin"]
        phlebotomy -> LIC [label="↓ LIC"]
        dietary_restr -> ferroportin [label="↓ substrate"]
        alcohol_avoid -> DMT1 [label="↓ absorption"]
        phlebotomy -> HIC_target
        phlebotomy -> liver_regress [label="if pre-cirrhotic"]
        phlebotomy -> cardiomyop_regr
        liver_regress -> symptom_improve
        cardiomyop_regr -> symptom_improve
        venesection_Hb -> phlebotomy [label="monitor"]
    }

    /* ================================================================
       CLUSTER 10: CLINICAL BIOMARKERS & DIAGNOSIS
    ================================================================ */
    subgraph cluster_biomarkers {
        label="⑩ Clinical Biomarkers & Diagnostic Pathway"
        style=filled; fillcolor="#FCE4EC"; color="#880E4F"; fontcolor="#880E4F"; fontsize=13

        serum_iron_lab[label="Serum Iron\n(μg/dL)\nNormal: 60–170", fillcolor="#AD1457", fontcolor=white]
        TIBC_lab     [label="TIBC (μg/dL)\nNormal: 250–370", fillcolor="#C2185B", fontcolor=white]
        TSAT_lab     [label="Transferrin Saturation\n(TS%)\nAlarm: >45%", fillcolor="#E91E63", fontcolor=white]
        ferritin_lab  [label="Serum Ferritin (ng/mL)\nMen: >300 alarm\nWomen: >200 alarm", fillcolor="#F06292"]
        HFE_testing  [label="HFE Gene Testing\n(C282Y/H63D PCR)", fillcolor="#F48FB1"]
        liver_biopsy [label="Liver Biopsy\n(Perls' stain\nMetavir fibrosis)", fillcolor="#F8BBD0"]
        MRI_liver    [label="MRI R2/R2* (T2*)\n(LIC estimation\nnon-invasive)", fillcolor="#FCE4EC"]
        MRI_heart    [label="Cardiac MRI T2*\n(≤20ms = overload)", fillcolor="#FCE4EC"]
        liver_stiffness[label="Liver Stiffness\n(FibroScan, kPa)", fillcolor="#F8BBD0"]
        echo_LVEF    [label="Echocardiography\nLVEF, diastolic dysfx", fillcolor="#F8BBD0"]
        glucose_hba1c[label="Fasting Glucose\nHbA1c", fillcolor="#F8BBD0"]
        LH_FSH       [label="LH/FSH Levels\n(hypogonadism)", fillcolor="#F8BBD0"]
        testosterone [label="Serum Testosterone\n(males)", fillcolor="#F8BBD0"]
        APRI_FIB4    [label="APRI / FIB-4 Score\n(non-invasive fibrosis)", fillcolor="#FFCDD2"]
        EASL_criteria[label="EASL/BSH Guidelines:\nTS% + ferritin → HFE\ngenotyping", fillcolor="#EF9A9A"]

        TSAT -> TSAT_lab [label="screening"]
        serum_ferritin -> ferritin_lab [label="biomarker"]
        ferritin_lab -> HFE_testing [label="if elevated"]
        TSAT_lab -> HFE_testing [label="if >45%"]
        HFE_testing -> liver_biopsy [label="if ferritin >1000\nor elevated LFTs"]
        LIC -> MRI_liver [label="non-invasive quant"]
        cardiac_T2star -> MRI_heart
        liver_fibrosis -> liver_stiffness [label="elastography"]
        liver_fibrosis -> liver_biopsy
        EF_decline -> echo_LVEF
        insulin_def -> glucose_hba1c
        hypogonadism -> LH_FSH
        hypogonadism -> testosterone
        ALT -> APRI_FIB4 [label="calculation"]
        EASL_criteria -> TSAT_lab [label="algorithm"]
        serum_iron_lab -> TSAT_lab [label="Fe/TIBC × 100"]
    }

    /* ================================================================
       CLUSTER 11: PHARMACODYNAMICS & TREATMENT OUTCOMES
    ================================================================ */
    subgraph cluster_outcomes {
        label="⑪ Treatment PD & Clinical Outcomes"
        style=filled; fillcolor="#EFEBE9"; color="#3E2723"; fontcolor="#3E2723"; fontsize=13

        iron_burden  [label="Total Body Iron Burden\n(normal: 3–5 g)\n(HH: 20–40 g)", fillcolor="#4E342E", fontcolor=white]
        phlebotomy_PD[label="Phlebotomy PD:\nΔFe = 250 mg/session\nDeplete 0.5–1 g/month", fillcolor="#6D4C41", fontcolor=white]
        DFO_PD_out   [label="DFO PD:\nΔFe = 60–90 mg/24h\n(intensive protocol)", fillcolor="#5D4037"]
        DFX_PD_out   [label="DFX PD:\nΔFe = 25–90 mg/kg/day\n(dose-dependent)", fillcolor="#795548"]
        DFP_PD_out   [label="DFP PD:\nΔFe (cardiac → blood\n→ urine)", fillcolor="#8D6E63"]
        combination  [label="DFP + DFO Combo\n(shuttle chelation,\ncardiac iron ↓)", fillcolor="#A1887F"]
        fibrosis_regr[label="Fibrosis Regression\n(early stage): +\n(cirrhosis): limited", fillcolor="#BCAAA4"]
        HCC_prevent  [label="HCC Risk Reduction\n(with phlebotomy)", fillcolor="#D7CCC8"]
        survival_HH  [label="Normal Life Expectancy\n(if treated early,\nbefore cirrhosis/DM)", fillcolor="#EFEBE9"]
        QOL_fatigue  [label="Quality of Life:\n↓ fatigue, arthralgia", fillcolor="#D7CCC8"]
        iron_target  [label="Iron Target:\nFerritin 50–100 ng/mL\nTS% <50%", fillcolor="#8D6E63", fontcolor=white]
        adverse_DFX  [label="DFX Adverse Effects:\nnephrotoxicity, GI,\nagranulocytosis (rare)", fillcolor="#FFCCBC"]
        adverse_DFP  [label="DFP Adverse Effects:\nagranulocytosis (1–2%)\narthropathy", fillcolor="#FFCCBC"]

        serum_ferritin -> iron_burden [label="correlates"]
        LIC -> iron_burden [label="direct measure"]
        phlebotomy -> phlebotomy_PD
        DFO_C -> DFO_PD_out
        DFX_C -> DFX_PD_out
        DFP_C -> DFP_PD_out
        DFP_PD_out -> combination [label="shuttle chelation"]
        DFO_PD_out -> combination
        iron_burden -> iron_target [label="target"]
        iron_target -> fibrosis_regr [label="treatment reversal"]
        iron_target -> HCC_prevent
        iron_target -> survival_HH
        iron_target -> QOL_fatigue
        DFX_C -> adverse_DFX [label="dose-related"]
        DFP_C -> adverse_DFP [label="monitoring needed"]
    }

    /* ================================================================
       INTER-CLUSTER CONNECTIONS (key cross-links)
    ================================================================ */
    /* Genetics → Hepcidin */
    ERFE_suppress -> BMP_co_recep [label="inhibits ↓", color=orange]
    HFE_TfR2 -> BMP_co_recep [label="lost signaling", color=red]
    BMP_co_recep -> SMAD1_5 [label="BMP sensitization", color=darkgreen]
    HFE_TfR2 -> BMP2 [style=dashed, label="HFE senses\niron via BMP", color=gray]
    C282Y -> hepcidin_low [style=bold, color=red, label="HFE mut\n→ ↓ hepcidin"]
    homozygous -> hepcidin_low [style=bold, color=red]

    /* Hepcidin → Iron absorption */
    hepcidin_25 -> hepcidin_fpn [label="binds FPN", color=blue]
    hepcidin_low -> ferroportin [style=bold, color=red, label="↑ FPN\n→ ↑ absorption"]
    hepcidin_25 -> ferroportin [color=blue, label="hepcidin\ndegrades FPN"]

    /* Iron transport → Storage */
    serum_iron -> NTBI [color=red, label="Tf sat >75%\n→ NTBI"]
    NTBI -> LIP [color=red]
    LIP -> ferritin_core [label="storage"]

    /* Storage → Organ damage */
    LIC -> ROS_liver [color=red, style=bold]
    NTBI -> cardiac_Fe [color=red, style=bold]
    NTBI -> pancreas_Fe [color=red, style=bold]

    /* Phlebotomy → Iron stores */
    phlebotomy -> serum_ferritin [color=blue, label="↓", style=bold]
    phlebotomy -> LIC [color=blue, label="↓ LIC", style=bold]

    /* Chelation → LIP/NTBI */
    DFO_C -> LIP [color="#006064", label="chelates\nLIP"]
    DFX_C -> NTBI [color="#006064", label="chelates\nNTBI/LIP"]
    DFP_C -> cardiac_Fe [color="#006064", label="cardiac\nchelation"]

    /* Biomarker readouts */
    serum_ferritin -> ferritin_lab [color=gray, style=dashed]
    LIC -> MRI_LIC [color=gray, style=dashed]
    TSAT -> TSAT_lab [color=gray, style=dashed]
}
