digraph C3G_QSP {
  rankdir=LR;
  compound=true;
  fontname="Helvetica";
  fontsize=22;
  labelloc="t";
  label="C3 Glomerulopathy (C3G: DDD & C3GN) QSP Mechanistic Map\nAlternative-Pathway Dysregulation (CFH/CFI/CFB/C3/C3NeF) · Glomerular C3 Deposition · Podocyte/Mesangial Injury · CKD Progression · Iptacopan/Pegcetacoplan/Eculizumab/Ravulizumab/Danicopan PK/PD";
  node [style=filled, fontname="Helvetica", fontsize=11, shape=box, margin="0.12,0.06"];
  edge [fontname="Helvetica", fontsize=9, color="#555555"];

  /* ============ CLUSTER 1: GENETIC / ACQUIRED PREDISPOSITION ============ */
  subgraph cluster_genetics {
    label="1. 유전적/후천적 소인 (Genetic & Acquired Predisposition)";
    style=filled; color="#FBEEE6"; fontsize=13;
    G1  [label="CFH loss-of-function\nvariant (1q31.3)", fillcolor="#F5B7B1"];
    G2  [label="CFHR5 duplication /\nCFH-CFHR hybrid gene\n(CFHR5 nephropathy)", fillcolor="#F1948A"];
    G3  [label="CFI loss-of-function\nvariant (4q25)", fillcolor="#F1948A"];
    G4  [label="CFB gain-of-function\nvariant (6p21.33,\nMHC class III)", fillcolor="#EC7063"];
    G5  [label="C3 gain-of-function\nvariant (convertase-\nresistant to decay)", fillcolor="#E74C3C", fontcolor=white];
    G6  [label="MCP/CD46\nloss-of-function\nvariant", fillcolor="#CB4335", fontcolor=white];
    G7  [label="THBD (thrombomodulin)\nvariant", fillcolor="#D7BDE2"];
    G8  [label="Complement Factor H-\nRelated protein (FHR1-5)\ncompetitive antagonism", fillcolor="#D2B4DE"];
    G9  [label="Monoclonal gammopathy /\nparaprotein (older-onset\nC3G, anti-FH light chain)", fillcolor="#C39BD3"];
    G10 [label="Post-infectious trigger\n(pharyngitis, viral URI)\nAP priming", fillcolor="#AF7AC5", fontcolor=white];
    G11 [label="Genetic panel testing &\nfamily cascade screening", fillcolor="#9B59B6", fontcolor=white];
    G12 [label="Copy-number variation\n(CNV) in RCA gene\ncluster (1q32)", fillcolor="#BB8FCE"];
    G1 -> G12; G2 -> G12; G3 -> G12;
  }

  /* ============ CLUSTER 2: AUTOANTIBODY DRIVERS ============ */
  subgraph cluster_autoAb {
    label="2. 자가항체 매개 기전 (Autoantibody Drivers)";
    style=filled; color="#F4ECF7"; fontsize=13;
    A1 [label="C3 Nephritic Factor\n(C3NeF) autoantibody\n(anti-C3bBb epitope)", fillcolor="#D7BDE2"];
    A2 [label="C3NeF convertase\nstabilization (blocks\nFactor H decay-\naccelerating activity)", fillcolor="#C39BD3"];
    A3 [label="Anti-Factor H\nautoantibody (functional\nFH blockade)", fillcolor="#AF7AC5", fontcolor=white];
    A4 [label="Anti-Factor B\nautoantibody", fillcolor="#9B59B6", fontcolor=white];
    A5 [label="Anti-C3b autoantibody", fillcolor="#8E44AD", fontcolor=white];
    A6 [label="Plasmablast/plasma-cell\nclone producing\nnephritic autoantibody", fillcolor="#76448A", fontcolor=white];
    A7 [label="Persistent vs transient\nC3NeF titer\n(prognostic marker)", fillcolor="#6C3483", fontcolor=white];
    G9 -> A3; A6 -> A1; A6 -> A3; A6 -> A4; A6 -> A5; A1 -> A2; A1 -> A7;
  }

  /* ============ CLUSTER 3: ALTERNATIVE PATHWAY AMPLIFICATION LOOP ============ */
  subgraph cluster_ap {
    label="3. 대안경로 증폭 루프 (Alternative Pathway Amplification Loop)";
    style=filled; color="#EBF5FB"; fontsize=13;
    P1  [label="Spontaneous C3\n\"tick-over\" hydrolysis\n(C3(H2O))", fillcolor="#AED6F1"];
    P2  [label="Factor B binding to\nC3(H2O)/C3b\n(pro-convertase)", fillcolor="#85C1E9"];
    P3  [label="Factor D cleavage of\nbound Factor B\n(rate-limiting protease)", fillcolor="#5DADE2"];
    P4  [label="C3 convertase\n(C3bBb) formation", fillcolor="#3498DB", fontcolor=white];
    P5  [label="Properdin (Factor P)\nstabilization of C3bBb\n(prolongs t1/2 ~10-fold)", fillcolor="#2E86C1", fontcolor=white];
    P6  [label="Amplification: C3\ncleavage → C3a + C3b\n(positive feedback)", fillcolor="#21618C", fontcolor=white];
    P7  [label="C3b surface deposition\n(opsonization, covalent\nthioester binding)", fillcolor="#1B4F72", fontcolor=white];
    P8  [label="C3a anaphylatoxin\n(C3aR-mediated\nchemotaxis)", fillcolor="#154360", fontcolor=white];
    P9  [label="Fluid-phase vs surface-\nbound convertase\nkinetic competition", fillcolor="#A9CCE3"];
    P10 [label="Loss of host-cell\nsurface discrimination\n(self vs non-self)", fillcolor="#7FB3D5"];
    G4 -> P2; G5 -> P4; P1 -> P2; P2 -> P3; P3 -> P4; P5 -> P4; P4 -> P6; P6 -> P7; P6 -> P8;
    A2 -> P4; A4 -> P4; A5 -> P4; P9 -> P4; P10 -> P7;
  }

  /* ============ CLUSTER 4: REGULATORY PROTEIN NETWORK ============ */
  subgraph cluster_regulators {
    label="4. 보체 조절인자 네트워크 (Complement Regulatory Network)";
    style=filled; color="#EAFAF1"; fontsize=13;
    R1 [label="Factor H (fluid-phase\ndecay-accelerating +\ncofactor activity)", fillcolor="#A9DFBF"];
    R2 [label="Factor I (serine\nprotease, cleaves\nC3b→iC3b with cofactor)", fillcolor="#82E0AA"];
    R3 [label="MCP/CD46 (membrane\ncofactor protein,\ncell-surface)", fillcolor="#58D68D"];
    R4 [label="DAF/CD55 (decay-\naccelerating factor,\nmembrane)", fillcolor="#2ECC71", fontcolor=white];
    R5 [label="CR1/CD35 (complement\nreceptor 1, cofactor +\nclearance)", fillcolor="#28B463", fontcolor=white];
    R6 [label="Vitronectin/clusterin\n(fluid-phase MAC\ninhibitors)", fillcolor="#1E8449", fontcolor=white];
    R7 [label="Net regulatory reserve\n(host protection index)", fillcolor="#196F3D", fontcolor=white];
    G1 -> R1 [style=dashed, label="LOF"]; G3 -> R2 [style=dashed, label="LOF"]; G6 -> R3 [style=dashed, label="LOF"];
    A3 -> R1 [style=dashed, color="#C0392B", label="blocks"];
    R1 -> P4 [style=dashed, color="#196F3D", label="inhibits"]; R2 -> P7 [style=dashed, color="#196F3D", label="degrades"];
    R3 -> P4 [style=dashed, color="#196F3D"]; R4 -> P4 [style=dashed, color="#196F3D"]; R5 -> R2;
    R1 -> R7; R2 -> R7; R3 -> R7; R4 -> R7; R5 -> R7; R6 -> R7;
  }

  /* ============ CLUSTER 5: TERMINAL PATHWAY / MAC ============ */
  subgraph cluster_terminal {
    label="5. 말단경로/막공격복합체 (Terminal Pathway / MAC)";
    style=filled; color="#FEF9E7"; fontsize=13;
    T1 [label="C5 convertase\n(C3bBbC3b)", fillcolor="#F9E79F"];
    T2 [label="C5 cleavage →\nC5a + C5b", fillcolor="#F7DC6F"];
    T3 [label="C5a anaphylatoxin\n(C5aR1-mediated\nleukocyte recruitment)", fillcolor="#F4D03F"];
    T4 [label="C5b-C6-C7-C8\nassembly\n(pre-MAC complex)", fillcolor="#F1C40F"];
    T5 [label="C9 polymerization →\nC5b-9 (Membrane\nAttack Complex)", fillcolor="#D4AC0D"];
    T6 [label="Sublytic MAC on\nglomerular cells\n(non-lethal signaling)", fillcolor="#B7950B"];
    T7 [label="Lytic MAC insertion\n(cell lysis, mesangial/\nendothelial)", fillcolor="#9A7D0A"];
    T8 [label="Soluble sC5b-9\n(circulating biomarker\nof terminal activation)", fillcolor="#7D6608"];
    P6 -> T1; P7 -> T1; T1 -> T2; T2 -> T3; T2 -> T4; T4 -> T5; T5 -> T6; T5 -> T7; T5 -> T8;
  }

  /* ============ CLUSTER 6: HISTOPATHOLOGIC DEPOSITION PATTERNS ============ */
  subgraph cluster_histopath {
    label="6. 사구체 침착 조직병리 (Glomerular Deposition Histopathology)";
    style=filled; color="#FDEDEC"; fontsize=13;
    H1 [label="Mesangial C3 deposition\n(immunofluorescence,\nC3 ≥2+ dominant)", fillcolor="#F5B7B1"];
    H2 [label="Absence of significant\nIg co-deposition\n(C3-dominant criterion)", fillcolor="#F1948A"];
    H3 [label="Membranoproliferative\n(MPGN) pattern:\nmesangial/endocapillary", fillcolor="#EC7063"];
    H4 [label="Subendothelial +\nsubepithelial +\nmesangial C3b deposits\n(C3GN morphology)", fillcolor="#E74C3C", fontcolor=white];
    H5 [label="Intramembranous ribbon-\nlike dense deposits\n(Dense Deposit Disease, DDD)", fillcolor="#CB4335", fontcolor=white];
    H6 [label="GBM double-contouring\n('tram-track')", fillcolor="#B03A2E"];
    H7 [label="Crescents (severe/\nrapidly progressive\nsubset)", fillcolor="#943126", fontcolor=white];
    H8 [label="Electron-microscopy\nclassification: C3GN\nvs DDD phenotype split", fillcolor="#7B241C", fontcolor=white];
    H9 [label="C4d-negative /\nC4d-positive atypical\noverlap variant", fillcolor="#78281F", fontcolor=white];
    P7 -> H1; T7 -> H1; H1 -> H2; H1 -> H3; H3 -> H4; H3 -> H5; H4 -> H8; H5 -> H8; H3 -> H6; H3 -> H7;
  }

  /* ============ CLUSTER 7: GLOMERULAR CELLULAR INJURY ============ */
  subgraph cluster_injury {
    label="7. 사구체 세포 손상 (Glomerular Cellular Injury)";
    style=filled; color="#EAF2F8"; fontsize=13;
    I1 [label="Mesangial cell\nproliferation & matrix\nexpansion", fillcolor="#AED6F1"];
    I2 [label="Endothelial cell\nactivation/injury\n(capillary loop)", fillcolor="#85C1E9"];
    I3 [label="Podocyte C5aR1/C3aR\nsignaling → cytoskeletal\nrearrangement", fillcolor="#5DADE2"];
    I4 [label="Podocyte foot-process\neffacement", fillcolor="#3498DB", fontcolor=white];
    I5 [label="Podocyte detachment /\nloss (irreversible)", fillcolor="#2E86C1", fontcolor=white];
    I6 [label="Slit-diaphragm protein\n(nephrin/podocin)\ndownregulation", fillcolor="#21618C", fontcolor=white];
    I7 [label="Glomerular basement\nmembrane permeability\nbarrier breakdown", fillcolor="#1B4F72", fontcolor=white];
    I8 [label="Leukocyte (neutrophil/\nmonocyte) glomerular\ninfiltration (C3a/C5a-driven)", fillcolor="#154360", fontcolor=white];
    I9 [label="Local cytokine release\n(IL-6, TNF-α, MCP-1)", fillcolor="#0B2F44", fontcolor=white];
    H1 -> I1; T6 -> I2; T3 -> I8; T3 -> I3; I3 -> I4; I4 -> I5; I4 -> I6; I6 -> I7; I8 -> I9; I9 -> I1;
  }

  /* ============ CLUSTER 8: TUBULOINTERSTITIAL & FIBROTIC PROGRESSION ============ */
  subgraph cluster_progression {
    label="8. 세뇨관간질 손상 및 섬유화 진행 (Tubulointerstitial Injury & Fibrosis)";
    style=filled; color="#FEF5E7"; fontsize=13;
    F1 [label="Filtered complement\nfragments / protein\ntubular reabsorption overload", fillcolor="#FAD7A0"];
    F2 [label="Proximal tubular\ncell activation &\nEMT-like phenotype shift", fillcolor="#F8C471"];
    F3 [label="Renin-angiotensin-\naldosterone system\n(RAAS) activation", fillcolor="#F5B041"];
    F4 [label="TGF-β1 / CTGF\nfibrogenic signaling", fillcolor="#F39C12"];
    F5 [label="Interstitial fibroblast\nactivation & myofibroblast\ntransdifferentiation", fillcolor="#E67E22"];
    F6 [label="Peritubular capillary\nrarefaction / hypoxia", fillcolor="#D35400"];
    F7 [label="Tubulointerstitial\nfibrosis & tubular\natrophy (IF/TA score)", fillcolor="#BA4A00"];
    F8 [label="Global glomerulo-\nsclerosis (% sclerotic\nglomeruli)", fillcolor="#A04000"];
    F9 [label="Nephron loss &\nhyperfiltration of\nremnant nephrons", fillcolor="#873600"];
    I7 -> F1; I5 -> F8; F1 -> F2; F2 -> F5; F3 -> F4; F4 -> F5; F5 -> F6; F6 -> F7; F7 -> F8; F8 -> F9; F9 -> F3 [style=dashed, label="feedback"];
  }

  /* ============ CLUSTER 9: EXTRARENAL MANIFESTATIONS ============ */
  subgraph cluster_extrarenal {
    label="9. 신장외 임상 발현 (Extrarenal Manifestations)";
    style=filled; color="#F5EEF8"; fontsize=13;
    E1 [label="Drusen (sub-RPE\ndeposits, complement-\nrich, DDD association)", fillcolor="#D7BDE2"];
    E2 [label="Age-related macular\ndegeneration-like\nretinopathy (early-onset)", fillcolor="#C39BD3"];
    E3 [label="Acquired partial\nlipodystrophy (APL,\nadipocyte C3 deposition)", fillcolor="#AF7AC5", fontcolor=white];
    E4 [label="Increased susceptibility\nto encapsulated bacterial\ninfection (low serum C3)", fillcolor="#9B59B6", fontcolor=white];
    T5 -> E1; E1 -> E2; T7 -> E3; R7 -> E4 [style=dashed];
  }

  /* ============ CLUSTER 10: KIDNEY TRANSPLANTATION ============ */
  subgraph cluster_transplant {
    label="10. 신장이식 및 재발 (Kidney Transplantation & Recurrence)";
    style=filled; color="#EBF5FB"; fontsize=13;
    X1 [label="ESKD → kidney\ntransplantation", fillcolor="#AED6F1"];
    X2 [label="Persistent systemic\nAP dysregulation\npost-transplant", fillcolor="#85C1E9"];
    X3 [label="Recurrent C3G in\nallograft (up to\n50-90% by histology)", fillcolor="#5DADE2"];
    X4 [label="Allograft loss from\nrecurrent disease", fillcolor="#3498DB", fontcolor=white];
    X5 [label="Pre-transplant genetic/\nC3NeF risk stratification", fillcolor="#2E86C1", fontcolor=white];
    F9 -> X1; A1 -> X2; G1 -> X2; X2 -> X3; X3 -> X4; X5 -> X2 [style=dashed];
  }

  /* ============ CLUSTER 11: IPTACOPAN (FACTOR B INHIBITOR) PK/PD ============ */
  subgraph cluster_ipta {
    label="11. 입타코판 PK/PD (Oral Factor B Inhibitor)";
    style=filled; color="#EAFAF1"; fontsize=13;
    K1 [label="Iptacopan oral dose\n(200 mg BID)", fillcolor="#A9DFBF"];
    K2 [label="Gut absorption\n(Ka, high oral\nbioavailability)", fillcolor="#82E0AA"];
    K3 [label="Central compartment\n(1-cpt, plasma\nconcentration)", fillcolor="#58D68D"];
    K4 [label="Reversible, high-affinity\nFactor B binding\n(Emax model, IC50)", fillcolor="#2ECC71", fontcolor=white];
    K5 [label="Alternative pathway\nfunctional blockade\n(AP activity assay ~0)", fillcolor="#28B463", fontcolor=white];
    K6 [label="CYP3A4 hepatic\nmetabolism / elimination", fillcolor="#1E8449", fontcolor=white];
    K1 -> K2; K2 -> K3; K3 -> K4; K4 -> K5; K3 -> K6; K5 -> P2 [style=dashed, color="#196F3D", label="inhibits"];
  }

  /* ============ CLUSTER 12: PEGCETACOPLAN (C3 INHIBITOR) PK/PD ============ */
  subgraph cluster_peg {
    label="12. 페그세타코플란 PK/PD (C3/C3b Inhibitor)";
    style=filled; color="#FEF9E7"; fontsize=13;
    L1 [label="Pegcetacoplan SC\ndose (1080 mg\ntwice weekly)", fillcolor="#F9E79F"];
    L2 [label="SC depot absorption\n(Ka, PEGylated\ncyclic peptide)", fillcolor="#F7DC6F"];
    L3 [label="Central compartment\n(1-cpt, slow CL)", fillcolor="#F4D03F"];
    L4 [label="High-affinity C3/C3b\nbinding (blocks all\nconvertase formation)", fillcolor="#F1C40F"];
    L5 [label="Upstream complete AP+CP\ncascade blockade\n(both convertases)", fillcolor="#D4AC0D"];
    L6 [label="Target-mediated drug\ndisposition (TMDD,\nC3b sink effect)", fillcolor="#B7950B"];
    L1 -> L2; L2 -> L3; L3 -> L4; L4 -> L5; L3 -> L6; L5 -> P7 [style=dashed, color="#196F3D", label="blocks"]; L5 -> T1 [style=dashed, color="#196F3D"];
  }

  /* ============ CLUSTER 13: C5 INHIBITOR (ECULIZUMAB/RAVULIZUMAB) PK/PD ============ */
  subgraph cluster_c5i {
    label="13. C5 억제제 PK/PD (Eculizumab / Ravulizumab)";
    style=filled; color="#FDEDEC"; fontsize=13;
    C1 [label="Eculizumab IV\n(900 mg q2w\nmaintenance)", fillcolor="#F5B7B1"];
    C2 [label="Ravulizumab IV\n(weight-based\nq8w, engineered\nFcRn recycling)", fillcolor="#F1948A"];
    C3 [label="2-compartment mAb PK\n(CL, Vc, Vp, Q)", fillcolor="#EC7063"];
    C4 [label="C5 target binding\n(near-complete\noccupancy at trough)", fillcolor="#E74C3C", fontcolor=white];
    C5 [label="Terminal pathway\nblockade (C5b-9\nformation halted)", fillcolor="#CB4335", fontcolor=white];
    C6 [label="Upstream AP amplification\nunaffected (C3b deposition\ncontinues)", fillcolor="#B03A2E"];
    C7 [label="Breakthrough terminal\nactivation between\ndoses (EVH-like)", fillcolor="#943126", fontcolor=white];
    C1 -> C3; C2 -> C3; C3 -> C4; C4 -> C5; C5 -> T5 [style=dashed, color="#196F3D", label="blocks"];
    C4 -> C6 [style=dashed]; C6 -> P7; C3 -> C7 [style=dashed];
  }

  /* ============ CLUSTER 14: DANICOPAN (FACTOR D INHIBITOR) PK/PD ============ */
  subgraph cluster_dan {
    label="14. 다니코판 PK/PD (Oral Factor D Inhibitor, Add-on)";
    style=filled; color="#F4ECF7"; fontsize=13;
    D1 [label="Danicopan oral dose\n(150 mg TID,\nadd-on therapy)", fillcolor="#D7BDE2"];
    D2 [label="Gut absorption &\ncentral compartment", fillcolor="#C39BD3"];
    D3 [label="Factor D protease\ninhibition (upstream\nof C3 convertase)", fillcolor="#AF7AC5", fontcolor=white];
    D4 [label="Residual AP activity\nsuppression on top of\nC5 inhibitor background", fillcolor="#9B59B6", fontcolor=white];
    D1 -> D2; D2 -> D3; D3 -> D4; D4 -> P3 [style=dashed, color="#196F3D", label="inhibits"]; C7 -> D1 [style=dashed, label="triggers add-on"];
  }

  /* ============ CLUSTER 15: BIOMARKERS ============ */
  subgraph cluster_biomarker {
    label="15. 바이오마커 (Complement & Renal Biomarkers)";
    style=filled; color="#EAF2F8"; fontsize=13;
    B1 [label="Serum C3\n(low in active AP\ndysregulation)", fillcolor="#AED6F1"];
    B2 [label="Serum C4\n(normal, distinguishes\nfrom CP/lupus disease)", fillcolor="#85C1E9"];
    B3 [label="Factor B & Bb\nfragment levels", fillcolor="#5DADE2"];
    B4 [label="Factor H & Factor I\nantigenic levels", fillcolor="#3498DB", fontcolor=white];
    B5 [label="sC5b-9 (soluble\nterminal complex)", fillcolor="#2E86C1", fontcolor=white];
    B6 [label="C3NeF titer /\nautoantibody assay", fillcolor="#21618C", fontcolor=white];
    B7 [label="AP hemolytic assay\n(ex-vivo functional\nactivity)", fillcolor="#1B4F72", fontcolor=white];
    B8 [label="24-h urine protein-\nto-creatinine ratio\n(UPCR)", fillcolor="#154360", fontcolor=white];
    B9 [label="Serum creatinine /\neGFR trajectory", fillcolor="#0B2F44", fontcolor=white];
    P6 -> B1 [style=dashed]; T8 -> B5 [style=dashed]; A1 -> B6 [style=dashed]; P4 -> B7 [style=dashed];
  }

  /* ============ CLUSTER 16: CLINICAL ENDPOINTS ============ */
  subgraph cluster_clinical {
    label="16. 임상 엔드포인트 (Clinical Endpoints & Outcome)";
    style=filled; color="#FEF5E7"; fontsize=13;
    CE1 [label="Complete remission\n(UPCR <0.5, stable\neGFR)", fillcolor="#FAD7A0"];
    CE2 [label="Partial remission\n(UPCR reduction\n≥50%)", fillcolor="#F8C471"];
    CE3 [label="Persistent nephrotic-\nrange proteinuria", fillcolor="#F5B041"];
    CE4 [label="eGFR decline slope\n(mL/min/1.73m²/yr)", fillcolor="#F39C12"];
    CE5 [label="Progression to\nESKD / dialysis", fillcolor="#E67E22"];
    CE6 [label="Composite renal\nsurvival endpoint\n(≥50% eGFR decline\nor ESKD)", fillcolor="#D35400"];
    CE7 [label="Histologic activity\nindex change\n(protocol biopsy)", fillcolor="#BA4A00"];
    CE8 [label="Health-related quality\nof life / fatigue\n(edema, CKD burden)", fillcolor="#A04000"];
    I5 -> CE3; F8 -> CE4; CE3 -> CE5; CE4 -> CE6; CE5 -> CE6; X4 -> CE6; CE6 -> CE8; F7 -> CE7;
    B8 -> CE1 [style=dashed]; B8 -> CE2 [style=dashed]; B8 -> CE3 [style=dashed]; B9 -> CE4 [style=dashed];
  }

  /* ============ CROSS-CLUSTER KEY EDGES ============ */
  A1 -> A2; A3 -> R1; P8 -> I3;
  H8 -> I1; H8 -> I2;
  K5 -> B7 [style=dashed, color="#196F3D"]; L5 -> B7 [style=dashed, color="#196F3D"];
  K5 -> B1 [style=dashed, color="#196F3D", label="normalizes"]; L5 -> B1 [style=dashed, color="#196F3D", label="normalizes"];
  D4 -> B7 [style=dashed, color="#196F3D"];
  I9 -> F3;
  E4 -> CE8 [style=dashed];
}
