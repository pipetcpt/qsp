digraph StableAngina_QSP {

    graph [
        label = "Stable Angina (Chronic Coronary Syndrome) — Quantitative Systems Pharmacology\nCoronary Physiology · Drug PK/PD · Ischemia Mechanisms · Clinical Endpoints"
        labelloc = t
        fontname  = "Helvetica"
        fontsize  = 20
        bgcolor   = "#FAFAFA"
        rankdir   = TB
        splines   = curved
        nodesep   = 0.3
        ranksep   = 0.6
        compound  = true
    ]

    node [fontname="Helvetica" fontsize=9 style=filled shape=box width=1.4 height=0.42]
    edge [fontname="Helvetica" fontsize=8 arrowsize=0.6]

    /* ============================================================
       CLUSTER 1 — Coronary Anatomy
    ============================================================ */
    subgraph cluster_coronary {
        label="Coronary Anatomy & Stenosis"
        style=filled fillcolor="#FFF3E0" color="#E65100" fontsize=11 fontcolor="#E65100"

        CAD           [label="Coronary Artery\nDisease (CAD)"         fillcolor="#FFCC80"]
        stenosis      [label="Fixed Stenosis\n(% Occlusion)"          fillcolor="#FFCC80"]
        plaque_burden [label="Plaque Burden\n(Atheroma)"              fillcolor="#FFCC80"]
        lumen_area    [label="Luminal\nCross-section"                 fillcolor="#FFF8E1"]
        CFR           [label="Coronary Flow\nReserve (CFR)"           fillcolor="#FFF8E1"]
        collaterals   [label="Collateral\nCirculation"                fillcolor="#FFF8E1"]
        stenosis_FFR  [label="FFR < 0.80\n(Hemodynamic sig.)"        fillcolor="#FFCC80"]
        LAD           [label="LAD Branch"                             fillcolor="#FFE0B2"]
        LCx           [label="LCx Branch"                            fillcolor="#FFE0B2"]
        RCA           [label="RCA"                                    fillcolor="#FFE0B2"]
        micro_vasc    [label="Coronary\nMicrovasculature"             fillcolor="#FFF8E1"]
        CAC_score     [label="Coronary Calcium\nScore (CAC)"         fillcolor="#FFF8E1"]
    }

    /* ============================================================
       CLUSTER 2 — Myocardial Oxygen Supply
    ============================================================ */
    subgraph cluster_o2supply {
        label="Myocardial Oxygen Supply"
        style=filled fillcolor="#E3F2FD" color="#1565C0" fontsize=11 fontcolor="#1565C0"

        CBF           [label="Coronary Blood\nFlow (CBF)"             fillcolor="#90CAF9"]
        CBF_rest      [label="Resting CBF\n(~250 mL/min)"            fillcolor="#BBDEFB"]
        O2_delivery   [label="O₂ Delivery\n(DO₂)"                    fillcolor="#90CAF9"]
        O2_extract    [label="O₂ Extraction\nFraction (~65%)"        fillcolor="#BBDEFB"]
        CaO2          [label="Arterial O₂\nContent (CaO₂)"           fillcolor="#BBDEFB"]
        autoregul     [label="Myocardial\nAutoregulation"             fillcolor="#BBDEFB"]
        diast_perf_t  [label="Diastolic\nPerfusion Time"             fillcolor="#BBDEFB"]
        perfusion_P   [label="Coronary Perfusion\nPressure (CPP)"    fillcolor="#90CAF9"]
        microvR       [label="Microvascular\nResistance"              fillcolor="#BBDEFB"]
        TIMI_flow     [label="TIMI Flow Grade"                        fillcolor="#BBDEFB"]
    }

    /* ============================================================
       CLUSTER 3 — Myocardial Oxygen Demand
    ============================================================ */
    subgraph cluster_o2demand {
        label="Myocardial Oxygen Demand"
        style=filled fillcolor="#FCE4EC" color="#AD1457" fontsize=11 fontcolor="#AD1457"

        MVO2          [label="Myocardial O₂\nConsumption (MVO₂)"     fillcolor="#F48FB1"]
        HR            [label="Heart Rate\n(bpm)"                      fillcolor="#F48FB1"]
        contractility [label="Contractility\n(dP/dtmax)"             fillcolor="#EF9A9A"]
        wall_stress   [label="Ventricular\nWall Stress"              fillcolor="#EF9A9A"]
        LVEDP         [label="LVEDP\n(Filling Pressure)"             fillcolor="#EF9A9A"]
        LVEDV         [label="LVEDV\n(Preload)"                      fillcolor="#FFCDD2"]
        SBP           [label="Systolic BP\n(mmHg)"                   fillcolor="#F48FB1"]
        RPP           [label="Rate-Pressure\nProduct (HR×SBP)"       fillcolor="#E91E63" fontcolor="white"]
        SVR           [label="Systemic Vascular\nResistance (SVR)"   fillcolor="#EF9A9A"]
        CO            [label="Cardiac Output\n(CO)"                  fillcolor="#F48FB1"]
        SV            [label="Stroke Volume\n(SV)"                   fillcolor="#FFCDD2"]
    }

    /* ============================================================
       CLUSTER 4 — Endothelium & NO
    ============================================================ */
    subgraph cluster_endo {
        label="Endothelial Function & NO/cGMP"
        style=filled fillcolor="#F3E5F5" color="#7B1FA2" fontsize=11 fontcolor="#7B1FA2"

        endothelium   [label="Vascular\nEndothelium"                  fillcolor="#CE93D8"]
        eNOS          [label="eNOS"                                   fillcolor="#CE93D8"]
        NO_endo       [label="Nitric Oxide\n(Endogenous)"             fillcolor="#BA68C8"]
        sGC           [label="Soluble Guanylyl\nCyclase (sGC)"       fillcolor="#E1BEE7"]
        cGMP_endo     [label="cGMP (Endo)"                           fillcolor="#CE93D8"]
        PKG           [label="Protein\nKinase G (PKG)"               fillcolor="#E1BEE7"]
        vasodilation  [label="VSMC Relaxation\n(↑ NO/cGMP)"         fillcolor="#CE93D8"]
        prostacyclin  [label="Prostacyclin\n(PGI₂)"                  fillcolor="#E1BEE7"]
        ET1           [label="Endothelin-1\n(ET-1)"                  fillcolor="#FFCDD2"]
        ROS           [label="ROS / O₂⁻\n(Oxidative Stress)"        fillcolor="#FFCDD2"]
        eNOS_unc      [label="eNOS\nUncoupling"                      fillcolor="#FFCDD2"]
        BH4           [label="BH4\n(eNOS Cofactor)"                  fillcolor="#E1BEE7"]
        TXA2_endo     [label="Thromboxane A₂\n(TXA₂)"              fillcolor="#FFCDD2"]
    }

    /* ============================================================
       CLUSTER 5 — Atherosclerosis
    ============================================================ */
    subgraph cluster_athero {
        label="Atherosclerosis & Plaque Biology"
        style=filled fillcolor="#FFF8E1" color="#F57F17" fontsize=11 fontcolor="#F57F17"

        oxLDL         [label="ox-LDL"                                fillcolor="#FFE082"]
        foam_cells    [label="Foam Cells\n(Lipid-laden Mφ)"         fillcolor="#FFD54F"]
        intima        [label="Intimal\nThickening"                   fillcolor="#FFE082"]
        fibrous_cap   [label="Fibrous Cap\n(Thickness)"              fillcolor="#FFE082"]
        lipid_core    [label="Necrotic\nLipid Core"                  fillcolor="#FFD54F"]
        VSMC_mig      [label="VSMC Migration\ninto Intima"          fillcolor="#FFF176"]
        MMP9          [label="MMP-9\n(Cap Degradation)"             fillcolor="#FFD54F"]
        plaque_stab   [label="Plaque Stability\n(Stable/Vulnerable)" fillcolor="#FFC107"]
        ICAM1         [label="ICAM-1/VCAM-1\n(Adhesion)"           fillcolor="#FFE082"]
        IL6           [label="IL-6\n(Inflammation)"                  fillcolor="#FFCC80"]
        hsCRP         [label="hsCRP\n(Biomarker)"                   fillcolor="#FFE082"]
    }

    /* ============================================================
       CLUSTER 6 — Autonomic & Neurohumoral
    ============================================================ */
    subgraph cluster_autonomic {
        label="Autonomic & Neurohumoral Regulation"
        style=filled fillcolor="#E8F5E9" color="#2E7D32" fontsize=11 fontcolor="#2E7D32"

        SNS           [label="Sympathetic NS"                        fillcolor="#A5D6A7"]
        catecholamines [label="NE / Epinephrine\n(Catecholamines)"  fillcolor="#A5D6A7"]
        beta1R        [label="β₁-Adrenoceptor\n(Cardiac)"           fillcolor="#81C784"]
        beta2R        [label="β₂-Adrenoceptor\n(Vascular)"         fillcolor="#81C784"]
        alpha1R       [label="α₁-Adrenoceptor\n(Vasoconstriction)" fillcolor="#C8E6C9"]
        PNS           [label="Parasympathetic NS"                    fillcolor="#A5D6A7"]
        vagal         [label="Vagal Tone\n(M₂ / ACh)"               fillcolor="#C8E6C9"]
        barorec       [label="Baroreceptors\n(Aorta/Carotid)"       fillcolor="#C8E6C9"]
        exercise      [label="Exercise / Stress\n(Demand Trigger)"  fillcolor="#FF8A65"]
        cAMP          [label="cAMP\n(2nd Messenger)"                fillcolor="#C8E6C9"]
        PKA           [label="Protein Kinase A\n(PKA)"              fillcolor="#C8E6C9"]
        If_SA         [label="I_f Current\n(SA Node)"               fillcolor="#C8E6C9"]
    }

    /* ============================================================
       CLUSTER 7 — RAAS
    ============================================================ */
    subgraph cluster_raas {
        label="RAAS & Blood Pressure"
        style=filled fillcolor="#E0F7FA" color="#00838F" fontsize=11 fontcolor="#00838F"

        renin         [label="Renin\n(Kidney)"                      fillcolor="#80DEEA"]
        angiotensinogen [label="Angiotensinogen"                    fillcolor="#80DEEA"]
        angI          [label="Angiotensin I"                        fillcolor="#80DEEA"]
        ACE           [label="ACE (Lung)"                           fillcolor="#80DEEA"]
        angII         [label="Angiotensin II"                       fillcolor="#4DD0E1"]
        AT1R          [label="AT₁ Receptor"                         fillcolor="#80DEEA"]
        aldosterone   [label="Aldosterone"                          fillcolor="#80DEEA"]
        Na_ret        [label="Na⁺/H₂O\nRetention"                  fillcolor="#B2EBF2"]
        vol_exp       [label="Volume\nExpansion"                    fillcolor="#B2EBF2"]
        ACEi          [label="ACE Inhibitor\n(Ramipril/Enalapril)" fillcolor="#A5D6A7" shape=diamond]
    }

    /* ============================================================
       CLUSTER 8 — Nitrates PK/PD
    ============================================================ */
    subgraph cluster_nitrate {
        label="Organic Nitrates — PK/PD"
        style=filled fillcolor="#FFFDE7" color="#F9A825" fontsize=11 fontcolor="#F9A825"

        NTG           [label="Nitroglycerin\nSL/Patch/IV"           fillcolor="#FFF176" shape=diamond]
        ISMN          [label="ISMN\n(Mononitrate PO)"               fillcolor="#FFF176" shape=diamond]
        ISDN          [label="ISDN\n(Dinitrate PO)"                 fillcolor="#FFF176" shape=diamond]
        nitrate_abs   [label="Absorption\n(ISMN BA~100%)"           fillcolor="#FFF9C4"]
        nitrate_Vd    [label="Distribution\n(Vd~3 L/kg)"            fillcolor="#FFF9C4"]
        ALDH2         [label="ALDH2\n(Mitochondrial)"               fillcolor="#FFEE58"]
        nitrate_NO    [label="NO Release\n(Pharmacological)"        fillcolor="#FFEE58"]
        nitrate_cGMP  [label="↑ cGMP\n(Nitrate-mediated)"          fillcolor="#FFF176"]
        preload_red   [label="↓ Preload\n(Venodilation)"            fillcolor="#FFF176"]
        cor_dil_N     [label="Coronary\nDilation (NTG)"             fillcolor="#FFF176"]
        NO_tolerance  [label="Nitrate Tolerance\n(ALDH2 inactiv.)" fillcolor="#EF9A9A"]
        eccentric     [label="Eccentric Dosing\n(Tolerance prevent)" fillcolor="#FFF9C4"]
        NTG_t12       [label="NTG t½~1–3 min\nISMN t½~4–5 h"      fillcolor="#FFF9C4"]
    }

    /* ============================================================
       CLUSTER 9 — Beta-Blockers PK/PD
    ============================================================ */
    subgraph cluster_bb {
        label="Beta-Blockers — PK/PD"
        style=filled fillcolor="#EDE7F6" color="#512DA8" fontsize=11 fontcolor="#512DA8"

        atenolol      [label="Atenolol\n50–100 mg QD"               fillcolor="#B39DDB" shape=diamond]
        metoprolol    [label="Metoprolol SR\n50–200 mg QD"          fillcolor="#B39DDB" shape=diamond]
        bisoprolol    [label="Bisoprolol\n5–10 mg QD"               fillcolor="#B39DDB" shape=diamond]
        carvedilol    [label="Carvedilol\n(α/β blocker)"            fillcolor="#9575CD" shape=diamond]
        BB_abs        [label="Oral Absorption\n(BA 40–95%)"         fillcolor="#D1C4E9"]
        BB_dist       [label="Distribution\n(Vd 1–10 L/kg)"        fillcolor="#D1C4E9"]
        BB_met        [label="Hepatic Met\n(CYP2D6)"                fillcolor="#D1C4E9"]
        BB_elim       [label="Renal Elim\n(Atenolol ~50%)"         fillcolor="#D1C4E9"]
        beta1_block   [label="β₁ Blockade\n(Competitive)"          fillcolor="#9575CD"]
        HR_red_BB     [label="↓ Heart Rate\n(−15–25%)"             fillcolor="#9575CD"]
        contr_red     [label="↓ Contractility\n(−15%)"             fillcolor="#9575CD"]
        BP_red_BB     [label="↓ Blood Pressure\n(−10–15 mmHg)"    fillcolor="#9575CD"]
        RPP_red       [label="↓ RPP\n(Key Anti-ischemic)"           fillcolor="#7E57C2" fontcolor="white"]
        BB_t12        [label="t½: Ateno 6h\nBisoprolol 11h"        fillcolor="#D1C4E9"]
    }

    /* ============================================================
       CLUSTER 10 — CCBs PK/PD
    ============================================================ */
    subgraph cluster_ccb {
        label="Calcium Channel Blockers — PK/PD"
        style=filled fillcolor="#E8EAF6" color="#283593" fontsize=11 fontcolor="#283593"

        amlodipine    [label="Amlodipine\n5–10 mg QD (DHP)"        fillcolor="#9FA8DA" shape=diamond]
        diltiazem     [label="Diltiazem SR\n120–360 mg QD"         fillcolor="#9FA8DA" shape=diamond]
        verapamil     [label="Verapamil SR\n120–480 mg QD"         fillcolor="#9FA8DA" shape=diamond]
        CCB_abs       [label="Oral Absorption\n(Amlo BA 64%)"      fillcolor="#C5CAE9"]
        CCB_dist      [label="Distribution\n(Vd ~20 L/kg)"        fillcolor="#C5CAE9"]
        CYP3A4_ccb    [label="CYP3A4\nMetabolism"                  fillcolor="#C5CAE9"]
        Ltype         [label="L-type Ca²⁺\nChannel (LTCC)"        fillcolor="#7986CB"]
        Ca_influx     [label="↓ Ca²⁺ Influx"                      fillcolor="#7986CB"]
        VSMC_relax    [label="VSMC Relaxation\n(Arterial dil)"    fillcolor="#7986CB"]
        afterload_red [label="↓ Afterload\n(SVR −20–30%)"         fillcolor="#7986CB"]
        HR_red_CCB    [label="↓ HR\n(Diltiazem/Verapamil)"        fillcolor="#9FA8DA"]
        cor_dil_C     [label="Coronary\nDilation (all CCBs)"       fillcolor="#9FA8DA"]
        amlo_t12      [label="Amlo t½ 35–50h\nDiltiazem 4–8h"    fillcolor="#C5CAE9"]
    }

    /* ============================================================
       CLUSTER 11 — Ranolazine
    ============================================================ */
    subgraph cluster_ran {
        label="Ranolazine — Late I_Na Inhibition"
        style=filled fillcolor="#E0F2F1" color="#00695C" fontsize=11 fontcolor="#00695C"

        ranolazine    [label="Ranolazine ER\n500–1000 mg BID"      fillcolor="#80CBC4" shape=diamond]
        late_INa      [label="Late I_Na (I_NaL)\nIschemia-induced"  fillcolor="#4DB6AC"]
        Na_OL         [label="↑ [Na⁺]ᵢ\nOverload"                 fillcolor="#FF8A65"]
        NCX           [label="NCX\n(Na⁺/Ca²⁺ Exch)"               fillcolor="#FFCC80"]
        Ca_OL         [label="↑ [Ca²⁺]ᵢ\nOverload"                fillcolor="#EF9A9A"]
        ran_block     [label="↓ I_NaL → ↓ Na⁺\n→ ↓ Ca²⁺ Overload" fillcolor="#4DB6AC"]
        met_eff       [label="↑ Metabolic\nEfficiency"             fillcolor="#80CBC4"]
        diast_fn      [label="↑ Diastolic\nRelaxation"             fillcolor="#80CBC4"]
        anti_ang_R    [label="Anti-anginal\n(Metabolic)"           fillcolor="#4DB6AC"]
        ran_t12       [label="t½ ~7h / BA ~76%\n(ER formulation)"  fillcolor="#B2DFDB"]
        CYP3A4_ran    [label="CYP3A4\nMetabolism"                  fillcolor="#B2DFDB"]
        QTc           [label="QTc Prolongation\n(Monitor)"         fillcolor="#FFF9C4"]
    }

    /* ============================================================
       CLUSTER 12 — Ivabradine
    ============================================================ */
    subgraph cluster_iva {
        label="Ivabradine — HCN/I_f Inhibition"
        style=filled fillcolor="#F1F8E9" color="#558B2F" fontsize=11 fontcolor="#558B2F"

        ivabradine    [label="Ivabradine\n5–7.5 mg BID"            fillcolor="#AED581" shape=diamond]
        HCN           [label="HCN Channel\n(I_f Current)"          fillcolor="#8BC34A"]
        SA_node       [label="SA Node\n(Sinoatrial)"               fillcolor="#8BC34A"]
        spont_depol   [label="Spontaneous\nDepolarization Rate"    fillcolor="#DCEDC8"]
        HR_red_I      [label="↓ Heart Rate\n(Pure Chronotropic)"   fillcolor="#8BC34A"]
        diast_dur     [label="↑ Diastolic\nDuration"               fillcolor="#8BC34A"]
        cor_perf_I    [label="↑ Coronary\nPerfusion Time"          fillcolor="#AED581"]
        phosphene     [label="Visual Phosphene\n(Retinal HCN)"     fillcolor="#FFF9C4"]
        iva_t12       [label="t½ ~2h\nBA ~40%"                     fillcolor="#DCEDC8"]
        CYP3A4_iva    [label="CYP3A4\nMetabolism"                  fillcolor="#DCEDC8"]
        HR_target     [label="Target HR\n55–60 bpm"                fillcolor="#AED581"]
    }

    /* ============================================================
       CLUSTER 13 — Antiplatelet & Statin
    ============================================================ */
    subgraph cluster_apstatin {
        label="Antiplatelet & Statin Therapy"
        style=filled fillcolor="#FBE9E7" color="#BF360C" fontsize=11 fontcolor="#BF360C"

        aspirin       [label="Aspirin\n75–100 mg QD"               fillcolor="#FFAB91" shape=diamond]
        clopidogrel   [label="Clopidogrel\n75 mg QD"               fillcolor="#FFAB91" shape=diamond]
        ticagrelor    [label="Ticagrelor\n60 mg BID"               fillcolor="#FFAB91" shape=diamond]
        COX1          [label="COX-1\n(Platelet TXA₂)"             fillcolor="#FF7043"]
        P2Y12         [label="P2Y12 Receptor\n(ADP-mediated)"     fillcolor="#FF7043"]
        plt_agg       [label="Platelet\nAggregation"               fillcolor="#FF7043"]
        thrombus_R    [label="Thrombus\nRisk"                      fillcolor="#FFCCBC"]
        statin        [label="Statin\n(Rosuvastatin/Atorva)"       fillcolor="#A5D6A7" shape=diamond]
        HMGCoA_R      [label="HMG-CoA\nReductase"                  fillcolor="#A5D6A7"]
        LDL_red       [label="↓ LDL-C\n(30–60%)"                  fillcolor="#A5D6A7"]
        plaque_reg    [label="Plaque Regression /\nStabilization"  fillcolor="#A5D6A7"]
        statin_pl     [label="Pleiotropic\n(↑ eNOS, ↓ IL-6)"      fillcolor="#A5D6A7"]
    }

    /* ============================================================
       CLUSTER 14 — Clinical Endpoints
    ============================================================ */
    subgraph cluster_endpoints {
        label="Ischemia & Clinical Endpoints"
        style=filled fillcolor="#FFEBEE" color="#B71C1C" fontsize=11 fontcolor="#B71C1C"

        ischemia      [label="Myocardial\nIschemia"                 fillcolor="#EF9A9A"]
        O2_imbal      [label="O₂ Supply-Demand\nImbalance"         fillcolor="#EF9A9A"]
        angina_ep     [label="Angina Episodes\n(/week)"             fillcolor="#EF5350" fontcolor="white"]
        ST_dep        [label="ST Depression\n(≥1 mm)"              fillcolor="#EF9A9A"]
        ex_tol        [label="Exercise Tolerance\n(METmax)"        fillcolor="#EF9A9A"]
        T2angina      [label="Time to 1 mm ST\nDepression"         fillcolor="#EF9A9A"]
        CCS           [label="CCS Class\nI (mild) → IV"            fillcolor="#E53935" fontcolor="white"]
        MACE          [label="MACE\n(CV Death/MI/Stroke)"          fillcolor="#C62828" fontcolor="white"]
        NTG_use       [label="Rescue NTG\nConsumption"             fillcolor="#FFCDD2"]
        SAQ           [label="QoL — SAQ\n(Seattle Angina Q)"       fillcolor="#FFCDD2"]
        silent_isch   [label="Silent\nIschemia"                    fillcolor="#FFCDD2"]
        isch_thresh   [label="Ischemic Threshold\n(RPP ~20,000)"   fillcolor="#EF9A9A"]
    }

    /* ============================================================
       CLUSTER 15 — Biomarkers
    ============================================================ */
    subgraph cluster_biomarkers {
        label="Biomarkers & Diagnostics"
        style=filled fillcolor="#F9FBE7" color="#827717" fontsize=11 fontcolor="#827717"

        TroponinIT    [label="Troponin I/T\n(↑ myocyte injury)"   fillcolor="#F0F4C3"]
        BNP           [label="BNP/NT-proBNP\n(↑ filling press.)"  fillcolor="#F0F4C3"]
        Holter        [label="Holter/ECG\n(ST changes)"           fillcolor="#F0F4C3"]
        Echo          [label="Echocardiography\n(EF, WMA)"        fillcolor="#F0F4C3"]
        SPECT         [label="Nuclear Perfusion\n(SPECT/PET)"     fillcolor="#F0F4C3"]
        FFR_test      [label="FFR\n(Invasive Test)"               fillcolor="#F0F4C3"]
        Lipid_panel   [label="Lipid Panel\n(LDL-C/HDL-C/TG)"    fillcolor="#F0F4C3"]
        HbA1c         [label="HbA1c\n(Metabolic)"                 fillcolor="#F0F4C3"]
        eGFR          [label="eGFR\n(Renal)"                      fillcolor="#F0F4C3"]
        CRP_lab       [label="hsCRP Lab\n(Inflammation)"          fillcolor="#F0F4C3"]
    }

    /* ============================================================
       EDGES — Coronary anatomy → O2 supply
    ============================================================ */
    CAD -> stenosis
    CAD -> plaque_burden
    plaque_burden -> stenosis
    stenosis -> lumen_area [label="narrows"]
    stenosis -> CFR        [label="impairs"]
    lumen_area -> CBF
    stenosis_FFR -> CBF    [label="limits flow" color="#E65100" style=bold]
    collaterals -> CBF     [label="partial restore"]
    CBF_rest -> autoregul
    autoregul -> microvR
    microvR -> CBF         [label="regulates" constraint=false]
    perfusion_P -> CBF
    diast_perf_t -> O2_delivery
    CaO2 -> O2_delivery
    CBF -> O2_delivery
    O2_extract -> O2_delivery
    TIMI_flow -> CBF       [label="reflects"]
    LAD -> micro_vasc
    LCx -> micro_vasc
    RCA -> micro_vasc

    /* O2 Supply/Demand → Ischemia */
    O2_delivery -> O2_imbal [label="supply" color="#1565C0"]
    MVO2 -> O2_imbal        [label="demand" color="#AD1457"]
    O2_imbal -> ischemia    [label="imbalance→ischemia" color="#B71C1C" style=bold]
    RPP -> isch_thresh
    isch_thresh -> ischemia [label="RPP>threshold" color="#B71C1C"]
    ischemia -> angina_ep
    ischemia -> ST_dep
    ischemia -> TroponinIT  [label="severe" constraint=false]
    ischemia -> silent_isch

    /* O2 Demand chain */
    HR -> MVO2     [label="major"]
    contractility -> MVO2
    wall_stress -> MVO2
    SVR -> wall_stress  [label="Laplace law"]
    LVEDV -> LVEDP
    LVEDP -> wall_stress
    SBP -> RPP
    HR -> RPP
    CO -> SBP
    SV -> CO
    HR -> CO

    /* Autonomic */
    exercise -> SNS        [label="activates" style=bold]
    SNS -> catecholamines
    catecholamines -> beta1R
    catecholamines -> alpha1R
    catecholamines -> beta2R
    beta1R -> cAMP
    cAMP -> PKA
    PKA -> HR              [label="↑ chronotropy"]
    PKA -> contractility   [label="↑ inotropy"]
    alpha1R -> SVR         [label="vasoconstriction"]
    PNS -> vagal
    vagal -> HR            [label="↓ HR" constraint=false arrowhead=tee color="#2E7D32"]
    SBP -> barorec         [label="senses"]
    barorec -> PNS         [label="activates" constraint=false]
    beta1R -> If_SA
    If_SA -> HR            [label="drives pacemaker"]

    /* RAAS */
    renin -> angiotensinogen [label="cleaves"]
    angiotensinogen -> angI
    ACE -> angI            [label="converts"]
    angI -> angII
    angII -> AT1R
    AT1R -> SVR            [label="vasoconstriction"]
    AT1R -> aldosterone
    aldosterone -> Na_ret
    Na_ret -> vol_exp
    vol_exp -> LVEDV       [label="↑ preload" constraint=false]
    SVR -> SBP             [label="↑ BP"]
    ACEi -> ACE            [label="inhibits" color="#2E7D32" arrowhead=tee]

    /* Endothelium / NO */
    endothelium -> eNOS
    eNOS -> NO_endo
    NO_endo -> sGC
    sGC -> cGMP_endo
    cGMP_endo -> PKG
    PKG -> vasodilation
    vasodilation -> CBF    [label="↑ BF" constraint=false]
    vasodilation -> SVR    [label="↓ SVR" arrowhead=tee constraint=false]
    endothelium -> prostacyclin
    prostacyclin -> plt_agg [label="inhibit" arrowhead=tee constraint=false]
    endothelium -> ET1     [label="disease state"]
    ET1 -> SVR             [label="potentiates" constraint=false]
    ROS -> NO_endo         [label="quenches NO" arrowhead=tee constraint=false color="#B71C1C"]
    ROS -> eNOS_unc
    eNOS_unc -> ROS        [label="generates O₂⁻" constraint=false]
    BH4 -> eNOS            [label="cofactor"]
    TXA2_endo -> plt_agg   [label="promotes"]

    /* Atherosclerosis */
    ROS -> oxLDL           [label="oxidizes LDL"]
    oxLDL -> foam_cells    [label="Mφ uptake"]
    foam_cells -> intima   [label="accumulate"]
    foam_cells -> lipid_core
    ICAM1 -> foam_cells    [label="recruit monocytes"]
    VSMC_mig -> fibrous_cap [label="stabilize"]
    MMP9 -> fibrous_cap    [label="degrades" arrowhead=tee]
    IL6 -> MMP9
    IL6 -> hsCRP           [label="↑ CRP"]
    lipid_core -> fibrous_cap [label="destabilizes" arrowhead=tee]
    intima -> stenosis     [label="→ stenosis" constraint=false]
    plaque_stab -> stenosis_FFR

    /* Statin */
    statin -> HMGCoA_R     [label="inhibits" arrowhead=tee]
    HMGCoA_R -> LDL_red    [label="↓ LDL synth" constraint=false]
    LDL_red -> oxLDL       [label="↓ substrate" arrowhead=tee constraint=false]
    LDL_red -> plaque_reg
    plaque_reg -> plaque_stab [label="↑ stability"]
    statin_pl -> ROS       [label="↓ ROS" arrowhead=tee constraint=false]
    statin_pl -> IL6       [label="↓ IL-6" arrowhead=tee constraint=false]
    statin_pl -> eNOS      [label="↑ eNOS"]

    /* Antiplatelet */
    aspirin -> COX1        [label="irrev inhib" arrowhead=tee]
    COX1 -> TXA2_endo      [label="produces"]
    clopidogrel -> P2Y12   [label="inhib (CYP2C19)" arrowhead=tee]
    ticagrelor -> P2Y12    [label="inhib (direct)" arrowhead=tee]
    P2Y12 -> plt_agg       [label="ADP-driven"]
    plt_agg -> thrombus_R
    COX1 -> plt_agg        [label="via TXA₂"]

    /* Nitrates PK/PD */
    NTG -> nitrate_abs     [label="SL rapid BA"]
    ISMN -> nitrate_abs    [label="oral BA~100%"]
    ISDN -> nitrate_abs    [label="oral BA~25%"]
    nitrate_abs -> nitrate_Vd
    nitrate_Vd -> ALDH2    [label="bioactivation"]
    ALDH2 -> nitrate_NO    [label="generates NO"]
    nitrate_NO -> nitrate_cGMP
    nitrate_cGMP -> preload_red [label="venodilation"]
    nitrate_cGMP -> cor_dil_N
    preload_red -> LVEDV   [label="↓ filling" arrowhead=tee constraint=false]
    cor_dil_N -> CBF       [label="↑ epicardial" constraint=false]
    NO_tolerance -> ALDH2  [label="inactivates" arrowhead=tee color="#B71C1C"]
    eccentric -> NO_tolerance [label="prevents" arrowhead=tee]
    NTG_t12 -> nitrate_Vd  [label="kinetics"]
    preload_red -> wall_stress [label="↓ LVEDP" arrowhead=tee constraint=false]

    /* BB PK/PD */
    atenolol -> BB_abs
    metoprolol -> BB_abs
    bisoprolol -> BB_abs
    carvedilol -> BB_abs
    BB_abs -> BB_dist
    BB_dist -> BB_met
    BB_dist -> BB_elim
    BB_dist -> beta1_block [label="β₁ occupancy"]
    beta1_block -> HR_red_BB
    beta1_block -> contr_red
    HR_red_BB -> RPP_red
    contr_red -> RPP_red
    BP_red_BB -> RPP_red
    beta1_block -> BP_red_BB
    HR_red_BB -> HR        [label="↓ HR" arrowhead=tee constraint=false]
    contr_red -> contractility [label="↓" arrowhead=tee constraint=false]
    BP_red_BB -> SBP       [label="↓ SBP" arrowhead=tee constraint=false]
    BB_t12 -> BB_dist
    beta1_block -> If_SA   [label="↓ If" arrowhead=tee constraint=false]

    /* CCB PK/PD */
    amlodipine -> CCB_abs
    diltiazem -> CCB_abs
    verapamil -> CCB_abs
    CCB_abs -> CCB_dist
    CCB_dist -> CYP3A4_ccb
    CCB_dist -> Ltype      [label="blocks"]
    Ltype -> Ca_influx
    Ca_influx -> VSMC_relax
    VSMC_relax -> afterload_red
    VSMC_relax -> cor_dil_C
    afterload_red -> SVR   [label="↓" arrowhead=tee constraint=false]
    afterload_red -> SBP   [label="↓" arrowhead=tee constraint=false]
    cor_dil_C -> CBF       [label="↑ coronary" constraint=false]
    diltiazem -> HR_red_CCB [label="AV node"]
    verapamil -> HR_red_CCB [label="AV node"]
    HR_red_CCB -> HR       [label="↓ HR" arrowhead=tee constraint=false]
    amlo_t12 -> CCB_dist

    /* Ranolazine PK/PD */
    ranolazine -> late_INa [label="inhibits I_NaL" arrowhead=tee]
    late_INa -> Na_OL      [label="drives\n(ischemia)"]
    Na_OL -> NCX
    NCX -> Ca_OL           [label="reverses→Ca²⁺"]
    Ca_OL -> diast_fn      [label="impairs" arrowhead=tee]
    ran_block -> Na_OL     [label="↓" arrowhead=tee]
    ran_block -> Ca_OL     [label="↓" arrowhead=tee]
    ran_block -> met_eff
    ran_block -> diast_fn
    ran_block -> anti_ang_R
    anti_ang_R -> angina_ep [label="↓" arrowhead=tee constraint=false]
    CYP3A4_ran -> ranolazine [label="metabolises" constraint=false]
    ran_t12 -> ranolazine  [label="kinetics"]
    ranolazine -> ran_block
    ranolazine -> QTc

    /* Ivabradine PK/PD */
    ivabradine -> HCN      [label="blocks" arrowhead=tee]
    HCN -> SA_node         [label="drives pacemaker"]
    SA_node -> spont_depol
    spont_depol -> HR      [label="sets rate"]
    ivabradine -> HR_red_I
    HR_red_I -> diast_dur  [label="↑ diastole"]
    diast_dur -> cor_perf_I
    cor_perf_I -> CBF      [label="↑ effective" constraint=false]
    HR_red_I -> HR         [label="↓" arrowhead=tee constraint=false]
    ivabradine -> phosphene [label="retinal HCN"]
    CYP3A4_iva -> ivabradine [label="metabolises" constraint=false]
    iva_t12 -> ivabradine
    HR_red_I -> HR_target

    /* Anti-ischemic effects */
    RPP_red -> RPP         [label="↓ RPP" arrowhead=tee constraint=false]
    RPP_red -> angina_ep   [label="↓" arrowhead=tee constraint=false]
    RPP_red -> ex_tol      [label="↑ tolerance" constraint=false]
    anti_ang_R -> ex_tol   [label="↑" constraint=false]
    diast_fn -> ex_tol     [label="↑ diastolic fn" constraint=false]
    cor_perf_I -> ischemia [label="↓ ischemia" arrowhead=tee constraint=false]

    /* Clinical endpoint chain */
    angina_ep -> CCS
    ex_tol -> CCS
    T2angina -> ex_tol
    ST_dep -> T2angina
    CCS -> SAQ
    CCS -> MACE            [label="predicts long-term"]
    NTG_use -> angina_ep
    NTG_use -> CCS

    /* Biomarkers */
    ischemia -> TroponinIT [label="↑ severe"]
    LVEDP -> BNP           [label="↑ filling P"]
    ischemia -> Holter     [label="ST changes"]
    SPECT -> ischemia      [label="reveals" constraint=false]
    FFR_test -> stenosis_FFR [label="measures"]
    oxLDL -> Lipid_panel   [label="reflected as LDL-C" constraint=false]
    Holter -> silent_isch  [label="detects"]
    Echo -> LVEDV          [label="measures" constraint=false]
    Echo -> SV             [label="measures EF×EDV" constraint=false]
    hsCRP -> CRP_lab
    IL6 -> CRP_lab         [label="induces"]
    CAC_score -> plaque_burden [label="quantifies"]

}
