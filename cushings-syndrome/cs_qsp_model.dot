    ACTH_inh_pas -> ACTH [color="#006064", style=dashed, label="억제"]
    SSTR5 -> Hyperglycemia_AE [color="#FF6F00"]
    A_pas_C -> GI_AE [color="#FF8F00", style=dashed]

    // ============================================================
    // EDGES: STEROIDOGENESIS INHIBITORS
    // ============================================================
    Keto_dose -> A_keto_gut [color="#FF6F00"]
    A_keto_gut -> A_keto_C [color="#FF6F00"]
    A_keto_C -> CYP17A1_inh_keto [color="#FF6F00", penwidth=2]
    A_keto_C -> CYP11B1_inh_keto [color="#FF6F00"]
    CYP17A1_inh_keto -> CYP17A1 [color="#FF6F00", style=dashed, label="억제"]
    CYP11B1_inh_keto -> CYP11B1 [color="#FF6F00", style=dashed]
    CYP17A1_inh_keto -> Cortisol_red_keto [color="#FF6F00"]
    CYP11B1_inh_keto -> Cortisol_red_keto [color="#FF6F00"]
    Cortisol_red_keto -> Cortisol_adrenal [color="#FF6F00", style=dashed]
    A_keto_C -> Hepatotox_keto [color="#BF360C", style=dashed]

    Mety_dose -> A_mety_gut [color="#FFA726"]
    A_mety_gut -> A_mety_C [color="#FFA726"]
    A_mety_C -> CYP11B1_inh_mety [color="#FFA726", penwidth=2]
    CYP11B1_inh_mety -> CYP11B1 [color="#FFA726", style=dashed, label="억제"]
    CYP11B1_inh_mety -> Deoxycortisol_acc [color="#FFA726"]
    Deoxycortisol_acc -> Deoxycortisol [color="#FFA726", style=dashed]

    Osilo_dose -> A_osilo_C [color="#FFEE58"]
    A_osilo_C -> CYP11B1_inh_osilo [color="#FF6F00", penwidth=2]
    CYP11B1_inh_osilo -> CYP11B1 [color="#FF6F00", style=dashed]
    CYP11B1_inh_osilo -> CYP11B2 [color="#FF6F00", style=dashed]
    CYP11B1_inh_osilo -> Cortisol_red_osilo [color="#FF6F00"]

    Cortisol_red_keto -> ACTH_escape [color="#FF3D00", style=dashed]
    Cortisol_red_osilo -> ACTH_escape [color="#FF3D00", style=dashed]
    CYP11B1_inh_mety -> ACTH_escape [color="#FF3D00", style=dashed]
    ACTH_escape -> ACTH [color="#FF3D00", label="탈출 → ACTH↑"]

    // ============================================================
    // EDGES: GR ANTAGONIST & CABERGOLINE
    // ============================================================
    Mife_dose -> A_mife_gut [color="#558B2F"]
    A_mife_gut -> A_mife_C [color="#558B2F"]
    A_mife_C -> GR_occupancy_mife [color="#558B2F", penwidth=2]
    GR_occupancy_mife -> GR_inh_mife [color="#558B2F"]
    GR_inh_mife -> GR_alpha [color="#558B2F", style=dashed, label="길항"]
    GR_inh_mife -> glucose_norm_mife [color="#558B2F"]
    GR_inh_mife -> Cortisol_raise_mife [color="#F57F17"]
    Cortisol_raise_mife -> ACTH [color="#F57F17", style=dashed]

    Cab_dose -> A_cab_C [color="#33691E"]
    A_cab_C -> D2R_pit [color="#33691E", penwidth=2]
    D2R_pit -> ACTH_inh_cab [color="#33691E"]
    ACTH_inh_cab -> ACTH [color="#33691E", style=dashed, label="억제"]
    A_cab_C -> Cab_AE [color="#FF8F00", style=dashed]

    Mitotane -> Adrenal_destruction [color="#BF360C", penwidth=2]
    Adrenal_destruction -> Cortisol_adrenal [color="#BF360C", style=dashed, label="파괴"]

    // ============================================================
    // EDGES: CLINICAL ENDPOINTS
    // ============================================================
    Cortisol_plasma -> UFC_24h [color="#4A148C", penwidth=2]
    Cortisol_plasma -> LNSC [color="#4A148C", penwidth=2, label="자정 샘플"]
    Cortisol_plasma -> Morning_cortisol [color="#4A148C"]
    Morning_cortisol -> Dex_test_1mg [color="#7B1FA2"]
    ACTH -> Dex_test_8mg [color="#7B1FA2"]
    ACTH -> CRH_stim_test [color="#7B1FA2"]
    CRH_stim_test -> IPSS [color="#6A1B9A"]
    IPSS -> Pituitary_adenoma_CS [color="#6A1B9A", label="확진"]

    VAT_expansion -> BMI_waist [color="#4A148C"]
    Blood_glucose -> HbA1c_CS [color="#4A148C"]
    Osteoporosis -> BMD_DXA [color="#4A148C"]
    BP_elevation -> BP_clinical [color="#4A148C"]
    Depression -> HDRS17 [color="#4A148C"]
    VAT_expansion -> Facial_features [color="#4A148C", style=dashed]
    Muscle_wasting -> Facial_features [color="#4A148C", style=dashed]

    UFC_24h -> Remission_criteria [color="#4A148C", penwidth=2]
    LNSC -> Remission_criteria [color="#4A148C"]
    Remission_criteria -> Recurrence_rate [color="#4A148C", style=dashed]

    // ============================================================
    // EDGES: ETIOLOGY LINKS
    // ============================================================
    Pituitary_adenoma_CS -> pit_adenoma [color="#4E342E", penwidth=2]
    Ectopic_ACTH_source -> ACTH [color="#4E342E", penwidth=2]
    Adrenal_adenoma_CS -> adrenal_adenoma [color="#4E342E", penwidth=2]
    Adrenal_carcinoma -> Cortisol_adrenal [color="#4E342E"]
    PBMAH -> Cortisol_adrenal [color="#4E342E"]
    MAS -> Gs_adr [color="#4E342E", label="GNAS↑"]
    Subclinical_CS -> UFC_24h [color="#795548", style=dashed]
    Cyclic_CS -> Cortisol_plasma [color="#795548", style=dashed]
    CRH_producing_tumor -> CRH [color="#795548"]
}
