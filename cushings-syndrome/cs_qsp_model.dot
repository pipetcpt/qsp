digraph CushingsSyndromeQSP {
    rankdir=TB;
    graph [fontname="Helvetica", fontsize=11, bgcolor="#FAFAFA", splines=ortho,
           label="Cushing's Syndrome QSP Model\n쿠싱 증후군 정량적 시스템 약리학 모델\n(HPA Axis · Steroidogenesis · Drug PK/PD · Clinical Endpoints)",
           labelloc=t, fontsize=14, nodesep=0.4, ranksep=0.6]
    node [fontname="Helvetica", fontsize=10, style="filled,rounded", shape=box]
    edge [fontname="Helvetica", fontsize=9, color="#555555"]

    // ============================================================
    // CLUSTER 1: HYPOTHALAMUS
    // ============================================================
    subgraph cluster_hypothalamus {
        label="🧠 시상하부 (Hypothalamus)";
        fontsize=13; fontname="Helvetica-Bold";
        style=filled; fillcolor="#EDF7ED"; color="#2E7D32"; penwidth=2;

        SCN [label="SCN\n(시상하부 교차핵)", fillcolor="#C8E6C9"]
        CLOCK_BMAL1 [label="CLOCK/BMAL1\n(일주기 유전자)", fillcolor="#C8E6C9"]
        Light_input [label="광자극\n(Light Input)", fillcolor="#A5D6A7"]
        stress_input [label="스트레스 입력\n(NE/Glu signal)", fillcolor="#FFCCBC"]
        CRH_neuron [label="CRH 뉴런\n(PVN 실방핵)", fillcolor="#80CBC4"]
        CRH [label="CRH\n(코르티코트로핀 유리 호르몬)", fillcolor="#4DB6AC", style="filled,rounded,bold"]
        AVP [label="AVP\n(아르기닌 바소프레신)", fillcolor="#4DB6AC"]
        Somatostatin_hyp [label="소마토스타틴\n(SRIF)", fillcolor="#B2DFDB"]
        Dopamine_hyp [label="도파민\n(DA, 시상하부)", fillcolor="#B2DFDB"]
        NPY_AgRP [label="NPY/AgRP\n(시상하부 식욕 펩타이드)", fillcolor="#C8E6C9"]
        GABA_hyp [label="GABA\n(억제성 신경전달)", fillcolor="#DCEDC8"]
        Beta_endorphin_hyp [label="β-엔도르핀\n(시상하부 오피오이드)", fillcolor="#C8E6C9"]
        Norepinephrine_stress [label="노르에피네프린\n(스트레스 반응)", fillcolor="#FFCCBC"]
        Circadian_drive [label="일주기 CRH 리듬\n(아침 피크, 오후 저점)", fillcolor="#C8E6C9"]
    }

    // ============================================================
    // CLUSTER 2: PITUITARY (ANTERIOR)
    // ============================================================
    subgraph cluster_pituitary {
        label="🔴 뇌하수체 전엽 (Anterior Pituitary)\n코르티코트로프 세포";
        fontsize=13; fontname="Helvetica-Bold";
        style=filled; fillcolor="#FFF3E0"; color="#E65100"; penwidth=2;

        CRHR1 [label="CRHR1\n(CRH 수용체 1형)", fillcolor="#FFE0B2"]
        V1bR [label="V1bR\n(바소프레신 수용체)", fillcolor="#FFE0B2"]
        Gs_pit [label="Gs 단백질\n(cAMP 신호)", fillcolor="#FFCC02"]
        PKA_pit [label="단백질 키나제 A\n(PKA-pit)", fillcolor="#FFB300"]
        CREB_pit [label="CREB\n(전사 인자)", fillcolor="#FF8F00"]
        POMC [label="POMC\n(프로오피오멜라노코르틴)", fillcolor="#FF6D00", style="filled,rounded,bold"]
        PC1_2 [label="전호르몬 전환효소\n(PC1/PC2)", fillcolor="#FFAB40"]
        ACTH [label="ACTH\n(부신피질 자극 호르몬)", fillcolor="#FF6D00", style="filled,rounded,bold"]
        GR_pit [label="GR-α\n(뇌하수체 글루코코르티코이드 수용체)", fillcolor="#FFAB40"]
        USP8 [label="USP8\n(유비퀴틴 특이 펩티다제 8)\n[쿠싱병 돌연변이 ~50%]", fillcolor="#FF7043"]
        EGFR_pit [label="EGFR\n(상피성장인자 수용체-pit)", fillcolor="#FFCCBC"]
        CDK4_6 [label="CDK4/6\n(사이클린 의존성 키나제)", fillcolor="#FF8A65"]
        Rb_protein [label="Rb 단백질\n(세포주기 억제)", fillcolor="#FF8A65"]
        NFkB_pit [label="NF-κB\n(전염증 전사 인자-pit)", fillcolor="#FFAB40"]
        corticotroph_prolif [label="코르티코트로프\n세포 증식", fillcolor="#FFCC02"]
        pit_adenoma [label="뇌하수체 선종\n(ACTH 분비 종양)", fillcolor="#FF3D00", style="filled,bold"]
    }

    // ============================================================
    // CLUSTER 3: ADRENAL CORTEX STEROIDOGENESIS
    // ============================================================
    subgraph cluster_adrenal {
        label="🟡 부신피질 스테로이드 생합성 (Adrenal Steroidogenesis)\n사속대 (Zona Fasciculata)";
        fontsize=13; fontname="Helvetica-Bold";
        style=filled; fillcolor="#FFFDE7"; color="#F9A825"; penwidth=2;

        MC2R [label="MC2R\n(ACTH 수용체)", fillcolor="#FFF9C4"]
        Gs_adr [label="Gs/Gi 단백질\n(부신 신호)", fillcolor="#FFF176"]
        cAMP_adrenal [label="cAMP↑\n(부신 내)", fillcolor="#FFEE58"]
        PKA_adrenal [label="PKA\n(부신 단백질 키나제 A)", fillcolor="#FFD600"]
        StAR [label="StAR\n(스테로이드 생합성 조절 단백질)", fillcolor="#FFAB00", style="filled,rounded,bold"]
        Cholesterol [label="콜레스테롤\n(미토콘드리아 내막)", fillcolor="#FFC107"]
        CYP11A1 [label="CYP11A1\n(콜레스테롤 desmolase, P450scc)", fillcolor="#FF8F00", style="filled,rounded,bold"]
        Pregnenolone [label="프레그네놀론\n(Pregnenolone)", fillcolor="#FFB300"]
        HSD3B2 [label="HSD3B2\n(3β-HSD 2형)", fillcolor="#FFA000"]
        CYP17A1 [label="CYP17A1\n(17α-수산화효소/lyase)", fillcolor="#FF8F00", style="filled,rounded,bold"]
        Progesterone [label="프로게스테론\n(Progesterone)", fillcolor="#FFB300"]
        OHP17 [label="17-OH-프로게스테론\n(17-OHP)", fillcolor="#FFB300"]
        CYP21A2 [label="CYP21A2\n(21-수산화효소)", fillcolor="#FFA000"]
        Deoxycortisol [label="11-데옥시코르티솔\n(11-Deoxycortisol, S)", fillcolor="#FFB300"]
        CYP11B1 [label="CYP11B1\n(11β-수산화효소)", fillcolor="#FF6F00", style="filled,rounded,bold"]
        Cortisol_adrenal [label="코르티솔\n(부신 내)", fillcolor="#FF6D00", style="filled,rounded,bold"]
        HSD11B1 [label="HSD11B1\n(11β-HSD 1형, 코르티솔 재활성화)", fillcolor="#FFA726"]
        HSD11B2 [label="HSD11B2\n(11β-HSD 2형, 코르티솔 불활성화)", fillcolor="#FFA726"]
        Cortisone [label="코르티손\n(Cortisone, 불활성)", fillcolor="#FFCC80"]
        adrenal_adenoma [label="부신 선종\n(ACTH-비의존형 CS)", fillcolor="#FF6D00", style="filled,bold"]
        CYP11B2 [label="CYP11B2\n(알도스테론 합성효소)", fillcolor="#FFA000"]
        Aldosterone_adr [label="알도스테론\n(Aldosterone)", fillcolor="#FFB300"]
    }

    // ============================================================
    // CLUSTER 4: GLUCOCORTICOID RECEPTOR SIGNALING
    // ============================================================
    subgraph cluster_GR {
        label="⚡ 글루코코르티코이드 수용체 신호 (GR Signaling)";
        fontsize=13; fontname="Helvetica-Bold";
        style=filled; fillcolor="#E8EAF6"; color="#3949AB"; penwidth=2;

        Cortisol_plasma [label="혈장 코르티솔\n(Free Cortisol, μg/dL)", fillcolor="#C5CAE9", style="filled,rounded,bold"]
        CBG [label="CBG\n(코르티코스테로이드 결합 글로불린)", fillcolor="#9FA8DA"]
        Albumin_bind [label="알부민 결합\n(낮은 친화도, 고용량)", fillcolor="#9FA8DA"]
        Cortisol_bound [label="결합형 코르티솔\n(~95%, 비활성)", fillcolor="#7986CB"]
        GR_alpha [label="GR-α\n(글루코코르티코이드 수용체 α)", fillcolor="#5C6BC0", style="filled,rounded,bold"]
        GR_beta [label="GR-β\n(우성음성 GR, 저항성 유발)", fillcolor="#7986CB"]
        HSP90 [label="HSP90\n(열충격 단백질 90)", fillcolor="#9FA8DA"]
        FKBP51 [label="FKBP51\n(음성 조절자, GR-cortisol 친화도↓)", fillcolor="#7986CB"]
        FKBP52 [label="FKBP52\n(양성 조절자, GR 핵이동↑)", fillcolor="#9FA8DA"]
        GR_cortisol_complex [label="GR-코르티솔 복합체\n(세포질)", fillcolor="#3F51B5"]
        GR_nuclear [label="GR 핵 이동\n(이량체화 → GRE 결합)", fillcolor="#283593", style="filled,rounded,bold"]
        GRE [label="GRE\n(글루코코르티코이드 반응 요소)\n→ 전사 활성화", fillcolor="#1A237E", fontcolor="white"]
        nGRE [label="nGRE\n(음성 GRE)\n→ 전사 억제 (CRH, POMC)", fillcolor="#1A237E", fontcolor="white"]
        AP1_tether [label="AP-1 접촉 억제\n(염증 유전자 억제)", fillcolor="#3949AB", fontcolor="white"]
        NFkB_tether [label="NF-κB 접촉 억제\n(사이토카인 억제)", fillcolor="#3949AB", fontcolor="white"]
        GILZ [label="GILZ\n(글루코코르티코이드 유도 루이신 지퍼)", fillcolor="#5C6BC0"]
        MKP1 [label="MKP1\n(MAPK 포스파타제 1)", fillcolor="#5C6BC0"]
        SGK1 [label="SGK1\n(혈청 글루코코르티코이드 키나제 1)", fillcolor="#5C6BC0"]
        GR_down_reg [label="GR 하향 조절\n(만성 노출 시)", fillcolor="#7986CB"]
    }

    // ============================================================
    // CLUSTER 5: METABOLIC COMPLICATIONS
    // ============================================================
    subgraph cluster_metabolic {
        label="🔥 대사 합병증 (Metabolic Complications)";
        fontsize=13; fontname="Helvetica-Bold";
        style=filled; fillcolor="#FCE4EC"; color="#C62828"; penwidth=2;

        PEPCK [label="PEPCK↑\n(간 당신생 효소)", fillcolor="#F8BBD0"]
        G6Pase [label="G6Pase↑\n(포도당-6-인산 가수분해효소)", fillcolor="#F8BBD0"]
        Hepatic_glucose [label="간 포도당 생성↑\n(Hepatic Glucose Output)", fillcolor="#EF9A9A"]
        GLUT4 [label="GLUT4↓\n(포도당 수송체 4형 감소)", fillcolor="#EF9A9A"]
        IRS1_serine [label="IRS-1 세린 인산화\n(인슐린 저항성 핵심)", fillcolor="#E57373"]
        IR_resistance [label="인슐린 저항성\n(말초 조직)", fillcolor="#EF5350", style="filled,rounded,bold"]
        Blood_glucose [label="혈당 상승\n(고혈당증)", fillcolor="#F44336", style="filled,rounded,bold"]
        Insulin_plasma [label="혈장 인슐린↑\n(보상성 과인슐린혈증)", fillcolor="#E53935"]
        Beta_cell_stress [label="췌장 β세포 스트레스\n(장기 손상)", fillcolor="#C62828"]

        Adiponectin_low [label="아디포넥틴↓\n(인슐린 감작 호르몬 감소)", fillcolor="#FFCDD2"]
        Leptin_high [label="렙틴↑\n(렙틴 저항성)", fillcolor="#FFCDD2"]
        Adipogenesis [label="중심성 지방 축적\n(Adipogenesis↑)", fillcolor="#EF9A9A"]
        Lipolysis_FFA [label="유리지방산↑\n(Lipolysis → FFA)", fillcolor="#EF9A9A"]
        VAT_expansion [label="내장지방 축적\n(Visceral Adipose Tissue)", fillcolor="#E53935", style="filled,rounded,bold"]
        Subcutaneous_atrophy [label="피하지방 위축\n(Subcutaneous Atrophy)", fillcolor="#FFCDD2"]

        Atrogin1_MuRF1 [label="Atrogin-1/MuRF1↑\n(근육 E3 유비퀴틴 리가제)", fillcolor="#EF9A9A"]
        Myostatin [label="미오스타틴↑\n(근육 성장 억제)", fillcolor="#EF9A9A"]
        IGF1_suppressed [label="IGF-1↓\n(근육 동화 감소)", fillcolor="#FFCDD2"]
        Muscle_wasting [label="근육 소모\n(Muscle Wasting/Weakness)", fillcolor="#E53935", style="filled,rounded,bold"]

        RANKL_up [label="RANKL↑\n(파골세포 활성화)", fillcolor="#EF9A9A"]
        OPG_down [label="OPG↓\n(골보호 인자 감소)", fillcolor="#EF9A9A"]
        Osteoblast_inh [label="조골세포 억제\n(Osteoblast Inhibition)", fillcolor="#EF9A9A"]
        Calcium_absorption [label="장내 칼슘 흡수↓\n(Vitamin D 길항)", fillcolor="#FFCDD2"]
        Osteoporosis [label="골다공증\n(Osteoporosis)", fillcolor="#E53935", style="filled,rounded,bold"]
    }

    // ============================================================
    // CLUSTER 6: CARDIOVASCULAR & RENAL EFFECTS
    // ============================================================
    subgraph cluster_cardio {
        label="💗 심혈관·신장 효과 (Cardiovascular & Renal Effects)";
        fontsize=13; fontname="Helvetica-Bold";
        style=filled; fillcolor="#E3F2FD"; color="#1565C0"; penwidth=2;

        Angiotensinogen [label="안지오텐시노겐\n(간 생성, GC 자극↑)", fillcolor="#BBDEFB"]
        Renin [label="레닌\n(Renin)", fillcolor="#90CAF9"]
        Angiotensin_I [label="안지오텐신 I\n(Angiotensin I)", fillcolor="#64B5F6"]
        ACE [label="ACE\n(안지오텐신 전환 효소)", fillcolor="#42A5F5"]
        Angiotensin_II [label="안지오텐신 II\n(Angiotensin II)", fillcolor="#2196F3"]
        AT1R [label="AT1R\n(Ang II 수용체)", fillcolor="#1E88E5"]
        Aldosterone_CV [label="알도스테론\n(Aldosterone, RAAS)", fillcolor="#1976D2"]
        Na_retention [label="나트륨 저류\n(Na Retention)", fillcolor="#1565C0", fontcolor="white"]
        Volume_expansion [label="혈장량 증가\n(Volume Expansion)", fillcolor="#0D47A1", fontcolor="white"]
        BP_elevation [label="혈압 상승\n(Hypertension)", fillcolor="#0D47A1", fontcolor="white", style="filled,rounded,bold"]
        EndothelinA [label="엔도텔린-1↑\n(혈관 수축)", fillcolor="#1565C0", fontcolor="white"]
        NO_decrease [label="산화질소↓\n(내피 기능 부전)", fillcolor="#1976D2"]
        Dyslipidemia [label="이상지질혈증\n(LDL↑, HDL↓)", fillcolor="#1E88E5"]
        CV_risk [label="심혈관 사건 위험\n(CV Risk ↑↑)", fillcolor="#1565C0", fontcolor="white", style="filled,rounded,bold"]
        Proteinuria [label="단백뇨\n(신장 손상)", fillcolor="#42A5F5"]
        GFR_decline [label="GFR 감소\n(사구체 과여과 후)", fillcolor="#64B5F6"]
        Hypercoagulability [label="과응고 상태\n(VTE 위험↑)", fillcolor="#90CAF9"]
    }

    // ============================================================
    // CLUSTER 7: IMMUNE SUPPRESSION
    // ============================================================
    subgraph cluster_immune {
        label="🛡️ 면역 억제 (Immune Suppression)";
        fontsize=13; fontname="Helvetica-Bold";
        style=filled; fillcolor="#F3E5F5"; color="#6A1B9A"; penwidth=2;

        Th1_suppression [label="Th1↓\n(세포 매개 면역 억제)", fillcolor="#E1BEE7"]
        Th2_shift [label="Th2 편향\n(체액 면역 상대적 증가)", fillcolor="#CE93D8"]
        Th17_inh [label="Th17↓\n(IL-17 억제)", fillcolor="#BA68C8"]
        Treg_change [label="Treg 변화\n(Treg 증가/기능 변화)", fillcolor="#CE93D8"]
        NK_cell_inh [label="NK세포↓\n(자연살해세포 억제)", fillcolor="#AB47BC"]
        Neutrophil_demarg [label="중성구 탈변연화\n(WBC↑, 기능 저하)", fillcolor="#9C27B0"]
        Lymphopenia [label="림프구 감소증\n(Lymphopenia)", fillcolor="#7B1FA2", fontcolor="white", style="filled,rounded,bold"]
        IL6_suppressed [label="IL-6↓\n(사이토카인 억제)", fillcolor="#CE93D8"]
        TNFa_suppressed [label="TNF-α↓\n(사이토카인 억제)", fillcolor="#CE93D8"]
        CRP_acute [label="CRP↑\n(급성기 단백, 일부 증가)", fillcolor="#BA68C8"]
        Infection_risk [label="감염 위험 증가\n(기회감염 포함)", fillcolor="#6A1B9A", fontcolor="white", style="filled,rounded,bold"]
        Wound_healing [label="상처 치유 지연\n(Impaired Wound Healing)", fillcolor="#7B1FA2", fontcolor="white"]
    }

    // ============================================================
    // CLUSTER 8: CNS & PSYCHIATRIC EFFECTS
    // ============================================================
    subgraph cluster_CNS {
        label="🧠 중추신경계 효과 (CNS & Psychiatric Effects)";
        fontsize=13; fontname="Helvetica-Bold";
        style=filled; fillcolor="#E8F5E9"; color="#1B5E20"; penwidth=2;

        Hippocampus_vol [label="해마 위축\n(Hippocampal Volume↓)", fillcolor="#C8E6C9", style="filled,rounded,bold"]
        BDNF_CNS [label="BDNF↓\n(뇌유래 신경영양인자)", fillcolor="#A5D6A7"]
        Neurogenesis_inh [label="신경 발생 억제\n(Neurogenesis↓)", fillcolor="#81C784"]
        NMDAR_exc [label="NMDA 수용체 흥분 독성\n(Glutamate Excitotoxicity)", fillcolor="#66BB6A"]
        Serotonin_inh [label="세로토닌계 억제\n(5-HT↓)", fillcolor="#4CAF50"]
        HPA_CNS_feedback [label="CNS-HPA 피드백\n(해마 GR 신호)", fillcolor="#388E3C"]
        Depression [label="우울증\n(Depression, 빈도 50-70%)", fillcolor="#2E7D32", fontcolor="white", style="filled,rounded,bold"]
        Anxiety_CS [label="불안 장애\n(Anxiety Disorders)", fillcolor="#33691E", fontcolor="white"]
        Cognitive_impair [label="인지 기능 저하\n(Cognitive Impairment)", fillcolor="#2E7D32", fontcolor="white"]
        Insomnia_CS [label="불면증\n(Circadian Disruption)", fillcolor="#388E3C", fontcolor="white"]
        Psychosis_CS [label="정신병 증상\n(Steroid Psychosis, rare)", fillcolor="#1B5E20", fontcolor="white"]
        GR_CNS [label="GR-α/MR\n(CNS 글루코코르티코이드 수용체)", fillcolor="#81C784"]
    }

    // ============================================================
    // CLUSTER 9: PASIREOTIDE PK/PD
    // ============================================================
    subgraph cluster_pasireotide {
        label="💊 파시레오티드 PK/PD (Pasireotide)\nSomatostatin Receptor Ligand";
        fontsize=13; fontname="Helvetica-Bold";
        style=filled; fillcolor="#E0F7FA"; color="#006064"; penwidth=2;

        Pas_dose [label="파시레오티드 투여\n(0.3-0.9mg BID SC)", shape=diamond, fillcolor="#B2EBF2"]
        A_pas_SC [label="A_pas_SC\n(피하 흡수 구획)", fillcolor="#80DEEA"]
        A_pas_C [label="A_pas_C\n(혈장 중심 구획)", fillcolor="#4DD0E1", style="filled,rounded,bold"]
        A_pas_P [label="A_pas_P\n(말초 구획)", fillcolor="#26C6DA"]
        SSTR1 [label="SSTR1\n(소마토스타틴 수용체 1)", fillcolor="#00ACC1"]
        SSTR2 [label="SSTR2\n(소마토스타틴 수용체 2)", fillcolor="#0097A7"]
