digraph DCM_QSP {
  graph [
    rankdir=LR,
    fontname="Helvetica",
    fontsize=12,
    bgcolor="#F5F7FA",
    label="Dilated Cardiomyopathy (DCM) — Comprehensive QSP Mechanistic Map\nDrug Classes: ACEi · ARB · Beta-blocker · MRA · ARNI · SGLT2i · Ivabradine · Levosimendan",
    labelloc=t,
    labeljust=c,
    pad=0.5,
    splines=curved
  ];
  node [fontname="Helvetica", fontsize=9, style="filled,rounded", fillcolor=white, margin="0.1,0.05"];
  edge [fontname="Helvetica", fontsize=8, arrowsize=0.7];

  /* ============================================================
     CLUSTER 1: GENETIC & MOLECULAR BASIS
  ============================================================ */
  subgraph cluster_genetics {
    label="Genetic & Molecular Basis";
    color="#7B2D8B";
    style=filled;
    fillcolor="#F3E5F5";
    fontcolor="#7B2D8B";
    fontsize=11;
    penwidth=2;

    TTN        [label="TTN\n(Titin ~25%)",       shape=box, fillcolor="#CE93D8", fontcolor=black];
    MYH7       [label="MYH7\n(β-MHC ~4%)",       shape=box, fillcolor="#CE93D8"];
    LMNA       [label="LMNA\n(Lamin A/C ~6%)",   shape=box, fillcolor="#CE93D8"];
    SCN5A      [label="SCN5A\n(Nav1.5 ~2%)",      shape=box, fillcolor="#CE93D8"];
    RBM20      [label="RBM20\n(RNA-BP ~2%)",      shape=box, fillcolor="#CE93D8"];
    PLN        [label="PLN\n(Phospholamban)",     shape=box, fillcolor="#CE93D8"];
    FLNC       [label="FLNC\n(Filamin C)",        shape=box, fillcolor="#CE93D8"];
    BAG3       [label="BAG3\n(Co-chaperone)",     shape=box, fillcolor="#CE93D8"];
    DSP        [label="DSP\n(Desmoplakin)",       shape=box, fillcolor="#CE93D8"];
    TNNT2      [label="TNNT2\n(Troponin T gene)", shape=box, fillcolor="#CE93D8"];

    SarcomereDefect    [label="Sarcomere\nDysfunction",     shape=diamond, fillcolor="#AB47BC", fontcolor=white];
    CytoskeletalDefect [label="Cytoskeletal\nDisruption",   shape=diamond, fillcolor="#AB47BC", fontcolor=white];
    CalciumHandling    [label="Ca²⁺ Handling\nDefect",      shape=diamond, fillcolor="#AB47BC", fontcolor=white];
    NuclearLamina      [label="Nuclear Lamina\nInstability", shape=diamond, fillcolor="#AB47BC", fontcolor=white];
  }

  /* ============================================================
     CLUSTER 2: CARDIOMYOCYTE PATHOPHYSIOLOGY
  ============================================================ */
  subgraph cluster_cardiomyocyte {
    label="Cardiomyocyte Pathophysiology";
    color="#C62828";
    style=filled;
    fillcolor="#FFEBEE";
    fontcolor="#C62828";
    fontsize=11;
    penwidth=2;

    MyocyteHypertrophy [label="Myocyte\nHypertrophy",        shape=oval, fillcolor="#EF9A9A"];
    MyocyteApoptosis   [label="Myocyte Apoptosis\n(Caspase-3↑)", shape=oval, fillcolor="#EF9A9A"];
    MyocyteNecrosis    [label="Myocyte\nNecrosis",            shape=oval, fillcolor="#EF9A9A"];
    Autophagy          [label="Autophagy\nImpairment",        shape=oval, fillcolor="#FFCDD2"];
    MitoDysfunction    [label="Mitochondrial\nDysfunction",   shape=oval, fillcolor="#FFCDD2"];
    OxidativeStress    [label="ROS / Oxidative\nStress",      shape=oval, fillcolor="#EF9A9A"];
    ERstress           [label="ER Stress\n(UPR↑)",            shape=oval, fillcolor="#FFCDD2"];
    CalciumOverload    [label="Ca²⁺ Overload\n(Cytosolic)",   shape=oval, fillcolor="#EF9A9A"];
    SERCA2a            [label="SERCA2a\n(Activity↓)",         shape=box, fillcolor="#FFCDD2"];
    NCX                [label="NCX1\n(Reverse mode↑)",        shape=box, fillcolor="#FFCDD2"];
    RyR2               [label="RyR2\n(Leaky channels)",       shape=box, fillcolor="#FFCDD2"];
    ATP_depletion      [label="ATP\nDepletion",               shape=oval, fillcolor="#EF9A9A"];
    TroponinI          [label="Troponin I\n(cTnI ↑)",         shape=hexagon, fillcolor="#FFCDD2"];
    TroponinT          [label="Troponin T\n(cTnT ↑)",         shape=hexagon, fillcolor="#FFCDD2"];
  }

  /* ============================================================
     CLUSTER 3: RAAS PATHWAY
  ============================================================ */
  subgraph cluster_raas {
    label="RAAS Pathway";
    color="#1565C0";
    style=filled;
    fillcolor="#E3F2FD";
    fontcolor="#1565C0";
    fontsize=11;
    penwidth=2;

    Angiotensinogen [label="Angiotensinogen\n(Liver)",        shape=box, fillcolor="#90CAF9"];
    Renin           [label="Renin\n(Kidney JGA)",             shape=box, fillcolor="#64B5F6"];
    AngI            [label="Angiotensin I\n(inactive)",       shape=oval, fillcolor="#90CAF9"];
    ACE             [label="ACE\n(Lung/Endothelium)",         shape=box, fillcolor="#64B5F6"];
    AngII           [label="Angiotensin II\n(active)",        shape=oval, fillcolor="#1E88E5", fontcolor=white];
    AT1R            [label="AT1R\n(AT1 receptor)",            shape=box, fillcolor="#42A5F5"];
    AT2R            [label="AT2R\n(cardioprotective)",        shape=box, fillcolor="#42A5F5"];
    Aldosterone     [label="Aldosterone\n(Adrenal cortex)",   shape=oval, fillcolor="#64B5F6"];
    MR_receptor     [label="MR\n(Mineralocorticoid-R)",       shape=box, fillcolor="#42A5F5"];
    NEP             [label="NEP\n(Neprilysin)",               shape=box, fillcolor="#90CAF9"];
    Chymase         [label="Chymase\n(ACE-independent)",      shape=box, fillcolor="#BBDEFB"];
    Ang17           [label="Ang(1-7)\n(Mas receptor)",        shape=oval, fillcolor="#90CAF9"];
    ACE2            [label="ACE2\n(Protective)",              shape=box, fillcolor="#42A5F5"];
  }

  /* ============================================================
     CLUSTER 4: SYMPATHETIC NERVOUS SYSTEM
  ============================================================ */
  subgraph cluster_sns {
    label="Sympathetic Nervous System";
    color="#E65100";
    style=filled;
    fillcolor="#FFF3E0";
    fontcolor="#E65100";
    fontsize=11;
    penwidth=2;

    HPAA            [label="HPA Axis\n(Stress Response)",      shape=box, fillcolor="#FFCC80"];
    Norepinephrine  [label="Norepinephrine\n(NE)",             shape=oval, fillcolor="#FF9800", fontcolor=white];
    Epinephrine     [label="Epinephrine\n(Epi)",               shape=oval, fillcolor="#FF9800", fontcolor=white];
    Beta1R          [label="β1-Adrenoreceptor\n(Heart↓)",      shape=box, fillcolor="#FFB74D"];
    Beta2R          [label="β2-Adrenoreceptor\n(Vasodilation)", shape=box, fillcolor="#FFB74D"];
    Alpha1R         [label="α1-Adrenoreceptor\n(Vasoconstriction)", shape=box, fillcolor="#FFB74D"];
    cAMP            [label="cAMP\n(2nd messenger)",            shape=oval, fillcolor="#FFCC80"];
    PKA             [label="PKA\n(Protein kinase A)",          shape=oval, fillcolor="#FFCC80"];
    HR_SNS          [label="Heart Rate\n(SNS↑)",               shape=oval, fillcolor="#FF9800", fontcolor=white];
    Inotropy        [label="Inotropy\n(Contractility)",        shape=oval, fillcolor="#FFB74D"];
    Vasoconstriction [label="Vasoconstriction\n(SVR↑)",        shape=oval, fillcolor="#FFB74D"];
    NE_spillover    [label="NE Spillover\n(Cardiac toxicity)", shape=oval, fillcolor="#FF9800", fontcolor=white];
    HF              [label="HCN4 Channel\n(If current)",       shape=box, fillcolor="#FFCC80"];
  }

  /* ============================================================
     CLUSTER 5: INFLAMMATION & CYTOKINES
  ============================================================ */
  subgraph cluster_inflammation {
    label="Inflammation & Immune Activation";
    color="#2E7D32";
    style=filled;
    fillcolor="#E8F5E9";
    fontcolor="#2E7D32";
    fontsize=11;
    penwidth=2;

    Macrophage_M1  [label="M1 Macrophage\n(pro-inflammatory)", shape=oval, fillcolor="#A5D6A7"];
    Macrophage_M2  [label="M2 Macrophage\n(anti-inflammatory)", shape=oval, fillcolor="#A5D6A7"];
    TNFalpha       [label="TNF-α\n(cytotoxic)",               shape=oval, fillcolor="#66BB6A", fontcolor=white];
    IL1beta        [label="IL-1β",                            shape=oval, fillcolor="#66BB6A", fontcolor=white];
    IL6            [label="IL-6\n(cardiac depressant)",       shape=oval, fillcolor="#66BB6A", fontcolor=white];
    IL10           [label="IL-10\n(anti-inflammatory)",       shape=oval, fillcolor="#A5D6A7"];
    IL18           [label="IL-18",                            shape=oval, fillcolor="#81C784"];
    TGFbeta        [label="TGF-β\n(pro-fibrotic)",           shape=oval, fillcolor="#66BB6A", fontcolor=white];
    MCP1           [label="MCP-1\n(CCL2)",                   shape=oval, fillcolor="#A5D6A7"];
    NFkB           [label="NF-κB\n(Transcription factor)",   shape=diamond, fillcolor="#43A047", fontcolor=white];
    CRP            [label="CRP\n(Inflammation marker)",      shape=hexagon, fillcolor="#C8E6C9"];
    CD4T           [label="CD4⁺ T-cells\n(Th1/Th2/Th17)",   shape=oval, fillcolor="#A5D6A7"];
    CD8T           [label="CD8⁺ T-cells\n(Cytotoxic)",       shape=oval, fillcolor="#A5D6A7"];
    Mast_cell      [label="Mast Cells\n(Histamine, proteases)", shape=oval, fillcolor="#C8E6C9"];
    NLRP3          [label="NLRP3\nInflammasome",             shape=box, fillcolor="#81C784"];
  }

  /* ============================================================
     CLUSTER 6: FIBROSIS & ECM REMODELING
  ============================================================ */
  subgraph cluster_fibrosis {
    label="Cardiac Fibrosis & ECM Remodeling";
    color="#6D4C41";
    style=filled;
    fillcolor="#EFEBE9";
    fontcolor="#6D4C41";
    fontsize=11;
    penwidth=2;

    Fibroblast     [label="Cardiac\nFibroblast",             shape=oval, fillcolor="#BCAAA4"];
    MyoFibroblast  [label="Myofibroblast\n(α-SMA+)",         shape=oval, fillcolor="#8D6E63", fontcolor=white];
    CollagenI      [label="Collagen I\n(stiff ECM)",         shape=box, fillcolor="#A1887F"];
    CollagenIII    [label="Collagen III\n(compliant ECM)",   shape=box, fillcolor="#A1887F"];
    LOX            [label="LOX\n(Crosslinking)",             shape=box, fillcolor="#BCAAA4"];
    MMP2           [label="MMP-2\n(Gelatinase A)",           shape=box, fillcolor="#BCAAA4"];
    MMP9           [label="MMP-9\n(Gelatinase B)",           shape=box, fillcolor="#BCAAA4"];
    TIMP1          [label="TIMP-1\n(MMP inhibitor)",         shape=box, fillcolor="#D7CCC8"];
    TIMP2          [label="TIMP-2\n(MMP inhibitor)",         shape=box, fillcolor="#D7CCC8"];
    Fibrosis_frac  [label="Interstitial\nFibrosis (%)",      shape=hexagon, fillcolor="#8D6E63", fontcolor=white];
    PICP           [label="PICP\n(Collagen synthesis marker)", shape=hexagon, fillcolor="#BCAAA4"];
    PIIINP         [label="PIIINP\n(Fibrosis biomarker)",    shape=hexagon, fillcolor="#BCAAA4"];
    Galectin3      [label="Galectin-3\n(Fibrosis marker)",   shape=hexagon, fillcolor="#D7CCC8"];
    STIFFNESS      [label="Myocardial\nStiffness (↑)",       shape=diamond, fillcolor="#8D6E63", fontcolor=white];
  }

  /* ============================================================
     CLUSTER 7: CARDIAC MECHANICS & HEMODYNAMICS
  ============================================================ */
  subgraph cluster_mechanics {
    label="Cardiac Mechanics & Hemodynamics";
    color="#1A237E";
    style=filled;
    fillcolor="#E8EAF6";
    fontcolor="#1A237E";
    fontsize=11;
    penwidth=2;

    LVEF           [label="LVEF\n(normal >55%)",             shape=hexagon, fillcolor="#7986CB", fontcolor=white];
    LVEDV          [label="LVEDV\n(↑ in DCM)",               shape=hexagon, fillcolor="#7986CB", fontcolor=white];
    LVESV          [label="LVESV\n(↑ in DCM)",               shape=hexagon, fillcolor="#7986CB", fontcolor=white];
    StrokeVolume   [label="Stroke Volume\n(SV = LVEDV-LVESV)", shape=oval, fillcolor="#9FA8DA"];
    CardiacOutput  [label="Cardiac Output\n(CO = HR × SV)", shape=oval, fillcolor="#9FA8DA"];
    PCWP           [label="PCWP\n(Wedge pressure ↑)",        shape=oval, fillcolor="#9FA8DA"];
    RAP            [label="RAP\n(Right atrial pressure)",    shape=oval, fillcolor="#C5CAE9"];
    LVEDP          [label="LVEDP\n(End-diastolic pressure)", shape=oval, fillcolor="#9FA8DA"];
    MAP_hemo       [label="MAP\n(Mean arterial pressure)",   shape=oval, fillcolor="#9FA8DA"];
    SVR            [label="SVR\n(Systemic vascular resistance)", shape=oval, fillcolor="#C5CAE9"];
    PVR            [label="PVR\n(Pulmonary vascular resistance)", shape=oval, fillcolor="#C5CAE9"];
    LVmass         [label="LV Mass\n(g/m²)",                 shape=hexagon, fillcolor="#9FA8DA"];
    LVFW           [label="LV Wall\nThickness (thin)",       shape=oval, fillcolor="#C5CAE9"];
    GLS            [label="GLS\n(Global Long. Strain)",      shape=hexagon, fillcolor="#7986CB", fontcolor=white];
    TAPSE          [label="TAPSE\n(RV function)",            shape=hexagon, fillcolor="#C5CAE9"];
  }

  /* ============================================================
     CLUSTER 8: NATRIURETIC PEPTIDE SYSTEM
  ============================================================ */
  subgraph cluster_bnp {
    label="Natriuretic Peptide System";
    color="#00838F";
    style=filled;
    fillcolor="#E0F7FA";
    fontcolor="#00838F";
    fontsize=11;
    penwidth=2;

    ANP            [label="ANP\n(Atrial NP)",                shape=oval, fillcolor="#4DD0E1"];
    BNP            [label="BNP\n(B-type NP, ↑ in HF)",      shape=hexagon, fillcolor="#00ACC1", fontcolor=white];
    NT_proBNP      [label="NT-proBNP\n(inactive fragment)",  shape=hexagon, fillcolor="#00ACC1", fontcolor=white];
    CNP            [label="CNP\n(C-type NP)",                shape=oval, fillcolor="#80DEEA"];
    NPRA           [label="NPR-A\n(GC-A receptor)",          shape=box, fillcolor="#4DD0E1"];
    NPRB           [label="NPR-B\n(GC-B receptor)",          shape=box, fillcolor="#4DD0E1"];
    cGMP_bnp       [label="cGMP\n(vasodilator, natriuretic)", shape=oval, fillcolor="#80DEEA"];
    NEP_BNP        [label="NEP (Neprilysin)\nBNP degradation", shape=box, fillcolor="#B2EBF2"];
    PKG            [label="PKG\n(cGMP-dependent PK)",        shape=oval, fillcolor="#B2EBF2"];
    Natriuresis    [label="Natriuresis\n& Diuresis",         shape=oval, fillcolor="#80DEEA"];
  }

  /* ============================================================
     CLUSTER 9: DRUG PK/PD
  ============================================================ */
  subgraph cluster_drugs {
    label="Drug Pharmacokinetics & Pharmacodynamics";
    color="#E65100";
    style=filled;
    fillcolor="#FFF8E1";
    fontcolor="#E65100";
    fontsize=11;
    penwidth=2;

    /* ACEi */
    Enalapril      [label="Enalapril\n(ACEi)",               shape=box, fillcolor="#FFCA28", fontcolor=black];
    Enalaprilat    [label="Enalaprilat\n(active)",           shape=box, fillcolor="#FFB300", fontcolor=black];

    /* ARB */
    Valsartan      [label="Valsartan\n(ARB)",                shape=box, fillcolor="#FFCA28"];
    Losartan       [label="Losartan\n(ARB)",                 shape=box, fillcolor="#FFE082"];

    /* Beta-blocker */
    Carvedilol     [label="Carvedilol\n(β1/β2/α1 blocker)",  shape=box, fillcolor="#FFA726", fontcolor=black];
    Metoprolol     [label="Metoprolol\n(β1-selective)",      shape=box, fillcolor="#FFB74D"];

    /* MRA */
    Spironolactone [label="Spironolactone\n(MRA)",           shape=box, fillcolor="#FFCA28"];
    Eplerenone     [label="Eplerenone\n(selective MRA)",     shape=box, fillcolor="#FFE082"];

    /* ARNI */
    Sacubitril     [label="Sacubitril\n(NEP inhibitor)",     shape=box, fillcolor="#FF7043", fontcolor=white];
    LBQ657         [label="LBQ657\n(active neprilysin inh)", shape=box, fillcolor="#FF8A65"];
    ARNI_combo     [label="Sacubitril/\nValsartan (ARNI)",   shape=diamond, fillcolor="#FF5722", fontcolor=white];

    /* SGLT2i */
    Dapagliflozin  [label="Dapagliflozin\n(SGLT2i)",         shape=box, fillcolor="#FFA000", fontcolor=white];
    Empagliflozin  [label="Empagliflozin\n(SGLT2i)",         shape=box, fillcolor="#FFB300", fontcolor=black];

    /* HCN blocker */
    Ivabradine     [label="Ivabradine\n(HCN4/If blocker)",   shape=box, fillcolor="#FF8F00", fontcolor=white];

    /* Inotrope */
    Levosimendan   [label="Levosimendan\n(Ca²⁺ sensitizer)", shape=box, fillcolor="#FF6F00", fontcolor=white];
    Dobutamine     [label="Dobutamine\n(β1 agonist, acute)", shape=box, fillcolor="#FFB300"];
  }

  /* ============================================================
     CLUSTER 10: RENAL & METABOLIC EFFECTS
  ============================================================ */
  subgraph cluster_renal {
    label="Renal & Metabolic Effects";
    color="#558B2F";
    style=filled;
    fillcolor="#F1F8E9";
    fontcolor="#558B2F";
    fontsize=11;
    penwidth=2;

    GFR            [label="GFR / eGFR\n(Kidney function)",  shape=hexagon, fillcolor="#AED581"];
    Sodium_ret     [label="Sodium\nRetention (↑)",          shape=oval, fillcolor="#C5E1A5"];
    Volume_overload [label="Volume\nOverload (↑)",          shape=oval, fillcolor="#8BC34A", fontcolor=white];
    Edema          [label="Peripheral\nEdema (↑)",          shape=oval, fillcolor="#AED581"];
    SGLT2          [label="SGLT2\n(Renal glucose transporter)", shape=box, fillcolor="#C5E1A5"];
    Glucosuria     [label="Glucosuria\n(osmotic diuresis)", shape=oval, fillcolor="#DCEDC8"];
    UricAcid       [label="Uric Acid\n(↓ SGLT2i)",         shape=oval, fillcolor="#DCEDC8"];
    Hematocrit     [label="Hematocrit\n(↑ SGLT2i)",        shape=hexagon, fillcolor="#C5E1A5"];
    Ketones        [label="Ketone Bodies\n(energy substrate)", shape=oval, fillcolor="#DCEDC8"];
  }

  /* ============================================================
     CLUSTER 11: CLINICAL ENDPOINTS
  ============================================================ */
  subgraph cluster_endpoints {
    label="Clinical Endpoints & Outcomes";
    color="#B71C1C";
    style=filled;
    fillcolor="#FCE4EC";
    fontcolor="#B71C1C";
    fontsize=11;
    penwidth=2;

    NYHA_class     [label="NYHA Class\n(I-IV)",              shape=hexagon, fillcolor="#EF9A9A"];
    SixMWT         [label="6-Minute Walk\nTest (m)",         shape=hexagon, fillcolor="#EF9A9A"];
    VO2max         [label="VO₂max\n(mL/kg/min)",             shape=hexagon, fillcolor="#EF9A9A"];
    QoL_KCCQ       [label="QoL (KCCQ)\nScore",               shape=hexagon, fillcolor="#FFCDD2"];
    HF_Hosp        [label="HF\nHospitalization",             shape=hexagon, fillcolor="#EF9A9A"];
    CV_Death       [label="CV Death",                        shape=hexagon, fillcolor="#C62828", fontcolor=white];
    All_Death      [label="All-Cause\nMortality",            shape=hexagon, fillcolor="#C62828", fontcolor=white];
    SCD            [label="Sudden Cardiac\nDeath (SCD)",     shape=hexagon, fillcolor="#B71C1C", fontcolor=white];
    Transplant     [label="Cardiac\nTransplantation",        shape=hexagon, fillcolor="#FFCDD2"];
    MCS            [label="Mechanical Circulatory\nSupport (LVAD)", shape=hexagon, fillcolor="#FFCDD2"];
    ICD_therapy    [label="ICD Therapy\n(VT/VF)",            shape=hexagon, fillcolor="#EF9A9A"];
    CRT_response   [label="CRT Response\n(LBBB, QRS>150ms)", shape=hexagon, fillcolor="#FFCDD2"];
  }

  /* ============================================================
     INTER-CLUSTER EDGES — GENETIC → CARDIOMYOCYTE
  ============================================================ */
  TTN  -> SarcomereDefect [label="titin truncation"];
  MYH7 -> SarcomereDefect [label="missense"];
  TNNT2 -> SarcomereDefect [label="mutation"];
  FLNC -> CytoskeletalDefect [label="filamin loss"];
  DSP  -> CytoskeletalDefect [label="desmosome disruption"];
  BAG3 -> Autophagy [label="chaperone loss"];
  LMNA -> NuclearLamina [label="lamin mutation"];
  PLN  -> CalciumHandling [label="hyperphos PLN"];
  RBM20 -> CalciumHandling [label="titin splicing defect"];
  SCN5A -> CalciumHandling [label="Na overload → Ca overload"];

  SarcomereDefect    -> MyocyteHypertrophy [label="load compensation"];
  SarcomereDefect    -> MitoDysfunction [label="energy demand↑"];
  CytoskeletalDefect -> MyocyteApoptosis [label="mechanical stress"];
  CytoskeletalDefect -> OxidativeStress;
  NuclearLamina      -> MyocyteApoptosis [label="DNA damage"];
  NuclearLamina      -> NFkB [label="nuclear stress"];
  CalciumHandling    -> CalciumOverload;
  CalciumHandling    -> SERCA2a [label="PLN inhibition↑"];

  SERCA2a -> CalciumOverload [label="SR Ca²⁺ ↓"];
  NCX     -> CalciumOverload [label="cytosolic Ca²⁺ ↑"];
  RyR2    -> CalciumOverload [label="SR leak"];
  CalciumOverload -> MyocyteApoptosis [label="calpain activation"];
  CalciumOverload -> MitoDysfunction [label="mPTP opening"];
  CalciumOverload -> Autophagy [label="ULK1 inhibition"];

  MitoDysfunction -> OxidativeStress [label="ETC leak → ROS"];
  MitoDysfunction -> ATP_depletion;
  OxidativeStress -> MyocyteApoptosis [label="Bax, cytochrome c"];
  OxidativeStress -> ERstress;
  OxidativeStress -> NFkB [label="IKK activation"];
  ERstress -> Autophagy [label="ER-phagy"];
  ERstress -> MyocyteApoptosis [label="CHOP pathway"];
  ATP_depletion -> MyocyteNecrosis [label="energy failure"];
  MyocyteNecrosis -> TroponinI [label="release"];
  MyocyteNecrosis -> TroponinT [label="release"];
  MyocyteApoptosis -> TroponinI;
  MyocyteHypertrophy -> LVmass;
  MyocyteApoptosis -> LVEF [label="loss of contractile units", color=red];
  MyocyteNecrosis -> LVEF [label="", color=red];

  /* ============================================================
     RAAS INTER-CLUSTER EDGES
  ============================================================ */
  Angiotensinogen -> AngI [label="cleaved by Renin"];
  Renin -> AngI;
  AngI -> AngII [label="ACE (primary)"];
  ACE  -> AngII;
  Chymase -> AngII [label="ACE-independent"];
  AngII -> AT1R [label="binds"];
  AngII -> AT2R [label="binds (protective)"];
  AT1R -> Aldosterone [label="adrenal zone glom."];
  AT1R -> Vasoconstriction [label="vascular smooth muscle"];
  AT1R -> Sodium_ret [label="renal proximal tubule"];
  AT1R -> NFkB [label="pro-inflammatory"];
  AT1R -> OxidativeStress [label="NADPH oxidase"];
  AT1R -> MyocyteHypertrophy [label="pathological remodeling"];
  AT2R -> Ang17 [label="cleaves", style=dashed];
  Aldosterone -> MR_receptor [label="binds"];
  MR_receptor -> Sodium_ret;
  MR_receptor -> Volume_overload;
  MR_receptor -> Fibroblast [label="activates", color="#6D4C41"];
  MR_receptor -> MyocyteHypertrophy;
  ACE2 -> Ang17 [label="generates"];
  Ang17 -> Natriuresis [label="Mas-R: beneficial"];
  NEP  -> ANP [label="degrades"];
  NEP  -> BNP [label="degrades"];

  /* RAAS → Cardiac */
  AT1R -> LVEDV [label="volume/pressure overload", color=red];
  Aldosterone -> Fibrosis_frac [label="collagen↑", color="#6D4C41"];

  /* ============================================================
     SNS EDGES
  ============================================================ */
  HPAA -> Norepinephrine;
  HPAA -> Epinephrine;
  CardiacOutput -> Norepinephrine [label="baroreceptor reflex\n(low CO → ↑ NE)", style=dashed, color="#E65100"];
  Norepinephrine -> Beta1R;
  Epinephrine    -> Beta1R;
  Epinephrine    -> Beta2R;
  Norepinephrine -> Alpha1R;
  Beta1R -> cAMP [label="Gs-AC activation"];
  cAMP -> PKA;
  PKA  -> SERCA2a [label="phospho-PLN → SERCA2a active"];
  PKA  -> RyR2 [label="hyperphosphorylation → leak"];
  PKA  -> HR_SNS [label="↑ HR"];
  PKA  -> Inotropy [label="↑ contractility (acute)"];
  Beta1R -> NE_spillover [label="chronic: downregulation"];
  NE_spillover -> MyocyteApoptosis [label="catecholamine toxicity"];
  NE_spillover -> OxidativeStress;
  Alpha1R -> Vasoconstriction;
  HR_SNS -> CardiacOutput;
  Inotropy -> StrokeVolume;
  HF -> HR_SNS [label="If current drives\n(ivabradine target)"];

  /* ============================================================
     INFLAMMATION EDGES
  ============================================================ */
  MyocyteNecrosis -> Macrophage_M1 [label="DAMPs release"];
  MyocyteApoptosis -> Macrophage_M1;
  OxidativeStress -> NFkB;
  NFkB -> TNFalpha;
  NFkB -> IL1beta;
  NFkB -> IL6;
  NFkB -> MCP1;
  NFkB -> Macrophage_M1 [label="M1 polarization"];
  Macrophage_M1 -> TNFalpha;
  Macrophage_M1 -> IL1beta;
  Macrophage_M1 -> IL6;
  Macrophage_M1 -> TGFbeta;
  Macrophage_M1 -> MMP9;
  NLRP3 -> IL1beta [label="caspase-1"];
  NLRP3 -> IL18;
  CalciumOverload -> NLRP3;
  TNFalpha -> MyocyteApoptosis [label="caspase-8"];
  TNFalpha -> OxidativeStress;
  TNFalpha -> MitoDysfunction;
  IL6 -> LVEF [label="negative inotropic", color=red];
  IL6 -> CRP;
  IL10 -> Macrophage_M2 [label="M2 polarization"];
  Macrophage_M2 -> TGFbeta [label="reparative"];
  CD4T -> TNFalpha;
  CD4T -> IL6;
  CD8T -> MyocyteApoptosis [label="perforin/granzyme"];
  Mast_cell -> TGFbeta;
  Mast_cell -> Fibroblast [label="tryptase activation"];
  MCP1 -> Macrophage_M1 [label="monocyte recruitment"];

  /* ============================================================
     FIBROSIS EDGES
  ============================================================ */
  TGFbeta -> MyoFibroblast [label="activation"];
  TGFbeta -> CollagenI [label="synthesis↑"];
  TGFbeta -> TIMP1;
  AT1R -> Fibroblast [label="activation"];
  Aldosterone -> Fibroblast;
  Fibroblast -> MyoFibroblast [label="transdifferentiation"];
  MyoFibroblast -> CollagenI;
  MyoFibroblast -> CollagenIII;
  MyoFibroblast -> LOX [label="crosslinker secretion"];
  LOX -> STIFFNESS [label="collagen XL"];
  CollagenI -> Fibrosis_frac;
  CollagenIII -> Fibrosis_frac;
  MMP2 -> CollagenI [label="degrades", style=dashed, color=green];
  MMP9 -> CollagenIII [label="degrades", style=dashed, color=green];
  TIMP1 -> MMP2 [label="inhibits", style=dashed, color=red];
  TIMP2 -> MMP9 [label="inhibits", style=dashed, color=red];
  Fibrosis_frac -> STIFFNESS;
  Fibrosis_frac -> LVEF [label="diastolic↓, systolic↓", color=red];
  Fibrosis_frac -> GLS [label="strain worsens", color=red];
  STIFFNESS -> LVEDP;
  STIFFNESS -> PCWP;
  PICP -> Fibrosis_frac;
  PIIINP -> Fibrosis_frac;
  Galectin3 -> TGFbeta [label="amplifies"];
  Galectin3 -> Fibrosis_frac;

  /* ============================================================
     CARDIAC MECHANICS INTER-EDGES
  ============================================================ */
  LVEF -> StrokeVolume;
  LVEDV -> StrokeVolume [label="preload"];
  LVESV -> StrokeVolume [label="SV = LVEDV-LVESV"];
  StrokeVolume -> CardiacOutput;
  HR_SNS -> CardiacOutput;
  CardiacOutput -> MAP_hemo;
  SVR -> MAP_hemo;
  PCWP -> Volume_overload;
  PCWP -> Edema;
  CardiacOutput -> GFR [label="renal perfusion"];
  MAP_hemo -> Renin [label="↓MAP → ↑Renin", style=dashed, color="#1565C0"];
  MAP_hemo -> HPAA [label="baroreceptor", style=dashed, color="#E65100"];
  LVEDV -> BNP [label="wall stress → release"];
  LVEDP -> BNP;
  PCWP -> ANP [label="atrial stretch"];

  /* ============================================================
     NATRIURETIC PEPTIDE EDGES
  ============================================================ */
  ANP -> NPRA;
  BNP -> NPRA;
  CNP -> NPRB;
  NPRA -> cGMP_bnp;
  NPRB -> cGMP_bnp;
  cGMP_bnp -> PKG;
  PKG -> Natriuresis [label="↑ Na excretion"];
  PKG -> Vasoconstriction [label="vasodilation", style=dashed, color=green];
  PKG -> Fibroblast [label="anti-fibrotic", style=dashed, color=green];
  Natriuresis -> Volume_overload [label="reduces", style=dashed, color=green];
  NEP_BNP -> BNP [label="cleaves/degrades", style=dashed, color=red];
  NEP_BNP -> ANP [label="degrades", style=dashed, color=red];
  NT_proBNP -> BNP [label="co-secreted\n(inactive)"];
  BNP -> NT_proBNP;

  /* ============================================================
     DRUG PK/PD EDGES
  ============================================================ */
  /* ACEi */
  Enalapril -> Enalaprilat [label="ester hydrolysis\n(liver)"];
  Enalaprilat -> ACE [label="competitive inhibition\n(↓ AngII prod)", color="#1565C0", style=bold];
  Enalaprilat -> NEP_BNP [label="minor inhibition"];

  /* ARB */
  Valsartan -> AT1R [label="competitive block\n(↓ signaling)", color="#1565C0", style=bold];
  Losartan  -> AT1R [label="block"];

  /* ARNI */
  Sacubitril -> LBQ657 [label="prodrug conversion"];
  LBQ657 -> NEP_BNP [label="potent inhibition\n(↑ ANP, BNP)", color="#00838F", style=bold];
  ARNI_combo -> AT1R [label="valsartan component\nblock AT1R", color="#1565C0"];
  ARNI_combo -> NEP_BNP [label="sacubitril component\nNEP inhibition", color="#00838F"];
  Sacubitril -> ARNI_combo;
  Valsartan  -> ARNI_combo;

  /* Beta-blockers */
  Carvedilol -> Beta1R [label="block (β1/β2/α1)\nup-regulation over time", color="#E65100", style=bold];
  Carvedilol -> Beta2R [label="block"];
  Carvedilol -> Alpha1R [label="block"];
  Carvedilol -> OxidativeStress [label="antioxidant\n(direct)", style=dashed, color=green];
  Metoprolol -> Beta1R [label="selective β1 block", color="#E65100", style=bold];

  /* MRA */
  Spironolactone -> MR_receptor [label="competitive block\n(↓ Na/water retention)", color="#1565C0", style=bold];
  Eplerenone     -> MR_receptor [label="selective block", color="#1565C0", style=bold];
  Spironolactone -> Fibrosis_frac [label="↓ fibrosis", style=dashed, color=green];
  Eplerenone     -> Fibrosis_frac [label="↓ fibrosis", style=dashed, color=green];

  /* SGLT2i */
  Dapagliflozin -> SGLT2 [label="inhibit glucose\nreabsorption", color="#558B2F", style=bold];
  Empagliflozin -> SGLT2 [label="inhibit", color="#558B2F", style=bold];
  SGLT2 -> Glucosuria;
  Glucosuria -> Volume_overload [label="osmotic diuresis\n↓ volume", style=dashed, color=green];
  Dapagliflozin -> OxidativeStress [label="↓ ROS", style=dashed, color=green];
  Dapagliflozin -> MitoDysfunction [label="↑ mito function", style=dashed, color=green];
  Dapagliflozin -> Ketones [label="ketogenesis↑"];
  Dapagliflozin -> Hematocrit [label="EPO↑, erythropoiesis"];
  Dapagliflozin -> NFkB [label="↓ inflammation", style=dashed, color=green];
  Dapagliflozin -> UricAcid [label="↓ uric acid"];
  Dapagliflozin -> Fibrosis_frac [label="↓ cardiac fibrosis", style=dashed, color=green];

  /* Ivabradine */
  Ivabradine -> HF [label="HCN4 block\n(↓ If current)", color="#E65100", style=bold];
  HF -> HR_SNS [label="pacemaker current"];
  Ivabradine -> HR_SNS [label="↓ HR (sinus)", style=dashed, color=green];

  /* Inotropes */
  Levosimendan -> CalciumHandling [label="Ca²⁺ sensitizer\n(TnC binding)"];
  Levosimendan -> Inotropy [label="↑ contractility\nno O₂ increase", color="#FF6F00"];
  Levosimendan -> SVR [label="K-ATP opener\nvasodilation", style=dashed, color=green];
  Dobutamine -> Beta1R [label="agonist (acute)"];

  /* ============================================================
     RENAL EDGES
  ============================================================ */
  GFR -> Sodium_ret [label="↓GFR → Na retention", style=dashed];
  Sodium_ret -> Volume_overload;
  Volume_overload -> LVEDV [label="preload↑"];
  Volume_overload -> PCWP [label="↑"];
  Volume_overload -> Edema;
  Edema -> NYHA_class [label="symptoms"];
  UricAcid -> OxidativeStress [label="xanthine oxidase"];

  /* ============================================================
     CLINICAL ENDPOINTS EDGES
  ============================================================ */
  LVEF -> NYHA_class [label="↓LVEF → worse NYHA", color=red];
  CardiacOutput -> NYHA_class [label="↓CO → fatigue", color=red];
  Volume_overload -> NYHA_class;
  SixMWT -> NYHA_class;
  CardiacOutput -> SixMWT [label="exercise capacity"];
  LVEF -> SixMWT;
  VO2max -> SixMWT;
  CardiacOutput -> VO2max;
  NYHA_class -> QoL_KCCQ [label="symptom burden"];
  SixMWT -> QoL_KCCQ;
  NYHA_class -> HF_Hosp [label="decompensation"];
  PCWP -> HF_Hosp [label="↑PCWP → hosp"];
  BNP -> HF_Hosp [label="↑BNP → risk"];
  LVEF -> CV_Death [label="↓LVEF → ↑risk", color="#B71C1C"];
  HF_Hosp -> CV_Death [label="↑ mortality risk"];
  SCD -> CV_Death;
  MyocyteApoptosis -> SCD [label="arrhythmia substrate"];
  Fibrosis_frac -> SCD [label="re-entry circuits"];
  LVEF -> ICD_therapy [label="LVEF<35%→ ICD"];
  CRT_response -> LVEF [label="CRT improves LVEF"];
  LVEF -> Transplant [label="LVEF<20% refractory"];
  MCS -> Transplant [label="bridge to Tx"];
  HF_Hosp -> All_Death;
  CV_Death -> All_Death;

  /* Drug effects on endpoints */
  Carvedilol -> LVEF [label="↑LVEF +5-10%", color=green, style=bold];
  Enalaprilat -> LVEF [label="↑LVEF", color=green];
  Valsartan -> LVEF [label="↑LVEF", color=green];
  ARNI_combo -> LVEF [label="↑LVEF (PARADIGM)", color=green, style=bold];
  Dapagliflozin -> LVEF [label="↑LVEF (DAPA-HF)", color=green, style=bold];
  Ivabradine -> LVEF [label="↑LVEF (SHIFT)", color=green];
  Spironolactone -> Fibrosis_frac [label="↓fibrosis (RALES)", color=green];
  ARNI_combo -> BNP [label="paradox: ↑BNP\n(NEP inhibition)\nbut ↓NT-proBNP", style=dashed];
  Dapagliflozin -> HF_Hosp [label="↓25% (DAPA-HF)", color=green, style=bold];
  ARNI_combo -> HF_Hosp [label="↓21% (PARADIGM)", color=green, style=bold];
  Carvedilol -> CV_Death [label="↓34% (COPERNICUS)", color=green, style=bold];
  Enalaprilat -> CV_Death [label="↓16% (CONSENSUS)", color=green, style=bold];
  ARNI_combo -> CV_Death [label="↓20% (PARADIGM)", color=green, style=bold];
  Dapagliflozin -> CV_Death [label="↓18% (DAPA-HF)", color=green, style=bold];
  Spironolactone -> CV_Death [label="↓30% (RALES)", color=green, style=bold];
  Ivabradine -> HF_Hosp [label="↓26% (SHIFT)", color=green];

  /* BNP feedback */
  BNP -> NYHA_class [label="elevated → worse sx"];
  NT_proBNP -> NYHA_class;
  PICP -> Fibrosis_frac;
  Galectin3 -> HF_Hosp [label="predictor"];
}
