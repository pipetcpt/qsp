  // Legend
  subgraph cluster_legend {
    label="Legend"
    style=filled; color="#F8F9FA"; pencolor="#95A5A6"
    rank=sink
    L_act   [label="─→  Activation / Upregulation", shape=plaintext, fontname="Helvetica"]
    L_inh   [label="- -→  Inhibition (blue dashed)", shape=plaintext, fontname="Helvetica", fontcolor=blue]
    L_drug  [label="─→  Drug Effect (green)", shape=plaintext, fontname="Helvetica", fontcolor="#117A65"]
    L_crit  [label="─→  Critical TTP Driver (red)", shape=plaintext, fontname="Helvetica", fontcolor=red]
    L_oct   [label="Octagon = Clinical Measurable", shape=octagon, fillcolor=white]
    L_hex   [label="Hexagon = Composite/Score", shape=hexagon, fillcolor=white]
    L_box3d [label="Box3d = Drug / Intervention", shape=box3d, fillcolor=white]
    L_diam  [label="Diamond = Gene/Threshold", shape=diamond, fillcolor=white]
  }
}
