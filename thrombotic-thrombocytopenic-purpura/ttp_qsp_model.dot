  ULVWF_pool -> VWF_A2_domain [label="cleavage site exposed"]
  ULVWF_pool -> VWF_plasma_Ag [label="antigen ↑ (VWF:Ag)"]
  VWF_shear -> VWF_A2_domain [label="unfolds A2"]
  VWF_A2_domain -> VWF_cleavage [label="ADAMTS13 target"]
  ADAMTS13_plasma -> VWF_cleavage [label="cleaves Y1605-M1606", color="#1A5276"]
