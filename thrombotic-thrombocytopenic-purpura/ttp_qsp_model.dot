digraph TTP_QSP_Model {
  graph [
    label="Thrombotic Thrombocytopenic Purpura (TTP)\nQuantitative Systems Pharmacology Model",
    fontname="Helvetica-Bold",
    fontsize=20,
    labelloc=t,
    bgcolor="#FAFAFA",
    rankdir=TB,
    splines=ortho,
    nodesep=0.35,
    ranksep=0.55,
    compound=true,
    pad=0.5
  ]
  node [fontname="Helvetica", fontsize=9, style=filled, shape=box, margin="0.1,0.05"]
  edge [fontname="Helvetica", fontsize=7, arrowsize=0.7]

  // ========== CLUSTER 1: ADAMTS13 Biology ==========
  subgraph cluster_adamts13 {
    label="① ADAMTS13 Biology"
    style=filled; color="#D6EAF8"; pencolor="#2980B9"; penwidth=2
    fontname="Helvetica-Bold"; fontsize=11

    ADAMTS13_gene      [label="ADAMTS13 Gene\n(chromosome 9q34)", shape=diamond, fillcolor="#AED6F1"]
    ADAMTS13_hepato    [label="Hepatocyte\nADAMTS13 Synthesis", fillcolor="#AED6F1"]
    ADAMTS13_stellate  [label="Hepatic Stellate Cell\nADAMTS13 (minor)", fillcolor="#AED6F1"]
    ADAMTS13_plasma    [label="Plasma ADAMTS13\nActivity (U/dL = %)", shape=octagon, fillcolor="#5DADE2", fontcolor=white]
    ADAMTS13_t12       [label="ADAMTS13 Half-Life\n~2–3 days", fillcolor="#D6EAF8"]
    ADAMTS13_inhibitor [label="ADAMTS13 Inhibitor\n(anti-ADAMTS13 IgG)", shape=hexagon, fillcolor="#F1948A"]
    inhibitor_titer    [label="Inhibitor Titer\n(Bethesda units, BU)", shape=octagon, fillcolor="#F1948A"]
    ADAMTS13_clearance [label="Immune-Mediated\nADAMTS13 Clearance", fillcolor="#F5B7B1"]
    ADAMTS13_threshold [label="Critical Threshold\n(<10% activity = TTP)", shape=diamond, fillcolor="#E74C3C", fontcolor=white]
    ADAMTS13_mutation  [label="Congenital ADAMTS13\nDeficiency (ADAMTS13 mut)", fillcolor="#D6EAF8"]
    ADAMTS13_Upshaw    [label="Upshaw-Schulman\nSyndrome (congenital TTP)", fillcolor="#D6EAF8"]
    ADAMTS13_VWF_bind  [label="ADAMTS13 Spacer Domain\nVWF A3 Interaction", fillcolor="#AED6F1"]
  }

  // ========== CLUSTER 2: VWF Biology ==========
  subgraph cluster_vwf {
    label="② von Willebrand Factor (VWF) Biology"
    style=filled; color="#FEF9E7"; pencolor="#F39C12"; penwidth=2
    fontname="Helvetica-Bold"; fontsize=11

    VWF_gene       [label="VWF Gene\n(chromosome 12p13)", shape=diamond, fillcolor="#F9E79F"]
    VWF_endothelial[label="Endothelial Cell\nVWF Synthesis (Weibel-Palade)", fillcolor="#F9E79F"]
    VWF_mega       [label="Megakaryocyte\nα-granule VWF Storage", fillcolor="#F9E79F"]
    WPB            [label="Weibel-Palade Body\n(WPB) Storage", fillcolor="#F4D03F"]
    ULVWF_secrete  [label="ULVWF Secretion\n(EC activation)", shape=hexagon, fillcolor="#D4AC0D", fontcolor=white]
    ULVWF_pool     [label="ULVWF Pool\n(Plasma, ng/mL)", shape=octagon, fillcolor="#D68910", fontcolor=white]
    VWF_A1_domain  [label="VWF A1 Domain\n(GPIbα binding site)", fillcolor="#F8C471"]
    VWF_A2_domain  [label="VWF A2 Domain\n(ADAMTS13 cleavage Y1605-M1606)", fillcolor="#FAD7A0"]
    VWF_A3_domain  [label="VWF A3 Domain\n(collagen binding)", fillcolor="#FAD7A0"]
    VWF_shear      [label="Shear Stress\nUnfolding of VWF A2", fillcolor="#F4D03F"]
    VWF_cleavage   [label="ADAMTS13 Cleavage\nof ULVWF → normal VWF", fillcolor="#AED6F1"]
    VWF_normal_mt  [label="Normal VWF Multimers\n(fully processed)", fillcolor="#ABEBC6"]
    VWF_propeptide [label="VWF Propeptide\n(pp, activation marker)", fillcolor="#F9E79F"]
    VWF_plasma_Ag  [label="Plasma VWF Antigen\n(VWF:Ag)", shape=octagon, fillcolor="#D68910", fontcolor=white]
    VWF_collagen   [label="VWF-Collagen\nBinding (injury)", fillcolor="#FAD7A0"]
  }

  // ========== CLUSTER 3: Platelet Biology ==========
  subgraph cluster_platelet {
    label="③ Platelet Biology & Microthrombus Formation"
    style=filled; color="#FDF2F8"; pencolor="#8E44AD"; penwidth=2
    fontname="Helvetica-Bold"; fontsize=11

    megakaryocyte  [label="Megakaryocyte\n(BM thrombopoiesis)", fillcolor="#D7BDE2"]
    TPO            [label="Thrombopoietin\n(TPO, c-Mpl)", fillcolor="#D7BDE2"]
    PLT_count      [label="Platelet Count\n(×10⁹/L)", shape=octagon, fillcolor="#9B59B6", fontcolor=white]
    PLT_lifespan   [label="Normal Platelet\nLifespan (~7–10 days)", fillcolor="#D7BDE2"]
    GPIb_alpha     [label="GP Ibα (CD42b)\nVWF Receptor on Platelet", fillcolor="#C39BD3"]
    GPIIb_IIIa     [label="GP IIb/IIIa (αIIbβ3)\nFibrinogen Receptor", fillcolor="#C39BD3"]
    PLT_activation [label="Platelet Activation\n& Shape Change", shape=hexagon, fillcolor="#7D3C98", fontcolor=white]
    PLT_aggreg     [label="Platelet Aggregation\n(primary plug)", fillcolor="#884EA0", fontcolor=white]
    microthrombi   [label="Platelet-Rich\nMicrothrombi (AU)", shape=octagon, fillcolor="#6C3483", fontcolor=white]
    PLT_consume    [label="Platelet Consumption\nRate (×10⁹/L/d)", fillcolor="#884EA0", fontcolor=white]
    TXA2           [label="Thromboxane A2\n(TXA2, vasoconstriction)", fillcolor="#C39BD3"]
    ADP_rel        [label="ADP Release\n(dense granule)", fillcolor="#C39BD3"]
    P2Y12_rec      [label="P2Y12 Receptor\n(ADP signaling)", fillcolor="#C39BD3"]
    PAR1           [label="PAR1/PAR4\n(thrombin receptors)", fillcolor="#C39BD3"]
    serotonin_rel  [label="Serotonin Release\n(5-HT, vasoconstriction)", fillcolor="#D7BDE2"]
    P_selectin     [label="P-Selectin (CD62P)\n(leukocyte adhesion)", fillcolor="#D7BDE2"]
    PLT_fibrinogen [label="Fibrinogen\n(αIIbβ3 cross-linking)", fillcolor="#C39BD3"]
  }

  // ========== CLUSTER 4: Endothelial Biology ==========
  subgraph cluster_endothelial {
    label="④ Endothelial Biology & Activation"
    style=filled; color="#EAFAF1"; pencolor="#1E8449"; penwidth=2
    fontname="Helvetica-Bold"; fontsize=11

    EC_basal       [label="Endothelial Cell\n(Quiescent/Basal)", fillcolor="#A9DFBF"]
    EC_activation  [label="EC Activation\n(cytokine/damage)", shape=hexagon, fillcolor="#27AE60", fontcolor=white]
    EC_shear       [label="Hemodynamic\nShear Stress", fillcolor="#58D68D"]
    WPB_release    [label="WPB Exocytosis\n(EC activation event)", fillcolor="#1E8449", fontcolor=white]
    P_sel_EC       [label="P-Selectin\n(EC surface, leukocyte)", fillcolor="#58D68D"]
    ICAM1          [label="ICAM-1 / VCAM-1\n(adhesion molecules)", fillcolor="#58D68D"]
    eNOS           [label="eNOS / Nitric Oxide\n(EC-protective)", fillcolor="#A9DFBF"]
    PGI2           [label="Prostacyclin (PGI2)\n(anti-platelet, vasodilate)", fillcolor="#A9DFBF"]
    ET1            [label="Endothelin-1\n(vasoconstriction)", fillcolor="#58D68D"]
    TF_EC          [label="Tissue Factor\n(EC surface, procoagulant)", fillcolor="#58D68D"]
    EC_apoptosis   [label="EC Apoptosis\n(severe injury)", fillcolor="#1E8449", fontcolor=white]
    HMGB1_EC       [label="HMGB1 / DAMPs\n(damage signals)", fillcolor="#58D68D"]
    complement_EC  [label="Complement MAC\n(EC membrane attack)", fillcolor="#A9DFBF"]
    angiopoietin2  [label="Angiopoietin-2\n(destabilize EC, WPB stored)", fillcolor="#58D68D"]
  }

  // ========== CLUSTER 5: Immune & Inflammatory Pathways ==========
  subgraph cluster_immune {
    label="⑤ Immune & Inflammatory Pathways"
    style=filled; color="#FDEDEC"; pencolor="#C0392B"; penwidth=2
    fontname="Helvetica-Bold"; fontsize=11

    naive_BCell    [label="Naive B Cell\n(CD19+, CD20+)", fillcolor="#FADBD8"]
    germinal_ctr   [label="Germinal Center\nReaction", fillcolor="#F5B7B1"]
    memory_BCell   [label="Memory B Cell\n(long-lived)", fillcolor="#F5B7B1"]
    plasma_cell    [label="Plasma Cell\n(Ab-secreting)", fillcolor="#F1948A"]
    Ab_prod        [label="Autoantibody Production\nRate (anti-ADAMTS13 IgG)", fillcolor="#F1948A"]
    CD4_Th         [label="CD4+ T Helper Cell\n(Th2/Tfh skew)", fillcolor="#FAD7A0"]
    CD4_Tfh        [label="Tfh Cell\n(PD-1+, CXCR5+, germinal ctr)", fillcolor="#FAD7A0"]
    Treg           [label="Regulatory T Cell\n(Treg, FOXP3+, suppressed)", fillcolor="#A9DFBF"]
    IL6            [label="IL-6\n(plasma cell survival, B cell)", fillcolor="#E74C3C", fontcolor=white]
    TNFa           [label="TNF-α\n(EC activation)", fillcolor="#E74C3C", fontcolor=white]
    IL10           [label="IL-10\n(anti-inflammatory)", fillcolor="#A9DFBF"]
    CXCL13         [label="CXCL13\n(Tfh/GC marker)", fillcolor="#F5B7B1"]
    complement_C3  [label="Complement C3\n(activation)", fillcolor="#FADBD8"]
    complement_C5  [label="Complement C5b-9\n(MAC, EC damage)", fillcolor="#F1948A"]
    NFkB           [label="NF-κB\n(master inflammatory TF)", fillcolor="#E74C3C", fontcolor=white]
    MHC_II         [label="MHC-II Antigen\nPresentation", fillcolor="#F5B7B1"]
    ADCP           [label="ADCP by Macrophage\n(Fc-mediated ADAMTS13 clearance)", fillcolor="#FADBD8"]
    IgG_subclass   [label="IgG1/IgG4 Subclass\n(IgG4 dominant in chronic)", fillcolor="#FADBD8"]
  }

  // ========== CLUSTER 6: Coagulation Cascade ==========
  subgraph cluster_coagulation {
    label="⑥ Secondary Coagulation & Fibrinolysis"
    style=filled; color="#EBF5FB"; pencolor="#1A5276"; penwidth=2
    fontname="Helvetica-Bold"; fontsize=11

    TF_path        [label="Tissue Factor\nPathway (FVIIa)", fillcolor="#AED6F1"]
    Factor_Xa      [label="Factor Xa\n(prothrombinase)", fillcolor="#AED6F1"]
    thrombin       [label="Thrombin (IIa)\n(FIb→Fib, PAR activation)", fillcolor="#5DADE2", fontcolor=white]
    fibrinogen     [label="Fibrinogen\n(340 kDa)", fillcolor="#AED6F1"]
    fibrin_clot    [label="Fibrin Clot\n(secondary hemostasis)", fillcolor="#85C1E9"]
    FXIII          [label="Factor XIIIa\n(fibrin cross-linking)", fillcolor="#AED6F1"]
    TFPI           [label="TFPI\n(TF pathway inhibitor)", fillcolor="#A9DFBF"]
    antithrombin   [label="Antithrombin III\n(thrombin inhibitor)", fillcolor="#A9DFBF"]
    protein_CS     [label="Protein C/S\n(anticoagulant system)", fillcolor="#A9DFBF"]
    tPA            [label="tPA / Plasminogen\n(fibrinolysis)", fillcolor="#AED6F1"]
    PAI1           [label="PAI-1\n(fibrinolysis inhibitor)", fillcolor="#FAD7A0"]
    D_dimer        [label="D-Dimer\n(fibrin degradation, ng/mL)", shape=octagon, fillcolor="#5DADE2", fontcolor=white]
    TAFI           [label="TAFI\n(thrombin-activatable fibrinolysis inhibitor)", fillcolor="#AED6F1"]
  }

  // ========== CLUSTER 7: Organ Damage ==========
  subgraph cluster_organs {
    label="⑦ Multiorgan Damage (Microvascular Occlusion)"
    style=filled; color="#FEF3C7"; pencolor="#B7950B"; penwidth=2
    fontname="Helvetica-Bold"; fontsize=11

    renal_MT       [label="Renal Microvascular\nMicrothrombi", fillcolor="#FCD34D"]
    creatinine     [label="Serum Creatinine\n(μmol/L)", shape=octagon, fillcolor="#F59E0B", fontcolor=white]
    GFR            [label="eGFR\n(mL/min/1.73m²)", shape=octagon, fillcolor="#D97706", fontcolor=white]
    renal_ischemia [label="Renal Tubular\nIschemia / ATN", fillcolor="#FCD34D"]
    proteinuria    [label="Proteinuria\n(TMA-related)", shape=octagon, fillcolor="#F59E0B"]
    brain_MT       [label="Cerebral\nMicrothrombi", fillcolor="#FCD34D"]
    neuro_score    [label="Neurological Score\n(MSTL severity)", shape=octagon, fillcolor="#D97706", fontcolor=white]
    confusion_s    [label="Confusion / Altered\nMental Status", fillcolor="#FCD34D"]
    seizure_s      [label="Seizure\n(CNS severe)", fillcolor="#FCD34D"]
    stroke_s       [label="Ischemic Stroke\n(large vessel)", fillcolor="#FCD34D"]
    cardiac_MT     [label="Cardiac Microvascular\nMicrothrombi", fillcolor="#FCD34D"]
    troponin       [label="Troponin I/T\n(ng/mL)", shape=octagon, fillcolor="#D97706", fontcolor=white]
    myocardial_inj [label="Myocardial Injury\n(MINOCA-TTP)", fillcolor="#FCD34D"]
    GI_ischemia    [label="GI Tract Ischemia\n(abdominal pain)", fillcolor="#FCD34D"]
    adrenal_hem    [label="Adrenal\nHemorrhage (rare)", fillcolor="#FCD34D"]
    retinal_MT     [label="Retinal\nMicrothrombi (visual Δ)", fillcolor="#FCD34D"]
  }

  // ========== CLUSTER 8: Hemolysis / MAHA ==========
  subgraph cluster_maha {
    label="⑧ MAHA — Microangiopathic Hemolytic Anemia"
    style=filled; color="#F3E5F5"; pencolor="#6C3483"; penwidth=2
    fontname="Helvetica-Bold"; fontsize=11

    RBC            [label="Red Blood Cell\n(RBC)", fillcolor="#E8DAEF"]
    mech_hemolysis [label="Mechanical Hemolysis\n(shear force RBC fragmentation)", shape=hexagon, fillcolor="#9B59B6", fontcolor=white]
    schistocyte    [label="Schistocytes\n(% RBCs on smear)", shape=octagon, fillcolor="#7D3C98", fontcolor=white]
    haptoglobin    [label="Haptoglobin\n(g/L — low/undetectable)", shape=octagon, fillcolor="#6C3483", fontcolor=white]
    LDH            [label="LDH\n(IU/L — markedly ↑)", shape=octagon, fillcolor="#6C3483", fontcolor=white]
    indirect_bili  [label="Indirect Bilirubin\n(μmol/L — hemolysis)", shape=octagon, fillcolor="#BB8FCE"]
    reticulocyte   [label="Reticulocyte Count\n(% — reactive ↑)", shape=octagon, fillcolor="#D7BDE2"]
    Hgb            [label="Hemoglobin\n(g/dL)", shape=octagon, fillcolor="#7D3C98", fontcolor=white]
    Hct            [label="Hematocrit (%)", shape=octagon, fillcolor="#E8DAEF"]
    free_Hgb_p     [label="Free Plasma Hgb\n(nmol/L)", fillcolor="#BB8FCE"]
    hemopexin      [label="Hemopexin\n(heme scavenger)", fillcolor="#D7BDE2"]
    ROS_ox         [label="ROS / Oxidative\nStress (EC damage)", fillcolor="#BB8FCE"]
    MAHA_composite [label="MAHA Composite\nSeverity Index", shape=hexagon, fillcolor="#6C3483", fontcolor=white]
    Coombs_neg     [label="Direct Coombs Test\nNegative (not immune hemolysis)", fillcolor="#E8DAEF"]
  }

  // ========== CLUSTER 9: Plasma Exchange PK ==========
  subgraph cluster_pex {
    label="⑨ Therapeutic Plasma Exchange (TPE/PEX)"
    style=filled; color="#E8F8F5"; pencolor="#117A65"; penwidth=2
    fontname="Helvetica-Bold"; fontsize=11

    PEX_initiate   [label="TPE Initiation\n(within hours of diagnosis)", shape=box3d, fillcolor="#76D7C4"]
    PEX_vol        [label="TPE Volume\n(1–1.5× plasma vol ~3L)", shape=box3d, fillcolor="#76D7C4"]
    PEX_freq       [label="TPE Frequency\n(daily → tapered)", shape=box3d, fillcolor="#76D7C4"]
    FFP            [label="Fresh Frozen Plasma\n(FFP replacement)", shape=box3d, fillcolor="#1ABC9C", fontcolor=white]
    SD_plasma      [label="Solvent/Detergent Plasma\n(SD, pathogen-reduced)", shape=box3d, fillcolor="#1ABC9C", fontcolor=white]
    ADAMTS13_repl  [label="ADAMTS13 Replacement\n(FFP/SD → ↑ plasma activity)", fillcolor="#1ABC9C", fontcolor=white]
    inh_removal    [label="Inhibitor Removal\n(anti-ADAMTS13 Ab removed)", fillcolor="#76D7C4"]
    ULVWF_removal2 [label="ULVWF Removal\n(large multimers cleared)", fillcolor="#76D7C4"]
    PEX_response   [label="TPE Response\n(PLT normalization days 3–7)", shape=octagon, fillcolor="#1ABC9C", fontcolor=white]
    PEX_days       [label="TPE Duration\n(median ~7–10 days)", shape=octagon, fillcolor="#76D7C4"]
    PEX_tapering   [label="TPE Tapering\n(→ q48h → q72h → stop)", shape=box3d, fillcolor="#76D7C4"]
    exacerbation   [label="Exacerbation After\nTPE Tapering", shape=hexagon, fillcolor="#117A65", fontcolor=white]
  }

  // ========== CLUSTER 10: Caplacizumab PK/PD ==========
  subgraph cluster_caplacizumab {
    label="⑩ Caplacizumab (Cablivi®) PK/PD"
    style=filled; color="#EAF2FF"; pencolor="#1A5276"; penwidth=2
    fontname="Helvetica-Bold"; fontsize=11

    CAPLA_dose     [label="Caplacizumab\n10mg IV bolus + 10mg SC qd", shape=box3d, fillcolor="#85C1E9"]
    CAPLA_SC_depot [label="SC Absorption\n(F~85%, Ka~0.8/d)", shape=cylinder, fillcolor="#AED6F1"]
    CAPLA_central  [label="Caplacizumab\nCentral (Cp, ng/mL)", shape=cylinder, fillcolor="#5DADE2", fontcolor=white]
    CAPLA_periph   [label="Caplacizumab\nPeripheral", shape=cylinder, fillcolor="#5DADE2", fontcolor=white]
    CAPLA_t12      [label="Elimination t½\n~6–8h (IV), ~11–13h (SC)", fillcolor="#AED6F1"]
    CAPLA_VWF_A1   [label="VWF A1 Domain\nBinding (nanobody)", fillcolor="#2980B9", fontcolor=white]
    CAPLA_block    [label="GPIbα–VWF Interaction\nBlocked (anti-platelet)", fillcolor="#2980B9", fontcolor=white]
    CAPLA_PLT_up   [label="Platelet↑ Effect\n(↓ ULVWF-platelet adhesion)", fillcolor="#2980B9", fontcolor=white]
    CAPLA_VWF_Ag_up[label="VWF:Ag Rise\n(free ULVWF accumulates)", shape=octagon, fillcolor="#5DADE2", fontcolor=white]
    CAPLA_EC50     [label="Caplacizumab IC50\n~2 ng/mL (VWF-PLT assay)", fillcolor="#AED6F1"]
    CAPLA_trough   [label="Trough Concentration\n(SC trough > IC50)", shape=octagon, fillcolor="#85C1E9"]
  }

  // ========== CLUSTER 11: Rituximab PK/PD ==========
  subgraph cluster_rituximab {
    label="⑪ Rituximab (Anti-CD20) PK/PD"
    style=filled; color="#FDF5E6"; pencolor="#784212"; penwidth=2
    fontname="Helvetica-Bold"; fontsize=11

    RTX_dose       [label="Rituximab\n375mg/m² IV wkly×4 (or 1000mg×2)", shape=box3d, fillcolor="#FAD7A0"]
    RTX_central    [label="Rituximab\nCentral (Cp, μg/mL)", shape=cylinder, fillcolor="#F8C471"]
    RTX_periph     [label="Rituximab\nPeripheral", shape=cylinder, fillcolor="#F8C471"]
    RTX_CD20_bound [label="RTX–CD20\nBound Complex", fillcolor="#E59866"]
    CD20_Ag        [label="CD20 Antigen\n(B cell surface, 200k/cell)", fillcolor="#FAD7A0"]
    RTX_ADCC_kill  [label="ADCC\n(NK cell Fc-γRIII killing)", fillcolor="#D35400", fontcolor=white]
    RTX_CDC_kill   [label="CDC\n(complement C1q killing)", fillcolor="#D35400", fontcolor=white]
    RTX_apoptosis  [label="Direct Apoptosis\n(caspase activation)", fillcolor="#D35400", fontcolor=white]
    BCell_deplete  [label="B Cell Depletion\n(6–12 months)", shape=octagon, fillcolor="#784212", fontcolor=white]
    BCell_recover  [label="B Cell Recovery\n(12–18 months)", fillcolor="#FAD7A0"]
    ADAMTS13_recov [label="ADAMTS13 Activity\nRecovery (↑ 6–12 wk)", shape=octagon, fillcolor="#F39C12"]
    RTX_TMDD      [label="Target-Mediated\nDisposition (TMDD, nonlinear)", fillcolor="#FAD7A0"]
    RTX_relapse_pr [label="Relapse Prevention\n(↑ sustained remission)", shape=octagon, fillcolor="#E59866"]
  }

  // ========== CLUSTER 12: Corticosteroids & Other Treatments ==========
  subgraph cluster_immunosuppression {
    label="⑫ Immunosuppression & Supportive Therapies"
    style=filled; color="#F5EEF8"; pencolor="#5B2C6F"; penwidth=2
    fontname="Helvetica-Bold"; fontsize=11

    PRED_dose      [label="Prednisolone\n1–2mg/kg/d PO/IV", shape=box3d, fillcolor="#D7BDE2"]
    PRED_PK        [label="Prednisolone PK\n(1-comp, t½~3h, V~35L)", shape=cylinder, fillcolor="#BB8FCE"]
    GR_binding     [label="Glucocorticoid\nReceptor (GR) Binding", fillcolor="#9B59B6", fontcolor=white]
    PRED_BCell_inh [label="B Cell Proliferation\nInhibition", fillcolor="#7D3C98", fontcolor=white]
    PRED_Ab_reduce [label="Autoantibody\nReduction", fillcolor="#7D3C98", fontcolor=white]
    PRED_cytokine  [label="IL-6 / TNF-α\nSuppression", fillcolor="#7D3C98", fontcolor=white]
    cyclosporine   [label="Cyclosporine A\n(CNI, calcineurin inh, rescue)", shape=box3d, fillcolor="#D7BDE2"]
    mycophenolate  [label="Mycophenolate Mofetil\n(MMF, refractory)", shape=box3d, fillcolor="#D7BDE2"]
    bortezomib     [label="Bortezomib\n(proteasome inh, plasma cell kill)", shape=box3d, fillcolor="#D7BDE2"]
    IVIG           [label="IVIG\n(Fc-receptor blockade)", shape=box3d, fillcolor="#D7BDE2"]
    splenectomy    [label="Splenectomy\n(refractory TTP)", shape=box3d, fillcolor="#C39BD3"]
    caplacizumab_cont [label="Caplacizumab\nContinued 30d post-TPE", shape=box3d, fillcolor="#85C1E9"]
    N_acetylcys    [label="N-Acetylcysteine\n(disrupt ULVWF-platelet, exp.)", shape=box3d, fillcolor="#D7BDE2"]
    recomb_A13     [label="Recombinant ADAMTS13\n(rADAMTS13, phase III)", shape=box3d, fillcolor="#AED6F1"]
  }

  // ========== CLUSTER 13: Clinical Endpoints & Scoring ==========
  subgraph cluster_clinical {
    label="⑬ Clinical Endpoints, Scoring & Response Assessment"
    style=filled; color="#F8F9FA"; pencolor="#2C3E50"; penwidth=2
    fontname="Helvetica-Bold"; fontsize=11

    PLASMIC_score  [label="PLASMIC Score\n(0–7, probability of TTP)", shape=hexagon, fillcolor="#BFC9CA"]
    clinical_resp  [label="Clinical Response\nPLT>150×10⁹/L ≥2d", shape=octagon, fillcolor="#85929E"]
    complete_remis [label="Complete Remission\n(PLT normal + LDH normal + no organ failure)", shape=hexagon, fillcolor="#5D6D7E", fontcolor=white]
    relapse_risk   [label="Relapse Risk\nADAMTS13 <10% off therapy", shape=hexagon, fillcolor="#E74C3C", fontcolor=white]
    exacerb_event  [label="Exacerbation Event\n(PLT↓ after initial response)", shape=hexagon, fillcolor="#E74C3C", fontcolor=white]
    mortality_30d  [label="30-day Mortality\n(~10–20% without treatment)", shape=hexagon, fillcolor="#2C3E50", fontcolor=white]
    TTR            [label="Time to Response\n(PLT>150k, days)", shape=octagon, fillcolor="#85929E"]
    TPE_sessions   [label="Number of TPE\nSessions (n)", shape=octagon, fillcolor="#85929E"]
    hospital_stay  [label="Hospital LOS\n(days)", shape=octagon, fillcolor="#BFC9CA"]
    ICU_admit      [label="ICU Admission\n(neuro / cardiac / multi-organ)", shape=hexagon, fillcolor="#2C3E50", fontcolor=white]
    TMA_score      [label="TMA Composite Score\n(PLT + LDH + Cr + Neuro)", shape=hexagon, fillcolor="#5D6D7E", fontcolor=white]
    immunologic_CR [label="Immunologic Remission\nADAMTS13 >50% + Ab undetect", shape=octagon, fillcolor="#85929E"]
    long_term_remis[label="Long-Term Remission\n(2-year relapse-free)", shape=hexagon, fillcolor="#5D6D7E", fontcolor=white]
  }

  // ===================== EDGES =====================

  // ADAMTS13 Biology
  ADAMTS13_gene -> ADAMTS13_hepato [label="transcription"]
