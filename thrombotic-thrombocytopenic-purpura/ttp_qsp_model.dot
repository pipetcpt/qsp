  ADAMTS13_VWF_bind -> VWF_cleavage [label="positions"]
  ADAMTS13_inhibitor -> inhibitor_titer [label="quantify (Bethesda)"]
  ADAMTS13_inhibitor -> ADAMTS13_clearance [label="opsonize→FcR"]
  ADAMTS13_clearance -> ADAMTS13_plasma [label="↓ activity", color=red, style=dashed]
  ADAMTS13_plasma -> ADAMTS13_threshold [label="<10% = critical", color=red]
  ADAMTS13_inhibitor -> ADAMTS13_plasma [label="direct neutralize", color=red, style=dashed]

  // VWF flows
  VWF_gene -> VWF_endothelial [label="transcription"]
