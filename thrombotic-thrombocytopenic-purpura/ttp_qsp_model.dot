  PLT_activation -> ADP_rel [label="dense granule"]
  PLT_activation -> P_selectin [label="alpha granule"]
  PLT_activation -> TXA2 [label="COX-1→TXA2"]
  PLT_fibrinogen -> GPIIb_IIIa [label="cross-links"]
  PLT_activation -> PLT_fibrinogen [label="activate αIIbβ3"]

  // Endothelial flows
  EC_shear -> EC_activation [label="triggers"]
