digraph ApasticAnemiaQSP {
    graph [
        label="Aplastic Anemia (AA) — Quantitative Systems Pharmacology Model\nImmune-Mediated HSC Destruction · Hematopoietic Recovery · Drug PK/PD"
        labelloc=t fontsize=22 fontname="Helvetica-Bold"
        bgcolor="#FAFAFA" rankdir=TB splines=ortho nodesep=0.5 ranksep=0.8
        pad=0.5
    ]
    node [fontname="Helvetica" fontsize=10 style="filled,rounded" shape=box]
    edge [fontname="Helvetica" fontsize=9]

    // ===== CLUSTER 1: IMMUNE TRIGGER & ANTIGEN PRESENTATION =====
    subgraph cluster_trigger {
        label="Immune Trigger & Antigen Presentation"
        style=filled fillcolor="#FFE8E8" color="#CC3333" penwidth=2 fontname="Helvetica-Bold" fontsize=13

        Trigger [label="Environmental Trigger\n(Viral, Chemical, Radiation)" fillcolor="#FF9999"]
        HLA_DR [label="HLA-DR\nPresentation" fillcolor="#FFBBBB"]
        APC [label="APC\n(Dendritic Cell)" fillcolor="#FFBBBB"]
        CD4_naive [label="Naive CD4+ T Cell" fillcolor="#FFCCCC"]
        CD8_naive [label="Naive CD8+ T Cell" fillcolor="#FFCCCC"]
        MHC_I [label="MHC Class I\nPresentation" fillcolor="#FFBBBB"]
        CrossReact [label="Cross-Reactive\nAutoantigen" fillcolor="#FF9999"]
        pDC [label="Plasmacytoid DC\n(IFN-I production)" fillcolor="#FFBBBB"]
    }

    // ===== CLUSTER 2: T CELL ACTIVATION & EXPANSION =====
    subgraph cluster_tcell {
        label="T Cell Activation & Clonal Expansion"
        style=filled fillcolor="#FFE8FF" color="#993399" penwidth=2 fontname="Helvetica-Bold" fontsize=13

        CD4_Th1 [label="Th1 CD4+ T Cell\n(IFN-γ, IL-2 producer)" fillcolor="#EE99EE"]
        CD8_CTL [label="CD8+ CTL\n(Cytotoxic)" fillcolor="#EE99EE"]
        Treg [label="Regulatory T Cell\n(Treg, FoxP3+)" fillcolor="#DDAADD"]
        Treg_def [label="Treg Deficiency\n(Reduced FoxP3+)" fillcolor="#FF88FF"]
        CD4_mem [label="CD4+ Memory T Cell" fillcolor="#EE99EE"]
        CD8_mem [label="CD8+ Memory T Cell" fillcolor="#EE99EE"]
        TCR [label="TCR Clonal\nExpansion" fillcolor="#CC77CC"]
        NKT [label="NKT Cell\n(CD161+)" fillcolor="#DDAADD"]
        NK [label="NK Cell\n(CD56+)" fillcolor="#DDAADD"]
        IL2R [label="IL-2 Receptor\n(CD25)" fillcolor="#CC77CC"]
        CTLA4 [label="CTLA-4\n(Co-inhibitory)" fillcolor="#DDAADD"]
        PD1 [label="PD-1\n(Checkpoint)" fillcolor="#DDAADD"]
    }

    // ===== CLUSTER 3: PRO-INFLAMMATORY CYTOKINES =====
    subgraph cluster_cytokines {
        label="Pro-inflammatory Cytokine Network"
        style=filled fillcolor="#FFF0CC" color="#CC8800" penwidth=2 fontname="Helvetica-Bold" fontsize=13

        IFNg [label="IFN-γ\n(Key mediator)" fillcolor="#FFDD77" shape=ellipse]
        TNFa [label="TNF-α\n(Apoptosis)" fillcolor="#FFDD77" shape=ellipse]
        IL2 [label="IL-2\n(T cell growth)" fillcolor="#FFEE99" shape=ellipse]
        IL6 [label="IL-6\n(Inflammation)" fillcolor="#FFEE99" shape=ellipse]
        IL15 [label="IL-15\n(NK/T survival)" fillcolor="#FFEE99" shape=ellipse]
        IL18 [label="IL-18\n(IFN-γ inducer)" fillcolor="#FFEE99" shape=ellipse]
        GM_CSF [label="GM-CSF\n(Myeloid growth)" fillcolor="#FFD966" shape=ellipse]
        MIF [label="MIF\n(Migration inh. factor)" fillcolor="#FFEE99" shape=ellipse]
        CXCL9 [label="CXCL9/10\n(T cell recruit)" fillcolor="#FFEE99" shape=ellipse]
        TGFb [label="TGF-β\n(Anti-inflam)" fillcolor="#CCEE99" shape=ellipse]
        IL10 [label="IL-10\n(Anti-inflam)" fillcolor="#CCEE99" shape=ellipse]
    }

    // ===== CLUSTER 4: HSC COMPARTMENT & APOPTOSIS =====
    subgraph cluster_hsc {
        label="HSC Compartment & Destruction Pathways"
        style=filled fillcolor="#E8F4E8" color="#336633" penwidth=2 fontname="Helvetica-Bold" fontsize=13

        HSC_LT [label="Long-term HSC\n(LT-HSC, CD34+CD38-)" fillcolor="#99CC99" shape=diamond]
        HSC_ST [label="Short-term HSC\n(ST-HSC)" fillcolor="#AADDAA"]
        MPP [label="Multipotent Progenitor\n(MPP)" fillcolor="#BBDDBB"]
        FasR [label="Fas Receptor\n(CD95, upregulated by IFN-γ)" fillcolor="#CC9999"]
        FasL [label="FasL\n(on CTL surface)" fillcolor="#CC9999"]
        Caspase [label="Caspase Cascade\n(Apoptosis)" fillcolor="#FF7777"]
        Perforin [label="Perforin/Granzyme B\n(CTL-mediated kill)" fillcolor="#FF7777"]
        NFkB [label="NF-κB\n(Activation)" fillcolor="#FFAA77"]
        Bcl2 [label="Bcl-2/Bcl-xL\n(Anti-apoptotic)" fillcolor="#AADDAA"]
        p53 [label="p53\n(Apoptosis activator)" fillcolor="#FF9999"]
        ROS [label="ROS\n(Oxidative stress)" fillcolor="#FFAA77"]
        Telomere [label="Telomere\nAttrition" fillcolor="#FFCCAA"]
        HSC_pool [label="HSC Pool Size\n(% of normal)" fillcolor="#66BB66" shape=ellipse]
        PNH_clone [label="PNH Clone\n(GPI-anchor deficient)" fillcolor="#FFDD99"]
        CDKN1A [label="CDKN1A/p21\n(Cell cycle arrest)" fillcolor="#FFAA77"]
    }

    // ===== CLUSTER 5: BONE MARROW MICROENVIRONMENT =====
    subgraph cluster_bme {
        label="Bone Marrow Microenvironment"
        style=filled fillcolor="#E8EEFF" color="#3355AA" penwidth=2 fontname="Helvetica-Bold" fontsize=13

        MSC [label="Mesenchymal\nStem Cell (MSC)" fillcolor="#AABBEE"]
        OsteoBl [label="Osteoblast\n(HSC niche)" fillcolor="#AABBEE"]
        Endothel [label="Bone Marrow\nEndothelial Cell" fillcolor="#AABBEE"]
        CXCL12 [label="CXCL12/SDF-1\n(HSC retention)" fillcolor="#BBCCFF" shape=ellipse]
        SCF [label="Stem Cell Factor\n(SCF/KitL)" fillcolor="#BBCCFF" shape=ellipse]
        TPO_bm [label="Thrombopoietin\n(TPO, c-Mpl)" fillcolor="#BBCCFF" shape=ellipse]
        EPO_bm [label="Erythropoietin\n(EPO, EpoR)" fillcolor="#BBCCFF" shape=ellipse]
        Ang1 [label="Angiopoietin-1\n(Niche protection)" fillcolor="#BBCCFF" shape=ellipse]
        VCAM1 [label="VCAM-1\n(Adhesion molecule)" fillcolor="#AABBEE"]
        BM_fat [label="BM Adipocyte\n(Replaces HSC niche)" fillcolor="#FFDDBB"]
        BM_fibrosis [label="BM Fibrosis\n(Stromal damage)" fillcolor="#FFBBAA"]
        Macrophage [label="BM Macrophage\n(Osteoclast)" fillcolor="#FFBBAA"]
    }

    // ===== CLUSTER 6: HEMATOPOIESIS & LINEAGE DIFFERENTIATION =====
    subgraph cluster_hematopoiesis {
        label="Hematopoiesis & Lineage Differentiation"
        style=filled fillcolor="#F0F8E8" color="#448844" penwidth=2 fontname="Helvetica-Bold" fontsize=13

        CMP [label="Common Myeloid\nProgenitor (CMP)" fillcolor="#CCEECC"]
        CLP [label="Common Lymphoid\nProgenitor (CLP)" fillcolor="#CCEECC"]
        MEP [label="Megakaryocyte-\nErythroid Prog. (MEP)" fillcolor="#CCEECC"]
        GMP [label="Granulocyte-Macrophage\nProgenitor (GMP)" fillcolor="#CCEECC"]
        BFU_E [label="BFU-E\n(Erythroid burst)" fillcolor="#DDDDEE"]
        CFU_E [label="CFU-E\n(Erythroid colony)" fillcolor="#DDDDEE"]
        Retic [label="Reticulocyte\n(Immature RBC)" fillcolor="#EEDDDD"]
        RBC [label="RBC (Mature)\nLifespan ~120d" fillcolor="#EE9999"]
        MK [label="Megakaryocyte\n(Ploidy ↑)" fillcolor="#EEDDBB"]
        PLT [label="Platelet\nLifespan ~10d" fillcolor="#DDBB77"]
        Promonocyte [label="Promonocyte\n→ Monocyte" fillcolor="#DDCCAA"]
        Mono [label="Monocyte\n→ Macrophage" fillcolor="#DDCCAA"]
        Neutrophil [label="Neutrophil\nLifespan ~8h" fillcolor="#CCDDAA"]
        Myelocyte [label="Myelocyte →\nMetamyelocyte" fillcolor="#CCDDAA"]
        Lymphocyte [label="B Cell\n(Lymphopoiesis)" fillcolor="#BBCCDD"]
    }

    // ===== CLUSTER 7: PERIPHERAL BLOOD & CLINICAL ENDPOINTS =====
    subgraph cluster_blood {
        label="Peripheral Blood & Clinical Endpoints"
        style=filled fillcolor="#FFF5E8" color="#AA6600" penwidth=2 fontname="Helvetica-Bold" fontsize=13

        Hgb [label="Hemoglobin\n(g/dL)" fillcolor="#FF9966" shape=ellipse]
        Hct [label="Hematocrit\n(%)" fillcolor="#FF9966" shape=ellipse]
        ANC [label="ANC\n(Absolute Neutrophil Count)" fillcolor="#FFBB88" shape=ellipse]
        ARC [label="ARC\n(Absolute Reticulocyte Count)" fillcolor="#FFCC99" shape=ellipse]
        PLT_count [label="Platelet Count\n(×10⁹/L)" fillcolor="#FFDD88" shape=ellipse]
        Lymph_count [label="Lymphocyte Count\n(×10⁹/L)" fillcolor="#EEDDAA" shape=ellipse]
        TransReq [label="Transfusion\nRequirement" fillcolor="#FF7744"]
        Bleeding [label="Bleeding Risk\n(Petechiae, purpura)" fillcolor="#FF4444"]
        Infection [label="Infection Risk\n(Febrile neutropenia)" fillcolor="#FF6666"]
        Fatigue [label="Fatigue\n(Anemia-related)" fillcolor="#FFAAAA"]
        Severity_SAA [label="Severity Classification\n(SAA/VSAA/nSAA)" fillcolor="#FF8844" shape=diamond]
    }

    // ===== CLUSTER 8: DRUG PK — ATG =====
    subgraph cluster_pk_atg {
        label="Drug PK: Anti-Thymocyte Globulin (ATG)"
        style=filled fillcolor="#E8F0FF" color="#1144AA" penwidth=2 fontname="Helvetica-Bold" fontsize=13

        ATG_dose [label="ATG Dose\n(hATG 40mg/kg/d × 4d\nor rATG 3.5mg/kg/d × 5d)" fillcolor="#99AAFF"]
        ATG_infusion [label="ATG IV Infusion\n(over 12-18h)" fillcolor="#AABBFF"]
        ATG_central [label="ATG Central\nCompartment (Vc)" fillcolor="#AABBFF"]
        ATG_periph [label="ATG Peripheral\nCompartment (Vp)" fillcolor="#BBCCFF"]
        ATG_CL [label="ATG Clearance\n(CL, rapid)" fillcolor="#8899EE"]
        ATG_Cmax [label="ATG Cmax\n(~6.4 mg/L)" fillcolor="#99AAEE"]
        ATG_AUC [label="ATG AUC\n(μg·h/mL)" fillcolor="#99AAEE"]
        ATG_trough [label="ATG Trough\nLevel" fillcolor="#AABBDD"]
    }

    // ===== CLUSTER 9: DRUG PK — CYCLOSPORINE =====
    subgraph cluster_pk_csa {
        label="Drug PK: Cyclosporine (CsA)"
        style=filled fillcolor="#EEF8FF" color="#2266CC" penwidth=2 fontname="Helvetica-Bold" fontsize=13

        CsA_dose [label="CsA Dose\n(5 mg/kg/d, PO BID)" fillcolor="#99CCFF"]
        CsA_abs [label="CsA Absorption\n(F ~34%, variable)" fillcolor="#AADDFF"]
        CsA_central [label="CsA Central\nCompartment" fillcolor="#AADDFF"]
        CsA_RBC [label="CsA RBC\nDistribution (~58%)" fillcolor="#BBDDFF"]
        CsA_trough [label="CsA Trough\n(Target 150-250 ng/mL)" fillcolor="#99BBEE"]
        CsA_CYP3A4 [label="CYP3A4\nMetabolism" fillcolor="#8899DD"]
        CsA_CL [label="CsA Clearance\n(t½ ~27h)" fillcolor="#8899DD"]
        CsA_DDI [label="Drug Interactions\n(CYP3A4 inhibitors/inducers)" fillcolor="#AABBDD"]
    }

    // ===== CLUSTER 10: DRUG PK — ELTROMBOPAG =====
    subgraph cluster_pk_eltro {
        label="Drug PK: Eltrombopag (EPAG)"
        style=filled fillcolor="#EEF5FF" color="#4477CC" penwidth=2 fontname="Helvetica-Bold" fontsize=13

        EPAG_dose [label="EPAG Dose\n(150 mg/d PO or\n75 mg/d in East Asian)" fillcolor="#AABBFF"]
        EPAG_abs [label="EPAG Absorption\n(F ~52%, food dependent)" fillcolor="#BBCCFF"]
        EPAG_central [label="EPAG Central\nCompartment" fillcolor="#BBCCFF"]
        EPAG_trough [label="EPAG Trough\n(≥ 70 μg/mL target)" fillcolor="#AABBEE"]
        EPAG_CYP [label="CYP1A2/2C8\nMetabolism" fillcolor="#99AADD"]
        EPAG_CL [label="EPAG Clearance\n(t½ ~21h)" fillcolor="#99AADD"]
        EPAG_metal [label="Metal Chelation\n(Avoid Ca/Mg/Al within 4h)" fillcolor="#BBBBDD"]
    }

    // ===== CLUSTER 11: DRUG PD — MECHANISMS =====
    subgraph cluster_pd {
        label="Drug Pharmacodynamics & Mechanisms of Action"
        style=filled fillcolor="#F5F0FF" color="#6633AA" penwidth=2 fontname="Helvetica-Bold" fontsize=13

        ATG_pd [label="ATG: T Cell Depletion\n(Anti-CD2/CD3/CD4/CD8/CD11a/CD25)" fillcolor="#CC99FF"]
        ATG_ADCC [label="ADCC\n(Fc-mediated killing)" fillcolor="#DDAAFF"]
        ATG_comp [label="Complement-mediated\nLysis" fillcolor="#DDAAFF"]
        CsA_pd [label="CsA: Calcineurin Inhibition\n(→ NFAT block → ↓IL-2)" fillcolor="#BB88FF"]
        Calcineurin [label="Calcineurin\n(PP2B phosphatase)" fillcolor="#CCAAFF"]
        NFAT [label="NFAT\n(Nuclear factor)" fillcolor="#CCAAFF"]
        IL2_block [label="IL-2 Transcription\nBlockade" fillcolor="#DDBBFF"]
        EPAG_pd [label="EPAG: TPO-R Agonism\n(c-Mpl stimulation)" fillcolor="#BB88FF"]
        JAK2_STAT5 [label="JAK2/STAT5\nSignaling" fillcolor="#CCAAFF"]
        HSC_stim [label="HSC Stimulation\n(Self-renewal ↑)" fillcolor="#AABB99"]
        Androgen_pd [label="Androgen: EPO↑\nBCL2↑, HSC expansion" fillcolor="#FFCCAA"]
        Danazol_dose [label="Danazol\n(400-800 mg/d)" fillcolor="#FFBBAA"]
        hATG_vs_rATG [label="hATG vs rATG\n(Response rate differential)" fillcolor="#EE88EE"]
        HSCT_cond [label="HSCT Conditioning\n(Cy/ATG or Flu/Cy)" fillcolor="#FF8877"]
    }

    // ===== CLUSTER 12: DISEASE SEVERITY & CLINICAL RESPONSE =====
    subgraph cluster_outcome {
        label="Disease Severity Classification & Clinical Outcomes"
        style=filled fillcolor="#F8F8F0" color="#777700" penwidth=2 fontname="Helvetica-Bold" fontsize=13

        nSAA [label="Non-Severe AA\n(nSAA)" fillcolor="#EEDD88"]
        SAA [label="Severe AA (SAA)\n(ANC <0.5 + 2 criteria)" fillcolor="#FFAA44"]
        VSAA [label="Very Severe AA\n(VSAA, ANC <0.2)" fillcolor="#FF7722"]
        CR [label="Complete Response\n(CR: all counts normal)" fillcolor="#66BB66"]
        PR [label="Partial Response\n(PR: transfusion-independent)" fillcolor="#AABB44"]
        NR [label="No Response\n(NR)" fillcolor="#DD4444"]
        Relapse [label="Relapse\n(post-CR/PR)" fillcolor="#FF6633"]
        Clonal_evol [label="Clonal Evolution\n(MDS/AML/PNH)" fillcolor="#FF3333"]
        MDS_transf [label="MDS Transformation\n(Monosomy 7, complex)" fillcolor="#FF5544"]
        PNH_expand [label="PNH Clone\nExpansion" fillcolor="#FFAA66"]
        GVHD [label="GvHD\n(post-HSCT)" fillcolor="#FF9977"]
        Graft_fail [label="Graft Failure\n(post-HSCT)" fillcolor="#FF6655"]
        Survival [label="Overall Survival\n(5-yr ~80%)" fillcolor="#44BB44" shape=diamond]
    }

    // ===== CLUSTER 13: SUPPORTIVE CARE =====
    subgraph cluster_support {
        label="Supportive Care & Monitoring"
        style=filled fillcolor="#F0FFF0" color="#228822" penwidth=2 fontname="Helvetica-Bold" fontsize=13

        pRBC [label="pRBC Transfusion\n(Hgb threshold <8 g/dL)" fillcolor="#FFAAAA"]
        PLT_transf [label="Platelet Transfusion\n(<10×10⁹/L)" fillcolor="#FFDDAA"]
        G_CSF [label="G-CSF\n(Neutropenia support)" fillcolor="#AADDAA"]
        Abx [label="Antimicrobial\nProphylaxis" fillcolor="#AABBAA"]
        IronChelation [label="Iron Chelation\n(Deferasirox)" fillcolor="#AABBCC"]
        CBC_monitor [label="CBC Monitoring\n(Weekly → monthly)" fillcolor="#CCDDAA"]
        BM_biopsy [label="Bone Marrow\nBiopsy (cellularity)" fillcolor="#CCCCAA"]
        Flow_PNH [label="Flow Cytometry\n(PNH clone size)" fillcolor="#AACCBB"]
        Chromosome [label="Chromosome Analysis\n(Cytogenetics)" fillcolor="#AACCBB"]
        HLA_typing [label="HLA Typing\n(Donor search)" fillcolor="#AABB99"]
    }

    // ================================================================
    // EDGES — IMMUNE PATHOGENESIS
    // ================================================================
    Trigger -> APC [label="antigen uptake" color="#CC3333"]
    Trigger -> CrossReact [label="molecular mimicry" color="#CC3333"]
    APC -> HLA_DR [label="present via" color="#993399"]
    APC -> MHC_I [label="present via" color="#993399"]
    HLA_DR -> CD4_naive [label="activate" color="#993399"]
    MHC_I -> CD8_naive [label="activate" color="#993399"]
    CrossReact -> CD8_naive [label="auto-antigen" color="#CC3333"]
    pDC -> IFNg [label="IFN-I→IFN-γ" color="#CC8800"]
    CD4_naive -> CD4_Th1 [label="differentiate" color="#993399"]
    CD4_naive -> Treg [label="FoxP3 induction\n(impaired in AA)" style=dashed color="#993399"]
    CD8_naive -> CD8_CTL [label="expand" color="#993399"]
    CD4_Th1 -> TCR [label="TCR clonal exp." color="#993399"]
    CD8_CTL -> TCR [label="oligoclonal" color="#993399"]
    Treg_def -> CD8_CTL [label="loss of suppression" color="#FF0000" penwidth=2]
    Treg -> Treg_def [label="reduced in AA" color="#FF0000"]
    IL2R -> CD8_CTL [label="growth signal" color="#993399"]
    NKT -> IFNg [label="produce" color="#CC8800"]
    NK -> IFNg [label="produce" color="#CC8800"]

    // CYTOKINE PRODUCTION
    CD4_Th1 -> IFNg [label="major source" color="#CC8800" penwidth=2]
    CD4_Th1 -> IL2 [label="produce" color="#CC8800"]
    CD4_Th1 -> TNFa [label="produce" color="#CC8800"]
    CD8_CTL -> IFNg [label="produce" color="#CC8800"]
    CD8_CTL -> TNFa [label="produce" color="#CC8800"]
    IL2 -> CD8_CTL [label="proliferation" color="#CC8800" dir=back]
    IL2 -> IL2R [label="upregulate" color="#CC8800"]
    IL6 -> APC [label="stimulate" color="#CC8800"]
    IL15 -> NK [label="survival signal" color="#CC8800"]
    IL18 -> IFNg [label="synergize" color="#CC8800"]
    GM_CSF -> Macrophage [label="activate" color="#CC8800"]
    CXCL9 -> CD8_CTL [label="recruit to BM" color="#CC8800" penwidth=2]
    IFNg -> CXCL9 [label="induce" color="#CC8800"]

    // HSC DESTRUCTION
    IFNg -> FasR [label="upregulate\non HSC" color="#CC3333" penwidth=2]
    FasL -> FasR [label="bind → apoptosis" color="#CC3333" penwidth=2]
    CD8_CTL -> FasL [label="express" color="#993399"]
    CD8_CTL -> Perforin [label="release" color="#993399" penwidth=2]
    FasR -> Caspase [label="activate" color="#CC3333"]
    Perforin -> Caspase [label="granzyme B" color="#CC3333"]
    TNFa -> NFkB [label="activate" color="#CC8800"]
    NFkB -> Caspase [label="pro-apoptotic\n(TNF-R1)" color="#CC3333"]
    TNFa -> ROS [label="induce" color="#CC8800"]
    IFNg -> ROS [label="oxidative burst" color="#CC8800"]
    ROS -> p53 [label="DNA damage" color="#CC3333"]
    p53 -> Caspase [label="activate" color="#CC3333"]
    p53 -> CDKN1A [label="p21 induction" color="#CC3333"]
    CDKN1A -> HSC_LT [label="cell cycle arrest" color="#CC3333"]
    Caspase -> HSC_LT [label="APOPTOSIS" color="#CC0000" penwidth=3 style=bold]
    Caspase -> HSC_ST [label="apoptosis" color="#CC0000" penwidth=2]
    Telomere -> Caspase [label="crisis" color="#CC3333"]
    Bcl2 -> Caspase [label="inhibit" color="#336633" style=dashed arrowhead=tee]

    // HSC COMPARTMENT
    HSC_LT -> HSC_pool [label="contribute" color="#336633" penwidth=2]
    HSC_LT -> HSC_ST [label="self-renew →\ndifferentiate" color="#336633"]
    HSC_ST -> MPP [label="differentiate" color="#336633"]
    MPP -> CMP [label="specify" color="#448844"]
    MPP -> CLP [label="specify" color="#448844"]
    PNH_clone -> HSC_LT [label="GPI-deficient\nsubpopulation" color="#CC8800" style=dashed]
    PNH_clone -> PNH_expand [label="expand\n(immune escape)" color="#CC8800"]

    // BME SUPPORT
    MSC -> CXCL12 [label="secrete" color="#3355AA"]
    MSC -> SCF [label="secrete" color="#3355AA"]
    Endothel -> SCF [label="secrete" color="#3355AA"]
    OsteoBl -> Ang1 [label="secrete" color="#3355AA"]
    OsteoBl -> CXCL12 [label="secrete" color="#3355AA"]
    CXCL12 -> HSC_LT [label="retain in niche" color="#3355AA"]
    SCF -> HSC_LT [label="survival + prolif" color="#3355AA"]
    Ang1 -> HSC_LT [label="quiescence" color="#3355AA"]
    VCAM1 -> HSC_LT [label="adhesion" color="#3355AA"]
    BM_fat -> BM_fibrosis [label="adipogenesis →\nfibrosis" color="#CC7700"]
    IFNg -> MSC [label="impair function" color="#CC3333" style=dashed]
    TNFa -> Endothel [label="damage" color="#CC3333" style=dashed]
    Macrophage -> BM_fibrosis [label="promote" color="#CC3333"]

    // HEMATOPOIESIS
    CMP -> MEP [label="bifurcate" color="#448844"]
    CMP -> GMP [label="bifurcate" color="#448844"]
    CLP -> Lymphocyte [label="→ B cell" color="#448844"]
    MEP -> BFU_E [label="erythroid" color="#448844"]
    MEP -> MK [label="megakaryocytic" color="#448844"]
    BFU_E -> CFU_E [label="EPO-dep" color="#448844"]
    EPO_bm -> CFU_E [label="rescue" color="#3355AA"]
    CFU_E -> Retic [label="mature" color="#448844"]
    Retic -> RBC [label="enucleate" color="#448844"]
    TPO_bm -> MK [label="maturation" color="#3355AA"]
    EPAG_pd -> TPO_bm [label="mimic TPO" color="#6633AA"]
    MK -> PLT [label="thrombopoiesis" color="#448844"]
    GMP -> Myelocyte [label="granulopoiesis" color="#448844"]
    Myelocyte -> Neutrophil [label="mature" color="#448844"]
    GMP -> Promonocyte [label="monopoiesis" color="#448844"]
    Promonocyte -> Mono [label="mature" color="#448844"]
    G_CSF -> GMP [label="stimulate" color="#228822"]
    GM_CSF -> GMP [label="stimulate" color="#228822"]

    // PERIPHERAL BLOOD
    RBC -> Hgb [label="determine" color="#AA6600"]
    RBC -> Hct [label="determine" color="#AA6600"]
    Neutrophil -> ANC [label="constitute" color="#AA6600"]
    Retic -> ARC [label="peripheral ARC" color="#AA6600"]
    PLT -> PLT_count [label="constitute" color="#AA6600"]
    Lymphocyte -> Lymph_count [label="constitute" color="#AA6600"]
    HSC_pool -> ANC [label="drive production" color="#336633" penwidth=2]
    HSC_pool -> Hgb [label="drive production" color="#336633" penwidth=2]
    HSC_pool -> PLT_count [label="drive production" color="#336633" penwidth=2]

    // CLINICAL SEVERITY
    ANC -> Severity_SAA [label="ANC <0.5 K/μL" color="#AA6600"]
    PLT_count -> Severity_SAA [label="PLT <20 K/μL" color="#AA6600"]
    ARC -> Severity_SAA [label="ARC <20 K/μL" color="#AA6600"]
    Severity_SAA -> nSAA [label="mild" color="#777700"]
    Severity_SAA -> SAA [label="ANC<0.5" color="#AA4400"]
    Severity_SAA -> VSAA [label="ANC<0.2" color="#CC2200"]
    ANC -> Infection [label="risk ↑" color="#CC3333"]
    PLT_count -> Bleeding [label="risk ↑" color="#CC3333"]
    Hgb -> Fatigue [label="cause" color="#CC3333"]
