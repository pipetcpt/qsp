digraph AplasticAnemia_QSP {
  graph [rankdir=LR, fontname="Helvetica", fontsize=10, bgcolor="#F8F8FF",
         label="Aplastic Anemia: Comprehensive QSP Mechanistic Map\n(Acquired AA: Immune-Mediated HSC Destruction | Drug PK/PD: ATG · CsA · Eltrombopag · Danazol)\n12 Clusters | 130+ Nodes | 120+ Edges",
         labelloc=t, labeljust=c, fontsize=14, fontcolor="#1a1a2e",
         nodesep=0.25, ranksep=0.5, compound=true]

  node [fontname="Helvetica", fontsize=8, style="filled,rounded", margin="0.05,0.02"]
  edge [fontname="Helvetica", fontsize=7, arrowsize=0.65]

  // =========================================================
  // CLUSTER 1: Environmental Triggers & Susceptibility
  // =========================================================
  subgraph cluster_trigger {
    label="1. Environmental Triggers & Susceptibility"
    style=filled; fillcolor="#FFF0F0"; color="#CC4444"; fontcolor="#CC4444"; penwidth=2

    HLA_DR15    [label="HLA-DR15\nSusceptibility Allele",   shape=diamond, fillcolor="#FFB3B3"]
    Viral_EBV   [label="Viral Trigger\n(EBV)",              shape=box,     fillcolor="#FFD0D0"]
    Viral_CMV   [label="Viral Trigger\n(CMV)",              shape=box,     fillcolor="#FFD0D0"]
    Viral_Hep   [label="Hepatitis Virus\n(Hep-NANE/HCV)",  shape=box,     fillcolor="#FFD0D0"]
    Viral_Parvo [label="Parvovirus B19\n(erythroid trop.)",shape=box,     fillcolor="#FFD0D0"]
    Chemical    [label="Chemical Exposure\n(Benzene, Pesticides)", shape=box, fillcolor="#FFB0B0"]
    Drug_Trig   [label="Drug-Induced\n(Chloramphenicol, CBZ)",    shape=box, fillcolor="#FFB0B0"]
    Radiation   [label="Radiation\nExposure",               shape=box,     fillcolor="#FFB0B0"]
    Idiopathic  [label="Idiopathic\n(~70% of cases)",       shape=box,     fillcolor="#FF9090"]
    TCR_Clonal  [label="Oligoclonal\nTCR Expansion",        shape=ellipse, fillcolor="#FF7070"]
    Antigen_Pres[label="Antigen\nPresentation (DC→T)",      shape=ellipse, fillcolor="#FFB3B3"]
    MHC_II      [label="MHC-II Peptide\nPresentation",      shape=box,     fillcolor="#FFD0D0"]
    Mol_Mim     [label="Molecular Mimicry\n(cross-reactive T cells)", shape=box, fillcolor="#FFD0D0"]
  }

  // =========================================================
  // CLUSTER 2: Innate Immune Activation
  // =========================================================
  subgraph cluster_innate {
    label="2. Innate Immune Activation"
    style=filled; fillcolor="#E8F4FF"; color="#2266AA"; fontcolor="#2266AA"; penwidth=2

    pDC         [label="Plasmacytoid DC\n(pDC)", shape=ellipse, fillcolor="#AACCFF"]
    mDC         [label="Myeloid DC\n(mDC)",       shape=ellipse, fillcolor="#AACCFF"]
    NK_cell     [label="NK Cell",                  shape=ellipse, fillcolor="#88AAFF"]
    NKT_cell    [label="NKT Cell\n(CD1d-restrict.)",shape=ellipse,fillcolor="#88AAFF"]
    Macrophage  [label="Macrophage\n(BM/spleen)", shape=ellipse, fillcolor="#AACCFF"]
    TLR_sig     [label="TLR3/7/9\nSignaling",     shape=box,     fillcolor="#CCE4FF"]
    NF_kB       [label="NF-κB\nActivation",       shape=ellipse, fillcolor="#AACCFF"]
    IL12_inn    [label="IL-12\n(DC→Th1 polar.)", shape=box,     fillcolor="#DDEECC"]
    IL15_inn    [label="IL-15\n(NK/CD8 activ.)", shape=box,     fillcolor="#DDEECC"]
    TNFa_mac    [label="TNF-α\n(Macrophage)",     shape=box,     fillcolor="#FFE0AA"]
    IFNg_NK     [label="IFN-γ\n(NK-derived)",    shape=box,     fillcolor="#FFE0AA"]
    IL18_inn    [label="IL-18\n(NLRP3/DC)",       shape=box,     fillcolor="#DDEECC"]
  }

  // =========================================================
  // CLUSTER 3: Autoreactive T-Cell Biology
  // =========================================================
  subgraph cluster_Tcell {
    label="3. Autoreactive T-Cell Biology (Core Driver)"
    style=filled; fillcolor="#E0F0FF"; color="#1144CC"; fontcolor="#1144CC"; penwidth=2

    Naive_CD4   [label="Naive CD4+ T Cell",          shape=ellipse, fillcolor="#99CCFF"]
    Th1_cell    [label="Th1 CD4+ Helper\n(T-bet+, IFN-γ+)", shape=ellipse, fillcolor="#77AAFF"]
    Naive_CD8   [label="Naive CD8+ T Cell",           shape=ellipse, fillcolor="#99CCFF"]
    Eff_CD8     [label="Effector CD8+\nCytotoxic T Cell",   shape=ellipse, fillcolor="#5588FF", fontcolor="white", penwidth=2]
    Treg        [label="Regulatory T Cell\n(CD4+CD25+FoxP3+)\n[DEPLETED in AA]", shape=ellipse, fillcolor="#FF9944"]
    Tbet        [label="T-bet Transcription\nFactor",  shape=box,     fillcolor="#AADDFF"]
    STAT1_T     [label="STAT1 Activation\n(CD8+ T cells)", shape=box, fillcolor="#BBDDFF"]
    Perforin    [label="Perforin/\nGranzyme B",        shape=box,     fillcolor="#FF8888"]
    FasL_T      [label="FasL Expression\n(CTL surface)",    shape=box, fillcolor="#FF8888"]
    TCR_ZAP70   [label="TCR/CD3 → ZAP-70 → LAT\n(T-cell activation)", shape=box, fillcolor="#BBCCFF"]
    Calcineurin [label="Calcineurin (CN)",             shape=box,     fillcolor="#BBCCFF"]
    NFATc1      [label="NFATc1\n(IL-2/IFN-γ transcr.)",shape=box,    fillcolor="#BBCCFF"]
    CTLA4       [label="CTLA-4\n(Treg suppressor signal)", shape=box, fillcolor="#FFCCAA"]
    PD1_path    [label="PD-1/PD-L1\n(exhaustion axis)", shape=box,   fillcolor="#FFCCAA"]
    CD28_cosig  [label="CD28\nCo-stimulation",         shape=box,     fillcolor="#BBCCFF"]
    IL2_Tcell   [label="IL-2 Signaling\n(CD8 proliferation)", shape=box, fillcolor="#CCEEFF"]
  }

  // =========================================================
  // CLUSTER 4: Cytokine Network
  // =========================================================
  subgraph cluster_cytokines {
    label="4. Cytokine Network & HSC-Killing Signals"
    style=filled; fillcolor="#FFFBE0"; color="#AA8800"; fontcolor="#AA8800"; penwidth=2

    IFNg        [label="IFN-γ\n(Key driver cytokine)", shape=ellipse, fillcolor="#FFD700", fontsize=10, penwidth=2]
    TNFa        [label="TNF-α\n(Fas upregul./apoptosis)", shape=ellipse, fillcolor="#FFA500"]
    IL2_cy      [label="IL-2\n(T-cell proliferation)", shape=ellipse, fillcolor="#FFEE88"]
    IL15_cy     [label="IL-15\n(NK/CTL activation)", shape=ellipse, fillcolor="#FFEE88"]
    TGFb        [label="TGF-β\n(Treg-derived; dual)",  shape=ellipse, fillcolor="#FFE0A0"]
    JAK1_STAT1  [label="JAK1-STAT1\n(IFN-γ receptor sig.)", shape=box, fillcolor="#FFDD77"]
    IRF1        [label="IRF1\n(→ apoptosis genes)", shape=box, fillcolor="#FFDD77"]
    TNFR1       [label="TNFR1\n(Death domain sig.)", shape=box, fillcolor="#FFBB66"]
    Casp8       [label="Caspase-8\n(Extrinsic apoptosis)", shape=box, fillcolor="#FF9966"]
    Casp3       [label="Caspase-3\n(Executioner)",     shape=box,     fillcolor="#FF7766"]
    Fas_HSC     [label="Fas (CD95)\non HSC surface",   shape=box,     fillcolor="#FF9999"]
    NO_sig      [label="Nitric Oxide (NO)\n(iNOS by IFN-γ)", shape=box, fillcolor="#FFFFAA"]
    CXCL10      [label="CXCL10 (IP-10)\n(IFN-γ-induced chemo.)", shape=box, fillcolor="#FFEE99"]
    EPO_cy      [label="Erythropoietin (EPO)\n(→ BFU-E/CFU-E)",   shape=box, fillcolor="#CCFFCC"]
    TPO_cy      [label="Thrombopoietin (TPO)\n(→ MPL/HSC/Mk)",    shape=box, fillcolor="#CCFFCC"]
    GCSF_cy     [label="G-CSF\n(→ Granulopoiesis)",   shape=box,     fillcolor="#CCFFCC"]
    SCF_cy      [label="SCF (Stem Cell Factor)\n(→ KIT on HSC)",   shape=box, fillcolor="#CCFFCC"]
    IL3_cy      [label="IL-3\n(Multi-lineage support)", shape=box,    fillcolor="#CCFFCC"]
  }

  // =========================================================
  // CLUSTER 5: Bone Marrow Microenvironment
  // =========================================================
  subgraph cluster_BM {
    label="5. Bone Marrow Microenvironment (Niche)"
    style=filled; fillcolor="#F4FFEC"; color="#336633"; fontcolor="#336633"; penwidth=2

    MSC         [label="Mesenchymal\nStromal Cell (MSC)", shape=ellipse, fillcolor="#BBFFBB"]
    Osteo       [label="Osteoblast\n(endosteal niche)", shape=box, fillcolor="#CCFFCC"]
    Adipocyte   [label="Adipocyte\n(↑ in AA → hostile niche)", shape=box, fillcolor="#FFFFAA"]
    Endothel    [label="Sinusoidal\nEndothelium",        shape=box,     fillcolor="#BBFFDD"]
    CXCL12      [label="CXCL12\n(MSC → HSC retention)", shape=box,     fillcolor="#AAFFAA"]
    CXCR4       [label="CXCR4 on HSC\n(homing receptor)", shape=box,   fillcolor="#AAFFAA"]
    SCF_niche   [label="SCF (niche)\n→ KIT+ HSC",       shape=box,     fillcolor="#AAFFAA"]
    BM_cellu    [label="BM Cellularity\n[<25% in sAA]", shape=diamond, fillcolor="#FF9999"]
    Fat_replace [label="Fatty Marrow\nReplacement",      shape=box,     fillcolor="#FFFAAA"]
    Notch_sig   [label="Notch Signaling\n(HSC self-renewal)", shape=box, fillcolor="#AAFFCC"]
    Wnt_sig     [label="Wnt/β-catenin\n(HSC maintenance)", shape=box,  fillcolor="#AAFFCC"]
    Ang1_VEGF   [label="Ang-1 / VEGF\n(vascular niche)", shape=box,   fillcolor="#CCFFEE"]
  }

  // =========================================================
  // CLUSTER 6: HSC Compartment & Progenitor Hierarchy
  // =========================================================
  subgraph cluster_HSC {
    label="6. HSC Compartment & Progenitor Hierarchy"
    style=filled; fillcolor="#E8FFE8"; color="#228822"; fontcolor="#228822"; penwidth=2

    LT_HSC      [label="LT-HSC\n(Long-Term HSC)",       shape=ellipse, fillcolor="#44BB44", fontcolor="white", penwidth=2]
    ST_HSC      [label="ST-HSC\n(Short-Term HSC)",       shape=ellipse, fillcolor="#66CC66"]
    MPP         [label="MPP\n(Multipotent Progenitor)",  shape=ellipse, fillcolor="#88DD88"]
    CMP         [label="CMP\n(Common Myeloid Prog.)",    shape=ellipse, fillcolor="#AADDAA"]
    CLP         [label="CLP\n(Common Lymphoid Prog.)",   shape=ellipse, fillcolor="#BBDDBB"]
    GMP         [label="GMP\n(Gran.-Monocyte Prog.)",    shape=ellipse, fillcolor="#CCEECC"]
    MEP         [label="MEP\n(Mk-Erythroid Prog.)",      shape=ellipse, fillcolor="#AADDAA"]
    BFU_E       [label="BFU-E\n(Burst-Forming Unit-E)", shape=ellipse, fillcolor="#BBEEBB"]
    CFU_E       [label="CFU-E\n(Colony-Forming Unit-E)", shape=ellipse, fillcolor="#BBEEBB"]
    CFU_Mk      [label="CFU-Mk\n(Megakaryocyte Prog.)", shape=ellipse, fillcolor="#BBEEBB"]
    HSC_SRen    [label="HSC Self-Renewal\n(quiescence/cyc.)", shape=box, fillcolor="#88FF88"]
    HSC_Apop    [label="HSC Apoptosis\n(IFN-γ/TNF-α/Fas)", shape=box, fillcolor="#FF8888"]
    KIT_HSC     [label="c-KIT (CD117)\non HSC",          shape=box,     fillcolor="#CCFFAA"]
    MPL_HSC     [label="MPL (TPO-R)\non HSC",            shape=box,     fillcolor="#CCFFAA"]
    PI3K_AKT    [label="PI3K/AKT/mTOR\n(survival signal)", shape=box,  fillcolor="#BBFFAA"]
    STAT5_HSC   [label="STAT5\n(TPO/EPAG → survival)",   shape=box,     fillcolor="#BBFFAA"]
    PNH_clone   [label="PNH Clone\n(GPI-AP− cells)",     shape=diamond, fillcolor="#FF9988"]
    PIGA_mut    [label="PIG-A Mutation\n(X-linked somatic)", shape=box, fillcolor="#FFBBAA"]
  }

  // =========================================================
  // CLUSTER 7: Mature Blood Cells & Clinical Endpoints
  // =========================================================
  subgraph cluster_blood {
    label="7. Hematopoiesis: Mature Cells & Clinical Severity"
    style=filled; fillcolor="#F0E8FF"; color="#663388"; fontcolor="#663388"; penwidth=2

    Proeryth    [label="Proerythroblast →\nNormoblast",   shape=box,     fillcolor="#DDBBFF"]
    Retic       [label="Reticulocyte\n(ARC corrected)",   shape=ellipse, fillcolor="#CC99FF"]
    RBC_cell    [label="Erythrocyte (RBC)\n[Hgb, g/dL]", shape=ellipse, fillcolor="#BB77FF"]
    Hgb_level   [label="Hemoglobin (g/dL)\n[Target CR: >10]", shape=diamond, fillcolor="#FF99CC"]
    Megakary    [label="Megakaryocyte\n(polyploidization)", shape=ellipse, fillcolor="#DDBBFF"]
    PLT_cell    [label="Platelet (PLT)\n[Normal: 150-400×10⁹/L]", shape=ellipse, fillcolor="#BB77FF"]
    PLT_count   [label="Platelet Count\n[Target CR: >100×10⁹/L]", shape=diamond, fillcolor="#FF99CC"]
    PMN_prec    [label="Myelocyte/Band\n(PMN precursors)", shape=box,    fillcolor="#DDBBFF"]
    Neutrophil  [label="Neutrophil (PMN)\n[Normal: 1.8-7.0×10⁹/L]", shape=ellipse, fillcolor="#BB77FF"]
    ANC         [label="ANC\n[Target CR: >1.0×10⁹/L]",  shape=diamond, fillcolor="#FF6699", penwidth=2]
    Monocyte    [label="Monocyte",                        shape=ellipse, fillcolor="#DDCCFF"]
    BLymph      [label="B Lymphocyte",                    shape=ellipse, fillcolor="#DDCCFF"]
    Sev_sAA     [label="Severe AA (sAA)\nANC<0.5, PLT<20k,\nRetic<20k", shape=box, fillcolor="#FF7777"]
    Sev_vsAA    [label="Very Severe AA\nANC<0.2×10⁹/L",  shape=box,     fillcolor="#FF4444"]
    Sev_nsAA    [label="Non-Severe AA\n(nsAA)",           shape=box,     fillcolor="#FF9999"]
    CR_out      [label="Complete Response (CR)\nANC>1.0, PLT>100k,\nHgb>10 g/dL", shape=hexagon, fillcolor="#44FF44"]
    PR_out      [label="Partial Response (PR)\nTransfusion-independent;\nnot sAA", shape=hexagon, fillcolor="#AAFFAA"]
    NR_out      [label="No Response (NR)\nFailed PR at 6 mo", shape=hexagon, fillcolor="#FF7777"]
    Relapse_out [label="Relapse\n(recurrence post-CR)", shape=hexagon, fillcolor="#FF9900"]
    Clonal_evo  [label="Clonal Evolution\nMDS / AML (~10-15% at 10y)", shape=hexagon, fillcolor="#FF6666"]
    Infect_risk [label="Infection Risk\n(ANC-driven)\nFungal, Gram-neg.", shape=diamond, fillcolor="#FF8888"]
    Bleed_risk  [label="Bleeding Risk\n(PLT-driven)",     shape=diamond, fillcolor="#FF9988"]
  }

  // =========================================================
  // CLUSTER 8: Telomere Biology
  // =========================================================
  subgraph cluster_telomere {
    label="8. Telomere Biology & Inherited Predisposition"
    style=filled; fillcolor="#E0FFFF"; color="#007799"; fontcolor="#007799"; penwidth=2

    TL_avg      [label="Average Telomere\nLength (TL, kb)",  shape=diamond, fillcolor="#88FFFF"]
    TERT_gene   [label="TERT Gene\n(hTERT protein)",          shape=box,     fillcolor="#AAFFFF"]
    TERC_gene   [label="TERC Gene\n(telomerase RNA comp.)",   shape=box,     fillcolor="#AAFFFF"]
    DKC1        [label="DKC1 (Dyskerin)\n(stabilizes TERC)", shape=box,     fillcolor="#BBFFFF"]
    Telomerase  [label="Telomerase\nComplex",                  shape=ellipse, fillcolor="#66DDDD"]
    Shelterin   [label="Shelterin Complex\n(TRF1/2, POT1,\nRAP1, TIN2, TPP1)", shape=box, fillcolor="#99DDFF"]
    HSC_senes   [label="HSC Replicative\nSenescence",          shape=box,     fillcolor="#FF9988"]
    DDR_TL      [label="DNA Damage Response\n(p53/p21 activation)", shape=box, fillcolor="#FFAAAA"]
    TERT_mut    [label="TERT/TERC Mutations\n(Dyskeratosis Congenita)", shape=box, fillcolor="#FFBBAA"]
    Short_TL    [label="Short Telomere\n(poor IST response)",  shape=diamond, fillcolor="#FF8888"]
    AR_TERT     [label="Androgen Receptor\n→ TERT transcription↑", shape=box, fillcolor="#FFEEAA"]
  }

  // =========================================================
  // CLUSTER 9: ATG Pharmacokinetics & Pharmacodynamics
  // =========================================================
  subgraph cluster_PK_ATG {
    label="9. ATG Pharmacokinetics (hATG & rATG)"
    style=filled; fillcolor="#F0F0FF"; color="#334477"; fontcolor="#334477"; penwidth=2

    hATG_dose   [label="hATG (Equine ATG)\n40 mg/kg/d × 4d IV\n(ATGAM®)", shape=box, fillcolor="#BBBBFF"]
    rATG_dose   [label="rATG (Rabbit ATG)\n3.5 mg/kg/d × 5d IV\n(Thymoglobulin®)", shape=box, fillcolor="#BBBBFF"]
    ATG_CENT    [label="ATG Central\nCompartment (Plasma)", shape=ellipse, fillcolor="#9999FF"]
    ATG_PERI    [label="ATG Peripheral\nCompartment (Tissue)", shape=ellipse, fillcolor="#AAAAFF"]
    ATG_t12     [label="t½ ~6d (hATG)\nt½ ~30d (rATG)\n(polyclonal IgG)", shape=box, fillcolor="#CCCCFF"]
    ATG_TMDD    [label="Target-Mediated\nDrug Disposition\n(T-cell binding)", shape=box, fillcolor="#AAAAEE"]
    T_depl      [label="T-Cell Depletion\n(CD3+ cells)",      shape=diamond, fillcolor="#FF8888"]
    CDC_ATG     [label="Complement-Mediated\nLysis (CDC)",    shape=box,     fillcolor="#BBAAFF"]
    ADCC_ATG    [label="ADCC\n(Fc-mediated killing)",         shape=box,     fillcolor="#BBAAFF"]
    Cyt_storm   [label="First-Dose\nCytokine Storm\n(serum sickness risk)", shape=box, fillcolor="#FFAAAA"]
    ADA_ATG     [label="Anti-ATG Antibody\n(ADA → fast clearance)", shape=box, fillcolor="#FFBBAA"]
    hATG_spec   [label="hATG Specificities\n(CD2, CD3, CD4, CD8,\nCD11a, CD16, CD18)", shape=box, fillcolor="#CCCCFF"]
    rATG_spec   [label="rATG Specificities\n(HLA, costimulatory\nmolecules, broader)", shape=box, fillcolor="#CCCCFF"]
  }

  // =========================================================
  // CLUSTER 10: Cyclosporine A PK/PD
  // =========================================================
  subgraph cluster_PK_CsA {
    label="10. Cyclosporine A (CsA) PK/PD"
    style=filled; fillcolor="#FFF8F0"; color="#884400"; fontcolor="#884400"; penwidth=2

    CsA_dose    [label="CsA Oral Dose\n3-5 mg/kg/d\n(Cmin target 100-200 ng/mL)", shape=box, fillcolor="#FFDDBB"]
    CsA_GUT     [label="CsA Absorption\n(F ~30-45%\nModif. microemulsion)", shape=box, fillcolor="#FFEECC"]
    CsA_CENT    [label="CsA Central\nCompartment",           shape=ellipse, fillcolor="#FFCC99"]
    CsA_PERI    [label="CsA Peripheral\nCompartment\n(Vd ~5 L/kg)", shape=ellipse, fillcolor="#FFDD99"]
    CYP3A4      [label="CYP3A4 Metabolism\n(hepatic/intestinal)", shape=box, fillcolor="#FFBB88"]
    Pgp_CsA     [label="P-gp (MDR1)\nEfflux",               shape=box,     fillcolor="#FFBB88"]
    CsA_Cmin    [label="Trough Conc. (Cmin)\n[100-200 ng/mL target]", shape=diamond, fillcolor="#FFAA77"]
    Cyclophilin [label="Cyclophilin A\n(CsA–CypA complex)", shape=box,     fillcolor="#FFCC99"]
    CsA_CN_inh  [label="Calcineurin\nInhibition",            shape=box,     fillcolor="#FF9966"]
    NFAT_block  [label="NFAT\nDephosphorylation\nBlocked",   shape=box,     fillcolor="#FF9966"]
    IL2_inh     [label="IL-2 Inhibited\n(CD8+ prolif.↓)",   shape=diamond, fillcolor="#FFCC66"]
    IFNg_inh    [label="IFN-γ Inhibited\n(T-cell suppr.)",  shape=diamond, fillcolor="#FFCC66"]
    Nephro_CsA  [label="Nephrotoxicity\n(afferent vasoconstr.)", shape=box, fillcolor="#FF9999"]
    HTN_CsA     [label="Hypertension\n(CsA side effect)",   shape=box,     fillcolor="#FFBBBB"]
  }

  // =========================================================
  // CLUSTER 11: Eltrombopag & Danazol PK/PD
  // =========================================================
  subgraph cluster_PK_EPAG {
    label="11. Eltrombopag (EPAG) & Danazol PK/PD"
    style=filled; fillcolor="#FFF0E8"; color="#884422"; fontcolor="#884422"; penwidth=2

    EPAG_dose   [label="Eltrombopag Dose\n75 mg/d oral\n(Asian: 50 mg/d)", shape=box, fillcolor="#FFCCAA"]
    EPAG_GUT    [label="EPAG Absorption\n(F ~52%; chelation\nwith Ca2+/Fe3+)", shape=box, fillcolor="#FFDDBB"]
    EPAG_CENT   [label="EPAG Central\nCompartment",          shape=ellipse, fillcolor="#FFBB88"]
    EPAG_t12    [label="t½ ~21-32 h\nCmax ~3 h\n(Vd ~10 L/kg)", shape=box, fillcolor="#FFCC99"]
    EPAG_metab  [label="Hepatic Metabolism\n(CYP1A2, CYP2C8,\nUGT1A1/1A3)", shape=box, fillcolor="#FFBB77"]
    Iron_chel   [label="Iron Chelation\n(NTBI; anti-prolif?)", shape=box,  fillcolor="#FFEEAA"]
    MPL_bind    [label="MPL (TPO-R)\nNon-compet. Agonist\n(transmembrane domain)", shape=box, fillcolor="#FF9966"]
    JAK2_STAT5  [label="JAK2-STAT5\n(downstream MPL)",       shape=box,     fillcolor="#FF9966"]
    HSC_exp     [label="HSC Expansion\n(c-MPL on LT-HSC)",  shape=diamond, fillcolor="#AAFFAA"]
    Mk_exp      [label="Megakaryocyte\nExpansion (PLT↑)",   shape=diamond, fillcolor="#AAFFAA"]
    Treg_ind    [label="Treg Induction\n(emerging evidence)", shape=box,   fillcolor="#FFEEAA"]
    Danazol     [label="Danazol\n200 mg TID oral\n[Telomere disease]", shape=box, fillcolor="#FFDDAA"]
    AR_sig      [label="Androgen Receptor\nActivation",       shape=box,    fillcolor="#FFCCAA"]
  }

  // =========================================================
  // CLUSTER 12: Supportive Care, HSCT & Monitoring
  // =========================================================
  subgraph cluster_support {
    label="12. Supportive Care, HSCT & Complications"
    style=filled; fillcolor="#F8F0E0"; color="#775500"; fontcolor="#775500"; penwidth=2

    GCSF_treat  [label="G-CSF\n(Filgrastim)\n[adjunct to IST]", shape=box, fillcolor="#CCFFAA"]
    RBC_tx      [label="RBC Transfusion\n[Hgb trigger <7-8 g/dL]", shape=box, fillcolor="#FFAACC"]
    PLT_tx      [label="Platelet Transfusion\n[PLT trigger <10-20k]", shape=box, fillcolor="#FFAACC"]
    HSCT        [label="Allo-HSCT\n(MSD, 1st-line <40y sAA)", shape=box, fillcolor="#AABBFF"]
    Iron_OL     [label="Transfusional Iron\nOverload (Ferritin↑)", shape=box, fillcolor="#FFAA88"]
    Deferasirox [label="Deferasirox\n(Iron chelation therapy)", shape=box, fillcolor="#FFCC99"]
    Cyclophos   [label="Cyclophosphamide\n(high-dose, salvage\nlymphoablation)", shape=box, fillcolor="#FFBBCC"]
    Romiplostim [label="Romiplostim\nAvatrombopag\n[alt. TPO-RA]", shape=box, fillcolor="#FFDDAA"]
    Luspatercept[label="Luspatercept\n(TGF-β trap)\n[investigational]", shape=box, fillcolor="#EEBBFF"]
    Sirolimus   [label="Sirolimus\n(mTOR inhibitor\nadjunct relapse)", shape=box, fillcolor="#FFCCDD"]
    BM_biopsy   [label="BM Trephine Biopsy\n(cellularity assess.)", shape=box, fillcolor="#CCDDFF"]
    Cyclospo_tox[label="CsA Monitoring\n(Cmin, renal function,\nBP, LFTs)", shape=box, fillcolor="#FFDDCC"]
    Prophyl     [label="Infection Prophylaxis\n(fluconazole, PCP\nprophylaxis)", shape=box, fillcolor="#CCFFDD"]
  }

  // =========================================================
  // EDGES
  // =========================================================

  // --- Triggers → Innate / T-cell priming ---
  Viral_EBV   -> Antigen_Pres [color="#CC4444"]
  Viral_CMV   -> Antigen_Pres [color="#CC4444"]
  Viral_Hep   -> Antigen_Pres [color="#CC4444"]
  Viral_Parvo -> pDC           [color="#CC4444"]
  Chemical    -> TLR_sig       [color="#CC4444"]
  Drug_Trig   -> TLR_sig       [color="#CC4444"]
  Idiopathic  -> Antigen_Pres  [color="#CC4444", style=dashed]
  HLA_DR15    -> TCR_Clonal    [color="#CC4444", style=dashed, label="suscept."]
  Antigen_Pres-> TCR_Clonal    [color="#CC4444"]
  Mol_Mim     -> TCR_Clonal    [color="#CC4444"]
  MHC_II      -> Naive_CD4     [color="#CC4444"]

  // --- Innate → Adaptive ---
  TLR_sig  -> NF_kB       [color="#2266AA"]
  NF_kB    -> IL12_inn    [color="#2266AA"]
  NF_kB    -> TNFa_mac    [color="#2266AA"]
  NF_kB    -> IL18_inn    [color="#2266AA"]
  pDC      -> IFNg_NK     [color="#2266AA"]
  mDC      -> Antigen_Pres[color="#2266AA"]
  mDC      -> IL12_inn    [color="#2266AA"]
  NK_cell  -> IFNg_NK     [color="#2266AA"]
  NKT_cell -> IL18_inn    [color="#2266AA"]
  Macrophage-> TNFa_mac   [color="#2266AA"]
  IL12_inn -> Naive_CD4   [color="#2266AA"]
  IL15_inn -> NK_cell     [color="#2266AA"]
  IL15_inn -> Eff_CD8     [color="#2266AA"]
  IL18_inn -> NK_cell     [color="#2266AA"]

  // --- T-cell activation cascade ---
  TCR_Clonal -> Naive_CD8   [color="#1144CC"]
  TCR_ZAP70  -> Calcineurin  [color="#1144CC"]
  Calcineurin-> NFATc1       [color="#1144CC"]
  NFATc1     -> IL2_cy       [color="#1144CC"]
  NFATc1     -> IFNg         [color="#1144CC"]
  CD28_cosig -> NFATc1       [color="#1144CC"]
  Naive_CD4  -> Th1_cell     [color="#1144CC"]
  IL12_inn   -> Tbet         [color="#1144CC"]
  Tbet       -> Th1_cell     [color="#1144CC"]
  Th1_cell   -> IFNg         [color="#1144CC"]
  IFNg       -> STAT1_T      [color="#AA8800", style=dashed]
  STAT1_T    -> Tbet         [color="#1144CC"]
  Naive_CD8  -> Eff_CD8      [color="#1144CC"]
  IL2_cy     -> Eff_CD8      [color="#1144CC", label="prolif."]
  Eff_CD8    -> Perforin      [color="#1144CC"]
  Eff_CD8    -> FasL_T        [color="#1144CC"]
  Treg       -> Eff_CD8      [color="#FF7700", arrowhead=tee, label="suppress"]
  CTLA4      -> NFATc1        [color="#FF7700", arrowhead=tee]
  IL2_Tcell  -> Eff_CD8       [color="#1144CC"]

  // --- Cytokine → HSC killing ---
  IFNg     -> JAK1_STAT1   [color="#AA8800"]
  JAK1_STAT1-> IRF1         [color="#AA8800"]
  IRF1     -> HSC_Apop      [color="#AA8800"]
  IFNg     -> Fas_HSC       [color="#AA8800", label="Fas↑"]
  TNFa     -> TNFR1         [color="#AA8800"]
  TNFR1    -> Casp8         [color="#AA8800"]
  Casp8    -> Casp3         [color="#AA8800"]
  Casp3    -> HSC_Apop      [color="#AA8800"]
  FasL_T   -> Fas_HSC       [color="#FF4444"]
  Fas_HSC  -> Casp8         [color="#FF4444"]
  Perforin -> HSC_Apop      [color="#FF4444"]
  IFNg     -> NO_sig        [color="#AA8800"]
  NO_sig   -> HSC_Apop      [color="#AA8800"]
  TNFa_mac -> TNFa          [color="#2266AA"]
  IFNg_NK  -> IFNg          [color="#2266AA"]

  // --- Growth factor → Hematopoiesis ---
  EPO_cy   -> BFU_E         [color="#228822"]
  EPO_cy   -> CFU_E         [color="#228822"]
  TPO_cy   -> CFU_Mk        [color="#228822"]
  TPO_cy   -> MPL_HSC       [color="#228822"]
  GCSF_cy  -> GMP           [color="#228822"]
  SCF_cy   -> KIT_HSC       [color="#228822"]
  IL3_cy   -> CMP           [color="#228822"]
  TGFb     -> BFU_E         [color="#AA8800", arrowhead=tee, label="inhibit"]

  // --- BM niche ---
  MSC      -> CXCL12        [color="#336633"]
  CXCL12   -> CXCR4         [color="#336633"]
  CXCR4    -> LT_HSC        [color="#336633"]
  MSC      -> SCF_niche      [color="#336633"]
  SCF_niche-> KIT_HSC        [color="#336633"]
  Osteo    -> Notch_sig      [color="#336633"]
  Notch_sig-> LT_HSC         [color="#336633"]
  Wnt_sig  -> LT_HSC         [color="#336633"]
  IFNg     -> Adipocyte      [color="#AA8800", label="adipo↑"]
  Adipocyte-> Fat_replace    [color="#336633"]
  Fat_replace-> BM_cellu     [color="#336633"]
  Endothel -> Ang1_VEGF      [color="#336633"]

  // --- HSC hierarchy ---
  LT_HSC   -> ST_HSC         [color="#228822"]
  ST_HSC   -> MPP            [color="#228822"]
  MPP      -> CMP            [color="#228822"]
  MPP      -> CLP            [color="#228822"]
  CMP      -> GMP            [color="#228822"]
  CMP      -> MEP            [color="#228822"]
  MEP      -> BFU_E          [color="#228822"]
  BFU_E    -> CFU_E          [color="#228822"]
  MEP      -> CFU_Mk         [color="#228822"]
  GMP      -> PMN_prec       [color="#228822"]
  KIT_HSC  -> PI3K_AKT       [color="#228822"]
  MPL_HSC  -> STAT5_HSC      [color="#228822"]
  STAT5_HSC-> HSC_SRen        [color="#228822"]
  PI3K_AKT -> HSC_SRen        [color="#228822"]
  HSC_Apop -> LT_HSC         [color="#FF4444", arrowhead=tee]
  PIGA_mut -> PNH_clone       [color="#884422"]
  LT_HSC   -> PNH_clone       [color="#884422", style=dashed]

  // --- Blood cell maturation ---
  CFU_E    -> Proeryth        [color="#663388"]
  Proeryth -> Retic           [color="#663388"]
  Retic    -> RBC_cell        [color="#663388"]
  RBC_cell -> Hgb_level       [color="#663388"]
  CFU_Mk   -> Megakary        [color="#663388"]
  Megakary -> PLT_cell        [color="#663388"]
  PLT_cell -> PLT_count       [color="#663388"]
  PMN_prec -> Neutrophil      [color="#663388"]
  Neutrophil-> ANC            [color="#663388"]

  // --- Severity & outcomes ---
  ANC      -> Sev_sAA         [color="#663388"]
  ANC      -> Sev_vsAA        [color="#663388"]
  PLT_count-> Sev_sAA         [color="#663388"]
  ANC      -> CR_out          [color="#228822"]
  PLT_count-> CR_out          [color="#228822"]
  Hgb_level-> CR_out          [color="#228822"]
  ANC      -> PR_out          [color="#228822"]
  Sev_sAA  -> NR_out          [color="#CC4444", style=dashed]
  CR_out   -> Relapse_out     [color="#FF8800", style=dashed]
  PNH_clone-> Clonal_evo      [color="#CC4444"]
  ANC      -> Infect_risk     [color="#FF4444", arrowhead=tee]
  PLT_count-> Bleed_risk      [color="#FF4444", arrowhead=tee]

  // --- Telomere biology ---
  TERT_gene-> Telomerase      [color="#007799"]
  TERC_gene-> Telomerase      [color="#007799"]
  DKC1     -> Telomerase      [color="#007799"]
  Telomerase-> TL_avg         [color="#007799"]
  Shelterin -> TL_avg         [color="#007799"]
  TERT_mut -> Short_TL        [color="#007799"]
  Short_TL -> HSC_senes       [color="#007799"]
  HSC_senes-> DDR_TL          [color="#007799"]
  DDR_TL   -> HSC_Apop        [color="#007799"]
  AR_TERT  -> TERT_gene       [color="#007799"]

  // --- ATG PK/PD ---
  hATG_dose -> ATG_CENT       [color="#334477"]
  rATG_dose -> ATG_CENT       [color="#334477"]
  ATG_CENT  -> ATG_PERI       [color="#334477"]
  ATG_CENT  -> ATG_TMDD       [color="#334477"]
  ATG_TMDD  -> T_depl         [color="#334477"]
  T_depl    -> Eff_CD8        [color="#334477", arrowhead=tee]
  T_depl    -> Th1_cell       [color="#334477", arrowhead=tee]
  T_depl    -> Treg           [color="#334477", arrowhead=tee, label="Treg\ndepleted short-term"]
  hATG_spec -> ATG_TMDD       [color="#334477"]
  rATG_spec -> ATG_TMDD       [color="#334477"]
  CDC_ATG   -> T_depl         [color="#334477"]
  ADCC_ATG  -> T_depl         [color="#334477"]
  ATG_CENT  -> Cyt_storm      [color="#334477"]
  ADA_ATG   -> ATG_CENT       [color="#CC4444", arrowhead=tee]

  // --- CsA PK/PD ---
  CsA_dose  -> CsA_GUT        [color="#884400"]
  CsA_GUT   -> CsA_CENT       [color="#884400"]
  CsA_CENT  -> CsA_PERI       [color="#884400"]
  CYP3A4    -> CsA_CENT       [color="#884400", arrowhead=tee]
  Pgp_CsA   -> CsA_GUT        [color="#884400", arrowhead=tee]
  CsA_CENT  -> CsA_Cmin       [color="#884400"]
  CsA_Cmin  -> Cyclophilin    [color="#884400"]
  Cyclophilin-> CsA_CN_inh    [color="#884400"]
  CsA_CN_inh -> Calcineurin   [color="#884400", arrowhead=tee]
  CsA_CN_inh -> NFAT_block    [color="#884400"]
  NFAT_block -> IL2_inh       [color="#884400"]
  NFAT_block -> IFNg_inh      [color="#884400"]
  IL2_inh   -> Eff_CD8        [color="#884400", arrowhead=tee]
  IFNg_inh  -> IFNg           [color="#884400", arrowhead=tee]
  CsA_CENT  -> Nephro_CsA     [color="#884400"]
  CsA_CENT  -> HTN_CsA        [color="#884400"]

  // --- EPAG & Danazol PK/PD ---
  EPAG_dose -> EPAG_GUT       [color="#884422"]
  EPAG_GUT  -> EPAG_CENT      [color="#884422"]
  Iron_chel -> EPAG_GUT       [color="#884422", arrowhead=tee]
  EPAG_CENT -> EPAG_metab     [color="#884422"]
  EPAG_CENT -> MPL_bind       [color="#884422"]
  MPL_bind  -> JAK2_STAT5     [color="#884422"]
  JAK2_STAT5-> HSC_exp        [color="#884422"]
  JAK2_STAT5-> Mk_exp         [color="#884422"]
  HSC_exp   -> LT_HSC         [color="#884422"]
  Mk_exp    -> CFU_Mk         [color="#884422"]
  MPL_bind  -> MPL_HSC        [color="#884422"]
  EPAG_CENT -> Treg_ind       [color="#884422"]
  Treg_ind  -> Treg           [color="#884422"]
  Danazol   -> AR_sig         [color="#884422"]
  AR_sig    -> AR_TERT        [color="#884422"]

  // --- Supportive care ---
  GCSF_treat-> GMP            [color="#775500"]
  RBC_tx    -> Hgb_level      [color="#775500"]
  PLT_tx    -> PLT_count      [color="#775500"]
  HSCT      -> LT_HSC         [color="#775500", label="donor HSC"]
  HSCT      -> Eff_CD8        [color="#775500", arrowhead=tee, label="replace"]
  RBC_tx    -> Iron_OL        [color="#775500"]
  Deferasirox-> Iron_OL       [color="#775500", arrowhead=tee]
  Sirolimus -> PI3K_AKT       [color="#775500", arrowhead=tee]
  Luspatercept-> TGFb         [color="#775500", arrowhead=tee]
  BM_biopsy -> BM_cellu       [color="#775500", style=dashed]
  Prophyl   -> Infect_risk    [color="#775500", arrowhead=tee]
  Romiplostim-> MPL_bind      [color="#775500"]
}
