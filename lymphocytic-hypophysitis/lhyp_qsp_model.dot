    /* ===================== CLUSTER 14: CLINICAL ENDPOINTS ===================== */
    subgraph cluster_endpoints {
        label="Clinical Outcomes & Endpoints"
        fontcolor="#ffffff"
        fontsize=13
        style="filled,rounded"
        color="#e0e0e0"
        bgcolor="#1a1a1a"

        headache [label="Headache\nScore (VAS)", fillcolor="#4a4a4a", fontcolor="white", shape=ellipse]
        visual_field_defect [label="Visual Field\nDefect (Bitemporal)", fillcolor="#4a4a4a", fontcolor="white", shape=ellipse]
        acth_deficiency [label="Secondary\nAdrenal Insufficiency", fillcolor="#5a3a3a", fontcolor="white", shape=ellipse]
