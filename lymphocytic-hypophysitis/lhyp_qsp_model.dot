        aquaporin2 [label="Aquaporin-2\n(Water channel)", fillcolor="#4a1a6a", fontcolor="white", shape=diamond]
        collecting_duct [label="Renal Collecting\nDuct", fillcolor="#3a1a5a", fontcolor="white", shape=cylinder]
        urine_osmolality [label="Urine Osmolality\n(mOsm/kg)", fillcolor="#5a2a7a", fontcolor="white", shape=ellipse]
        serum_osmolality [label="Serum Osmolality\n(mOsm/kg)", fillcolor="#5a2a7a", fontcolor="white", shape=ellipse]
        diabetes_insipidus [label="Diabetes\nInsipidus (DI)", fillcolor="#6a2a8a", fontcolor="white", shape=ellipse]
    }

    /* ===================== CLUSTER 12: DRUG PK ===================== */
    subgraph cluster_drug_pk {
        label="Drug Pharmacokinetics"
        fontcolor="#80deea"
