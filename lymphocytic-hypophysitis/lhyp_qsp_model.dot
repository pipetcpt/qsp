        tgn_metabolites [label="6-TGN Metabolites\n(Active thiopurines)", fillcolor="#005a6a", fontcolor="white", shape=ellipse]
        tpmt_enzyme [label="TPMT Enzyme\n(6-MP inactivation)", fillcolor="#003a4a", fontcolor="white", shape=diamond]
