        bone_effect [label="Osteoporosis\n(Steroid-induced)", fillcolor="#5a3a00", fontcolor="white", shape=ellipse]
        cushingoid [label="Cushingoid\nFacies/Features", fillcolor="#6a3a00", fontcolor="white", shape=ellipse]
        rtx_b_depletion [label="B-Cell\nDepletion (Rtx)", fillcolor="#5a3000", fontcolor="white", shape=ellipse]
        mtx_dhfr [label="DHFR Inhibition\n(MTX)", fillcolor="#5a2a00", fontcolor="white", shape=diamond]
        aza_lymphocyte_inhib [label="Lymphocyte Proliferation\nInhibition (AZA)", fillcolor="#5a3000", fontcolor="white", shape=ellipse]
