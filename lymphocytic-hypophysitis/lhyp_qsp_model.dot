digraph LymphoHypophysitisQSP {
    graph [
        label="Lymphocytic Hypophysitis (LyH) — QSP Mechanistic Map\nAutoimmune Pituitary Disease · Multi-Axis Endocrine Disruption · Drug PK/PD",
        labelloc=t,
        fontsize=22,
        fontname="Helvetica-Bold",
        bgcolor="#0d1117",
        fontcolor="#e6edf3",
        rankdir=TB,
        splines=ortho,
        nodesep=0.5,
        ranksep=0.8,
        compound=true
    ]
    node [fontname="Helvetica", fontsize=10, style="filled,rounded", penwidth=1.5]
    edge [fontname="Helvetica", fontsize=8, penwidth=1.2]

    /* ===================== CLUSTER 1: DISEASE TRIGGERS & GENETICS ===================== */
    subgraph cluster_triggers {
        label="Disease Triggers & Genetic Risk Factors"
        fontcolor="#f0c040"
        fontsize=13
        style="filled,rounded"
        color="#f0c040"
        bgcolor="#1c1f26"

        pregnancy [label="Pregnancy /\nPostpartum State", fillcolor="#5a3e7c", fontcolor="white", shape=ellipse]
        postpartum_state [label="Postpartum\nHormonal Shifts", fillcolor="#5a3e7c", fontcolor="white", shape=ellipse]
        infection_trigger [label="Viral Infection\nTrigger", fillcolor="#7c2d2d", fontcolor="white", shape=ellipse]
        genetic_susceptibility [label="Genetic\nSusceptibility", fillcolor="#3d5a80", fontcolor="white", shape=box]
        hla_dr3 [label="HLA-DR3\nHaplotype", fillcolor="#2d5986", fontcolor="white", shape=box]
        hla_dr4 [label="HLA-DR4\nHaplotype", fillcolor="#2d5986", fontcolor="white", shape=box]
        ctla4_polymorphism [label="CTLA4\nPolymorphism\n(49A/G)", fillcolor="#2d5986", fontcolor="white", shape=box]
        molecular_mimicry [label="Molecular\nMimicry", fillcolor="#7c2d2d", fontcolor="white", shape=diamond]
        viral_antigen [label="Viral Antigen\n(LCMV, MCMV)", fillcolor="#7c2d2d", fontcolor="white", shape=hexagon]
        autoimmune_diathesis [label="Autoimmune\nDiathesis", fillcolor="#5a3e7c", fontcolor="white", shape=ellipse]
        ipilimumab_trigger [label="CTLA4-Ig / Anti-PD1\nCheckpoint Inhibitor", fillcolor="#8b4513", fontcolor="white", shape=hexagon]
        pit1_antigen [label="Pituitary-Specific\nAutoantigens\n(PIT-1, RABPHILIN-3L)", fillcolor="#5a3e7c", fontcolor="white", shape=box]
    }

    /* ===================== CLUSTER 2: INNATE IMMUNE SYSTEM ===================== */
    subgraph cluster_innate {
        label="Innate Immune System"
        fontcolor="#4fc3f7"
        fontsize=13
        style="filled,rounded"
        color="#4fc3f7"
        bgcolor="#0f1e2e"

        apcs [label="Antigen-Presenting\nCells (APCs)", fillcolor="#1a3a5c", fontcolor="white", shape=box]
        dendritic_cells [label="Dendritic\nCells (DCs)", fillcolor="#1a4a7c", fontcolor="white", shape=box]
        macrophages [label="Macrophages\nM1/M2", fillcolor="#1a3a5c", fontcolor="white", shape=box]
        nk_cells [label="Natural Killer\nCells (NK)", fillcolor="#1a3a5c", fontcolor="white", shape=box]
        complement_system [label="Complement\nSystem", fillcolor="#0d2a4a", fontcolor="white", shape=ellipse]
        c3 [label="C3 Activation\n& Cleavage", fillcolor="#0d2a4a", fontcolor="white", shape=diamond]
        c4 [label="C4 Cleavage /\nImmuneComplex", fillcolor="#0d2a4a", fontcolor="white", shape=diamond]
        tlr_signaling [label="TLR Signaling\n(TLR2/TLR4)", fillcolor="#1a3a5c", fontcolor="white", shape=box]
        nlrp3 [label="NLRP3\nInflammasome", fillcolor="#2a4a6c", fontcolor="white", shape=box]
        ros_production [label="ROS / Oxidative\nStress", fillcolor="#3a2a1a", fontcolor="white", shape=ellipse]
        mhc_class2 [label="MHC Class II\nPresentation", fillcolor="#1a4a7c", fontcolor="white", shape=box]
        nfkb_innate [label="NF-κB\nActivation", fillcolor="#2a3a6c", fontcolor="white", shape=diamond]
    }

    /* ===================== CLUSTER 3: ADAPTIVE IMMUNE SYSTEM ===================== */
    subgraph cluster_adaptive {
        label="Adaptive Immune System"
        fontcolor="#81c784"
        fontsize=13
        style="filled,rounded"
        color="#81c784"
        bgcolor="#0f2010"

        naive_cd4_t [label="Naïve CD4+\nT Cells", fillcolor="#1a3a1a", fontcolor="white", shape=box]
        th1_cells [label="Th1 Cells\n(IFN-γ producer)", fillcolor="#2a5a2a", fontcolor="white", shape=box]
        th17_cells [label="Th17 Cells\n(IL-17 producer)", fillcolor="#2a5a2a", fontcolor="white", shape=box]
        tfh_cells [label="T Follicular\nHelper (Tfh)", fillcolor="#2a5a2a", fontcolor="white", shape=box]
        cd8_cytotoxic [label="CD8+ Cytotoxic\nT Cells (CTL)", fillcolor="#1a4a1a", fontcolor="white", shape=box]
        treg_cells [label="Regulatory T Cells\n(Tregs, FoxP3+)", fillcolor="#3a6a3a", fontcolor="white", shape=ellipse]
        naive_b [label="Naïve B\nCells", fillcolor="#1a3a1a", fontcolor="white", shape=box]
        memory_b [label="Memory B\nCells", fillcolor="#2a5a2a", fontcolor="white", shape=box]
        plasma_cells [label="Plasma Cells\n(Ab-secreting)", fillcolor="#3a6a3a", fontcolor="white", shape=box]
        anti_pit1_abs [label="Anti-PIT1\nAutoantibodies", fillcolor="#4a7a2a", fontcolor="white", shape=diamond]
        anti_rabphilin_abs [label="Anti-RABPHILIN-3L\nAutoantibodies", fillcolor="#4a7a2a", fontcolor="white", shape=diamond]
        apa [label="Anti-Pituitary\nAntibodies (APA)", fillcolor="#4a7a4a", fontcolor="white", shape=diamond]
        igg4_class_switch [label="IgG4 Class\nSwitching (rare)", fillcolor="#3a6a2a", fontcolor="white", shape=ellipse]
    }

    /* ===================== CLUSTER 4: CYTOKINE NETWORK ===================== */
    subgraph cluster_cytokines {
        label="Cytokine & Chemokine Network"
        fontcolor="#ffb74d"
        fontsize=13
        style="filled,rounded"
        color="#ffb74d"
        bgcolor="#2a1a00"

        il1beta [label="IL-1β\n(Inflammasome)", fillcolor="#5a3000", fontcolor="white", shape=ellipse]
        il2 [label="IL-2\n(T-cell growth)", fillcolor="#5a3000", fontcolor="white", shape=ellipse]
        il4 [label="IL-4\n(Th2/B-cell)", fillcolor="#4a2800", fontcolor="white", shape=ellipse]
        il6 [label="IL-6\n(Pleiotropic)", fillcolor="#5a3800", fontcolor="white", shape=ellipse]
        il10 [label="IL-10\n(Anti-inflam.)", fillcolor="#3a5030", fontcolor="white", shape=ellipse]
        il12 [label="IL-12\n(Th1 polarizing)", fillcolor="#5a3000", fontcolor="white", shape=ellipse]
        il17a [label="IL-17A\n(Neutrophil recruit)", fillcolor="#5a3000", fontcolor="white", shape=ellipse]
        il21 [label="IL-21\n(B-cell activation)", fillcolor="#4a2800", fontcolor="white", shape=ellipse]
        il23 [label="IL-23\n(Th17 maintenance)", fillcolor="#5a3000", fontcolor="white", shape=ellipse]
        ifn_gamma [label="IFN-γ\n(Macrophage activ.)", fillcolor="#6a4000", fontcolor="white", shape=ellipse]
        tnf_alpha [label="TNF-α\n(Pro-inflam.)", fillcolor="#7a3000", fontcolor="white", shape=ellipse]
        tgf_beta [label="TGF-β\n(Fibrosis/Treg)", fillcolor="#3a4a2a", fontcolor="white", shape=ellipse]
        vegf [label="VEGF\n(Angiogenesis)", fillcolor="#3a4a20", fontcolor="white", shape=ellipse]
        cxcl10 [label="CXCL10/IP-10\n(T-cell attract.)", fillcolor="#5a3800", fontcolor="white", shape=ellipse]
        ccl2 [label="CCL2/MCP-1\n(Monocyte recruit.)", fillcolor="#5a3800", fontcolor="white", shape=ellipse]
    }

    /* ===================== CLUSTER 5: PITUITARY PATHOLOGY ===================== */
    subgraph cluster_pituitary {
        label="Pituitary Gland Anatomy & Pathology"
        fontcolor="#ef9a9a"
        fontsize=13
        style="filled,rounded"
        color="#ef9a9a"
        bgcolor="#2a0f0f"

        pit_anterior [label="Anterior\nPituitary (AP)", fillcolor="#5a1a1a", fontcolor="white", shape=cylinder]
        pit_posterior [label="Posterior\nPituitary (PP)", fillcolor="#4a1a1a", fontcolor="white", shape=cylinder]
        lymphocytic_infiltrate [label="Lymphocytic\nInfiltration\n(CD4+/CD8+)", fillcolor="#7a1a1a", fontcolor="white", shape=ellipse]
        pituitary_mass [label="Pituitary\nMass Lesion\n(MRI T1-enhancement)", fillcolor="#8a1a1a", fontcolor="white", shape=ellipse]
        pit_fibrosis [label="Pituitary\nFibrosis", fillcolor="#7a1a1a", fontcolor="white", shape=ellipse]
        corticotrophs [label="Corticotrophs\n(ACTH-cells)", fillcolor="#4a1a2a", fontcolor="white", shape=box]
        thyrotrophs [label="Thyrotrophs\n(TSH-cells)", fillcolor="#4a1a2a", fontcolor="white", shape=box]
        gonadotrophs [label="Gonadotrophs\n(FSH/LH-cells)", fillcolor="#4a1a2a", fontcolor="white", shape=box]
        somatotrophs [label="Somatotrophs\n(GH-cells)", fillcolor="#4a1a2a", fontcolor="white", shape=box]
        lactotrophs [label="Lactotrophs\n(PRL-cells)", fillcolor="#4a1a2a", fontcolor="white", shape=box]
        vasopressin_neurons [label="AVP Neurons\n(Posterior Pituitary)", fillcolor="#3a1a3a", fontcolor="white", shape=box]
        infundibular_stalk [label="Infundibular\nStalk Involvement", fillcolor="#7a1a1a", fontcolor="white", shape=diamond]
        sella_expansion [label="Sella Turcica\nExpansion", fillcolor="#6a1a1a", fontcolor="white", shape=box]
        optic_chiasm [label="Optic Chiasm\nCompression", fillcolor="#8a2a1a", fontcolor="white", shape=ellipse]
        cavernous_sinus [label="Cavernous Sinus\nInvolvement", fillcolor="#7a2a1a", fontcolor="white", shape=box]
        pit1_tf [label="PIT-1\nTranscription Factor", fillcolor="#4a1a1a", fontcolor="white", shape=diamond]
        tbx19_tf [label="TBX19/Tpit\nTranscription Factor", fillcolor="#4a1a1a", fontcolor="white", shape=diamond]
    }

    /* ===================== CLUSTER 6: HYPOTHALAMIC CONTROL ===================== */
    subgraph cluster_hypothalamus {
        label="Hypothalamic Regulatory Hormones"
        fontcolor="#b39ddb"
        fontsize=13
        style="filled,rounded"
        color="#b39ddb"
        bgcolor="#1a1040"

        crh [label="CRH\n(Corticotropin-Releasing\nHormone)", fillcolor="#3a2a6a", fontcolor="white", shape=ellipse]
        trh [label="TRH\n(Thyrotropin-Releasing\nHormone)", fillcolor="#3a2a6a", fontcolor="white", shape=ellipse]
        gnrh [label="GnRH\n(Gonadotropin-Releasing\nHormone, pulsatile)", fillcolor="#3a2a6a", fontcolor="white", shape=ellipse]
        ghrh [label="GHRH\n(GH-Releasing\nHormone)", fillcolor="#3a2a6a", fontcolor="white", shape=ellipse]
        somatostatin [label="Somatostatin\n(SRIF, inhibits GH)", fillcolor="#5a3a7a", fontcolor="white", shape=ellipse]
        dopamine [label="Dopamine\n(Inhibits PRL)", fillcolor="#5a3a7a", fontcolor="white", shape=ellipse]
        avp_hypothalamic [label="Hypothalamic AVP\n(CRH potentiator)", fillcolor="#4a2a6a", fontcolor="white", shape=ellipse]
        kisspeptin [label="Kisspeptin\n(GnRH regulator)", fillcolor="#3a2a6a", fontcolor="white", shape=diamond]
        npy [label="NPY\n(Appetite / GnRH)", fillcolor="#3a2a6a", fontcolor="white", shape=ellipse]
        arcuate_nucleus [label="Arcuate\nNucleus", fillcolor="#2a1a5a", fontcolor="white", shape=box]
    }

    /* ===================== CLUSTER 7: HPA AXIS ===================== */
    subgraph cluster_hpa {
        label="HPA Axis (Hypothalamus–Pituitary–Adrenal)"
        fontcolor="#80cbc4"
        fontsize=13
        style="filled,rounded"
        color="#80cbc4"
        bgcolor="#0a2020"

        acth [label="ACTH\n(pg/mL)\nPulsatile, diurnal", fillcolor="#1a4a4a", fontcolor="white", shape=ellipse]
        pomc [label="Pro-Opiomelanocortin\n(POMC precursor)", fillcolor="#1a3a3a", fontcolor="white", shape=box]
        cortisol_plasma [label="Cortisol\n(nmol/L)\nTotal plasma", fillcolor="#2a5a5a", fontcolor="white", shape=ellipse]
        free_cortisol [label="Free Cortisol\n(biologically active)", fillcolor="#3a6a5a", fontcolor="white", shape=ellipse]
        cbg [label="Cortisol-Binding\nGlobulin (CBG)", fillcolor="#1a3a3a", fontcolor="white", shape=box]
        adrenal_cortex [label="Adrenal Cortex\n(Zona Fasciculata)", fillcolor="#2a4a3a", fontcolor="white", shape=cylinder]
        gr_receptor_hpa [label="Glucocorticoid\nReceptor (GR)", fillcolor="#2a5a4a", fontcolor="white", shape=diamond]
        nfkb_hpa [label="NF-κB\n(GR suppresses)", fillcolor="#3a4a3a", fontcolor="white", shape=diamond]
        hpa_feedback [label="Negative Feedback\n(Cortisol → Pit/Hypo)", fillcolor="#3a6a6a", fontcolor="white", shape=ellipse]
        cortisol_diurnal [label="Diurnal Rhythm\n(Peak: 08:00 AM)", fillcolor="#1a4a3a", fontcolor="white", shape=ellipse]
        cortisone [label="Cortisone\n(Inactive metabolite)", fillcolor="#1a3a2a", fontcolor="white", shape=ellipse]
    }

    /* ===================== CLUSTER 8: HPT AXIS ===================== */
    subgraph cluster_hpt {
        label="HPT Axis (Hypothalamus–Pituitary–Thyroid)"
        fontcolor="#f48fb1"
        fontsize=13
        style="filled,rounded"
        color="#f48fb1"
        bgcolor="#2a0020"

        tsh [label="TSH\n(mIU/L)\nThyrotropin", fillcolor="#5a1a3a", fontcolor="white", shape=ellipse]
        free_t4 [label="Free T4 (fT4)\n(pmol/L)\nL-thyroxine", fillcolor="#6a1a4a", fontcolor="white", shape=ellipse]
        free_t3 [label="Free T3 (fT3)\n(pmol/L)\nActive hormone", fillcolor="#7a1a5a", fontcolor="white", shape=ellipse]
        thyroid_follicle [label="Thyroid Follicle\nCells", fillcolor="#4a1a3a", fontcolor="white", shape=cylinder]
        tpo_enzyme [label="TPO\n(Thyroid Peroxidase)", fillcolor="#3a1a2a", fontcolor="white", shape=diamond]
        thyroglobulin [label="Thyroglobulin\n(Tg)", fillcolor="#3a1a2a", fontcolor="white", shape=box]
        deiodinase1 [label="Deiodinase D1\n(Liver/Kidney)", fillcolor="#4a1a3a", fontcolor="white", shape=diamond]
        deiodinase2 [label="Deiodinase D2\n(Brain/Pituitary)", fillcolor="#4a1a3a", fontcolor="white", shape=diamond]
        t4_binding_globulin [label="TBG\n(T4-Binding Globulin)", fillcolor="#3a1a2a", fontcolor="white", shape=box]
    }

    /* ===================== CLUSTER 9: HPG AXIS ===================== */
    subgraph cluster_hpg {
        label="HPG Axis (Hypothalamus–Pituitary–Gonadal)"
        fontcolor="#ffe082"
        fontsize=13
        style="filled,rounded"
        color="#ffe082"
        bgcolor="#2a2000"

        fsh [label="FSH\n(IU/L)\nFollicle-Stimulating\nHormone", fillcolor="#5a4a00", fontcolor="white", shape=ellipse]
        lh [label="LH\n(IU/L)\nLuteinizing\nHormone", fillcolor="#5a4a00", fontcolor="white", shape=ellipse]
        estradiol [label="Estradiol (E2)\n(pmol/L)", fillcolor="#6a5000", fontcolor="white", shape=ellipse]
        testosterone [label="Testosterone\n(nmol/L)", fillcolor="#6a5000", fontcolor="white", shape=ellipse]
        progesterone [label="Progesterone\n(nmol/L)", fillcolor="#6a5000", fontcolor="white", shape=ellipse]
        inhibin_b [label="Inhibin B\n(FSH inhibitor)", fillcolor="#5a4a00", fontcolor="white", shape=diamond]
        amh [label="AMH\n(Anti-Müllerian H)", fillcolor="#5a4a00", fontcolor="white", shape=diamond]
        granulosa_cells [label="Granulosa Cells\n(Ovarian follicle)", fillcolor="#4a3a00", fontcolor="white", shape=cylinder]
        leydig_cells [label="Leydig Cells\n(Testicular)", fillcolor="#4a3a00", fontcolor="white", shape=cylinder]
        gnrh_receptor [label="GnRH-R\n(Pituitary receptor)", fillcolor="#5a4a00", fontcolor="white", shape=diamond]
    }

    /* ===================== CLUSTER 10: GH/IGF-1 AXIS ===================== */
    subgraph cluster_gh {
        label="GH / IGF-1 Axis"
        fontcolor="#a5d6a7"
        fontsize=13
        style="filled,rounded"
        color="#a5d6a7"
        bgcolor="#0a200a"

        gh [label="Growth Hormone\n(GH, ng/mL)\nPulsatile secretion", fillcolor="#1a4a1a", fontcolor="white", shape=ellipse]
        igf1 [label="IGF-1\n(ng/mL)\nSomatomedin C", fillcolor="#2a5a2a", fontcolor="white", shape=ellipse]
        igfbp3 [label="IGFBP-3\n(IGF-1 carrier)", fillcolor="#1a3a1a", fontcolor="white", shape=box]
        liver_ghr [label="Hepatic GH\nReceptor (GHR)", fillcolor="#2a4a2a", fontcolor="white", shape=diamond]
        jak2_stat5b [label="JAK2/STAT5b\nSignaling", fillcolor="#2a4a2a", fontcolor="white", shape=diamond]
        gh_receptor_bone [label="GH Receptor\n(Bone / Muscle)", fillcolor="#1a3a1a", fontcolor="white", shape=diamond]
        bone_density [label="Bone Mineral\nDensity (BMD)", fillcolor="#3a5a3a", fontcolor="white", shape=ellipse]
    }

    /* ===================== CLUSTER 11: PROLACTIN & ADH ===================== */
    subgraph cluster_prl_adh {
        label="Prolactin & ADH (Posterior Pituitary)"
        fontcolor="#ce93d8"
        fontsize=13
        style="filled,rounded"
        color="#ce93d8"
        bgcolor="#200a30"

