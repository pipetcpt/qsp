        central_hypogonad [label="Central\nHypogonadism", fillcolor="#5a3a3a", fontcolor="white", shape=ellipse]
        gh_deficiency [label="GH Deficiency\n(Adult onset)", fillcolor="#5a3a3a", fontcolor="white", shape=ellipse]
        hyperprolactinemia [label="Hyperprolactinemia\n(Stalk effect)", fillcolor="#5a3a3a", fontcolor="white", shape=ellipse]
        pit_function_score [label="Pituitary Function\nComposite Score", fillcolor="#5a5a2a", fontcolor="white", shape=ellipse]
        mri_volume [label="Pituitary Volume\n(MRI, cm³)", fillcolor="#4a4a4a", fontcolor="white", shape=ellipse]
        stalk_thickness [label="Stalk Thickness\n(MRI, mm)", fillcolor="#4a4a4a", fontcolor="white", shape=ellipse]
        fatigue_score [label="Fatigue Score\n(Fatigue Severity Scale)", fillcolor="#4a4a4a", fontcolor="white", shape=ellipse]
        qol_score [label="Quality of Life\n(SF-36)", fillcolor="#5a5a5a", fontcolor="white", shape=ellipse]
        adrenal_crisis_risk [label="Adrenal Crisis\nRisk (Acute)", fillcolor="#6a2a2a", fontcolor="white", shape=ellipse]
    }

    /* ===================== INTER-CLUSTER EDGES ===================== */

    /* Triggers → Innate Immunity */
    pregnancy -> postpartum_state [label="hormonal shift", color="#b39ddb", style=dashed]
    postpartum_state -> pit1_antigen [label="self-antigen\nexposure", color="#b39ddb"]
    infection_trigger -> molecular_mimicry [label="cross-reactive\nepitopes", color="#ef9a9a"]
    molecular_mimicry -> pit1_antigen [label="mimics pituitary\nantigen", color="#ef9a9a"]
    genetic_susceptibility -> hla_dr3 [color="#4fc3f7"]
    genetic_susceptibility -> hla_dr4 [color="#4fc3f7"]
    genetic_susceptibility -> ctla4_polymorphism [color="#4fc3f7"]
    ipilimumab_trigger -> ctla4_polymorphism [label="blocks CTLA4", color="#f44336", style=dashed]
    autoimmune_diathesis -> genetic_susceptibility [color="#b39ddb", style=dashed]
    viral_antigen -> apcs [label="cross-present\nto T cells", color="#4fc3f7"]
    pit1_antigen -> apcs [label="presented via\nMHC-II", color="#4fc3f7"]

    /* Innate Immune Activation */
    apcs -> dendritic_cells [color="#4fc3f7"]
    apcs -> macrophages [color="#4fc3f7"]
    dendritic_cells -> mhc_class2 [color="#4fc3f7"]
    tlr_signaling -> nfkb_innate [color="#ffb74d"]
    tlr_signaling -> nlrp3 [color="#ffb74d"]
    nlrp3 -> il1beta [label="caspase-1\ncleavage", color="#ffb74d"]
    macrophages -> ros_production [color="#ef9a9a"]
    ros_production -> nfkb_innate [color="#ffb74d"]
    nfkb_innate -> il6 [color="#ffb74d"]
    nfkb_innate -> tnf_alpha [color="#ffb74d"]
    complement_system -> c3 [color="#4fc3f7"]
    complement_system -> c4 [color="#4fc3f7"]

    /* Innate → Adaptive */
    mhc_class2 -> naive_cd4_t [label="antigen\npresentation", color="#81c784"]
    dendritic_cells -> th1_cells [label="IL-12 signal", color="#81c784"]
    il12 -> th1_cells [label="polarizes → Th1", color="#81c784"]
    il23 -> th17_cells [label="maintains Th17", color="#81c784"]
    nk_cells -> cd8_cytotoxic [label="cytotoxic\ncooperation", color="#81c784"]

    /* Adaptive Immune Cell Differentiation */
    naive_cd4_t -> th1_cells [color="#81c784"]
    naive_cd4_t -> th17_cells [color="#81c784"]
    naive_cd4_t -> tfh_cells [color="#81c784"]
    naive_cd4_t -> treg_cells [label="FoxP3+ induction", color="#81c784"]
    tfh_cells -> naive_b [label="T-cell help", color="#81c784"]
    naive_b -> memory_b [label="germinal\ncenter reaction", color="#81c784"]
    naive_b -> plasma_cells [label="antibody\nsecretion", color="#81c784"]
    plasma_cells -> anti_pit1_abs [color="#4a7a2a"]
    plasma_cells -> anti_rabphilin_abs [color="#4a7a2a"]
    anti_pit1_abs -> apa [color="#4a7a4a"]
    anti_rabphilin_abs -> apa [color="#4a7a4a"]
    plasma_cells -> igg4_class_switch [label="IL-4/IL-10 drive", color="#81c784", style=dashed]

    /* Cytokine Production */
    th1_cells -> ifn_gamma [color="#ffb74d"]
    th1_cells -> il2 [color="#ffb74d"]
    th17_cells -> il17a [color="#ffb74d"]
    tfh_cells -> il21 [color="#ffb74d"]
    macrophages -> tnf_alpha [color="#ffb74d"]
    macrophages -> il6 [color="#ffb74d"]
    treg_cells -> tgf_beta [label="suppressive", color="#ffb74d", style=dashed]
    treg_cells -> il10 [label="anti-inflam.", color="#a5d6a7", style=dashed]
    dendritic_cells -> il12 [color="#ffb74d"]
    dendritic_cells -> il23 [color="#ffb74d"]
    tnf_alpha -> cxcl10 [color="#ffb74d"]
    ifn_gamma -> cxcl10 [color="#ffb74d"]
    il6 -> ccl2 [color="#ffb74d"]

    /* Immune → Pituitary Damage */
    lymphocytic_infiltrate -> pit_anterior [label="T/B cell infiltration", color="#ef9a9a"]
    lymphocytic_infiltrate -> pit_posterior [label="posterior LyH", color="#ef9a9a", style=dashed]
    cd8_cytotoxic -> corticotrophs [label="cytotoxic kill", color="#ef9a9a"]
    cd8_cytotoxic -> thyrotrophs [label="cytotoxic kill", color="#ef9a9a"]
    cd8_cytotoxic -> gonadotrophs [label="cytotoxic kill", color="#ef9a9a"]
    cd8_cytotoxic -> somatotrophs [label="cytotoxic kill", color="#ef9a9a"]
    cd8_cytotoxic -> lactotrophs [label="cytotoxic kill", color="#ef9a9a"]
    apa -> corticotrophs [label="ADCC, complement", color="#ef9a9a"]
    apa -> thyrotrophs [label="ADCC", color="#ef9a9a"]
    c3 -> pit_anterior [label="complement\ndeposition", color="#ef9a9a"]
    il6 -> pit_fibrosis [label="TGF-β induction", color="#ef9a9a", style=dashed]
    tgf_beta -> pit_fibrosis [label="fibrogenesis", color="#ef9a9a"]
    tnf_alpha -> lymphocytic_infiltrate [label="amplifies", color="#ef9a9a"]
    cxcl10 -> lymphocytic_infiltrate [label="T-cell attraction", color="#ef9a9a"]
    ccl2 -> macrophages [label="monocyte recruit", color="#4fc3f7"]

    /* Pituitary Mass Effects */
    lymphocytic_infiltrate -> pituitary_mass [label="mass formation", color="#ef9a9a"]
    pituitary_mass -> sella_expansion [label="pressure", color="#ef9a9a"]
    pituitary_mass -> infundibular_stalk [label="stalk involvement", color="#ef9a9a"]
    pituitary_mass -> optic_chiasm [label="superior\nextension", color="#ef9a9a"]
    infundibular_stalk -> cavernous_sinus [label="lateral extension", color="#ef9a9a", style=dashed]
    sella_expansion -> headache [label="dural stretch", color="white"]
    optic_chiasm -> visual_field_defect [label="bitemporal\nhemianopia", color="white"]

    /* Transcription factors */
    pit1_tf -> somatotrophs [label="PIT-1 drives", color="#b39ddb"]
    pit1_tf -> thyrotrophs [label="PIT-1 drives", color="#b39ddb"]
    pit1_tf -> lactotrophs [label="PIT-1 drives", color="#b39ddb"]
    tbx19_tf -> corticotrophs [label="Tpit drives", color="#b39ddb"]

    /* Hypothalamic Control */
    arcuate_nucleus -> gnrh [color="#b39ddb"]
    arcuate_nucleus -> kisspeptin [color="#b39ddb"]
    kisspeptin -> gnrh [label="stimulates\npulse", color="#b39ddb"]
    npy -> gnrh [label="inhibits\n(starvation)", color="#b39ddb", style=dashed]
    avp_hypothalamic -> crh [label="potentiates", color="#b39ddb"]

    /* Hypothalamus → Pituitary Hormones */
    crh -> corticotrophs [label="→ ACTH release", color="#80cbc4"]
    trh -> thyrotrophs [label="→ TSH release", color="#f48fb1"]
    gnrh -> gonadotrophs [label="→ FSH/LH\nrelease", color="#ffe082"]
    gnrh -> gnrh_receptor [color="#ffe082"]
    gnrh_receptor -> gonadotrophs [color="#ffe082"]
    ghrh -> somatotrophs [label="stimulates GH", color="#a5d6a7"]
    somatostatin -> somatotrophs [label="inhibits GH", color="#a5d6a7", style=dashed]
    dopamine -> lactotrophs [label="inhibits PRL\n(via D2)", color="#ce93d8", style=dashed]

    /* HPA Axis */
    corticotrophs -> pomc [label="POMC synthesis", color="#80cbc4"]
    pomc -> acth [label="PC1/3 cleavage", color="#80cbc4"]
    acth -> adrenal_cortex [label="stimulates\nsteroidogenesis", color="#80cbc4"]
    adrenal_cortex -> cortisol_plasma [label="cortisol\nsecretion", color="#80cbc4"]
    cortisol_plasma -> cbg [label="90% bound", color="#80cbc4"]
    cortisol_plasma -> free_cortisol [label="10% free,\nactive", color="#80cbc4"]
    free_cortisol -> gr_receptor_hpa [label="GR activation", color="#80cbc4"]
    free_cortisol -> cortisone [label="11β-HSD2\n(inactive)", color="#80cbc4", style=dashed]
    gr_receptor_hpa -> nfkb_hpa [label="GR suppresses\nNF-κB", color="#80cbc4", style=dashed]
    free_cortisol -> crh [label="negative\nfeedback (−)", color="#ef5350", style=dashed]
    free_cortisol -> acth [label="short-loop\nfeedback (−)", color="#ef5350", style=dashed]
    hpa_feedback -> corticotrophs [label="reduces ACTH", color="#ef5350", style=dashed]
    cortisol_diurnal -> acth [label="circadian\ndrive", color="#80cbc4"]

    /* HPT Axis */
    thyrotrophs -> tsh [label="TSH secretion", color="#f48fb1"]
    tsh -> thyroid_follicle [label="TSH-R activation", color="#f48fb1"]
    thyroid_follicle -> tpo_enzyme [color="#f48fb1"]
    tpo_enzyme -> thyroglobulin [label="iodination", color="#f48fb1"]
    thyroglobulin -> free_t4 [label="proteolysis\n→ T4 release", color="#f48fb1"]
    free_t4 -> deiodinase1 [label="T4→T3\nperipheral", color="#f48fb1"]
    free_t4 -> deiodinase2 [label="T4→T3\npituitary", color="#f48fb1"]
    deiodinase1 -> free_t3 [color="#f48fb1"]
    deiodinase2 -> free_t3 [color="#f48fb1"]
    free_t4 -> t4_binding_globulin [label="bound form\n(~99%)", color="#f48fb1"]
    free_t3 -> tsh [label="negative\nfeedback (−)", color="#ef5350", style=dashed]
    free_t4 -> tsh [label="negative\nfeedback (−)", color="#ef5350", style=dashed]

    /* HPG Axis */
    gonadotrophs -> fsh [label="FSH secretion", color="#ffe082"]
    gonadotrophs -> lh [label="LH secretion", color="#ffe082"]
    fsh -> granulosa_cells [label="follicle growth", color="#ffe082"]
    lh -> granulosa_cells [label="ovulation trigger", color="#ffe082"]
    lh -> leydig_cells [label="testosterone\nstimulus", color="#ffe082"]
    granulosa_cells -> estradiol [label="aromatase", color="#ffe082"]
    granulosa_cells -> inhibin_b [label="inhibin B\nproduction", color="#ffe082"]
    granulosa_cells -> amh [color="#ffe082"]
    leydig_cells -> testosterone [label="Leydig\nsteroidogenesis", color="#ffe082"]
    estradiol -> fsh [label="negative\nfeedback (−)", color="#ef5350", style=dashed]
    estradiol -> lh [label="positive/negative\nfeedback", color="#ffe082", style=dashed]
    inhibin_b -> fsh [label="selective\nFSH inhibition", color="#ef5350", style=dashed]
    testosterone -> lh [label="negative\nfeedback (−)", color="#ef5350", style=dashed]

    /* GH/IGF-1 Axis */
    somatotrophs -> gh [label="GH secretion\n(pulsatile)", color="#a5d6a7"]
    gh -> liver_ghr [label="hepatic GHR\nactivation", color="#a5d6a7"]
    liver_ghr -> jak2_stat5b [label="JAK2/STAT5b\nphosphorylation", color="#a5d6a7"]
    jak2_stat5b -> igf1 [label="IGF-1 gene\ntranscription", color="#a5d6a7"]
    igf1 -> igfbp3 [label="complex\nformation", color="#a5d6a7"]
    gh -> gh_receptor_bone [label="direct bone\neffects", color="#a5d6a7"]
    igf1 -> bone_density [label="stimulates\nosteoblasts", color="#a5d6a7"]
    igf1 -> gh [label="negative\nfeedback (−)", color="#ef5350", style=dashed]
    igf1 -> somatostatin [label="+ somatostatin", color="#a5d6a7", style=dashed]
    somatostatin -> gh [label="inhibits (−)", color="#ef5350", style=dashed]

    /* Prolactin */
    lactotrophs -> prolactin [label="PRL secretion", color="#ce93d8"]
    infundibular_stalk -> prolactin [label="dopamine\nblockade → ↑PRL", color="#ce93d8"]
    prolactin -> prl_receptor [label="PRL-R binding", color="#ce93d8"]
    prl_receptor -> mammary_tissue [label="JAK2/STAT5a", color="#ce93d8"]
    prolactin -> hyperprolactinemia [color="white"]

    /* ADH / Posterior Pituitary */
    vasopressin_neurons -> adh_posterior [label="AVP release\n(osmotic stimulus)", color="#ce93d8"]
    adh_posterior -> v2r_receptor [label="V2R activation\n(collecting duct)", color="#ce93d8"]
    v2r_receptor -> aquaporin2 [label="AQP2\ninsertion", color="#ce93d8"]
    aquaporin2 -> collecting_duct [label="water\nreabsorption", color="#ce93d8"]
    collecting_duct -> urine_osmolality [label="urine concentration", color="#ce93d8"]
    serum_osmolality -> adh_posterior [label="osmotic\nstimulus", color="#ce93d8"]
    adh_posterior -> diabetes_insipidus [label="↓ADH → DI", color="white", style=dashed]

    /* Pituitary Dysfunction → Hormone Deficiencies */
    corticotrophs -> acth_deficiency [label="cell loss", color="#ef9a9a", style=dashed]
    thyrotrophs -> central_hypothyroid [label="cell loss", color="#ef9a9a", style=dashed]
    gonadotrophs -> central_hypogonad [label="cell loss", color="#ef9a9a", style=dashed]
    somatotrophs -> gh_deficiency [label="cell loss", color="#ef9a9a", style=dashed]
    acth_deficiency -> adrenal_crisis_risk [label="cortisol\ndeficiency", color="#ef5350"]

    /* Pituitary Function Score */
    acth_deficiency -> pit_function_score [color="white"]
    central_hypothyroid -> pit_function_score [color="white"]
    central_hypogonad -> pit_function_score [color="white"]
    gh_deficiency -> pit_function_score [color="white"]
    mri_volume -> pit_function_score [color="white"]
    stalk_thickness -> mri_volume [color="white"]
    pituitary_mass -> mri_volume [label="MRI quantification", color="white"]

    /* Fatigue and QoL */
    acth_deficiency -> fatigue_score [color="white"]
    gh_deficiency -> fatigue_score [color="white"]
    central_hypothyroid -> fatigue_score [color="white"]
    central_hypogonad -> fatigue_score [color="white"]
    fatigue_score -> qol_score [color="white"]
    headache -> qol_score [color="white"]
    visual_field_defect -> qol_score [color="white"]

    /* Drug PK */
    pred_dose -> pred_gut [label="oral absorption\nka=1.2/h", color="#80deea"]
    pred_gut -> pred_central [label="bioavailability\nF=0.82", color="#80deea"]
    pred_central -> pred_peripheral [label="Q=25 L/h", color="#80deea"]
    pred_peripheral -> pred_central [label="redistribution", color="#80deea"]
    pred_central -> pred_metabolism [label="CYP3A4\nCL=8.5 L/h", color="#80deea"]
    aza_dose -> aza_activation [label="xanthine oxidase\n+HGPRT", color="#80deea"]
    aza_activation -> tgn_metabolites [label="6-TGN active", color="#80deea"]
    tgn_metabolites -> tpmt_enzyme [label="TPMT inactivation", color="#80deea", style=dashed]
    rituximab_dose -> rtx_plasma [label="IV infusion\nFH=1.0", color="#80deea"]
    mtx_dose -> mtx_plasma [label="oral/SC\nabsorption", color="#80deea"]

    /* Drug PD → Immune Effects */
    pred_central -> gr_occupancy [label="[Cpred] → GR\nbinding", color="#ffcc80"]
    gr_occupancy -> pred_antiinflam [label="GRE activation", color="#ffcc80"]
    pred_antiinflam -> cytokine_inhibition [label="↓IL-1β, TNF-α\n↓IL-6, IL-17", color="#ffcc80"]
    pred_antiinflam -> immune_suppression_pd [color="#ffcc80"]
    immune_suppression_pd -> lymphocyte_apoptosis [label="GC-induced\napoptosis", color="#ffcc80"]
    lymphocyte_apoptosis -> lymphocytic_infiltrate [label="reduces\ninfiltration", color="#a5d6a7", style=dashed]
    cytokine_inhibition -> il6 [label="suppresses", color="#a5d6a7", style=dashed]
    cytokine_inhibition -> tnf_alpha [label="suppresses", color="#a5d6a7", style=dashed]
    gr_occupancy -> hpa_suppression [label="suppresses\nHPA axis", color="#ef5350", style=dashed]
    hpa_suppression -> acth [label="iatrogenic ACTH\nsuppression", color="#ef5350", style=dashed]

    /* Steroid side effects */
    pred_central -> glucose_effect [label="GR→insulin\nresistance", color="#ef9a9a", style=dashed]
    pred_central -> bone_effect [label="osteoblast\ninhibition", color="#ef9a9a", style=dashed]
    pred_central -> cushingoid [label="long-term\ntherapy", color="#ef9a9a", style=dashed]

    /* AZA → Lymphocyte inhibition */
    tgn_metabolites -> aza_lymphocyte_inhib [label="purine synthesis\ninhibition", color="#ffcc80"]
    aza_lymphocyte_inhib -> th1_cells [label="reduces Th1\nproliferation", color="#a5d6a7", style=dashed]
    aza_lymphocyte_inhib -> th17_cells [label="reduces Th17", color="#a5d6a7", style=dashed]

    /* RTX → B cell depletion */
    rtx_plasma -> rtx_b_depletion [label="CD20 binding\nADCC/CDC", color="#ffcc80"]
    rtx_b_depletion -> plasma_cells [label="depletes\nB→Plasma", color="#a5d6a7", style=dashed]
    rtx_b_depletion -> apa [label="reduces APA\nproduction", color="#a5d6a7", style=dashed]

    /* MTX effects */
    mtx_plasma -> mtx_dhfr [label="DHFR inhibition", color="#ffcc80"]
    mtx_dhfr -> naive_b [label="inhibits B cell\nproliferation", color="#a5d6a7", style=dashed]
    mtx_dhfr -> naive_cd4_t [label="inhibits T cell\nproliferation", color="#a5d6a7", style=dashed]

    /* Hormone replacement therapy */
    acth_deficiency -> cortisol_plasma [label="Hydrocortisone\nreplacement", color="#80deea", style=dotted]
    central_hypothyroid -> free_t4 [label="Levothyroxine\nreplacement", color="#f48fb1", style=dotted]
    central_hypogonad -> estradiol [label="Estrogen/T\nreplacement", color="#ffe082", style=dotted]
    gh_deficiency -> igf1 [label="rhGH\ntherapy", color="#a5d6a7", style=dotted]
    diabetes_insipidus -> adh_posterior [label="Desmopressin\n(DDAVP) Rx", color="#ce93d8", style=dotted]
}
