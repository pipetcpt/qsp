    /* ===================== CLUSTER 13: DRUG PD ===================== */
    subgraph cluster_drug_pd {
        label="Drug Pharmacodynamics & Adverse Effects"
        fontcolor="#ffcc80"
        fontsize=13
        style="filled,rounded"
        color="#ffcc80"
        bgcolor="#2a1a00"

