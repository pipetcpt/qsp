digraph NF1_QSP {
  // =====================================================================
  // Neurofibromatosis Type 1 (NF1) - Mechanistic Map
  // NF1 (17q11.2) LOF -> neurofibromin RAS-GAP loss -> constitutive RAS-GTP
  // -> RAF-MEK-ERK hyperactivation in neural-crest Schwann cell lineage ->
  // plexiform/cutaneous neurofibroma, OPG, MPNST, skeletal/vascular/CNS/skin
  // manifestations. MEK1/2 inhibitors (selumetinib, mirdametinib, trametinib,
  // binimetinib) block the downstream node shared by all tumor phenotypes.
  // 16 clusters, 150+ nodes.
  // =====================================================================
  rankdir=LR;
  graph [fontname="Helvetica", fontsize=20, labelloc=t, label="Neurofibromatosis Type 1 (NF1) — Mechanistic Map: Neurofibromin-RAS-MAPK Axis, Tumor Pathology, MEK-Inhibitor PK/PD, Multi-Organ & Clinical Endpoints", compound=true, splines=true, nodesep=0.22, ranksep=0.55];
  node [fontname="Helvetica", fontsize=11, style=filled, shape=box, margin="0.12,0.06"];
  edge [fontname="Helvetica", fontsize=9, arrowsize=0.7];

  // ------------------------------------------------------------------
  subgraph cluster_genetics {
    label="1. Genetics & Etiology"; style=filled; color="#cfe8ff"; fontsize=13;
    NF1_GENE [label="NF1 gene\n17q11.2\n(~350 kb, 60 exons)", fillcolor="#a8d0f0"];
    LOF_MUT [label="Loss-of-function\nmutation\n(truncating/missense/splice)", fillcolor="#a8d0f0"];
    DENOVO [label="De novo mutation\n(~50% of cases)", fillcolor="#a8d0f0"];
    AUTOSOM_DOM [label="Autosomal dominant\ninheritance\n(100% penetrance)", fillcolor="#a8d0f0"];
    SECOND_HIT [label="Somatic 2nd-hit\n(LOH, biallelic loss)\nin Schwann cell", fillcolor="#a8d0f0"];
    MICRODEL [label="NF1 microdeletion\n(1.4/1.2 Mb, ~5-10%)\n± SUZ12 co-deletion", fillcolor="#a8d0f0"];
    SEVERE_PHENO [label="Severe phenotype:\nhigh tumor burden,\ndysmorphism, ID", fillcolor="#f6c6c6"];
    MOSAICISM [label="Segmental/mosaic NF1\n(post-zygotic)", fillcolor="#a8d0f0"];
    LEGIUS [label="Legius syndrome\n(SPRED1, 15q14)\nkey mimic/DDx", fillcolor="#e8e8e8"];
    NF1_GENE -> LOF_MUT; DENOVO -> LOF_MUT; LOF_MUT -> AUTOSOM_DOM;
    LOF_MUT -> SECOND_HIT; MICRODEL -> SEVERE_PHENO; LOF_MUT -> MICRODEL;
    LOF_MUT -> MOSAICISM; LEGIUS -> DDX [style=dashed];
  }

  // ------------------------------------------------------------------
  subgraph cluster_neurofibromin {
    label="2. Neurofibromin - RAS-GAP Function"; style=filled; color="#d8f0d8"; fontsize=13;
    NEUROFIBROMIN [label="Neurofibromin\n(2818 aa, GRD domain)", fillcolor="#a8e0a8"];
    GRD [label="GAP-related domain\n(GRD)", fillcolor="#a8e0a8"];
    RAS_GTP [label="RAS-GTP\n(active)", fillcolor="#f6c6c6"];
    RAS_GDP [label="RAS-GDP\n(inactive)", fillcolor="#a8e0a8"];
    NEUROFIBROMIN_LOSS [label="Neurofibromin\nhaplo-/nullizygosity", fillcolor="#f6c6c6"];
    GAP_ACTIVITY [label="RAS-GAP catalytic\nactivity ↓↓", fillcolor="#f6c6c6"];
    CAMP_PKA [label="cAMP-PKA\nco-regulation", fillcolor="#a8e0a8"];
    LOF_MUT -> NEUROFIBROMIN_LOSS;
    NEUROFIBROMIN -> GRD; GRD -> RAS_GTP [label="hydrolyzes\nRAS-GTP->GDP", color="#2a7a2a"];
    NEUROFIBROMIN_LOSS -> GAP_ACTIVITY; GAP_ACTIVITY -> RAS_GTP [label="disinhibits", color=red];
    RAS_GTP -> RAS_GDP [style=dashed, color="#2a7a2a", label="intrinsic +\nGAP-assisted"];
    NEUROFIBROMIN -> CAMP_PKA;
  }

  // ------------------------------------------------------------------
  subgraph cluster_mapk {
    label="3. RAS-RAF-MEK-ERK (MAPK) Cascade"; style=filled; color="#ffe6cc"; fontsize=13;
    RTK [label="RTK activation\n(EGFR/PDGFR/KIT)", fillcolor="#f7cf9e"];
    SOS_GRB2 [label="GRB2-SOS\nGEF complex", fillcolor="#f7cf9e"];
    RAF [label="RAF (A/B/C-RAF)\ndimerization", fillcolor="#f7cf9e"];
    MEK [label="MEK1/2\n(dual Thr/Tyr kinase)", fillcolor="#f7cf9e"];
    ERK [label="ERK1/2", fillcolor="#f7cf9e"];
    PERK_NUC [label="Nuclear pERK\ntranslocation", fillcolor="#f7cf9e"];
    ETS_FOS [label="ELK1/c-FOS/c-MYC\ntranscription", fillcolor="#f7cf9e"];
    PI3K_AKT [label="PI3K-AKT-mTOR\n(parallel RAS effector)", fillcolor="#f7cf9e"];
    NEG_FEEDBACK [label="ERK->RTK negative\nfeedback (DUSP/SPRY)", fillcolor="#e8e8e8"];
    ADAPTIVE_RESIST [label="Feedback relief on\nMEKi -> RTK reactivation\n(adaptive resistance)", fillcolor="#f6c6c6"];
    RTK -> SOS_GRB2 -> RAS_GTP; RAS_GTP -> RAF -> MEK -> ERK -> PERK_NUC -> ETS_FOS;
    RAS_GTP -> PI3K_AKT;
    ERK -> NEG_FEEDBACK [style=dashed]; NEG_FEEDBACK -> RTK [style=dashed, color="#2a7a2a", label="suppresses"];
    ADAPTIVE_RESIST -> RTK [color=red, label="disinhibits\nunder MEKi"];
  }

  // ------------------------------------------------------------------
  subgraph cluster_schwann {
    label="4. Schwann-Cell / Tumor Microenvironment Biology"; style=filled; color="#fde3ff"; fontsize=13;
    SCP [label="Neural-crest-derived\nSchwann cell precursor", fillcolor="#e3b8ea"];
    NF1_NULL_SC [label="NF1-/- Schwann cell\n(biallelic loss)", fillcolor="#f6c6c6"];
    MAST_CELL [label="Mast cell recruitment\n(SCF-KIT chemotaxis)", fillcolor="#e3b8ea"];
    FIBROBLAST [label="Fibroblast\nproliferation/collagen", fillcolor="#e3b8ea"];
    MACROPHAGE [label="Tumor-associated\nmacrophages (TAM)", fillcolor="#e3b8ea"];
    ECM_REMODEL [label="ECM remodeling\n(collagen, mucin)", fillcolor="#e3b8ea"];
    NEURON_AXON [label="Peripheral nerve\naxon architecture\ndisruption", fillcolor="#e3b8ea"];
    NF1_NULL_SC -> ERK [style=dashed]; MAST_CELL -> FIBROBLAST; MACROPHAGE -> FIBROBLAST;
    FIBROBLAST -> ECM_REMODEL; NF1_NULL_SC -> NEURON_AXON;
    SECOND_HIT -> NF1_NULL_SC; SCP -> NF1_NULL_SC;
  }

  // ------------------------------------------------------------------
  subgraph cluster_pn {
    label="5. Plexiform Neurofibroma (PN) Pathology"; style=filled; color="#ffd9d9"; fontsize=13;
    PN_INITIATION [label="Congenital PN\ninitiation (in utero)", fillcolor="#f0a8a8"];
    PN_GROWTH [label="PN volumetric\ngrowth (childhood/\nadolescence)", fillcolor="#f0a8a8"];
    PUBERTY_GROWTH [label="Puberty/pregnancy\nhormone-accelerated\ngrowth", fillcolor="#f0a8a8"];
    PN_INTERNAL [label="Deep/internal PN\n(paraspinal, plexus,\nvisceral, orbital)", fillcolor="#f0a8a8"];
    PN_SUPERFICIAL [label="Superficial/diffuse\nPN (disfigurement)", fillcolor="#f0a8a8"];
    PN_COMPRESSION [label="Nerve/airway/\nvascular compression", fillcolor="#f0a8a8"];
    PN_INOPERABLE [label="Inoperable PN\n(encasing structures)", fillcolor="#f0a8a8"];
    NF1_NULL_SC -> PN_INITIATION -> PN_GROWTH; PUBERTY_GROWTH -> PN_GROWTH;
    PN_GROWTH -> PN_INTERNAL; PN_GROWTH -> PN_SUPERFICIAL;
    PN_INTERNAL -> PN_COMPRESSION; PN_INTERNAL -> PN_INOPERABLE;
    ECM_REMODEL -> PN_GROWTH;
  }

  // ------------------------------------------------------------------
  subgraph cluster_cnf {
    label="6. Cutaneous & Subcutaneous Neurofibroma"; style=filled; color="#ffe9d6"; fontsize=13;
    CNF_ONSET [label="Cutaneous NF (cNF)\nonset ~puberty", fillcolor="#f0c090"];
    CNF_COUNT [label="cNF count/burden\n(>99% adults NF1)", fillcolor="#f0c090"];
    CNF_HORMONE [label="GHR/estrogen/\nprogesterone receptor\nsignaling in cNF", fillcolor="#f0c090"];
    SUBQ_NF [label="Subcutaneous\nnodular NF", fillcolor="#f0c090"];
    DISFIGUREMENT [label="Cosmetic\ndisfigurement", fillcolor="#f0c090"];
    NF1_NULL_SC -> CNF_ONSET -> CNF_COUNT; CNF_HORMONE -> CNF_COUNT;
    PUBERTY_GROWTH -> CNF_HORMONE; CNF_COUNT -> SUBQ_NF; CNF_COUNT -> DISFIGUREMENT;
  }

  // ------------------------------------------------------------------
  subgraph cluster_mpnst {
    label="7. Malignant Transformation (MPNST)"; style=filled; color="#ffb3b3"; fontsize=13;
    ATYPICAL_NF [label="Atypical neurofibroma\n(ANNUBP)\nCDKN2A loss", fillcolor="#e07070"];
    MPNST_INIT [label="MPNST initiation\n(TP53, PRC2/SUZ12\nEED loss)", fillcolor="#e07070"];
    MPNST_GROWTH [label="MPNST growth\n& local invasion", fillcolor="#e07070"];
    MPNST_METS [label="Metastasis\n(lung, bone)", fillcolor="#e07070"];
    MPNST_LIFETIME [label="Lifetime MPNST risk\n8-13% in NF1", fillcolor="#e07070"];
    FDG_PET [label="FDG-PET SUVmax\nsurveillance", fillcolor="#e8e8e8"];
    PN_INTERNAL -> ATYPICAL_NF [label="20x risk\nvs no internal PN"]; ATYPICAL_NF -> MPNST_INIT -> MPNST_GROWTH -> MPNST_METS;
    MPNST_INIT -> MPNST_LIFETIME; FDG_PET -> ATYPICAL_NF [style=dashed, label="detects"];
  }

  // ------------------------------------------------------------------
  subgraph cluster_opg {
    label="8. Optic Pathway & CNS Glioma"; style=filled; color="#d6e6ff"; fontsize=13;
    OPG_INIT [label="Optic pathway\nglioma (OPG) onset\n(~20% of NF1 children)", fillcolor="#a0b8e8"];
    OPG_GROWTH [label="OPG WHO grade I\npilocytic astrocytoma\ngrowth", fillcolor="#a0b8e8"];
    OPG_VISUAL [label="Chiasmatic/\nretro-chiasmatic\nvisual pathway compression", fillcolor="#a0b8e8"];
    OTHER_GLIOMA [label="Brainstem/\nother low-grade glioma", fillcolor="#a0b8e8"];
    UBO [label="T2-hyperintensities\n(UBOs)", fillcolor="#e8e8e8"];
    NF1_NULL_SC -> OPG_INIT [label="astrocyte/\nprogenitor lineage"]; OPG_INIT -> OPG_GROWTH -> OPG_VISUAL;
    OPG_INIT -> OTHER_GLIOMA; NF1_GENE -> UBO [style=dashed];
  }

  // ------------------------------------------------------------------
  subgraph cluster_skeletal {
    label="9. Skeletal / Orthopedic"; style=filled; color="#e0f0e0"; fontsize=13;
    SPHENOID_DYSPL [label="Sphenoid wing\ndysplasia", fillcolor="#9ecf9e"];
    SCOLIOSIS [label="Dystrophic\nscoliosis", fillcolor="#9ecf9e"];
    TIBIAL_DYSPL [label="Tibial dysplasia\n(anterolateral bowing)", fillcolor="#9ecf9e"];
    PSEUDARTHROSIS [label="Tibial\npseudarthrosis\n(non-union fracture)", fillcolor="#9ecf9e"];
    SHORT_STATURE [label="Short stature /\nmacrocephaly", fillcolor="#9ecf9e"];
    OSTEOPENIA [label="Osteopenia /\nreduced BMD", fillcolor="#9ecf9e"];
    NEUROFIBROMIN_LOSS -> SCOLIOSIS; NEUROFIBROMIN_LOSS -> TIBIAL_DYSPL -> PSEUDARTHROSIS;
    PN_INTERNAL -> SPHENOID_DYSPL; NEUROFIBROMIN_LOSS -> SHORT_STATURE;
    NEUROFIBROMIN_LOSS -> OSTEOPENIA;
  }

  // ------------------------------------------------------------------
  subgraph cluster_vascular {
    label="10. Vasculopathy / Cardiovascular"; style=filled; color="#ffe0e0"; fontsize=13;
    VASC_SMC [label="Vascular smooth\nmuscle RAS-MAPK\ndysregulation", fillcolor="#e89a9a"];
    STENOSIS [label="Arterial stenosis\n(renal, cerebral)", fillcolor="#e89a9a"];
    ANEURYSM [label="Aneurysm /\nmoyamoya-like disease", fillcolor="#e89a9a"];
    HYPERTENSION [label="Hypertension\n(renal artery + pheo)", fillcolor="#e89a9a"];
    PHEO [label="Pheochromocytoma\n(~1-5%)", fillcolor="#e89a9a"];
    CHD [label="Congenital heart\ndisease (PS, HCM)", fillcolor="#e89a9a"];
    NEUROFIBROMIN_LOSS -> VASC_SMC -> STENOSIS; VASC_SMC -> ANEURYSM; STENOSIS -> HYPERTENSION;
    NEUROFIBROMIN_LOSS -> PHEO -> HYPERTENSION; NEUROFIBROMIN_LOSS -> CHD;
  }

  // ------------------------------------------------------------------
  subgraph cluster_cns {
    label="11. CNS / Neurocognitive"; style=filled; color="#e6e0ff"; fontsize=13;
    STRATTERA_PATH [label="Striatal/prefrontal\nRAS-MAPK-dependent\nsynaptic plasticity deficit", fillcolor="#b3a0e0"];
    LEARNING_DIS [label="Specific learning\ndisability\n(30-70%)", fillcolor="#b3a0e0"];
    ADHD_NF1 [label="ADHD-like\ninattention (~40%)", fillcolor="#b3a0e0"];
    VISUOSPATIAL [label="Visuospatial /\nnonverbal deficits", fillcolor="#b3a0e0"];
    HEADACHE [label="Headache /\nmigraine", fillcolor="#b3a0e0"];
    NEUROFIBROMIN_LOSS -> STRATTERA_PATH -> LEARNING_DIS; STRATTERA_PATH -> ADHD_NF1;
    STRATTERA_PATH -> VISUOSPATIAL; UBO -> HEADACHE [style=dashed];
  }

  // ------------------------------------------------------------------
  subgraph cluster_skin_lisch {
    label="12. Dermatologic & Ophthalmic Hallmarks"; style=filled; color="#fff3cc"; fontsize=13;
    CALM [label="Cafe-au-lait\nmacules (>=6)", fillcolor="#e0c060"];
    FRECKLING [label="Axillary/inguinal\nfreckling (Crowe sign)", fillcolor="#e0c060"];
    LISCH [label="Lisch nodules\n(iris hamartoma)", fillcolor="#e0c060"];
    CHOROIDAL [label="Choroidal\nabnormalities (OCT)", fillcolor="#e0c060"];
    NF1_NULL_SC -> CALM; NF1_NULL_SC -> FRECKLING; NF1_NULL_SC -> LISCH; NF1_NULL_SC -> CHOROIDAL;
  }

  // ------------------------------------------------------------------
  subgraph cluster_pkdrug {
    label="13. Drug PK — MEK1/2 Inhibitors"; style=filled; color="#cceeff"; fontsize=13;
    SEL_DOSE [label="Selumetinib\n25 mg/m2 BID PO\n(capsule/granule)", fillcolor="#7ec8e3"];
    SEL_ABS [label="GI absorption\n(Tmax ~1.5-2 h)\nfood-independent", fillcolor="#7ec8e3"];
    SEL_CYP [label="CYP3A4/2C19\nmetabolism\n(N-desmethyl metabolite)", fillcolor="#7ec8e3"];
    SEL_CENTRAL [label="Selumetinib\nplasma Cp\n(t1/2 ~9 h)", fillcolor="#7ec8e3"];
    MIR_DOSE [label="Mirdametinib\n2 mg/m2 BID PO\n(3wk-on/1wk-off)", fillcolor="#7ec8e3"];
    MIR_ABS [label="GI absorption\n(Tmax ~1-4 h)", fillcolor="#7ec8e3"];
    MIR_CENTRAL [label="Mirdametinib\nplasma Cp\n(t1/2 ~35-40 h)", fillcolor="#7ec8e3"];
    TRAM_BINI [label="Trametinib /\nBinimetinib\n(off-label alt. MEKi)", fillcolor="#a8dcee"];
    DRUG_HOLIDAY [label="Dose interruption /\nreduction (AE-driven)", fillcolor="#e8e8e8"];
    SEL_DOSE -> SEL_ABS -> SEL_CENTRAL; SEL_CENTRAL -> SEL_CYP [style=dashed];
    MIR_DOSE -> MIR_ABS -> MIR_CENTRAL;
    DRUG_HOLIDAY -> SEL_CENTRAL [style=dashed, color=red]; DRUG_HOLIDAY -> MIR_CENTRAL [style=dashed, color=red];
  }

  // ------------------------------------------------------------------
  subgraph cluster_pddrug {
    label="14. Drug PD — Tumor Response"; style=filled; color="#d0f0ff"; fontsize=13;
    MEK_INHIB [label="MEK1/2 ATP-competitive\n(allosteric) inhibition", fillcolor="#5aa8cc"];
    PERK_SUPPRESS [label="pERK suppression\n(>=80% target)", fillcolor="#5aa8cc"];
    TGI [label="Tumor growth\ninhibition (Simeoni\nsignal-transduction)", fillcolor="#5aa8cc"];
    PN_REGRESSION [label="PN volume\nregression (>=20%\n= REiNS response)", fillcolor="#5aa8cc"];
    CNF_MODEST [label="Modest cNF\nresponse", fillcolor="#5aa8cc"];
    OPG_RESPONSE [label="OPG volume\nresponse", fillcolor="#5aa8cc"];
    RESISTANCE_REBOUND [label="Adaptive resistance /\ntumor regrowth\non discontinuation", fillcolor="#f6c6c6"];
    SEL_CENTRAL -> MEK_INHIB; MIR_CENTRAL -> MEK_INHIB; TRAM_BINI -> MEK_INHIB;
    MEK -> MEK_INHIB [style=dashed, color=blue, label="drug\ntarget"];
    MEK_INHIB -> PERK_SUPPRESS -> TGI -> PN_REGRESSION;
    TGI -> CNF_MODEST; TGI -> OPG_RESPONSE;
    ADAPTIVE_RESIST -> RESISTANCE_REBOUND; RESISTANCE_REBOUND -> PN_REGRESSION [color=red, style=dashed, label="attenuates"];
    DRUG_HOLIDAY -> RESISTANCE_REBOUND [color=red];
  }

  // ------------------------------------------------------------------
  subgraph cluster_safety {
    label="15. Safety / Adverse Events"; style=filled; color="#f0d0d0"; fontsize=13;
    ACNEIFORM [label="Acneiform rash\n(~90% any grade)", fillcolor="#d98a8a"];
    PARONYCHIA [label="Paronychia\n(~20-60%)", fillcolor="#d98a8a"];
    CPK_ELEV [label="Asymptomatic CPK\nelevation", fillcolor="#d98a8a"];
    GI_AE [label="Nausea/vomiting/\ndiarrhea", fillcolor="#d98a8a"];
    LVEF_DECLINE [label="LVEF decline\n(~5-11%, reversible)", fillcolor="#d98a8a"];
    RPED [label="Retinal pigment\nepitheliopathy (RPED) /\nCSR", fillcolor="#d98a8a"];
    GROWTH_IMPAIR [label="Growth-plate /\nlinear growth impact\n(pediatric, theoretical)", fillcolor="#d98a8a"];
    MEK_INHIB -> ACNEIFORM; MEK_INHIB -> PARONYCHIA; MEK_INHIB -> CPK_ELEV;
    MEK_INHIB -> GI_AE; MEK_INHIB -> LVEF_DECLINE; MEK_INHIB -> RPED; MEK_INHIB -> GROWTH_IMPAIR;
  }

  // ------------------------------------------------------------------
  subgraph cluster_clinical {
    label="16. Clinical Endpoints & Outcomes"; style=filled; color="#e8ffe0"; fontsize=13;
    PAIN_NRS [label="Pain NRS-11\n(tumor pain intensity)", fillcolor="#8fc98f"];
    PAIN_INTERFERENCE [label="Pain Interference\nIndex (PII)", fillcolor="#8fc98f"];
    HRQOL [label="HRQoL\n(PedsQL / INF1-QOL)", fillcolor="#8fc98f"];
    FUNCTION [label="Motor strength /\nROM function", fillcolor="#8fc98f"];
    VISUAL_ACUITY [label="Visual acuity\n(OPG subgroup)", fillcolor="#8fc98f"];
    ORR [label="Objective Response\nRate (ORR, REiNS)", fillcolor="#8fc98f"];
    MORTALITY [label="MPNST-related\nmortality", fillcolor="#8fc98f"];
    PN_REGRESSION -> PAIN_NRS -> PAIN_INTERFERENCE -> HRQOL;
    PN_COMPRESSION -> PAIN_NRS [color=red]; PN_REGRESSION -> FUNCTION; PN_REGRESSION -> ORR;
    OPG_RESPONSE -> VISUAL_ACUITY; OPG_VISUAL -> VISUAL_ACUITY [color=red];
    MPNST_METS -> MORTALITY; DISFIGUREMENT -> HRQOL [color=red];
    ACNEIFORM -> HRQOL [color=red, style=dashed];
  }

  // ------------------------------------------------------------------
  // Cross-cluster integration edges
  DDX [label="Differential diagnosis\nworkup", shape=ellipse, fillcolor="#e8e8e8", style=filled];
  PN_INOPERABLE -> SEL_DOSE [style=dashed, color=blue, label="indication"];
  PN_INOPERABLE -> MIR_DOSE [style=dashed, color=blue, label="indication"];
  OPG_GROWTH -> SEL_DOSE [style=dashed, color=blue, label="off-label\nindication"];
  MPNST_LIFETIME -> FDG_PET [style=dashed];
  SEVERE_PHENO -> PN_GROWTH [style=dashed];
  RAS_GTP -> NF1_NULL_SC [style=dashed];
}
