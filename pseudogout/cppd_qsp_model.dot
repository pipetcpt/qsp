digraph CPPD_QSP {
    // ===== GLOBAL GRAPH SETTINGS =====
    graph [
        label="Pseudogout (CPPD Crystal Deposition Disease)\nQuantitative Systems Pharmacology Model",
        labelloc=t, labeljust=c,
        fontname="Helvetica", fontsize=20, fontcolor="#1a1a2e",
        bgcolor="#f8f9fa",
        rankdir=TB,
        nodesep=0.45, ranksep=0.65,
        pad=0.6,
        splines=true,
        concentrate=false
    ]
    node [fontname="Helvetica", fontsize=10, style="filled,rounded", shape=box, margin="0.15,0.08"]
    edge [fontname="Helvetica", fontsize=8, arrowsize=0.7]

    // ===== CLUSTER 1: RISK FACTORS & PREDISPOSING CONDITIONS =====
    subgraph cluster_risk {
        label="Risk Factors & Predisposing Conditions"
        style="filled,rounded" color="#c0392b" fillcolor="#fdecea" fontcolor="#c0392b" fontsize=13 fontname="Helvetica-Bold"

        Age        [label="Advanced Age\n(≥65 yr)", fillcolor="#ff8a80", color="#c0392b"]
        PHPT       [label="Hyperparathyroidism\n(PTH↑ → Ca²⁺↑)", fillcolor="#ff8a80", color="#c0392b"]
        Hypomag    [label="Hypomagnesemia\n(Mg²⁺↓)", fillcolor="#ff8a80", color="#c0392b"]
        Hemochr    [label="Hemochromatosis\n(Fe²⁺ accumulation)", fillcolor="#ff8a80", color="#c0392b"]
        WilsonDis  [label="Wilson's Disease\n(Cu²⁺ accumulation)", fillcolor="#ff8a80", color="#c0392b"]
        Hypophosph [label="Hypophosphatasia\n(ALPL/TNAP mutation)", fillcolor="#ff8a80", color="#c0392b"]
        FamilCPPD  [label="Familial CPPD\n(ANKH mutation)", fillcolor="#ff8a80", color="#c0392b"]
        OA_comorbid[label="Osteoarthritis\n(coexisting)", fillcolor="#ffcdd2", color="#c0392b"]
        Trauma     [label="Joint Trauma /\nSurgery (trigger)", fillcolor="#ff8a80", color="#c0392b"]
        NutrDef    [label="Nutritional Deficiency\n(Mg²⁺, Pi)", fillcolor="#ffcdd2", color="#c0392b"]
    }

    // ===== CLUSTER 2: INORGANIC PYROPHOSPHATE (PPi) METABOLISM =====
    subgraph cluster_ppi {
        label="Inorganic Pyrophosphate (PPi) Metabolism"
        style="filled,rounded" color="#8e44ad" fillcolor="#f3e5f5" fontcolor="#6a0dad" fontsize=13 fontname="Helvetica-Bold"

        ATP_hydrol [label="ATP Hydrolysis\n(NTPDase1/2, ENPP1)", fillcolor="#ce93d8", color="#8e44ad"]
        ENPP1      [label="ENPP1 / NPP1\n(generates PPi from ATP)", fillcolor="#ba68c8", color="#8e44ad"]
        ANKH_ch    [label="ANKH Channel\n(PPi efflux: ICF→ECF)", fillcolor="#ab47bc", color="#8e44ad", fontcolor="white"]
        PPi_ICF    [label="Intracellular PPi\n(chondrocyte)", fillcolor="#e1bee7", color="#8e44ad"]
        PPi_ECF    [label="Extracellular PPi\n(pericellular matrix)", fillcolor="#ce93d8", color="#8e44ad"]
        TNAP       [label="TNAP / ALPL\n(tissue-nonspecific\nalk. phosphatase)\nPPi → 2Pi", fillcolor="#9c27b0", color="#6a0dad", fontcolor="white"]
        NT5E       [label="NT5E / CD73\n(AMP → Adenosine)", fillcolor="#d1c4e9", color="#8e44ad"]
        Pi_pool    [label="Inorganic Phosphate (Pi)\npool (extracellular)", fillcolor="#e8daef", color="#8e44ad"]
        Ca_art     [label="Articular Ca²⁺\nconcentration", fillcolor="#e1bee7", color="#8e44ad"]
        Mg_inh     [label="Mg²⁺ (inhibits\nCPPD nucleation)", fillcolor="#e8daef", color="#8e44ad"]
    }

    // ===== CLUSTER 3: CPPD CRYSTAL DYNAMICS =====
    subgraph cluster_crystal {
        label="CPPD Crystal Dynamics"
        style="filled,rounded" color="#1565c0" fillcolor="#e3f2fd" fontcolor="#0d47a1" fontsize=13 fontname="Helvetica-Bold"

        NucCPPD    [label="CPPD Nucleation\n(Ca₂P₂O₇ seed\nformation)", fillcolor="#90caf9", color="#1565c0"]
        CrystGrow  [label="Crystal Growth\n(monoclinic +\ntriclinic phases)", fillcolor="#64b5f6", color="#1565c0"]
        CrystCart  [label="Crystal Burden\nin Cartilage\n(mg/g dry wt)", fillcolor="#1976d2", color="#0d47a1", fontcolor="white"]
        Chondrocalc[label="Chondrocalcinosis\n(imaging confirmed)", fillcolor="#42a5f5", color="#1565c0"]
        CrystShed  [label="Crystal Shedding\n(mechanical / trauma\n→ synovial fluid)", fillcolor="#2196f3", color="#1565c0", fontcolor="white"]
        CrystSF    [label="CPPD Crystals\nin Synovial Fluid\n(positively birefringent)", fillcolor="#64b5f6", color="#1565c0"]
        CrystCoat  [label="Crystal Coating\nby IgG / C3\n(opsonization)", fillcolor="#bbdefb", color="#1565c0"]
    }

    // ===== CLUSTER 4: INNATE IMMUNE ACTIVATION =====
    subgraph cluster_innate {
        label="Innate Immune Activation"
        style="filled,rounded" color="#e65100" fillcolor="#fff3e0" fontcolor="#bf360c" fontsize=13 fontname="Helvetica-Bold"

        MacroPhag  [label="Synovial Macrophage\n(M1 polarized)", fillcolor="#ffcc80", color="#e65100"]
        TLR2_4     [label="TLR2/TLR4\n(crystal PRR)", fillcolor="#ffa726", color="#e65100"]
        FcgR       [label="FcγR / CR3\n(opsonized crystal\nphagocytosis)", fillcolor="#ffa726", color="#e65100"]
        Phago      [label="Phagolysosomal\nRupture\n(crystal escape)", fillcolor="#ff7043", color="#e65100", fontcolor="white"]
        CathB      [label="Cathepsin B\nRelease\n(lysosomal leakage)", fillcolor="#ff8a65", color="#e65100"]
        NLRP3_act  [label="NLRP3 Inflammasome\nActivation\n(ASC/Caspase-1)", fillcolor="#d84315", color="#bf360c", fontcolor="white"]
        Casp1      [label="Caspase-1\nActivation", fillcolor="#ff7043", color="#e65100", fontcolor="white"]
        IL1b_pre   [label="Pro-IL-1β\n(synthesis\nvia NF-κB)", fillcolor="#ffb74d", color="#e65100"]
        IL1b_mat   [label="Mature IL-1β\n(secreted)", fillcolor="#ef6c00", color="#e65100", fontcolor="white"]
        IL18       [label="IL-18\n(co-activated\nwith NLRP3)", fillcolor="#ffa726", color="#e65100"]
        Pyroptosis [label="Pyroptosis\n(GSDMD pore\nformation)", fillcolor="#ff8a65", color="#e65100"]
        NFkB       [label="NF-κB Activation\n(p65 nuclear\ntranslocation)", fillcolor="#e64a19", color="#bf360c", fontcolor="white"]
        ROS_burst  [label="ROS Burst\n(NADPH oxidase\nactivation)", fillcolor="#ffb74d", color="#e65100"]
        MitoStress [label="Mitochondrial\nStress (mtROS)", fillcolor="#ffe0b2", color="#e65100"]
    }

    // ===== CLUSTER 5: NEUTROPHIL BIOLOGY =====
    subgraph cluster_neutrophil {
        label="Neutrophil Recruitment & Activation"
        style="filled,rounded" color="#2e7d32" fillcolor="#e8f5e9" fontcolor="#1b5e20" fontsize=13 fontname="Helvetica-Bold"

        IL8_CXCL8  [label="IL-8 / CXCL8\n(neutrophil chemokine)", fillcolor="#a5d6a7", color="#2e7d32"]
        C5a        [label="C5a\n(complement\nchemotactic factor)", fillcolor="#81c784", color="#2e7d32"]
        LTB4       [label="LTB4\n(5-LOX product\nchemotaxis)", fillcolor="#66bb6a", color="#2e7d32"]
        NeutRecruit[label="Neutrophil\nRecruitment\n(synovial fluid)", fillcolor="#388e3c", color="#1b5e20", fontcolor="white"]
        NeutActiv  [label="Neutrophil\nActivation\n(crystal engulfment)", fillcolor="#2e7d32", color="#1b5e20", fontcolor="white"]
        MPO        [label="MPO / Elastase\nRelease\n(degranulation)", fillcolor="#4caf50", color="#2e7d32"]
        NETs       [label="NETosis\n(NET release,\nDNA+Histones)", fillcolor="#81c784", color="#2e7d32"]
        NeutCrystLysis [label="Neutrophil Lysis\n(crystal-induced\ncytolysis)", fillcolor="#a5d6a7", color="#2e7d32"]
        IL1Ra_neut [label="IL-1Ra Release\n(anti-inflammatory\nfeedback)", fillcolor="#c8e6c9", color="#2e7d32"]
    }

    // ===== CLUSTER 6: INFLAMMATORY MEDIATORS =====
    subgraph cluster_inflam {
        label="Inflammatory Mediators & Signaling"
        style="filled,rounded" color="#d81b60" fillcolor="#fce4ec" fontcolor="#880e4f" fontsize=13 fontname="Helvetica-Bold"

        IL6        [label="IL-6\n(pleotropic\ncytokine)", fillcolor="#f48fb1", color="#d81b60"]
        TNFa       [label="TNF-α\n(macrophage-derived\npro-inflammatory)", fillcolor="#f06292", color="#d81b60"]
        IL1Ra      [label="IL-1Ra\n(endogenous\nantagonist)", fillcolor="#fce4ec", color="#d81b60"]
        COX2       [label="COX-2\n(inducible\nprostaglandin syn)", fillcolor="#e91e63", color="#880e4f", fontcolor="white"]
        PGE2       [label="PGE2\n(pain sensitization\nvasodilation)", fillcolor="#f48fb1", color="#d81b60"]
        LOX5       [label="5-LOX\n(leukotriene\nsynthesis)", fillcolor="#ec407a", color="#d81b60"]
        Complement [label="Complement\nActivation\n(C3/C5 pathway)", fillcolor="#f8bbd0", color="#d81b60"]
        MMP1_3_13  [label="MMP-1/3/13\n(collagenase/\nstromelysin)", fillcolor="#e91e63", color="#880e4f", fontcolor="white"]
        ADAMTS     [label="ADAMTS-4/5\n(aggrecanase)", fillcolor="#f06292", color="#d81b60"]
        TGFb       [label="TGF-β\n(fibrosis /\nremodeling)", fillcolor="#fce4ec", color="#d81b60"]
        VEGF       [label="VEGF\n(angiogenesis\npannus)", fillcolor="#f8bbd0", color="#d81b60"]
        SP_CGRP    [label="Substance P / CGRP\n(nociceptive\nneuropeptides)", fillcolor="#fce4ec", color="#d81b60"]
    }

    // ===== CLUSTER 7: SYNOVIAL JOINT & CARTILAGE PATHOLOGY =====
    subgraph cluster_joint {
        label="Synovial Joint & Cartilage Pathology"
        style="filled,rounded" color="#37474f" fillcolor="#eceff1" fontcolor="#263238" fontsize=13 fontname="Helvetica-Bold"

        Synoviocyte [label="Synoviocyte\nActivation\n(FLS/MLS)", fillcolor="#b0bec5", color="#546e7a"]
        Pannus      [label="Pannus Formation\n(inflammatory\ngranulation)", fillcolor="#90a4ae", color="#546e7a"]
        JointEff    [label="Joint Effusion\n(synovial fluid\nvolume↑)", fillcolor="#cfd8dc", color="#546e7a"]
        WBC_SF      [label="SF WBC Count\n(>50,000/µL\nacute attack)", fillcolor="#78909c", color="#37474f", fontcolor="white"]
        CartDamage  [label="Cartilage Damage\n(collagen/aggrecan\nloss)", fillcolor="#607d8b", color="#37474f", fontcolor="white"]
        CartInteg   [label="Cartilage Integrity\n(CI%, 0-100%)", fillcolor="#b0bec5", color="#546e7a"]
        CollagenII  [label="Collagen II\nDegradation\n(COL2A1↓)", fillcolor="#90a4ae", color="#546e7a"]
        AggrecanLoss[label="Aggrecan Loss\n(ACAN cleavage)", fillcolor="#b0bec5", color="#546e7a"]
        Chondrocyte [label="Chondrocyte\nApoptosis\n(Caspase-3↑)", fillcolor="#78909c", color="#37474f", fontcolor="white"]
        SubchBone   [label="Subchondral Bone\nSclerosis /\nRemodeling", fillcolor="#90a4ae", color="#546e7a"]
        Osteophyte  [label="Osteophyte\nFormation", fillcolor="#cfd8dc", color="#546e7a"]
        JointSpace  [label="Joint Space\nNarrowing\n(radiographic)", fillcolor="#b0bec5", color="#546e7a"]
    }

    // ===== CLUSTER 8: CLINICAL ENDPOINTS =====
    subgraph cluster_clinical {
        label="Clinical Endpoints & Outcomes"
        style="filled,rounded" color="#4527a0" fillcolor="#ede7f6" fontcolor="#311b92" fontsize=13 fontname="Helvetica-Bold"

        PainVAS    [label="Pain VAS\n(0-10 scale)", fillcolor="#b39ddb", color="#4527a0"]
        SwellingScore [label="Joint Swelling\nScore", fillcolor="#9575cd", color="#4527a0"]
        AttackFreq [label="Attack Frequency\n(episodes/year)", fillcolor="#7e57c2", color="#4527a0", fontcolor="white"]
        AttackDur  [label="Attack Duration\n(days to resolution)", fillcolor="#9575cd", color="#4527a0"]
        CRP_lab    [label="CRP\n(biomarker)", fillcolor="#b39ddb", color="#4527a0"]
        ESR_lab    [label="ESR\n(mm/hr)", fillcolor="#ce93d8", color="#4527a0"]
        SF_WBClab  [label="SF WBC\n(diagnostic)", fillcolor="#b39ddb", color="#4527a0"]
        Chondrocalc_score [label="Chondrocalcinosis\nScore (XR/US)", fillcolor="#9575cd", color="#4527a0"]
        CrystIdent [label="Crystal\nIdentification\n(compensated\npolarized light)", fillcolor="#7e57c2", color="#4527a0", fontcolor="white"]
        OA_progress[label="OA Progression\n(JSN / KL grade)", fillcolor="#b39ddb", color="#4527a0"]
        CumGlucoExp[label="Cumulative\nGlucocorticoid\nExposure", fillcolor="#ce93d8", color="#4527a0"]
        QoL        [label="Quality of Life\n(SF-36/HAQ)", fillcolor="#e8daef", color="#4527a0"]
    }

    // ===== CLUSTER 9: DRUG PK/PD — COLCHICINE & NSAIDs =====
    subgraph cluster_drug1 {
        label="Drug PK/PD: Colchicine & NSAIDs"
        style="filled,rounded" color="#00695c" fillcolor="#e0f2f1" fontcolor="#004d40" fontsize=13 fontname="Helvetica-Bold"

        Colch_dose  [label="Colchicine\n0.5-1.2mg PO\n(acute/prophylaxis)", fillcolor="#80cbc4", color="#00695c", shape=diamond]
        Colch_abs   [label="Colchicine\nAbsorption (F=0.45)\nCmax ~1-3 ng/mL", fillcolor="#4db6ac", color="#00695c"]
        Colch_Cp    [label="Colchicine\nPlasma Conc.\n(t½=26-31h)", fillcolor="#26a69a", color="#004d40", fontcolor="white"]
        Colch_tubulin [label="Tubulin\nPolymerization\nInhibition", fillcolor="#00897b", color="#004d40", fontcolor="white"]
        Colch_NLRP3 [label="NLRP3 Inhibition\n(via PYCARD/ASC\nspeck)", fillcolor="#00796b", color="#004d40", fontcolor="white"]
        Colch_neutmig [label="Neutrophil\nMigration ↓\n(crystal phagocytosis↓)", fillcolor="#4db6ac", color="#00695c"]
        Colch_IL1b  [label="IL-1β Secretion ↓\n(Colchicine effect)", fillcolor="#80cbc4", color="#00695c"]
        Indo_dose   [label="Indomethacin\n50mg TID PO", fillcolor="#a5d6a7", color="#388e3c", shape=diamond]
        Indo_Cp     [label="Indomethacin\nPlasma Conc.\n(t½=4.5h, F=0.98)", fillcolor="#66bb6a", color="#2e7d32"]
        COX12_inh   [label="COX-1/2\nInhibition\n(non-selective)", fillcolor="#43a047", color="#2e7d32", fontcolor="white"]
        PGE2_inhib  [label="PGE2 Synthesis ↓", fillcolor="#81c784", color="#2e7d32"]
        TXA2_inhib  [label="TXA2 ↓\n(antiplatelet)", fillcolor="#a5d6a7", color="#2e7d32"]
        Naprox_dose [label="Naproxen\n500mg BID PO", fillcolor="#c8e6c9", color="#388e3c", shape=diamond]
    }

    // ===== CLUSTER 10: DRUG PK/PD — GLUCOCORTICOIDS & BIOLOGICS =====
    subgraph cluster_drug2 {
        label="Drug PK/PD: Glucocorticoids & Biologics"
        style="filled,rounded" color="#1565c0" fillcolor="#e8eaf6" fontcolor="#0d47a1" fontsize=13 fontname="Helvetica-Bold"

        Pred_dose   [label="Prednisolone\n30-40mg/day PO\n(taper 7-10 days)", fillcolor="#9fa8da", color="#3949ab", shape=diamond]
        Pred_Cp     [label="Prednisolone\nPlasma Conc.\n(t½=2.5-4h)", fillcolor="#7986cb", color="#3949ab"]
        GR_occ      [label="GR Occupancy\n(transrepression\nNF-κB/AP-1)", fillcolor="#5c6bc0", color="#1a237e", fontcolor="white"]
        GR_genomic  [label="Genomic GR Effect\n(IκBα↑ / MKP-1↑)", fillcolor="#7986cb", color="#3949ab"]
        GR_inflam   [label="Inflammation ↓\n(TNF/IL-6/COX2↓)", fillcolor="#9fa8da", color="#3949ab"]
        IA_Pred     [label="Intra-articular\nTriamcinolone 40mg", fillcolor="#c5cae9", color="#3949ab", shape=diamond]
        Ana_dose    [label="Anakinra\n100mg/day SC", fillcolor="#80cbc4", color="#00838f", shape=diamond]
        Ana_Cp      [label="Anakinra Plasma\n(t½=4-6h SC)", fillcolor="#26c6da", color="#00838f"]
        IL1R_block  [label="IL-1R Blockade\n(competitive\nantagonism)", fillcolor="#00acc1", color="#006064", fontcolor="white"]
        Cana_dose   [label="Canakinumab\n150mg SC q3m", fillcolor="#80deea", color="#00838f", shape=diamond]
        Cana_Cp     [label="Canakinumab\nPlasma\n(t½=26 days)", fillcolor="#4dd0e1", color="#00838f"]
        IL1b_neutr  [label="IL-1β Neutralization\n(anti-IL-1β mAb)", fillcolor="#26c6da", color="#00838f"]
        HCQ_dose    [label="Hydroxychloroquine\n200-400mg/day\n(chronic prophylaxis)", fillcolor="#b0bec5", color="#546e7a", shape=diamond]
        HCQ_lyso    [label="Lysosomal\npH↑ (HCQ)\n→ NLRP3↓", fillcolor="#90a4ae", color="#546e7a"]
        MTX_dose    [label="Methotrexate\n7.5-15mg/wk\n(chronic prophylaxis)", fillcolor="#b0bec5", color="#546e7a", shape=diamond]
        MTX_aden    [label="Adenosine ↑\n(MTX via ATIC)\n→ anti-inflammatory", fillcolor="#cfd8dc", color="#546e7a"]
    }

    // ===== CLUSTER 11: PPi TRANSPORT GENETICS =====
    subgraph cluster_genetics {
        label="PPi Transport Genetics & Metabolism"
        style="filled,rounded" color="#6d4c41" fillcolor="#efebe9" fontcolor="#3e2723" fontsize=13 fontname="Helvetica-Bold"

        ANKH_mut   [label="ANKH Mutation\n(GOF → PPi efflux↑\nFamilial CPPD)", fillcolor="#bcaaa4", color="#795548"]
        ENPP1_over [label="ENPP1\nOverexpression\n(PPi generation↑)", fillcolor="#a1887f", color="#6d4c41"]
        TNAP_low   [label="TNAP / ALPL↓\n(PPi clearance↓\ne.g. hemochromatosis)", fillcolor="#8d6e63", color="#6d4c41", fontcolor="white"]
        CTGF_TGFb  [label="CTGF / TGF-β\n(ENPP1↑ in\nchondrocytes)", fillcolor="#bcaaa4", color="#795548"]
        IGF1       [label="IGF-1\n(ENPP1↑ signaling)", fillcolor="#d7ccc8", color="#795548"]
        TNAP_Mg    [label="Mg²⁺ Effect\non TNAP\n(cofactor)", fillcolor="#c8b9b9", color="#795548"]
        HIF1a      [label="HIF-1α\n(hypoxia → ENPP1↑\nin OA cartilage)", fillcolor="#bcaaa4", color="#795548"]
    }

    // ===== CLUSTER 12: SYSTEMS FEEDBACK & RESOLUTION =====
    subgraph cluster_resolution {
        label="Inflammatory Resolution & Chronic Phase"
        style="filled,rounded" color="#558b2f" fillcolor="#f1f8e9" fontcolor="#33691e" fontsize=13 fontname="Helvetica-Bold"

        LipoxinA4  [label="Lipoxin A4\n(pro-resolving\nmediator)", fillcolor="#aed581", color="#558b2f"]
        RvD1       [label="Resolvin D1\n(SPM, neutrophil\napoptosis↑)", fillcolor="#c5e1a5", color="#558b2f"]
        Treg       [label="Treg Cells\n(IL-10 / TGF-β\nanti-inflammatory)", fillcolor="#dce775", color="#689f38"]
        IL10       [label="IL-10\n(anti-inflammatory\ncytokine)", fillcolor="#aed581", color="#558b2f"]
        MRC1       [label="M2 Macrophage\n(MRC1+, phagocytosis\nof debris)", fillcolor="#8bc34a", color="#558b2f"]
        Efferocyt  [label="Efferocytosis\n(apoptotic neutrophil\nclearance)", fillcolor="#c5e1a5", color="#558b2f"]
        AttackRes  [label="Attack Resolution\n(typically 7-10 days\nuntreated)", fillcolor="#dcedc8", color="#558b2f"]
        ChronInflam[label="Chronic Low-Grade\nInflammation\n(between attacks)", fillcolor="#f0f4c3", color="#689f38"]
        ChronCPPD  [label="Chronic CPPD\nArthropathy\n(OA-like progression)", fillcolor="#d4e157", color="#9e9d24"]
    }

    // ===== INTER-CLUSTER EDGES =====

    // Risk factors → PPi metabolism
    Age        -> ENPP1_over [label="age↑ ENPP1", color="#8e44ad", style=dashed]
    PHPT       -> Ca_art     [label="Ca²⁺↑", color="#8e44ad"]
    Hypomag    -> Mg_inh     [label="Mg²⁺↓", color="#8e44ad"]
    Hypomag    -> TNAP_Mg    [label="cofactor↓", color="#8e44ad", style=dashed]
    Hemochr    -> TNAP_low   [label="Fe²⁺ inhibits\nTNAP", color="#8e44ad"]
    WilsonDis  -> TNAP_low   [label="Cu²⁺ inhibits\nTNAP", color="#8e44ad"]
    Hypophosph -> TNAP_low   [label="ALPL loss\nof function", color="#8e44ad"]
    FamilCPPD  -> ANKH_mut   [label="GOF mutation", color="#8e44ad"]
    OA_comorbid-> HIF1a      [label="hypoxia in OA", color="#8e44ad", style=dashed]
    Trauma     -> CrystShed  [label="mechanical\ntrigger", color="#1565c0"]
    NutrDef    -> Mg_inh     [label="dietary Mg↓", color="#8e44ad", style=dashed]

    // PPi metabolism → crystal formation
    ATP_hydrol -> PPi_ICF   [label="PPi production", color="#8e44ad"]
    ENPP1      -> PPi_ECF   [label="extracellular\nPPi", color="#8e44ad"]
    ANKH_ch    -> PPi_ECF   [label="PPi efflux", color="#8e44ad"]
    PPi_ICF    -> ANKH_ch   [label="substrate", color="#8e44ad"]
    PPi_ECF    -> TNAP      [label="TNAP substrate", color="#8e44ad", style=dashed]
    TNAP       -> Pi_pool   [label="PPi→2Pi\nhydrolysis", color="#8e44ad"]
    NT5E       -> Pi_pool   [label="AMP→Ado+Pi", color="#8e44ad", style=dashed]
    PPi_ECF    -> NucCPPD   [label="pericellular\nPPi + Ca²⁺", color="#1565c0"]
    Ca_art     -> NucCPPD   [label="Ca²⁺↑", color="#1565c0"]
    Mg_inh     -> NucCPPD   [label="↓ nucleation", color="#558b2f", style=dashed, arrowhead=tee]

    // Genetics → PPi
    ANKH_mut   -> ANKH_ch   [label="GOF →\nefflux↑", color="#6d4c41"]
    ENPP1_over -> ENPP1     [color="#6d4c41"]
    TNAP_low   -> TNAP      [arrowhead=tee, color="#6d4c41", style=dashed]
    CTGF_TGFb  -> ENPP1_over [color="#6d4c41"]
    IGF1       -> ENPP1_over [color="#6d4c41"]
    TNAP_Mg    -> TNAP      [color="#6d4c41", style=dashed]
    HIF1a      -> ENPP1_over [color="#6d4c41"]

    // Crystal dynamics
    NucCPPD    -> CrystGrow  [label="seed → growth", color="#1565c0"]
    CrystGrow  -> CrystCart  [label="matrix\ndeposition", color="#1565c0"]
    CrystCart  -> Chondrocalc [label="radiographic\nvisibility", color="#1565c0"]
    CrystCart  -> CrystShed  [label="fibrocartilage\ndisruption", color="#1565c0"]
    CrystShed  -> CrystSF    [label="crystal release\ninto SF", color="#1565c0"]
    CrystSF    -> CrystCoat  [label="IgG/C3\nopsonization", color="#1565c0"]
    CrystCoat  -> FcgR       [label="opsonized\ncrystal", color="#e65100"]

    // Innate immune
    CrystSF    -> TLR2_4    [label="DAMP signal", color="#e65100"]
    CrystSF    -> MacroPhag [label="crystal contact", color="#e65100"]
    TLR2_4     -> NFkB      [label="MyD88/\nTRIF", color="#e65100"]
    FcgR       -> Phago     [label="phagocytosis", color="#e65100"]
    Phago      -> CathB     [label="lysosomal\nrupture", color="#e65100"]
    CathB      -> NLRP3_act [label="NLRP3\nactivation", color="#e65100"]
    NFkB       -> IL1b_pre  [label="Pro-IL-1β\nsynthesis", color="#e65100"]
    NFkB       -> COX2      [label="COX-2\ninduction", color="#d81b60"]
    NFkB       -> TNFa      [label="TNF-α\ntranscription", color="#d81b60"]
    NLRP3_act  -> Casp1     [color="#e65100"]
    Casp1      -> IL1b_mat  [label="Pro→mature\nIL-1β", color="#e65100"]
    Casp1      -> IL18      [label="IL-18\nmaturation", color="#e65100"]
    Casp1      -> Pyroptosis [color="#e65100"]
    IL1b_mat   -> NFkB      [label="IL-1R →\nNF-κB amplification", color="#e65100"]
    ROS_burst  -> NLRP3_act [label="K⁺ efflux /\nROS signal", color="#e65100"]
    MitoStress -> ROS_burst  [color="#e65100"]
    MacroPhag  -> ROS_burst  [color="#e65100"]
    MacroPhag  -> IL6        [label="macrophage\nIL-6", color="#d81b60"]
    MacroPhag  -> TNFa       [color="#d81b60"]
    MacroPhag  -> IL8_CXCL8  [color="#2e7d32"]
    MacroPhag  -> Complement  [color="#d81b60"]

    // Neutrophil recruitment
    IL1b_mat   -> IL8_CXCL8 [label="NF-κB→IL-8", color="#2e7d32"]
    TNFa       -> IL8_CXCL8 [color="#2e7d32"]
    Complement -> C5a        [label="C5 cleavage", color="#2e7d32"]
    LOX5       -> LTB4       [label="LTB4 synthesis", color="#2e7d32"]
    IL8_CXCL8  -> NeutRecruit [color="#2e7d32"]
    C5a        -> NeutRecruit [color="#2e7d32"]
    LTB4       -> NeutRecruit [color="#2e7d32"]
    NeutRecruit -> NeutActiv  [label="crystal contact", color="#2e7d32"]
    NeutActiv  -> MPO        [color="#2e7d32"]
    NeutActiv  -> NETs       [color="#2e7d32"]
    NeutActiv  -> NeutCrystLysis [color="#2e7d32"]
    NeutActiv  -> NLRP3_act  [label="neutrophil\nNLRP3", color="#e65100", style=dashed]
    NeutCrystLysis -> IL1b_mat [label="crystal release\nfrom neut", color="#e65100", style=dashed]
    NETs       -> NFkB       [label="NET-PAMPs\n→ signaling", color="#e65100", style=dashed]
    NeutRecruit -> IL1Ra_neut [label="self-limiting\nsignal", color="#d81b60", style=dashed]

    // Inflammatory mediators
    IL1b_mat   -> PainVAS   [label="nociception", color="#4527a0"]
    IL1b_mat   -> COX2      [label="COX-2\ninduction", color="#d81b60"]
    IL1b_mat   -> MMP1_3_13 [label="MMP\ninduction", color="#d81b60"]
    IL1b_mat   -> ADAMTS    [label="aggrecanase\ninduction", color="#d81b60"]
    IL6        -> CRP_lab   [label="hepatocyte\nAPP", color="#4527a0"]
    IL6        -> ESR_lab   [color="#4527a0"]
    TNFa       -> IL6       [color="#d81b60"]
    TNFa       -> COX2      [color="#d81b60"]
    TNFa       -> MMP1_3_13 [color="#d81b60"]
    COX2       -> PGE2      [color="#d81b60"]
    PGE2       -> PainVAS   [label="peripheral\nsensitization", color="#4527a0"]
    PGE2       -> JointEff  [label="vasodilation /\nedema", color="#37474f"]
    LOX5       -> LTB4      [color="#2e7d32"]
    SP_CGRP    -> PainVAS   [label="central/peripheral\nnociception", color="#4527a0"]
    MMP1_3_13  -> CartDamage [color="#37474f"]
    ADAMTS     -> AggrecanLoss [color="#37474f"]
    MPO        -> CartDamage  [label="oxidative\ndamage", color="#37474f"]
    VEGF       -> Pannus     [color="#37474f"]
    TGFb       -> Synoviocyte [color="#37474f"]

    // Joint pathology
    CrystSF    -> WBC_SF    [label="SF leukocytosis", color="#37474f"]
    IL8_CXCL8  -> WBC_SF   [color="#37474f"]
    NeutRecruit -> WBC_SF   [color="#37474f"]
    WBC_SF     -> SF_WBClab [color="#4527a0"]
    JointEff   -> SwellingScore [color="#4527a0"]
    Synoviocyte -> JointEff [color="#37474f"]
    CartDamage -> CartInteg  [arrowhead=tee, color="#37474f"]
    AggrecanLoss -> CartInteg [arrowhead=tee, color="#37474f"]
    CollagenII -> CartInteg  [arrowhead=tee, color="#37474f"]
    MMP1_3_13  -> CollagenII [arrowhead=tee, color="#37474f"]
    Chondrocyte -> CartInteg [arrowhead=tee, label="apoptosis\n→ CI↓", color="#37474f"]
    CrystCart  -> Chondrocyte [label="crystal\ncytotoxicity", color="#37474f"]
    CartInteg  -> JointSpace [arrowhead=tee, color="#37474f"]
    JointSpace -> OA_progress [color="#4527a0"]
    SubchBone  -> Osteophyte [color="#37474f"]
    CartDamage -> SubchBone  [color="#37474f"]

    // Clinical endpoints
    PainVAS    -> QoL        [arrowhead=tee, color="#4527a0"]
    SwellingScore -> QoL     [arrowhead=tee, color="#4527a0"]
    AttackFreq -> QoL        [arrowhead=tee, color="#4527a0"]
    OA_progress -> QoL       [arrowhead=tee, color="#4527a0"]
    CrystSF    -> CrystIdent [color="#4527a0"]
    CrystCart  -> Chondrocalc_score [color="#4527a0"]
    CRP_lab    -> AttackFreq [label="inflammatory\nburden marker", color="#4527a0", style=dashed]
    CartInteg  -> OA_progress [arrowhead=tee, color="#4527a0"]

    // Resolution
    Efferocyt  -> LipoxinA4  [label="SPM production", color="#558b2f"]
    LipoxinA4  -> NeutRecruit [arrowhead=tee, label="stop signal", color="#558b2f"]
    RvD1       -> NeutRecruit [arrowhead=tee, color="#558b2f"]
    IL10       -> NFkB        [arrowhead=tee, color="#558b2f"]
    IL10       -> MMP1_3_13   [arrowhead=tee, color="#558b2f"]
    MRC1       -> Efferocyt   [color="#558b2f"]
    Treg       -> IL10        [color="#558b2f"]
    IL1Ra      -> IL1b_mat    [arrowhead=tee, label="IL-1R\ncompetition", color="#d81b60", style=dashed]
    IL1Ra_neut -> IL1b_mat    [arrowhead=tee, color="#d81b60", style=dashed]
    AttackRes  -> ChronInflam [label="residual\ninflammation", color="#558b2f"]
    ChronInflam -> ChronCPPD  [label="OA-like\nprogression", color="#558b2f"]
    ChronCPPD  -> CrystCart   [label="↑ crystal\nburden cycle", color="#1565c0", style=dashed]
    Pannus     -> CartDamage  [color="#37474f"]

    // Drug effects — Colchicine
    Colch_dose -> Colch_abs  [color="#00695c"]
    Colch_abs  -> Colch_Cp   [color="#00695c"]
    Colch_Cp   -> Colch_tubulin [color="#00695c"]
    Colch_Cp   -> Colch_NLRP3  [color="#00695c"]
    Colch_tubulin -> NeutRecruit [arrowhead=tee, label="migration↓", color="#00695c"]
    Colch_tubulin -> NeutActiv  [arrowhead=tee, color="#00695c"]
    Colch_NLRP3   -> NLRP3_act [arrowhead=tee, color="#00695c"]
    Colch_NLRP3   -> IL1b_mat  [arrowhead=tee, color="#00695c"]
    Colch_IL1b    -> IL1b_mat  [arrowhead=tee, color="#00695c"]
    Colch_NLRP3   -> Colch_IL1b [color="#00695c"]

    // Drug effects — NSAIDs
    Indo_dose  -> Indo_Cp    [color="#388e3c"]
    Naprox_dose -> Indo_Cp   [label="naproxen PK\n(separate)", color="#388e3c", style=dashed]
    Indo_Cp    -> COX12_inh  [color="#388e3c"]
    COX12_inh  -> COX2       [arrowhead=tee, color="#388e3c"]
    COX12_inh  -> PGE2_inhib [color="#388e3c"]
    COX12_inh  -> TXA2_inhib [color="#388e3c"]
    PGE2_inhib -> PGE2       [arrowhead=tee, color="#388e3c"]
    PGE2_inhib -> PainVAS    [arrowhead=tee, label="analgesia", color="#388e3c"]

    // Drug effects — Glucocorticoids
    Pred_dose  -> Pred_Cp    [color="#1565c0"]
    IA_Pred    -> GR_occ     [label="intra-articular\nhigh local conc.", color="#1565c0", style=dashed]
    Pred_Cp    -> GR_occ     [color="#1565c0"]
    GR_occ     -> GR_genomic [color="#1565c0"]
    GR_genomic -> NFkB       [arrowhead=tee, label="IκBα↑", color="#1565c0"]
    GR_genomic -> COX2       [arrowhead=tee, color="#1565c0"]
    GR_genomic -> IL6        [arrowhead=tee, color="#1565c0"]
    GR_inflam  -> TNFa       [arrowhead=tee, color="#1565c0"]
    GR_genomic -> GR_inflam  [color="#1565c0"]
    CumGlucoExp -> OA_progress [label="steroid-induced\nbone loss", color="#4527a0", style=dashed]
    Pred_Cp    -> CumGlucoExp [color="#1565c0", style=dashed]

    // Drug effects — Biologics
    Ana_dose   -> Ana_Cp     [color="#00838f"]
    Ana_Cp     -> IL1R_block [color="#00838f"]
    IL1R_block -> IL1b_mat   [arrowhead=tee, label="IL-1R\nblockade", color="#00838f"]
    Cana_dose  -> Cana_Cp    [color="#00838f"]
    Cana_Cp    -> IL1b_neutr [color="#00838f"]
    IL1b_neutr -> IL1b_mat   [arrowhead=tee, label="IL-1β\nneutralization", color="#00838f"]
    HCQ_dose   -> HCQ_lyso   [color="#546e7a"]
    HCQ_lyso   -> NLRP3_act  [arrowhead=tee, label="lysosomal\npH↑", color="#546e7a"]
    HCQ_lyso   -> CathB      [arrowhead=tee, color="#546e7a"]
    MTX_dose   -> MTX_aden   [color="#546e7a"]
    MTX_aden   -> NFkB       [arrowhead=tee, label="adenosine\nA2A/A3R", color="#546e7a"]
    MTX_aden   -> IL1b_mat   [arrowhead=tee, color="#546e7a"]
    MTX_aden   -> IL6        [arrowhead=tee, color="#546e7a"]
}
