digraph Alport_QSP {
  rankdir=LR;
  compound=true;
  fontname="Helvetica";
  fontsize=22;
  labelloc="t";
  label="Alport Syndrome (AS) — Type IV Collagen Nephropathy QSP Mechanistic Map\nCOL4A3/A4/A5 Genotype-Dependent GBM Failure · Podocyte Injury · RAAS/Fibrosis · Cochlear & Ocular Basement Membrane Defects · RAASi/Sparsentan/Bardoxolone/Lademirsen/SGLT2i PK/PD";
  node [style=filled, fontname="Helvetica", fontsize=11, shape=box, margin="0.12,0.06"];
  edge [fontname="Helvetica", fontsize=9, color="#555555"];

  /* ============ CLUSTER 1: GENETIC ETIOLOGY ============ */
  subgraph cluster_genetics {
    label="1. 유전적 병인 (Genetic Etiology, COL4A3/A4/A5)";
    style=filled; color="#FBEEE6"; fontsize=13;
    G1  [label="COL4A5 mutation\n(Xq22.3, X-linked,\n~80% of AS)", fillcolor="#F5B7B1"];
    G2  [label="COL4A3 mutation\n(2q36.3,\nautosomal)", fillcolor="#F1948A"];
    G3  [label="COL4A4 mutation\n(2q36.3,\nautosomal)", fillcolor="#F1948A"];
    G4  [label="XLAS hemizygous male\n(most severe,\nESRD by 20s-30s)", fillcolor="#EC7063"];
    G5  [label="XLAS heterozygous female\n(mosaic, X-inactivation-\nvariable severity)", fillcolor="#E74C3C", fontcolor=white];
    G6  [label="Autosomal recessive\nbiallelic COL4A3/A4\n(ARAS, severe both sexes)", fillcolor="#CB4335", fontcolor=white];
    G7  [label="Autosomal dominant\nheterozygous COL4A3/A4\n(ADAS, thin-BM-nephropathy\nspectrum, mild)", fillcolor="#D7BDE2"];
    G8  [label="Digenic trans-heterozygous\nCOL4A3+COL4A4\n(modifier phenotype)", fillcolor="#D2B4DE"];
    G9  [label="Truncating vs missense/\nglycine-substitution\nvariant class", fillcolor="#C39BD3"];
    G10 [label="Family pedigree\nscreening / cascade\ntesting", fillcolor="#AF7AC5", fontcolor=white];
    G11 [label="Genetic counseling &\nprenatal/preimplantation\ndiagnosis", fillcolor="#9B59B6", fontcolor=white];
    G1 -> G4; G1 -> G5; G2 -> G6; G3 -> G6; G2 -> G7; G3 -> G7; G2 -> G8 [style=dashed]; G3 -> G8 [style=dashed];
    G9 -> G4 [style=dashed]; G9 -> G6 [style=dashed]; G10 -> G11;
  }

  /* ============ CLUSTER 2: MOLECULAR COLLAGEN IV NETWORK ============ */
  subgraph cluster_molecular {
    label="2. 분자병태생리: IV형 콜라겐 네트워크 (Molecular Collagen IV Network)";
    style=filled; color="#EBF5FB"; fontsize=13;
    M1  [label="Normal α3α4α5(IV)\nheterotrimer NC1\ntrimerization", fillcolor="#AED6F1"];
    M2  [label="Defective α-chain\nfolding / triple-helix\ninstability", fillcolor="#85C1E9"];
    M3  [label="ER retention &\nERAD/proteasomal\ndegradation", fillcolor="#5DADE2"];
    M4  [label="Failure to replace\nfetal α1α1α2(IV)\nnetwork", fillcolor="#3498DB", fontcolor=white];
    M5  [label="Absent/reduced\nα3α4α5(IV) network\nin mature GBM", fillcolor="#2E86C1", fontcolor=white];
    M6  [label="Compensatory but\nmechanically inferior\nα1α2(IV) network", fillcolor="#21618C", fontcolor=white];
    M7  [label="Loss of NC1\nsulfilimine crosslinking", fillcolor="#1B4F72", fontcolor=white];
    M8  [label="Reduced GBM tensile\nstrength / mechanical\nresilience", fillcolor="#154360", fontcolor=white];
    M9  [label="Alport/Goodpasture\nepitope conformational\nchange", fillcolor="#A9CCE3"];
    M10 [label="Lens capsule basement\nmembrane assembly\ndefect", fillcolor="#7FB3D5"];
    M11 [label="Cochlear basement\nmembrane assembly\ndefect", fillcolor="#5499C7"];
    M12 [label="Post-transplant alloimmune\nanti-GBM risk (donor normal\ncollagen as neoantigen)", fillcolor="#2874A6", fontcolor=white];
    G1 -> M2; G2 -> M2; G3 -> M2; G6 -> M2; G7 -> M2 [style=dashed];
    M2 -> M3; M3 -> M5; M4 -> M6; M5 -> M6; M5 -> M7; M7 -> M8; M6 -> M8;
    M5 -> M9; M9 -> M12 [style=dashed]; M5 -> M10; M5 -> M11;
  }

  /* ============ CLUSTER 3: GBM STRUCTURAL PROGRESSION ============ */
  subgraph cluster_gbm {
    label="3. 사구체 기저막 구조 진행 (GBM Structural Progression)";
    style=filled; color="#EAFAF1"; fontsize=13;
    B1  [label="Thin GBM\n(early lamina densa\nthinning)", fillcolor="#A9DFBF"];
    B2  [label="GBM lamellation\n('basket-weave'\nsplitting)", fillcolor="#82E0AA"];
    B3  [label="Irregular alternating\nthickening/thinning", fillcolor="#58D68D"];
    B4  [label="Progressive GBM\nsplitting propagation", fillcolor="#2ECC71", fontcolor=white];
    B5  [label="Loss of GBM negative-\ncharge barrier (heparan\nsulfate proteoglycan)", fillcolor="#28B463", fontcolor=white];
    B6  [label="Mechanical GBM\nmicrotears", fillcolor="#1E8449", fontcolor=white];
    B7  [label="Segmental\nglomerulosclerosis foci", fillcolor="#145A32", fontcolor=white];
    B8  [label="Global\nglomerulosclerosis\n(advanced)", fillcolor="#0B5345", fontcolor=white];
    B9  [label="Bowman's capsule\nadhesion / crescent\nformation (rare)", fillcolor="#117864", fontcolor=white];
    B10 [label="Nephron loss\n(sclerosed glomeruli\ncount)", fillcolor="#0E6655", fontcolor=white];
    M8 -> B1; M6 -> B1; B1 -> B2; B2 -> B3; B3 -> B4; B4 -> B6; B4 -> B5;
    B6 -> B7; B7 -> B8; B8 -> B9 [style=dashed]; B8 -> B10;
  }

  /* ============ CLUSTER 4: PODOCYTE INJURY & PROTEINURIA ============ */
  subgraph cluster_podocyte {
    label="4. 족세포 손상 및 단백뇨 (Podocyte Injury & Proteinuria)";
    style=filled; color="#FEF9E7"; fontsize=13;
    P1  [label="Mechanical stress\ntransmission to foot\nprocesses", fillcolor="#FAD7A0"];
    P2  [label="Podocyte foot process\neffacement", fillcolor="#F8C471"];
    P3  [label="Slit diaphragm protein\ndisruption (nephrin/\npodocin)", fillcolor="#F5B041"];
    P4  [label="Podocyte actin\ncytoskeletal\nreorganization", fillcolor="#F39C12"];
    P5  [label="Podocyte apoptosis\n/ detachment", fillcolor="#D68910"];
    P6  [label="Podocyte depletion\n(non-regenerative)", fillcolor="#B9770E"];
    P7  [label="Albumin/protein leak\nacross GBM", fillcolor="#9C640C"];
    P8  [label="Microalbuminuria\n(early)", fillcolor="#7E5109"];
    P9  [label="Overt proteinuria /\nrising UACR", fillcolor="#6E2C00"];
    P10 [label="Nephrotic-range\nproteinuria (advanced)", fillcolor="#4A2005", fontcolor=white];
    P11 [label="Persistent microscopic\n± episodic gross\nhematuria", fillcolor="#873600", fontcolor=white];
    B6 -> P1; B1 -> P1; P1 -> P2; P2 -> P3; P3 -> P4; P4 -> P5; P5 -> P6; P6 -> B10 [style=dashed];
    B5 -> P7; P2 -> P7; P7 -> P8; P8 -> P9; P9 -> P10; B6 -> P11;
  }

  /* ============ CLUSTER 5: GLOMERULAR HEMODYNAMICS & RAAS ============ */
  subgraph cluster_raas {
    label="5. 사구체 혈류역학 및 RAAS (Glomerular Hemodynamics & RAAS)";
    style=filled; color="#F4ECF7"; fontsize=13;
    H1  [label="Compensatory\nhyperfiltration\n(nephron loss-driven)", fillcolor="#D7BDE2"];
    H2  [label="Single-nephron\nGFR increase", fillcolor="#C39BD3"];
    H3  [label="Glomerular capillary\nhypertension", fillcolor="#A569BD"];
    H4  [label="Afferent dilation /\nefferent constriction\n(Ang II-mediated)", fillcolor="#8E44AD", fontcolor=white];
    H5  [label="RAAS activation", fillcolor="#7D3C98", fontcolor=white];
    H6  [label="Angiotensin II\ngeneration", fillcolor="#6C3483", fontcolor=white];
    H7  [label="AT1 receptor signaling\n(podocyte/mesangial/\ntubular)", fillcolor="#5B2C6F", fontcolor=white];
    H8  [label="Aldosterone-mediated\nfibrosis potentiation", fillcolor="#4A235A", fontcolor=white];
    H9  [label="Endothelin-1 (ET-1)\nupregulation", fillcolor="#76448A", fontcolor=white];
    H10 [label="ETA receptor-mediated\nvasoconstriction &\nmesangial proliferation", fillcolor="#633974", fontcolor=white];
    H11 [label="Intraglomerular pressure\nvicious cycle (feedback)", fillcolor="#512E5F", fontcolor=white];
    H12 [label="Secondary systemic\nhypertension", fillcolor="#6C3483", fontcolor=white];
    B10 -> H1; P6 -> H1 [style=dashed]; H1 -> H2; H2 -> H3; H3 -> H4; H4 -> H5; H5 -> H6; H6 -> H7;
    H5 -> H8 [style=dashed]; H9 -> H10; H3 -> H11; H11 -> B6 [style=dashed, color="#CB4335"]; H11 -> P1 [style=dashed, color="#CB4335"];
    H6 -> H12; H3 -> P1;
  }

  /* ============ CLUSTER 6: FIBROTIC CASCADE ============ */
  subgraph cluster_fibrosis {
    label="6. 섬유화 캐스케이드 (Fibrotic Cascade)";
    style=filled; color="#FDEDEC"; fontsize=13;
    F1  [label="Mesangial cell\nactivation", fillcolor="#F5B7B1"];
    F2  [label="Mesangial matrix\nexpansion", fillcolor="#F1948A"];
    F3  [label="TGF-β1\nupregulation", fillcolor="#EC7063"];
    F4  [label="CTGF (CCN2)\ninduction", fillcolor="#E74C3C", fontcolor=white];
    F5  [label="Myofibroblast\ntransdifferentiation\n(EMT/EndMT)", fillcolor="#CB4335", fontcolor=white];
    F6  [label="Tubular epithelial\ncell injury\n(proteinuria toxicity)", fillcolor="#B03A2E", fontcolor=white];
    F7  [label="Interstitial fibroblast\nproliferation", fillcolor="#943126", fontcolor=white];
    F8  [label="Interstitial collagen\nI/III deposition", fillcolor="#78281F", fontcolor=white];
    F9  [label="Tubular atrophy", fillcolor="#641E16", fontcolor=white];
    F10 [label="Peritubular capillary\nrarefaction", fillcolor="#512E1A", fontcolor=white];
    F11 [label="Interstitial fibrosis &\ntubular atrophy\n(IFTA composite)", fillcolor="#3B1A0F", fontcolor=white];
    F12 [label="miR-21 upregulation\n(pro-fibrotic amplifier)", fillcolor="#943126", fontcolor=white];
    H7 -> F1; H10 -> F1; F1 -> F2; H7 -> F3; H10 -> F3; F3 -> F4; F12 -> F4;
    P9 -> F6; F3 -> F6; F6 -> F5; F3 -> F5; F5 -> F7; F7 -> F8; F8 -> F9; F6 -> F9;
    F6 -> F10; F9 -> F11; F10 -> F11; F2 -> B7 [style=dashed]; F11 -> B10 [style=dashed, color="#CB4335"];
  }

  /* ============ CLUSTER 7: INFLAMMATORY AMPLIFICATION ============ */
  subgraph cluster_inflam {
    label="7. 염증 증폭 (Inflammatory Amplification)";
    style=filled; color="#EAF2F8"; fontsize=13;
    I1 [label="Macrophage infiltration\n(glomerular/interstitial)", fillcolor="#AED6F1"];
    I2 [label="M1 pro-inflammatory\npolarization", fillcolor="#7FB3D5"];
    I3 [label="M2 reparative/\nprofibrotic polarization\n(late)", fillcolor="#5499C7"];
    I4 [label="Complement activation\n(alternative pathway,\nC3 deposition)", fillcolor="#2E86C1", fontcolor=white];
    I5 [label="NLRP3 inflammasome\nactivation (tubular)", fillcolor="#21618C", fontcolor=white];
    I6 [label="MCP-1/CCL2\nchemokine gradient", fillcolor="#1B4F72", fontcolor=white];
    I7 [label="CD4/CD8 T-cell\ninfiltration (minor)", fillcolor="#154360", fontcolor=white];
    I8 [label="Reactive oxygen\nspecies (ROS)\namplification", fillcolor="#0B4F6C", fontcolor=white];
    P9 -> I6; B7 -> I4 [style=dashed]; I6 -> I1; I1 -> I2; I1 -> I3 [style=dashed]; I2 -> F3;
    F6 -> I5; I5 -> F3; I2 -> I7 [style=dashed]; F6 -> I8; I8 -> F6; I8 -> P5;
  }

  /* ============ CLUSTER 8: COCHLEAR EXTRARENAL MANIFESTATION ============ */
  subgraph cluster_cochlea {
    label="8. 이신장외 병변 — 와우 (Cochlear Manifestations)";
    style=filled; color="#E8F8F5"; fontsize=13;
    C1 [label="Cochlear basement\nmembrane collagen IV\ndefect (basilar/spiral)", fillcolor="#A3E4D7"];
    C2 [label="Stria vascularis\nstructural instability", fillcolor="#76D7C4"];
    C3 [label="Organ of Corti hair\ncell vulnerability", fillcolor="#48C9B0"];
    C4 [label="Progressive high-\nfrequency sensorineural\nhearing loss", fillcolor="#17A589", fontcolor=white];
    C5 [label="Audiometric threshold\nshift (dB HL) tracking", fillcolor="#148F77", fontcolor=white];
    C6 [label="Speech-frequency\ninvolvement\n(advanced)", fillcolor="#117A65", fontcolor=white];
    C7 [label="Vestibular\ninvolvement (rare)", fillcolor="#0E6251", fontcolor=white];
    M11 -> C1; C1 -> C2; C2 -> C3; C3 -> C4; C4 -> C5; C5 -> C6; C2 -> C7 [style=dashed];
  }

  /* ============ CLUSTER 9: OCULAR EXTRARENAL MANIFESTATION ============ */
  subgraph cluster_ocular {
    label="9. 이신장외 병변 — 안구 (Ocular Manifestations)";
    style=filled; color="#FEF5E7"; fontsize=13;
    O1 [label="Anterior lens capsule\ncollagen IV defect", fillcolor="#FAE5D3"];
    O2 [label="Anterior lenticonus\n(progressive lens\nprotrusion)", fillcolor="#F8D7A0"];
    O3 [label="Lens capsule\nmicroruptures\n('oil-droplet' reflex)", fillcolor="#F5CBA7"];
    O4 [label="Perimacular dot-and-\nfleck retinopathy", fillcolor="#EDBB99"];
    O5 [label="Posterior polymorphous\ncorneal dystrophy\n(rare)", fillcolor="#DC7633"];
    O6 [label="Recurrent corneal\nerosion syndrome", fillcolor="#CA6F1E"];
    O7 [label="Progressive refractive\nchange / cataract risk", fillcolor="#B9770E"];
    M10 -> O1; O1 -> O2; O1 -> O3 [style=dashed]; O1 -> O4; O1 -> O5 [style=dashed]; O5 -> O6 [style=dashed];
    O2 -> O7; O3 -> O7;
  }

  /* ============ CLUSTER 10: DRUG PHARMACOKINETICS ============ */
  subgraph cluster_pk {
    label="10. 약물 약동학 (Drug Pharmacokinetics)";
    style=filled; color="#EBEDEF"; fontsize=13;
    D1 [label="Ramipril oral\nabsorption (gut depot)", fillcolor="#D6DBDF"];
    D2 [label="Ramiprilat (active\nACEi metabolite),\ncentral compartment", fillcolor="#AEB6BF"];
    D3 [label="Losartan oral\nabsorption (gut depot)", fillcolor="#D6DBDF"];
    D4 [label="Losartan carboxylic acid\n(E-3174, active ARB\nmetabolite)", fillcolor="#AEB6BF"];
    D5 [label="Sparsentan oral\nabsorption & central\ncompartment", fillcolor="#85929E"];
    D6 [label="Bardoxolone methyl\noral absorption &\ncentral compartment", fillcolor="#717D7E"];
    D7 [label="Lademirsen (RG-012)\nSC depot, plasma &\nkidney-tissue distribution", fillcolor="#5D6D7E"];
    D8 [label="Dapagliflozin (SGLT2i)\noral absorption &\ncentral compartment", fillcolor="#4D5656"];
    D9 [label="Finerenone (nonsteroidal\nMRA) oral absorption\n& central compartment", fillcolor="#424949"];
    D1 -> D2; D3 -> D4;
  }

  /* ============ CLUSTER 11: DRUG PHARMACODYNAMICS / MOA ============ */
  subgraph cluster_pd {
    label="11. 약물 작용기전 (Drug Pharmacodynamics / MoA)";
    style=filled; color="#FDF2E9"; fontsize=13;
    X1 [label="ACE inhibition →\nreduced Ang II\ngeneration", fillcolor="#FAE5D3"];
    X2 [label="AT1 receptor\nblockade (ARB)", fillcolor="#F8D7A0"];
    X3 [label="Combined RAAS blockade\n→ reduced intraglomerular\npressure", fillcolor="#F5CBA7"];
    X4 [label="Sparsentan dual ETA/AT1\nblockade → additive\npressure & fibrosis ↓", fillcolor="#EDBB99"];
    X5 [label="Bardoxolone Nrf2/Keap1\nactivation → antioxidant/\nanti-inflammatory genes", fillcolor="#E59866"];
    X6 [label="Lademirsen anti-miR-21\n→ de-repression of\nfibrosis-suppressor genes", fillcolor="#DC7633"];
    X7 [label="SGLT2 inhibition →\ntubuloglomerular feedback\nrestoration", fillcolor="#CA6F1E"];
    X8 [label="Finerenone MR blockade\n→ reduced aldosterone-\nfibrosis potentiation", fillcolor="#B9770E"];
    D2 -> X1 [color="#2874A6"]; X1 -> H6 [arrowhead=tee, color="#2874A6"];
    D4 -> X2 [color="#2874A6"]; X2 -> H7 [arrowhead=tee, color="#2874A6"];
    X1 -> X3; X2 -> X3; X3 -> H3 [arrowhead=tee, color="#2874A6"]; X3 -> H11 [arrowhead=tee, color="#2874A6"];
    D5 -> X4 [color="#2874A6"]; X4 -> H7 [arrowhead=tee, color="#2874A6"]; X4 -> H10 [arrowhead=tee, color="#2874A6"]; X4 -> F3 [arrowhead=tee, color="#2874A6"];
    D6 -> X5 [color="#2874A6"]; X5 -> I8 [arrowhead=tee, color="#2874A6"]; X5 -> F3 [arrowhead=tee, color="#2874A6"]; X5 -> E1 [style=dashed, color="#CB4335"];
    D7 -> X6 [color="#2874A6"]; X6 -> F12 [arrowhead=tee, color="#2874A6"]; X6 -> F4 [arrowhead=tee, color="#2874A6"];
    D8 -> X7 [color="#2874A6"]; X7 -> H2 [arrowhead=tee, color="#2874A6"]; X7 -> H3 [arrowhead=tee, color="#2874A6"];
    D9 -> X8 [color="#2874A6"]; X8 -> H8 [arrowhead=tee, color="#2874A6"];
  }

  /* ============ CLUSTER 12: CLINICAL ENDPOINTS ============ */
  subgraph cluster_clin {
    label="12. 임상 엔드포인트 (Clinical Endpoints)";
    style=filled; color="#F4F6F6"; fontsize=13;
    E1  [label="eGFR trajectory\n(CKD-EPI)", fillcolor="#D5D8DC"];
    E2  [label="eGFR decline slope\n(mL/min/1.73m²/yr)", fillcolor="#BFC9CA"];
    E3  [label="UACR / 24h\nproteinuria", fillcolor="#AAB7B8"];
    E4  [label="Time to 40% eGFR\ndecline (composite\ntrial endpoint)", fillcolor="#909497"];
    E5  [label="ESRD / kidney\nfailure onset", fillcolor="#797D7F", fontcolor=white];
    E6  [label="Dialysis\ninitiation", fillcolor="#616A6B", fontcolor=white];
    E7  [label="Kidney\ntransplantation", fillcolor="#4D5656", fontcolor=white];
    E8  [label="Post-transplant\nanti-GBM alloimmune\nnephritis risk", fillcolor="#424949", fontcolor=white];
    E9  [label="Hearing threshold\nprogression (composite)", fillcolor="#909497"];
    E10 [label="Ocular staging\ncomposite", fillcolor="#909497"];
    E11 [label="Renal survival /\noverall survival hazard", fillcolor="#212F3C", fontcolor=white];
    B10 -> E1 [arrowhead=tee]; F11 -> E1 [arrowhead=tee]; E1 -> E2; P9 -> E3; P10 -> E3;
    E1 -> E4; E2 -> E4; E4 -> E5; E5 -> E6; E5 -> E7; E7 -> E8; M12 -> E8 [style=dashed];
    C5 -> E9; C6 -> E9; O2 -> E10; O4 -> E10; E5 -> E11; E1 -> E11;
  }
}
