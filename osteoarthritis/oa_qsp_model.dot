digraph OA_QSP {
    graph [
        rankdir=LR
        compound=true
        fontname="Helvetica"
        fontsize=12
        bgcolor="#FAFAFA"
        splines=curved
        nodesep=0.4
        ranksep=0.9
        label="Osteoarthritis QSP Mechanistic Map\nChondrocyte Biology · ECM Degradation · Inflammatory Cytokines · Subchondral Bone · Synovitis · Pain Signaling · Drug PK/PD"
        labelloc=t
        labeljust=c
        fontsize=14
    ]
    node [shape=box fontname="Helvetica" fontsize=8 style="rounded,filled" margin="0.08,0.04"]
    edge [fontname="Helvetica" fontsize=7 arrowsize=0.65]

    // ══════════════════════════════════════════════════════
    // CLUSTER 1: Risk Factors & Disease Initiation
    // ══════════════════════════════════════════════════════
    subgraph cluster_risk {
        label="1. Risk Factors & Initiation"
        style=filled fillcolor="#FFF9C4" fontsize=10 fontcolor="#5D4037"

        Age        [label="Age\n(>45 yr)" fillcolor="#FFF176"]
        BMI        [label="Obesity\n(BMI>30)" fillcolor="#FFF176"]
        FemSex     [label="Female Sex\n(Postmenopause)" fillcolor="#FFF176"]
        JointInj   [label="Prior\nJoint Injury" fillcolor="#FFE082"]
        GenRisk    [label="Genetic Risk\n(GDF5,ALDH1A2,\nMC4R SNPs)" fillcolor="#FFE082"]
        OccLoad    [label="Occupational\nLoading" fillcolor="#FFE082"]
        MechStress [label="Abnormal\nMechanical\nStress" fillcolor="#FFCC80"]
        OxStress   [label="Oxidative\nStress\n(ROS/RNS↑)" fillcolor="#FFAB91"]
        CellSenesc [label="Cellular\nSenescence\n(SASP)" fillcolor="#FFAB91"]
        KLGrade    [label="KL Grade\n(0→IV)" fillcolor="#FF8A65" fontcolor="white"]
        Estrogen   [label="Estrogen↓\n(protective loss)" fillcolor="#F48FB1"]
        Leptin     [label="Leptin/\nAdiponectin\n(adipokines)" fillcolor="#FFCC80"]
    }

    // ══════════════════════════════════════════════════════
    // CLUSTER 2: Chondrocyte Biology
    // ══════════════════════════════════════════════════════
    subgraph cluster_chondro {
        label="2. Chondrocyte Biology"
        style=filled fillcolor="#E8F5E9" fontsize=10 fontcolor="#1B5E20"

        Chondro       [label="Viable\nChondrocyte\nPool" fillcolor="#A5D6A7" shape=ellipse]
        ChondroProl   [label="Chondrocyte\nProliferation" fillcolor="#C8E6C9"]
        ChondroApopt  [label="Chondrocyte\nApoptosis\n(Cas-3/Cas-7)" fillcolor="#FFCDD2"]
        ChondroAutoph [label="Autophagy\n(Beclin-1/LC3)" fillcolor="#C8E6C9"]
        MitoDysf      [label="Mitochondrial\nDysfunction\n(ETC complex)" fillcolor="#FFCDD2"]
        NF_kB         [label="NF-κB\nActivation\n(p65/p50)" fillcolor="#FF8A65" fontcolor="white"]
        MAPK_p38      [label="p38 MAPK\n(stress kinase)" fillcolor="#FF7043" fontcolor="white"]
        MAPK_ERK      [label="ERK1/2 MAPK\n(survival/inflam)" fillcolor="#FF8A65"]
        Wnt_sig       [label="Wnt/β-catenin\nSignaling" fillcolor="#FFB74D"]
        HIF1a         [label="HIF-1α\n(O2 sensor)" fillcolor="#CE93D8"]
        mTORC1        [label="mTORC1\n(anabolic)" fillcolor="#80DEEA"]
        PI3K_Akt      [label="PI3K/Akt\n(survival)" fillcolor="#80DEEA"]
        p53_p21       [label="p53/p21\nSenescence\nArrest" fillcolor="#FFCDD2"]
        SIRT1         [label="SIRT1\nDeacetylase\n(anti-SASP)" fillcolor="#C8E6C9"]
        SOX9          [label="SOX-9\n(Chondrogenic TF)" fillcolor="#43A047" fontcolor="white"]
        RUNX2         [label="RUNX2\n(Hypertrophic TF)" fillcolor="#EF9A9A"]
    }

    // ══════════════════════════════════════════════════════
    // CLUSTER 3: Extracellular Matrix (Cartilage)
    // ══════════════════════════════════════════════════════
    subgraph cluster_ecm {
        label="3. Cartilage Extracellular Matrix"
        style=filled fillcolor="#E3F2FD" fontsize=10 fontcolor="#0D47A1"

        ColII       [label="Collagen\nType II\n(%normal)" fillcolor="#90CAF9" shape=ellipse]
        Aggrecan    [label="Aggrecan\n(%normal)" fillcolor="#90CAF9" shape=ellipse]
        Fibronectin [label="Fibronectin\nFragments (FN-f)" fillcolor="#EF9A9A"]
        HyalJoint   [label="Synovial\nHyaluronan\n(HA polymer)" fillcolor="#90CAF9"]
        Biglycan    [label="Biglycan /\nDecorin\n(SLRPs)" fillcolor="#BBDEFB"]
        Lubricin    [label="Lubricin\n(PRG4)\nBoundary lube" fillcolor="#BBDEFB"]
        COMP        [label="COMP\n(Cartilage OMP)" fillcolor="#FFF59D" shape=diamond]
        ECM_Loss    [label="ECM\nDegradation\n(Net loss)" fillcolor="#EF5350" fontcolor="white"]
        JSW         [label="Joint Space\nWidth (mm)" fillcolor="#FFF59D" shape=diamond]
        CartVol     [label="Cartilage\nVolume\n(MRI, mL)" fillcolor="#FFF59D" shape=diamond]
    }

    // ══════════════════════════════════════════════════════
    // CLUSTER 4: Inflammatory Cytokines & Mediators
    // ══════════════════════════════════════════════════════
    subgraph cluster_inflam {
        label="4. Inflammatory Cytokines & Mediators"
        style=filled fillcolor="#FCE4EC" fontsize=10 fontcolor="#880E4F"

        IL1b    [label="IL-1β\n(master catabolic)" fillcolor="#F48FB1" shape=ellipse]
        TNFa    [label="TNF-α" fillcolor="#F48FB1" shape=ellipse]
        IL6     [label="IL-6\n(JAK-STAT3)" fillcolor="#F06292" shape=ellipse]
        IL8     [label="IL-8\n(CXCL8)\nneutrophil attract" fillcolor="#F06292" shape=ellipse]
        IL17A   [label="IL-17A/F\n(Th17)" fillcolor="#E91E63" fontcolor="white" shape=ellipse]
        IL15    [label="IL-15\nT cell\nactivation" fillcolor="#F06292" shape=ellipse]
        LIF     [label="LIF/\nOncostatin-M\n(gp130)" fillcolor="#EC407A" fontcolor="white" shape=ellipse]
        HMGB1   [label="HMGB1\n(DAMP / RAGE)" fillcolor="#C62828" fontcolor="white" shape=ellipse]
        S100A8  [label="S100A8/A9\nAlarmin (TLR4)" fillcolor="#E53935" fontcolor="white" shape=ellipse]
        TGFb1   [label="TGF-β1\n(dual: fibrosis\n& anabolic)" fillcolor="#CE93D8" shape=ellipse]
        PGE2    [label="PGE2\n(prostaglandin E2)" fillcolor="#FF8A65" shape=ellipse]
        LTB4    [label="LTB4\n(leukotriene B4)\nneutrophil chemo" fillcolor="#FF7043" shape=ellipse]
        NO      [label="Nitric Oxide\n(iNOS-derived)" fillcolor="#FFCDD2" shape=ellipse]
        VEGF    [label="VEGF-A\n(angiogenesis\nsynovium)" fillcolor="#F48FB1" shape=ellipse]
    }

    // ══════════════════════════════════════════════════════
    // CLUSTER 5: Catabolic Proteases
    // ══════════════════════════════════════════════════════
    subgraph cluster_enzymes {
        label="5. Catabolic Proteases (MMPs / ADAMTSs)"
        style=filled fillcolor="#FBE9E7" fontsize=10 fontcolor="#BF360C"

        MMP1    [label="MMP-1\n(Collagenase-1)" fillcolor="#FFAB91"]
        MMP3    [label="MMP-3\n(Stromelysin-1)\nactivator" fillcolor="#FF7043" fontcolor="white"]
        MMP13   [label="MMP-13\n(Collagenase-3)\nKEY enzyme" fillcolor="#D84315" fontcolor="white"]
        MMP9    [label="MMP-9\n(Gelatinase-B)" fillcolor="#FFAB91"]
        MMP14   [label="MT1-MMP\n(MMP-14)\nmembrane-type" fillcolor="#FF5722" fontcolor="white"]
        ADAM17  [label="ADAM-17\n(TACE)\nTNF-α shedding" fillcolor="#FF8A65"]
        ADAMTS4 [label="ADAMTS-4\n(Aggrecanase-1)" fillcolor="#FF7043" fontcolor="white"]
        ADAMTS5 [label="ADAMTS-5\n(Aggrecanase-2)\nDOMINANT" fillcolor="#D84315" fontcolor="white"]
        CathK   [label="Cathepsin K/B/D\n(lysosomal)" fillcolor="#FFCCBC"]
        HTRA1   [label="HTRA1\nSerine protease\n(aggrecan)" fillcolor="#FFAB91"]
    }

    // ══════════════════════════════════════════════════════
    // CLUSTER 6: Anabolic & Protective Mediators
    // ══════════════════════════════════════════════════════
    subgraph cluster_anabolic {
        label="6. Anabolic & Protective Mediators"
        style=filled fillcolor="#E8EAF6" fontsize=10 fontcolor="#1A237E"

        IGF1    [label="IGF-1\n(anabolic growth)" fillcolor="#9FA8DA"]
        BMP7    [label="BMP-7\n(OP-1)\nanti-catabolic" fillcolor="#7986CB" fontcolor="white"]
        FGF18   [label="FGF-18\n(cartilage repair\n→sprifermin)" fillcolor="#5C6BC0" fontcolor="white"]
        FGF2    [label="FGF-2\n(mitogenic)" fillcolor="#9FA8DA"]
        FGFR3   [label="FGFR3\nreceptor" fillcolor="#3949AB" fontcolor="white"]
        TIMP1   [label="TIMP-1\n(MMP-1/9/14\ninhibitor)" fillcolor="#7986CB" fontcolor="white"]
        TIMP2   [label="TIMP-2\n(MMP-14\ninhibitor)" fillcolor="#7986CB" fontcolor="white"]
        TIMP3   [label="TIMP-3\n(ADAMTS-4/5\ninhibitor)" fillcolor="#5C6BC0" fontcolor="white"]
        IL10    [label="IL-10\n(anti-inflam)" fillcolor="#80CBC4"]
        IL4     [label="IL-4\n(M2 macrophage\npolarization)" fillcolor="#80CBC4"]
        IL13    [label="IL-13\n(Th2 cytokine)" fillcolor="#80CBC4"]
        Lubricin2 [label="PRG4/Lubricin\n(wear protection)" fillcolor="#BBDEFB"]
    }

    // ══════════════════════════════════════════════════════
    // CLUSTER 7: Subchondral Bone Remodeling
    // ══════════════════════════════════════════════════════
    subgraph cluster_bone {
        label="7. Subchondral Bone Remodeling"
        style=filled fillcolor="#EFEBE9" fontsize=10 fontcolor="#3E2723"

        RANKL     [label="RANKL\n(TNFSF11)" fillcolor="#A1887F" shape=ellipse]
        OPG       [label="OPG\n(TNFRSF11B)\ndecoy receptor" fillcolor="#80CBC4" shape=ellipse]
        RANK      [label="RANK\n(Osteoclast\nreceptor)" fillcolor="#A1887F"]
        OC        [label="Osteoclast\nActivity\n(resorption)" fillcolor="#EF9A9A" shape=ellipse]
        OB        [label="Osteoblast\nActivity\n(formation)" fillcolor="#C8E6C9" shape=ellipse]
        BoneScler [label="Subchondral\nSclerosis\n(stiffness↑)" fillcolor="#D7CCC8"]
        Osteophyte[label="Osteophyte\nFormation\n(bone spur)" fillcolor="#BCAAA4"]
        BML       [label="Bone Marrow\nLesion (MRI)" fillcolor="#FFF59D" shape=diamond]
        WntBone   [label="Wnt/LRP5-6\n(bone formation)" fillcolor="#FFB74D"]
        DKK1      [label="DKK-1\n(Wnt inhibitor)" fillcolor="#FFCDD2"]
        Sclerost  [label="Sclerostin\n(SOST)" fillcolor="#FFCDD2"]
        CTX1bm    [label="CTX-I\n(bone resorption\nbiomarker)" fillcolor="#FFF59D" shape=diamond]
        PINPbm    [label="PINP\n(bone formation\nbiomarker)" fillcolor="#FFF59D" shape=diamond]
        Netrin1   [label="Netrin-1\n(sensory nerve\ningrowth→pain)" fillcolor="#FFAB91"]
    }

    // ══════════════════════════════════════════════════════
    // CLUSTER 8: Synovitis & Immune Infiltrate
    // ══════════════════════════════════════════════════════
    subgraph cluster_synovium {
        label="8. Synovitis & Immune Cell Infiltrate"
        style=filled fillcolor="#F3E5F5" fontsize=10 fontcolor="#4A148C"

        FLS        [label="Fibroblast-like\nSynoviocytes\n(FLS)" fillcolor="#CE93D8" shape=ellipse]
        MacroM1    [label="Macrophage M1\n(pro-inflammatory\nCD86+)" fillcolor="#FF8A65" shape=ellipse]
        MacroM2    [label="Macrophage M2\n(anti-inflam\nCD206+)" fillcolor="#80CBC4" shape=ellipse]
        MastCell   [label="Mast Cells\n(histamine/\nPGD2)" fillcolor="#F06292" shape=ellipse]
        Neutro     [label="Neutrophils\n(NETs/ROS)" fillcolor="#FF5722" fontcolor="white" shape=ellipse]
        Th17       [label="Th17 Cells\n(IL-17A)" fillcolor="#EC407A" fontcolor="white" shape=ellipse]
        Treg       [label="Treg Cells\n(IL-10/TGF-β)" fillcolor="#66BB6A" fontcolor="white" shape=ellipse]
        CD8T       [label="CD8+ T Cells\n(cytotoxic)" fillcolor="#EF9A9A" shape=ellipse]
        Synovitis  [label="Synovitis\nScore (0–3)" fillcolor="#EF9A9A" shape=diamond]
        EffVol     [label="Joint Effusion\nVolume (mL)" fillcolor="#FFF59D" shape=diamond]
        SynoFluid  [label="Synovial\nFluid (mL)" fillcolor="#BBDEFB"]
    }

    // ══════════════════════════════════════════════════════
    // CLUSTER 9: Pain Signaling
    // ══════════════════════════════════════════════════════
    subgraph cluster_pain {
        label="9. Pain Signaling"
        style=filled fillcolor="#FFF8E1" fontsize=10 fontcolor="#BF360C"

        COX2      [label="COX-2\n(PTGS2)" fillcolor="#FFCC80"]
        iNOS_e    [label="iNOS (NOS2)\nNO synthesis" fillcolor="#FFCC80"]
        EP1_4     [label="EP1–EP4\n(PGE2 receptors)" fillcolor="#FF8A65"]
        Bradykinin[label="Bradykinin\n(B2R)\nplasma kallikrein" fillcolor="#FF7043"]
        SubstP    [label="Substance P\n(NK1R)\nNeuropeptide" fillcolor="#E53935" fontcolor="white"]
        CGRP      [label="CGRP\n(Neuropeptide\nvasodilation)" fillcolor="#E53935" fontcolor="white"]
        NGF       [label="NGF\n(Nerve growth\nfactor)" fillcolor="#C62828" fontcolor="white"]
        TrkA      [label="TrkA\n(NGF receptor\nhigh-affinity)" fillcolor="#B71C1C" fontcolor="white"]
        TRPV1     [label="TRPV1\n(Capsaicin\nreceptor)" fillcolor="#B71C1C" fontcolor="white"]
        TRPA1     [label="TRPA1\n(Cold/irritant\nchannel)" fillcolor="#D32F2F" fontcolor="white"]
        ASIC3     [label="ASIC3\n(Acid-sensing\nchannel)" fillcolor="#E53935" fontcolor="white"]
        P2X3      [label="P2X3/P2X4\n(Purinergic\nnociception)" fillcolor="#FF5722" fontcolor="white"]
        DRG       [label="DRG Neurons\n(C/Aδ fibers\nnociceptors)" fillcolor="#FFCDD2" shape=ellipse]
        SpinalDH  [label="Spinal Dorsal\nHorn (NMDAR\nwind-up)" fillcolor="#FFAB91"]
        CentralS  [label="Central\nSensitization\n(↓pain threshold)" fillcolor="#F44336" fontcolor="white"]
        VASPain   [label="VAS Pain\nScore (0–100)" fillcolor="#FFF59D" shape=diamond]
        NRS       [label="NRS Pain\n(0–10)" fillcolor="#FFF59D" shape=diamond]
    }

    // ══════════════════════════════════════════════════════
    // CLUSTER 10: Drug PK/PD
    // ══════════════════════════════════════════════════════
    subgraph cluster_pk {
        label="10. Drug PK/PD (Therapeutic Interventions)"
        style=filled fillcolor="#E0F2F1" fontsize=10 fontcolor="#004D40"

        NSAID_dose   [label="NSAID Dose\n(Celecoxib 200mg\nor Naproxen 500mg)" fillcolor="#80CBC4" shape=parallelogram]
        NSAID_gut    [label="NSAID Gut\n(absorption)" fillcolor="#B2DFDB"]
        NSAID_plasma [label="NSAID Plasma\nC_max~2–3μg/mL\nt½~11h" fillcolor="#4DB6AC"]
        NSAID_joint  [label="NSAID Joint\nFluid\nKp=0.4" fillcolor="#26A69A" fontcolor="white"]
        COX2_inh     [label="COX-2\nInhibition (%)\nIC50~0.04μg/mL" fillcolor="#00897B" fontcolor="white"]

        IACS_dose    [label="IA Corticosteroid\n(Triamcinolone\n40 mg)" fillcolor="#FFCC80" shape=parallelogram]
        IACS_joint   [label="IACS Joint\nConc. (μg/mL)\nt½~3d" fillcolor="#FFE082"]
        IACS_plasma  [label="IACS Plasma\nSpillover\n(HPA axis)" fillcolor="#FFCC80"]
        GR_act       [label="Glucocorticoid\nReceptor (GR)\nNuclear transloc" fillcolor="#FFB300"]

        HA_dose      [label="IA Hyaluronic\nAcid (Synvisc\n16mg×3)" fillcolor="#90CAF9" shape=parallelogram]
        HA_joint_c   [label="HA Joint\nConc. (mg/mL)\nt½~17h" fillcolor="#BBDEFB"]

        Spriferm_d   [label="Sprifermin\n(FGF-18,\n30μg IA Q12w)" fillcolor="#CE93D8" shape=parallelogram]
        Spriferm_pk  [label="Sprifermin\nJoint PK\nt½~16min" fillcolor="#E1BEE7"]

        Tanez_d      [label="Tanezumab\n(anti-NGF mAb\n2.5mg SC Q8w)" fillcolor="#EF9A9A" shape=parallelogram]
        Tanez_pk     [label="Tanezumab\nPlasma PK\nt½~23d" fillcolor="#FFCDD2"]

        Loreciv_d    [label="Lorecivivint\n(CLK2/DYRK1A\nWnt inhibitor IA)" fillcolor="#FFAB91" shape=parallelogram]
        Loreciv_pk   [label="Lorecivivint\nJoint PK\nSMG1 path" fillcolor="#FFCCBC"]
    }

    // ══════════════════════════════════════════════════════
    // CLUSTER 11: Circulating Biomarkers
    // ══════════════════════════════════════════════════════
    subgraph cluster_biomarkers {
        label="11. Circulating & Urinary Biomarkers"
        style=filled fillcolor="#F9FBE7" fontsize=10 fontcolor="#33691E"

        uCTXII  [label="uCTX-II\n(Urine Col-II\nCrosslinks μg/mmolCr)" fillcolor="#DCE775" shape=diamond]
        COMPbm  [label="Serum COMP\n(μg/mL)" fillcolor="#DCE775" shape=diamond]
        HAbm    [label="Serum HA\n(ng/mL)" fillcolor="#DCE775" shape=diamond]
        CS846   [label="CS 846 Epitope\n(Aggrecan\nSynthesis)" fillcolor="#C5E1A5" shape=diamond]
        IL6sys  [label="Serum IL-6\n(pg/mL)" fillcolor="#AED581" shape=diamond]
        hsCRP   [label="hs-CRP\n(mg/L)" fillcolor="#AED581" shape=diamond]
        MMP3bm  [label="Serum MMP-3\n(ng/mL)" fillcolor="#AED581" shape=diamond]
        coll2_1 [label="Coll2-1 Peptide\n(Col-II 108–116\ndenaturation)" fillcolor="#DCE775" shape=diamond]
    }

    // ══════════════════════════════════════════════════════
    // CLUSTER 12: Clinical Endpoints
    // ══════════════════════════════════════════════════════
    subgraph cluster_endpoints {
        label="12. Clinical Endpoints & Structural Outcomes"
        style=filled fillcolor="#ECEFF1" fontsize=10 fontcolor="#263238"

        KOOS    [label="KOOS\n(0–100\nhigher=better)" fillcolor="#90A4AE" shape=diamond]
        WOMAC   [label="WOMAC Total\n(0–96\nlower=better)" fillcolor="#90A4AE" shape=diamond]
        OARSI_resp [label="OARSI\nResponder\nCriteria" fillcolor="#B0BEC5" shape=diamond]
        TUG     [label="Timed Up\n& Go (sec)" fillcolor="#B0BEC5" shape=diamond]
        TKR     [label="TKR\nProbability\n(%/5yr)" fillcolor="#EF5350" fontcolor="white" shape=diamond]
        SF36    [label="SF-36 PCS\nPhysical QoL" fillcolor="#CFD8DC" shape=diamond]
        OARSI_g [label="OARSI Grade\n(0–4\nhistology)" fillcolor="#78909C" fontcolor="white" shape=diamond]
        SRA     [label="Structural\nRelevant\nAttainment" fillcolor="#B0BEC5" shape=diamond]
    }

    // ══════════════════════════════════════════════════════
    // EDGES: Risk Factors → Disease Processes
    // ══════════════════════════════════════════════════════
    Age        -> OxStress   [label="mtROS↑"]
    Age        -> CellSenesc [label="↑p16/p21"]
    Age        -> IGF1       [label="IGF-1R↓" style=dashed color="#9E9E9E"]
    BMI        -> MechStress [label="joint load"]
    BMI        -> Leptin     [label="adipose→"]
    BMI        -> IL6        [label="adipokine" color="#E53935"]
    FemSex     -> Estrogen
    JointInj   -> MechStress [label="altered\nbiomechanics"]
    GenRisk    -> ColII      [label="GDF5→\nlower quality" style=dashed]
    OccLoad    -> MechStress
    Estrogen   -> RANKL      [label="estrogen loss\n→RANKL↑" color="#E53935"]
    Estrogen   -> IL1b       [label="estrogen loss\n→↑" color="#E53935" style=dashed]
    Leptin     -> IL1b       [label="lepR→\nNF-κB" color="#E53935"]
    Leptin     -> MMP13      [label="↑" color="#E53935"]
    MechStress -> NF_kB      [label="piezo1/2\nmechano-\nreceptor" color="#E53935"]
    MechStress -> MAPK_p38   [label="integrin-FAK" color="#E53935"]
    MechStress -> MAPK_ERK
    OxStress   -> ChondroApopt [label="mitoch. pathway" color="#E53935"]
    OxStress   -> NF_kB      [label="IκBα\noxidation" color="#E53935"]
    OxStress   -> MMP13      [label="↑" color="#E53935"]
    CellSenesc -> IL6        [label="SASP" color="#E53935"]
    CellSenesc -> IL8        [label="SASP" color="#E53935"]
    CellSenesc -> MMP13      [label="SASP" color="#E53935"]
    CellSenesc -> VEGF       [label="SASP" color="#E53935"]
    p53_p21    -> CellSenesc [label="G1 arrest"]
    KLGrade    -> ECM_Loss   [label="structural\ncorrelate"]
    KLGrade    -> VASPain    [label="pain\ncorrelation" color="#E53935" style=dashed]

    // Chondrocyte Biology
    NF_kB      -> MMP13      [label="transcription" color="#E53935" penwidth=2]
    NF_kB      -> MMP3       [color="#E53935"]
    NF_kB      -> ADAMTS5    [color="#E53935" penwidth=2]
    NF_kB      -> COX2       [label="↑PTGS2" color="#E53935" penwidth=2]
    NF_kB      -> IL6        [color="#E53935"]
    NF_kB      -> IL8        [color="#E53935"]
    NF_kB      -> iNOS_e     [color="#E53935"]
    MAPK_p38   -> MMP13      [color="#E53935"]
    MAPK_p38   -> ChondroApopt [color="#E53935"]
    MAPK_p38   -> IL1b       [label="autocrine" color="#E53935"]
    MAPK_ERK   -> ChondroProl [color="#4CAF50"]
    MAPK_ERK   -> MMP13      [color="#E53935"]
    Wnt_sig    -> RUNX2      [label="hypertrophy"]
    Wnt_sig    -> MMP13      [label="β-cat→\nTcf4" color="#E53935"]
    Wnt_sig    -> Osteophyte [label="bone spurs" color="#FF5722"]
    HIF1a      -> VEGF       [label="hypoxia\n→angio" color="#FF9800"]
    HIF1a      -> Aggrecan   [label="↑synthesis\nat low O2" color="#4CAF50"]
    mTORC1     -> ChondroProl [color="#4CAF50"]
    mTORC1     -> ColII      [label="anabolic" color="#4CAF50"]
    PI3K_Akt   -> mTORC1     [color="#4CAF50"]
    PI3K_Akt   -> ChondroApopt [label="↓ survival" color="#4CAF50" arrowhead=tee style=dashed]
    PI3K_Akt   -> p53_p21    [label="↓ Mdm2↑" color="#4CAF50" arrowhead=tee style=dashed]
    SIRT1      -> NF_kB      [label="deacetylates\np65 ↓" color="#4CAF50" arrowhead=tee style=dashed]
    SIRT1      -> CellSenesc [label="↓ SASP" color="#4CAF50" arrowhead=tee style=dashed]
    SOX9       -> ColII      [label="TF→COL2A1\npromoter" color="#4CAF50" penwidth=2]
    SOX9       -> Aggrecan   [label="TF→ACAN\npromoter" color="#4CAF50" penwidth=2]
    SOX9       -> Lubricin   [color="#4CAF50"]
