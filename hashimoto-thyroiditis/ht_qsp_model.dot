digraph HashimotoThyroiditis_QSP {
  graph [
    rankdir=LR,
    fontname="Helvetica",
    fontsize=11,
    bgcolor="#FAFAFA",
    label="Hashimoto's Thyroiditis — Quantitative Systems Pharmacology Model\nHPT Axis · Thyroid Follicular Biology · Autoimmune Pathogenesis · Peripheral T4/T3 Metabolism · Drug PK/PD\n(Levothyroxine · Liothyronine · Selenium · Methimazole)",
    labelloc=t,
    labeljust=c,
    splines=curved,
    nodesep=0.35,
    ranksep=0.9,
    pad=0.5
  ];
  node [fontname="Helvetica", fontsize=8, style=filled, shape=box, margin="0.12,0.06"];
  edge [fontname="Helvetica", fontsize=7, arrowsize=0.65];

  // ============================================================
  // CLUSTER 1: Hypothalamic-Pituitary-Thyroid (HPT) Axis
  // ============================================================
  subgraph cluster_HPT {
    label="Hypothalamic-Pituitary-Thyroid (HPT) Axis";
    style=filled; fillcolor="#EBF5FB"; color="#1A5276"; penwidth=2.5;

    Hypothalamus     [label="Hypothalamus\n(PVN neurons)",      fillcolor="#1A5276", fontcolor=white];
    TRH              [label="TRH\n(Thyrotropin-Releasing\nHormone)",  fillcolor="#2471A3", fontcolor=white, shape=ellipse];
    Portal_TRH       [label="Hypophyseal\nPortal Blood",         fillcolor="#2E86C1", fontcolor=white];
    TRH_Receptor     [label="TRH-R\n(Gq-coupled GPCR)",         fillcolor="#5DADE2"];
    IP3_DAG          [label="IP3/DAG\n(PLC-β pathway)",          fillcolor="#85C1E9"];
    Ca2_Signal       [label="Ca²⁺\nMobilization",               fillcolor="#AED6F1"];
    Anterior_Pit     [label="Anterior Pituitary\n(Thyrotroph Cells)", fillcolor="#1A5276", fontcolor=white];
    TSH_Synthesis    [label="TSH Synthesis\n& Secretion",        fillcolor="#2471A3", fontcolor=white];
    TSH_Serum        [label="TSH\n(Serum, mIU/L)",               fillcolor="#1ABC9C", fontcolor=white, shape=ellipse];
    Pit_T3_Feedback  [label="Pituitary T3\n(D2-derived, local)", fillcolor="#F0B27A"];
    Hyp_TH_Feedback  [label="Hypothalamic\nNeg. Feedback (T3/T4)", fillcolor="#F0B27A"];
    Somatostatin     [label="Somatostatin\n(Inhibits TRH/TSH)",  fillcolor="#AED6F1"];
    Dopamine_Pit     [label="Dopamine\n(Inhibits TSH)",          fillcolor="#AED6F1"];
    Cortisol_Pit     [label="Cortisol\n(Inhibits TRH/TSH)",      fillcolor="#FDEBD0"];
    TSH_Pulse        [label="Circadian\nTSH Pulsatility",        fillcolor="#D6EAF8"];
  }

  // ============================================================
  // CLUSTER 2: Thyroid Gland — Follicular Cell Biology
  // ============================================================
  subgraph cluster_Thyroid {
    label="Thyroid Gland — Follicular Cell Biology & Hormone Synthesis";
    style=filled; fillcolor="#EAFAF1"; color="#1E8449"; penwidth=2.5;

    Follicular_Cell  [label="Thyroid Follicular\nCell (Thyrocyte)",  fillcolor="#1E8449", fontcolor=white];
    TSHR             [label="TSH Receptor\n(TSHR / LGR6)\nGs-coupled", fillcolor="#27AE60", fontcolor=white];
    cAMP_PKA         [label="cAMP / PKA\nSignaling Cascade",         fillcolor="#58D68D"];
    PI3K_Akt         [label="PI3K/Akt\n(TSH non-cAMP path)",         fillcolor="#82E0AA"];
    NIS              [label="NIS (SLC5A5)\nNa⁺/I⁻ Symporter\n(Basolateral)", fillcolor="#27AE60", fontcolor=white];
    Pendrin          [label="Pendrin (SLC26A4)\nApical I⁻ Efflux",   fillcolor="#58D68D"];
    Iodine_Diet      [label="Dietary Iodine\n(I⁻, 150 μg/day RDI)",  fillcolor="#D5F5E3"];
    Iodide_Uptake    [label="Iodide (I⁻)\nActive Uptake",            fillcolor="#A9DFBF"];
    ThOx1            [label="DUOX1 (THOX1)\nH₂O₂ Generation",        fillcolor="#A9DFBF"];
    ThOx2            [label="DUOX2 (THOX2)\nH₂O₂ Generation\n(Major)", fillcolor="#27AE60", fontcolor=white];
    TPO_Enzyme       [label="Thyroid Peroxidase\n(TPO)\nHeme enzyme", fillcolor="#1E8449", fontcolor=white];
    Tg_Synthesis     [label="Thyroglobulin (Tg)\nSynthesis (660 kDa)", fillcolor="#58D68D"];
    Organification   [label="Iodide\nOrganification\n(TPO + H₂O₂)",  fillcolor="#82E0AA"];
    MIT              [label="MIT\n(Mono-iodotyrosine)",               fillcolor="#A9DFBF"];
    DIT              [label="DIT\n(Di-iodotyrosine)",                 fillcolor="#A9DFBF"];
    Coupling_Rxn     [label="Coupling Reaction\n(TPO-catalyzed)",     fillcolor="#58D68D"];
    T4_Formation     [label="T4 Formation\n(DIT + DIT → thyroxine)",  fillcolor="#27AE60", fontcolor=white];
    T3_Formation     [label="T3 Formation\n(MIT + DIT → triiodo)", fillcolor="#27AE60", fontcolor=white];
    Colloid_Store    [label="Colloid Storage\n(Tg-T4/T3 in lumen)",  fillcolor="#A9DFBF"];
    Endocytosis_Tg   [label="Endocytosis\n(Colloid Retrieval)",       fillcolor="#58D68D"];
    Lysosomal_Prot   [label="Lysosomal\nProteolysis",                 fillcolor="#82E0AA"];
    T4_Secretion     [label="T4 Secretion\n(~80–100 μg/day)",        fillcolor="#1E8449", fontcolor=white];
    T3_Secretion     [label="T3 Secretion\n(~5 μg/day thyroidal)",   fillcolor="#27AE60", fontcolor=white];
    Wolff_Chaikoff   [label="Wolff-Chaikoff Effect\n(excess I⁻ → NIS↓)", fillcolor="#FDEBD0"];
    Thyroid_Blood    [label="Thyroid Blood\nSupply (vascularization)", fillcolor="#D5F5E3"];
  }

  // ============================================================
  // CLUSTER 3: Peripheral Thyroid Hormone Metabolism
  // ============================================================
  subgraph cluster_Peripheral {
    label="Peripheral T4/T3 Metabolism & Distribution";
    style=filled; fillcolor="#FEF9E7"; color="#9A7D0A"; penwidth=2.5;

    T4_Plasma        [label="Free T4\n(fT4 ~12 pmol/L)",            fillcolor="#D4AC0D", fontcolor=white, shape=ellipse];
    T3_Plasma        [label="Free T3\n(fT3 ~5 pmol/L)",             fillcolor="#E67E22", fontcolor=white, shape=ellipse];
    TBG              [label="TBG\n(Thyroxine-Binding\nGlobulin, 75%)", fillcolor="#F8C471"];
    TBPA             [label="TBPA / TTR\n(Transthyretin, 15%)",       fillcolor="#FAD7A0"];
    Albumin_Bind     [label="Albumin\n(Binding, 10%)",               fillcolor="#FDEBD0"];
    T4_Bound         [label="Bound T4\n(99.97% protein-bound)",      fillcolor="#F9E79F"];
    T3_Bound         [label="Bound T3\n(99.7% protein-bound)",       fillcolor="#F9E79F"];
    DIO1             [label="Type I Deiodinase\n(DIO1)\nLiver, Kidney, Thyroid", fillcolor="#D4AC0D", fontcolor=white];
    DIO2             [label="Type II Deiodinase\n(DIO2)\nBrain, Pituitary, BAT", fillcolor="#CA6F1E", fontcolor=white];
    DIO3             [label="Type III Deiodinase\n(DIO3)\nPlacenta, Brain, Skin", fillcolor="#A04000", fontcolor=white];
    rT3              [label="Reverse T3 (rT3)\n(Inactive metabolite)", fillcolor="#FAD7A0"];
    T4_Liver         [label="T4 Hepatic\nUptake & Glucuronidation",  fillcolor="#F8C471"];
    T3_Liver         [label="T3 Hepatic\nGlucuronidation/Sulfation", fillcolor="#F8C471"];
    Biliary_Ex       [label="Biliary Excretion\n+ Enterohepatic Circ.", fillcolor="#FDEBD0"];
    Urinary_Ex       [label="Urinary Excretion\n(T3/T4 metabolites)", fillcolor="#FDEBD0"];
    Se_DIO_Cofactor  [label="Selenium\n(Selenocysteine in DIO1-3)",  fillcolor="#F0E68C"];
    D2_Pituitary     [label="D2 in Pituitary\n(Local T3 production)", fillcolor="#F8C471"];
  }

  // ============================================================
  // CLUSTER 4: Thyroid Hormone Genomic & Non-Genomic Actions
  // ============================================================
  subgraph cluster_TH_Action {
    label="Thyroid Hormone Action — Genomic & Non-Genomic";
    style=filled; fillcolor="#F4ECF7"; color="#6C3483"; penwidth=2.5;

    TR_alpha1        [label="TRα1 (NR1A1)\nCardiac, Bone, CNS",     fillcolor="#6C3483", fontcolor=white];
    TR_alpha2        [label="TRα2\n(Dominant negative)",             fillcolor="#A569BD"];
    TR_beta1         [label="TRβ1 (NR1A2)\nLiver, Kidney",          fillcolor="#7D3C98", fontcolor=white];
    TR_beta2         [label="TRβ2\nPituitary, Cochlea, Retina",      fillcolor="#9B59B6", fontcolor=white];
    RXR_Heterodimer  [label="RXR\n(Heterodimer Partner)",            fillcolor="#BB8FCE"];
    TRE_Binding      [label="Thyroid Response\nElement (TRE)",       fillcolor="#D7BDE2"];
    Coactivators     [label="Coactivators\n(SRC-1, CBP/p300, MED12)", fillcolor="#D7BDE2"];
    Gene_Transcription [label="Gene Transcription\nActivation / Repression", fillcolor="#6C3483", fontcolor=white];
    BMR_Genes        [label="Metabolic Genes\n(UCP1, SERCA, Na-K-ATPase)", fillcolor="#BB8FCE"];
    Cardiac_Genes    [label="Cardiac Genes\n(MHC-α, SERCA2a, HCN4, PLB)", fillcolor="#BB8FCE"];
    Lipid_Genes      [label="Lipid Metabolism\n(LDLr, FAS, HMGCR, ApoB)", fillcolor="#BB8FCE"];
    Bone_Genes       [label="Bone Turnover\n(OPG, RANKL, collagen)", fillcolor="#BB8FCE"];
    GH_IGF1_Axis     [label="GH/IGF-1 Axis\n(TRβ → GH gene ↑)",     fillcolor="#D2B4DE"];
    Thermogenesis    [label="Thermogenesis\n& BMR Increase",         fillcolor="#A569BD"];
    Beta_AR_Sensitize [label="β-AR Sensitization\n(↑ cAMP sensitivity)", fillcolor="#D2B4DE"];
    Mito_Biogenesis  [label="Mitochondrial\nBiogenesis (PGC-1α↑)",  fillcolor="#BB8FCE"];
    Non_Genomic_TH   [label="Non-Genomic\nActions (MAPK, PI3K, AMPK)", fillcolor="#D2B4DE"];
    SHBG_Production  [label="SHBG Production\n(Liver, T3-responsive)", fillcolor="#E8DAEF"];
  }

  // ============================================================
  // CLUSTER 5: Autoimmune Pathogenesis — Adaptive Immunity
  // ============================================================
  subgraph cluster_Autoimmune {
    label="Autoimmune Pathogenesis — Adaptive Immune Response";
    style=filled; fillcolor="#FDEDEC"; color="#B03A2E"; penwidth=2.5;

    Thyroid_Antigen  [label="Thyroid Antigens\n(TPO, Tg, TSHR,\nMCT8, pendrin)", fillcolor="#B03A2E", fontcolor=white];
    APC_DC           [label="Antigen-Presenting Cell\n(Dendritic Cell / Macrophage)", fillcolor="#922B21", fontcolor=white];
    MHC_II           [label="MHC-II\nAntigen Presentation\n(HLA-DR3/DR4/DR5)", fillcolor="#EC7063"];
    CD4_T_Helper     [label="CD4+ T Helper\nCell Activation",      fillcolor="#B03A2E", fontcolor=white];
    Th1_Cell         [label="Th1 Cells\n(IFN-γ, IL-2, TNF-α)",     fillcolor="#922B21", fontcolor=white, shape=ellipse];
    Th17_Cell        [label="Th17 Cells\n(IL-17A, IL-21, IL-22)",   fillcolor="#C0392B", fontcolor=white, shape=ellipse];
    Treg_Cell        [label="Treg Cells\n(FOXP3+, IL-10, TGF-β)",   fillcolor="#82E0AA", shape=ellipse];
    Tfh_Cell         [label="Tfh Cells\n(T follicular helper,\nIL-21, CXCR5+)", fillcolor="#F1948A"];
    FOXP3_Defect     [label="FOXP3+\nTreg Deficiency\n(Hashimoto pathogenesis)", fillcolor="#F1948A"];
    IL12_Signaling   [label="IL-12/IL-18\n(Th1 polarization)",      fillcolor="#FADBD8"];
    IL23_Signaling   [label="IL-23/IL-6\n(Th17 expansion)",         fillcolor="#FADBD8"];
    IFN_gamma        [label="IFN-γ\nMacrophage/MHCII Upregulation", fillcolor="#EC7063"];
    TNF_alpha        [label="TNF-α\nPro-inflammatory",              fillcolor="#EC7063"];
    IL17A            [label="IL-17A\nNeutrophil Recruit., Chemo.", fillcolor="#FADBD8"];
    IL21_BTcell      [label="IL-21\n(B cell differentiation)",       fillcolor="#FADBD8"];
    B_Cell           [label="B Cell\nActivation & Expansion",       fillcolor="#B03A2E", fontcolor=white, shape=ellipse];
    GC_Reaction      [label="Germinal Center\nReaction (Thyroid LN)", fillcolor="#EC7063"];
    Plasma_Cell      [label="Plasma Cell\n(Long-lived, IgG-secreting)", fillcolor="#922B21", fontcolor=white];
    Anti_TPO_Ab      [label="Anti-TPO\nIgG Antibodies\n(Titer ≤34 IU/mL normal)", fillcolor="#B03A2E", fontcolor=white, shape=ellipse];
    Anti_Tg_Ab       [label="Anti-Tg\nIgG Antibodies\n(Titer ≤40 IU/mL normal)", fillcolor="#922B21", fontcolor=white, shape=ellipse];
    Anti_TSHR_Block  [label="Anti-TSHR\nBlocking Ab\n(TSH-R signaling ↓)", fillcolor="#FADBD8"];
    ADCC_Mechanism   [label="ADCC\n(Ab-Dependent Cellular\nCytotoxicity)", fillcolor="#EC7063"];
    Complement_Act   [label="Complement\nActivation\n(C1q, C3, C5)", fillcolor="#FADBD8"];
    MAC_Formation    [label="MAC (C5b-9)\nMembrane Attack\nComplex", fillcolor="#EC7063"];
    Thyrocyte_Apop   [label="Thyrocyte\nApoptosis\n(Fas/FasL, TRAIL)", fillcolor="#922B21", fontcolor=white];
    CD8_CTL          [label="CD8+ CTL\n(Direct Thyrocyte Killing)", fillcolor="#EC7063"];
    Lymph_Infiltrate [label="Lymphocytic\nInfiltration\n(Hallmark lesion)", fillcolor="#B03A2E", fontcolor=white];
    Hurthle_Change   [label="Hürthle Cell\nMetaplasia\n(Oxyphilic change)", fillcolor="#F5B7B1"];
    Germinal_Center2 [label="Intrathyroidal\nGerminal Centers",     fillcolor="#F5B7B1"];
  }

  // ============================================================
  // CLUSTER 6: Innate Immunity & Oxidative Stress
  // ============================================================
  subgraph cluster_Innate {
    label="Innate Immunity & Oxidative Stress";
    style=filled; fillcolor="#FDF2E9"; color="#CA6F1E"; penwidth=2.5;

    pDC              [label="Plasmacytoid DC\n(Type I IFN source)",  fillcolor="#CA6F1E", fontcolor=white];
    mDC              [label="Myeloid DC\n(IL-12 producer)",          fillcolor="#D35400", fontcolor=white];
    M1_Macrophage    [label="M1 Macrophage\n(Thyroid infiltrating)", fillcolor="#E67E22", fontcolor=white];
    TLR_Signaling    [label="TLR Signaling\n(TLR3/TLR4/TLR7/TLR9)", fillcolor="#F8C471"];
    NF_kB            [label="NF-κB\nActivation",                     fillcolor="#E67E22", fontcolor=white];
    NLRP3_Inflamsome [label="NLRP3\nInflammasome",                   fillcolor="#F8C471"];
    IL1_beta         [label="IL-1β\nMaturation & Secretion",         fillcolor="#E67E22", fontcolor=white];
    IL6_Innate       [label="IL-6\n(Systemic acute phase)",          fillcolor="#F8C471"];
    CXCL10_IP10      [label="CXCL10 / IP-10\n(T cell chemotaxis)",  fillcolor="#FAD7A0"];
    CCL5_RANTES      [label="CCL5 / RANTES\n(Leukocyte recruit.)",  fillcolor="#FAD7A0"];
    CXCL9_CXCL11     [label="CXCL9/CXCL11\n(Th1 chemotaxis)",       fillcolor="#FAD7A0"];
    ROS_Oxidative    [label="Reactive Oxygen\nSpecies (ROS)",        fillcolor="#F0B27A"];
    GPx_Activity     [label="GPx (Glutathione\nPeroxidase) Activity", fillcolor="#FAD7A0"];
    Selenoprotein_P  [label="Selenoprotein P\n(Se transport to thyroid)", fillcolor="#F8C471"];
    NK_Cell          [label="NK Cell\n(ADCC effector)",              fillcolor="#FAD7A0"];
    Type_I_IFN       [label="Type I IFN\n(IFN-α/β)\nMHCII upregulation", fillcolor="#F8C471"];
    iNOS_NO          [label="iNOS / NO\n(Nitric oxide production)",  fillcolor="#FAD7A0"];
    MHC_I_Upregulate [label="MHC-I\nUpregulation\n(by IFN-γ on thyrocytes)", fillcolor="#FAD7A0"];
  }

  // ============================================================
  // CLUSTER 7: Drug Pharmacokinetics
  // ============================================================
  subgraph cluster_PK {
    label="Drug Pharmacokinetics";
    style=filled; fillcolor="#EBF5FB"; color="#1F618D"; penwidth=2.5;

    LT4_Oral_Dose    [label="Levothyroxine (LT4)\nOral Dose\n(μg/day)",        fillcolor="#1F618D", fontcolor=white, shape=parallelogram];
    LT4_Gut          [label="LT4 Gut Compartment\n(Absorption F~70–80%)",      fillcolor="#2471A3", fontcolor=white];
    LT4_Central      [label="LT4 Central\nCompartment (Vc)",                   fillcolor="#2980B9", fontcolor=white];
    LT4_Peripheral   [label="LT4 Peripheral\nCompartment (Vp)",                fillcolor="#3498DB", fontcolor=white];
    LT4_Protein_Bind [label="LT4 Protein Binding\n(TBG, ~99.97%)",            fillcolor="#85C1E9"];
    LT4_DIO_Convert  [label="LT4 → T3\n(DIO1/DIO2 conversion)",               fillcolor="#5DADE2"];
    LT4_Elimination  [label="LT4 Elimination\n(t½ ~7 days, ke≈0.1 day⁻¹)",   fillcolor="#AED6F1"];
    LiT3_Oral_Dose   [label="Liothyronine (LiT3)\nOral Dose",                  fillcolor="#1F618D", fontcolor=white, shape=parallelogram];
    LiT3_Central     [label="LiT3 Central\nCompartment",                       fillcolor="#2C81BF", fontcolor=white];
    Se_Oral_Dose     [label="Selenium\n200 μg/day Oral\n(selenomethionine)",   fillcolor="#1F618D", fontcolor=white, shape=parallelogram];
    Se_Plasma        [label="Selenium\nPlasma (μg/L)",                         fillcolor="#2980B9", fontcolor=white, shape=ellipse];
    Se_Tissue_Depot  [label="Selenium\nTissue Depot",                          fillcolor="#5DADE2"];
    MMI_Oral_Dose    [label="Methimazole (MMI)\nOral Dose (mg/day)",           fillcolor="#1F618D", fontcolor=white, shape=parallelogram];
    MMI_Plasma       [label="MMI Plasma\nConcentration",                       fillcolor="#34495E", fontcolor=white];
    PTU_Oral_Dose    [label="PTU\n(Propylthiouracil)\nDose (mg/day)",          fillcolor="#1F618D", fontcolor=white, shape=parallelogram];
    PTU_Plasma       [label="PTU Plasma\nConcentration\n(t½ ~1–2 h)",         fillcolor="#3D566E", fontcolor=white];
    LT4_Food_Effect  [label="Food/Drug\nInteraction\n(Ca²⁺, Fe, PPI ↓ abs.)", fillcolor="#AED6F1"];
  }

  // ============================================================
  // CLUSTER 8: Drug Pharmacodynamics / Mechanisms of Action
  // ============================================================
  subgraph cluster_PD {
    label="Drug Pharmacodynamics — Mechanisms of Action";
    style=filled; fillcolor="#E8F8F5"; color="#0E6655"; penwidth=2.5;

    LT4_HPT_Feedback [label="LT4 → fT4↑ → T3↑\n→ TSH Suppression\n(Neg. Feedback)", fillcolor="#0E6655", fontcolor=white];
    TSH_Normalization [label="TSH\nNormalization\n(Target 0.4–4.0 mIU/L)", fillcolor="#1ABC9C", fontcolor=white];
    Symptom_Relief   [label="Hypothyroid\nSymptom Relief",                  fillcolor="#1ABC9C", fontcolor=white];
    LT4_BMR_Effect   [label="BMR\nRestoration",                             fillcolor="#48C9B0"];
    LT4_Cardiac_Eff  [label="Cardiac Function\nImprovement\n(HR, contractility)", fillcolor="#48C9B0"];
    LT4_Lipid_Eff    [label="LDL-C Reduction\n(LDLr expression ↑)",         fillcolor="#48C9B0"];
    Se_GPx_Effect    [label="Se → GPx↑\n→ H₂O₂ ↓, ROS ↓\n(Thyroid protection)", fillcolor="#A2D9CE"];
    Se_DIO_Effect    [label="Se → DIO1/2 ↑\n→ T4→T3 ↑\n(Hormone activation)", fillcolor="#A2D9CE"];
    Se_Ab_Reduction  [label="Se → Anti-TPO Ab ↓\n~50% reduction\n(Gärtner 2002 RCT)", fillcolor="#1ABC9C", fontcolor=white];
    Se_NF_kB_Effect  [label="Se → NF-κB ↓\n→ Inflammation ↓",              fillcolor="#A2D9CE"];
    Se_Apoptosis_Eff [label="Se → Thyrocyte\nApoptosis ↓",                  fillcolor="#A2D9CE"];
    MMI_TPO_Block    [label="MMI Blocks\nTPO Activity\n(organification)",    fillcolor="#76D7C4"];
    PTU_TPO_DIO_Block [label="PTU Blocks\nTPO + DIO1\n(T4→T3 ↓)",           fillcolor="#76D7C4"];
    LT4_Excess_Bone  [label="LT4 Excess →\nBone Resorption ↑\n(RANKL↑)",   fillcolor="#F9E79F"];
    LT4_Excess_Cardiac [label="LT4 Excess →\nAFib Risk ↑\n(Subclinical thyrotox.)", fillcolor="#FDEBD0"];
    Combo_T4_T3      [label="Combo LT4/LiT3\nOptimal Tissue T3\n(Subset patients)", fillcolor="#48C9B0"];
    LT4_Weight_Effect [label="LT4 → Weight ↓\n(BMR ↑, lipolysis ↑)",        fillcolor="#A2D9CE"];
    Se_Pregnancy_Eff [label="Se → Postpartum\nThyroiditis Risk ↓",           fillcolor="#A2D9CE"];
  }

  // ============================================================
  // CLUSTER 9: Clinical Endpoints & Biomarkers
  // ============================================================
  subgraph cluster_Clinical {
    label="Clinical Endpoints & Biomarkers";
    style=filled; fillcolor="#F8F9FA"; color="#4D5656"; penwidth=2.5;

    TSH_Biomarker    [label="Serum TSH\n(0.4–4.0 mIU/L)",           fillcolor="#4D5656", fontcolor=white, shape=ellipse];
    fT4_Biomarker    [label="Free T4 (fT4)\n(9–23 pmol/L)",          fillcolor="#626567", fontcolor=white, shape=ellipse];
    fT3_Biomarker    [label="Free T3 (fT3)\n(3.5–6.5 pmol/L)",       fillcolor="#626567", fontcolor=white, shape=ellipse];
    AntiTPO_Biomarker [label="Anti-TPO Ab\n(>34 IU/mL = positive)",  fillcolor="#ABB2B9", shape=ellipse];
    AntiTg_Biomarker [label="Anti-Tg Ab\n(>40 IU/mL = positive)",    fillcolor="#ABB2B9", shape=ellipse];
    Thyroid_Vol_US   [label="Thyroid Volume\n(Ultrasound, mL)\n(Normal: F<18, M<25)", fillcolor="#BFC9CA", shape=ellipse];
    BMD_Score        [label="BMD (T-score)\nOsteoporosis Monitor",   fillcolor="#BFC9CA"];
    Heart_Rate_Clin  [label="Heart Rate (bpm)\n+ ECG QTc",           fillcolor="#BFC9CA"];
    LDL_Chol_Clin    [label="LDL-Cholesterol\n(mmol/L)",             fillcolor="#BFC9CA"];
    BMI_Weight_Clin  [label="BMI / Body Weight\n(kg/m²)",            fillcolor="#BFC9CA"];
    Fatigue_Score    [label="Fatigue\n(FSS / MFI-20)",               fillcolor="#D5D8DC"];
    Depression_Score [label="Depression\n(PHQ-9 / BDI)",             fillcolor="#D5D8DC"];
    Cognitive_Func   [label="Cognitive Function\n(MMSE, MoCA)",      fillcolor="#D5D8DC"];
    QoL_Score        [label="Quality of Life\n(SF-36, ThyPRO)",      fillcolor="#D5D8DC"];
    Goiter_Size      [label="Goiter\n(Thyroid Enlargement)",         fillcolor="#BFC9CA"];
    Myxedema_CL      [label="Myxedema\n(Severe Hypothyroid State)",  fillcolor="#626567", fontcolor=white];
    Hair_Skin_CL     [label="Hair Loss\nDry Skin (cutaneous)", fillcolor="#D5D8DC"];
    Cold_Intolerance [label="Cold Intolerance\nConstipation",        fillcolor="#D5D8DC"];
  }

  // ============================================================
  // CLUSTER 10: Complications & Comorbidities
  // ============================================================
  subgraph cluster_Comorbid {
    label="Complications, Comorbidities & Disease Progression";
    style=filled; fillcolor="#FEF5E7"; color="#A04000"; penwidth=2.5;

    Subclinical_HypoT [label="Subclinical\nHypothyroidism\n(TSH↑, fT4 normal)", fillcolor="#A04000", fontcolor=white];
    Overt_HypoT      [label="Overt\nHypothyroidism\n(TSH↑, fT4↓)",           fillcolor="#784212", fontcolor=white];
    Dyslipidemia_Co  [label="Dyslipidemia\n(LDL↑, TG↑, HDL↓)",              fillcolor="#E59866"];
    CV_Risk_Co       [label="Cardiovascular\nRisk ↑ (CAD, HF)",              fillcolor="#CA6F1E", fontcolor=white];
    Diastolic_HTN    [label="Diastolic\nHypertension",                        fillcolor="#FAD7A0"];
    HFpEF_Risk       [label="HFpEF Risk ↑\n(Diastolic Dysfunc.)",            fillcolor="#F0B27A"];
    Depr_Anxiety_Co  [label="Depression & Anxiety\n(Neuropsychiatric)",       fillcolor="#D2B4DE"];
    Infertility_Co   [label="Infertility\nMenstrual Disorders",               fillcolor="#FAD7A0"];
    Preg_Complication [label="Pregnancy\nComplications\n(Pre-eclampsia, loss)", fillcolor="#FDEBD0"];
    Fetal_Neuro      [label="Fetal\nNeurodevelopment\nImpairment (IQ ↓)",     fillcolor="#FDEBD0"];
    Osteoporosis_Co  [label="Osteoporosis\n(LT4 over-treatment)",             fillcolor="#E59866"];
    MALT_Lymphoma    [label="MALT Lymphoma\nRisk ↑ (~3× general\npopulation)", fillcolor="#CA6F1E", fontcolor=white];
    Other_AI_Co      [label="Autoimmune\nOverlap\n(T1D, RA, celiac, SLE)",   fillcolor="#F8C471"];
    Hashimoto_Enc    [label="Hashimoto\nEncephalopathy\n(Rare, anti-NAE ab)", fillcolor="#FAD7A0"];
    Thyroid_Damage   [label="Thyroid\nFibrosis / Atrophy\n(End-stage)", fillcolor="#784212", fontcolor=white, shape=diamond];
  }

  // ============================================================
  // EDGES — HPT Axis Internal
  // ============================================================
  Hypothalamus     -> TRH              [label="produces"];
  TRH              -> Portal_TRH       [label="secreted into"];
  Portal_TRH       -> TRH_Receptor     [label="binds Gq"];
  TRH_Receptor     -> IP3_DAG          [label="PLC-β"];
  IP3_DAG          -> Ca2_Signal       [label="IP3→ER"];
  Ca2_Signal       -> TSH_Synthesis    [label="triggers exocytosis"];
  Anterior_Pit     -> TSH_Synthesis    [label="site of"];
  TSH_Synthesis    -> TSH_Serum        [label="releases"];
  TSH_Pulse        -> TSH_Serum        [label="pulsatile"];
  Somatostatin     -> TSH_Synthesis    [label="inhibits", style=dashed, color="#E74C3C"];
  Dopamine_Pit     -> TSH_Synthesis    [label="inhibits", style=dashed, color="#E74C3C"];
  Cortisol_Pit     -> TRH              [label="inhibits", style=dashed, color="#E74C3C"];
  Cortisol_Pit     -> TSH_Synthesis    [label="inhibits", style=dashed, color="#E74C3C"];
  Pit_T3_Feedback  -> TSH_Synthesis    [label="strong inhibition", style=dashed, color="#E74C3C"];
  Hyp_TH_Feedback  -> TRH              [label="inhibits", style=dashed, color="#E74C3C"];

  // HPT → Thyroid
  TSH_Serum        -> TSHR             [label="activates (Kd~0.1 nM)"];
  TSHR             -> cAMP_PKA         [label="Gs → AC → cAMP"];
  TSHR             -> PI3K_Akt         [label="Gq path"];
  cAMP_PKA         -> NIS              [label="↑ transcription"];
  cAMP_PKA         -> TPO_Enzyme       [label="↑ expression"];
  cAMP_PKA         -> Tg_Synthesis     [label="↑ synthesis"];
  cAMP_PKA         -> T4_Secretion     [label="stimulates"];
  cAMP_PKA         -> T3_Secretion     [label="stimulates"];
  cAMP_PKA         -> ThOx2            [label="↑ activity"];
  PI3K_Akt         -> Thyroid_Blood    [label="angiogenesis"];

  // Thyroid synthesis
  Iodine_Diet      -> Iodide_Uptake    [label="NIS-mediated"];
  NIS              -> Iodide_Uptake    [label="active transport\n(basolateral)"];
  Iodide_Uptake    -> Pendrin          [label="→ apical efflux"];
  Pendrin          -> Organification   [label="provides I⁻"];
  ThOx1            -> Organification   [label="H₂O₂ supply"];
  ThOx2            -> Organification   [label="H₂O₂ (major)"];
  TPO_Enzyme       -> Organification   [label="catalyzes"];
  Tg_Synthesis     -> Organification   [label="Tg substrate"];
  Organification   -> MIT              [label="1 iodine → MIT"];
  Organification   -> DIT              [label="2 iodines → DIT"];
  MIT              -> Coupling_Rxn     [label="+"];
  DIT              -> Coupling_Rxn     [label="+"];
  Coupling_Rxn     -> T3_Formation     [label="MIT + DIT"];
  Coupling_Rxn     -> T4_Formation     [label="DIT + DIT"];
  T3_Formation     -> Colloid_Store    [label="stored as Tg-T3"];
  T4_Formation     -> Colloid_Store    [label="stored as Tg-T4"];
  Colloid_Store    -> Endocytosis_Tg   [label="TSH-stimulated"];
  Endocytosis_Tg   -> Lysosomal_Prot  [label="cathepsin"];
  Lysosomal_Prot   -> T4_Secretion    [label="releases T4"];
  Lysosomal_Prot   -> T3_Secretion    [label="releases T3"];
  Iodide_Uptake    -> Wolff_Chaikoff   [label="excess → acute"];
  Wolff_Chaikoff   -> NIS              [label="auto-inhibit", style=dashed, color="#E74C3C"];
  Thyroid_Blood    -> Follicular_Cell  [label="nourishes"];

  // Peripheral metabolism
  T4_Secretion     -> T4_Plasma        [label="enters circulation"];
  T3_Secretion     -> T3_Plasma        [label="enters circulation"];
  T4_Plasma        -> TBG              [label="binds"];
  T4_Plasma        -> TBPA             [label="binds"];
  T4_Plasma        -> Albumin_Bind     [label="binds"];
  TBG              -> T4_Bound;
  TBPA             -> T4_Bound;
  Albumin_Bind     -> T4_Bound;
  T3_Plasma        -> T3_Bound         [label="TBG binding"];
  T4_Plasma        -> DIO1             [label="5'-deiodinase"];
  T4_Plasma        -> DIO2             [label="5'-deiodinase"];
  T4_Plasma        -> DIO3             [label="5-deiodinase"];
  DIO1             -> T3_Plasma        [label="T4→T3 (~60%)"];
  DIO2             -> T3_Plasma        [label="T4→T3 (~20%)"];
  DIO3             -> rT3              [label="T4→rT3"];
  Se_DIO_Cofactor  -> DIO1             [label="selenocysteine\nrequired"];
  Se_DIO_Cofactor  -> DIO2             [label="selenocysteine\nrequired"];
  Se_DIO_Cofactor  -> DIO3             [label="selenocysteine\nrequired"];
  D2_Pituitary     -> Pit_T3_Feedback  [label="local T3"];
  DIO2             -> D2_Pituitary     [label="pituitary DIO2"];
  T4_Plasma        -> T4_Liver         [label="hepatic uptake"];
  T3_Plasma        -> T3_Liver         [label="glucuronidation"];
  T4_Liver         -> Biliary_Ex       [label="conjugates"];
  T3_Liver         -> Urinary_Ex       [label="sulfation"];

  // T4/T3 → HPT feedback
  T3_Plasma        -> Hyp_TH_Feedback  [label="central feedback", constraint=false];
  T4_Plasma        -> Hyp_TH_Feedback  [label="central", constraint=false];

  // TH Genomic Actions
  T3_Plasma        -> TR_alpha1        [label="binds (Kd~1 nM)"];
  T3_Plasma        -> TR_beta1         [label="binds (Kd~0.5 nM)"];
  T3_Plasma        -> TR_beta2         [label="binds pituitary"];
  TR_alpha1        -> RXR_Heterodimer  [label="heterodimerizes"];
  TR_beta1         -> RXR_Heterodimer  [label="heterodimerizes"];
  TR_beta2         -> RXR_Heterodimer  [label="heterodimerizes"];
  RXR_Heterodimer  -> TRE_Binding      [label="binds DNA"];
  TRE_Binding      -> Coactivators     [label="recruits"];
  Coactivators     -> Gene_Transcription [label="HAT activity"];
  Gene_Transcription -> BMR_Genes;
  Gene_Transcription -> Cardiac_Genes;
  Gene_Transcription -> Lipid_Genes;
  Gene_Transcription -> Bone_Genes;
  Gene_Transcription -> SHBG_Production;
  BMR_Genes        -> Thermogenesis;
  BMR_Genes        -> Mito_Biogenesis;
  Cardiac_Genes    -> Beta_AR_Sensitize;
  TR_beta1         -> GH_IGF1_Axis     [label="GH gene TRE"];
  T3_Plasma        -> Non_Genomic_TH   [label="rapid action"];
  TR_alpha2        -> TR_alpha1        [label="competes (no T3 bind)", style=dashed];

  // Autoimmune pathogenesis
  Thyroid_Antigen  -> APC_DC           [label="engulfed/processed"];
  APC_DC           -> MHC_II           [label="presents peptides"];
  MHC_II           -> CD4_T_Helper     [label="activates"];
  CD4_T_Helper     -> Th1_Cell         [label="IL-12 → Th1"];
  CD4_T_Helper     -> Th17_Cell        [label="IL-23/IL-6"];
  CD4_T_Helper     -> Treg_Cell        [label="TGF-β → iTreg"];
  CD4_T_Helper     -> Tfh_Cell         [label="CXCR5, ICOS"];
  IL12_Signaling   -> Th1_Cell         [label="STAT4"];
  IL23_Signaling   -> Th17_Cell        [label="STAT3"];
  FOXP3_Defect     -> Treg_Cell        [label="impairs", style=dashed, color="#E74C3C"];
  Th1_Cell         -> IFN_gamma;
  Th1_Cell         -> TNF_alpha;
  Th17_Cell        -> IL17A;
  Th17_Cell        -> IL21_BTcell;
  IFN_gamma        -> M1_Macrophage    [label="activates"];
  IFN_gamma        -> MHC_I_Upregulate [label="↑ thyrocyte MHC-I"];
  TNF_alpha        -> NF_kB            [label="induces"];
  IL17A            -> NF_kB            [label="activates"];
  Tfh_Cell         -> B_Cell           [label="IL-21, CD40L"];
  B_Cell           -> GC_Reaction      [label="enters"];
  GC_Reaction      -> Plasma_Cell      [label="differentiates"];
  GC_Reaction      -> Germinal_Center2 [label="intrathyroidal"];
  Plasma_Cell      -> Anti_TPO_Ab      [label="secretes"];
  Plasma_Cell      -> Anti_Tg_Ab       [label="secretes"];
  Plasma_Cell      -> Anti_TSHR_Block  [label="secretes"];
  Anti_TPO_Ab      -> ADCC_Mechanism   [label="opsonizes thyrocyte"];
  Anti_TPO_Ab      -> Complement_Act   [label="C1q activation"];
  Complement_Act   -> MAC_Formation    [label="cascade"];
  MAC_Formation    -> Thyrocyte_Apop   [label="lyses"];
  ADCC_Mechanism   -> NK_Cell;
  NK_Cell          -> Thyrocyte_Apop   [label="kills"];
  CD8_CTL          -> Thyrocyte_Apop   [label="perforin/granzyme"];
  Th1_Cell         -> CD8_CTL          [label="activates"];
  MHC_I_Upregulate -> CD8_CTL          [label="target recognition"];
  Thyrocyte_Apop   -> Thyroid_Antigen  [label="releases Ag\n(amplifies)", style=dashed, color="#B03A2E", constraint=false];
  Thyrocyte_Apop   -> Lymph_Infiltrate [label="→ infiltration"];
  Thyrocyte_Apop   -> Hurthle_Change   [label="mitochondrial\nstress response"];
  Lymph_Infiltrate -> Germinal_Center2;
  Anti_TSHR_Block  -> TSHR             [label="blocks TSH signaling", style=dashed, color="#E74C3C"];

  // Innate immunity
  APC_DC           -> pDC              [label="pDC subset"];
  APC_DC           -> mDC              [label="mDC subset"];
  pDC              -> Type_I_IFN       [label="major source"];
  mDC              -> IL12_Signaling   [label="produces IL-12"];
  mDC              -> TLR_Signaling    [label="pattern recog."];
  TLR_Signaling    -> NF_kB            [label="MyD88"];
  NF_kB            -> IL6_Innate       [label="→"];
  NF_kB            -> TNF_alpha        [label="→"];
  NF_kB            -> CXCL10_IP10      [label="→"];
  NF_kB            -> CCL5_RANTES      [label="→"];
  NF_kB            -> CXCL9_CXCL11    [label="→"];
  NF_kB            -> iNOS_NO          [label="→"];
  NLRP3_Inflamsome -> IL1_beta         [label="cleaves pro-IL-1β"];
  ROS_Oxidative    -> NLRP3_Inflamsome [label="activates"];
  ThOx2            -> ROS_Oxidative    [label="H₂O₂ excess"];
  GPx_Activity     -> ROS_Oxidative    [label="scavenges", style=dashed];
  Selenoprotein_P  -> Se_DIO_Cofactor  [label="Se delivery"];
  CXCL10_IP10      -> Lymph_Infiltrate [label="Th1 attraction"];
  CCL5_RANTES      -> Lymph_Infiltrate [label="chemoattract"];
  CXCL9_CXCL11    -> Lymph_Infiltrate;
  Type_I_IFN       -> M1_Macrophage    [label="primes"];
  IL1_beta         -> NF_kB            [label="amplification", constraint=false];
  IL6_Innate       -> IL23_Signaling   [label="Th17 skewing"];
  iNOS_NO          -> ROS_Oxidative    [label="peroxynitrite"];

  // Drug PK
  LT4_Oral_Dose    -> LT4_Gut          [label="oral absorption"];
  LT4_Food_Effect  -> LT4_Gut          [label="↓ absorption", style=dashed, color="#E74C3C"];
  LT4_Gut          -> LT4_Central      [label="ka ~0.48 h⁻¹"];
  LT4_Central      -> LT4_Peripheral   [label="k12"];
  LT4_Peripheral   -> LT4_Central      [label="k21"];
  LT4_Central      -> LT4_Elimination  [label="ke (t½~7 d)"];
  LT4_Central      -> LT4_Protein_Bind [label="TBG binds"];
  LT4_Central      -> LT4_DIO_Convert  [label="DIO1/DIO2"];
  LT4_DIO_Convert  -> T3_Plasma        [label="adds T3 pool"];
  LT4_Central      -> T4_Plasma        [label="adds fT4"];
  LiT3_Oral_Dose   -> LiT3_Central     [label="rapid abs\nt½~1 day"];
  LiT3_Central     -> T3_Plasma        [label="rapid peak"];
  Se_Oral_Dose     -> Se_Plasma        [label="F~85%"];
  Se_Plasma        -> Se_Tissue_Depot  [label="distribution"];
  Se_Tissue_Depot  -> Selenoprotein_P  [label="incorporates"];
  Se_Plasma        -> GPx_Activity     [label="selenoprotein\ncofactor"];
  Se_Plasma        -> Se_DIO_Cofactor  [label="DIO selenocysteine"];
  MMI_Oral_Dose    -> MMI_Plasma       [label="rapid abs, F~95%\nt½~6 h"];
  PTU_Oral_Dose    -> PTU_Plasma       [label="abs, t½~1–2 h"];

  // Drug PD
  T4_Plasma        -> LT4_HPT_Feedback [label="→ D2 → T3"];
  T3_Plasma        -> LT4_HPT_Feedback [label="direct"];
  LT4_HPT_Feedback -> TSH_Normalization [label="TSH ↓ to normal"];
  TSH_Normalization -> Symptom_Relief;
  Symptom_Relief   -> Fatigue_Score    [label="FSS ↓"];
  Symptom_Relief   -> Depression_Score [label="PHQ-9 ↓"];
  Symptom_Relief   -> Cognitive_Func   [label="improves"];
  Symptom_Relief   -> Hair_Skin_CL     [label="improves"];
  Symptom_Relief   -> Cold_Intolerance [label="resolves"];
  LT4_Central      -> LT4_BMR_Effect   [label="BMR restored"];
  LT4_BMR_Effect   -> BMI_Weight_Clin  [label="BMI ↓"];
  LT4_Central      -> LT4_Cardiac_Eff;
  LT4_Cardiac_Eff  -> Heart_Rate_Clin  [label="HR normalized"];
  LT4_Central      -> LT4_Lipid_Eff;
  LT4_Lipid_Eff    -> LDL_Chol_Clin    [label="LDL-C ↓"];
  Se_Plasma        -> Se_GPx_Effect;
  Se_GPx_Effect    -> ROS_Oxidative    [label="↓ ROS", style=dashed];
  Se_GPx_Effect    -> Thyrocyte_Apop   [label="↓ apoptosis", style=dashed];
  Se_Plasma        -> Se_DIO_Effect;
  Se_DIO_Effect    -> T3_Plasma        [label="T4→T3 ↑"];
  Se_Plasma        -> Se_Ab_Reduction;
  Se_Ab_Reduction  -> Anti_TPO_Ab      [label="titer ↓", style=dashed];
  Se_Ab_Reduction  -> Anti_Tg_Ab       [label="titer ↓", style=dashed];
  Se_Plasma        -> Se_NF_kB_Effect;
  Se_NF_kB_Effect  -> NF_kB            [label="suppresses", style=dashed];
  Se_Plasma        -> Se_Apoptosis_Eff;
  Se_Apoptosis_Eff -> Thyrocyte_Apop   [label="↓ apoptosis", style=dashed];
  Se_Plasma        -> Se_Pregnancy_Eff [label="postpartum\nthyroiditis ↓", style=dashed];
  MMI_Plasma       -> MMI_TPO_Block;
  MMI_TPO_Block    -> TPO_Enzyme       [label="irreversible\ninhibition", style=dashed, color="#E74C3C"];
  MMI_TPO_Block    -> Organification   [label="blocks", style=dashed, color="#E74C3C"];
  PTU_Plasma       -> PTU_TPO_DIO_Block;
  PTU_TPO_DIO_Block -> TPO_Enzyme      [label="inhibits", style=dashed, color="#E74C3C"];
  PTU_TPO_DIO_Block -> DIO1            [label="inhibits DIO1", style=dashed, color="#E74C3C"];
  LT4_Oral_Dose    -> LT4_Excess_Bone  [label="excess dose"];
  LT4_Excess_Bone  -> BMD_Score        [label="T-score ↓"];
  LT4_Oral_Dose    -> LT4_Excess_Cardiac [label="overdose"];
  LT4_Excess_Cardiac -> Heart_Rate_Clin [label="AF risk ↑"];
  LiT3_Central     -> Combo_T4_T3;
  LT4_Central      -> Combo_T4_T3;
  Combo_T4_T3      -> T3_Plasma        [label="stable T3 level"];
  Combo_T4_T3      -> QoL_Score        [label="some patients"];
  LT4_Central      -> LT4_Weight_Effect;
  LT4_Weight_Effect -> BMI_Weight_Clin [label="moderate effect"];

  // Clinical biomarkers from physiology
  T4_Plasma        -> fT4_Biomarker;
  T3_Plasma        -> fT3_Biomarker;
  TSH_Serum        -> TSH_Biomarker;
  Anti_TPO_Ab      -> AntiTPO_Biomarker;
  Anti_Tg_Ab       -> AntiTg_Biomarker;
  Thyrocyte_Apop   -> Thyroid_Damage   [label="cumulative"];
  Thyroid_Damage   -> T4_Secretion     [label="↓ capacity", style=dashed, color="#E74C3C"];
  Thyroid_Damage   -> T3_Secretion     [label="↓ capacity", style=dashed, color="#E74C3C"];
  Thyroid_Damage   -> Goiter_Size      [label="early ↑"];
  Thyroid_Damage   -> Thyroid_Vol_US   [label="correlates"];
  Thermogenesis    -> BMI_Weight_Clin  [label="basal T3 effect"];
  Cardiac_Genes    -> Heart_Rate_Clin  [label="HCN4 → rate"];
  Lipid_Genes      -> LDL_Chol_Clin    [label="LDLr ↑ → LDL ↓"];
  Bone_Genes       -> BMD_Score        [label="RANKL/OPG"];

  // Comorbidities
  Thyroid_Damage   -> Subclinical_HypoT [label="↓ T4 → TSH↑"];
  Subclinical_HypoT -> Overt_HypoT     [label="progression\n(~3–5%/year)"];
  Overt_HypoT      -> Dyslipidemia_Co  [label="LDLr ↓ → LDL↑"];
  Overt_HypoT      -> CV_Risk_Co       [label="atherosclerosis"];
  Overt_HypoT      -> Depr_Anxiety_Co  [label="neuropsychiatric"];
  Overt_HypoT      -> Infertility_Co   [label="anovulation"];
  Overt_HypoT      -> Diastolic_HTN    [label="SVR↑"];
  Overt_HypoT      -> Myxedema_CL      [label="severe"];
  Myxedema_CL      -> HFpEF_Risk       [label="cardiac dysfunction"];
  Infertility_Co   -> Preg_Complication [label="if pregnancy occurs"];
  Preg_Complication -> Fetal_Neuro     [label="maternal T4 critical"];
  LT4_Excess_Bone  -> Osteoporosis_Co  [label="long-term"];
  Lymph_Infiltrate -> MALT_Lymphoma    [label="MALT formation"];
  Lymph_Infiltrate -> Other_AI_Co      [label="polyautoimmunity"];
  Anti_TPO_Ab      -> Hashimoto_Enc    [label="rare CNS\ncross-reactivity"];
  Dyslipidemia_Co  -> CV_Risk_Co       [label="CAD risk"];
  Diastolic_HTN    -> HFpEF_Risk       [label="contributes"];
}
