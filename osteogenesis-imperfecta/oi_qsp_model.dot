digraph OI_QSP {
  rankdir=LR;
  compound=true;
  fontname="Helvetica";
  fontsize=22;
  labelloc="t";
  label="Osteogenesis Imperfecta (OI) — Type I Collagen Defect → Bone Fragility QSP Mechanistic Map\nCOL1A1/COL1A2/CRTAP-P3H1-CYPB Pathway · Osteoblast-Osteoclast Coupling · Anti-resorptive/Anabolic/Anti-sclerostin/Anti-TGF-β Therapy";
  node [style=filled, fontname="Helvetica", fontsize=11, shape=box, margin="0.12,0.06"];
  edge [fontname="Helvetica", fontsize=9, color="#555555"];

  /* ============ CLUSTER 1: GENETIC ETIOLOGY ============ */
  subgraph cluster_genetics {
    label="1. 유전적 병인 (Genetic Etiology)";
    style=filled; color="#FBEEE6"; fontsize=13;
    G1 [label="COL1A1 mutation\n(17q21.33, glycine substitution)", fillcolor="#F5B7B1"];
    G2 [label="COL1A2 mutation\n(7q21.3, glycine substitution)", fillcolor="#F5B7B1"];
    G3 [label="Type I collagen\nquantitative defect\n(null allele, OI type I)", fillcolor="#F5B7B1"];
    G4 [label="Type I collagen\nqualitative defect\n(structural, OI type II-IV)", fillcolor="#F5B7B1"];
    G5 [label="CRTAP mutation\n(3p22.3)", fillcolor="#F1948A"];
    G6 [label="P3H1/LEPRE1 mutation\n(1p34.2)", fillcolor="#F1948A"];
    G7 [label="PPIB/CYPB mutation\n(15q22.31)", fillcolor="#F1948A"];
    G8 [label="Prolyl 3-hydroxylation\ncomplex dysfunction\n(recessive OI type VII-VIII)", fillcolor="#F1948A"];
    G9 [label="SERPINH1 (HSP47)\nmutation", fillcolor="#EDBB99"];
    G10 [label="FKBP10 mutation", fillcolor="#EDBB99"];
    G11 [label="Collagen chaperone/\npost-translational\nfolding defect", fillcolor="#EDBB99"];
    G12 [label="IFITM5 mutation\n(OI type V, mesh-like bone)", fillcolor="#D7BDE2"];
    G13 [label="WNT1 mutation\n(recessive, low BMD)", fillcolor="#D7BDE2"];
    G14 [label="SP7/Osterix mutation", fillcolor="#D7BDE2"];
    G1 -> G3; G1 -> G4; G2 -> G3; G2 -> G4;
    G5 -> G8; G6 -> G8; G7 -> G8;
    G9 -> G11; G10 -> G11;
    G8 -> G4; G11 -> G4;
  }

  /* ============ CLUSTER 2: COLLAGEN BIOSYNTHESIS ============ */
  subgraph cluster_biosynth {
    label="2. 콜라겐 생합성/분비 경로 (Collagen Biosynthesis)";
    style=filled; color="#EBF5FB"; fontsize=13;
    B1 [label="Pro-alpha1(I)/\npro-alpha2(I) chain\nsynthesis (ER)", fillcolor="#AED6F1"];
    B2 [label="Triple helix\nregistration/folding", fillcolor="#AED6F1"];
    B3 [label="Prolyl 4-hydroxylase\n(P4H) hydroxylation", fillcolor="#AED6F1"];
    B4 [label="Lysyl hydroxylase\n(LH1/PLOD2) modification", fillcolor="#AED6F1"];
    B5 [label="HSP47 chaperone\nbinding/quality control", fillcolor="#AED6F1"];
    B6 [label="Procollagen\nER-to-Golgi transport", fillcolor="#85C1E9"];
    B7 [label="ER stress /\nunfolded protein response\n(UPR, misfolded collagen retention)", fillcolor="#5DADE2"];
    B8 [label="Procollagen\nC/N-proteinase cleavage\n(BMP1, ADAMTS2/3)", fillcolor="#85C1E9"];
    B9 [label="Fibril self-assembly\n& lateral packing", fillcolor="#3498DB"];
    B10 [label="Lysyl oxidase (LOX)\ncross-linking", fillcolor="#3498DB"];
    B11 [label="Mature type I collagen\nfibril (bone matrix)", fillcolor="#2E86C1", fontcolor=white];
    G3 -> B1; G4 -> B2 [label="misfolded\nhelix"];
    B1 -> B2; B2 -> B3; B2 -> B4; B3 -> B5; B4 -> B5;
    B5 -> B6; B2 -> B7 [label="delayed folding\n(slower helix\npropagation)", color="#CB4335"];
    B7 -> B6 [style=dashed, color="#CB4335", label="ER retention/\napoptosis"];
    B6 -> B8; B8 -> B9; B9 -> B10; B10 -> B11;
    G11 -> B5 [label="chaperone\ndeficiency"];
    G8 -> B4 [label="3-Hyp\nmodification loss"];
  }

  /* ============ CLUSTER 3: BONE MATRIX & OSTEOBLAST ============ */
  subgraph cluster_matrix {
    label="3. 골기질/조골세포 기능이상 (Matrix & Osteoblast Dysfunction)";
    style=filled; color="#EAFAF1"; fontsize=13;
    M1 [label="Osteoblast\ndifferentiation\n(Runx2/Osterix)", fillcolor="#A9DFBF"];
    M2 [label="Defective collagen\nmatrix deposition", fillcolor="#82E0AA", fontcolor=black];
    M3 [label="Reduced\nmineral-to-matrix\nratio abnormality", fillcolor="#58D68D"];
    M4 [label="Hypermineralization\nof abnormal matrix\n(compensatory)", fillcolor="#28B463", fontcolor=white];
    M5 [label="Decreased trabecular\n& cortical bone volume", fillcolor="#1E8449", fontcolor=white];
    M6 [label="Reduced bone\nmaterial strength\n(brittleness)", fillcolor="#145A32", fontcolor=white];
    M7 [label="Osteoblast\napoptosis (UPR-driven)", fillcolor="#E74C3C", fontcolor=white];
    M8 [label="Osteocyte\nnetwork disruption", fillcolor="#CB4335", fontcolor=white];
    B11 -> M2; B7 -> M7;
    M1 -> M2; M2 -> M3; M3 -> M4; M4 -> M5; M3 -> M6; M5 -> M6;
    M7 -> M1 [style=dashed, label="reduced\nosteoblast\nnumber", color="#CB4335"];
    M8 -> M6;
  }

  /* ============ CLUSTER 4: SCLEROSTIN/WNT & RANKL-OPG COUPLING ============ */
  subgraph cluster_coupling {
    label="4. 골재형성 커플링: WNT/Sclerostin · RANKL-OPG (Remodeling Coupling)";
    style=filled; color="#FEF9E7"; fontsize=13;
    C1 [label="Osteocyte\nSOST/sclerostin\nsecretion", fillcolor="#F9E79F"];
    C2 [label="Sclerostin binds\nLRP5/6 co-receptor", fillcolor="#F7DC6F"];
    C3 [label="Wnt/beta-catenin\nsignaling inhibition", fillcolor="#F4D03F"];
    C4 [label="Reduced\nosteoblastogenesis", fillcolor="#F1C40F"];
    C5 [label="RANKL expression\n(osteocyte/osteoblast)", fillcolor="#E67E22", fontcolor=white];
    C6 [label="OPG (osteoprotegerin)\ndecoy receptor", fillcolor="#F0B27A"];
    C7 [label="RANKL/OPG ratio\nelevated in OI", fillcolor="#D35400", fontcolor=white];
    C8 [label="Osteoclast\nprecursor recruitment\n(RANK signaling)", fillcolor="#BA4A00", fontcolor=white];
    C9 [label="Osteoclast\ndifferentiation &\nactivation", fillcolor="#A04000", fontcolor=white];
    C10 [label="Elevated bone\nresorption\n(high bone turnover)", fillcolor="#7E3A0A", fontcolor=white];
    M8 -> C1; C1 -> C2; C2 -> C3; C3 -> C4; C4 -> M1 [style=dashed, color="#CB4335"];
    C1 -> C5; C5 -> C7; C6 -> C7 [arrowhead=tee]; C7 -> C8; C8 -> C9; C9 -> C10;
    C10 -> M5 [color="#CB4335", label="uncoupled\nresorption>formation"];
  }

  /* ============ CLUSTER 5: TGF-BETA SIGNALING EXCESS ============ */
  subgraph cluster_tgfb {
    label="5. TGF-β 신호 과활성 (Excess TGF-β Bioavailability)";
    style=filled; color="#F4ECF7"; fontsize=13;
    T1 [label="Disorganized matrix\nreleases latent\nTGF-beta stores", fillcolor="#D2B4DE"];
    T2 [label="Elevated active\nTGF-beta bioavailability", fillcolor="#C39BD3"];
    T3 [label="SMAD2/3\nphosphorylation", fillcolor="#AF7AC5"];
    T4 [label="Impaired\nosteoblast maturation", fillcolor="#9B59B6", fontcolor=white];
    T5 [label="Increased\nosteoclastogenesis\n(TGF-b/RANKL synergy)", fillcolor="#884EA0", fontcolor=white];
    T6 [label="Muscle weakness /\nmyopathy component", fillcolor="#7D3C98", fontcolor=white];
    T7 [label="Fresolimumab\n(anti-TGF-beta mAb,\ninvestigational, Grafe 2014\nNat Med / NCT03064074)", fillcolor="#5B2C6F", fontcolor=white];
    M2 -> T1; T1 -> T2; T2 -> T3; T3 -> T4; T3 -> T5; T2 -> T6;
    T4 -> M1 [style=dashed, color="#CB4335"];
    T5 -> C9 [color="#CB4335"];
    T7 -> T2 [arrowhead=tee, color="#117A65", label="neutralizes\nactive TGF-b"];
  }

  /* ============ CLUSTER 6: SKELETAL PHENOTYPE / CLASSIFICATION ============ */
  subgraph cluster_phenotype {
    label="6. 골격 표현형 및 Sillence 분류 (Skeletal Phenotype & Classification)";
    style=filled; color="#FDEDEC"; fontsize=13;
    P1 [label="Type I OI\n(mild, non-deforming)", fillcolor="#FADBD8"];
    P2 [label="Type II OI\n(perinatal lethal)", fillcolor="#F1948A"];
    P3 [label="Type III OI\n(progressively\ndeforming, severe)", fillcolor="#EC7063"];
    P4 [label="Type IV OI\n(moderate severity)", fillcolor="#E74C3C", fontcolor=white];
    P5 [label="Type V-VIII OI\n(recessive/rare variants)", fillcolor="#CB4335", fontcolor=white];
    P6 [label="Recurrent long-bone\nfractures (low trauma)", fillcolor="#B03A2E", fontcolor=white];
    P7 [label="Progressive\nlong-bone bowing/\ndeformity", fillcolor="#943126", fontcolor=white];
    P8 [label="Vertebral compression\nfractures / scoliosis", fillcolor="#78281F", fontcolor=white];
    P9 [label="Short stature /\ngrowth impairment", fillcolor="#943126", fontcolor=white];
    P10 [label="Basilar invagination\n(craniocervical)", fillcolor="#78281F", fontcolor=white];
    G3 -> P1; G4 -> P2; G4 -> P3; G4 -> P4; G8 -> P5; G11 -> P5; G13 -> P5;
    M6 -> P6; P6 -> P7; P7 -> P8; T4 -> P9; P3 -> P10; P4 -> P10;
  }

  /* ============ CLUSTER 7: EXTRASKELETAL MANIFESTATIONS ============ */
  subgraph cluster_extraskeletal {
    label="7. 골외 증상 (Extraskeletal Manifestations)";
    style=filled; color="#EBF5FB"; fontsize=13;
    E1 [label="Dentinogenesis\nimperfecta\n(dentin collagen defect)", fillcolor="#AED6F1"];
    E2 [label="Blue/gray sclerae\n(thin collagen-poor\nsclera, choroid visible)", fillcolor="#85C1E9"];
    E3 [label="Hearing loss\n(otosclerosis-like,\nossicular collagen)", fillcolor="#5DADE2"];
    E4 [label="Cardiac valve\nregurgitation /\naortic root dilation", fillcolor="#3498DB", fontcolor=white];
    E5 [label="Ligamentous laxity /\njoint hypermobility", fillcolor="#2E86C1", fontcolor=white];
    E6 [label="Easy bruising /\nvascular fragility", fillcolor="#21618C", fontcolor=white];
    E7 [label="Pulmonary\nrestrictive disease\n(chest deformity)", fillcolor="#1B4F72", fontcolor=white];
    M2 -> E1; M2 -> E2; M2 -> E3; M2 -> E4; M2 -> E5; M2 -> E6; P8 -> E7;
  }

  /* ============ CLUSTER 8: PAIN / DISABILITY / QOL ENDPOINTS ============ */
  subgraph cluster_clinical {
    label="8. 임상 엔드포인트 (Clinical & Functional Endpoints)";
    style=filled; color="#FEF5E7"; fontsize=13;
    CL1 [label="Annualized\nfracture rate (AFR)", fillcolor="#FAD7A0"];
    CL2 [label="Areal BMD\n(DXA Z-score)\nlumbar spine", fillcolor="#F8C471"];
    CL3 [label="Bone turnover\nmarkers\n(P1NP, CTX, BSAP)", fillcolor="#F5B041"];
    CL4 [label="Height /\ngrowth velocity\n(Z-score)", fillcolor="#F39C12"];
    CL5 [label="Mobility function\n(6MWT, Bleck score,\nPODCI)", fillcolor="#E67E22", fontcolor=white];
    CL6 [label="Chronic pain /\nquality of life\n(PedsQL, SF-36)", fillcolor="#D68910", fontcolor=white];
    CL7 [label="Vertebral\ncompression fracture\ncount", fillcolor="#CA6F1E", fontcolor=white];
    P6 -> CL1; M5 -> CL2; C10 -> CL3; M2 -> CL3; P9 -> CL4;
    P7 -> CL5; P8 -> CL5; P6 -> CL6; P8 -> CL6; P8 -> CL7;
  }

  /* ============ CLUSTER 9: BISPHOSPHONATE PK/PD ============ */
  subgraph cluster_bp {
    label="9. 비스포스포네이트 PK/PD (Bisphosphonate Therapy)";
    style=filled; color="#E8F8F5" fontsize=13;
    BP1 [label="IV Pamidronate\n(cyclical, q3-4mo)", fillcolor="#A3E4D7"];
    BP2 [label="IV Zoledronic acid\n(annual/semi-annual)", fillcolor="#76D7C4"];
    BP3 [label="Oral Alendronate/\nRisedronate", fillcolor="#48C9B0"];
    BP4 [label="Skeletal uptake\n(hydroxyapatite\nbinding, central Csk)", fillcolor="#1ABC9C"];
    BP5 [label="Renal elimination\n(unbound fraction)", fillcolor="#17A589"];
    BP6 [label="Osteoclast FPPS\ninhibition\n(mevalonate pathway)", fillcolor="#148F77", fontcolor=white];
    BP7 [label="Osteoclast\napoptosis", fillcolor="#117A65", fontcolor=white];
    BP8 [label="Reduced bone\nresorption", fillcolor="#0E6655", fontcolor=white];
    BP9 [label="Acute phase\nreaction (fever,\nmyalgia, 1st infusion)", fillcolor="#E74C3C", fontcolor=white];
    BP10 [label="Hypocalcemia\nrisk", fillcolor="#C0392B", fontcolor=white];
    BP11 [label="Osteonecrosis of jaw /\natypical femoral fracture\n(long-term risk)", fillcolor="#922B21", fontcolor=white];
    BP1 -> BP4; BP2 -> BP4; BP3 -> BP4; BP4 -> BP5;
    BP4 -> BP6; BP6 -> BP7; C9 -> BP7 [style=dashed]; BP7 -> BP8; BP8 -> C10 [arrowhead=tee, color="#117A65"];
    BP1 -> BP9; BP2 -> BP9; BP8 -> BP10; BP4 -> BP11 [style=dashed];
    BP8 -> CL1 [arrowhead=tee, color="#117A65", label="reduces\nfracture"];
    BP8 -> CL2 [color="#117A65", label="increases\nBMD"];
    BP8 -> CL3 [arrowhead=tee, color="#117A65"];
  }

  /* ============ CLUSTER 10: DENOSUMAB / ANTI-RANKL PK/PD ============ */
  subgraph cluster_dmab {
    label="10. 데노수맙 PK/PD (Anti-RANKL mAb)";
    style=filled; color="#FDF2E9" fontsize=13;
    D1 [label="Denosumab SC\n(60mg q6mo, off-label\npediatric dosing)", fillcolor="#F5CBA7"];
    D2 [label="Target-mediated\ndrug disposition\n(RANKL binding)", fillcolor="#F0B27A"];
    D3 [label="Free RANKL\nneutralization", fillcolor="#EB984E"];
    D4 [label="Osteoclastogenesis\nblockade", fillcolor="#E67E22", fontcolor=white];
    D5 [label="Rebound\nhypercalcemia/\nresorption on\ndiscontinuation", fillcolor="#CA6F1E", fontcolor=white];
    D1 -> D2; D2 -> D3; D3 -> C8 [arrowhead=tee, color="#CA6F1E"]; D3 -> D4;
    D4 -> C10 [arrowhead=tee, color="#CA6F1E"];
    D4 -> CL1 [arrowhead=tee, color="#CA6F1E"];
    D4 -> CL2 [color="#CA6F1E"];
    D5 -> C10 [color="#CB4335", label="withdrawal\nflare"];
  }

  /* ============ CLUSTER 11: TERIPARATIDE / ANABOLIC ============ */
  subgraph cluster_anabolic {
    label="11. 테리파라타이드/아나볼릭 (PTH Analog — Contraindicated in Growing Bone)";
    style=filled; color="#FBEEE6" fontsize=13;
    A1 [label="Teriparatide SC\n(daily, adult\nOI type I only)", fillcolor="#F5B7B1"];
    A2 [label="Intermittent PTH1R\nactivation (osteoblast)", fillcolor="#F1948A"];
    A3 [label="Increased bone\nformation\n(anabolic window)", fillcolor="#EC7063", fontcolor=white];
    A4 [label="Contraindicated:\nopen growth plates\n(osteosarcoma risk)", fillcolor="#B03A2E", fontcolor=white];
    A1 -> A2; A2 -> A3; A3 -> M1 [color="#117A65"]; A2 -> A4 [style=dashed, color="#922B21"];
    A3 -> CL2 [color="#117A65"];
  }

  /* ============ CLUSTER 12: ANTI-SCLEROSTIN (SETRUSUMAB) INVESTIGATIONAL ============ */
  subgraph cluster_setrusumab {
    label="12. 항-스클레로스틴 항체 (Setrusumab, Investigational)";
    style=filled; color="#F4ECF7" fontsize=13;
    S1 [label="Setrusumab IV\n(anti-sclerostin mAb,\nq4wk, ASTEROID/ORBIT\nNCT03118570/NCT05125276)", fillcolor="#D2B4DE"];
    S2 [label="Sclerostin\nneutralization", fillcolor="#C39BD3"];
    S3 [label="Restored Wnt/\nbeta-catenin\nosteoblastogenesis", fillcolor="#AF7AC5", fontcolor=white];
    S4 [label="Reduced\nRANKL-driven\nosteoclastogenesis\n(coupling shift)", fillcolor="#9B59B6", fontcolor=white];
    S1 -> S2; S2 -> C2 [arrowhead=tee, color="#117A65", label="blocks\nLRP5/6 inhibition"];
    S2 -> S3; S2 -> S4; S3 -> M1 [color="#117A65"]; S4 -> C9 [arrowhead=tee, color="#117A65"];
    S3 -> CL1 [arrowhead=tee, color="#117A65"];
    S3 -> CL2 [color="#117A65"];
  }

  /* ============ CLUSTER 13: SURGICAL / REHABILITATION INTERVENTIONS ============ */
  subgraph cluster_surgery {
    label="13. 수술/재활 중재 (Surgical & Rehabilitative Interventions)";
    style=filled; color="#EAFAF1" fontsize=13;
    SU1 [label="Intramedullary\nrodding (Fassier-Duval,\ntelescoping rod)", fillcolor="#A9DFBF"];
    SU2 [label="Spinal fusion\n(severe scoliosis)", fillcolor="#82E0AA"];
    SU3 [label="Physical therapy /\nweight-bearing\nexercise program", fillcolor="#58D68D"];
    SU4 [label="Vitamin D /\ncalcium\nsupplementation", fillcolor="#28B463", fontcolor=white];
    SU5 [label="Fracture healing\n& remodeling", fillcolor="#1E8449", fontcolor=white];
    SU1 -> P7 [arrowhead=tee, color="#117A65", label="prevents\nrefracture/bowing"];
    SU2 -> P8 [arrowhead=tee, color="#117A65"];
    SU3 -> CL5 [color="#117A65"];
    SU4 -> M3 [color="#117A65"];
    P6 -> SU5; SU5 -> M5 [style=dashed];
  }

  /* ============ CLUSTER 14: PK COMPARTMENT SUMMARY (cross-links) ============ */
  subgraph cluster_pklink {
    label="14. 약물-질환 통합 피드백 (Integrated Drug-Disease Feedback)";
    style=filled; color="#FDF2E9" fontsize=13;
    F1 [label="Bone remodeling\nunit (BMU)\nactivation frequency", fillcolor="#F5CBA7"];
    F2 [label="Coupled\nformation-resorption\nbalance", fillcolor="#EB984E"];
    F3 [label="Net bone mineral\ncontent trajectory", fillcolor="#CA6F1E", fontcolor=white];
    C10 -> F1; M1 -> F1; F1 -> F2; F2 -> F3; F3 -> CL2; F3 -> CL1 [arrowhead=tee];
    BP8 -> F2 [color="#117A65"]; D4 -> F2 [color="#117A65"]; S3 -> F2 [color="#117A65"]; A3 -> F2 [color="#117A65"];
  }

  { rank=same; G1; G2; G5; G6; G7; G9; G10; G12; G13; G14; }
  { rank=same; CL1; CL2; CL3; CL4; CL5; CL6; CL7; }
}
