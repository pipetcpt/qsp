digraph RP_QSP {
  rankdir=LR;
  compound=true;
  fontname="Helvetica";
  fontsize=22;
  labelloc="t";
  label="Retinitis Pigmentosa (RP) — Inherited Photoreceptor Degeneration QSP Mechanistic Map\nRHO/RPGR/USH2A/PDE6/RPE65 Genotypes · Rod-Cone Secondary Death · Gene/Optogenetic/Neuroprotective Therapy PK/PD";
  node [style=filled, fontname="Helvetica", fontsize=11, shape=box, margin="0.12,0.06"];
  edge [fontname="Helvetica", fontsize=9, color="#555555"];

  /* ============ CLUSTER 1: GENETIC ETIOLOGY ============ */
  subgraph cluster_genetics {
    label="1. 유전적 병인 (Genetic Etiology, 90+ genes)";
    style=filled; color="#FBEEE6"; fontsize=13;
    G1  [label="RHO mutation\n(4q21.2, AD,\n~25% adRP, P23H hotspot)", fillcolor="#F5B7B1"];
    G2  [label="RPGR mutation\n(Xp11.4, ORF15,\n~70% XLRP)", fillcolor="#F1948A"];
    G3  [label="RP2 mutation\n(Xp11.23, minor XLRP)", fillcolor="#F1948A"];
    G4  [label="USH2A mutation\n(1q41, AR,\nsyndromic/nonsyndromic)", fillcolor="#EC7063"];
    G5  [label="PDE6A/PDE6B\nmutation (AR,\nphosphodiesterase)", fillcolor="#E74C3C", fontcolor=white];
    G6  [label="RPE65 mutation\n(1p31.3, AR,\nLCA2/EOSRD)", fillcolor="#CB4335", fontcolor=white];
    G7  [label="CRB1 mutation\n(1q31.3, AR,\nCoats-like RP/LCA)", fillcolor="#D7BDE2"];
    G8  [label="NR2E3 mutation\n(15q23, enhanced\nS-cone syndrome)", fillcolor="#D7BDE2"];
    G9  [label="RP1 mutation\n(8q12.1, AD/AR)", fillcolor="#D2B4DE"];
    G10 [label="EYS mutation\n(6q12, AR,\nlargest human gene)", fillcolor="#D2B4DE"];
    G11 [label="PRPF31/PRPF8/\nPRPF3 mutation\n(splicing factor, AD,\nincomplete penetrance)", fillcolor="#C39BD3"];
    G12 [label="BBS1-21 mutation\n(Bardet-Biedl,\nciliopathy, syndromic)", fillcolor="#AF7AC5", fontcolor=white];
    G13 [label="Usher syndrome\nUSH1/2/3 classification\n(RP + hearing loss ±\nvestibular dysfunction)", fillcolor="#9B59B6", fontcolor=white];
    G14 [label="Digenic/mitochondrial/\nde novo variants\n(ROM1+RDS, etc.)", fillcolor="#8E44AD", fontcolor=white];
    G4 -> G13; G12 -> G7 [style=dashed];
  }

  /* ============ CLUSTER 2: MOLECULAR PHOTORECEPTOR PATHOPHYSIOLOGY ============ */
  subgraph cluster_molecular {
    label="2. 분자병태생리: 광수용체 단백질 이상 (Molecular Pathophysiology)";
    style=filled; color="#EBF5FB"; fontsize=13;
    M1  [label="Misfolded rhodopsin\n(P23H, ER retention)", fillcolor="#AED6F1"];
    M2  [label="ER stress /\nunfolded protein\nresponse (UPR)", fillcolor="#85C1E9"];
    M3  [label="CHOP-mediated\napoptotic signaling", fillcolor="#5DADE2"];
    M4  [label="PDE6 loss-of-function\n(cGMP hydrolysis failure)", fillcolor="#3498DB", fontcolor=white];
    M5  [label="Elevated intracellular\ncGMP", fillcolor="#2E86C1", fontcolor=white];
    M6  [label="CNG channel\nhyperactivation", fillcolor="#21618C", fontcolor=white];
    M7  [label="Excess Ca2+ influx\n(rod outer segment)", fillcolor="#1B4F72", fontcolor=white];
    M8  [label="Calpain/caspase-3\nactivation", fillcolor="#154360", fontcolor=white];
    M9  [label="Connecting cilium /\nIFT transport defect\n(RPGR-ORF15, BBSome)", fillcolor="#A9CCE3"];
    M10 [label="Failed rhodopsin\ntrafficking to\nouter segment", fillcolor="#7FB3D5"];
    M11 [label="mRNA splicing\ndysregulation\n(PRPF mutants)", fillcolor="#5499C7"];
    M12 [label="PARP1/PARthanatos\n& AIF-mediated\ncell death", fillcolor="#2874A6", fontcolor=white];
    M13 [label="cGMP-PKG\nexcitotoxic cascade", fillcolor="#1F618D", fontcolor=white];
    M14 [label="Photoreceptor\napoptosis\n(caspase-dependent/\nindependent)", fillcolor="#154360", fontcolor=white];
    G1 -> M1; M1 -> M2; M2 -> M3; G5 -> M4; M4 -> M5; M5 -> M6; M6 -> M7; M7 -> M8;
    G2 -> M9; G12 -> M9; M9 -> M10; G11 -> M11; M11 -> M2;
    M5 -> M13; M13 -> M12; M3 -> M14; M8 -> M14; M12 -> M14; M10 -> M14 [style=dashed];
  }

  /* ============ CLUSTER 3: ROD-CONE SECONDARY DEATH ============ */
  subgraph cluster_rodcone {
    label="3. 간상세포-원추세포 상호작용 및 이차 사멸 (Rod-Cone Secondary Death)";
    style=filled; color="#EAFAF1"; fontsize=13;
    R1 [label="Primary rod\nphotoreceptor loss\n(genotype-dependent rate)", fillcolor="#A9DFBF"];
    R2 [label="Loss of rod-derived\ncone viability factor\n(RdCVF/NXNL1)", fillcolor="#82E0AA"];
    R3 [label="Reduced retinal\noxygen consumption\n(post-rod-loss)", fillcolor="#58D68D"];
    R4 [label="Choroidal\nhyperoxia exposure\nto cones", fillcolor="#2ECC71", fontcolor=white];
    R5 [label="Oxidative stress /\nreactive oxygen\nspecies (ROS)", fillcolor="#28B463", fontcolor=white];
    R6 [label="Cone outer segment\nshortening / dormancy", fillcolor="#1E8449", fontcolor=white];
    R7 [label="Secondary cone\nphotoreceptor death", fillcolor="#145A32", fontcolor=white];
    R8 [label="Glucose/lactate\nshuttle disruption\n(Muller-photoreceptor)", fillcolor="#0B5345", fontcolor=white];
    R9 [label="Trophic factor\ndepletion (bFGF/\nCNTF endogenous)", fillcolor="#117864", fontcolor=white];
    R10 [label="mTOR/autophagy\ndysregulation in cones", fillcolor="#0E6655", fontcolor=white];
    R11 [label="Central cone-rich\nfovea relative sparing\n(until late stage)", fillcolor="#0B5345", fontcolor=white];
    R12 [label="Progressive concentric\nphotoreceptor loss\n(periphery-to-center)", fillcolor="#073B2E", fontcolor=white];
    M14 -> R1; R1 -> R2 [arrowhead=tee]; R2 -> R6 [style=dashed, color="#CB4335"];
    R1 -> R3; R3 -> R4; R4 -> R5; R5 -> R6; R6 -> R7; R1 -> R8; R8 -> R7 [style=dashed];
    R1 -> R9 [arrowhead=tee]; R9 -> R6 [style=dashed, color="#CB4335"]; R5 -> R10; R10 -> R7;
    R7 -> R11 [style=dashed]; R1 -> R12; R7 -> R12;
  }

  /* ============ CLUSTER 4: RPE & VISUAL CYCLE ============ */
  subgraph cluster_rpe {
    label="4. 망막색소상피/시각회로 (RPE & Visual Cycle)";
    style=filled; color="#FEF9E7"; fontsize=13;
    V1 [label="RPE65\nisomerohydrolase\n(all-trans to 11-cis)", fillcolor="#F9E79F"];
    V2 [label="LRAT esterification\n(retinol -> retinyl ester)", fillcolor="#F7DC6F"];
    V3 [label="11-cis-retinal\nregeneration", fillcolor="#F4D03F"];
    V4 [label="Rhodopsin/opsin\nregeneration\n(chromophore reload)", fillcolor="#F1C40F"];
    V5 [label="Apo-opsin\naccumulation\n(RPE65-null)", fillcolor="#D4AC0D", fontcolor=white];
    V6 [label="Constitutive opsin\nsignaling (dark noise)", fillcolor="#B7950B", fontcolor=white];
    V7 [label="RPE phagocytosis of\nouter segment discs", fillcolor="#9A7D0A", fontcolor=white];
    V8 [label="RPE dysfunction /\nlipofuscin accumulation", fillcolor="#7D6608", fontcolor=white];
    V9 [label="RPE migration into\nretina (bone-spicule\npigmentation)", fillcolor="#F0B27A"];
    V10 [label="IRBP-mediated\nretinoid shuttle", fillcolor="#EB984E"];
    V11 [label="Choriocapillaris /\nretinal vascular\nattenuation", fillcolor="#E67E22", fontcolor=white];
    V12 [label="Optic disc pallor\n(gliotic atrophy)", fillcolor="#CA6F1E", fontcolor=white];
    G6 -> V1 [arrowhead=tee, color="#CB4335", label="loss of\nfunction"]; V1 -> V2 [style=dashed]; V2 -> V3; V10 -> V3; V3 -> V4;
    V1 -> V5 [arrowhead=tee]; V5 -> V6; V6 -> M13 [style=dashed]; R1 -> V7 [arrowhead=tee, color="#CB4335"];
    V7 -> V8 [style=dashed]; R12 -> V9; V9 -> V8; R1 -> V11; R7 -> V11; V11 -> V12;
  }

  /* ============ CLUSTER 5: NEUROINFLAMMATION & RETINAL REMODELING ============ */
  subgraph cluster_remodel {
    label="5. 신경염증/망막 리모델링 (Neuroinflammation & Retinal Remodeling)";
    style=filled; color="#F4ECF7"; fontsize=13;
    N1 [label="Muller cell\nreactive gliosis\n(GFAP upregulation)", fillcolor="#D2B4DE"];
    N2 [label="Microglial\nactivation &\nmigration to ONL", fillcolor="#C39BD3"];
    N3 [label="Pro-inflammatory\ncytokines\n(TNF-a, IL-1b, IL-6)", fillcolor="#AF7AC5", fontcolor=white];
    N4 [label="Complement\nactivation (C3/C5)", fillcolor="#9B59B6", fontcolor=white];
    N5 [label="Bipolar/horizontal\ncell dendrite\nretraction", fillcolor="#884EA0", fontcolor=white];
    N6 [label="Aberrant neurite\nsprouting / synaptic\nrewiring", fillcolor="#7D3C98", fontcolor=white];
    N7 [label="Glial scar\nformation", fillcolor="#6C3483", fontcolor=white];
    N8 [label="Retinal ganglion\ncell relative\npreservation", fillcolor="#5B2C6F", fontcolor=white];
    N9 [label="Blood-retinal\nbarrier breakdown", fillcolor="#4A235A", fontcolor=white];
    N10 [label="Progressive inner\nretinal circuit\ndegeneration (late)", fillcolor="#3B1E4F", fontcolor=white];
    R1 -> N1; N1 -> N2; N2 -> N3; N3 -> N4; N3 -> N9; R7 -> N5; N5 -> N6; N6 -> N7;
    R12 -> N8 [style=dashed]; N8 -> N10 [style=dashed, color="#CB4335"]; N7 -> N10; N4 -> N10;
  }

  /* ============ CLUSTER 6: CLINICAL PHENOTYPE & STAGING ============ */
  subgraph cluster_phenotype {
    label="6. 임상 표현형 및 병기 (Clinical Phenotype & Staging)";
    style=filled; color="#FDEDEC"; fontsize=13;
    P1 [label="Nyctalopia\n(night blindness,\nearliest symptom)", fillcolor="#FADBD8"];
    P2 [label="Progressive\nmid-peripheral\nvisual field loss", fillcolor="#F1948A"];
    P3 [label="Ring scotoma\nformation", fillcolor="#EC7063"];
    P4 [label="Tunnel vision\n(severe peripheral\nconstriction)", fillcolor="#E74C3C", fontcolor=white];
    P5 [label="Central vision loss\n(late-stage, cone\ninvolvement)", fillcolor="#CB4335", fontcolor=white];
    P6 [label="Photopsia /\nglare sensitivity", fillcolor="#B03A2E", fontcolor=white];
    P7 [label="Legal blindness\n(BCVA <20/200 or\nVF <20 deg)", fillcolor="#943126", fontcolor=white];
    P8 [label="Syndromic RP:\nsensorineural hearing\nloss (Usher)", fillcolor="#78281F", fontcolor=white];
    P9 [label="Syndromic RP:\nobesity/polydactyly/\nrenal (Bardet-Biedl)", fillcolor="#641E16", fontcolor=white];
    P10 [label="Posterior subcapsular\ncataract (common\ncomorbidity)", fillcolor="#4E1A12", fontcolor=white];
    P11 [label="Age-of-onset spectrum\n(LCA congenital ->\nadRP 2nd-3rd decade)", fillcolor="#F5B7B1"];
    P12 [label="Disease progression\nrate by genotype\n(RPE65>RPGR>RHO>USH2A)", fillcolor="#EC7063"];
    R1 -> P1; R12 -> P2; P2 -> P3; P3 -> P4; R7 -> P5; P4 -> P6; P4 -> P7; P5 -> P7;
    G13 -> P8; G12 -> P9; R1 -> P10; G6 -> P11 [style=dashed]; G1 -> P11 [style=dashed]; G14 -> P12 [style=dashed];
  }

  /* ============ CLUSTER 7: CLINICAL ENDPOINTS & BIOMARKERS ============ */
  subgraph cluster_endpoints {
    label="7. 임상 엔드포인트 및 바이오마커 (Clinical Endpoints & Biomarkers)";
    style=filled; color="#FEF5E7"; fontsize=13;
    CL1 [label="Full-field ERG\nrod b-wave amplitude", fillcolor="#FAD7A0"];
    CL2 [label="Full-field ERG\ncone/photopic\namplitude", fillcolor="#F8C471"];
    CL3 [label="Goldmann/kinetic\nvisual field area\n(deg2, III4e)", fillcolor="#F5B041"];
    CL4 [label="Best-corrected\nvisual acuity\n(BCVA, logMAR)", fillcolor="#F39C12"];
    CL5 [label="OCT ellipsoid zone\n(EZ) width", fillcolor="#E67E22", fontcolor=white];
    CL6 [label="Fundus autofluorescence\nhyper-AF ring diameter", fillcolor="#D68910", fontcolor=white];
    CL7 [label="Full-field stimulus\nthreshold (FST)", fillcolor="#CA6F1E", fontcolor=white];
    CL8 [label="Multi-luminance\nmobility test\n(MLMT) score", fillcolor="#BA4A00", fontcolor=white];
    CL9 [label="Central subfield\nthickness (CST,\ncystoid macular edema)", fillcolor="#A04000", fontcolor=white];
    CL10 [label="Vision-related\nquality of life\n(NEI-VFQ-25)", fillcolor="#7E3A0A", fontcolor=white];
    R1 -> CL1 [arrowhead=tee, color="#CB4335"]; R7 -> CL2 [arrowhead=tee, color="#CB4335"];
    R12 -> CL3 [arrowhead=tee, color="#CB4335"]; R7 -> CL4 [arrowhead=tee, color="#CB4335"];
    R12 -> CL5 [arrowhead=tee, color="#CB4335"]; V9 -> CL6; CL1 -> CL7 [arrowhead=tee, dir=back, color="#CB4335"];
    CL1 -> CL8 [style=dashed]; CL2 -> CL8 [style=dashed]; N9 -> CL9; CL3 -> CL10 [arrowhead=tee, dir=back];
  }

  /* ============ CLUSTER 8: GENE THERAPY PK/PD ============ */
  subgraph cluster_genetherapy {
    label="8. 유전자 치료 PK/PD (AAV Gene Augmentation Therapy)";
    style=filled; color="#E8F8F5"; fontsize=13;
    GT1 [label="Voretigene neparvovec\n(AAV2-hRPE65v2,\nsubretinal, one-time,\nRPE65-biallelic only)", fillcolor="#A3E4D7"];
    GT2 [label="Subretinal bleb\nvector genome\ntransduction (RPE)", fillcolor="#76D7C4"];
    GT3 [label="Transgene RPE65\nprotein expression\n(sustained, episomal)", fillcolor="#48C9B0"];
    GT4 [label="Restored\nisomerohydrolase\nactivity", fillcolor="#1ABC9C"];
    GT5 [label="AAV capsid\nimmune response\n(pre-existing NAb,\nT-cell)", fillcolor="#E74C3C", fontcolor=white];
    GT6 [label="Peri-operative\nretinal thinning\n(foveal, surgical risk)", fillcolor="#C0392B", fontcolor=white];
    GT7 [label="Botaretigene\nsparoparvovec\n(AAV8-RPGR,\nXLRP, investigational)", fillcolor="#17A589", fontcolor=white];
    GT8 [label="Cotoretigene\ntoliparvovec\n(AAV5-RPGR,\nXIRIUS trial)", fillcolor="#148F77", fontcolor=white];
    GT9 [label="Codon-optimized\nRPGR-ORF15\nexpression cassette", fillcolor="#117A65", fontcolor=white];
    GT10 [label="Restored ciliary\nprotein trafficking\n(RPGR-corrected)", fillcolor="#0E6655", fontcolor=white];
    GT11 [label="Durability /\nlong-term transgene\nexpression (4+ yr)", fillcolor="#0B5345", fontcolor=white];
    GT12 [label="Dose-dependent\nretinal toxicity\n(high-dose AAV,\nphotoreceptor thinning)", fillcolor="#922B21", fontcolor=white];
    GT13 [label="CRISPR base/prime\nediting (RHO P23H,\ninvestigational)", fillcolor="#5DADE2"];
    GT14 [label="Mutation-independent\ngene augmentation\nlimits (dominant-negative\nRHO not amenable)", fillcolor="#2E86C1", fontcolor=white];
    GT1 -> GT2; GT2 -> GT3; GT3 -> GT4; GT4 -> V1 [color="#117A65", label="restores\nvisual cycle"];
    GT1 -> GT5 [style=dashed]; GT1 -> GT6 [style=dashed, color="#CB4335"]; GT3 -> GT11;
    GT7 -> GT9; GT8 -> GT9; GT9 -> GT10; GT10 -> M9 [color="#117A65", label="corrects\ncilium transport"];
    GT7 -> GT12 [style=dashed, color="#CB4335"]; GT13 -> M1 [color="#117A65", style=dashed];
    G1 -> GT14 [style=dashed]; GT14 -> GT13 [style=dashed];
    GT4 -> V3 [color="#117A65"]; GT4 -> V4 [color="#117A65"];
  }

  /* ============ CLUSTER 9: OPTOGENETIC THERAPY PK/PD ============ */
  subgraph cluster_optogenetic {
    label="9. 광유전학 치료 PK/PD (Optogenetic Gene Therapy)";
    style=filled; color="#FDF2E9"; fontsize=13;
    OP1 [label="MCO-010\n(AAV2-multi-characteristic\nopsin, intravitreal,\nNanoscope RESTORE)", fillcolor="#F5CBA7"];
    OP2 [label="Intravitreal vector\ndiffusion to inner\nretina", fillcolor="#F0B27A"];
    OP3 [label="MCO opsin expression\nin surviving bipolar/\nRGC cells", fillcolor="#EB984E"];
    OP4 [label="Genotype- and\nstage-independent\nlight sensitivity\n(bypass pathway)", fillcolor="#E67E22", fontcolor=white];
    OP5 [label="Broad-spectrum\nambient-light\nactivation (no\ngoggles required)", fillcolor="#CA6F1E", fontcolor=white];
    OP6 [label="Restored ON-pathway\nsignal to inner\nretina/RGC", fillcolor="#BA4A00", fontcolor=white];
    OP7 [label="Chronic intraocular\ninflammation risk\n(vector-related)", fillcolor="#E74C3C", fontcolor=white];
    OP8 [label="Functional vision\nimprovement independent\nof rod/cone survival", fillcolor="#A04000", fontcolor=white];
    OP9 [label="Foundational\noptogenetic proof-\nof-concept (ChR2,\nBusskamp 2010)", fillcolor="#F5CBA7"];
    OP10 [label="Partial visual\nfunction recovery\n(Sahel 2021 case\nreport, ChrimsonR)", fillcolor="#F0B27A"];
    OP1 -> OP2; OP2 -> OP3; N8 -> OP3 [label="requires\nRGC survival"];
    OP3 -> OP4; OP4 -> OP5; OP3 -> OP6; OP6 -> OP8; OP1 -> OP7 [style=dashed, color="#CB4335"];
    OP8 -> CL7 [arrowhead=tee, color="#117A65"]; OP8 -> CL8 [color="#117A65"];
    OP9 -> OP1 [style=dashed]; OP10 -> OP8 [style=dashed];
  }

  /* ============ CLUSTER 10: NEUROPROTECTIVE & ANTIOXIDANT THERAPY ============ */
  subgraph cluster_neuroprotect {
    label="10. 신경보호/항산화 치료 PK/PD (Neuroprotective & Antioxidant Therapy)";
    style=filled; color="#EAFAF1"; fontsize=13;
    NP1 [label="CNTF encapsulated\ncell technology\nimplant (NT-501,\nintravitreal)", fillcolor="#A9DFBF"];
    NP2 [label="Sustained\nzero-order CNTF\nrelease", fillcolor="#82E0AA"];
    NP3 [label="CNTFR-alpha/\nJAK-STAT3\nsurvival signaling", fillcolor="#58D68D"];
    NP4 [label="Anti-apoptotic\nphotoreceptor\nrescue (preclinical)", fillcolor="#28B463", fontcolor=white];
    NP5 [label="Paradoxical ERG\namplitude suppression\n(reversible, dose-\ndependent)", fillcolor="#E74C3C", fontcolor=white];
    NP6 [label="N-acetylcysteine\n(NAC) oral,\nantioxidant", fillcolor="#1E8449", fontcolor=white];
    NP7 [label="Glutathione\nrepletion / ROS\nscavenging", fillcolor="#145A32", fontcolor=white];
    NP8 [label="Vitamin A palmitate\noral 15,000 IU/day\n(Berson DBA regimen)", fillcolor="#0B5345", fontcolor=white];
    NP9 [label="Docosahexaenoic\nacid (DHA)\nsupplementation", fillcolor="#117864", fontcolor=white];
    NP10 [label="Rhodopsin\nchromophore/membrane\ncofactor support", fillcolor="#0E6655", fontcolor=white];
    NP11 [label="Recombinant RdCVF\nprotein therapy\n(investigational)", fillcolor="#0B5345", fontcolor=white];
    NP12 [label="Valproic acid\n(historical, evidence\nweak/possibly harmful)", fillcolor="#7B241C", fontcolor=white];
    NP13 [label="Modest slowing of\nERG amplitude decline\n(~20% per Berson trial)", fillcolor="#5B2C6F", fontcolor=white];
    NP14 [label="Hepatotoxicity /\nbone density monitoring\n(high-dose vit A)", fillcolor="#4A235A", fontcolor=white];
    NP1 -> NP2; NP2 -> NP3; NP3 -> NP4; NP4 -> R1 [color="#117A65", arrowhead=tee, label="slows rod\napoptosis"];
    NP3 -> NP5 [style=dashed, color="#CB4335"]; NP5 -> CL1 [arrowhead=tee, color="#CB4335"];
    NP6 -> NP7; NP7 -> R5 [arrowhead=tee, color="#117A65"]; R5 -> NP6 [style=invis];
    NP8 -> NP10; NP10 -> V4 [color="#117A65"]; NP9 -> NP10; NP8 -> NP13; NP13 -> CL1 [color="#117A65"];
    NP8 -> NP14 [style=dashed, color="#CB4335"]; NP11 -> R2 [color="#117A65", arrowhead=tee]; NP12 -> R1 [style=dashed, color="#CB4335"];
  }

  /* ============ CLUSTER 11: COMPLICATION MANAGEMENT ============ */
  subgraph cluster_complication {
    label="11. 합병증 관리 (Complication Management)";
    style=filled; color="#F4ECF7"; fontsize=13;
    CM1 [label="Cystoid macular\nedema (CME, ~10-20%\nof RP patients)", fillcolor="#D2B4DE"];
    CM2 [label="Topical dorzolamide\n(carbonic anhydrase\ninhibitor, CAI)", fillcolor="#C39BD3"];
    CM3 [label="Oral acetazolamide\n(systemic CAI)", fillcolor="#AF7AC5", fontcolor=white];
    CM4 [label="Enhanced RPE fluid\npump / subretinal\nfluid resorption", fillcolor="#9B59B6", fontcolor=white];
    CM5 [label="Reduced central\nsubfield thickness", fillcolor="#884EA0", fontcolor=white];
    CM6 [label="Posterior subcapsular\ncataract surgery\n(phacoemulsification)", fillcolor="#7D3C98", fontcolor=white];
    CM7 [label="Anti-VEGF\n(limited role, only\nsecondary CNV rare)", fillcolor="#6C3483", fontcolor=white];
    CM8 [label="Low-vision\nrehabilitation /\nassistive devices", fillcolor="#5B2C6F", fontcolor=white];
    N9 -> CM1; CM1 -> CM2; CM1 -> CM3; CM2 -> CM4; CM3 -> CM4; CM4 -> CM5; CM5 -> CL9 [color="#117A65", arrowhead=tee];
    P10 -> CM6; CM6 -> CL4 [color="#117A65"]; CM1 -> CM7 [style=dashed]; P7 -> CM8;
  }

  /* ============ CLUSTER 12: RETINAL PROSTHESIS & ASSISTIVE TECHNOLOGY ============ */
  subgraph cluster_prosthesis {
    label="12. 망막 보철/보조기기 (Retinal Prosthesis & Assistive Technology)";
    style=filled; color="#FBEEE6"; fontsize=13;
    PR1 [label="Argus II epiretinal\nimplant (60-electrode\narray, end-stage RP)", fillcolor="#F5B7B1"];
    PR2 [label="Electrical stimulation\nof surviving RGC/\ninner retina", fillcolor="#F1948A"];
    PR3 [label="Bypass of degenerated\nphotoreceptor layer", fillcolor="#EC7063"];
    PR4 [label="Light/motion\nperception restoration\n(crude spatial vision)", fillcolor="#E74C3C", fontcolor=white];
    PR5 [label="Device explantation /\nlong-term reliability\nissues (discontinued\ncommercially 2020)", fillcolor="#B03A2E", fontcolor=white];
    PR6 [label="Wearable low-vision\naids (bioptic telescope,\nsmart glasses, OCR)", fillcolor="#943126", fontcolor=white];
    N8 -> PR2 [label="requires\nRGC survival"]; PR1 -> PR2; PR2 -> PR3; PR3 -> PR4; PR4 -> CL8 [color="#117A65"];
    PR1 -> PR5 [style=dashed, color="#CB4335"]; P7 -> PR6; PR6 -> CL10 [color="#117A65"];
  }

  { rank=same; G1; G2; G4; G5; G6; G7; G8; G9; G10; G11; G12; G13; G14; }
  { rank=same; CL1; CL2; CL3; CL4; CL5; CL6; CL7; CL8; CL9; CL10; }
}
