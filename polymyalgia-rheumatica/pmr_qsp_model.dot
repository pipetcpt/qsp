digraph PMR_QSP {
  graph [
    label="Polymyalgia Rheumatica (PMR) — Quantitative Systems Pharmacology Map\nIncluding: Innate/Adaptive Immunity · IL-6/JAK-STAT · HPA Axis · Prednisolone PK/PD · Tocilizumab PK/PD · Bone Effects · Vascular/GCA · Clinical Endpoints"
    labelloc=t fontsize=22 fontname="Helvetica-Bold"
    rankdir=TB bgcolor="#FAFAFA" splines=ortho nodesep=0.5 ranksep=0.8
    compound=true
  ]
  node [shape=box style="rounded,filled" fontsize=10 fontname="Helvetica" width=1.6 height=0.4]
  edge [fontsize=8 fontname="Helvetica" arrowsize=0.7]

  /* ================================================================
     CLUSTER 1: EPIDEMIOLOGY / RISK FACTORS
  ================================================================ */
  subgraph cluster_epidemiology {
    label="Epidemiology & Risk Factors" style=filled fillcolor="#FFF9E6"
    color="#E6C200" penwidth=2 fontsize=13 fontname="Helvetica-Bold"

    Age_ge50       [label="Age ≥ 50\n(peak 70–80y)" fillcolor="#FFE066"]
    Female_sex     [label="Female Sex\n(F:M ≈ 2–3:1)" fillcolor="#FFE066"]
    Nordic_ancestry [label="Northern European\nAncestry" fillcolor="#FFE066"]
    HLA_DRB1_04    [label="HLA-DRB1*04\n(Shared Epitope)" fillcolor="#FFD966"]
    HLA_DRB1_01    [label="HLA-DRB1*01\nSusceptibility" fillcolor="#FFD966"]
    PTPN22_variant [label="PTPN22 R620W\nVariant" fillcolor="#FFD966"]
    Env_trigger    [label="Environmental Trigger\n(Infection, Season)" fillcolor="#FFCC66"]
    Seasonal_peak  [label="Seasonal Clustering\n(Spring-Summer)" fillcolor="#FFCC66"]
    Incidence_rate [label="Incidence Rate\n~50–100/100,000/y" fillcolor="#FFE599"]
    Genetic_susceptibility [label="Genetic\nSusceptibility" fillcolor="#FFD966"]
  }

  /* ================================================================
     CLUSTER 2: INNATE IMMUNITY
  ================================================================ */
  subgraph cluster_innate {
    label="Innate Immunity" style=filled fillcolor="#E8F5E9"
    color="#4CAF50" penwidth=2 fontsize=13 fontname="Helvetica-Bold"

    mDC          [label="Myeloid\nDendritic Cells" fillcolor="#A5D6A7"]
    pDC          [label="Plasmacytoid\nDendritic Cells" fillcolor="#A5D6A7"]
    Monocytes    [label="Monocytes\n(CD14+CD16+)" fillcolor="#81C784"]
    MacM1        [label="Macrophage M1\n(Pro-inflam)" fillcolor="#66BB6A"]
    MacM2        [label="Macrophage M2\n(Anti-inflam)" fillcolor="#A5D6A7"]
    Neutrophils  [label="Neutrophils\n(NET formation)" fillcolor="#81C784"]
    NK_cells     [label="NK Cells\n(IFN-γ source)" fillcolor="#A5D6A7"]
    NLRP3        [label="NLRP3\nInflammasome" fillcolor="#66BB6A"]
    TLR4         [label="TLR4 Signaling\n(LPS, DAMP)" fillcolor="#81C784"]
    TLR7_9       [label="TLR7/9\n(Viral RNA/DNA)" fillcolor="#81C784"]
    NF_kB_innate [label="NF-κB\n(Innate)" fillcolor="#66BB6A"]
    Complement   [label="Complement\nActivation" fillcolor="#A5D6A7"]
    C3a_C5a      [label="C3a / C5a\nAnaphylatoxins" fillcolor="#C8E6C9"]
    DAMPs        [label="DAMPs\n(HMGB1, HSP60)" fillcolor="#81C784"]
    PAMPs        [label="PAMPs\n(Microbial)" fillcolor="#81C784"]
    IL1beta_innate [label="IL-1β\n(NLRP3 → Casp1)" fillcolor="#66BB6A"]
    COX2_innate  [label="COX-2 / PGE2\n(Macrophage)" fillcolor="#A5D6A7"]
    ROS_innate   [label="Reactive Oxygen\nSpecies (ROS)" fillcolor="#C8E6C9"]
  }

  /* ================================================================
     CLUSTER 3: ADAPTIVE IMMUNITY
  ================================================================ */
  subgraph cluster_adaptive {
    label="Adaptive Immunity" style=filled fillcolor="#E3F2FD"
    color="#1565C0" penwidth=2 fontsize=13 fontname="Helvetica-Bold"

    Th1_cells    [label="CD4+ Th1 Cells\n(IFN-γ, TNF-α)" fillcolor="#90CAF9"]
    Th17_cells   [label="CD4+ Th17 Cells\n(IL-17A/F, IL-22)" fillcolor="#64B5F6"]
    Treg_cells   [label="CD4+ Treg Cells\n(FoxP3+, IL-10)" fillcolor="#BBDEFB"]
    CD8_T        [label="CD8+ T Cells\n(Cytotoxic)" fillcolor="#90CAF9"]
    B_cells      [label="B Lymphocytes\n(Memory B, GC)" fillcolor="#64B5F6"]
    Plasma_cells [label="Plasma Cells\n(Ig production)" fillcolor="#90CAF9"]
    MHC_II       [label="MHC Class II\nPresentation" fillcolor="#BBDEFB"]
    Costim_CD28  [label="CD80/86-CD28\nCostimulation" fillcolor="#BBDEFB"]
    TCR_signal   [label="TCR Signaling\n(ZAP70, LAT)" fillcolor="#90CAF9"]
    FoxP3        [label="FoxP3\n(Treg Lineage)" fillcolor="#BBDEFB"]
    RORgt        [label="RORγt\n(Th17 Lineage)" fillcolor="#64B5F6"]
    T_bet        [label="T-bet\n(Th1 Lineage)" fillcolor="#90CAF9"]
    IL2_signal   [label="IL-2 / CD25\n(T-cell Prolif)" fillcolor="#BBDEFB"]
    GCB_center   [label="Germinal Center\nB-cell Response" fillcolor="#BBDEFB"]
  }

  /* ================================================================
     CLUSTER 4: CYTOKINES & CHEMOKINES
  ================================================================ */
  subgraph cluster_cytokines {
    label="Cytokines & Chemokines" style=filled fillcolor="#FCE4EC"
    color="#C62828" penwidth=2 fontsize=13 fontname="Helvetica-Bold"

    IL6          [label="IL-6\n(Central driver)" fillcolor="#EF9A9A"]
    sIL6R        [label="Soluble IL-6Rα\n(trans-signaling)" fillcolor="#FFCDD2"]
    sgp130       [label="sgp130\n(Decoy receptor)" fillcolor="#FFCDD2"]
    IL6_complex  [label="IL-6:IL-6R:gp130\nSignaling Complex" fillcolor="#EF9A9A"]
    TNF_alpha    [label="TNF-α\n(Macrophage, Th1)" fillcolor="#EF9A9A"]
    IL17A        [label="IL-17A\n(Th17)" fillcolor="#F48FB1"]
    IL17F        [label="IL-17F\n(Th17)" fillcolor="#F48FB1"]
    IL23         [label="IL-23\n(DC → Th17)" fillcolor="#F48FB1"]
    IFN_gamma    [label="IFN-γ\n(Th1, NK)" fillcolor="#EF9A9A"]
    IL1beta      [label="IL-1β\n(Broad pro-inflam)" fillcolor="#EF9A9A"]
    IL4          [label="IL-4\n(B-cell help)" fillcolor="#F8BBD9"]
    IL10         [label="IL-10\n(Anti-inflam)" fillcolor="#F8BBD9"]
    IL13         [label="IL-13\n(Th2)" fillcolor="#F8BBD9"]
    VEGF         [label="VEGF\n(Vasoproliferation)" fillcolor="#FFCDD2"]
    TGF_beta     [label="TGF-β\n(Fibrosis, Treg)" fillcolor="#F8BBD9"]
    CXCL8        [label="CXCL8 (IL-8)\n(Neutrophil recruit)" fillcolor="#F48FB1"]
    CCL2         [label="CCL2 (MCP-1)\n(Monocyte recruit)" fillcolor="#F48FB1"]
    CXCL10       [label="CXCL10 (IP-10)\n(Th1 attract)" fillcolor="#FFCDD2"]
    MIF          [label="MIF\n(Migration Inhib F)" fillcolor="#FFCDD2"]
    IL21         [label="IL-21\n(GC / Th17 amp)" fillcolor="#F8BBD9"]
  }

  /* ================================================================
     CLUSTER 5: JAK-STAT / INTRACELLULAR SIGNALING
  ================================================================ */
  subgraph cluster_signaling {
    label="JAK-STAT & Intracellular Signaling" style=filled fillcolor="#F3E5F5"
    color="#7B1FA2" penwidth=2 fontsize=13 fontname="Helvetica-Bold"

    JAK1         [label="JAK1\n(IL-6Rβ/gp130)" fillcolor="#CE93D8"]
    JAK2         [label="JAK2\n(IFN-γR, EpoR)" fillcolor="#CE93D8"]
    TYK2         [label="TYK2\n(IL-12, IFN-α)" fillcolor="#CE93D8"]
    STAT3        [label="pSTAT3\n(IL-6 downstream)" fillcolor="#BA68C8"]
    STAT1        [label="pSTAT1\n(IFN-γ downstream)" fillcolor="#CE93D8"]
    SOCS3        [label="SOCS3\n(JAK-STAT feedback)" fillcolor="#E1BEE7"]
    PI3K_Akt     [label="PI3K-Akt\nSurvival pathway" fillcolor="#CE93D8"]
    mTOR         [label="mTOR\n(T-cell metabolism)" fillcolor="#BA68C8"]
    NF_kB_adapt  [label="NF-κB\n(Adaptive)" fillcolor="#BA68C8"]
    IkB_alpha    [label="IκBα\n(NF-κB inhibitor)" fillcolor="#E1BEE7"]
    MAPK_ERK     [label="MAPK/ERK\n(Proliferation)" fillcolor="#CE93D8"]
    AP1          [label="AP-1\n(Inflammatory genes)" fillcolor="#CE93D8"]
    cAMP_PKA     [label="cAMP/PKA\n(Steroid pathway)" fillcolor="#E1BEE7"]
    Epigenetics  [label="Epigenetic\nModification (H3Ac)" fillcolor="#E1BEE7"]
  }

  /* ================================================================
     CLUSTER 6: TARGET TISSUE (Shoulder/Hip Girdle)
  ================================================================ */
  subgraph cluster_tissue {
    label="Target Tissue — Shoulder & Hip Girdle" style=filled fillcolor="#FFF3E0"
    color="#E65100" penwidth=2 fontsize=13 fontname="Helvetica-Bold"

    Shoulder_synovium  [label="Shoulder Synovium\n(GH joint)" fillcolor="#FFCC80"]
    Hip_synovium       [label="Hip Synovium\n(Coxofemoral)" fillcolor="#FFCC80"]
    Subacromial_bursa  [label="Subacromial Bursa\n(Fluid accum)" fillcolor="#FFB74D"]
    Subdeltoid_bursa   [label="Subdeltoid Bursa\n(US finding)" fillcolor="#FFB74D"]
    Trochanteric_bursa [label="Trochanteric Bursa\n(Hip pain source)" fillcolor="#FFB74D"]
    Bicipital_tenosynov [label="Bicipital\nTenosynovitis" fillcolor="#FFCC80"]
    FLS_synov          [label="Fibroblast-like\nSynoviocytes (FLS)" fillcolor="#FFB74D"]
    Synovial_fluid     [label="Synovial Fluid\n(IL-6, IL-1β rich)" fillcolor="#FFCC80"]
    Synovial_neovascul [label="Synovial\nNeovascularization" fillcolor="#FFCC80"]
    Muscle_fascia      [label="Muscle Fascia\n(Periscapular)" fillcolor="#FFCC80"]
    Proximal_myopathy  [label="Proximal Muscle\nWeakness" fillcolor="#FFB74D"]
    PGE2_tissue        [label="PGE2\n(Tissue pain)" fillcolor="#FFB74D"]
    COX2_tissue        [label="COX-2\n(FLS / Synoviocytes)" fillcolor="#FFB74D"]
    Tissue_edema       [label="Tissue Edema\n(MRI finding)" fillcolor="#FFCC80"]
    Giant_cell_form    [label="Giant Cell\nFormation (±GCA)" fillcolor="#FFB74D"]
  }

  /* ================================================================
     CLUSTER 7: PREDNISOLONE PK/PD
  ================================================================ */
  subgraph cluster_pred {
    label="Prednisolone PK/PD" style=filled fillcolor="#E8EAF6"
    color="#283593" penwidth=2 fontsize=13 fontname="Helvetica-Bold"

    Pred_dose       [label="Prednisolone Dose\n(Oral, mg/day)" fillcolor="#9FA8DA"]
    Pred_abs        [label="GI Absorption\n(F ≈ 82%)" fillcolor="#9FA8DA"]
    Pred_central    [label="Prednisolone\nCentral (Cp)" fillcolor="#7986CB"]
    Pred_peripheral [label="Prednisolone\nPeripheral (Ct)" fillcolor="#9FA8DA"]
    Pred_protein_bd [label="Protein Binding\n(CBG, Albumin)" fillcolor="#C5CAE9"]
    Pred_CYP3A4     [label="CYP3A4\nMetabolism → Pred" fillcolor="#9FA8DA"]
    Pred_free       [label="Free Prednisolone\n(Cp_free)" fillcolor="#7986CB"]
    GR_cytoplasm    [label="Glucocorticoid Receptor\n(Cytoplasm, GRα)" fillcolor="#7986CB"]
    GR_Pred_complex [label="GR–Prednisolone\nComplex (nucleus)" fillcolor="#5C6BC0"]
    Transrepression [label="Transrepression\n(NF-κB, AP-1↓)" fillcolor="#5C6BC0"]
    Transactivation [label="Transactivation\n(GRE→Anti-inflam)" fillcolor="#5C6BC0"]
    GILZ            [label="GILZ\n(Anti-inflam gene)" fillcolor="#7986CB"]
    MKP1            [label="MKP-1\n(MAPK phosphatase↑)" fillcolor="#9FA8DA"]
    AnnexinA1       [label="Annexin A1\n(Lipocortin-1↑)" fillcolor="#9FA8DA"]
    IkB_induced     [label="IκBα induction\n(NF-κB negative FB)" fillcolor="#9FA8DA"]
    Pred_adverse    [label="GC Adverse Effects\n(Glucose, BP, BMD)" fillcolor="#C5CAE9"]
    Pred_taper      [label="Tapering Schedule\n(ACR/BSR guideline)" fillcolor="#9FA8DA"]
  }

  /* ================================================================
     CLUSTER 8: TOCILIZUMAB PK/PD
  ================================================================ */
  subgraph cluster_tcz {
    label="Tocilizumab PK/PD (IL-6R Blocker)" style=filled fillcolor="#E0F7FA"
    color="#006064" penwidth=2 fontsize=13 fontname="Helvetica-Bold"

    TCZ_dose        [label="Tocilizumab Dose\n(SC 162 mg Q1W/Q2W)" fillcolor="#80DEEA"]
    TCZ_abs         [label="SC Absorption\n(F ≈ 80%)" fillcolor="#80DEEA"]
    TCZ_central     [label="Tocilizumab\nCentral (Cp)" fillcolor="#4DD0E1"]
    TCZ_peripheral  [label="Tocilizumab\nPeripheral (Ct)" fillcolor="#80DEEA"]
    mIL6R           [label="Membrane IL-6Rα\n(mIL-6R on cells)" fillcolor="#4DD0E1"]
    sIL6R_TCZ       [label="Soluble IL-6Rα\n(sIL-6R, free)" fillcolor="#80DEEA"]
    TCZ_mIL6R_cpx  [label="TCZ:mIL-6R\nComplex (cell)" fillcolor="#00BCD4"]
    TCZ_sIL6R_cpx  [label="TCZ:sIL-6R\nComplex (plasma)" fillcolor="#00BCD4"]
    IL6_signal_blk  [label="IL-6 Signaling\nBlocked (cis+trans)" fillcolor="#00ACC1"]
    STAT3_inhib     [label="pSTAT3\nInhibited" fillcolor="#0097A7"]
    CRP_suppressed  [label="CRP/Fibrinogen\nSuppressed" fillcolor="#80DEEA"]
    TCZ_target_med  [label="Target-mediated\nDrug Disposition" fillcolor="#B2EBF2"]
    TCZ_half_life   [label="t½ ≈ 13d (Q2W)\nconc-dependent" fillcolor="#B2EBF2"]
  }

  /* ================================================================
     CLUSTER 9: HPA AXIS
  ================================================================ */
  subgraph cluster_hpa {
    label="HPA Axis & Glucocorticoid Physiology" style=filled fillcolor="#F9FBE7"
    color="#827717" penwidth=2 fontsize=13 fontname="Helvetica-Bold"

    Hypothalamus    [label="Hypothalamus\n(PVN)" fillcolor="#F0F4C3"]
    CRH             [label="CRH\n(Corticotropin-RH)" fillcolor="#DCE775"]
    Pituitary       [label="Anterior Pituitary\n(Corticotroph)" fillcolor="#F0F4C3"]
    ACTH            [label="ACTH\n(Plasma)" fillcolor="#DCE775"]
    Adrenal_gland   [label="Adrenal Cortex\n(Zona fasciculata)" fillcolor="#F0F4C3"]
    Cortisol_endog  [label="Endogenous Cortisol\n(Diurnal rhythm)" fillcolor="#DCE775"]
    GR_pituitary    [label="GR in Pituitary\n(Feedback sensor)" fillcolor="#F0F4C3"]
    HPA_feedback    [label="HPA Negative\nFeedback Loop" fillcolor="#DCE775"]
    Adrenal_atrophy [label="Adrenal Atrophy\n(Prolonged GC use)" fillcolor="#F0F4C3"]
    HPA_recovery    [label="HPA Axis\nRecovery (months)" fillcolor="#F0F4C3"]
    Cortisol_total  [label="Total Cortisol\n(Endogenous + Exogenous)" fillcolor="#DCE775"]
    Circadian_CRH   [label="Circadian Rhythm\nCRH pulse" fillcolor="#F0F4C3"]
  }

  /* ================================================================
     CLUSTER 10: BONE EFFECTS
  ================================================================ */
  subgraph cluster_bone {
    label="Bone Effects (GC-Induced Osteoporosis)" style=filled fillcolor="#FFF8E1"
    color="#F57F17" penwidth=2 fontsize=13 fontname="Helvetica-Bold"

    Osteoblast      [label="Osteoblast\n(Bone formation↓)" fillcolor="#FFE082"]
    Osteoclast      [label="Osteoclast\n(Bone resorption↑)" fillcolor="#FFD54F"]
    RANK            [label="RANK\n(Osteoclast precursor)" fillcolor="#FFD54F"]
    RANKL           [label="RANKL\n(IL-6/GC induced↑)" fillcolor="#FFD54F"]
    OPG             [label="OPG\n(Decoy receptor, GC↓)" fillcolor="#FFE082"]
    Wnt_signaling   [label="Wnt/β-catenin\n(Osteoblast GC↓)" fillcolor="#FFE082"]
    DKK1            [label="DKK1\n(Wnt inhibitor, GC↑)" fillcolor="#FFD54F"]
    Sclerostin      [label="Sclerostin\n(SOST, GC↑)" fillcolor="#FFD54F"]
    BMD_lumbar      [label="Lumbar BMD\n(L1-L4)" fillcolor="#FFCC02"]
    BMD_hip         [label="Hip BMD\n(Femoral neck)" fillcolor="#FFCC02"]
    Vertebral_fx    [label="Vertebral Fracture\n(Risk ↑ 30–50%)" fillcolor="#FFD54F"]
    Ca_metabolism   [label="Calcium\nMetabolism (↓absorption)" fillcolor="#FFE082"]
    VitD_status     [label="Vitamin D\n(Supplementation)" fillcolor="#FFE082"]
    Bisphosphonate  [label="Bisphosphonate\n(Prophylactic)" fillcolor="#FFE082"]
  }

  /* ================================================================
     CLUSTER 11: VASCULAR / GCA ASSOCIATION
  ================================================================ */
  subgraph cluster_vascular {
    label="Vascular Inflammation & GCA Overlap" style=filled fillcolor="#FCE4EC"
    color="#880E4F" penwidth=2 fontsize=13 fontname="Helvetica-Bold"

    Temporal_artery [label="Temporal Artery\n(Cranial GCA)" fillcolor="#F48FB1"]
    Aorta_inflam    [label="Thoracic Aorta\n(Large-vessel GCA)" fillcolor="#F48FB1"]
    Endothelium     [label="Vascular Endothelium\n(VCAM-1, ICAM-1)" fillcolor="#F8BBD9"]
    VEGF_vasc       [label="VEGF\n(Angiogenesis↑)" fillcolor="#F48FB1"]
    Platelet_activ  [label="Platelet Activation\n(Thrombosis risk)" fillcolor="#F8BBD9"]
    PMR_GCA_overlap [label="PMR-GCA Overlap\n(~15–20% of PMR)" fillcolor="#F06292"]
    Ischemic_risk   [label="Ischemic Risk\n(Vision, Stroke)" fillcolor="#E91E63"]
    Large_vessel_GCA [label="Large-vessel GCA\n(PET-CT finding)" fillcolor="#F48FB1"]
    Aortitis_risk   [label="Aortitis\n(Aneurysm risk)" fillcolor="#F06292"]
    IL17_vasc       [label="IL-17 in\nVascular Inflam" fillcolor="#F8BBD9"]
    IFNg_vasc       [label="IFN-γ in\nArterial Wall" fillcolor="#F8BBD9"]
  }

  /* ================================================================
     CLUSTER 12: CLINICAL ENDPOINTS & DISEASE ACTIVITY
  ================================================================ */
  subgraph cluster_endpoints {
    label="Clinical Endpoints & Disease Activity Scores" style=filled fillcolor="#ECEFF1"
    color="#37474F" penwidth=2 fontsize=13 fontname="Helvetica-Bold"

    CRP_level       [label="CRP\n(mg/L, normal<5)" fillcolor="#B0BEC5"]
    ESR_level       [label="ESR\n(mm/hr, normal<50)" fillcolor="#B0BEC5"]
    Fibrinogen      [label="Fibrinogen\n(Acute phase)" fillcolor="#CFD8DC"]
    PMR_AS          [label="PMR Activity Score\n(PMR-AS, 0–70)" fillcolor="#90A4AE"]
    Pain_VAS        [label="Pain VAS\n(0–100 mm)" fillcolor="#90A4AE"]
    Morning_stiff   [label="Morning Stiffness\n(Duration, min)" fillcolor="#90A4AE"]
    Physician_global [label="Physician Global\nAssessment (0–10)" fillcolor="#90A4AE"]
    Patient_global  [label="Patient Global\nAssessment (0–10)" fillcolor="#90A4AE"]
    FACIT_fatigue   [label="FACIT-Fatigue\n(0–52)" fillcolor="#B0BEC5"]
    HAQ_disability  [label="HAQ-DI\n(0–3)" fillcolor="#B0BEC5"]
    Steroid_dose    [label="Steroid Dose\n(mg/day Pred-eq)" fillcolor="#90A4AE"]
    Remission       [label="Remission\n(PMR-AS≤7, CRP norm)" fillcolor="#78909C"]
    Relapse_event   [label="Relapse Event\n(↑PMR-AS ≥10)" fillcolor="#78909C"]
    Treatment_dur   [label="Treatment Duration\n(Median ~2 years)" fillcolor="#CFD8DC"]
    ACR_response    [label="ACR/EULAR\nResponse Criteria" fillcolor="#90A4AE"]
    IL6_blood       [label="Plasma IL-6\n(Biomarker)" fillcolor="#B0BEC5"]
    GC_sparing      [label="GC Sparing\n(Primary endpoint)" fillcolor="#78909C"]
  }

  /* ================================================================
     INTRA-CLUSTER EDGES
  ================================================================ */

  /* Epidemiology → Innate/Adaptive */
  Age_ge50 -> Env_trigger [style=dashed color="#999"]
  Female_sex -> Genetic_susceptibility [style=dashed color="#999"]
  HLA_DRB1_04 -> MHC_II [label="peptide pres." color="#1565C0"]
  HLA_DRB1_01 -> MHC_II [color="#1565C0"]
  PTPN22_variant -> TCR_signal [label="phosphatase↓" color="#1565C0"]
  Env_trigger -> pDC [label="viral trigger" color="#4CAF50"]
  Env_trigger -> TLR7_9 [color="#4CAF50"]
  Seasonal_peak -> Env_trigger [style=dashed]

  /* Innate immunity wiring */
  DAMPs -> TLR4 [color="#4CAF50"]
  PAMPs -> TLR4 [color="#4CAF50"]
  PAMPs -> TLR7_9 [color="#4CAF50"]
  TLR4 -> NF_kB_innate [color="#4CAF50"]
  TLR7_9 -> NF_kB_innate [color="#4CAF50"]
  NF_kB_innate -> IL1beta_innate [label="transcription" color="#C62828"]
  NF_kB_innate -> TNF_alpha [color="#C62828"]
  NF_kB_innate -> IL6 [color="#C62828"]
  NF_kB_innate -> CXCL8 [color="#C62828"]
  NF_kB_innate -> CCL2 [color="#C62828"]
  NF_kB_innate -> COX2_innate [color="#C62828"]
  NLRP3 -> IL1beta_innate [label="Caspase-1" color="#4CAF50"]
  MacM1 -> NLRP3 [color="#4CAF50"]
  MacM1 -> IL6 [color="#C62828"]
  MacM1 -> TNF_alpha [color="#C62828"]
  MacM1 -> IL23 [color="#C62828"]
  mDC -> IL23 [color="#C62828"]
  pDC -> IFN_gamma [color="#C62828"]
  NK_cells -> IFN_gamma [color="#C62828"]
  Complement -> C3a_C5a [color="#4CAF50"]
  C3a_C5a -> Neutrophils [label="recruit" color="#4CAF50"]
  Neutrophils -> ROS_innate [color="#4CAF50"]
  ROS_innate -> DAMPs [color="#4CAF50"]
  CCL2 -> Monocytes [label="recruit" color="#4CAF50"]
  Monocytes -> MacM1 [label="differentiate" color="#4CAF50"]

  /* Innate → Adaptive */
  mDC -> MHC_II [color="#1565C0"]
  IL1beta_innate -> Th17_cells [label="polarize" color="#1565C0"]
  IL23 -> Th17_cells [label="maintain" color="#1565C0"]
  IL6 -> Th17_cells [label="polarize" color="#1565C0"]
  IL6 -> Treg_cells [label="suppress" style=dashed color="#1565C0" arrowhead=tee]
  IFN_gamma -> Th1_cells [color="#1565C0"]

  /* Adaptive immunity wiring */
  MHC_II -> TCR_signal [color="#1565C0"]
  Costim_CD28 -> TCR_signal [color="#1565C0"]
  TCR_signal -> IL2_signal [color="#1565C0"]
  IL2_signal -> Th1_cells [label="prolif" color="#1565C0"]
  IL2_signal -> Th17_cells [label="prolif" color="#1565C0"]
  T_bet -> Th1_cells [color="#1565C0"]
  RORgt -> Th17_cells [color="#1565C0"]
  FoxP3 -> Treg_cells [color="#1565C0"]
  Th1_cells -> IFN_gamma [label="produce" color="#C62828"]
  Th1_cells -> TNF_alpha [color="#C62828"]
  Th17_cells -> IL17A [label="produce" color="#C62828"]
  Th17_cells -> IL17F [color="#C62828"]
  Th17_cells -> IL21 [color="#C62828"]
  Treg_cells -> IL10 [label="produce" color="#C62828"]
  Treg_cells -> TGF_beta [color="#C62828"]
  B_cells -> GCB_center [color="#1565C0"]
  GCB_center -> Plasma_cells [color="#1565C0"]
  IL21 -> GCB_center [color="#C62828"]

  /* Cytokines → Signaling */
  IL6 -> IL6_complex [color="#C62828"]
  sIL6R -> IL6_complex [label="trans-sig" color="#C62828"]
