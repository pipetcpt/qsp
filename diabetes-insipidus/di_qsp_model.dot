digraph DI_QSP {
  /* =====================================================================
     Diabetes Insipidus (Arginine Vasopressin Disorders, AVP-D / AVP-R)
     Quantitative Systems Pharmacology Map
     12 clusters, 140+ nodes; hypothalamic AVP -> V2R/AQP2 -> water balance
     Pharmacology: desmopressin (SC/IN/PO/sublingual), thiazide, amiloride,
                   indomethacin, tolvaptan (comparator), chlorpropamide.
     ===================================================================== */
  graph [rankdir=LR, splines=spline, overlap=false, nodesep=0.18,
         ranksep=0.55, fontname="Helvetica", fontsize=10,
         label="Diabetes Insipidus / Arginine Vasopressin Disorders — QSP Map\n(AVP-D · AVP-R · Gestational · Primary Polydipsia)",
         labelloc="t", labeljust="c"];
  node  [shape=box, style="rounded,filled", fontname="Helvetica",
         fontsize=9, color="#333333"];
  edge  [color="#666666", fontsize=8, fontname="Helvetica"];

  /* ====== Cluster 1: Etiology / Genetics ==================== */
  subgraph cluster_etio {
    label="1. Etiology & Genetics"; style="rounded,filled"; fillcolor="#fde2e4";
    color="#c92a2a";
    GEN_AVP   [label="AVP gene (20p13)\nautosomal dominant\nFNDI (signal/neurophysin II)"];
    GEN_AVPR2 [label="AVPR2 (Xq28)\nX-linked NDI\n>250 LoF mutations"];
    GEN_AQP2  [label="AQP2 (12q13)\nautosomal rec/dom NDI\n40+ mutations"];
    AUTOIM    [label="Anti-vasopressin\nneuron antibodies\n(lymphocytic infundibuloneurohypophysitis)"];
    TUMOR     [label="Sellar/suprasellar tumor\ncraniopharyngioma·germinoma\nmetastasis (lung/breast)"];
    TRAUMA    [label="Head trauma\ntranssphenoidal surgery\ntriphasic response"];
    INFILT    [label="Infiltrative disease\nLCH·sarcoidosis·IgG4-RD\nWegener"];
    LITHIUM   [label="Lithium toxicity\n(>15y exposure 30-40%)\nENaC entry + AQP2 down"];
    HYPERCA   [label="Hypercalcemia\nCaSR activation in TAL"];
    HYPOK     [label="Hypokalemia\nimpaired AQP2 trafficking"];
    POST_OBS  [label="Post-obstructive\ndiuresis"];
    PREG_VPase [label="Placental vasopressinase\n(gestational DI, 3rd trimester)"];
    PSYCH      [label="Primary polydipsia\npsychogenic·dipsogenic\nschizophrenia"];
    IDIO      [label="Idiopathic\n(~30% adults, ~50% kids)"];
  }

  /* ====== Cluster 2: Hypothalamus & Neurohypophysis ========== */
  subgraph cluster_hypo {
    label="2. Hypothalamic-Neurohypophyseal Axis"; style="rounded,filled"; fillcolor="#ffe8cc";
    color="#d9480f";
    SON   [label="Supraoptic nucleus (SON)\nmagnocellular AVP neurons"];
    PVN   [label="Paraventricular nucleus (PVN)\nmagno + parvocellular"];
    OXY   [label="Oxytocin co-secretion\n(magnocellular)"];
    AVPpre [label="AVP precursor\nsignal-AVP-NPII-copeptin\n(165 aa)"];
    NPII  [label="Neurophysin II\nchaperone"];
    COPEP [label="Copeptin (C-terminal)\nstable surrogate\nLLD 1-2 pmol/L"];
    PROC  [label="Proteolytic processing\nin Herring bodies"];
    PSTalk [label="Pituitary stalk\nhypothalamo-hypophyseal tract"];
    POSTPIT [label="Posterior pituitary\nneurohypophysis"];
    NEUROVES [label="Neurosecretory\nvesicles"];
    BRIGHT  [label="Posterior pituitary\nbright spot on MRI\n(absent in CDI)"];
    AVPdaily [label="AVP daily release\n~50-200 pmol/d"];
    AVPbasal [label="Plasma AVP (basal)\n0.5-2 pmol/L"];
    AVPpeak  [label="Plasma AVP (peak)\n5-15 pmol/L (osmotic)\n>20 (hemodynamic)"];
    HALF_AVP [label="AVP plasma t½ 10-30 min\nrenal/hepatic clearance"];
  }

  /* ====== Cluster 3: Osmolality / Sodium Sensing ============= */
  subgraph cluster_osmo {
    label="3. Osmolality & Volume Sensing"; style="rounded,filled"; fillcolor="#fff3bf";
    color="#e67700";
    OVLT  [label="OVLT (organum vasculosum\nlamina terminalis)\nosmoreceptors"];
    SFO   [label="Subfornical organ (SFO)\nAng II sensitive"];
    MnPO  [label="Median preoptic nucleus\n(MnPO) integrator"];
    NA_X  [label="Na_x channel\n(SCN7A) Na+ sensor"];
    TRPV1 [label="TRPV1/TRPV4\nosmosensors"];
    POSMTHRESH [label="Osmotic threshold ~280 mOsm/kg\n(AVP release setpoint)"];
    THIRSTTH   [label="Thirst threshold ~290 mOsm/kg\nhigher than AVP"];
    BARO  [label="Atrial/aortic\nbaroreceptors"];
    NTS   [label="Nucleus tractus solitarius\n(NTS)"];
    A1NA  [label="A1 noradrenergic\nrelay -> PVN/SON"];
    SLOPE [label="AVP-osmolality slope\n~0.4 pmol/L per mOsm/kg"];
    HUMID  [label="High humidity / heat\nsweat -> H2O loss"];
    ANGII  [label="Angiotensin II\n(SFO -> thirst, AVP)"];
  }

  /* ====== Cluster 4: V2 Receptor & cAMP Signaling ============ */
  subgraph cluster_v2 {
    label="4. V2 Receptor & cAMP/PKA Signaling (Principal Cells)"; style="rounded,filled"; fillcolor="#d3f9d8";
    color="#2f9e44";
    V2R   [label="V2 receptor (AVPR2)\nGs-coupled GPCR\nbasolateral CD principal cells"];
    GS    [label="Gαs subunit"];
    AC    [label="Adenylyl cyclase VI\n(predominant)"];
    cAMP  [label="cAMP\nsecond messenger"];
    PKA   [label="Protein kinase A\nholoenzyme"];
    CREB  [label="CREB phosphorylation\n(AQP2 transcription)"];
    EPAC  [label="EPAC\n(Rap1, AQP2 traffic)"];
    PDE4  [label="PDE4 phosphodiesterase\n(cAMP degradation)"];
    A_KAP [label="AKAPs anchoring\n(AKAP18/220)"];
    V1A   [label="V1a receptor\nvascular Gq\nIP3/Ca2+"];
    V1B   [label="V1b receptor\nant. pituitary\nACTH potentiator"];
    OTR   [label="Oxytocin receptor\ncross-reactivity at high dose"];
    DESENS [label="V2R desensitization\nβ-arrestin internalization"];
    MUT_LOF [label="V2R LoF mutations\nclass I-V trafficking defects"];
  }

  /* ====== Cluster 5: AQP2 Water Channel Trafficking ========== */
  subgraph cluster_aqp {
    label="5. Aquaporin-2 Trafficking & Long-term Regulation"; style="rounded,filled"; fillcolor="#c5f6fa";
    color="#0c8599";
    AQP2_GENE [label="AQP2 gene transcription\n(CREB·AP-1·TonEBP)"];
    AQP2_mRNA [label="AQP2 mRNA"];
    AQP2_CYTO [label="AQP2 cytoplasmic vesicles\n(storage pool)"];
    AQP2_APIC [label="AQP2 apical membrane\n(active water channel)"];
    PHOS_S256 [label="pS256 phosphorylation\nPKA-mediated insertion"];
    PHOS_S261 [label="pS261/S264/S269\nfine-tuning"];
    UBQ       [label="K63-Ub of AQP2\nendocytosis"];
    AQP3_4    [label="AQP3/AQP4\nbasolateral exit"];
    SHORT     [label="Short-term effect\n(min-hours)\nvesicle shuttling"];
    LONG      [label="Long-term effect\n(>24 h)\ntranscriptional"];
    TONEBP    [label="TonEBP/NFAT5\nhypertonic activation"];
    AQP2_MUT  [label="AQP2 mutations\n(class I/II)"];
    CD_OSM    [label="Medullary osmotic\ngradient (1200 mOsm/kg)"];
    NACLCO    [label="NKCC2 (TAL)\ncountercurrent multiplier"];
  }

  /* ====== Cluster 6: Renal Tubular Water Handling ============ */
  subgraph cluster_renal {
    label="6. Renal Water & Electrolyte Handling"; style="rounded,filled"; fillcolor="#d0bfff";
    color="#5f3dc4";
    GFR     [label="GFR 90-120 mL/min/1.73m2\n~180 L filtrate/d"];
    PCT     [label="Proximal tubule\n~67% Na/H2O isotonic reabs"];
    LOH     [label="Loop of Henle\nNKCC2 / countercurrent"];
    DCT     [label="Distal convoluted tubule\nthiazide-sensitive NCC"];
    CD_PRINC [label="Collecting duct principal cell\n(target of AVP)"];
    CD_INTER [label="Intercalated cells\nH+/HCO3-"];
    ENaC     [label="ENaC\nNa+ entry"];
    UREA_UT  [label="UT-A1/A3 urea transport\nintramedullary recycling"];
    UO_BASE  [label="Basal urine output\n1-2 L/d, Uosm 600-800"];
    UO_DI    [label="DI urine output\n3-20 L/d, Uosm <300"];
    POLYUR   [label="Polyuria threshold\n>50 mL/kg/d (>3 L)"];
    UO_MAX   [label="Max free water excretion\n~18 L/d (full V2R block)"];
    UMUSCLE  [label="Urinary concentration\ndefect mild/mod/severe"];
  }

  /* ====== Cluster 7: Thirst, Behavior & Volume ============== */
  subgraph cluster_thirst {
    label="7. Thirst, Drinking Behavior & Volume"; style="rounded,filled"; fillcolor="#ffe3e3";
    color="#c2255c";
    THIRST_SCALE [label="Thirst VAS 0-10\npatient-reported"];
    DRINK   [label="Water intake\nL/d"];
    POLYDIP [label="Polydipsia\n>3 L/d"];
    NOCTURIA [label="Nocturia\nfrequency >2/night"];
    ENURESIS [label="Enuresis (children)"];
    TBW     [label="Total body water (TBW)\n~60% BW (men), ~50% (women)"];
    ECW     [label="Extracellular water"];
    ICW     [label="Intracellular water"];
    NA_TOT  [label="Total exchangeable Na+"];
    K_TOT   [label="Total exchangeable K+"];
    P_OSM   [label="Plasma osmolality\n275-295 mOsm/kg"];
    P_NA    [label="Plasma Na+\n135-145 mmol/L"];
    DEHYD   [label="Dehydration\n(if access to water restricted)"];
    HYPERNA [label="Hypernatremia\nNa+ >145 -> >155 severe"];
    BV      [label="Effective circulating\nvolume"];
  }

  /* ====== Cluster 8: Drug Pharmacology (Desmopressin & Friends) ==== */
  subgraph cluster_drug {
    label="8. Drug PK / PD"; style="rounded,filled"; fillcolor="#e7f5ff";
    color="#1c7ed6";
    DDAVP   [label="Desmopressin (DDAVP)\n1-deamino-8-D-Arg vasopressin\nV2-selective synthetic agonist"];
    DDAVP_SC [label="SC/IV DDAVP\n0.5-4 µg, F=100%"];
    DDAVP_IN [label="Intranasal DDAVP\n5-40 µg, F ~3-5%\nspray/rhinyl"];
    DDAVP_PO [label="Oral DDAVP\n100-1200 µg, F ~0.16%"];
    DDAVP_SL [label="Sublingual lyophilisate\n(MELT) 60-360 µg, F ~0.25%"];
    DDAVP_PK [label="t½ 2-4 h SC\n3 h oral; ~10x V1a sparing\nminimal pressor effect"];
    DDAVP_PD [label="V2R agonist EC50 ~0.4 pmol/L\nIntrinsic activity 1.0"];
    THZ     [label="Thiazide (HCTZ)\n12.5-50 mg/d\nNCC inhibitor"];
    THZ_PARA [label="Paradoxical antidiuresis\nin NDI: ECV contraction\n-> PCT Na/H2O reabs"];
    AMI     [label="Amiloride 5-20 mg/d\nENaC blocker\nblocks Li+ entry"];
    INDO    [label="Indomethacin 1-3 mg/kg/d\nCOX inhibition -> PGE2 down\n-> AQP2 traffic up"];
    TOLV    [label="Tolvaptan (V2 antagonist)\ncomparator/SIADH/ADPKD"];
    CHLOR   [label="Chlorpropamide (legacy)\npotentiates partial AVP\nhypoglycemia risk"];
    DESMO_TID [label="Dosing TID typical\nbreak-through polyuria"];
    DESMO_ADVERSE [label="Hyponatremia risk\n(7-10% if unmonitored)"];
    LICARB  [label="Lithium carbonate\n(NDI inducer/comparator)"];
  }

  /* ====== Cluster 9: Hypothalamo-pituitary axis (additional) === */
  subgraph cluster_ahp {
    label="9. Co-existing Pituitary Dysfunction"; style="rounded,filled"; fillcolor="#fff4e6";
    color="#e8590c";
    ANT_PIT [label="Anterior pituitary\nGH/ACTH/TSH/PRL/LH/FSH"];
    ACTH_DEF [label="ACTH deficiency\nunmasks DI\n(cortisol allows free water excretion)"];
    GH_DEF   [label="GH deficiency\nin trauma/tumor"];
    TSH_DEF  [label="Central hypothyroidism"];
    GONAD    [label="Hypogonadotropic\nhypogonadism"];
    TRIPHASIC [label="Triphasic response\npost-surgery\nDI -> SIADH -> permanent DI"];
    SIADH    [label="SIADH (inverse)\nAVP excess -> hyponatremia"];
    ADIP     [label="Adipsic DI (hypothalamic)\nimpaired thirst"];
  }

  /* ====== Cluster 10: Diagnostic Workup ==================== */
  subgraph cluster_dx {
    label="10. Diagnosis & Biomarkers"; style="rounded,filled"; fillcolor="#e3fafc";
    color="#1098ad";
    WDT   [label="Water deprivation test\n(Miller-Moses)\n8-h dehydration + DDAVP"];
    HYPNAS [label="Hypertonic saline\ncopeptin test\nChrist-Crain 2019 NEJM"];
    ARGCH  [label="Arginine-stimulated copeptin\nWinzeler 2019 Lancet"];
    COP_BASE [label="Baseline copeptin\n<2.6 pmol/L -> AVP-D"];
    COP_PROV [label="Stimulated copeptin\n>4.9 -> primary polydipsia\n<4.9 -> AVP-D"];
    UOSM_NORM [label="Uosm >800 mOsm/kg\n-> normal"];
    UOSM_PART [label="Uosm 300-800\npartial DI"];
    UOSM_SEV  [label="Uosm <300\ncomplete DI"];
    MRI_PIT  [label="Pituitary MRI\nT1 bright spot\nstalk thickening"];
    OSMRESP  [label="DDAVP response\nUosm increase >50%\n-> AVP-D"];
    GENETIC  [label="Genetic testing\nAVP/AVPR2/AQP2 NGS"];
  }

  /* ====== Cluster 11: Complications / Endpoints ============ */
  subgraph cluster_comp {
    label="11. Complications & Clinical Endpoints"; style="rounded,filled"; fillcolor="#ffe0b2";
    color="#fd7e14";
    HYPERNA_E [label="Severe hypernatremia\nNa+ >160\nseizures, coma"];
    HYPONA_E  [label="Iatrogenic hyponatremia\n(over-DDAVP)\nNa+ <130"];
    BLAD_DIST [label="Bladder distension\n(chronic polyuria)\nhydronephrosis"];
    GROWTH    [label="Growth failure\n(pediatric NDI)"];
    QOL       [label="Quality of life\nsleep disruption"];
    OSMODEMY  [label="Osmotic demyelination\nrapid Na+ correction"];
    CV_RISK   [label="Cardiovascular events\n(chronic volume depletion)"];
    SUDDEN    [label="Sudden death\n(adipsic DI + acute illness)"];
    PREG_OUT  [label="Pregnancy outcomes\n(gestational DI)\nDDAVP safe"];
  }

  /* ====== Cluster 12: Special Populations ================ */
  subgraph cluster_special {
    label="12. Pediatrics, Pregnancy & Geriatrics"; style="rounded,filled"; fillcolor="#fbf3db";
    color="#9c8410";
    PEDI [label="Pediatric NDI\nAVPR2 X-linked\nfailure to thrive"];
    PED_DDAVP [label="Pediatric DDAVP dosing\n0.1-0.4 µg/kg IN"];
    PREG [label="Pregnancy\nplacental vasopressinase x4\ndegrades native AVP\nDDAVP not degraded"];
    GERI [label="Elderly\nimpaired thirst, drug clearance\nNa+ monitoring"];
    DIAL [label="Dialysis (ESRD)\naltered urine output\nhemodialysis sessions"];
  }

  /* ====== EDGES: Etiology -> hypothalamus/V2R/AQP2 ============= */
  GEN_AVP   -> AVPpre [label="LoF/dominant negative"];
  AUTOIM    -> SON;
  AUTOIM    -> PVN;
  TUMOR     -> PSTalk;
  TUMOR     -> POSTPIT;
  TRAUMA    -> PSTalk;
  INFILT    -> PSTalk;
  IDIO      -> SON;
  GEN_AVPR2 -> V2R [label="trafficking/folding"];
  GEN_AQP2  -> AQP2_GENE;
  LITHIUM   -> ENaC [label="entry via ENaC"];
  LITHIUM   -> AQP2_GENE [label="down-regulation"];
  HYPERCA   -> NACLCO [label="CaSR TAL"];
  HYPOK     -> AQP2_APIC [label="impaired insertion"];
  POST_OBS  -> CD_PRINC;
  PREG_VPase -> AVPbasal [label="degrades AVP (not DDAVP)"];
  PSYCH     -> DRINK [label="excess intake"];

  /* AVP synthesis cascade */
  SON  -> AVPpre;
  PVN  -> AVPpre;
  AVPpre -> PROC -> NPII;
  AVPpre -> COPEP;
  PROC  -> NEUROVES -> POSTPIT;
  POSTPIT -> AVPdaily -> AVPbasal;
  PSTalk  -> POSTPIT;
  POSTPIT -> BRIGHT [style=dashed];
  AVPbasal -> AVPpeak [label="osmotic·hemodynamic"];
  AVPpeak  -> HALF_AVP;

  /* Osmotic & baroreflex inputs */
  P_OSM -> OVLT;
  P_OSM -> SFO;
  OVLT  -> MnPO -> SON;
  SFO   -> MnPO;
  NA_X  -> OVLT;
  TRPV1 -> OVLT;
  POSMTHRESH -> AVPbasal [style=dotted];
  THIRSTTH   -> THIRST_SCALE [style=dotted];
  BARO  -> NTS -> A1NA -> SON;
  HUMID -> TBW [style=dashed];
  ANGII -> SFO;
  ANGII -> THIRST_SCALE;
  SLOPE -> AVPbasal [style=dotted];

  /* AVP -> V2 cascade */
  AVPbasal -> V2R;
  V2R -> GS -> AC -> cAMP -> PKA;
  cAMP -> EPAC;
  PKA  -> CREB -> AQP2_GENE;
  PKA  -> PHOS_S256;
  cAMP -> PDE4 [dir=back, label="degrades"];
  A_KAP -> PKA;
  AQP2_GENE -> AQP2_mRNA -> AQP2_CYTO -> AQP2_APIC;
  PHOS_S256 -> AQP2_APIC [label="trafficking"];
  PHOS_S261 -> AQP2_APIC [label="modulates"];
  AQP2_APIC -> UBQ [label="endocytosis"];
  AQP3_4 -> CD_PRINC [label="basolateral"];
  TONEBP -> AQP2_GENE [label="hypertonic"];
  AQP2_MUT -> AQP2_APIC [color="red", label="trafficking defect"];
  DESENS -> V2R [color="red"];

  /* V1a/V1b extra-renal */
  AVPbasal -> V1A [style=dashed];
  AVPbasal -> V1B [style=dashed];
  V1A -> BV [label="vasopressor"];
  V1B -> ACTH_DEF [style=dashed];

  /* Renal water handling */
  GFR -> PCT -> LOH -> DCT -> CD_PRINC;
  CD_PRINC -> AQP2_APIC;
  AQP2_APIC -> UO_BASE [label="H2O reabs"];
  CD_PRINC -> UREA_UT;
  NACLCO -> CD_OSM;
  CD_OSM -> UO_BASE [label="driving force"];
  UO_BASE -> POLYUR [style=dashed];
  UO_DI -> POLYUR;
  ENaC -> CD_PRINC;
  UMUSCLE -> UO_DI;
  UO_MAX -> UO_DI [style=dotted];

  /* Behavior */
  P_OSM -> THIRST_SCALE;
  THIRST_SCALE -> DRINK -> TBW;
  TBW -> ECW;
  TBW -> ICW;
  ECW -> P_NA -> P_OSM;
  NA_TOT -> ECW;
  K_TOT -> ICW;
  UO_DI -> TBW [color="red", label="loss"];
  TBW -> BV;
  BV -> BARO;
  DRINK -> NOCTURIA;
  POLYDIP -> NOCTURIA;
  NOCTURIA -> ENURESIS;
  DEHYD -> HYPERNA;
  HYPERNA -> P_NA;

  /* Drug PK / PD */
  DDAVP_SC -> DDAVP;
  DDAVP_IN -> DDAVP;
  DDAVP_PO -> DDAVP;
  DDAVP_SL -> DDAVP;
  DDAVP -> DDAVP_PK;
  DDAVP -> DDAVP_PD;
  DDAVP_PD -> V2R [label="agonist"];
  DDAVP_PD -> OTR [style=dotted, label="weak"];
  DESMO_TID -> DDAVP;
  DDAVP -> DESMO_ADVERSE [color="red"];
  THZ -> DCT [label="NCC inhibition"];
  THZ -> THZ_PARA -> PCT [label="ECV contraction"];
  AMI -> ENaC;
  INDO -> CD_PRINC [label="PGE2 down"];
  TOLV -> V2R [color="red", label="antagonist"];
  CHLOR -> V2R [label="potentiator (legacy)"];
  LICARB -> LITHIUM;

  /* Co-existing pituitary */
  ANT_PIT -> ACTH_DEF [style=dashed];
  ANT_PIT -> GH_DEF;
  ANT_PIT -> TSH_DEF;
  ANT_PIT -> GONAD;
  ACTH_DEF -> P_NA [label="cortisol replaces water excretion"];
  TUMOR -> ANT_PIT;
  TRAUMA -> TRIPHASIC -> POSTPIT;
  TRIPHASIC -> SIADH [style=dashed, label="phase 2"];
  SON -> ADIP [style=dotted];

  /* Diagnosis */
  WDT -> UOSM_NORM;
  WDT -> UOSM_PART;
  WDT -> UOSM_SEV;
  HYPNAS -> COP_PROV;
  ARGCH -> COP_PROV;
  COP_BASE -> AVPbasal [style=dotted];
  COP_PROV -> AVPbasal [style=dotted];
  UOSM_SEV -> OSMRESP;
  OSMRESP -> DDAVP_PD;
  MRI_PIT -> BRIGHT;
  MRI_PIT -> PSTalk;
  GENETIC -> GEN_AVP;
  GENETIC -> GEN_AVPR2;
  GENETIC -> GEN_AQP2;

  /* Complications */
  HYPERNA -> HYPERNA_E;
  DDAVP -> HYPONA_E [label="overdose risk"];
  HYPONA_E -> OSMODEMY [color="red", label="rapid correction"];
  POLYUR -> BLAD_DIST;
  PEDI  -> GROWTH;
  POLYDIP -> QOL;
  NOCTURIA -> QOL;
  DEHYD -> CV_RISK;
  ADIP -> SUDDEN;
  PREG -> PREG_OUT;

  /* Special populations */
  PEDI -> PED_DDAVP -> DDAVP;
  PREG -> PREG_VPase;
  PREG -> DDAVP [label="safe in pregnancy"];
  GERI -> DDAVP [label="dose reduction"];
  DIAL -> UO_DI [style=dotted];

  /* Legends */
  { rank=sink;
    LEG [shape=note, fillcolor="#fff9db",
         label="Legend: solid arrows = direct biological flow.\nDashed = modulatory. Red = pathological.\nClusters 1-7 disease mechanism, 8-12 drugs, comorbidity, diagnostics, complications."];
  }
}
