digraph SPS_QSP {
  graph [layout=dot, rankdir=LR, splines=polyline, nodesep=0.35, ranksep=0.6, overlap=false,
         fontname="Helvetica", fontsize=11, labelloc=t,
         label="Stiff Person Syndrome (SPS) — Quantitative Systems Pharmacology Map\nAnti-GAD65 autoimmunity → GABAergic deficit → spinal/cortical hyperexcitability → rigidity & spasm"];
  node  [shape=box, style="rounded,filled", fontname="Helvetica", fontsize=10, color="#444444", penwidth=1];
  edge  [color="#666666", fontsize=9, arrowsize=0.7];

  /* ===================== 1. GENETIC & TRIGGER ===================== */
  subgraph cluster_genetics {
    label="1. Genetic susceptibility & triggers";
    style="rounded,filled"; fillcolor="#f4f0ff"; color="#7a5cc6";
    HLA_DRB1_03    [label="HLA-DRB1*03:01\n(odds ratio ≈ 3-5)", fillcolor="#e6dcff"];
    HLA_DQB1_02    [label="HLA-DQB1*02:01", fillcolor="#e6dcff"];
    PTPN22         [label="PTPN22\nR620W", fillcolor="#e6dcff"];
    AIRE_var       [label="AIRE / Treg defects", fillcolor="#e6dcff"];
    CTLA4_var      [label="CTLA-4 polymorphism", fillcolor="#e6dcff"];
    INFECT_TRIG    [label="Molecular mimicry\n(EBV, enterovirus)", fillcolor="#e6dcff"];
    PARANEO        [label="Paraneoplastic trigger\n(breast, SCLC, thymoma)", fillcolor="#e6dcff"];
    ICI_DRUG       [label="Immune checkpoint\ninhibitor exposure", fillcolor="#e6dcff"];
  }

  /* ===================== 2. IMMUNE CASCADE ===================== */
  subgraph cluster_immune {
    label="2. Adaptive immune cascade";
    style="rounded,filled"; fillcolor="#fff0f0"; color="#c64a4a";
    APC            [label="APC (DC)\nGAD65 peptide presentation", fillcolor="#ffd6d6"];
    Th1            [label="CD4+ Th1\n(IFN-γ, IL-2)", fillcolor="#ffd6d6"];
    Th17           [label="CD4+ Th17\n(IL-17, IL-21)", fillcolor="#ffd6d6"];
    Tfh            [label="T-follicular helper\n(IL-21, ICOS)", fillcolor="#ffd6d6"];
    Treg_def       [label="Treg dysfunction\n(↓ FOXP3, ↓ IL-10)", fillcolor="#ffd6d6"];
    Bcell_naive    [label="Naive B cell\nGAD65-specific", fillcolor="#ffd6d6"];
    GC_react       [label="Germinal-center\nreaction (CXCL13)", fillcolor="#ffd6d6"];
    Plasmablast    [label="Plasmablast\nCD19+CD27hi", fillcolor="#ffd6d6"];
    LL_PC          [label="Long-lived plasma cell\n(BM niche)", fillcolor="#ffd6d6"];
    Memory_B       [label="Memory B cell\nCD20+CD27+", fillcolor="#ffd6d6"];
    CSF_Bcell      [label="Intrathecal\nB-cell clones", fillcolor="#ffd6d6"];
  }

  /* ===================== 3. ANTIBODY / EFFECTORS ===================== */
  subgraph cluster_ab {
    label="3. Autoantibody effectors";
    style="rounded,filled"; fillcolor="#fff7e6"; color="#c68a2e";
    GAD65_Ab_S     [label="Serum anti-GAD65 IgG\n(>10,000 U/mL diagnostic)", fillcolor="#ffe8b8"];
    GAD65_Ab_CSF   [label="CSF anti-GAD65 IgG\n(intrathecal index >1)", fillcolor="#ffe8b8"];
    GAD67_Ab       [label="Cross-reactive\nanti-GAD67", fillcolor="#ffe8b8"];
    Amphiphysin_Ab [label="Anti-amphiphysin\n(paraneoplastic SPS)", fillcolor="#ffe8b8"];
    GlyR_Ab        [label="Anti-glycine receptor\n(PERM variant)", fillcolor="#ffe8b8"];
    DPPX_Ab        [label="Anti-DPPX\n(rare SPS-plus)", fillcolor="#ffe8b8"];
    GABARAP_Ab     [label="Anti-GABA-A receptor-\nassociated protein", fillcolor="#ffe8b8"];
    Gephyrin_Ab    [label="Anti-gephyrin", fillcolor="#ffe8b8"];
    OCB            [label="Oligoclonal bands\nin CSF", fillcolor="#ffe8b8"];
  }

  /* ===================== 4. CNS NEUROCHEM ===================== */
  subgraph cluster_neuro {
    label="4. CNS GABAergic neurochemistry";
    style="rounded,filled"; fillcolor="#eef7ff"; color="#3a78c2";
    GAD65_enzyme   [label="GAD65 enzyme\n(presynaptic, vesicular)", fillcolor="#cfe4ff"];
    GAD67_enzyme   [label="GAD67 enzyme\n(cytosolic)", fillcolor="#cfe4ff"];
    GABA_synth     [label="GABA synthesis\n(Glu → GABA)", fillcolor="#cfe4ff"];
    GABA_pool      [label="Vesicular GABA pool", fillcolor="#cfe4ff"];
    VGAT           [label="VGAT vesicular\ntransporter", fillcolor="#cfe4ff"];
    GABA_release   [label="Quantal GABA release", fillcolor="#cfe4ff"];
    GABA_A_R       [label="GABA-A receptor\n(α1β2γ2)", fillcolor="#cfe4ff"];
    GABA_B_R       [label="GABA-B receptor\n(metabotropic)", fillcolor="#cfe4ff"];
    GAT1           [label="GAT-1 reuptake", fillcolor="#cfe4ff"];
    GABA_T         [label="GABA transaminase", fillcolor="#cfe4ff"];
    GlyR_R         [label="Glycine receptor\n(GlyR α1)", fillcolor="#cfe4ff"];
    NMDA_R         [label="NMDA receptor", fillcolor="#cfe4ff"];
    AMPA_R         [label="AMPA receptor", fillcolor="#cfe4ff"];
    Glutamate      [label="Glutamatergic drive\n(Glu)", fillcolor="#cfe4ff"];
  }

  /* ===================== 5. SPINAL CIRCUIT ===================== */
  subgraph cluster_spinal {
    label="5. Spinal motor circuitry";
    style="rounded,filled"; fillcolor="#eaf6ee"; color="#3aa05e";
    Renshaw        [label="Renshaw cell\n(recurrent inhibition)", fillcolor="#cfeacf"];
    Ia_inh         [label="Ia inhibitory\ninterneuron", fillcolor="#cfeacf"];
    Ib_GTO         [label="Ib / GTO afferent", fillcolor="#cfeacf"];
    Presyn_inh     [label="Presynaptic inhibition\n(GABAergic axoaxonic)", fillcolor="#cfeacf"];
    Alpha_MN       [label="α-motor neuron\nfiring rate", fillcolor="#cfeacf"];
    Gamma_MN       [label="γ-motor neuron\n(spindle gain)", fillcolor="#cfeacf"];
    Reciprocal_inh [label="Reciprocal Ia inhibition", fillcolor="#cfeacf"];
    H_reflex       [label="H-reflex\n(amplitude / Hmax/Mmax)", fillcolor="#cfeacf"];
    F_wave         [label="F-wave persistence", fillcolor="#cfeacf"];
    EAU_Cocont     [label="Agonist-antagonist\nco-contraction", fillcolor="#cfeacf"];
  }

  /* ===================== 6. SUPRASPINAL / CORTEX ===================== */
  subgraph cluster_cortex {
    label="6. Supraspinal & autonomic";
    style="rounded,filled"; fillcolor="#fff0fa"; color="#b34db2";
    Motor_cortex   [label="Motor cortex\nhyperexcitability", fillcolor="#fcd6f1"];
    Brainstem_RF   [label="Brainstem\nreticular formation", fillcolor="#fcd6f1"];
    Cerebellum     [label="Cerebellar GABAergic\nPurkinje (PERM)", fillcolor="#fcd6f1"];
    Amygdala       [label="Amygdala\n(task-specific anxiety)", fillcolor="#fcd6f1"];
    Limbic_GABA    [label="Limbic GABA\n(panic / phobia)", fillcolor="#fcd6f1"];
    Sympathetic    [label="Sympathetic surge\n(tachycardia, sweating)", fillcolor="#fcd6f1"];
    Vagal_tone     [label="Parasympathetic\nwithdrawal", fillcolor="#fcd6f1"];
  }

  /* ===================== 7. CLINICAL FEATURES ===================== */
  subgraph cluster_clinical {
    label="7. Clinical phenotype";
    style="rounded,filled"; fillcolor="#f0f8e8"; color="#618c2f";
    Axial_stiff    [label="Axial / lumbar rigidity\n(lordosis)", fillcolor="#dfecbf"];
    Limb_stiff     [label="Limb stiffness\n(>50% truncal)", fillcolor="#dfecbf"];
    Spasms         [label="Painful spasms\n(stimulus / startle)", fillcolor="#dfecbf"];
    Gait           [label="Stiff / robotic gait", fillcolor="#dfecbf"];
    Falls          [label="Statue-like falls\n(unprotected)", fillcolor="#dfecbf"];
    PERM           [label="PERM variant\n(encephalomyelitis)", fillcolor="#dfecbf"];
    SPS_plus       [label="SPS-plus\n(cerebellar/oculomotor)", fillcolor="#dfecbf"];
    Focal_SPS      [label="Focal / stiff-limb\nsyndrome", fillcolor="#dfecbf"];
    Comorbid_DM    [label="Type 1 diabetes\n(~30%)", fillcolor="#dfecbf"];
    Comorbid_thy   [label="Autoimmune thyroid\n(~10%)", fillcolor="#dfecbf"];
    Anxiety_phob   [label="Task-specific phobia\n/ agoraphobia", fillcolor="#dfecbf"];
    Resp_compromise[label="Respiratory crisis\n(diaphragm spasm)", fillcolor="#dfecbf"];
  }

  /* ===================== 8. PK COMPARTMENTS ===================== */
  subgraph cluster_pk {
    label="8. PK compartments (drugs)";
    style="rounded,filled"; fillcolor="#fff4ec"; color="#cf6f1e";
    Diaz_GUT       [label="Diazepam GI", fillcolor="#ffd9b8"];
    Diaz_CENT      [label="Diazepam plasma", fillcolor="#ffd9b8"];
    Diaz_CNS       [label="Diazepam brain\nfree drug", fillcolor="#ffd9b8"];
    Diaz_DMD       [label="Desmethyldiazepam\n(active, t½ ~50h)", fillcolor="#ffd9b8"];
    Baclo_GUT      [label="Baclofen GI", fillcolor="#ffd9b8"];
    Baclo_CENT     [label="Baclofen plasma", fillcolor="#ffd9b8"];
    Baclo_IT       [label="Intrathecal baclofen\nCSF compartment", fillcolor="#ffd9b8"];
    Gaba_PK        [label="Gabapentin plasma", fillcolor="#ffd9b8"];
    Tiag_PK        [label="Tiagabine plasma\n(GAT-1 inhibitor)", fillcolor="#ffd9b8"];
    IVIG_PK        [label="IVIG plasma\n(t½ 21-28d)", fillcolor="#ffd9b8"];
    Rituximab_PK   [label="Rituximab plasma\n(target-mediated)", fillcolor="#ffd9b8"];
    PLEX_REM       [label="Plasmapheresis\n(40% IgG removal/session)", fillcolor="#ffd9b8"];
    PredPK         [label="Prednisone PK\n(prodrug → prednisolone)", fillcolor="#ffd9b8"];
    MMF_PK         [label="Mycophenolate PK\n(MPA)", fillcolor="#ffd9b8"];
    Tacro_PK       [label="Tacrolimus PK", fillcolor="#ffd9b8"];
    BTKi_PK        [label="BTK inhibitor PK\n(experimental)", fillcolor="#ffd9b8"];
  }

  /* ===================== 9. PD / MoA NODES ===================== */
  subgraph cluster_pd {
    label="9. Drug pharmacodynamics & MoA";
    style="rounded,filled"; fillcolor="#f0fbff"; color="#3a92a8";
    Diaz_PAM       [label="Diazepam PAM at\nGABA-A α1/α2/α3/α5", fillcolor="#cceef9"];
    Baclo_PAM      [label="Baclofen GABA-B\nagonism", fillcolor="#cceef9"];
    Gaba_a2d       [label="Gabapentin / pregabalin\nα2δ-1 binding", fillcolor="#cceef9"];
    Tiag_GAT       [label="Tiagabine GAT-1\nblockade → ↑ GABA", fillcolor="#cceef9"];
    Vigab_GABA_T   [label="Vigabatrin GABA-T\nirreversible inhibitor", fillcolor="#cceef9"];
    BTZ_VgT        [label="Bortezomib plasma-cell\ndepletion", fillcolor="#cceef9"];
    Rituximab_CD20 [label="Rituximab CD20+ B-cell\ndepletion", fillcolor="#cceef9"];
    Obinu_CD20     [label="Obinutuzumab\n(glycoengineered CD20)", fillcolor="#cceef9"];
    Inebilizumab   [label="Inebilizumab\n(anti-CD19)", fillcolor="#cceef9"];
    FcRn_Block     [label="FcRn block (rozanolixizumab\n/ efgartigimod)", fillcolor="#cceef9"];
    IVIG_idiotype  [label="IVIG anti-idiotype +\nFcγR modulation", fillcolor="#cceef9"];
    Pred_GR        [label="Prednisolone\nGR-mediated\nlymphopenia", fillcolor="#cceef9"];
    MMF_IMPDH      [label="MMF IMPDH-2\ninhibition", fillcolor="#cceef9"];
    Tacro_calcin   [label="Tacrolimus calcineurin/\nIL-2 inhibition", fillcolor="#cceef9"];
    HSCT           [label="Autologous HSCT\n(immune reset)", fillcolor="#cceef9"];
  }

  /* ===================== 10. BIOMARKERS / SCALES ===================== */
  subgraph cluster_biomarker {
    label="10. Biomarkers & clinical endpoints";
    style="rounded,filled"; fillcolor="#f4f4f4"; color="#4a4a4a";
    HSI            [label="Heightened Sensitivity\nIndex (HSI)", fillcolor="#e0e0e0"];
    Distrib_score  [label="Stiffness distribution\nscore (0-6)", fillcolor="#e0e0e0"];
    Severity_score [label="Stiffness severity\nscore (0-6)", fillcolor="#e0e0e0"];
    Spasm_freq     [label="Spasm frequency\n(per 24h diary)", fillcolor="#e0e0e0"];
    PROMIS_phys    [label="PROMIS physical\nfunction", fillcolor="#e0e0e0"];
    QoL            [label="EQ-5D / SF-36", fillcolor="#e0e0e0"];
    Anti_GAD_titer [label="Anti-GAD65 titer\n(RIA, IU/mL)", fillcolor="#e0e0e0"];
    CSF_index      [label="Intrathecal IgG index", fillcolor="#e0e0e0"];
    EMG_continuous [label="EMG continuous motor\nunit activity", fillcolor="#e0e0e0"];
    Hmax_Mmax      [label="H/M ratio", fillcolor="#e0e0e0"];
    MRS_GABA       [label="MRS brain GABA\n(motor cortex)", fillcolor="#e0e0e0"];
    Falls_rate     [label="Annual falls rate", fillcolor="#e0e0e0"];
    Hosp_rate      [label="Hospitalization rate", fillcolor="#e0e0e0"];
  }

  /* ===================== 11. SAFETY / TOX ===================== */
  subgraph cluster_safety {
    label="11. Safety, AE, tolerance";
    style="rounded,filled"; fillcolor="#fff5f0"; color="#b85c4f";
    BZD_tol        [label="BZD tolerance &\ndependence", fillcolor="#ffd1c4"];
    BZD_resp_dep   [label="Respiratory depression\n(BZD + opioid)", fillcolor="#ffd1c4"];
    Baclo_with     [label="Baclofen withdrawal\n(IT pump failure)", fillcolor="#ffd1c4"];
    PML_risk       [label="PML risk\n(rituximab, MMF)", fillcolor="#ffd1c4"];
    Infx_risk      [label="Infection risk\n(hypogammaglobulinemia)", fillcolor="#ffd1c4"];
    Steroid_AE     [label="Steroid AE\n(osteoporosis, DM)", fillcolor="#ffd1c4"];
    IVIG_thrombo   [label="IVIG thrombosis\n/ aseptic meningitis", fillcolor="#ffd1c4"];
    HSCT_AE        [label="HSCT TRM, infertility", fillcolor="#ffd1c4"];
    Falls_injury   [label="Falls / fractures", fillcolor="#ffd1c4"];
    Cognitive_AE   [label="Cognitive blunting\n(high-dose BZD)", fillcolor="#ffd1c4"];
  }

  /* ===================== EDGES (signal flow) ===================== */
  /* Genetic & trigger → immune */
  HLA_DRB1_03 -> APC [label="Ag presentation"];
  HLA_DQB1_02 -> APC;
  PTPN22      -> Th1 [label="↑ activation"];
  AIRE_var    -> Treg_def;
  CTLA4_var   -> Treg_def;
  INFECT_TRIG -> APC  [label="mimicry"];
  PARANEO     -> APC  [label="tumor Ag"];
  ICI_DRUG    -> Treg_def [label="↓ Treg"];

  /* APC → T cells */
  APC -> Th1;
  APC -> Th17;
  APC -> Tfh;
  Th1 -> Bcell_naive [label="cytokine help"];
  Tfh -> GC_react;
  Bcell_naive -> GC_react -> Plasmablast;
  Plasmablast -> LL_PC;
  Plasmablast -> Memory_B;
  GC_react -> CSF_Bcell [label="CNS migration"];
  Treg_def -> Th1 [label="loss of brake", color="#cf3f3f"];
  Treg_def -> Th17 [color="#cf3f3f"];

  /* Plasma cells → antibodies */
  LL_PC       -> GAD65_Ab_S;
  Plasmablast -> GAD65_Ab_S;
  CSF_Bcell   -> GAD65_Ab_CSF;
  GAD65_Ab_S  -> GAD65_Ab_CSF [label="BBB transudation"];
  GAD65_Ab_S  -> GAD67_Ab;
  GAD65_Ab_S  -> GABARAP_Ab;
  GAD65_Ab_S  -> Gephyrin_Ab;
  PARANEO     -> Amphiphysin_Ab;
  Bcell_naive -> GlyR_Ab [label="PERM variant"];
  GC_react    -> OCB;
  GC_react    -> DPPX_Ab;

  /* Antibody → GABAergic deficit */
  GAD65_Ab_CSF -> GAD65_enzyme [label="enzyme inhibition", color="#cf3f3f"];
  GAD65_Ab_CSF -> VGAT         [label="↓ vesicular loading", color="#cf3f3f"];
  GAD65_Ab_CSF -> GABA_release [label="↓ quantal release", color="#cf3f3f"];
  GABARAP_Ab   -> GABA_A_R     [label="↓ surface receptor", color="#cf3f3f"];
  Gephyrin_Ab  -> GABA_A_R     [color="#cf3f3f"];
  GlyR_Ab      -> GlyR_R       [color="#cf3f3f"];

  /* GABAergic chain */
  GAD65_enzyme -> GABA_synth;
  GAD67_enzyme -> GABA_synth;
  GABA_synth   -> GABA_pool;
  VGAT         -> GABA_pool;
  GABA_pool    -> GABA_release;
  GABA_release -> GABA_A_R;
  GABA_release -> GABA_B_R;
  GAT1         -> GABA_pool   [label="reuptake"];
  GABA_T       -> GABA_synth  [label="catabolism", style=dashed];
  Glutamate    -> NMDA_R;
  Glutamate    -> AMPA_R;
  GABA_A_R     -> Alpha_MN    [label="inhibition"];
  GABA_B_R     -> Alpha_MN;
  GABA_A_R     -> Renshaw;
  GABA_A_R     -> Ia_inh;
  GABA_A_R     -> Presyn_inh;
  GlyR_R       -> Renshaw;
  GlyR_R       -> Ia_inh;

  /* Spinal circuit pathology */
  Renshaw      -> Alpha_MN    [label="recurrent inh."];
  Ia_inh       -> Reciprocal_inh -> Alpha_MN;
  Presyn_inh   -> Alpha_MN    [label="afferent gain"];
  Alpha_MN     -> EAU_Cocont;
  Gamma_MN     -> EAU_Cocont;
  Alpha_MN     -> H_reflex;
  Alpha_MN     -> F_wave;
  H_reflex     -> Hmax_Mmax;
  Ib_GTO       -> Alpha_MN;

  /* Cortex */
  Motor_cortex -> Glutamate;
  Brainstem_RF -> Alpha_MN;
  Cerebellum   -> Motor_cortex [style=dashed];
  Amygdala     -> Sympathetic;
  Limbic_GABA  -> Amygdala     [label="↓ in SPS"];
  Sympathetic  -> Spasms       [label="trigger"];
  Vagal_tone   -> Anxiety_phob;

  /* Clinical features */
  Alpha_MN     -> Axial_stiff;
  Alpha_MN     -> Limb_stiff;
  EAU_Cocont   -> Spasms;
  Spasms       -> Falls;
  Limb_stiff   -> Gait;
  Gait         -> Falls;
  Motor_cortex -> Spasms;
  GlyR_R       -> PERM;
  Cerebellum   -> SPS_plus;
  Alpha_MN     -> Focal_SPS;
  AIRE_var     -> Comorbid_DM;
  AIRE_var     -> Comorbid_thy;
  Amygdala     -> Anxiety_phob;
  Resp_compromise -> Hosp_rate;
  Spasms       -> Resp_compromise;

  /* PK → PD */
  Diaz_GUT   -> Diaz_CENT -> Diaz_CNS -> Diaz_PAM;
  Diaz_CENT  -> Diaz_DMD   -> Diaz_PAM;
  Diaz_PAM   -> GABA_A_R   [label="↑ Cl- gating"];
  Baclo_GUT  -> Baclo_CENT -> Baclo_PAM;
  Baclo_IT   -> Baclo_PAM  [label="direct CSF"];
  Baclo_PAM  -> GABA_B_R;
  Gaba_PK    -> Gaba_a2d   -> Alpha_MN [label="↓ glutamate release"];
  Tiag_PK    -> Tiag_GAT   -> GAT1     [label="block"];
  Tiag_GAT   -> GABA_release [label="↑ synaptic GABA"];
  Vigab_GABA_T -> GABA_T   [label="irreversible"];
  IVIG_PK    -> IVIG_idiotype -> GAD65_Ab_S [label="neutralize / clear"];
  Rituximab_PK -> Rituximab_CD20 -> Memory_B [label="depletion"];
  Rituximab_CD20 -> Bcell_naive;
  Obinu_CD20  -> Memory_B;
  Inebilizumab -> Plasmablast;
  Inebilizumab -> Memory_B;
  FcRn_Block   -> GAD65_Ab_S [label="↑ IgG catabolism"];
  PredPK       -> Pred_GR  -> Th1;
  Pred_GR      -> Th17;
  MMF_PK       -> MMF_IMPDH -> Bcell_naive [label="anti-proliferative"];
  Tacro_PK     -> Tacro_calcin -> Th1;
  BTKi_PK      -> Bcell_naive [label="BCR signaling"];
  PLEX_REM     -> GAD65_Ab_S [label="bulk removal"];
  BTZ_VgT      -> LL_PC;
  HSCT         -> Memory_B  [label="reset"];
  HSCT         -> LL_PC;

  /* Biomarkers */
  GAD65_Ab_S   -> Anti_GAD_titer;
  GAD65_Ab_CSF -> CSF_index;
  Alpha_MN     -> EMG_continuous;
  Limb_stiff   -> Distrib_score;
  Axial_stiff  -> Severity_score;
  Spasms       -> Spasm_freq;
  Limb_stiff   -> HSI;
  Falls        -> Falls_rate;
  GABA_A_R     -> MRS_GABA;
  Gait         -> PROMIS_phys;
  PROMIS_phys  -> QoL;
  Spasm_freq   -> QoL;

  /* Safety */
  Diaz_PAM     -> BZD_tol;
  Diaz_PAM     -> Cognitive_AE;
  Diaz_CNS     -> BZD_resp_dep;
  Baclo_IT     -> Baclo_with [style=dashed, label="abrupt stop"];
  Rituximab_CD20 -> PML_risk;
  MMF_IMPDH    -> PML_risk;
  Rituximab_CD20 -> Infx_risk;
  IVIG_PK      -> IVIG_thrombo;
  Pred_GR      -> Steroid_AE;
  HSCT         -> HSCT_AE;
  Falls        -> Falls_injury;
  Falls_injury -> Hosp_rate;
}
