digraph HAE_QSP_Model {
    graph [
        label="Hereditary Angioedema (HAE) — QSP Mechanistic Map\nKallikrein-Kinin System · C1-INH Biology · Bradykinin Signaling · PK/PD",
        labelloc=t, labeljust=c,
        fontname="Helvetica", fontsize=16, fontcolor="#1a1a2e",
        bgcolor="#f8f9fa",
        splines=line, overlap=false,
        layout=fdp, K=0.9,
        pad=0.8
    ]
    node [fontname="Helvetica", fontsize=9, style=filled, shape=box, margin="0.12,0.06"]
    edge [fontname="Helvetica", fontsize=7, penwidth=1.1, arrowsize=0.7]

    /* ═══════════════════════════════════════════════════════════
       CLUSTER 1: 유전 기초 (Genetic Basis)
    ══════════════════════════════════════════════════════════ */
    subgraph cluster_genetics {
        label="① Genetic Basis & Molecular Pathology"
        style=filled; fillcolor="#e8f4f8"; color="#2196F3"; penwidth=2
        fontname="Helvetica-Bold"; fontsize=11; fontcolor="#1565C0"

        SERPING1_gene [label="SERPING1 Gene\n(C1-INH encoding)", fillcolor="#bbdefb", shape=diamond]
        C1INH_protein [label="C1-Inhibitor\n(native, functional)", fillcolor="#1976D2", fontcolor=white]
        C1INH_type1 [label="HAE Type I\n(C1INH deficient\n<10-50% level)", fillcolor="#ef9a9a"]
        C1INH_type2 [label="HAE Type II\n(C1INH dysfunctional\nNormal antigen)", fillcolor="#ef9a9a"]
        FXII_gene [label="F12 Gene (FXII)", fillcolor="#bbdefb", shape=diamond]
        FXII_mut_HAE3 [label="FXII p.Thr328Lys\n(HAE type III)", fillcolor="#f48fb1"]
        KNG1_gene [label="KNG1 Gene\n(Kininogen)", fillcolor="#bbdefb", shape=diamond]
        KLKB1_gene [label="KLKB1 Gene\n(Prekallikrein)", fillcolor="#bbdefb", shape=diamond]
        PLG_ANGPT1 [label="ANGPT1/PLG Mut\n(HAE nC1INH)", fillcolor="#f48fb1"]
        SERPING1_mut_null [label="Null Mutation\n(frameshift, nonsense)", fillcolor="#ffcdd2", shape=ellipse]
        SERPING1_mut_missense [label="Missense Mutation\n(dysfunctional prot)", fillcolor="#ffcdd2", shape=ellipse]
        HNF1A_promoter [label="HNF1alpha\n(C1INH promoter)", fillcolor="#e1f5fe", shape=ellipse]
        Estrogen_HAE3 [label="Estrogen\n(FXII activation)", fillcolor="#fce4ec", shape=ellipse]
        C1INH_regulation [label="C1-INH regulates:\nC1r/C1s, MASPs\ntPA, FXI, FXa", fillcolor="#c8e6c9"]
    }

    /* ═══════════════════════════════════════════════════════════
       CLUSTER 2: 접촉 활성화 (Contact Activation)
    ══════════════════════════════════════════════════════════ */
    subgraph cluster_contact {
        label="② Contact Activation System"
        style=filled; fillcolor="#fff9e6"; color="#FF9800"; penwidth=2
        fontname="Helvetica-Bold"; fontsize=11; fontcolor="#E65100"

        FXII_zymogen [label="FXII (Factor XII)\nHageman Factor", fillcolor="#ffe082"]
        Surface_trigger [label="Contact Trigger\n(collagen, heparan\nsulfate, polyphosphate)", fillcolor="#ffcc80", shape=ellipse]
        Polyphosphate [label="Polyphosphates\n(platelet, bacterial)", fillcolor="#ffcc80", shape=ellipse]
        FXIIa [label="FXIIa (activated)\n[Serine protease]", fillcolor="#F57C00", fontcolor=white]
        FXIIf [label="FXIIf (80kDa)\n[Fluid phase]", fillcolor="#ef6c00", fontcolor=white]
        PK_zymogen [label="Prekallikrein\n(KLKB1 precursor)", fillcolor="#ffe082"]
        HK_HMWK [label="HMWK (High-MW\nKininogen, cofactor)", fillcolor="#ffe082"]
        Zn2plus [label="Zn2+\n(HMWK-PK\ncofactor)", fillcolor="#fff9c4", shape=ellipse]
        uPA_activator [label="uPA/tPA\n(alt. FXII\nactivation)", fillcolor="#ffe0b2", shape=ellipse]
        FXI_activation [label="FXI (Coagulation)\nby FXIIa", fillcolor="#ffecb3"]
        Auto_amplification [label="Autoamplification\nFXIIa-Kal-FXIIf\nPositive feedback", fillcolor="#ff8f00", fontcolor=white, shape=hexagon]
    }

    /* ═══════════════════════════════════════════════════════════
       CLUSTER 3: 칼리크레인-키닌 (KKS)
    ══════════════════════════════════════════════════════════ */
    subgraph cluster_KKS {
        label="③ Kallikrein-Kinin System (KKS)"
        style=filled; fillcolor="#fce4ec"; color="#E91E63"; penwidth=2
        fontname="Helvetica-Bold"; fontsize=11; fontcolor="#880E4F"

        Plasma_Kallikrein [label="Plasma Kallikrein\n(KLKB1 activated)\nKey pathogenic enzyme", fillcolor="#E91E63", fontcolor=white]
        Tissue_Kallikrein [label="Tissue Kallikrein\n(KLK1)", fillcolor="#f48fb1"]
        HMWK_cleavage [label="HMWK Cleavage\n(2-chain BK release)", fillcolor="#f8bbd9"]
        BK_bradykinin [label="Bradykinin (BK)\n9-amino acid peptide\nPrimary mediator", fillcolor="#c2185b", fontcolor=white, shape=oval]
        Kallidin_LysBK [label="Kallidin\n(Lys-Bradykinin)\nTissue kallikrein", fillcolor="#f06292"]
        BK_des_arg9 [label="des-Arg9-BK\n[B1R agonist]", fillcolor="#f48fb1"]
        BK_half_life [label="BK t1/2 < 30 sec\n(rapid kininase\ndegradation)", fillcolor="#fce4ec", shape=note]
        ACE_kininase2 [label="ACE (Kininase II)\nMajor BK degrader", fillcolor="#c8e6c9", shape=diamond]
        NEP_endopeptidase [label="Neprilysin (NEP)\nNeutral endopeptidase", fillcolor="#c8e6c9", shape=diamond]
        Carboxypeptidase_N [label="Carboxypeptidase N\n(plasma kininase I)", fillcolor="#c8e6c9", shape=diamond]
        Carboxypeptidase_M [label="Carboxypeptidase M\n(membrane-bound)", fillcolor="#c8e6c9", shape=diamond]
        HMWK_cleaved_ratio [label="Cleaved HMWK\n(diagnostic biomarker)", fillcolor="#fce4ec", shape=note]
    }

    /* ═══════════════════════════════════════════════════════════
       CLUSTER 4: C1-INH & 보체 (C1-INH & Complement)
    ══════════════════════════════════════════════════════════ */
    subgraph cluster_complement {
        label="④ C1-INH Biology & Complement Activation"
        style=filled; fillcolor="#e8f5e9"; color="#4CAF50"; penwidth=2
        fontname="Helvetica-Bold"; fontsize=11; fontcolor="#1B5E20"

        C1INH_native [label="C1-INH\n(Active Serpin)\nReactive center loop", fillcolor="#4CAF50", fontcolor=white]
        Serpin_mechanism [label="SERPIN Inhibition\nSuicide mechanism:\nRCL cleaved, covalent", fillcolor="#a5d6a7", shape=hexagon]
        C1INH_FXIIa [label="C1-INH:FXIIa\nCovalent Complex\n[Inhibited FXIIa]", fillcolor="#81c784"]
        C1INH_Kallikrein [label="C1-INH:Kallikrein\nCovalent Complex\n[Inhibited Kal]", fillcolor="#81c784"]
        C1INH_C1r [label="C1-INH:C1r/C1s\nClassical pathway\ninhibition", fillcolor="#81c784"]
        C1INH_MASP1 [label="C1-INH:MASP1/2\nLectin pathway\ninhibition", fillcolor="#a5d6a7"]
        C1_complex [label="C1q:C1r2:C1s2\nClassical Pathway\nInitiation Complex", fillcolor="#66bb6a"]
        C4_cleavage [label="C4 Cleavage\nC4 -> C4a + C4b\n[Diagnostic marker]", fillcolor="#a5d6a7"]
        C4_serum [label="Serum C4\nKEY DIAGNOSTIC\nLow in HAE I/II\nNormal in HAE III", fillcolor="#2E7D32", fontcolor=white, shape=parallelogram]
        C2_cleavage [label="C2 Cleavage\nC2 -> C2a + C2b", fillcolor="#c8e6c9"]
        C2_kinin [label="C2 Kinin (minor)\nPro-edema peptide", fillcolor="#dcedc8"]
        C3_convertase [label="C3 Convertase\n(C4b2a)\nClassical pathway", fillcolor="#81c784"]
        C1INH_consumption [label="C1-INH Consumption\nReduced levels\nUncontrolled KKS", fillcolor="#e8f5e9", shape=note]
    }

    /* ═══════════════════════════════════════════════════════════
       CLUSTER 5: BK 수용체 신호 (BK Receptor Signaling)
    ══════════════════════════════════════════════════════════ */
    subgraph cluster_BK_signaling {
        label="⑤ Bradykinin Receptor Signaling"
        style=filled; fillcolor="#f3e5f5"; color="#9C27B0"; penwidth=2
        fontname="Helvetica-Bold"; fontsize=11; fontcolor="#4A148C"

        B2R [label="B2 Receptor\n(BDKRB2)\nConstitutively expressed\nPrimary mediator", fillcolor="#9C27B0", fontcolor=white]
        B2R_BK_complex [label="B2R:BK Complex\nG-protein activation", fillcolor="#ba68c8"]
        Gq_protein [label="Gq Protein\n(primary coupling)", fillcolor="#ce93d8"]
        Gi_protein [label="Gi Protein\n(cAMP decrease)", fillcolor="#ce93d8"]
        PLC_beta [label="PLCbeta\n(Phospholipase C-B)", fillcolor="#ab47bc"]
        IP3 [label="IP3\n(Inositol\ntrisphosphate)", fillcolor="#e1bee7"]
        DAG [label="DAG\n(Diacylglycerol)", fillcolor="#e1bee7"]
        Ca2plus [label="Ca2+ Release\n(ER stores)\nIntracellular Ca2+", fillcolor="#7b1fa2", fontcolor=white]
        PKC [label="PKC\n(Protein Kinase C)", fillcolor="#ce93d8"]
        eNOS [label="eNOS\n(endothelial NOS)\nCalmodulin-dependent", fillcolor="#ab47bc"]
        NO_production [label="NO Production\n(Nitric Oxide)\nVasodilation +\npermeability", fillcolor="#6a1b9a", fontcolor=white, shape=oval]
        sGC_cGMP [label="sGC -> cGMP\nVasodilation\nsignaling", fillcolor="#ce93d8"]
        B1R [label="B1 Receptor\n(BDKRB1)\nInducible (inflam)\nSecondary mediator", fillcolor="#8e24aa", fontcolor=white]
        B1R_activation [label="B1R:des-Arg9BK\nActivation\nChronic/recurrent", fillcolor="#ce93d8"]
        NFkB_B1 [label="NF-kB Activation\n(via B1R)\nIL-1B, TNF-alpha", fillcolor="#7b1fa2", fontcolor=white]
        EGFR_trans [label="EGFR Transactiv.\n(via B2R)\nMAPK/ERK", fillcolor="#ba68c8"]
        Arachidonic_acid [label="Arachidonic Acid\nRelease (PLA2)", fillcolor="#e1bee7"]
        PGI2_production [label="PGI2 + PGE2\n(Vasodilation)", fillcolor="#ce93d8"]
        Beta_arrestin [label="B2R Desensitiz.\nbeta-Arrestin\n(B2R internalized)", fillcolor="#e1bee7"]
    }

    /* ═══════════════════════════════════════════════════════════
       CLUSTER 6: 혈관 효과 (Vascular Effects)
    ══════════════════════════════════════════════════════════ */
    subgraph cluster_vascular {
        label="⑥ Vascular Endothelial Effects & Edema"
        style=filled; fillcolor="#e0f2f1"; color="#009688"; penwidth=2
        fontname="Helvetica-Bold"; fontsize=11; fontcolor="#004D40"

        EC_tight_junctions [label="Endothelial Tight\nJunctions disrupted", fillcolor="#80cbc4"]
        VE_cadherin [label="VE-Cadherin\nAdheren junction\ndisruption", fillcolor="#4db6ac"]
        ZO1_ZO2 [label="ZO-1/ZO-2\nTight junction\nproteins", fillcolor="#b2dfdb"]
        Actin_remodel [label="Actin Cytoskel.\nRemodeling\n(cell retraction)", fillcolor="#4db6ac"]
        Endothelial_permeability [label="Endothelial Permeab.\nINCreased\nKey pathogenic event", fillcolor="#00695C", fontcolor=white, shape=oval]
        Plasma_extravasation [label="Plasma Extravasation\nto Interstitium\n(protein-rich fluid)", fillcolor="#00897B", fontcolor=white]
        Vasodilation [label="Local Vasodilation\n(arteriolar/venular)", fillcolor="#26a69a"]
        Subcutaneous_edema [label="Subcutaneous Edema\nSkin: 46-91% attacks", fillcolor="#80cbc4"]
        Abdominal_edema [label="Abdominal Edema\nGI wall: 30-40%\nSevere pain", fillcolor="#4db6ac"]
        Laryngeal_edema [label="Laryngeal Edema\nAirways: LETHAL\nif untreated!", fillcolor="#b71c1c", fontcolor=white, shape=hexagon]
        Urogenital_edema [label="Urogenital Edema\n(genitalia, bladder)", fillcolor="#b2dfdb"]
        Erythema_marginatum [label="Erythema Marginatum\n(prodromal sign\n1-24h before)", fillcolor="#80cbc4"]
        AQP1 [label="AQP1 Aquaporin\nWater flux\nfacilitation", fillcolor="#b2dfdb", shape=diamond]
        Mast_cell_NOT [label="Mast cells NOT\nprimarily involved\n(HAE not allergic)\nNo IgE/histamine", fillcolor="#f5f5f5", shape=note, style="dashed,filled"]
    }

    /* ═══════════════════════════════════════════════════════════
       CLUSTER 7: 발작 병태 (Attack Pathogenesis)
    ══════════════════════════════════════════════════════════ */
    subgraph cluster_attack {
        label="⑦ Acute Attack Pathogenesis & Triggers"
        style=filled; fillcolor="#fff3e0"; color="#FF5722"; penwidth=2
        fontname="Helvetica-Bold"; fontsize=11; fontcolor="#BF360C"

        Trigger_emotional [label="Emotional Stress\n(catecholamines,\nFXII activation)", fillcolor="#ffccbc"]
        Trigger_physical [label="Physical Trauma\nMinor/Major", fillcolor="#ffccbc"]
        Trigger_surgical [label="Surgery/Dental\nHIGH RISK\n(prophylaxis req.)", fillcolor="#ff7043"]
        Trigger_estrogen [label="Estrogen\n(OCP, HRT, pregnancy\nFXII activation++)", fillcolor="#f48fb1"]
        Trigger_ACEi [label="ACE Inhibitor\n(blocks BK degradation\nBK accumulation)", fillcolor="#ef9a9a"]
        Trigger_infection [label="Infection\n(endotoxin\nactivates FXII)", fillcolor="#ffccbc"]
        Attack_onset [label="Attack Onset\n12-36h post-trigger", fillcolor="#ff5722", fontcolor=white, shape=oval]
        Attack_peak [label="Attack Peak\n24-48h max severity", fillcolor="#e64a19", fontcolor=white]
        Attack_duration [label="Duration: 2-5 days\n(untreated) vs\n4-8h (treated)", fillcolor="#ff8a65"]
        Attack_prodrome [label="Prodromal Phase\n(tingling, erythema\nfatigue, anxiety)", fillcolor="#ffccbc"]
        Recurrence [label="Recurrence: 1-50\nattacks/year\n(highly variable)", fillcolor="#ffe0b2"]
        HAE_mortality [label="HAE Mortality\nLaryngeal asphyx.\nHist. ~30% families", fillcolor="#b71c1c", fontcolor=white, shape=hexagon]
        C4_during_attack [label="C4 drops during\nattack; also low\nbetween attacks", fillcolor="#fff9c4", shape=note]
    }

    /* ═══════════════════════════════════════════════════════════
       CLUSTER 8: 급성 치료 PK/PD (Acute Treatment)
    ══════════════════════════════════════════════════════════ */
    subgraph cluster_acute_drugs {
        label="⑧ Acute Treatment PK/PD"
        style=filled; fillcolor="#e3f2fd"; color="#2196F3"; penwidth=2
        fontname="Helvetica-Bold"; fontsize=11; fontcolor="#0D47A1"

        Icatibant [label="Icatibant (Firazyr)\n30mg SC peptide\nB2R antagonist", fillcolor="#1E88E5", fontcolor=white]
        Icatibant_PK [label="Icatibant PK\nka=0.74/h, F=97%\nVd=29L, t1/2=1.3h", fillcolor="#90caf9"]
        Icatibant_B2R_block [label="Icatibant B2R Block\nKi=0.47 nM\nCompetitive\nImax>98%", fillcolor="#1976D2", fontcolor=white]
        Icatibant_effect [label="Clinical Effect\nOnset: 30 min\nRelief: 2h\nRepeat if needed", fillcolor="#42a5f5"]
        C1INH_IV_Berinert [label="C1-INH IV\n(Berinert 20U/kg)\nPlasma-derived", fillcolor="#1E88E5", fontcolor=white]
        C1INH_IV_PK [label="C1-INH IV PK\nVd=3.3L\nt1/2=30-50h\nCL=0.04 L/h", fillcolor="#bbdefb"]
        C1INH_IV_restore [label="C1-INH Restoration\nReplenishes pool\nRestores inhibition", fillcolor="#90caf9"]
        C1INH_rHALP [label="Recombinant C1-INH\n(Ruconest 50U/kg)\nFaster action", fillcolor="#42a5f5"]
        Ecallantide [label="Ecallantide\n(Kalbitor 30mg SC)\nKallikrein inhibitor\n[US only]", fillcolor="#1565C0", fontcolor=white]
        Ecallantide_Ki [label="Ecallantide Ki=24pM\nAnti-kallikrein Fab\nRapid onset", fillcolor="#90caf9"]
        FFP_rescue [label="FFP (rescue)\nC1-INH + coag\nfactors", fillcolor="#bbdefb"]
        Icatibant_vs_C1INH [label="Head-to-head:\nIcatibant ~= C1-INH\n(IASC study)", fillcolor="#e3f2fd", shape=note]
    }

    /* ═══════════════════════════════════════════════════════════
       CLUSTER 9: 예방 치료 PK/PD (Prophylaxis)
    ══════════════════════════════════════════════════════════ */
    subgraph cluster_prophylaxis {
        label="⑨ Prophylaxis Treatment PK/PD"
        style=filled; fillcolor="#e8f5e9"; color="#388E3C"; penwidth=2
        fontname="Helvetica-Bold"; fontsize=11; fontcolor="#1B5E20"

        Berotralstat [label="Berotralstat\n(Orladeyo 150mg PO)\nOral kallikrein inhib\nQD prophylaxis", fillcolor="#2E7D32", fontcolor=white]
        Berotralstat_PK [label="Berotralstat PK\nF=57%, ka=0.35/h\nVd=268L, t1/2=93h\nCL=2.0 L/h", fillcolor="#a5d6a7"]
        Berotralstat_PD [label="Berotralstat PD\nIC50=3.7nM\nEmax=85-92%\nKallikrein inhib.", fillcolor="#388E3C", fontcolor=white]
        Berotralstat_clinical [label="BELO study:\n-44% attacks\nMedian 0/month", fillcolor="#66bb6a"]
        Lanadelumab [label="Lanadelumab\n(Takhzyro 300mg SC)\nAnti-KLKB1 mAb\nQ2W or Q4W", fillcolor="#1B5E20", fontcolor=white]
        Lanadelumab_PK [label="Lanadelumab PK\nF=61%, Tmax=5-7d\nVd=6.4L, t1/2=17d\nCL=0.0139 L/h", fillcolor="#a5d6a7"]
        Lanadelumab_MoA [label="Lanadelumab MoA\nBlocks prekallikrein\nactivation KD<100pM", fillcolor="#2E7D32", fontcolor=white]
        Lanadelumab_clinical [label="HELP OLE:\n87% attack reduc.\n32% attack-free\n(300mg Q2W)", fillcolor="#43a047"]
        C1INH_SC_Haegarda [label="C1-INH SC\n(Haegarda 60U/kg)\nTwice-weekly SC\nprophylaxis", fillcolor="#4CAF50", fontcolor=white]
        C1INH_SC_PK [label="Haegarda SC PK\nF=43%, Tmax=48-72h\nSteady-state C1INH\nraise >40%", fillcolor="#a5d6a7"]
        C1INH_SC_clinical [label="CONFIDENT trial:\n95% attack reduc.\nnormalize C4", fillcolor="#66bb6a"]
        Danazol_old [label="Danazol (androgen)\nOlder prophylaxis\nC1INH synthesis up\n(side effects)", fillcolor="#c8e6c9"]
        Tranexamic_acid [label="Tranexamic Acid\nOlder/mild cases\nAntifibrinolytic\n(limited efficacy)", fillcolor="#c8e6c9"]
        Garadacimab [label="Garadacimab\n(Anti-FXIIa Ab)\nPhase 3 positive\n[Emerging]", fillcolor="#dce775", style="dashed,filled"]
        STP705_dsiRNA [label="STP705 (dsiRNA)\nKNG1 silencing\nExperimental", fillcolor="#f0f4c3", style="dashed,filled"]
    }

    /* ═══════════════════════════════════════════════════════════
       CLUSTER 10: 면역·염증 증폭 (Immune Amplification)
    ══════════════════════════════════════════════════════════ */
    subgraph cluster_inflammation {
        label="⑩ Immune & Inflammatory Amplification"
        style=filled; fillcolor="#fff8e1"; color="#FFC107"; penwidth=2
        fontname="Helvetica-Bold"; fontsize=11; fontcolor="#FF6F00"

        IL1B_induction [label="IL-1B Induction\n(via B1R/NF-kB)\nChronic inflam.", fillcolor="#ffe082"]
        TNFa_induction [label="TNF-alpha Induction\nAmplification loop", fillcolor="#ffe082"]
        IL6_local [label="IL-6 Local\nVascular permeability\nincrease", fillcolor="#ffe082"]
        Coagulation_crosstalk [label="Coagulation Cross.\nFXII->FXI->FIXa\nThrombin generation", fillcolor="#ffd54f"]
        Thrombin_PAR1 [label="Thrombin -> PAR1\nMast cell activation\nPlatelet aggreg.", fillcolor="#ffb300"]
        Fibrinolysis_link [label="Fibrinolysis Link\ntPA/plasmin -> FXII\nReactivation loop", fillcolor="#ffe082"]
        vWF_release [label="vWF Release\n(EC activation)\nPlatelet adhesion", fillcolor="#ffd740"]
        P_selectin_expr [label="P-Selectin\nNeutrophil\nrecruitment", fillcolor="#ffe082"]
        Neutrophil_recruit [label="Neutrophil\nRecruitment\n(late phase)", fillcolor="#ffd54f"]
        HAE_vs_allergic [label="HAE vs Allergic AE:\nNo histamine,\nNo IgE, No H1/H2\nantihistamine effect", fillcolor="#fff9c4", shape=note]
    }

    /* ═══════════════════════════════════════════════════════════
       CLUSTER 11: 임상 엔드포인트 (Clinical Endpoints)
    ══════════════════════════════════════════════════════════ */
    subgraph cluster_endpoints {
        label="⑪ Clinical Endpoints & Biomarkers"
        style=filled; fillcolor="#fce4ec"; color="#E91E63"; penwidth=2
        fontname="Helvetica-Bold"; fontsize=11; fontcolor="#880E4F"

        Attack_frequency [label="Attack Frequency\n(attacks/month)\nPrimary endpoint", fillcolor="#E91E63", fontcolor=white]
        Attack_severity [label="Attack Severity\n(VAS 0-100)\nSymptom score", fillcolor="#f06292"]
        Symptom_duration [label="Symptom Duration\n(hours to resolution)", fillcolor="#f48fb1"]
        Location_skin [label="Skin (46-91%)\nFace, extremities\ntrunk", fillcolor="#fce4ec"]
        Location_abdomen [label="Abdomen (30-40%)\nSevere cramping\nmimics acute abdomen", fillcolor="#f48fb1"]
        Location_larynx [label="Larynx (0.9%/attack)\nAirway obstruction\nEMERGENCY", fillcolor="#c62828", fontcolor=white, shape=hexagon]
        AE_QoL [label="AE-QoL\n(Angioedema\nQuality of Life)", fillcolor="#f48fb1"]
        ACE_test [label="ACE Test\n(Control Test 0-16)\n>=10 = controlled", fillcolor="#e91e63", fontcolor=white]
        Emergency_visits [label="ED Visits\n(severe attacks)", fillcolor="#f06292"]
        C4_biomarker [label="C4 Level\nKEY BIOMARKER\nLow in HAE I/II\n(interattack too)", fillcolor="#c62828", fontcolor=white, shape=parallelogram]
        C1INH_antigen_bio [label="C1-INH Antigen\n<50% in HAE I", fillcolor="#f48fb1", shape=parallelogram]
        C1INH_functional_bio [label="C1-INH Function\n<50% in HAE I/II\nDiagnostic", fillcolor="#c62828", fontcolor=white, shape=parallelogram]
        Plasma_BK_bio [label="Plasma BK Level\nUp during attacks\nexperimental", fillcolor="#f48fb1", shape=parallelogram]
        HMWK_biomarker [label="Cleaved HMWK\nUp during attacks\nnormalize in remission", fillcolor="#f06292", shape=parallelogram]
        Kallikrein_activity [label="Plasma Kallikrein\nActivity (up attacks)", fillcolor="#f48fb1", shape=parallelogram]
        Days_free [label="Symptom-Free Days\nWell-controlled:\n<=2 attacks/month", fillcolor="#fce4ec"]
    }

    /* ═══════════════════════════════════════════════════════════
       CLUSTER 12: 진단 체계 (Diagnostic Workup)
    ══════════════════════════════════════════════════════════ */
    subgraph cluster_diagnosis {
        label="⑫ Diagnostic Workup & HAE Classification"
        style=filled; fillcolor="#ede7f6"; color="#673AB7"; penwidth=2
        fontname="Helvetica-Bold"; fontsize=11; fontcolor="#311B92"

        Clinical_suspicion [label="Clinical Suspicion\nRecurrent angioedema\nFamily history\nLaryngeal/abdom.", fillcolor="#b39ddb"]
        Step1_C4 [label="Step 1: Serum C4\n(Low = screen +)\n>90% sensitivity", fillcolor="#7e57c2", fontcolor=white]
