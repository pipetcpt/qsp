        ACEi_AE_dx [label="ACEi-induced AE\nBK-mediated\nNormal C1INH/C4\nNot HAE", fillcolor="#e1bee7", shape=parallelogram]
        Differential_diag [label="Differential:\nAllergic AE (IgE)\nHistaminergic AE\nMast cell disease", fillcolor="#ede7f6", shape=note]
    }

