digraph CPN_QSP {
  graph [
    layout=fdp,
    overlap=false,
    fontname="Helvetica",
    fontsize=12,
    nodesep=0.35,
    ranksep=0.55,
    label="만성 신우신염 (Chronic Pyelonephritis) — QSP Mechanistic Map\nBacterial Pathogenesis · Innate/Adaptive Immunity · Renal Fibrosis · Antibiotic PK/PD · Clinical Endpoints",
    labelloc=t,
    labelfontsize=15,
    bgcolor="#f8f9fa"
  ];
  node [shape=box, style="filled,rounded", fontname="Helvetica", fontsize=9, margin="0.12,0.06"];
  edge [fontname="Helvetica", fontsize=8, arrowsize=0.7];

  // ============================================================
  // CLUSTER 1 — Bacterial Pathogens
  // ============================================================
  subgraph cluster_bacteria {
    label="① Bacterial Pathogens\n(병원성 세균)";
    style=filled; color="#cc3333"; fillcolor="#fff0f0"; fontsize=11; fontcolor="#cc0000";

    Ecoli        [label="E. coli (UPEC)\n대장균", fillcolor="#ff8888", shape=ellipse];
    Klebsiella   [label="Klebsiella\npneumoniae", fillcolor="#ffaaaa", shape=ellipse];
    Proteus      [label="Proteus\nmirabilis", fillcolor="#ffbbbb", shape=ellipse];
    Pseudomonas  [label="Pseudomonas\naeruginosa", fillcolor="#ffcccc", shape=ellipse];
    Enterococcus [label="Enterococcus\nfaecalis", fillcolor="#ffdddd", shape=ellipse];
    TypeI_Fim    [label="Type I Fimbriae\n(FimH—mannose)", fillcolor="#ffdddd"];
    P_Fim        [label="P-Fimbriae\n(PapG—Gal-Gal)", fillcolor="#ffdddd"];
    HlyA         [label="α-Hemolysin\n(HlyA toxin)", fillcolor="#ffcccc"];
    Aerobactin   [label="Aerobactin\n(Fe siderophore)", fillcolor="#ffcccc"];
    CNF1         [label="CNF1 Toxin\n(Rho-GTPase)", fillcolor="#ffcccc"];
    LPS          [label="Lipopolysaccharide\n(LPS / Lipid A)", fillcolor="#ff7777"];
    Flagellin    [label="Flagellin\n(fliC — PAMP)", fillcolor="#ffaaaa"];
    Biofilm      [label="Biofilm\nFormation", fillcolor="#ff9999"];
    QS           [label="Quorum Sensing\n(LuxI/LuxR)", fillcolor="#ffbbbb"];
    BacterialLoad [label="Renal Bacterial\nBurden (CFU/g)", fillcolor="#dd0000", fontcolor=white, shape=diamond];
    ESBL         [label="ESBL / KPC\n(β-lactamase)", fillcolor="#ff5555"];
    gyrA         [label="gyrA/parC\nMutation (FQ-R)", fillcolor="#ff6666"];
    DHFR_mut     [label="DHFR Mutation\n(TMP-R)", fillcolor="#ff7777"];
  }

  // ============================================================
  // CLUSTER 2 — Urinary Tract Anatomy & VUR
  // ============================================================
  subgraph cluster_anatomy {
    label="② Urinary Tract Anatomy & VUR\n(요로 해부학 및 방광요관역류)";
    style=filled; color="#3355cc"; fillcolor="#f0f4ff"; fontsize=11; fontcolor="#2244aa";

    Bladder      [label="Bladder\n방광", fillcolor="#99bbff"];
    Ureter       [label="Ureter\n요관", fillcolor="#aaccff"];
    UVJ          [label="UVJ\n방광요관접합부", fillcolor="#bbddff"];
    VUR_Grade    [label="VUR Grade I–V\n(역류 중증도)", fillcolor="#4477ee", fontcolor=white, shape=diamond];
    IntraRR      [label="Intrarenal Reflux\n신내 역류", fillcolor="#7799ee"];
    CompPap      [label="Compound Papillae\n복합 유두 (취약)", fillcolor="#99aaee"];
    RenalPelvis  [label="Renal Pelvis\n신우", fillcolor="#8899dd"];
    Kidney       [label="Kidney Parenchyma\n신장 실질", fillcolor="#5577cc", fontcolor=white];
    UrineFlow    [label="Urine Flow Rate\n소변 흐름", fillcolor="#aabbee"];
    Obstruction  [label="Obstructive\nUropathy", fillcolor="#7788dd"];
    NeuroBladder [label="Neurogenic Bladder\n신경인성방광", fillcolor="#9999cc"];
    UrinaryCal   [label="Urinary Calculi\n요로결석 (nidus)", fillcolor="#8888cc"];
  }

  // ============================================================
  // CLUSTER 3 — Innate Immune / TLR Signaling
  // ============================================================
  subgraph cluster_innate {
    label="③ Innate Immune Response & TLR Signaling\n(선천 면역 및 톨-유사 수용체)";
    style=filled; color="#cc6600"; fillcolor="#fffbf0"; fontsize=11; fontcolor="#aa4400";

    TLR4   [label="TLR4\n(LPS receptor)", fillcolor="#ffbb66"];
    TLR5   [label="TLR5\n(flagellin)", fillcolor="#ffbb66"];
    TLR11  [label="TLR11\n(FliC)", fillcolor="#ffcc77"];
    TLR2   [label="TLR2\n(peptidoglycan)", fillcolor="#ffcc77"];
    MyD88  [label="MyD88\nadaptor", fillcolor="#ff9933"];
    IRAK4  [label="IRAK4\nkinase", fillcolor="#ff9933"];
    TRAF6  [label="TRAF6\nubiquitin ligase", fillcolor="#ff8822"];
    IKK    [label="IKK complex\n(IKKα/β/γ)", fillcolor="#ff7711"];
    NFkB   [label="NF-κB\n(p65/p50)", fillcolor="#ee5500", fontcolor=white, shape=diamond];
    AP1    [label="AP-1\n(c-Fos/c-Jun)", fillcolor="#ff9944"];
    IRF3   [label="IRF3\n(IFN-I pathway)", fillcolor="#ffaa55"];
    NLRP3  [label="NLRP3\nInflammasome", fillcolor="#ffaa44"];
    Casp1  [label="Caspase-1\nactivation", fillcolor="#ffbb55"];
    ProIL1 [label="Pro-IL-1β\n→ IL-1β (mature)", fillcolor="#ffcc66"];
    Complt [label="Complement\nC1q–C3–C9", fillcolor="#ffdd88"];
    C3b    [label="C3b\nOpsonin", fillcolor="#ffee99"];
    C5a    [label="C5a\nAnaphylatoxin", fillcolor="#ffee99"];
    MAC    [label="Membrane Attack\nComplex (MAC)", fillcolor="#ffdd77"];
    Neutro [label="Neutrophils\n(PMN infiltration)", fillcolor="#ffd700", shape=ellipse];
    Macro  [label="Macrophages\n(M1/M2 switch)", fillcolor="#ffa500", shape=ellipse];
    NK     [label="NK Cells\n(innate lymphoid)", fillcolor="#ffcc44", shape=ellipse];
    Mast   [label="Mast Cells\n(histamine/cytokines)", fillcolor="#ffee77", shape=ellipse];
    ROS    [label="ROS\nOxidative Stress", fillcolor="#ff6600"];
    MPO    [label="MPO\nmyeloperoxidase", fillcolor="#ff8800"];
    NETs   [label="NETs\n(neutrophil extracell.)", fillcolor="#ffaa00"];
  }

  // ============================================================
  // CLUSTER 4 — Cytokine / Chemokine Network
  // ============================================================
  subgraph cluster_cytokines {
    label="④ Cytokine & Chemokine Network\n(사이토카인 / 케모카인)";
    style=filled; color="#336633"; fillcolor="#f0fff0"; fontsize=11; fontcolor="#224422";

    IL1b   [label="IL-1β\n(pyrogenic)", fillcolor="#55cc55"];
    IL6    [label="IL-6\n(acute phase)", fillcolor="#44bb44"];
    IL8    [label="IL-8 / CXCL8\n(PMN chemoattract.)", fillcolor="#55cc55"];
    TNFa   [label="TNF-α\n(master cytokine)", fillcolor="#33aa33"];
    IL10   [label="IL-10\n(anti-inflammatory)", fillcolor="#88dd88"];
    IL12   [label="IL-12\n(Th1 polarization)", fillcolor="#55bb55"];
    IL17   [label="IL-17A\n(neutrophil mobil.)", fillcolor="#66cc66"];
    IL18   [label="IL-18\n(IFN-γ inducer)", fillcolor="#44aa44"];
    IL22   [label="IL-22\n(epithelial repair)", fillcolor="#77dd77"];
    IFNg   [label="IFN-γ\n(M1 activation)", fillcolor="#33aa33"];
    TGFb1  [label="TGF-β1\n(master pro-fibrotic)", fillcolor="#228822", fontcolor=white, shape=diamond];
    VEGF   [label="VEGF\n(angiogenesis)", fillcolor="#66cc66"];
    CXCL10 [label="CXCL10 / IP-10\n(T-cell chemoattr.)", fillcolor="#55bb55"];
    MCP1   [label="MCP-1 / CCL2\n(monocyte chemo.)", fillcolor="#44aa44"];
    RANTES [label="RANTES / CCL5\n(T/NK chemoattr.)", fillcolor="#55aa55"];
    HGF    [label="HGF\n(tubular repair)", fillcolor="#88ee88"];
  }

  // ============================================================
  // CLUSTER 5 — Adaptive Immunity
  // ============================================================
  subgraph cluster_adaptive {
    label="⑤ Adaptive Immune Response\n(획득 면역)";
    style=filled; color="#663399"; fillcolor="#f8f0ff"; fontsize=11; fontcolor="#552288";

    DCs      [label="Dendritic Cells\n(antigen present.)", fillcolor="#cc99ff", shape=ellipse];
    MHC2     [label="MHC Class II\npresentation", fillcolor="#ddaaff"];
    Th1      [label="CD4+ Th1 Cells\n(cellular)", fillcolor="#bb88ff", shape=ellipse];
    Th17     [label="CD4+ Th17 Cells\n(IL-17 secret.)", fillcolor="#aa77ff", shape=ellipse];
    Treg     [label="CD4+ Tregs\n(suppression)", fillcolor="#dd99ff", shape=ellipse];
    CTL      [label="CD8+ CTL\n(cytotoxic kill)", fillcolor="#9966ff", shape=ellipse];
    Bcells   [label="B Lymphocytes\n(Ab production)", fillcolor="#cc88ee", shape=ellipse];
    Plasma   [label="Plasma Cells\n(Ig secretion)", fillcolor="#bb77ee", shape=ellipse];
    IgG_Ab   [label="IgG Antibodies\n(opsonization)", fillcolor="#ddaaff"];
    sIgA     [label="Secretory IgA\n(mucosal defense)", fillcolor="#eeccff"];
    MemT     [label="Memory T Cells\n(long-term)", fillcolor="#ccaaff", shape=ellipse];
    MemB     [label="Memory B Cells\n(long-term)", fillcolor="#ddbbff", shape=ellipse];
    AIRE     [label="Thymic AIRE\n(self-tolerance)", fillcolor="#eeddff"];
  }

  // ============================================================
  // CLUSTER 6 — Renal Injury & Fibrosis
  // ============================================================
  subgraph cluster_fibrosis {
    label="⑥ Renal Injury & Fibrotic Remodeling\n(신장 손상 및 섬유화)";
    style=filled; color="#880044"; fillcolor="#fff0f8"; fontsize=11; fontcolor="#660033";

    TubEpi   [label="Tubular Epithelium\n세뇨관 상피세포", fillcolor="#ff99cc"];
    EMT      [label="EMT\n(상피-간엽 전환)", fillcolor="#ff66aa", shape=diamond];
    Myofib   [label="Myofibroblast\n(αSMA+ activated)", fillcolor="#ff55aa"];
    ColI     [label="Collagen I / III\n(interstitial ECM)", fillcolor="#ff88bb"];
    ColIV    [label="Collagen IV\n(GBM component)", fillcolor="#ff99cc"];
    MMP9     [label="MMP-9 / MMP-13\n(matrix degrade)", fillcolor="#ffaabb"];
    TIMP1    [label="TIMP-1 / TIMP-2\n(MMP inhibitor)", fillcolor="#ffbbcc"];
    Fibro    [label="Fibronectin\n(ECM scaffold)", fillcolor="#ffaacc"];
    Scar     [label="Renal Scar\n신장 반흔 (DMSA↓)", fillcolor="#aa0044", fontcolor=white, shape=diamond];
    Podo     [label="Podocyte Damage\n(foot process effac.)", fillcolor="#ff77aa"];
    GBM_T    [label="GBM Thickening\n사구체 기저막 비후", fillcolor="#ff88bb"];
    InterInf [label="Interstitial\nInflammation", fillcolor="#ff99bb"];
    TubAtr   [label="Tubular Atrophy\n세뇨관 위축", fillcolor="#ff88bb"];
    RAAS_R   [label="RAAS (renal)\nAngiotensin II", fillcolor="#ffaacc"];
    OxStress [label="Oxidative Stress\n(8-OHdG, NOX)", fillcolor="#ff77bb"];
    Pyroptosis [label="Pyroptosis\n(gasdermins)", fillcolor="#ff66aa"];
  }

  // ============================================================
  // CLUSTER 7 — Renal Function & Clinical Endpoints
  // ============================================================
  subgraph cluster_renal {
    label="⑦ Renal Function & Clinical Endpoints\n(신기능 및 임상 결과)";
    style=filled; color="#224488"; fillcolor="#f0f8ff"; fontsize=11; fontcolor="#113366";

    GFR      [label="GFR\n(mL/min/1.73m²)", fillcolor="#3377cc", fontcolor=white, shape=diamond];
    Creat    [label="Serum Creatinine\n혈청 크레아티닌", fillcolor="#4488dd"];
    BUN      [label="BUN\n혈중 요소질소", fillcolor="#4488dd"];
    Proturia [label="Proteinuria\n(ACR mg/g)", fillcolor="#5599ee"];
    Hematur  [label="Hematuria\n혈뇨", fillcolor="#6699dd"];
    Pyuria   [label="Pyuria / WBC cast\n농뇨", fillcolor="#7799cc"];
    Bacteriu [label="Bacteriuria\n(CFU/mL)", fillcolor="#3366bb"];
    BP       [label="Hypertension\n(SBP > 140 mmHg)", fillcolor="#2255aa", fontcolor=white];
    CKD_S    [label="CKD Stage 1→5\n만성 신부전 단계", fillcolor="#113388", fontcolor=white, shape=diamond];
    ESKD     [label="ESKD / Dialysis\n(말기신부전)", fillcolor="#001166", fontcolor=white, shape=diamond];
    Recurr   [label="UTI Recurrence\n재발률 (n/year)", fillcolor="#4477bb"];
    DMSA     [label="DMSA Scan\n(scar score 0–3)", fillcolor="#5588cc"];
    Fever    [label="Fever / Chills\n발열 (>38°C)", fillcolor="#6699dd"];
    FlankPain [label="Flank Pain\n(NRS 0–10)", fillcolor="#7788cc"];
    Dysuria  [label="LUTS / Dysuria\n(IPSS 배뇨증상)", fillcolor="#8899dd"];
    WBC_CRP  [label="WBC / CRP / PCT\n(Inflammatory mark.)", fillcolor="#5577cc"];
    Anemia   [label="Renal Anemia\n(EPO deficiency)", fillcolor="#4466bb"];
  }

  // ============================================================
  // CLUSTER 8 — Antibiotic PK
  // ============================================================
  subgraph cluster_pk {
    label="⑧ Antibiotic Pharmacokinetics\n(항생제 약동학)";
    style=filled; color="#886600"; fillcolor="#fffcf0"; fontsize=11; fontcolor="#664400";

    Cipro    [label="Ciprofloxacin\n500 mg PO BID\n(fluoroquinolone)", fillcolor="#ffdd00", shape=hexagon];
    CiproC   [label="Cipro: Central (C1)\n(μg/mL)", fillcolor="#ffee44"];
    CiproP   [label="Cipro: Peripheral (C2)\n(μg/mL)", fillcolor="#fff077"];
    CiproR   [label="Cipro: Renal Conc.\n(free, μg/mL)", fillcolor="#ffdd33"];
    TMPSMX   [label="TMP-SMX\n160/800 mg PO BID\n(antifolate)", fillcolor="#ffcc00", shape=hexagon];
    TMP_C    [label="TMP: Central\n(μg/mL)", fillcolor="#ffee55"];
    SMX_C    [label="SMX: Central\n(μg/mL)", fillcolor="#ffee66"];
    Nit      [label="Nitrofurantoin\n100 mg PO QD\n(prophylaxis)", fillcolor="#ffbb00", shape=hexagon];
    NitU     [label="Nitrofurantoin\nUrinary Conc. (μg/mL)", fillcolor="#ffdd44"];
    Fosfo    [label="Fosfomycin\n3 g PO × 1\n(cell wall syn.)", fillcolor="#ff9900", shape=hexagon];
    FosU     [label="Fosfomycin\nUrinary Conc. (μg/mL)", fillcolor="#ffbb33"];
    Pivm     [label="Pivmecillinam\n400 mg PO TID\n(Gram-neg.)", fillcolor="#ffaa00", shape=hexagon];
    PivC     [label="Pivmecillinam\nCentral (μg/mL)", fillcolor="#ffcc44"];
    Genta    [label="Gentamicin\n5 mg/kg IV QD\n(aminoglycosidee)", fillcolor="#ee8800", shape=hexagon];
    GentC    [label="Gentamicin\nCentral (μg/mL)", fillcolor="#ffaa22"];
  }

  // ============================================================
  // CLUSTER 9 — PD / Bactericidal Mechanisms
  // ============================================================
  subgraph cluster_pd {
    label="⑨ Pharmacodynamics (PD)\n(약력학 / 살균 효과)";
    style=filled; color="#005500"; fillcolor="#f0fff4"; fontsize=11; fontcolor="#003300";

    fAUC_MIC  [label="fAUC/MIC\n(FQ index)", fillcolor="#66cc44", shape=diamond];
    Cmax_MIC  [label="Cmax/MIC\n(conc.-depend.)", fillcolor="#77dd55"];
    T_MIC     [label="T > MIC\n(time-depend.)", fillcolor="#88ee66"];
    MIC_cipro [label="MIC Cipro\n(μg/mL isolate)", fillcolor="#99bb44"];
    MIC_tmp   [label="MIC TMP-SMX\n(mg/L isolate)", fillcolor="#99bb44"];
    Kill_Rate [label="Bacterial Kill\nRate (log₁₀ CFU/h)", fillcolor="#33aa00", fontcolor=white, shape=diamond];
    FQ_gyrase [label="FQ → DNA Gyrase\n(GyrA/ParC inhib.)", fillcolor="#55cc22"];
    TMP_DHFR  [label="TMP → DHFR\n(folate synth. inhib.)", fillcolor="#44bb11"];
    Nit_mech  [label="Nitrofurantoin →\nDNA/protein damage", fillcolor="#66cc33"];
    PAE       [label="Post-Antibiotic\nEffect (PAE)", fillcolor="#88dd55"];
    MPC       [label="Mutant Prevention\nConc. (MPC)", fillcolor="#77cc44"];
    AdaptR    [label="Adaptive Resistance\n(biofilm)", fillcolor="#aa7700"];
    SelectR   [label="Selective Pressure →\nResistance Selection", fillcolor="#cc8800"];
  }

  // ============================================================
  // CLUSTER 10 — Systemic Effects & Comorbidities
  // ============================================================
  subgraph cluster_systemic {
    label="⑩ Systemic Effects & Comorbidities\n(전신 효과 및 동반질환)";
    style=filled; color="#440066"; fillcolor="#f8f0ff"; fontsize=11; fontcolor="#330055";

    Urosepsis [label="Urosepsis\n요로패혈증", fillcolor="#9944cc"];
    SysInflam [label="Systemic SIRS\n전신 염증 반응", fillcolor="#8833bb"];
    PCT       [label="Procalcitonin\n(PCT, sepsis mark.)", fillcolor="#aa66dd"];
    AKI       [label="AKI\n(급성 신손상)", fillcolor="#7733aa"];
    DM        [label="Diabetes Mellitus\n(UTI risk ↑↑)", fillcolor="#bb88ee"];
    Immunosupp [label="Immunosuppression\n(transplant/chemo)", fillcolor="#cc99ff"];
    Pregnancy [label="Pregnancy\n(risk ↑ 3–4×)", fillcolor="#ddaaff"];
    RenalHTN  [label="Renovascular HTN\n(scar RAAS)", fillcolor="#aa77cc"];
    Hyperkal  [label="Hyperkalemia\n(CKD complication)", fillcolor="#9966bb"];
    AcidBase  [label="Metabolic Acidosis\n(CKD complication)", fillcolor="#8855aa"];
    Microbiome [label="Urinary Microbiome\n(dysbiosis → risk)", fillcolor="#bb99dd"];
    Genetic   [label="Host Genetics\n(CLDN16, FUT2)", fillcolor="#ccaaee"];
  }

  // ============================================================
  // EDGES — Bacterial pathogenesis
  // ============================================================
  Ecoli -> TypeI_Fim;
  Ecoli -> P_Fim;
  Ecoli -> HlyA;
  Ecoli -> Aerobactin;
  Ecoli -> CNF1;
  Ecoli -> LPS;
  Ecoli -> Flagellin;
  Ecoli -> Biofilm;
  Ecoli -> QS;
  Klebsiella -> LPS;
  Klebsiella -> Biofilm;
  Proteus -> HlyA;
  Proteus -> LPS;
  Pseudomonas -> Biofilm;
  Enterococcus -> LPS;
  QS -> Biofilm [label="density-depend."];
  Biofilm -> BacterialLoad [label="sessile persist."];
  Biofilm -> ESBL [label="gene transfer"];
  ESBL -> gyrA [style=dashed, label="co-resistance"];
  TypeI_Fim -> BacterialLoad [label="bladder attach."];
  P_Fim -> BacterialLoad [label="renal ascent"];
  HlyA -> BacterialLoad [label="tissue invasion"];

  // VUR pathway
  Bladder -> UVJ;
  UVJ -> VUR_Grade;
  VUR_Grade -> IntraRR;
  VUR_Grade -> BacterialLoad [label="retrograde urine"];
  IntraRR -> CompPap;
  CompPap -> RenalPelvis;
  RenalPelvis -> Kidney;
  Kidney -> BacterialLoad;
  Obstruction -> BacterialLoad [label="urinary stasis"];
  UrineFlow -> BacterialLoad [label="flush ↓", style=dashed, color=blue];
  NeuroBladder -> Obstruction;
  UrinaryCal -> Obstruction;
  Ureter -> RenalPelvis;

  // TLR signaling
  LPS -> TLR4 [label="binds MD2"];
  Flagellin -> TLR5;
  Flagellin -> TLR11;
  TypeI_Fim -> TLR4 [label="FimH"];
  P_Fim -> TLR4 [label="CXCR1"];
  TLR2 -> MyD88;
  TLR4 -> MyD88;
  TLR5 -> MyD88;
  TLR11 -> MyD88;
  MyD88 -> IRAK4;
  IRAK4 -> TRAF6;
  TRAF6 -> IKK;
  IKK -> NFkB [label="IκB phospho."];
  IKK -> AP1;
  TLR4 -> IRF3 [label="TRIF pathway"];
  HlyA -> NLRP3 [label="K+ efflux"];
  NLRP3 -> Casp1;
  Casp1 -> ProIL1 [label="cleaves"];
  ProIL1 -> IL1b;
  Casp1 -> Pyroptosis [label="gasdermin-D"];
  Pyroptosis -> TubEpi [label="lytic death"];
  LPS -> Complt [label="alt. pathway"];
  Complt -> C3b;
  Complt -> C5a;
  Complt -> MAC;
  MAC -> TubEpi [label="lysis"];

  // NFkB → cytokines
  NFkB -> IL1b;
  NFkB -> IL6;
  NFkB -> IL8;
  NFkB -> TNFa;
  NFkB -> IL12;
  NFkB -> MCP1;
  NFkB -> VEGF;
  AP1 -> IL8;
  IRF3 -> CXCL10;

  // Cytokine network
  IL1b -> IL6;
  IL1b -> Fever;
  IL1b -> IL18;
  IL18 -> IFNg;
  IL6 -> WBC_CRP;
  IL6 -> Fever;
  IL8 -> Neutro [label="recruit"];
  C5a -> Neutro [label="chemotaxis"];
  MCP1 -> Macro [label="recruit"];
  CXCL10 -> Th1 [label="recruit"];
  RANTES -> Treg;
  TNFa -> ROS;
  TNFa -> NFkB [label="loop", constraint=false];
  IL12 -> IFNg;
  IL12 -> Th1;
  IL17 -> Neutro [label="mobilize"];
  IFNg -> Macro [label="M1 activ."];
  IL10 -> NFkB [style=dashed, label="inhibit", color=red];
  IL10 -> TGFb1 [label="Treg context"];
  TGFb1 -> EMT [label="key driver"];
  TGFb1 -> Myofib;
  TGFb1 -> TIMP1;
  HGF -> TubEpi [label="repair signal"];

  // Immune effectors
  Neutro -> ROS;
  Neutro -> MPO;
  Neutro -> NETs;
  Neutro -> BacterialLoad [label="kill ↓", color=blue, style=bold];
  Macro -> BacterialLoad [label="phagocyte", color=blue];
  Macro -> IL12;
  Macro -> TNFa;
  Macro -> TGFb1 [label="M2→fibrosis"];
  NK -> IFNg;
  NK -> IL12;
  Mast -> IL8;
  Mast -> TNFa;
  ROS -> TubEpi [label="oxidative dmg"];
  ROS -> OxStress;
  NETs -> TubEpi [label="tissue dmg"];
  MPO -> OxStress;

  // Adaptive immunity
  DCs -> MHC2;
  MHC2 -> Th1;
  MHC2 -> Th17;
  Th1 -> CTL;
  Th1 -> IFNg;
  Th17 -> IL17;
  Treg -> IL10;
  IL12 -> Th17;
  Bcells -> Plasma;
  Plasma -> IgG_Ab;
  Plasma -> sIgA;
  IgG_Ab -> BacterialLoad [label="opsonize", color=blue];
  sIgA -> BacterialLoad [label="anti-adhesion", color=blue];
  Th1 -> MemT;
  Bcells -> MemB;
  MemT -> Th1 [label="reactivation", constraint=false];
  MemB -> Bcells [constraint=false];
  AIRE -> Treg;
  Genetic -> VUR_Grade;
  Genetic -> sIgA;

  // Renal fibrosis
  BacterialLoad -> TubEpi [label="direct attack"];
  InterInf -> TubEpi;
  TubEpi -> EMT [label="stress"];
  EMT -> Myofib;
  RAAS_R -> TGFb1 [label="Ang II"];
  OxStress -> Podo;
  Myofib -> ColI;
  Myofib -> ColIV;
  Myofib -> Fibro;
  ColI -> Scar;
  Fibro -> Scar;
  MMP9 -> ColI [label="degrade", style=dashed];
  TIMP1 -> MMP9 [label="inhibit", style=dashed, color=red];
  Podo -> GBM_T;
  GBM_T -> Proturia;
  TubAtr -> Scar;
