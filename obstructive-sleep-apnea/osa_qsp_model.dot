digraph OSA_QSP_Model {

  graph [
    label = "Obstructive Sleep Apnea (OSA)\nQuantitative Systems Pharmacology Model\n폐쇄성 수면 무호흡증 QSP 모델",
    labelloc = "t",
    fontname = "Helvetica",
    fontsize = 20,
    rankdir = TB,
    compound = true,
    splines = curved,
    overlap = false,
    nodesep = 0.35,
    ranksep = 0.55,
    bgcolor = "#FAFAFA",
    pad = "0.8"
  ]
  node [fontname = "Helvetica", fontsize = 9, style = "filled,rounded", shape = box, margin = "0.12,0.06"]
  edge [fontname = "Helvetica", fontsize = 8, arrowsize = 0.7]

  /* ══════════════════════════════════════════
     CLUSTER 1: Risk Factors & Epidemiology
  ══════════════════════════════════════════ */
  subgraph cluster_risk_factors {
    label = "Risk Factors & Epidemiology\n위험 인자 및 역학"
    style = filled
    color = "#999999"
    fillcolor = "#F2F2F2"
    fontsize = 13; fontname = "Helvetica-Bold"
    node [fillcolor = "#DCDCDC"]

    RF_obesity    [label = "Obesity\n비만 (BMI ≥30)", shape = ellipse]
    RF_male       [label = "Male Sex\n남성", shape = ellipse]
    RF_age        [label = "Age ≥40\n고령", shape = ellipse]
    RF_craniofacial [label = "Craniofacial\nAnatomy\n두개안면 구조", shape = ellipse]
    RF_menopause  [label = "Menopause\n폐경", shape = ellipse]
    RF_alcohol    [label = "Alcohol Use\n음주", shape = ellipse]
    RF_sedatives  [label = "Sedative Use\n진정제 사용", shape = ellipse]
    RF_smoking    [label = "Smoking\n흡연", shape = ellipse]
    RF_genetics   [label = "Genetic Factors\n유전적 요인", shape = ellipse]
    RF_tonsillar  [label = "Tonsillar\nHypertrophy\n편도 비대", shape = ellipse]
    RF_nasal_congestion [label = "Nasal\nCongestion\n비강 폐색", shape = ellipse]
    RF_hypothyroid [label = "Hypothyroidism\n갑상선기능저하증", shape = ellipse]
  }

  /* ══════════════════════════════════════════
     CLUSTER 2: Upper Airway Anatomy & Mechanics
  ══════════════════════════════════════════ */
  subgraph cluster_upper_airway {
    label = "Upper Airway Anatomy & Mechanics\n상기도 해부학 및 역학"
    style = filled
    color = "#3A85C9"
    fillcolor = "#DCF0FA"
    fontsize = 13; fontname = "Helvetica-Bold"
    node [fillcolor = "#B8DFF4"]

    UA_pcrit        [label = "Critical Closing\nPressure (Pcrit)\n폐쇄 임계압", shape = box, fillcolor = "#FF9966"]
    UA_retropalatal [label = "Retropalatal\nAirway\n구개후 기도"]
    UA_retroglossal [label = "Retroglossal\nAirway\n설후 기도"]
    UA_pharynx      [label = "Pharyngeal\nCompliance\n인두 순응도"]
    UA_tongue       [label = "Tongue Base\nSize/Position\n혀 기저부"]
    UA_soft_palate  [label = "Soft Palate\nLength\n연구개 길이"]
    UA_parapharyngeal [label = "Parapharyngeal\nFat Pad\n인두주위 지방"]
    UA_luminal_area [label = "Pharyngeal\nLuminal Area\n인두 단면적"]
    UA_flow         [label = "Airflow\n(L/min)"]
    UA_insp_pressure [label = "Inspiratory\nDriving Pressure\n흡기 구동압"]
    UA_critical_flow [label = "Critical Flow\nLimitation\n유량 제한", shape = diamond, fillcolor = "#FF6633"]
    UA_apnea_event  [label = "Apnea/Hypopnea\nEvent\n무호흡/저호흡", shape = diamond, fillcolor = "#FF3333"]
    UA_genioglossus [label = "Genioglossus\nMuscle Activity\n이설근 활성도"]
    UA_dilator_muscles [label = "Pharyngeal\nDilator Muscles\n인두 개대근"]
    UA_nasal_resistance [label = "Nasal\nResistance\n비강 저항"]
    UA_uvula        [label = "Uvula\nLength/Size\n목젖 크기"]
  }

  /* ══════════════════════════════════════════
     CLUSTER 3: Respiratory Control System
  ══════════════════════════════════════════ */
  subgraph cluster_respiratory_control {
    label = "Respiratory Control System\n호흡 조절 시스템"
    style = filled
    color = "#3A9E3A"
    fillcolor = "#E0F5E0"
    fontsize = 13; fontname = "Helvetica-Bold"
    node [fillcolor = "#C0E8C0"]

    RC_loop_gain    [label = "Loop Gain (LG)\n루프 이득 (>1=불안정)", fillcolor = "#FFCC66"]
    RC_plant_gain   [label = "Plant Gain\nPaCO2/VE"]
    RC_controller_gain [label = "Controller Gain\nVE/PaCO2"]
    RC_mixing_gain  [label = "Circulation/\nMixing Delay\n혼합 지연"]
    RC_central_chemo [label = "Central\nChemoreceptors\n중추 화학수용체\n(Medulla oblongata)"]
    RC_peripheral_chemo [label = "Peripheral\nChemoreceptors\n말초 화학수용체\n(Carotid Body)"]
    RC_paCO2        [label = "PaCO2 (mmHg)\n동맥 이산화탄소"]
    RC_paO2         [label = "PaO2 (mmHg)\n동맥 산소분압"]
    RC_apneic_thresh [label = "Apneic CO2\nThreshold\n무호흡 CO2 역치"]
    RC_arousal_threshold [label = "Arousal\nThreshold\n각성 역치"]
    RC_respiratory_drive [label = "Respiratory\nDrive\n호흡 구동력"]
    RC_ventilation  [label = "Minute\nVentilation VE\n분당 환기량"]
    RC_VCO2         [label = "CO2 Production\nVCO2"]
    RC_tidal_vol    [label = "Tidal Volume\nVT (mL)"]
    RC_resp_rate    [label = "Respiratory\nRate RR (/min)"]
  }

  /* ══════════════════════════════════════════
     CLUSTER 4: Sleep Architecture
  ══════════════════════════════════════════ */
  subgraph cluster_sleep_architecture {
    label = "Sleep Architecture\n수면 구조"
    style = filled
    color = "#8855BB"
    fillcolor = "#EEE5F8"
    fontsize = 13; fontname = "Helvetica-Bold"
    node [fillcolor = "#D8C8F0"]

    SA_wake         [label = "Wakefulness\n각성"]
    SA_N1           [label = "NREM N1\n(Light Sleep)\n얕은 수면"]
    SA_N2           [label = "NREM N2\n(Baseline)\n기본 수면"]
    SA_N3           [label = "NREM N3\n(SWS/Deep)\n깊은 수면"]
    SA_rem          [label = "REM Sleep\nREM 수면"]
    SA_arousal      [label = "Arousal\nEvent\n수면 각성", shape = diamond, fillcolor = "#FFDD55"]
    SA_sleep_onset  [label = "Sleep Onset\nLatency (min)\n수면 잠복기"]
    SA_sleep_effic  [label = "Sleep Efficiency\n수면 효율 (%)"]
    SA_TST          [label = "Total Sleep Time\n총 수면 시간 (h)"]
    SA_fragmentation [label = "Sleep\nFragmentation\n수면 분절"]
    SA_circadian    [label = "Circadian\nRhythm\n생체리듬"]
    SA_adenosine    [label = "Adenosine\nSleep Pressure\n아데노신 축적"]
    SA_NREM_REM_cycle [label = "NREM-REM Cycle\n~90 min"]
  }

  /* ══════════════════════════════════════════
     CLUSTER 5: Intermittent Hypoxia & Oxidative Stress
  ══════════════════════════════════════════ */
  subgraph cluster_hypoxia {
    label = "Intermittent Hypoxia & Oxidative Stress\n간헐적 저산소증 및 산화 스트레스"
    style = filled
    color = "#E87820"
    fillcolor = "#FEF3E6"
    fontsize = 13; fontname = "Helvetica-Bold"
    node [fillcolor = "#FDDBB0"]

    IH_SpO2         [label = "SpO2\n산소포화도 (%)", fillcolor = "#FF9944"]
    IH_ODI          [label = "Oxygen Desaturation\nIndex (ODI)\n산소탈포화 지수"]
    IH_HIF1a        [label = "HIF-1α\nHypoxia-Inducible\nFactor-1α"]
    IH_ROS          [label = "Reactive Oxygen\nSpecies (ROS)\n활성산소"]
    IH_NOX2         [label = "NADPH Oxidase\n(NOX2)"]
    IH_XO           [label = "Xanthine\nOxidase"]
    IH_NF_kB        [label = "NF-κB\nActivation\nNF-κB 활성화"]
    IH_antioxidant  [label = "Antioxidant Defense\nSOD / GPx / Catalase\n항산화 방어계"]
    IH_reoxygenation [label = "Reoxygenation\nInjury\n재산소화 손상"]
    IH_EPO          [label = "Erythropoietin\n(EPO)↑\n적혈구생성인자"]
    IH_VEGF         [label = "VEGF\n혈관내피성장인자"]
    IH_ET1          [label = "Endothelin-1\n(ET-1)↑\n내피소"]
    IH_iNOS         [label = "iNOS\nActivation"]
    IH_peroxynitrite [label = "Peroxynitrite\n퍼옥시니트라이트"]
  }

  /* ══════════════════════════════════════════
     CLUSTER 6: Cardiovascular Effects
  ══════════════════════════════════════════ */
  subgraph cluster_cardiovascular {
    label = "Cardiovascular & Autonomic Effects\n심혈관 및 자율신경계 효과"
    style = filled
    color = "#CC2222"
    fillcolor = "#FEE8E8"
    fontsize = 13; fontname = "Helvetica-Bold"
    node [fillcolor = "#FFCCCC"]

    CV_SNS          [label = "Sympathetic\nNervous System↑\n교감신경 항진"]
    CV_NE           [label = "Plasma\nNorepinephrine↑\n노르에피네프린"]
    CV_SBP          [label = "Systolic BP↑\n수축기 혈압\n(mmHg)"]
    CV_DBP          [label = "Diastolic BP↑\n이완기 혈압\n(mmHg)"]
    CV_nondipping   [label = "Non-dipping\nBP Pattern\n야간 혈압 비강하"]
    CV_HR           [label = "Heart Rate↑\n심박수 (bpm)"]
    CV_HRV          [label = "Heart Rate\nVariability↓\n심박변이도"]
    CV_RAAS         [label = "RAAS\nActivation\nRAAS 활성화"]
    CV_AngII        [label = "Angiotensin II↑\n안지오텐신 II"]
    CV_aldosterone  [label = "Aldosterone↑\n알도스테론"]
    CV_NO           [label = "Nitric Oxide↓\n산화질소 감소"]
    CV_endothelial  [label = "Endothelial\nDysfunction\n내피세포 기능장애"]
    CV_atherosclerosis [label = "Atherosclerosis\nProgression\n죽상동맥경화"]
    CV_IMT          [label = "Carotid IMT↑\n경동맥 내중막 두께"]
    CV_AF_risk      [label = "Atrial\nFibrillation Risk↑\n심방세동 위험", shape = diamond]
    CV_LVH          [label = "Left Ventricular\nHypertrophy\n좌심실 비대"]
    CV_pulm_HTN     [label = "Pulmonary\nHypertension\n폐동맥 고혈압"]
    CV_MACE         [label = "MACE Risk↑\n(MI, Stroke)\n주요 심뇌혈관 사건", shape = diamond, fillcolor = "#FF4444"]
    CV_arrhythmia   [label = "Ventricular\nArrhythmia Risk\n심실 부정맥"]
    CV_cor_pulmonale [label = "Cor Pulmonale\n폐성심"]
  }

  /* ══════════════════════════════════════════
     CLUSTER 7: Metabolic & Endocrine Effects
  ══════════════════════════════════════════ */
  subgraph cluster_metabolic {
    label = "Metabolic & Endocrine Effects\n대사 및 내분비 효과"
    style = filled
    color = "#228833"
    fillcolor = "#E4F4E4"
    fontsize = 13; fontname = "Helvetica-Bold"
    node [fillcolor = "#BCDDB0"]

    ME_IR           [label = "Insulin\nResistance↑\n인슐린 저항성\n(HOMA-IR)", fillcolor = "#FFAA55"]
    ME_glucose      [label = "Fasting Glucose↑\n공복 혈당 (mg/dL)"]
    ME_insulin_sec  [label = "β-cell\nInsulin Secretion\n인슐린 분비"]
    ME_leptin       [label = "Leptin↑\n렙틴 과다\n(내성 동반)"]
    ME_adiponectin  [label = "Adiponectin↓\n아디포넥틴 감소"]
    ME_ghrelin      [label = "Ghrelin↑\n그렐린 증가"]
    ME_cortisol     [label = "Cortisol↑\nHPA Axis\n코르티솔/HPA"]
    ME_LDL          [label = "LDL\nCholesterol↑\nLDL 콜레스테롤"]
    ME_TG           [label = "Triglycerides↑\n중성지방"]
    ME_HDL          [label = "HDL\nCholesterol↓\nHDL 콜레스테롤"]
    ME_FFA          [label = "Free Fatty\nAcids↑\n유리 지방산"]
    ME_adipose_inflam [label = "Adipose Tissue\nInflammation\n지방조직 염증"]
    ME_IL6          [label = "IL-6↑\n(pg/mL)"]
    ME_TNFa         [label = "TNF-α↑\n(pg/mL)"]
    ME_CRP          [label = "hsCRP↑\n(mg/L)"]
    ME_GH           [label = "GH Pulse\nSuppression\n성장호르몬 억제"]
    ME_T2DM_risk    [label = "T2DM Risk↑\n제2형 당뇨 위험", shape = diamond]
    ME_MetSyn       [label = "Metabolic\nSyndrome\n대사증후군"]
  }

  /* ══════════════════════════════════════════
     CLUSTER 8: Neurological & Cognitive Effects
  ══════════════════════════════════════════ */
  subgraph cluster_neurological {
    label = "Neurological, Cognitive & Psychiatric Effects\n신경·인지·정신과적 효과"
    style = filled
    color = "#2244AA"
    fillcolor = "#E8ECFF"
    fontsize = 13; fontname = "Helvetica-Bold"
    node [fillcolor = "#C8D4FF"]

    NE_EDS          [label = "Excessive Daytime\nSleepiness (EDS)\n과도한 주간 졸음", fillcolor = "#FFDD88"]
    NE_ESS          [label = "Epworth\nSleepiness Scale\n엡워스 졸음척도 (ESS)"]
    NE_cognitive    [label = "Cognitive\nImpairment\n인지 기능 저하"]
    NE_attention    [label = "Attention/\nConcentration↓\n주의력 저하"]
    NE_memory       [label = "Memory\nImpairment↓\n기억력 저하"]
    NE_hippocampus  [label = "Hippocampal\nVolume↓\n해마 위축"]
    NE_BDNF         [label = "BDNF↓\n뇌유래신경성장인자"]
    NE_depression   [label = "Depression/\nAnxiety↑\n우울/불안"]
    NE_quality_life [label = "QoL↓\n(FOSQ Score)\n수면 관련 삶의 질"]
    NE_histamine    [label = "Histaminergic\nWakefulness\nH1 수용체"]
    NE_orexin       [label = "Orexin/Hypocretin\n오렉신 각성계"]
    NE_dopamine     [label = "Dopaminergic\nReward/Arousal\n도파민 각성"]
    NE_executive    [label = "Executive\nFunction↓\n집행기능 저하"]
    NE_accident     [label = "Traffic/Work\nAccident Risk↑\n사고 위험", shape = diamond, fillcolor = "#FF8866"]
    NE_ADHD_like    [label = "ADHD-like\nSymptoms\n주의력결핍 증상"]
  }

  /* ══════════════════════════════════════════
     CLUSTER 9: Drug PK/PD
  ══════════════════════════════════════════ */
  subgraph cluster_pharmacology {
    label = "Drug PK/PD & Therapeutic Interventions\n약물 PK/PD 및 치료 중재"
    style = filled
    color = "#CC9900"
    fillcolor = "#FFFBE6"
    fontsize = 13; fontname = "Helvetica-Bold"
    node [fillcolor = "#F8EDAA"]

    /* CPAP */
    CPAP_dose       [label = "CPAP\n(Pressure cmH2O)\n지속기도양압", shape = parallelogram, fillcolor = "#AAFFAA"]
    CPAP_effect     [label = "CPAP Pneumatic\nSplinting\n기도 부목 효과", shape = box]

    /* MAD */
    MAD_device      [label = "Mandibular\nAdvancement\nDevice (MAD)\n하악 전진 장치", shape = parallelogram, fillcolor = "#AAFFAA"]
    MAD_effect      [label = "MAD Pcrit\nReduction\n인두 개통 효과"]

    /* Modafinil */
    MODA_dose       [label = "Modafinil\n200mg QD\nF=40%, t½=15h", shape = parallelogram]
    MODA_Cp         [label = "Modafinil\nPlasma Conc\n(μg/mL)"]
    MODA_PD         [label = "Modafinil PD\nOrexin / Hist\n각성 촉진"]

    /* Solriamfetol */
    SOLRI_dose      [label = "Solriamfetol\n75-150mg QD\nF=95%, t½=7.1h", shape = parallelogram]
    SOLRI_Cp        [label = "Solriamfetol\nPlasma Conc\n(μg/mL)"]
    SOLRI_PD        [label = "Solriamfetol PD\nDAT/NET Inhibition\n도파민/노르에피 재흡수 억제"]

    /* Pitolisant */
    PITO_dose       [label = "Pitolisant\n17.8-35.6mg QD\nF≥90%, t½=20h", shape = parallelogram]
    PITO_Cp         [label = "Pitolisant\nPlasma Conc\n(ng/mL)"]
    PITO_PD         [label = "Pitolisant PD\nH3 Receptor\nAntagonism\nHA 방출 촉진"]

    /* Tirzepatide (SURMOUNT-OSA) */
    TIRZ_dose       [label = "Tirzepatide\n10-15mg QW sc\nGLP-1/GIP RA\nt½=5d", shape = parallelogram]
    TIRZ_Cp         [label = "Tirzepatide\nPlasma Conc\n(ng/mL)"]
    TIRZ_PD_weight  [label = "Tirzepatide PD\nWeight Loss\n-15 to -20%\nBMI 감소"]
    TIRZ_PD_OSA     [label = "SURMOUNT-OSA\nAHI Reduction\n-55% events/hr"]

    /* Eszopiclone (arousal threshold) */
    ESZOP_dose      [label = "Eszopiclone\n3mg QHS\nF=80%, t½=6h", shape = parallelogram]
    ESZOP_Cp        [label = "Eszopiclone\nPlasma Conc\n(ng/mL)"]
    ESZOP_PD        [label = "Eszopiclone PD\nGABA-A↑\nArousal Threshold↑"]

    /* Acetazolamide */
    ACETZ_dose      [label = "Acetazolamide\n250mg BID\nF=90%, t½=10h", shape = parallelogram]
    ACETZ_Cp        [label = "Acetazolamide\nPlasma Conc\n(μg/mL)"]
    ACETZ_PD        [label = "Acetazolamide PD\nCarbonic Anhydrase\nInhibition\nLoop Gain↓"]

    /* Supplemental Oxygen */
    O2_therapy      [label = "Supplemental\nOxygen\n2-3 L/min\n산소 요법", shape = parallelogram, fillcolor = "#AADDFF"]
    O2_PD           [label = "O2 PD\nSpO2↑\nLoop Gain↓"]

    /* AD109 */
    AD109_dose      [label = "AD109\n(Atomoxetine +\nOxybutynin)\n배합 요법", shape = parallelogram]
    AD109_PD        [label = "AD109 PD\nAT↑ + LG↓\n이중 기전"]
  }

  /* ══════════════════════════════════════════
     CLUSTER 10: Clinical Endpoints & Biomarkers
  ══════════════════════════════════════════ */
  subgraph cluster_clinical {
    label = "Clinical Endpoints & Diagnostic Biomarkers\n임상 종말점 및 진단 바이오마커"
    style = filled
    color = "#555555"
    fillcolor = "#F0F0F0"
    fontsize = 13; fontname = "Helvetica-Bold"
    node [fillcolor = "#E0E0E0"]

    CE_AHI          [label = "AHI\n(events/hr)\n무호흡-저호흡 지수", fillcolor = "#FF9999"]
    CE_ODI          [label = "ODI ≥4%\n(events/hr)\n산소탈포화 지수"]
    CE_T90          [label = "T90\n(% time SpO2<90%)\nSpO2<90% 시간"]
    CE_nadir_SpO2   [label = "Nadir SpO2\n최저 산소포화도 (%)"]
    CE_arousal_idx  [label = "Arousal Index\n(events/hr)\n각성 지수"]
    CE_AHI_REM      [label = "REM-AHI\nREM 관련 AHI"]
    CE_AHI_supine   [label = "Supine AHI\n앙와위 AHI"]
    CE_FOSQ10       [label = "FOSQ-10\nFunctional Outcomes\nof Sleep QSP"]
    CE_snoring_dB   [label = "Snoring\nIntensity (dB)\n코골이 강도"]
    CE_BP_24h       [label = "24h Ambulatory\nBP Reduction\n24시간 혈압 감소"]
    CE_MetRisk      [label = "Metabolic\nRisk Score\n대사 위험 점수"]
    CE_PSG          [label = "Polysomnography\nPSG 수면다원검사"]
    CE_HSAT         [label = "Home Sleep\nApnea Test\n가정용 수면 검사"]
    CE_WatchPAT     [label = "WatchPAT\nPAT 기반 수면 검사"]
    CE_biomarker_panel [label = "Biomarker Panel\n(HIF, CRP, IL-6,\nNE, Adiponectin)\n바이오마커 패널"]
  }

  /* ════════════════════════════════════════════════
     INTER-CLUSTER EDGES
  ════════════════════════════════════════════════ */

  /* Risk Factors → Upper Airway */
  RF_obesity -> UA_parapharyngeal [label = "↑ fat deposition"]
  RF_obesity -> UA_tongue        [label = "↑ tongue base fat"]
  RF_craniofacial -> UA_retropalatal [label = "retrognathia"]
  RF_craniofacial -> UA_retroglossal [label = "small mandible"]
  RF_tonsillar -> UA_retropalatal   [label = "↑ tissue bulk"]
