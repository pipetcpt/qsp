digraph LAM_QSP {
  // ============================================================
  // Lymphangioleiomyomatosis (LAM) — Comprehensive QSP Map
  // mTOR/TSC pathway · LAM cell biology · Lung pathology
  // Hormonal regulation · Drug PK/PD · Clinical endpoints
  // ============================================================
  graph [
    label="Lymphangioleiomyomatosis (LAM)\nQuantitative Systems Pharmacology Model"
    labelloc=t fontsize=22 fontname="Helvetica-Bold"
    bgcolor="#F8F8FF" splines=ortho nodesep=0.4 ranksep=0.8
    compound=true
  ]
  node [fontname="Helvetica" fontsize=10 shape=box style="filled,rounded" margin="0.1,0.05"]
  edge [fontname="Helvetica" fontsize=8]

  // ============================================================
  // CLUSTER 1: Genetic & Molecular Basis
  // ============================================================
  subgraph cluster_01_genetics {
    label="1. Genetic Basis (TSC1/TSC2)" style=filled fillcolor="#FFE4E1" color="#CC4444" penwidth=2
    node [fillcolor="#FFB3B3"]

    TSC1_germline_mut [label="TSC1 Germline\nMutation (Chr 9q34)" shape=diamond]
    TSC2_germline_mut [label="TSC2 Germline\nMutation (Chr 16p13)" shape=diamond]
    TSC1_somatic_mut  [label="TSC1 Somatic\nMutation (Sporadic)" shape=diamond]
    TSC2_somatic_mut  [label="TSC2 Somatic\nMutation (Sporadic)" shape=diamond fillcolor="#FF8888"]
    LOH               [label="Loss of\nHeterozygosity (LOH)"]
    two_hit_model     [label="Two-Hit Model\n(Knudson Hypothesis)" shape=hexagon]
    hamartin          [label="Hamartin\n(TSC1 Protein)"]
    tuberin           [label="Tuberin\n(TSC2 Protein)"]
    TSC_complex       [label="TSC1-TSC2\nHeterodimer Complex" fillcolor="#FF6666"]
    TSC_complex_loss  [label="TSC Complex\nLoss-of-Function" shape=hexagon fillcolor="#CC0000" fontcolor=white]
    TSC_LAM           [label="TSC-LAM\n(40% of TSC pts)" shape=ellipse]
    sporadic_LAM      [label="Sporadic LAM\n(~80% of LAM pts)" shape=ellipse]
    GAP_activity      [label="GAP Activity\n(Rheb GTPase-\nActivating Protein)"]
  }

  // ============================================================
  // CLUSTER 2: LAM Cell Origin & Phenotype
  // ============================================================
  subgraph cluster_02_origin {
    label="2. LAM Cell Origin & Phenotype" style=filled fillcolor="#FFF0E0" color="#CC8800" penwidth=2
    node [fillcolor="#FFD080"]

    neural_crest_progenitor [label="Neural Crest\nProgenitor Cells" shape=ellipse]
    uterine_LAM_source      [label="Uterine/Pelvic\nLAM Cell Source" shape=ellipse]
    LAM_precursor_cell      [label="LAM Precursor\nCell (Metastatic)"]
    hematogenous_spread     [label="Hematogenous\n& Lymphatic Spread"]
    LAM_cell                [label="LAM Cell\n(Neoplastic SMC)" fillcolor="#FF9900" shape=box3d]
    HMB45_pos               [label="HMB-45+\n(Melanocytic)"]
    alpha_SMA               [label="α-Smooth Muscle\nActin (α-SMA+)"]
    desmin_pos              [label="Desmin+\n(Muscle Marker)"]
    ERalpha_expr            [label="ERα Expression\n(Estrogen Receptor)"]
    PR_expr                 [label="Progesterone\nReceptor (PR+)"]
    CD44_expr               [label="CD44+\n(Stem Cell Marker)"]
    LAM_cluster_blood       [label="LAM Cell Clusters\nin Blood/Urine"]
  }

  // ============================================================
  // CLUSTER 3: Upstream Signaling Inputs
  // ============================================================
  subgraph cluster_03_upstream {
    label="3. Upstream mTOR Signaling Inputs" style=filled fillcolor="#E8F4E8" color="#228822" penwidth=2
    node [fillcolor="#AADDAA"]

    growth_factors  [label="Growth Factors\n(IGF-1, EGF, PDGF)"]
    RTK             [label="Receptor Tyrosine\nKinase (RTK)"]
    IRS1            [label="IRS-1\n(Adaptor Protein)"]
    PI3K_class1     [label="PI3K Class I\n(p110/p85)"]
    PIP2            [label="PIP2\n(Substrate)"]
    PIP3            [label="PIP3\n(Second Messenger)" fillcolor="#77CC77"]
    PTEN            [label="PTEN\n(Lipid Phosphatase)" fillcolor="#FF9999"]
    PDK1            [label="PDK1\n(Kinase)"]
    Akt             [label="Akt/PKB\n(Ser473, Thr308)" fillcolor="#44AA44"]
    AMPK            [label="AMPK\n(Energy Sensor)" fillcolor="#88BB88"]
    LKB1_STK11      [label="LKB1/STK11\n(AMPK Kinase)"]
    AMP_ATP_ratio   [label="AMP:ATP Ratio\n(Energy Status)"]
    Hypoxia_HIF1a   [label="HIF-1α\n(Hypoxia Response)"]
    REDD1           [label="REDD1\n(Stress Response)"]
    RAS_GTP         [label="RAS-GTP\n(Mitogenic Signal)"]
    RAF_MEK_ERK     [label="RAF→MEK→ERK\n(MAPK Cascade)"]
    RSK             [label="RSK\n(p90 RSK)"]
    amino_acids     [label="Amino Acids\n(Leucine, Arg)"]
    RAG_GTPases     [label="RAG GTPases\n(A/B/C/D)"]
    Ragulator       [label="Ragulator Complex\n(Lysosomal Surface)"]
    Vps34           [label="Vps34\n(PI3K Class III)"]
    CASTOR1         [label="CASTOR1\n(Arg Sensor)"]
    SESTRIN2        [label="SESTRIN2\n(Leu Sensor)"]
  }

  // ============================================================
  // CLUSTER 4: TSC1/2 → Rheb → mTOR Core
  // ============================================================
  subgraph cluster_04_mtor_core {
    label="4. TSC/Rheb/mTOR Core Axis" style=filled fillcolor="#E0E8FF" color="#2244AA" penwidth=2
    node [fillcolor="#AAB8EE"]

    TSC2_pT1462     [label="TSC2-pT1462\n(Akt phospho-\ninhibits GAP)"]
    TSC2_pS1387     [label="TSC2-pS1387\n(AMPK activates\nGAP)"]
    TSC2_pS664      [label="TSC2-pS664\n(ERK phospho-\ninhibits)"]
    Rheb_GDP        [label="Rheb-GDP\n(Inactive)" fillcolor="#AAAAEE"]
    Rheb_GTP        [label="Rheb-GTP\n(Active)" fillcolor="#4444FF" fontcolor=white]
    mTOR_kinase     [label="mTOR Kinase\n(Ser/Thr kinase)"]
    Raptor          [label="Raptor\n(mTORC1 scaffold)"]
    Rictor          [label="Rictor\n(mTORC2 scaffold)"]
    mLST8           [label="mLST8\n(GβL)"]
    PRAS40          [label="PRAS40\n(mTORC1 inhibitor)"]
    DEPTOR          [label="DEPTOR\n(mTOR inhibitor)"]
    mTORC1          [label="mTORC1\n(Active Complex)" fillcolor="#2222CC" fontcolor=white shape=box3d]
    mTORC2          [label="mTORC2\n(Rictor/mTOR/mLST8)" fillcolor="#4444BB" fontcolor=white shape=box3d]
    FKBP12          [label="FKBP12\n(Sirolimus binding)"]
    FKBP12_rap      [label="FKBP12·Sirolimus\nComplex" fillcolor="#9999DD"]
  }

  // ============================================================
  // CLUSTER 5: mTORC1 Downstream Substrates
  // ============================================================
  subgraph cluster_05_substrates {
    label="5. mTORC1 Downstream Substrates" style=filled fillcolor="#F0E8FF" color="#7722AA" penwidth=2
    node [fillcolor="#CC99EE"]

    S6K1            [label="S6K1\n(p70-S6K1)"]
    S6K1_pT389      [label="S6K1-pT389\n(Active)" fillcolor="#9933CC"]
    rpS6            [label="rpS6\n(Ribosomal protein S6)"]
    S6_pS235        [label="S6-pS235/236\n(Active)"]
    fourEBP1        [label="4E-BP1\n(Translation repressor)"]
    fourEBP1_hypo   [label="4E-BP1 (hypo-P)\n(Repressor Active)" fillcolor="#AAAAAA"]
    fourEBP1_hyper  [label="4E-BP1 (hyper-P)\n(Repressor Released)" fillcolor="#9933CC"]
    eIF4E           [label="eIF4E\n(Cap-binding)"]
    eIF4F_complex   [label="eIF4F Complex\n(eIF4E/G/A)"]
    cap_dep_transl  [label="Cap-Dependent\nTranslation↑"]
    ribosome_biosyn [label="Ribosome\nBiogenesis↑"]
    ULK1            [label="ULK1\n(Autophagy Init.)"]
    ULK1_pS757     [label="ULK1-pS757\n(mTORC1 Inhibits)"]
    autophagy       [label="Autophagy\n(Inhibited by mTORC1)" fillcolor="#AAAAFF"]
    TFEB            [label="TFEB\n(Lysosome Biogen.)"]
    TFEB_cytoplasm  [label="TFEB-P\n(Cytoplasmic, Inactive)"]
    SREBP1          [label="SREBP1/2\n(Lipid Synthesis)"]
    Lipin1          [label="Lipin-1\n(Phosphatidic acid)"]
    protein_synth   [label="Protein Synthesis\n& Cell Growth↑"]
    cell_size       [label="Cell Size\nIncrease"]
  }

  // ============================================================
  // CLUSTER 6: LAM Cell Biology
  // ============================================================
  subgraph cluster_06_lam_biology {
    label="6. LAM Cell Biology & Behavior" style=filled fillcolor="#FFF5E0" color="#AA6600" penwidth=2
    node [fillcolor="#FFDD88"]

    LAM_proliferation   [label="LAM Cell\nProliferation↑"]
    LAM_survival        [label="LAM Cell\nSurvival (Anti-apoptosis)"]
    LAM_migration       [label="LAM Cell\nMigration↑"]
    LAM_invasion        [label="LAM Cell\nInvasion (Matrix)"]
    CXCL12_CXCR4       [label="CXCL12/CXCR4\n(Homing Signal)"]
    E_cadherin_loss     [label="E-Cadherin Loss\n(EMT-like)"]
    N_cadherin          [label="N-Cadherin\n(Mesenchymal)"]
    vimentin_pos        [label="Vimentin+\n(Mesenchymal)"]
    Bcl2               [label="Bcl-2/Bcl-XL\n(Anti-apoptotic)"]
    cMyc               [label="c-Myc\n(Oncogene)"]
    cyclinD1           [label="Cyclin D1\n(Cell Cycle G1→S)"]
    p27_Kip1           [label="p27/Kip1\n(CDK inhibitor,↓)"]
    VEGF_A             [label="VEGF-A\n(Angiogenesis)"]
    VEGF_D             [label="VEGF-D\n(Key Biomarker)" fillcolor="#FF9900" shape=box3d]
    MMP2               [label="MMP-2\n(Gelatinase A)"]
    MMP9               [label="MMP-9\n(Gelatinase B)"]
    MMP13              [label="MMP-13\n(Collagenase 3)"]
    TIMP1              [label="TIMP-1\n(MMP inhibitor)"]
    TIMP2              [label="TIMP-2\n(MMP inhibitor)"]
    uPA                [label="uPA/tPA\n(Plasminogen Act.)"]
    cathepsin_D        [label="Cathepsin-D\n(Lysosomal Protease)"]
    S6K1_feedback      [label="S6K1→IRS-1\nNeg. Feedback"]
  }

  // ============================================================
  // CLUSTER 7: Lung Pathology
  // ============================================================
  subgraph cluster_07_lung {
    label="7. Lung Pathology & Structural Changes" style=filled fillcolor="#E0F0FF" color="#2266AA" penwidth=2
    node [fillcolor="#99CCFF"]

    LAM_nodule          [label="LAM Nodule\n(Perivascular/bronchiolar)"]
    ECM_degradation     [label="ECM Degradation\n(Elastin, Collagen IV)"]
    elastin_fragments   [label="Elastin Fragments\n(Desmosine, Isodesmosine)"]
    alveolar_wall_destr [label="Alveolar Wall\nDestruction"]
    cyst_nucleation     [label="Cyst Nucleation\n(Air space enlargement)"]
    lung_cyst_growth    [label="Lung Cyst Growth\n(Progressive)"]
    CT_cyst_score       [label="CT Cyst Score\n(Warwick/Visual)"]
    air_trapping        [label="Air Trapping\n(Obstruction)"]
    airflow_obstruction [label="Airflow\nObstruction (FEV1↓)"]
    DLco_impairment     [label="DLCO Impairment\n(Gas Exchange↓)"]
    pneumothorax        [label="Pneumothorax\n(Cyst Rupture)"]
    chylothorax         [label="Chylothorax\n(Lymph Leak)"]
    pleural_effusion    [label="Pleural Effusion\n(Chylous)"]
    airway_remodeling   [label="Airway\nRemodeling"]
    smooth_muscle_hyp   [label="Smooth Muscle\nHyperplasia (Airway)"]
    obstructive_pattern [label="Obstructive Pattern\n(Spirometry)"]
  }

  // ============================================================
  // CLUSTER 8: Lymphatic & Extrapulmonary Involvement
  // ============================================================
  subgraph cluster_08_lymphatic {
    label="8. Lymphatic & Extra-Pulmonary Involvement" style=filled fillcolor="#E8FFE8" color="#226622" penwidth=2
    node [fillcolor="#99EE99"]

    VEGFR3              [label="VEGFR-3\n(Lymphangiog. Receptor)"]
    lymphangiogenesis   [label="Lymphangiogenesis\n(VEGF-D/VEGFR-3)"]
    lymphatic_vessel_dil[label="Lymphatic Vessel\nDilation"]
    lymph_node_LAM      [label="Lymph Node\nInvolvement"]
    retroperitoneal_LAM [label="Retroperitoneal\nLymphangiomyoma"]
    thoracic_duct       [label="Thoracic Duct\nObstruction"]
    angiomyolipoma      [label="Renal\nAngiomyolipoma (AML)"]
    AML_hemorrhage      [label="AML Hemorrhage\nRisk (>3cm)"]
    chylous_ascites     [label="Chylous Ascites"]
    LAM_extralung       [label="Extra-pulmonary\nLAM (rare)"]
    PROX1               [label="PROX1\n(Lymphatic TF)"]
    podoplanin          [label="Podoplanin\n(D2-40, Lymph marker)"]
    LYVE1               [label="LYVE-1\n(Lymph Endothelium)"]
  }

  // ============================================================
  // CLUSTER 9: Hormonal Regulation
  // ============================================================
  subgraph cluster_09_hormonal {
    label="9. Hormonal Regulation (Estrogen/Progesterone)" style=filled fillcolor="#FFE8F8" color="#AA2288" penwidth=2
    node [fillcolor="#FFBBEE"]

    E2_estradiol        [label="17β-Estradiol (E2)\n(Ovarian/Adrenal)"]
    ERalpha_nuclear     [label="ERα\n(Nuclear Receptor)"]
    ERE_transcription   [label="ERE-Driven\nTranscription↑"]
    E2_PI3K_nongenomic  [label="E2 Non-genomic\nPI3K/Akt Activation"]
    E2_mTOR_crosstalk   [label="E2→mTORC1\n(Akt→TSC2 inhib.)"]
    progesterone_E      [label="Progesterone\n(Cytoprotective?)"]
    PRR_signaling       [label="PR Signaling\n(Controversial)"]
    pregnancy_worsen    [label="Pregnancy-Related\nWorsening Risk"]
    OCP_effect          [label="Oral Contraceptive\nEffect (uncertain)"]
    GnRH_agonist        [label="GnRH Agonist\n(Leuprolide off-label)"]
    ovariectomy_effect  [label="Oophorectomy\n(Estrogen ablation)"]
    aromatase           [label="Aromatase\n(CYP19A1)"]
    SHBG               [label="SHBG\n(Binding protein)"]
    menopause_LAM       [label="Post-Menopausal\nSlower Progression"]
  }

  // ============================================================
  // CLUSTER 10: Drug PK (mTOR Inhibitors)
  // ============================================================
  subgraph cluster_10_PK {
    label="10. Drug Pharmacokinetics (mTOR Inhibitors)" style=filled fillcolor="#F5F5E0" color="#888800" penwidth=2
    node [fillcolor="#EEEE99"]

    Sirolimus_dose      [label="Sirolimus Dose\n(2mg/day oral)" shape=component fillcolor="#AAAAFF"]
    Sirolimus_GUT       [label="Sirolimus\nGI Absorption\n(F~15%, variable)"]
    Sirolimus_CENTRAL   [label="Sirolimus\nCentral (Blood)\nCp (ng/mL)" fillcolor="#DDDDFF"]
    Sirolimus_PERIPH    [label="Sirolimus\nPeripheral Tissues\nVss=12L/kg" fillcolor="#DDDDFF"]
    Sirolimus_target    [label="Target Trough\n5-15 ng/mL"]
    Sirolimus_CYP3A4    [label="CYP3A4/5\nMetabolism (Liver)"]
    Sirolimus_Pgp       [label="P-gp Efflux\n(Intestine/BBB)"]
    Sirolimus_t12       [label="t½ ~62h\n(Long half-life)"]
    Everolimus_dose     [label="Everolimus Dose\n(10mg/day oral)" shape=component fillcolor="#FFAAAA"]
    Everolimus_GUT      [label="Everolimus\nGI Absorption\n(F~30%)"]
    Everolimus_CENTRAL  [label="Everolimus\nCentral (Blood)\nCp (ng/mL)" fillcolor="#FFCCCC"]
    Everolimus_PERIPH   [label="Everolimus\nPeripheral Tissues"]
    Everolimus_target   [label="Target Trough\n5-10 ng/mL"]
    Everolimus_t12      [label="t½ ~28h\n(Shorter than Siro)"]
    FKBP12_binding      [label="FKBP12 Binding\n(Kd ~0.2nM)"]
    Sirolimus_TDM       [label="TDM\n(Therapeutic Drug\nMonitoring)"]
  }

  // ============================================================
  // CLUSTER 11: Drug Pharmacodynamics
  // ============================================================
  subgraph cluster_11_PD {
    label="11. Drug Pharmacodynamics & Effects" style=filled fillcolor="#FFF0F5" color="#AA0044" penwidth=2
    node [fillcolor="#FFCCDD"]

    mTORC1_inhibition   [label="mTORC1\nInhibition" fillcolor="#DD4477"]
    S6K1_pT389_reduc    [label="S6K1-pT389\nReduction (PD marker)"]
    fourEBP1_hypophos   [label="4E-BP1 De-\nphosphorylation"]
    LAM_cytostasis      [label="LAM Cell\nCytostasis (≠cytocidal)"]
    LAM_prolifSuppressed[label="Proliferation\nSuppressed"]
    autophagy_induced   [label="Autophagy\nInduction (mTORC1-off)"]
    VEGFD_reduction     [label="VEGF-D Level\nReduction (~30%)"]
    MMP_reduction       [label="MMP Activity\nReduction"]
    FEV1_stabilization  [label="FEV1 Stabilization\n(MILES Trial)"]
    FEV1_partial_recov  [label="FEV1 Partial\nRecovery (on-Rx)"]
    FEV1_loss_off_Rx    [label="FEV1 Loss\n(Off-Treatment)"]
    DLCO_stabilization  [label="DLCO\nStabilization"]
    AML_shrinkage       [label="AML Volume\nReduction (>50%)"]
    drug_resistance     [label="Partial Resistance\n(mTORC2 escape)"]
    mTORC2_escape       [label="mTORC2→Akt-pS473\nEscape Activation"]
    S6K1_IRS1_rebound   [label="S6K1-IRS1 Neg.\nFeedback Rebound"]
  }

  // ============================================================
  // CLUSTER 12: Adverse Effects
  // ============================================================
  subgraph cluster_12_AE {
    label="12. mTOR Inhibitor Adverse Effects" style=filled fillcolor="#F0F0F0" color="#555555" penwidth=2
    node [fillcolor="#CCCCCC"]

    stomatitis          [label="Stomatitis/\nMouth Ulcers (30-40%)"]
    interstitial_pneum  [label="Interstitial\nPneumonitis (1-5%)"]
    hyperlipidemia_AE   [label="Hyperlipidemia\n(Cholesterol/TG↑)"]
    hyperglycemia_AE    [label="Hyperglycemia\n(Insulin Resist.)"]
    bone_marrow_AE      [label="Bone Marrow\nSuppression"]
    infection_risk      [label="Infection Risk↑\n(Immunosuppression)"]
    wound_healing       [label="Wound Healing\nDelay"]
    peripheral_edema    [label="Peripheral\nEdema"]
    menstrual_irreg     [label="Menstrual\nIrregularity"]
    fertility_impair    [label="Fertility\nImpairment"]
    renal_toxicity      [label="Proteinuria\n(Renal)"]
  }

  // ============================================================
  // CLUSTER 13: Biomarkers
  // ============================================================
  subgraph cluster_13_biomarkers {
    label="13. Disease Biomarkers" style=filled fillcolor="#E8F8FF" color="#005599" penwidth=2
    node [fillcolor="#AADDFF"]

    serum_VEGFD         [label="Serum VEGF-D\n(Diagnostic: >800pg/mL)" fillcolor="#4499FF" fontcolor=white]
    serum_siro_trough   [label="Sirolimus Trough\n(Target 5-15ng/mL)"]
    urine_LAM_cells     [label="Urine LAM Cell\nClusters"]
    serum_desmosine     [label="Serum/Urine\nDesmosine (Elastin↓)"]
    alphaSmA_blood      [label="Serum α-SMA\n(Research)"]
    CT_HR               [label="CT Chest\n(HRCT Cyst Pattern)"]
    HRCT_cyst_volume    [label="HRCT Cyst Volume\n(% Lung)"]
    Warwick_score       [label="Warwick CT Score\n(0-4 per zone)"]
    spirometry_FEV1     [label="FEV1 (L/% pred.)\n(Annual decline)"]
    spirometry_FVC      [label="FVC (L/% pred.)"]
    DLCO_ml             [label="DLCO (mL/min/mmHg\n% predicted)"]
    ABG_pO2             [label="Arterial PO2\n(Hypoxemia)"]
    six_MWT             [label="6-Min Walk Test\n(6MWD, SpO2 nadir)"]
  }

  // ============================================================
  // CLUSTER 14: Clinical Endpoints & Management
  // ============================================================
  subgraph cluster_14_endpoints {
    label="14. Clinical Endpoints & Management" style=filled fillcolor="#F0FFE8" color="#226622" penwidth=2
    node [fillcolor="#BBFFAA"]

    SGRQ_score          [label="SGRQ Score\n(QoL, 0-100)"]
    MRC_dyspnea         [label="MRC Dyspnea\nScale (1-5)"]
    EQ5D_score          [label="EQ-5D\n(Health utility)"]
    FEV1_decline_rate   [label="FEV1 Annual\nDecline Rate\n(~120mL/yr untreated)"]
    disease_progression [label="Disease Progression\n(CT + PFT + Sx)"]
    oxygen_therapy      [label="Supplemental O2\n(Hypoxemia)"]
    lung_transplant     [label="Lung Transplantation\n(FEV1<30%, O2 dep.)" fillcolor="#44CC44"]
    transplant_survival [label="Post-Transplant\n5yr Survival ~75%"]
    LAM_recurrence_graft[label="LAM Recurrence\nin Graft (<5%)"]
    sirolimus_bridge    [label="Sirolimus Bridge\nPre-Transplant"]
    genetic_counseling  [label="Genetic Counseling\n(TSC1/2 testing)"]
    MILES_trial         [label="MILES Trial\n(NEJM 2011)"]
    ERS_guidelines      [label="ERS Guidelines\n(2010, 2022)" shape=note]
    ATS_ERS_guidelines  [label="ATS/ERS Statement\n(2010)" shape=note]
  }

  // ============================================================
  // INTER-CLUSTER EDGES
  // ============================================================

  // Cluster 1: Genetic basis
  TSC1_germline_mut -> hamartin [color="#CC4444" label="encodes"]
  TSC2_germline_mut -> tuberin  [color="#CC4444" label="encodes"]
  TSC1_somatic_mut  -> hamartin [color="#CC4444" style=dashed]
  TSC2_somatic_mut  -> tuberin  [color="#CC4444" style=dashed]
  hamartin -> TSC_complex  [color="#CC4444"]
  tuberin  -> TSC_complex  [color="#CC4444"]
  LOH -> TSC_complex_loss  [color="#AA0000"]
  two_hit_model -> TSC_complex_loss [color="#AA0000"]
  TSC_complex_loss -> GAP_activity [color="#AA0000" label="loss" style=dashed]
  TSC_LAM -> TSC1_germline_mut [color="#884444" style=dashed]
  TSC_LAM -> TSC2_germline_mut [color="#884444" style=dashed]
  sporadic_LAM -> TSC2_somatic_mut [color="#884444" style=dashed label="de novo"]

  // Cluster 1 → Cluster 4
  TSC_complex -> GAP_activity  [color="#AA0000"]
  GAP_activity -> Rheb_GDP     [color="#2244AA" label="TSC2 is GAP\nfor Rheb"]

  // Cluster 2: LAM cell origin
  neural_crest_progenitor -> LAM_precursor_cell [color="#CC8800"]
  uterine_LAM_source -> hematogenous_spread [color="#CC8800"]
  hematogenous_spread -> LAM_precursor_cell [color="#CC8800"]
  LAM_precursor_cell -> LAM_cell [color="#CC8800" label="engraftment"]
  LAM_cell -> HMB45_pos       [color="#CC8800"]
  LAM_cell -> alpha_SMA       [color="#CC8800"]
  LAM_cell -> desmin_pos      [color="#CC8800"]
  LAM_cell -> ERalpha_expr    [color="#AA2288"]
  LAM_cell -> PR_expr         [color="#AA2288"]
  LAM_cell -> CD44_expr       [color="#CC8800"]
  LAM_cell -> LAM_cluster_blood [color="#CC8800" label="shed"]

  // Cluster 3: Upstream → Cluster 4
  growth_factors -> RTK           [color="#228822"]
  RTK -> IRS1                     [color="#228822"]
  IRS1 -> PI3K_class1             [color="#228822"]
  PI3K_class1 -> PIP2             [color="#228822"]
  PIP2 -> PIP3                    [color="#228822" label="PI3K"]
  PTEN -> PIP3                    [color="#CC4444" label="PIP3→PIP2\n(inhibit)" arrowhead=tee]
  PIP3 -> PDK1                    [color="#228822"]
