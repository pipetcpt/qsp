digraph IBS_QSP_Model {
  graph [
    label="Irritable Bowel Syndrome (IBS) — Quantitative Systems Pharmacology Model\nBrain-Gut Axis · Serotonin Signaling · Visceral Hypersensitivity · Microbiome · Drug PK/PD"
    labelloc=t fontsize=20 fontname="Helvetica-Bold"
    rankdir=TB splines=curved nodesep=0.30 ranksep=0.50
    bgcolor="#FAFAFA" pad=0.5
  ]
  node [fontname="Helvetica" fontsize=9 style="filled,rounded" shape=box margin="0.12,0.06"]
  edge [fontname="Helvetica" fontsize=7 arrowsize=0.65]

  /* ============================================================
     CLUSTER 1: CNS / Brain-Gut Axis / HPA Axis
     ============================================================ */
  subgraph cluster_CNS {
    label="① CNS / Brain-Gut Axis / HPA Axis"
    style=filled fillcolor="#E8F4FD" color="#2980B9" penwidth=2 fontsize=12 fontname="Helvetica-Bold"

    stress         [label="Psychological\nStress" fillcolor="#AED6F1"]
    amygdala       [label="Amygdala\n(Fear/Anxiety)" fillcolor="#AED6F1"]
    PFC            [label="Prefrontal Cortex\n(Emotional Regulation)" fillcolor="#AED6F1"]
    insula         [label="Insula Cortex\n(Visceral Awareness)" fillcolor="#AED6F1"]
    ACC            [label="Anterior Cingulate\nCortex (Pain)" fillcolor="#AED6F1"]
    thalamus       [label="Thalamus\n(Sensory Relay)" fillcolor="#AED6F1"]
    hypothalamus   [label="Hypothalamus\n(CRF release)" fillcolor="#85C1E9"]
    CRF            [label="CRF/CRH\n(Corticotropin-\nReleasing Factor)" fillcolor="#5DADE2"]
    pituitary      [label="Anterior Pituitary\n(ACTH)" fillcolor="#85C1E9"]
    ACTH           [label="ACTH" fillcolor="#5DADE2"]
    adrenal        [label="Adrenal Cortex" fillcolor="#85C1E9"]
    cortisol       [label="Cortisol\n(Glucocorticoid)" fillcolor="#5DADE2"]
    ANS_symp       [label="Sympathetic NS\n(tone increased)" fillcolor="#AED6F1"]
    vagus          [label="Vagus Nerve\n(Parasympathetic)" fillcolor="#AED6F1"]
    NE_central     [label="Norepinephrine\n(Central)" fillcolor="#85C1E9"]
    sHT_brain      [label="Brain Serotonin\n(Mood/Pain gate)" fillcolor="#85C1E9"]
    BDNF           [label="BDNF\n(Neuroplasticity)" fillcolor="#AED6F1"]
    descend_inhib  [label="Descending Pain\nInhibition" fillcolor="#AED6F1"]
    NE_descend     [label="NE Descending\nModulation" fillcolor="#85C1E9"]
  }

  /* ============================================================
     CLUSTER 2: Enteric Nervous System (ENS)
     ============================================================ */
  subgraph cluster_ENS {
    label="② Enteric Nervous System (ENS)"
    style=filled fillcolor="#EAFAF1" color="#27AE60" penwidth=2 fontsize=12 fontname="Helvetica-Bold"

    myenteric       [label="Myenteric Plexus\n(Auerbach)" fillcolor="#A9DFBF"]
    submucosal_plex [label="Submucosal Plexus\n(Meissner)" fillcolor="#A9DFBF"]
    IPAN            [label="IPANs\n(Intrinsic Primary\nAfferent Neurons)" fillcolor="#58D68D"]
    SN_neurons      [label="S-Neurons\n(Slow AHP)" fillcolor="#A9DFBF"]
    AH_neurons      [label="AH-Neurons\n(After-Hyperp.)" fillcolor="#A9DFBF"]
    exc_motor       [label="Excitatory Motor\nNeurons (ACh/SubP)" fillcolor="#58D68D"]
    inh_motor       [label="Inhibitory Motor\nNeurons (VIP/NOS)" fillcolor="#58D68D"]
    ascending_exc   [label="Ascending Excitatory\nPathway" fillcolor="#A9DFBF"]
    descend_inh_ENS [label="Descending Inhibitory\nPathway (ENS)" fillcolor="#A9DFBF"]
    ACh_ENS         [label="Acetylcholine\n(ENS)" fillcolor="#58D68D"]
    VIP             [label="VIP\n(Vasointestinal\nPeptide)" fillcolor="#A9DFBF"]
    NO_ENS          [label="Nitric Oxide\n(ENS smooth muscle)" fillcolor="#A9DFBF"]
    peristaltic_ref [label="Peristaltic Reflex" fillcolor="#58D68D"]
  }

  /* ============================================================
     CLUSTER 3: Serotonin (5-HT) Signaling System
     ============================================================ */
  subgraph cluster_5HT {
    label="③ Serotonin (5-HT) Signaling"
    style=filled fillcolor="#FEF9E7" color="#F39C12" penwidth=2 fontsize=12 fontname="Helvetica-Bold"

    EC_cells      [label="Enterochromaffin\n(EC) Cells\n(5-HT factory)" fillcolor="#FAD7A0"]
    TPH1          [label="TPH1\n(Tryptophan\nHydroxylase-1)" fillcolor="#F8C471"]
    tryptophan    [label="Tryptophan\n(Dietary precursor)" fillcolor="#FAD7A0"]
    gut_sHT       [label="Luminal/Mucosal\n5-HT" fillcolor="#F39C12" fontcolor=white]
    SERT          [label="SERT\n(5-HT Reuptake\nTransporter)" fillcolor="#F8C471"]
    sHT3R         [label="5-HT3 Receptors\n(Afferent/Secretion)" fillcolor="#E67E22" fontcolor=white]
    sHT4R         [label="5-HT4 Receptors\n(Peristalsis/Prokinetic)" fillcolor="#E67E22" fontcolor=white]
    sHT1AR        [label="5-HT1A Receptors\n(Inhibitory, ENS/CNS)" fillcolor="#FAD7A0"]
    platelet_sHT  [label="Platelet 5-HT\n(Blood store)" fillcolor="#FAD7A0"]
    sHIAA         [label="5-HIAA\n(5-HT Metabolite)" fillcolor="#FAD7A0"]
    MAOI_enz      [label="MAO-A\n(5-HT degradation)" fillcolor="#FAD7A0"]
    sHT_overflow  [label="5-HT Overflow\n(IBS-D excess)" fillcolor="#F39C12" fontcolor=white]
  }

  /* ============================================================
     CLUSTER 4: Gut Epithelial Barrier
     ============================================================ */
  subgraph cluster_barrier {
    label="④ Gut Epithelial Barrier"
    style=filled fillcolor="#FDEDEC" color="#E74C3C" penwidth=2 fontsize=12 fontname="Helvetica-Bold"

    enterocytes    [label="Enterocytes\n(Absorptive cells)" fillcolor="#F1948A"]
    goblet_cells   [label="Goblet Cells\n(Mucus secretion)" fillcolor="#F1948A"]
    mucus_layer    [label="Mucus Layer\n(Protective barrier)" fillcolor="#EC7063"]
    tight_junct    [label="Tight Junctions\n(Claudin/Occludin/ZO-1)" fillcolor="#EC7063"]
    zonulin        [label="Zonulin\n(TJ modulator)" fillcolor="#F1948A"]
    permeability   [label="Intestinal\nPermeability UP" fillcolor="#E74C3C" fontcolor=white]
    LPS_translocate [label="LPS/Antigen\nTranslocation" fillcolor="#E74C3C" fontcolor=white]
    TLR4           [label="TLR4\n(LPS receptor)" fillcolor="#F1948A"]
    MLCK           [label="MLCK\n(TJ phosphorylation)" fillcolor="#F1948A"]
    IFNg_barrier   [label="IFN-gamma\nBarrier disruption" fillcolor="#F1948A"]
    cGMP_CFTR      [label="cGMP to CFTR\n(Cl- secretion)" fillcolor="#F1948A"]
    GCC            [label="GC-C Receptor\n(Guanylate Cyclase-C)" fillcolor="#EC7063"]
  }

  /* ============================================================
     CLUSTER 5: Immune / Mucosal Inflammation
     ============================================================ */
  subgraph cluster_immune {
    label="⑤ Immune and Mucosal Inflammation"
    style=filled fillcolor="#F3E5F5" color="#8E44AD" penwidth=2 fontsize=12 fontname="Helvetica-Bold"

    mast_cells    [label="Mast Cells\n(Key IBS effector)" fillcolor="#CE93D8"]
    mast_activ    [label="Mast Cell\nActivation" fillcolor="#9C27B0" fontcolor=white]
    tryptase_prot [label="Tryptase\n(Serine protease)" fillcolor="#CE93D8"]
    histamine_mc  [label="Histamine\n(from Mast cells)" fillcolor="#CE93D8"]
    CRF_mast_R    [label="CRF-R2\n(on Mast cells)" fillcolor="#CE93D8"]
    TNFa          [label="TNF-alpha\n(up in IBS mucosa)" fillcolor="#9C27B0" fontcolor=white]
    IL1b          [label="IL-1beta\n(Sensitization)" fillcolor="#9C27B0" fontcolor=white]
    IL6           [label="IL-6\n(Acute phase)" fillcolor="#CE93D8"]
    IL10          [label="IL-10\n(Anti-inflam; down IBS)" fillcolor="#CE93D8"]
    IL17          [label="IL-17A\n(Barrier disruption)" fillcolor="#CE93D8"]
    mucosal_Tcells [label="Mucosal T Cells\n(CD4+/CD8+)" fillcolor="#CE93D8"]
    IgE_mast      [label="IgE-Mast\nCross-linking" fillcolor="#CE93D8"]
    PGE2          [label="PGE2\n(Sensitizer)" fillcolor="#9C27B0" fontcolor=white]
    calprotectin  [label="Fecal\nCalprotectin UP" fillcolor="#CE93D8"]
    PAR2          [label="PAR-2\n(Protease-Activated\nReceptor-2)" fillcolor="#9C27B0" fontcolor=white]
  }

  /* ============================================================
     CLUSTER 6: Gut Microbiome
     ============================================================ */
  subgraph cluster_microbiome {
    label="⑥ Gut Microbiome and Metabolites"
    style=filled fillcolor="#E8F5E9" color="#2E7D32" penwidth=2 fontsize=12 fontname="Helvetica-Bold"

    firmicutes      [label="Firmicutes\n(up in IBS-D)" fillcolor="#81C784"]
    bacteroidetes   [label="Bacteroidetes\n(altered ratio)" fillcolor="#81C784"]
    lacto           [label="Lactobacillus spp.\n(down in IBS)" fillcolor="#66BB6A"]
    bifido          [label="Bifidobacterium spp.\n(down in IBS)" fillcolor="#66BB6A"]
    methano         [label="Methanobrevibacter\n(CH4 constipation)" fillcolor="#81C784"]
    hydrogen_prod   [label="H2-Producing\nBacteria" fillcolor="#81C784"]
    SIBO            [label="SIBO\n(Small Intestinal\nBacterial Overgrowth)" fillcolor="#4CAF50" fontcolor=white]
    SCFA            [label="SCFAs\n(Butyrate/Propionate\n/Acetate)" fillcolor="#66BB6A"]
    butyrate        [label="Butyrate\n(Colonocyte fuel\nBarrier support)" fillcolor="#81C784"]
    bile_acids      [label="Bile Acids\n(up primary in IBS-D)" fillcolor="#81C784"]
    bile_FXR        [label="FXR/TGR5\n(Bile acid receptors)" fillcolor="#81C784"]
    tryptophan_micro [label="Tryptophan\nMetabolism\n(Indoles/Kynurenine)" fillcolor="#81C784"]
    H2S             [label="Hydrogen Sulfide\n(Visceral sensitizer)" fillcolor="#81C784"]
    methane_gas     [label="Methane Gas\n(down motility)" fillcolor="#81C784"]
    dysbiosis       [label="Dysbiosis Index\n(Microbiome imbalance)" fillcolor="#4CAF50" fontcolor=white]
  }

  /* ============================================================
     CLUSTER 7: Visceral Hypersensitivity & Pain
     ============================================================ */
  subgraph cluster_pain {
    label="⑦ Visceral Hypersensitivity and Afferent Signaling"
    style=filled fillcolor="#FFF3E0" color="#E65100" penwidth=2 fontsize=12 fontname="Helvetica-Bold"

    DRG           [label="Dorsal Root\nGanglion (DRG)" fillcolor="#FFCC80"]
    spinal_dorsal [label="Spinal Cord\nDorsal Horn" fillcolor="#FFCC80"]
    TRPV1         [label="TRPV1 Channels\n(Heat/pain sensor)" fillcolor="#FF7043" fontcolor=white]
    TRPA1         [label="TRPA1 Channels\n(Chemical irritant)" fillcolor="#FFCC80"]
    SubstanceP    [label="Substance P\n(NK1R ligand)" fillcolor="#FF7043" fontcolor=white]
    CGRP          [label="CGRP\n(Vasodilator/Pain)" fillcolor="#FFCC80"]
    NK1R          [label="NK1 Receptors\n(Spinal cord)" fillcolor="#FFCC80"]
    bradykinin    [label="Bradykinin\n(B2R activation)" fillcolor="#FF7043" fontcolor=white]
    wind_up       [label="Wind-Up\nPhenomenon" fillcolor="#FF7043" fontcolor=white]
    central_sens  [label="Central\nSensitization" fillcolor="#BF360C" fontcolor=white]
    NMDAR_pain    [label="NMDA Receptors\n(Sensitization)" fillcolor="#FFCC80"]
    afferent_A    [label="A-delta Fibers\n(Sharp pain)" fillcolor="#FFCC80"]
    afferent_C    [label="C Fibers\n(Dull/burning pain)" fillcolor="#FFCC80"]
    spinal_sHT3   [label="Spinal 5-HT3R\n(Pain facilitation)" fillcolor="#FFCC80"]
  }

  /* ============================================================
     CLUSTER 8: Clinical Endpoints
     ============================================================ */
  subgraph cluster_clinical {
    label="⑧ Clinical Endpoints and Patient-Reported Outcomes"
    style=filled fillcolor="#ECEFF1" color="#455A64" penwidth=2 fontsize=12 fontname="Helvetica-Bold"

    pain_score     [label="Abdominal Pain\nScore (NRS 0-10)" fillcolor="#B0BEC5"]
    bloating       [label="Bloating/\nDistension" fillcolor="#B0BEC5"]
    stool_BSFS     [label="Bristol Stool Form\nScale (1-7)" fillcolor="#90A4AE"]
    transit_time   [label="Colonic Transit\nTime (hours)" fillcolor="#B0BEC5"]
    IBS_SSS        [label="IBS Symptom\nSeverity Score (0-500)" fillcolor="#607D8B" fontcolor=white]
    QoL_IBS        [label="QoL-IBS\n(Quality of Life)" fillcolor="#B0BEC5"]
    defecation_freq [label="Defecation\nFrequency/day" fillcolor="#B0BEC5"]
    stool_water    [label="Fecal Water\nContent (%)" fillcolor="#B0BEC5"]
    urgency        [label="Urgency\nScore" fillcolor="#B0BEC5"]
    GI_global      [label="Global\nAssessment\n(Adequate Relief)" fillcolor="#607D8B" fontcolor=white]
    serum_CgA      [label="Serum\nChromogranin A\n(EC cell marker)" fillcolor="#B0BEC5"]
    rectal_sens    [label="Rectal Sensitivity\n(Barostat mmHg)" fillcolor="#B0BEC5"]
  }

  /* ============================================================
     CLUSTER 9: Pharmacological Interventions
     ============================================================ */
  subgraph cluster_drugs {
    label="⑨ Pharmacological Interventions — Drug PK/PD"
    style=filled fillcolor="#E3F2FD" color="#0D47A1" penwidth=2 fontsize=12 fontname="Helvetica-Bold"

    alosetron      [label="Alosetron\n(5-HT3 Antag.)\nIBS-D (female)" fillcolor="#1565C0" fontcolor=white]
    ondansetron    [label="Ondansetron\n(5-HT3 Antag.)" fillcolor="#1E88E5" fontcolor=white]
    prucalopride   [label="Prucalopride\n(5-HT4 Agonist)\nIBS-C" fillcolor="#0277BD" fontcolor=white]
    tegaserod      [label="Tegaserod\n(5-HT4/5-HT1A)\nIBS-C (historical)" fillcolor="#1E88E5" fontcolor=white]
    hyoscine       [label="Hyoscine\n(Anticholinergic\nAntispasmodic)" fillcolor="#42A5F5"]
    mebeverine     [label="Mebeverine\n(Smooth muscle\nrelaxant)" fillcolor="#42A5F5"]
    peppermint_oil [label="Peppermint Oil\n(TRPM8 agonist\nCa2+ channel blocker)" fillcolor="#42A5F5"]
    dicyclomine    [label="Dicyclomine\n(Anticholinergic)" fillcolor="#42A5F5"]
    amitriptyline  [label="Amitriptyline\n(TCA; Low-dose\nVisceral analgesia)" fillcolor="#1565C0" fontcolor=white]
    duloxetine     [label="Duloxetine\n(SNRI; Pain mod.)" fillcolor="#1E88E5" fontcolor=white]
    SSRIs          [label="SSRIs\n(Fluoxetine/Paroxetine\nIBS-C use)" fillcolor="#1E88E5" fontcolor=white]
    rifaximin      [label="Rifaximin\n(Non-absorbable\nAntibiotic)\nSIBO/IBS-D" fillcolor="#0D47A1" fontcolor=white]
    linaclotide    [label="Linaclotide\n(GC-C Agonist)\nIBS-C + Pain" fillcolor="#1565C0" fontcolor=white]
    lubiprostone   [label="Lubiprostone\n(ClC-2 activator)\nIBS-C (female)" fillcolor="#1E88E5" fontcolor=white]
    plecanatide    [label="Plecanatide\n(GC-C Agonist)\nIBS-C" fillcolor="#42A5F5"]
    eluxadoline    [label="Eluxadoline\n(mu/kappa agonist\ndelta antagonist)\nIBS-D" fillcolor="#0D47A1" fontcolor=white]
    probiotics     [label="Probiotics\n(VSL#3, LGG\nBifidum/Plantarum)" fillcolor="#42A5F5"]
    drug1_central  [label="Drug1\nCentral CMT (Cp1)" fillcolor="#90CAF9"]
    drug1_periph   [label="Drug1\nPeripheral CMT (Cp2)" fillcolor="#90CAF9"]
    drug2_central  [label="Drug2\nCentral CMT (Cp3)" fillcolor="#90CAF9"]
    drug2_periph   [label="Drug2\nPeripheral CMT (Cp4)" fillcolor="#90CAF9"]
  }

  /* ============================================================
     EDGES — CNS / HPA Axis
     ============================================================ */
  stress -> amygdala [color="#2980B9"]
  stress -> hypothalamus [label="CRF stim" color="#2980B9"]
  amygdala -> hypothalamus [color="#2980B9"]
  amygdala -> ANS_symp [label="fear/stress" color="#2980B9"]
  PFC -> amygdala [label="top-down\ninhibit" color="#27AE60" style=dashed]
  hypothalamus -> CRF [color="#2980B9"]
  CRF -> pituitary [color="#2980B9"]
  pituitary -> ACTH [color="#2980B9"]
  ACTH -> adrenal [color="#2980B9"]
  adrenal -> cortisol [color="#2980B9"]
  cortisol -> permeability [label="TJ opening" color="#E74C3C"]
  cortisol -> mast_activ [label="CRF-mast" color="#8E44AD"]
  CRF -> CRF_mast_R [label="direct mast\nactivation" color="#8E44AD"]
  cortisol -> mucosal_Tcells [label="complex\nmodulation" color="#8E44AD" style=dashed]
  ANS_symp -> gut_sHT [label="NE/EC cells" color="#F39C12"]
  ANS_symp -> mast_activ [label="beta-AR" color="#8E44AD"]
  vagus -> myenteric [label="vago-vagal\nreflex" color="#27AE60"]
  vagus -> descend_inhib [label="vagal\nanalgesia" color="#2980B9"]
  NE_central -> descend_inhib [color="#2980B9"]
  sHT_brain -> descend_inhib [label="bulbospinal\n5-HT" color="#F39C12"]
  BDNF -> central_sens [label="neuroplastic" color="#E65100"]
  descend_inhib -> spinal_dorsal [label="pain inhibit" color="#27AE60" style=dashed]
  NE_descend -> spinal_dorsal [label="alpha2 inhib" color="#27AE60" style=dashed]
  insula -> pain_score [color="#455A64"]
  ACC -> pain_score [color="#455A64"]
  thalamus -> insula [color="#2980B9"]
  thalamus -> ACC [color="#2980B9"]
  spinal_dorsal -> thalamus [color="#E65100"]

  /* ============================================================
     EDGES — ENS internal
     ============================================================ */
  IPAN -> ascending_exc [color="#27AE60"]
  IPAN -> descend_inh_ENS [color="#27AE60"]
  ascending_exc -> exc_motor [color="#27AE60"]
  descend_inh_ENS -> inh_motor [color="#27AE60"]
  exc_motor -> ACh_ENS [color="#27AE60"]
  exc_motor -> SubstanceP [label="ENS SubP" color="#E65100"]
  inh_motor -> VIP [color="#27AE60"]
  inh_motor -> NO_ENS [color="#27AE60"]
  myenteric -> peristaltic_ref [color="#27AE60"]
  submucosal_plex -> peristaltic_ref [color="#27AE60"]
  AH_neurons -> SN_neurons [color="#27AE60"]
  SN_neurons -> exc_motor [color="#27AE60"]
  SN_neurons -> inh_motor [color="#27AE60"]
  ACh_ENS -> peristaltic_ref [color="#27AE60"]
  peristaltic_ref -> transit_time [label="propulsion" color="#455A64"]

  /* ============================================================
     EDGES — 5-HT Signaling
     ============================================================ */
  tryptophan -> TPH1 [color="#F39C12"]
  TPH1 -> gut_sHT [color="#F39C12"]
  EC_cells -> gut_sHT [label="release" color="#F39C12"]
  gut_sHT -> sHT3R [color="#F39C12"]
  gut_sHT -> sHT4R [color="#F39C12"]
  gut_sHT -> sHT1AR [color="#F39C12"]
  gut_sHT -> SERT [label="reuptake\nsubstrate" color="#E67E22"]
  SERT -> sHIAA [label="metabolism" color="#E67E22"]
  SERT -> platelet_sHT [label="platelet\nuptake" color="#FAD7A0"]
  MAOI_enz -> sHIAA [color="#E67E22"]
  gut_sHT -> sHT_overflow [label="IBS-D excess" color="#E67E22"]
  sHT3R -> DRG [label="visceral\nafferent" color="#E65100"]
  sHT3R -> IPAN [label="mucosal\nstimulation" color="#27AE60"]
  sHT4R -> peristaltic_ref [label="pro-kinetic" color="#27AE60"]
  sHT4R -> ascending_exc [color="#27AE60"]
  sHT_overflow -> pain_score [color="#E65100"]
  sHT_overflow -> transit_time [label="motility up\nIBS-D" color="#455A64"]

  /* ============================================================
     EDGES — Barrier
     ============================================================ */
  goblet_cells -> mucus_layer [color="#E74C3C"]
  mucus_layer -> permeability [label="protection" color="#27AE60" style=dashed]
  tight_junct -> permeability [label="sealing" color="#27AE60" style=dashed]
  zonulin -> tight_junct [label="opens TJs" color="#E74C3C"]
  MLCK -> tight_junct [label="phosphorylate\noccludin" color="#E74C3C"]
  permeability -> LPS_translocate [color="#E74C3C"]
  LPS_translocate -> TLR4 [color="#8E44AD"]
  TLR4 -> TNFa [label="NF-kB" color="#8E44AD"]
  TLR4 -> IL1b [label="NLRP3" color="#8E44AD"]
  IFNg_barrier -> MLCK [label="barrier\nbreaking" color="#E74C3C"]
  GCC -> cGMP_CFTR [label="cGMP up" color="#1565C0"]
  cGMP_CFTR -> stool_water [label="Cl-/fluid\nsecretion" color="#455A64"]
  cGMP_CFTR -> TRPV1 [label="cGMP sensitiz\ndown" color="#27AE60" style=dashed]
  enterocytes -> tight_junct [label="maintain" color="#27AE60" style=dashed]

  /* ============================================================
     EDGES — Immune / Inflammation
     ============================================================ */
  mast_cells -> mast_activ [color="#8E44AD"]
  CRF_mast_R -> mast_activ [label="CRF mast" color="#8E44AD"]
  IgE_mast -> mast_activ [label="allergen" color="#8E44AD"]
  mast_activ -> tryptase_prot [color="#8E44AD"]
  mast_activ -> histamine_mc [color="#8E44AD"]
  mast_activ -> TNFa [color="#8E44AD"]
  mast_activ -> IL1b [color="#8E44AD"]
  tryptase_prot -> PAR2 [color="#8E44AD"]
  PAR2 -> TRPV1 [label="sensitize\nafferents" color="#E65100"]
  PAR2 -> permeability [label="barrier down" color="#E74C3C"]
  histamine_mc -> sHT3R [label="histamine\nsensitizes" color="#F39C12"]
  histamine_mc -> afferent_C [label="H1R pain" color="#E65100"]
  TNFa -> mucosal_Tcells [color="#8E44AD"]
  TNFa -> IL6 [color="#8E44AD"]
  TNFa -> MLCK [label="perm up" color="#E74C3C"]
  IL1b -> central_sens [label="neuroimm." color="#E65100"]
  IL1b -> PGE2 [label="COX-2" color="#8E44AD"]
  IL6 -> mucosal_Tcells [color="#8E44AD"]
  IL10 -> mast_activ [label="suppress" color="#27AE60" style=dashed]
  IL10 -> TNFa [label="suppress" color="#27AE60" style=dashed]
  IL17 -> permeability [label="claudin down" color="#E74C3C"]
  PGE2 -> pain_score [label="sensitize" color="#E65100"]
  PGE2 -> TRPV1 [label="sensitiz up" color="#E65100"]
  mucosal_Tcells -> IFNg_barrier [label="Th1/IFN-g" color="#E74C3C"]
  mucosal_Tcells -> IL17 [label="Th17" color="#8E44AD"]
  calprotectin -> dysbiosis [label="inflam\nmarker" color="#2E7D32"]

  /* ============================================================
     EDGES — Microbiome
     ============================================================ */
  lacto -> SCFA [color="#2E7D32"]
  bifido -> SCFA [color="#2E7D32"]
  lacto -> dysbiosis [label="protect" color="#27AE60" style=dashed]
  bifido -> dysbiosis [label="protect" color="#27AE60" style=dashed]
  firmicutes -> hydrogen_prod [color="#2E7D32"]
  hydrogen_prod -> SIBO [color="#2E7D32"]
  methano -> methane_gas [color="#2E7D32"]
  methane_gas -> transit_time [label="constipation" color="#455A64"]
  SIBO -> dysbiosis [color="#2E7D32"]
  dysbiosis -> permeability [label="leaky gut" color="#E74C3C"]
  dysbiosis -> mast_activ [label="LPS mast" color="#8E44AD"]
  SCFA -> butyrate [color="#2E7D32"]
  butyrate -> enterocytes [label="fuel" color="#27AE60"]
