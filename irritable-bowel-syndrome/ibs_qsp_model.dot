digraph IBS_QSP {
  graph [
    label="Irritable Bowel Syndrome (IBS) — Quantitative Systems Pharmacology Map\nBrain-Gut Axis · Serotonin Signaling · Visceral Hypersensitivity · Mucosal Immunity · Drug PK/PD",
    labelloc=t, fontsize=20, fontname="Helvetica-Bold",
    bgcolor="#0a0a14", fontcolor="white",
    layout=fdp, splines=true, compound=true, overlap=false,
    nodesep=0.35, ranksep=0.55, pad=0.8, K=1.2
  ];
  node [shape=box, style="rounded,filled", fontname="Helvetica", fontsize=9];
  edge [fontname="Helvetica", fontsize=7.5, color="#aaaaaa", arrowsize=0.7];

  // ================================================================
  // CLUSTER 1: Central Nervous System
  // ================================================================
  subgraph cluster_CNS {
    label="Central Nervous System (CNS)";
    style=filled; fillcolor="#0d1b4a"; color="#4a7aff"; fontcolor="white"; fontsize=13;

    ACC       [label="ACC\n(Anterior Cingulate Cortex)", fillcolor="#1a3a8a", fontcolor="white"];
    Insula    [label="Insula\n(Interoceptive Awareness)", fillcolor="#1a3a8a", fontcolor="white"];
    PFC       [label="PFC\n(Prefrontal Cortex)", fillcolor="#1a3a8a", fontcolor="white"];
    Amygdala  [label="Amygdala\n(Fear/Anxiety)", fillcolor="#1a3a8a", fontcolor="white"];
    PAG       [label="PAG\n(Periaqueductal Gray)", fillcolor="#2a4a9a", fontcolor="white"];
    Thalamus  [label="Thalamus\n(Pain Relay)", fillcolor="#2a4a9a", fontcolor="white"];
    SomCortex [label="S1/S2 Cortex\n(Pain Perception)", fillcolor="#1a3a8a", fontcolor="white"];
    LC        [label="Locus Coeruleus\n(NE / Arousal)", fillcolor="#2a4a9a", fontcolor="white"];
    RVM       [label="RVM\n(Rostral Ventromedial Medulla)", fillcolor="#2a4a9a", fontcolor="white"];
    NTS       [label="NTS\n(Nucleus Tractus Solitarius)", fillcolor="#2a4a9a", fontcolor="white"];
    Catastroph [label="Pain Catastrophizing\n(Psychosocial)", fillcolor="#0a2060", fontcolor="white"];
    AnxDep    [label="Anxiety / Depression\n(Comorbidity 50-90%)", fillcolor="#0a2060", fontcolor="white"];
    TopDown   [label="Top-Down\nPain Modulation", fillcolor="#1a2a70", fontcolor="white"];
  }

  // ================================================================
  // CLUSTER 2: HPA Axis & Stress Response
  // ================================================================
  subgraph cluster_HPA {
    label="HPA Axis & Stress Response";
    style=filled; fillcolor="#1a0a3a"; color="#9a4aff"; fontcolor="white"; fontsize=13;

    Hypothalamus [label="Hypothalamus (PVN)\nStress Integration", fillcolor="#3a1a5a", fontcolor="white"];
    CRH          [label="CRH\n(Corticotropin-Releasing Hormone)", fillcolor="#5a1a7a", fontcolor="white"];
    CRHR1        [label="CRH-R1\n(Pituitary + Mast cells)", fillcolor="#4a1a6a", fontcolor="white"];
    CRHR2        [label="CRH-R2\n(Peripheral / ENS)", fillcolor="#4a1a6a", fontcolor="white"];
    Pituitary    [label="Anterior Pituitary\n(Corticotrophs)", fillcolor="#3a1a5a", fontcolor="white"];
    ACTH         [label="ACTH\n(Adrenocorticotropin)", fillcolor="#5a2a7a", fontcolor="white"];
    AdrenalCortex [label="Adrenal Cortex\n(Zona Fasciculata)", fillcolor="#3a1a5a", fontcolor="white"];
    Cortisol     [label="Cortisol\n(Glucocorticoid)", fillcolor="#7a2a9a", fontcolor="white"];
    CortisolFB   [label="Cortisol\nNegative Feedback (HPA)", fillcolor="#2a0a4a", fontcolor="white"];
    EarlyStress  [label="Early-Life Stress\n(Epigenetic Imprinting)", fillcolor="#2a0a4a", fontcolor="white"];
    ChronicStress [label="Chronic Psychosocial\nStress (IBS trigger)", fillcolor="#4a2a6a", fontcolor="white"];
    UCN          [label="Urocortin 1/2/3\n(CRH-R2 ligands)", fillcolor="#3a1a5a", fontcolor="white"];
  }

  // ================================================================
  // CLUSTER 3: Autonomic Nervous System
  // ================================================================
  subgraph cluster_ANS {
    label="Autonomic Nervous System";
    style=filled; fillcolor="#0a1a2a"; color="#2a9aaa"; fontcolor="white"; fontsize=13;

    VagusNerve   [label="Vagus Nerve (CN X)\n75% afferent fibers", fillcolor="#1a3a4a", fontcolor="white"];
    VagalAfferents [label="Vagal Afferents\n(Nodose Ganglion → NTS)", fillcolor="#1a3a4a", fontcolor="white"];
    VagalEfferents [label="Vagal Efferents\n(Cholinergic → ENS)", fillcolor="#1a3a4a", fontcolor="white"];
    SympChain    [label="Sympathetic Chain\n(T9–L2 splanchnic)", fillcolor="#1a3a4a", fontcolor="white"];
    SplanchnicN  [label="Splanchnic Nerves\n(Visceral pain afferents)", fillcolor="#1a3a4a", fontcolor="white"];
    NE_ANS       [label="Norepinephrine\n(Sympathetic terminal)", fillcolor="#2a4a5a", fontcolor="white"];
    ACh_ANS      [label="Acetylcholine\n(Parasympathetic)", fillcolor="#2a4a5a", fontcolor="white"];
    Alpha2R      [label="α2-Adrenoceptor\n(ENS pre-synaptic)", fillcolor="#2a4a5a", fontcolor="white"];
    Beta1R       [label="β1/β2-AR\n(Gut relaxation)", fillcolor="#2a4a5a", fontcolor="white"];
    SpinalDH     [label="Dorsal Horn\n(L1–L2 / T10–T11)", fillcolor="#1a3a4a", fontcolor="white"];
    DRG          [label="Dorsal Root Ganglia\n(Visceral C/Aδ fibers)", fillcolor="#2a4a5a", fontcolor="white"];
    DNIC         [label="DNIC\n(Conditioned Pain Modulation)", fillcolor="#0a2a3a", fontcolor="white"];
  }

  // ================================================================
  // CLUSTER 4: Enteric Nervous System
  // ================================================================
  subgraph cluster_ENS {
    label="Enteric Nervous System (ENS) — 'Second Brain'  ~500 million neurons";
    style=filled; fillcolor="#0a2a0a"; color="#2aaa4a"; fontcolor="white"; fontsize=13;

    SubmucosalPlexus [label="Submucosal Plexus\n(Meissner's)", fillcolor="#1a4a1a", fontcolor="white"];
    MyentericPlexus  [label="Myenteric Plexus\n(Auerbach's)", fillcolor="#1a4a1a", fontcolor="white"];
    IPAN             [label="IPANs\n(Intrinsic Primary Afferent Neurons)", fillcolor="#2a5a2a", fontcolor="white"];
    AscInterN        [label="Ascending Interneurons\n(ChAT+  excitatory)", fillcolor="#1a4a1a", fontcolor="white"];
    DescInterN       [label="Descending Interneurons\n(5-HT+ / NO+ inhibitory)", fillcolor="#1a4a1a", fontcolor="white"];
    ExcMotorN        [label="Excitatory Motor Neurons\n(ACh + SP, oral contraction)", fillcolor="#2a5a2a", fontcolor="white"];
    InhMotorN        [label="Inhibitory Motor Neurons\n(VIP + NO, aboral relaxation)", fillcolor="#2a5a2a", fontcolor="white"];
    ACh_ENS          [label="ACh (ENS)\nM2/M3 receptors", fillcolor="#3a6a3a", fontcolor="white"];
    SubP_ENS         [label="Substance P\n(NK1R on smooth muscle)", fillcolor="#3a6a3a", fontcolor="white"];
    VIP_ENS          [label="VIP\n(Vasoactive Intestinal Peptide)", fillcolor="#3a6a3a", fontcolor="white"];
    NO_ENS           [label="Nitric Oxide (ENS)\n(NANC inhibitory)", fillcolor="#3a6a3a", fontcolor="white"];
    CGRP_ENS         [label="CGRP (ENS)\n(Calcitonin Gene-Related Peptide)", fillcolor="#3a6a3a", fontcolor="white"];
    NPY_ENS          [label="NPY\n(Neuropeptide Y, anti-secretory)", fillcolor="#2a5a2a", fontcolor="white"];
    ICC              [label="ICC\n(Interstitial Cells of Cajal, pacemaker)", fillcolor="#1a4a1a", fontcolor="white"];
    CircularMuscle   [label="Circular Smooth Muscle\n(segmentation / mixing)", fillcolor="#0a3a0a", fontcolor="white"];
    LongMuscle       [label="Longitudinal Smooth Muscle\n(propulsion)", fillcolor="#0a3a0a", fontcolor="white"];
    PeaceSignal      [label="Peristaltic Reflex\n(ascending excitation +\ndescending relaxation)", fillcolor="#1a4a1a", fontcolor="white"];
  }

  // ================================================================
  // CLUSTER 5: Serotonin (5-HT) Signaling
  // ================================================================
  subgraph cluster_5HT {
    label="Serotonin (5-HT) Signaling  — Gut contains ~95% of body 5-HT";
    style=filled; fillcolor="#3a1a00"; color="#ff8a2a"; fontcolor="white"; fontsize=13;

    LTryptophan  [label="L-Tryptophan\n(dietary amino acid)", fillcolor="#4a1a00", fontcolor="white"];
    TPH1         [label="TPH1\n(Tryptophan Hydroxylase 1, EC cells)", fillcolor="#6a3a00", fontcolor="white"];
    TPH2         [label="TPH2\n(Tryptophan Hydroxylase 2, ENS/CNS)", fillcolor="#6a3a00", fontcolor="white"];
    FiveHTP      [label="5-HTP\n(5-Hydroxytryptophan)", fillcolor="#5a2a00", fontcolor="white"];
    AADC         [label="AADC\n(Aromatic AA Decarboxylase)", fillcolor="#5a2a00", fontcolor="white"];
    EC_Cells     [label="EC Cells\n(Enterochromaffin, >80% of mucosal 5-HT)", fillcolor="#7a3a00", fontcolor="#ffcc44"];
    Serotonin    [label="5-HT (Released)\nLuminal + Basolateral", fillcolor="#8a4a00", fontcolor="#ffcc44"];
    SERT         [label="SERT (SLC6A4)\n5-HT Reuptake Transporter", fillcolor="#6a3a00", fontcolor="white"];
    Platelets5HT [label="Platelets\n(5-HT storage & systemic transport)", fillcolor="#5a2a00", fontcolor="white"];
    MAO_A        [label="MAO-A\n(Mitochondrial degradation)", fillcolor="#5a2a00", fontcolor="white"];
    HIAA         [label="5-HIAA\n(Urinary metabolite biomarker)", fillcolor="#4a1a00", fontcolor="white"];
    HT3R         [label="5-HT3R\n(Ionotropic, afferent nerves + EC cells)", fillcolor="#8a4a00", fontcolor="#ffcc44"];
    HT4R         [label="5-HT4R\n(Gs-GPCR, motor neurons + ICC)", fillcolor="#8a4a00", fontcolor="#ffcc44"];
    HT7R         [label="5-HT7R\n(Gs-GPCR, ENS/CNS relaxation)", fillcolor="#6a3a00", fontcolor="white"];
    HT1AR        [label="5-HT1A/1B R\n(Autoreceptor on EC cells/raphe)", fillcolor="#6a3a00", fontcolor="white"];
    cAMP_5HT4   [label="cAMP↑ (5-HT4R)\nAC → PKA → ACh release", fillcolor="#5a2a00", fontcolor="white"];
  }

  // ================================================================
  // CLUSTER 6: Gut Barrier & Mucosal Integrity
  // ================================================================
  subgraph cluster_Barrier {
    label="Intestinal Epithelial Barrier & Mucosal Integrity";
    style=filled; fillcolor="#2a1a0a"; color="#9a6a2a"; fontcolor="white"; fontsize=13;

    GobletCells  [label="Goblet Cells\n(Mucin-2 / MUC5AC)", fillcolor="#4a2a0a", fontcolor="white"];
    MucusLayer   [label="Mucus Layer\n(inner gel + outer loose layer)", fillcolor="#5a3a1a", fontcolor="white"];
    IEC          [label="Intestinal Epithelial Cells\n(IEC, colonocytes)", fillcolor="#4a2a0a", fontcolor="white"];
    TightJunction [label="Tight Junctions\n(Claudin-1/2/3, Occludin, ZO-1)", fillcolor="#5a3a1a", fontcolor="white"];
    ZO1          [label="ZO-1 / ZO-2\n(Scaffold proteins)", fillcolor="#4a2a0a", fontcolor="white"];
    ECadherin    [label="E-Cadherin\n(Adherens junctions)", fillcolor="#4a2a0a", fontcolor="white"];
    ParaCell     [label="Paracellular Permeability ↑\n(Leaky Gut in IBS)", fillcolor="#6a4a2a", fontcolor="#ffcc44"];
    SIgA         [label="Secretory IgA\n(Luminal immune defense)", fillcolor="#4a2a0a", fontcolor="white"];
    Defensins    [label="α/β-Defensins\n(Antimicrobial peptides)", fillcolor="#4a2a0a", fontcolor="white"];
    BileAcids    [label="Bile Acids\n(Primary: CA/CDCA; Secondary: DCA/LCA)", fillcolor="#5a3a1a", fontcolor="white"];
    FXR          [label="FXR\n(Farnesoid X Receptor)", fillcolor="#4a2a0a", fontcolor="white"];
    TGR5         [label="TGR5 / GPBAR1\n(Bile acid → 5-HT release in EC cells)", fillcolor="#4a2a0a", fontcolor="white"];
    CFTR         [label="CFTR\n(Cl⁻ channel, cGMP/cAMP regulated)", fillcolor="#4a2a0a", fontcolor="white"];
    NHE3         [label="NHE3\n(Na+/H+ exchanger, absorption)", fillcolor="#4a2a0a", fontcolor="white"];
    AQP3         [label="AQP3\n(Aquaporin, water transport)", fillcolor="#4a2a0a", fontcolor="white"];
  }

  // ================================================================
  // CLUSTER 7: Gut Microbiome & Dysbiosis
  // ================================================================
  subgraph cluster_Microbiome {
    label="Gut Microbiome & Dysbiosis";
    style=filled; fillcolor="#1a2a0a"; color="#6a8a2a"; fontcolor="white"; fontsize=13;

    Bacteroidetes  [label="Bacteroidetes\n(↓ in IBS-D)", fillcolor="#2a4a0a", fontcolor="white"];
    Firmicutes     [label="Firmicutes\n(F:B ratio↑ in IBS-C)", fillcolor="#2a4a0a", fontcolor="white"];
    Proteobacteria [label="Proteobacteria\n(↑, LPS-producing)", fillcolor="#2a4a0a", fontcolor="white"];
    Bifidobacterium [label="Bifidobacterium\n(↓ in IBS)", fillcolor="#2a4a0a", fontcolor="white"];
    Lactobacillus  [label="Lactobacillus spp.\n(Probiotic)", fillcolor="#2a4a0a", fontcolor="white"];
    Dysbiosis      [label="Gut Dysbiosis\n(Altered F:B ratio, diversity↓)", fillcolor="#4a6a0a", fontcolor="#ccff44"];
    Butyrate       [label="Butyrate (SCFA)\n(Energy, anti-inflammatory, TJ integrity)", fillcolor="#3a5a1a", fontcolor="white"];
    Propionate     [label="Propionate (SCFA)\n(Motility regulator, GPR41/43)", fillcolor="#3a5a1a", fontcolor="white"];
    Acetate        [label="Acetate (SCFA)\n(Systemic energy, GPR43)", fillcolor="#3a5a1a", fontcolor="white"];
    LPS_MB         [label="LPS\n(TLR4 ligand → mucosal inflammation)", fillcolor="#5a7a1a", fontcolor="#ffff44"];
    IndoleMetab    [label="Indole / IAA / IPA\n(Tryptophan catabolites, AhR ligands)", fillcolor="#3a5a1a", fontcolor="white"];
    SecBileAcids   [label="Secondary Bile Acids\n(DCA/LCA via Bacteroides/Clostridium)", fillcolor="#3a5a1a", fontcolor="white"];
    GasProduction  [label="H2 / CH4 / H2S\n(Fermentation → bloating)", fillcolor="#4a6a1a", fontcolor="white"];
    Methane        [label="Methane (CH4)\n(Methanobrevibacter → IBS-C)", fillcolor="#3a5a1a", fontcolor="white"];
    SIBO           [label="SIBO\n(Small Intestinal Bacterial Overgrowth)", fillcolor="#4a6a1a", fontcolor="#ccff44"];
    PostInfection  [label="Post-Infectious Trigger\n(PI-IBS, 10–20% of cases)", fillcolor="#3a5a1a", fontcolor="white"];
  }

  // ================================================================
  // CLUSTER 8: Mucosal Immune Activation
  // ================================================================
  subgraph cluster_Immune {
    label="Mucosal Immune Activation — Low-Grade Inflammation";
    style=filled; fillcolor="#2a0a0a"; color="#aa2a2a"; fontcolor="white"; fontsize=13;

    MastCells       [label="Mast Cells (MC)\nProximity to submucosal nerves", fillcolor="#4a0a0a", fontcolor="white"];
    MC_Degran       [label="MC Degranulation\n(IgE / CRH / bacterial LPS)", fillcolor="#6a1a1a", fontcolor="white"];
    Histamine       [label="Histamine\n(H1R: pain sensitization; H2R: secretion)", fillcolor="#5a1a1a", fontcolor="white"];
    Tryptase_MC     [label="Tryptase\n(PAR-2 activation → TJ disruption)", fillcolor="#5a1a1a", fontcolor="white"];
    PGE2            [label="PGE2\n(EP1/EP2/EP4R → pain + secretion)", fillcolor="#5a1a1a", fontcolor="white"];
    TNFalpha        [label="TNF-α\n(Low-grade, TJ disruption)", fillcolor="#6a2a2a", fontcolor="white"];
    IL6_Imm         [label="IL-6\n(Neuromodulatory cytokine)", fillcolor="#5a1a1a", fontcolor="white"];
    IL1B            [label="IL-1β\n(Hyperalgesia induction)", fillcolor="#5a1a1a", fontcolor="white"];
    IL10_Imm        [label="IL-10\n(Anti-inflammatory, ↓ in IBS)", fillcolor="#4a0a0a", fontcolor="white"];
    Th1_Imm         [label="Th1\n(IFN-γ / TNF-α dominant in IBS-D)", fillcolor="#5a1a1a", fontcolor="white"];
    Th2_Imm         [label="Th2\n(IL-4 / IL-13 in IBS-C)", fillcolor="#5a1a1a", fontcolor="white"];
    Tregs_Imm       [label="Regulatory T Cells\n(IL-10 / TGF-β)", fillcolor="#4a0a0a", fontcolor="white"];
    Eosinophils     [label="Eosinophils\n(↑ in duodenum/jejunum)", fillcolor="#5a1a1a", fontcolor="white"];
    TLR4_Imm        [label="TLR4\n(LPS recognition → NFκB)", fillcolor="#4a0a0a", fontcolor="white"];
    TLR2_Imm        [label="TLR2\n(Bacterial peptidoglycan)", fillcolor="#4a0a0a", fontcolor="white"];
    PAR2_Imm        [label="PAR-2\n(Protease-Activated Receptor)", fillcolor="#5a1a1a", fontcolor="white"];
    NFkB            [label="NF-κB\n(Transcription → cytokine production)", fillcolor="#6a2a2a", fontcolor="white"];
    LowGradeInflam  [label="Low-Grade Mucosal\nInflammation (IBS hallmark)", fillcolor="#7a2a2a", fontcolor="#ffaa44"];
  }

  // ================================================================
  // CLUSTER 9: Visceral Hypersensitivity & Pain
  // ================================================================
  subgraph cluster_Pain {
    label="Visceral Hypersensitivity & Pain Signaling";
    style=filled; fillcolor="#2a0505"; color="#ff4a4a"; fontcolor="white"; fontsize=13;

    ViscNoci     [label="Visceral Nociceptors\n(High-threshold AMH fibers)", fillcolor="#4a0a0a", fontcolor="white"];
    TRPV1        [label="TRPV1\n(Capsaicin/acid/heat sensor, ↑ in IBS)", fillcolor="#6a1a1a", fontcolor="#ffcc44"];
    TRPV4        [label="TRPV4\n(Osmotic/mechanical stretch)", fillcolor="#5a0a0a", fontcolor="white"];
    TRPA1        [label="TRPA1\n(Cold/reactive chemicals)", fillcolor="#5a0a0a", fontcolor="white"];
    P2X3_Pain    [label="P2X3\n(ATP purinergic receptor on afferents)", fillcolor="#5a0a0a", fontcolor="white"];
    SubP_Pain    [label="Substance P\n(NK1R → spinal sensitization)", fillcolor="#6a1a1a", fontcolor="white"];
    CGRP_Pain    [label="CGRP (Pain)\n(Vasodilation / neurogenic inflammation)", fillcolor="#5a0a0a", fontcolor="white"];
    BDNF_Pain    [label="BDNF\n(TrkB → peripheral sensitization)", fillcolor="#5a0a0a", fontcolor="white"];
    NGF_Pain     [label="NGF\n(Nerve Growth Factor, MC-derived)", fillcolor="#5a0a0a", fontcolor="white"];
    SpinalSens   [label="Spinal Cord Sensitization\n(WDR neurons)", fillcolor="#6a1a1a", fontcolor="#ffcc44"];
    WindUp       [label="Wind-Up\n(Repeated C-fiber → NMDA activation)", fillcolor="#5a0a0a", fontcolor="white"];
    NR2B_NMDA    [label="NR2B / NMDA\n(Glutamate → LTP of pain)", fillcolor="#5a0a0a", fontcolor="white"];
    MuOR         [label="μ-Opioid Receptor\n(Pain inhibition)", fillcolor="#4a0a0a", fontcolor="white"];
    KappaOR      [label="κ-Opioid Receptor\n(Visceral analgesia)", fillcolor="#4a0a0a", fontcolor="white"];
    DeltaOR      [label="δ-Opioid Receptor\n(Pain modulation)", fillcolor="#4a0a0a", fontcolor="white"];
    CentralSens  [label="Central Sensitization\n(Amplified pain response)", fillcolor="#7a2a2a", fontcolor="#ffcc44"];
    AllodyniaVis [label="Visceral Allodynia\n(Pain to normal distension)", fillcolor="#6a2a2a", fontcolor="white"];
    Hyperalgesia [label="Visceral Hyperalgesia\n(↑ pain to noxious stimuli)", fillcolor="#6a2a2a", fontcolor="white"];
    ATP_Release  [label="ATP Release\n(EC cells / mucosal distension)", fillcolor="#5a0a0a", fontcolor="white"];
  }

  // ================================================================
  // CLUSTER 10: Drug PK/PD
  // ================================================================
  subgraph cluster_Drug {
    label="Drug PK/PD — IBS Pharmacotherapy";
    style=filled; fillcolor="#001a2a"; color="#2a9aff"; fontcolor="white"; fontsize=13;

    // --- Alosetron (IBS-D) ---
    AloOral    [label="Alosetron\n0.5–1 mg BID (IBS-D)", fillcolor="#003a5a", fontcolor="#44ccff"];
    AloPlas    [label="Alosetron Plasma\nt½=1.5 h, F=60%, Vc=77 L", fillcolor="#004a6a", fontcolor="white"];
    AloPeriph  [label="Alosetron Peripheral\nCMT", fillcolor="#003a5a", fontcolor="white"];
    Alo5HT3    [label="5-HT3R Occupancy\n(IC50=1.6 nM, Kd=0.64 nM)", fillcolor="#004a6a", fontcolor="#44ccff"];

    // --- Linaclotide (IBS-C) ---
    LinaOral   [label="Linaclotide\n290 μg QD (IBS-C)", fillcolor="#003a5a", fontcolor="#44ccff"];
    LinaLumen  [label="Linaclotide Lumen\n(<2% systemic bioavailability)", fillcolor="#004a6a", fontcolor="white"];
    GCC_Act    [label="GC-C Receptor\nActivation (Guanylate Cyclase-C)", fillcolor="#004a6a", fontcolor="#44ccff"];
    cGMP_Lina  [label="cGMP↑ (intracellular)\nCFTR activation → Cl⁻/H2O secretion", fillcolor="#003a5a", fontcolor="white"];

    // --- Rifaximin (IBS-D/SIBO) ---
    RifaOral   [label="Rifaximin\n550 mg TID × 14 d", fillcolor="#003a5a", fontcolor="#44ccff"];
    RifaLumen  [label="Rifaximin Lumen\n<0.4% systemic, F~negligible", fillcolor="#004a6a", fontcolor="white"];
    RifaTarget [label="Rifaximin Target\n(RNA polymerase β-subunit)", fillcolor="#003a5a", fontcolor="white"];

    // --- Loperamide (IBS-D) ---
    LopeOral   [label="Loperamide\n2 mg PRN (IBS-D)", fillcolor="#003a5a", fontcolor="#44ccff"];
    LopePlas   [label="Loperamide Plasma\nt½=10 h, F=40%, BBB-excluded", fillcolor="#004a6a", fontcolor="white"];
    LopeMuOR   [label="μ-OR Agonism\n(Peripheral, gut wall)", fillcolor="#004a6a", fontcolor="#44ccff"];

    // --- Eluxadoline (IBS-D) ---
    EluxaOral  [label="Eluxadoline\n100 mg BID (IBS-D)", fillcolor="#003a5a", fontcolor="#44ccff"];
    EluxaTarget [label="μ + κ Agonist /\nδ Antagonist (ENS)", fillcolor="#004a6a", fontcolor="#44ccff"];

    // --- Lubiprostone (IBS-C) ---
    LubiOral   [label="Lubiprostone\n8 μg BID (IBS-C)", fillcolor="#003a5a", fontcolor="#44ccff"];
    LubiClC2   [label="ClC-2 Cl⁻ Channel\nActivation (apical membrane)", fillcolor="#004a6a", fontcolor="white"];

    // --- Tegaserod (IBS-C) ---
    TegaOral   [label="Tegaserod\n6 mg BID (IBS-C)", fillcolor="#003a5a", fontcolor="#44ccff"];
    TegaHT4    [label="5-HT4R Partial Agonism\n(EC50~45 nM, t½=11 h)", fillcolor="#004a6a", fontcolor="#44ccff"];

    // --- Amitriptyline (Low-dose TCA) ---
    TCA_Oral   [label="Amitriptyline\n10–75 mg QD (neuromodulator)", fillcolor="#003a5a", fontcolor="#44ccff"];
    TCA_SERT   [label="SERT + NET Inhibition\n(↑ synaptic 5-HT + NE)", fillcolor="#004a6a", fontcolor="white"];
    TCA_Ach    [label="Anticholinergic Effect\n(M1/M3 antagonism → ↓motility)", fillcolor="#003a5a", fontcolor="white"];

    // --- Citalopram/SSRI ---
    SSRI_Oral  [label="Citalopram 20 mg QD\n(SSRI, IBS-D)", fillcolor="#003a5a", fontcolor="#44ccff"];
    SSRI_SERT  [label="SERT Selective\nInhibition (→ ↑5-HT)", fillcolor="#004a6a", fontcolor="white"];

    // --- Pregabalin/Gabapentin ---
    Pregabalin [label="Pregabalin/Gabapentin\n(α2δ VGCC, visceral pain)", fillcolor="#003a5a", fontcolor="#44ccff"];
    PregaTarget [label="α2δ VGCC Subunit\n(Presynaptic Ca2+ → ↓SP/CGRP)", fillcolor="#004a6a", fontcolor="white"];
  }

  // ================================================================
  // CLUSTER 11: Gut Motility & IBS Subtypes
  // ================================================================
  subgraph cluster_Motility {
    label="Gut Motility Regulation & IBS Clinical Subtypes";
    style=filled; fillcolor="#1a1a00"; color="#aaaa2a"; fontcolor="white"; fontsize=13;

    ColonTransit  [label="Colonic Transit Time\n(CTT, Normal: 30–40 h)", fillcolor="#3a3a00", fontcolor="white"];
    SmIntTransit  [label="Small Intestinal\nTransit Time (SITT)", fillcolor="#3a3a00", fontcolor="white"];
    BristolScale  [label="Bristol Stool Form\nScale (BSFS 1–7)", fillcolor="#3a3a00", fontcolor="white"];
    IBSD_Type     [label="IBS-D\n(Diarrhea-Predominant)\nBSFS ≥6 >25% stools", fillcolor="#5a5a00", fontcolor="#ffff44"];
    IBSC_Type     [label="IBS-C\n(Constipation-Predominant)\nBSFS ≤2 >25% stools", fillcolor="#5a5a00", fontcolor="#ffff44"];
    IBSM_Type     [label="IBS-M\n(Mixed)\nBSFS alternating", fillcolor="#4a4a00", fontcolor="white"];
    IBSU_Type     [label="IBS-U\n(Unsubtyped)", fillcolor="#3a3a00", fontcolor="white"];
    MMC           [label="MMC Phase III\n(Migrating Motor Complex, interdigestive)", fillcolor="#3a3a00", fontcolor="white"];
    PostprandMot  [label="Gastrocolic Reflex\n(Postprandial motility ↑)", fillcolor="#3a3a00", fontcolor="white"];
    DefecReflex   [label="Defecation Reflex\n(Puborectalis / EAS / IAS)", fillcolor="#3a3a00", fontcolor="white"];
    SecretFunc    [label="Intestinal Secretion\n(Cl⁻/H2O balance → stool water)", fillcolor="#3a3a00", fontcolor="white"];
    MotilinR      [label="Motilin Receptor\n(Phase III MMC initiation)", fillcolor="#3a3a00", fontcolor="white"];
    GLP1_Mot      [label="GLP-1\n(Ileal brake → ↓gastric emptying)", fillcolor="#3a3a00", fontcolor="white"];
    PYY_Mot       [label="PYY 3-36\n(Ileal brake → ↓motility)", fillcolor="#3a3a00", fontcolor="white"];
  }

  // ================================================================
  // CLUSTER 12: Clinical Endpoints
  // ================================================================
  subgraph cluster_Endpoints {
    label="Clinical Endpoints & Outcome Measures";
    style=filled; fillcolor="#002a00"; color="#2aff4a"; fontcolor="white"; fontsize=13;

    AbdPain     [label="Abdominal Pain\n(NRS 0–10 / VAS)", fillcolor="#004a00", fontcolor="#44ff44"];
    Bloating    [label="Abdominal Bloating /\nDistension (NRS)", fillcolor="#003a00", fontcolor="white"];
    StoolFreq   [label="Stool Frequency\n(BM / week)", fillcolor="#003a00", fontcolor="white"];
    StoolConsist [label="Stool Consistency\n(BSFS score)", fillcolor="#003a00", fontcolor="white"];
    Urgency     [label="Fecal Urgency /\nIncomplete Evacuation", fillcolor="#003a00", fontcolor="white"];
    IBS_SSS     [label="IBS-SSS\n(Symptom Severity Score 0–500)", fillcolor="#005a00", fontcolor="#44ff44"];
    IBS_QoL     [label="IBS-QoL\n(34-item quality of life)", fillcolor="#005a00", fontcolor="#44ff44"];
    ROME4       [label="ROME IV Criteria\n(Recurrent pain ≥1d/wk × 3 mo)", fillcolor="#004a00", fontcolor="white"];
    GAR         [label="Global Assessment\nof Relief (GAR)", fillcolor="#003a00", fontcolor="white"];
    WorkProd    [label="Work Productivity\n(WPAI-IBS)", fillcolor="#003a00", fontcolor="white"];
    Responder   [label="Responder Definition\n(≥30% pain + ≥50% SSS reduction)", fillcolor="#005a00", fontcolor="#44ff44"];
    FlareUp     [label="Symptom Flare\n(Stress-induced exacerbation)", fillcolor="#003a00", fontcolor="white"];
    PI_IBS      [label="PI-IBS\n(Post-Infectious, worse prognosis)", fillcolor="#003a00", fontcolor="white"];
    Biomarkers  [label="Biomarkers\n(Fecal calprotectin, bile acid, tryptophan)", fillcolor="#003a00", fontcolor="white"];
  }

