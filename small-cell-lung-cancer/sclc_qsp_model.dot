digraph SCLC_QSP {
  graph [
    label="Small Cell Lung Cancer (SCLC) — QSP Mechanistic Map\nNeuroendocrine subtype biology · DNA damage response · Immune checkpoints · Drug PK/PD"
    labelloc=t fontname="Helvetica" fontsize=18
    bgcolor="#FAFAFA" rankdir=LR
    splines=ortho nodesep=0.5 ranksep=1.2
    compound=true
  ]
  node [fontname="Helvetica" fontsize=11 style="filled,rounded" shape=box]
  edge [fontname="Helvetica" fontsize=9 arrowsize=0.7]

  /* ============================================================
     CLUSTER 1: Genetic Alterations / Tumor Suppressors
  ============================================================ */
  subgraph cluster_genetics {
    label="Genetic Alterations" bgcolor="#FFE8E8"
    fontname="Helvetica" fontsize=13 color="#CC0000" style="rounded,filled"

    TP53      [label="TP53\n(90% loss)" fillcolor="#FF6B6B" fontcolor=white]
    RB1       [label="RB1\n(>85% loss)" fillcolor="#FF6B6B" fontcolor=white]
    CREBBP    [label="CREBBP/EP300\n(HAT loss)" fillcolor="#FF9999"]
    MYC       [label="MYC\n(amplification)" fillcolor="#FF4444" fontcolor=white]
    MYCL      [label="MYCL\n(amplification)" fillcolor="#FF6666" fontcolor=white]
    MYCN      [label="MYCN\n(amplification)" fillcolor="#FF8888"]
    PTEN_mut  [label="PTEN\n(loss/mut)" fillcolor="#FFB3B3"]
    SOX2_amp  [label="SOX2\n(amplification)" fillcolor="#FFB3B3"]
    FGFR1_amp [label="FGFR1\n(amplification)" fillcolor="#FFCCCC"]
    PIK3CA_mut[label="PIK3CA\n(mutation)" fillcolor="#FFCCCC"]
  }

  /* ============================================================
     CLUSTER 2: Neuroendocrine Subtype Transcription Factors
  ============================================================ */
  subgraph cluster_subtypes {
    label="Neuroendocrine Subtypes" bgcolor="#E8F5E9"
    fontname="Helvetica" fontsize=13 color="#2E7D32" style="rounded,filled"

    ASCL1     [label="ASCL1\n(NE-high subtype)" fillcolor="#4CAF50" fontcolor=white]
    NEUROD1   [label="NEUROD1\n(NE-high variant)" fillcolor="#66BB6A" fontcolor=white]
    YAP1      [label="YAP1\n(NE-low subtype)" fillcolor="#A5D6A7"]
    POU2F3    [label="POU2F3\n(tuft cell-like)" fillcolor="#C8E6C9"]
    REST      [label="REST\n(repressor)" fillcolor="#81C784"]
    INSM1     [label="INSM1\n(NE marker)" fillcolor="#A5D6A7"]
    CHGA      [label="CgA\n(NE secretory)" fillcolor="#C8E6C9"]
    SYP       [label="Synaptophysin\n(NE marker)" fillcolor="#C8E6C9"]
    CD56      [label="CD56/NCAM\n(NE marker)" fillcolor="#DCEDC8"]
    DLL3_NE   [label="DLL3\n(NE-restricted)" fillcolor="#4CAF50" fontcolor=white]
  }

  /* ============================================================
     CLUSTER 3: DLL3/Notch Signaling
  ============================================================ */
  subgraph cluster_dll3_notch {
    label="DLL3/Notch Pathway" bgcolor="#E3F2FD"
    fontname="Helvetica" fontsize=13 color="#1565C0" style="rounded,filled"

    DLL3_surf [label="DLL3 Surface\n(aberrant ligand)" fillcolor="#1E88E5" fontcolor=white]
    DLL1      [label="DLL1/4\n(canonical)" fillcolor="#90CAF9"]
    Notch1    [label="Notch1" fillcolor="#64B5F6"]
    Notch2    [label="Notch2" fillcolor="#64B5F6"]
    Notch3    [label="Notch3" fillcolor="#64B5F6"]
    NICD      [label="NICD\n(cleaved)" fillcolor="#42A5F5"]
    HES1      [label="HES1\n(repressor)" fillcolor="#90CAF9"]
    HEY1      [label="HEY1" fillcolor="#BBDEFB"]
    ADAM10    [label="ADAM10\n(sheddase)" fillcolor="#BBDEFB"]
    gamma_sec [label="γ-Secretase\n(PSEN1/2)" fillcolor="#BBDEFB"]
    Dll3_inh  [label="DLL3-Notch\nInhibition" fillcolor="#1565C0" fontcolor=white shape=diamond]
  }

  /* ============================================================
     CLUSTER 4: DNA Damage Response
  ============================================================ */
  subgraph cluster_ddr {
    label="DNA Damage Response" bgcolor="#FFF3E0"
    fontname="Helvetica" fontsize=13 color="#E65100" style="rounded,filled"

    DSB       [label="DSBs\n(double-strand breaks)" fillcolor="#FF8F00" fontcolor=white]
    SSB       [label="SSBs\n(single-strand breaks)" fillcolor="#FFA726"]
    ATM_node  [label="ATM\nkinase" fillcolor="#FF6F00" fontcolor=white]
    ATR_node  [label="ATR\nkinase" fillcolor="#FF8F00" fontcolor=white]
    CHEK1     [label="CHK1\n(S-phase arrest)" fillcolor="#FFB74D"]
    CHEK2     [label="CHK2\n(G1/G2 arrest)" fillcolor="#FFB74D"]
    PARP1     [label="PARP1\n(SSB repair)" fillcolor="#FFA000" fontcolor=white]
    p21_waf   [label="p21/WAF1\n(CDK inhibitor)" fillcolor="#FFCC80"]
    H2AX      [label="γH2AX\n(DSB marker)" fillcolor="#FFCC80"]
    RAD51     [label="RAD51\n(HR repair)" fillcolor="#FFE082"]
    TOP2      [label="Topoisomerase II\n(target)" fillcolor="#FFA726"]
    Topo_inh  [label="Topo-II\nPoison Effect" fillcolor="#E65100" fontcolor=white shape=diamond]
  }

  /* ============================================================
     CLUSTER 5: Cell Cycle Regulation
  ============================================================ */
  subgraph cluster_cellcycle {
    label="Cell Cycle" bgcolor="#F3E5F5"
    fontname="Helvetica" fontsize=13 color="#6A1B9A" style="rounded,filled"

    G1_phase  [label="G1 Phase" fillcolor="#CE93D8"]
    S_phase   [label="S Phase" fillcolor="#BA68C8"]
    G2M_phase [label="G2/M Phase" fillcolor="#AB47BC"]
    CDK4_6    [label="CDK4/6\n(G1 progression)" fillcolor="#9C27B0" fontcolor=white]
    CyclinD   [label="Cyclin D" fillcolor="#CE93D8"]
    CDK2      [label="CDK2" fillcolor="#BA68C8"]
    CyclinE   [label="Cyclin E" fillcolor="#CE93D8"]
    RB_phos   [label="Rb phosphorylation\n(inactivation)" fillcolor="#E1BEE7"]
    E2F_act   [label="E2F activation\n(proliferation)" fillcolor="#D1C4E9"]
    CDK4_6i   [label="CDK4/6 inhibition\n(trilaciclib)" fillcolor="#6A1B9A" fontcolor=white shape=diamond]
    Mitosis   [label="Mitosis\n(cell division)" fillcolor="#9C27B0" fontcolor=white]
    Apoptosis [label="Apoptosis\n(cell death)" fillcolor="#7B1FA2" fontcolor=white]
  }

  /* ============================================================
     CLUSTER 6: Immune Landscape & Checkpoints
  ============================================================ */
  subgraph cluster_immune {
    label="Tumor Immune Microenvironment" bgcolor="#E0F7FA"
    fontname="Helvetica" fontsize=13 color="#006064" style="rounded,filled"

    CD8T      [label="CD8+ T cells\n(effector)" fillcolor="#00ACC1" fontcolor=white]
    CD4T      [label="CD4+ Th cells" fillcolor="#26C6DA"]
    Treg      [label="Tregs\n(suppressive)" fillcolor="#80DEEA"]
    NK_cell   [label="NK cells" fillcolor="#00BCD4" fontcolor=white]
    DC        [label="Dendritic cells\n(APCs)" fillcolor="#4DD0E1"]
    Macro_M1  [label="M1 Macrophage\n(pro-inflam)" fillcolor="#26C6DA"]
    Macro_M2  [label="M2 Macrophage\n(immunosuppressive)" fillcolor="#80DEEA"]
    MDSC      [label="MDSCs\n(suppressive)" fillcolor="#80DEEA"]
    PD1       [label="PD-1\n(CD8/CD4)" fillcolor="#00838F" fontcolor=white]
    PDL1      [label="PD-L1\n(tumor/macro)" fillcolor="#00838F" fontcolor=white]
    TIGIT     [label="TIGIT\n(coinhibitory)" fillcolor="#0097A7" fontcolor=white]
    CD155     [label="CD155/PVR\n(TIGIT ligand)" fillcolor="#4DD0E1"]
    CD47      [label="CD47\n('don't eat me')" fillcolor="#26C6DA"]
    SIRPa     [label="SIRPα\n(macrophage)" fillcolor="#4DD0E1"]
    MHC1      [label="MHC-I\n(antigen pres.)" fillcolor="#26C6DA"]
    IFNg      [label="IFN-γ" fillcolor="#00BCD4" fontcolor=white]
    TMB       [label="Tumor Mutational\nBurden (TMB)" fillcolor="#80DEEA"]
    Checkpoint[label="Checkpoint Block\n(PD-1/PD-L1)" fillcolor="#006064" fontcolor=white shape=diamond]
  }

  /* ============================================================
     CLUSTER 7: Intracellular Signaling
  ============================================================ */
  subgraph cluster_signaling {
    label="Intracellular Signaling" bgcolor="#FBE9E7"
    fontname="Helvetica" fontsize=13 color="#BF360C" style="rounded,filled"

    PI3K      [label="PI3K" fillcolor="#FF7043" fontcolor=white]
    AKT       [label="AKT" fillcolor="#FF5722" fontcolor=white]
    mTOR      [label="mTOR" fillcolor="#E64A19" fontcolor=white]
    MAPK      [label="MAPK/ERK" fillcolor="#FF7043" fontcolor=white]
    MEK       [label="MEK" fillcolor="#FF8A65"]
    STAT3     [label="STAT3" fillcolor="#FFAB91"]
    BCL2      [label="BCL-2\n(anti-apoptotic)" fillcolor="#FF5722" fontcolor=white]
    BCL_XL    [label="BCL-XL" fillcolor="#FF7043" fontcolor=white]
    MCL1      [label="MCL-1" fillcolor="#FF8A65"]
    Bax       [label="Bax/Bak\n(pro-apoptotic)" fillcolor="#FFAB91"]
    Caspase   [label="Caspase cascade" fillcolor="#BF360C" fontcolor=white]
    VEGF      [label="VEGF\n(angiogenesis)" fillcolor="#FFCCBC"]
    FGFR      [label="FGFR1\n(proliferation)" fillcolor="#FFAB91"]
  }

  /* ============================================================
     CLUSTER 8: Drug PK — Immunotherapy
  ============================================================ */
  subgraph cluster_pk_io {
    label="Immunotherapy PK" bgcolor="#E8EAF6"
    fontname="Helvetica" fontsize=13 color="#283593" style="rounded,filled"

    Atezo_dose[label="Atezolizumab\n1200 mg q3w iv" fillcolor="#5C6BC0" fontcolor=white shape=cylinder]
    Atezo_C   [label="Atezolizumab\nCentral (Cc)" fillcolor="#7986CB" fontcolor=white]
    Atezo_P   [label="Atezolizumab\nPeripheral (Cp)" fillcolor="#9FA8DA"]
    Durva_dose[label="Durvalumab\n1500 mg q4w iv" fillcolor="#3949AB" fontcolor=white shape=cylinder]
    Durva_C   [label="Durvalumab\nCentral (Cc)" fillcolor="#5C6BC0" fontcolor=white]
    Tarlat_dose[label="Tarlatamab\n10 mg q2w iv" fillcolor="#1A237E" fontcolor=white shape=cylinder]
    Tarlat_C  [label="Tarlatamab\nCentral" fillcolor="#283593" fontcolor=white]
    Tarlat_T  [label="Tarlatamab\nTumor compt." fillcolor="#303F9F" fontcolor=white]
    Tarlat_P  [label="Tarlatamab\nPeripheral" fillcolor="#3949AB" fontcolor=white]
    Atezo_RO  [label="PD-L1 Receptor\nOccupancy" fillcolor="#5C6BC0" fontcolor=white]
    Durva_RO  [label="PD-L1 Receptor\nOccupancy" fillcolor="#3949AB" fontcolor=white]
  }

  /* ============================================================
     CLUSTER 9: Drug PK — Chemotherapy & Small Molecules
  ============================================================ */
  subgraph cluster_pk_chemo {
    label="Chemotherapy & Small Molecule PK" bgcolor="#F9FBE7"
    fontname="Helvetica" fontsize=13 color="#558B2F" style="rounded,filled"

    Carbo_dose [label="Carboplatin\nAUC5-6 q3w iv" fillcolor="#689F38" fontcolor=white shape=cylinder]
    Carbo_C    [label="Carboplatin\nPlasma (Cc)" fillcolor="#7CB342" fontcolor=white]
    Etop_dose  [label="Etoposide\n100 mg/m² d1-3" fillcolor="#33691E" fontcolor=white shape=cylinder]
    Etop_C     [label="Etoposide\nCentral" fillcolor="#558B2F" fontcolor=white]
    Etop_T     [label="Etoposide\nTumor" fillcolor="#689F38" fontcolor=white]
    Lurbi_dose [label="Lurbinectedin\n3.2 mg/m² q3w iv" fillcolor="#827717" fontcolor=white shape=cylinder]
    Lurbi_C    [label="Lurbinectedin\nPlasma" fillcolor="#9E9D24" fontcolor=white]
    Topo_dose  [label="Topotecan\n1.5 mg/m² d1-5" fillcolor="#F57F17" fontcolor=white shape=cylinder]
    Topo_C     [label="Topotecan\nCentral" fillcolor="#F9A825" fontcolor=white]
    Trila_dose [label="Trilaciclib\n240 mg/m² iv" fillcolor="#E65100" fontcolor=white shape=cylinder]
    Trila_C    [label="Trilaciclib\nPlasma" fillcolor="#EF6C00" fontcolor=white]
    Nivo_dose  [label="Nivolumab\n360 mg q3w iv" fillcolor="#4E342E" fontcolor=white shape=cylinder]
    Nivo_C     [label="Nivolumab\nCentral (Cc)" fillcolor="#6D4C41" fontcolor=white]
  }

  /* ============================================================
     CLUSTER 10: Tumor Dynamics & Clinical Endpoints
  ============================================================ */
  subgraph cluster_clinical {
    label="Tumor Dynamics & Clinical Endpoints" bgcolor="#ECEFF1"
    fontname="Helvetica" fontsize=13 color="#263238" style="rounded,filled"

    Tumor_prol [label="Proliferating\nTumor Cells" fillcolor="#455A64" fontcolor=white]
    Tumor_arr  [label="G1-arrested\nTumor Cells" fillcolor="#607D8B" fontcolor=white]
    Tumor_apop [label="Apoptotic\nCells" fillcolor="#78909C"]
    Tumor_res  [label="Resistant\nTumor Cells" fillcolor="#263238" fontcolor=white]
    Tumor_Burd [label="Tumor Burden\n(SLD, cm)" fillcolor="#37474F" fontcolor=white]
    ORR        [label="ORR\n(%)" fillcolor="#546E7A"]
    PFS        [label="PFS\n(median months)" fillcolor="#607D8B"]
    OS         [label="OS\n(median months)" fillcolor="#263238" fontcolor=white]
    ECOG       [label="ECOG PS" fillcolor="#78909C"]
    LDH        [label="LDH\n(biomarker)" fillcolor="#90A4AE"]
    NSE        [label="NSE\n(NE biomarker)" fillcolor="#90A4AE"]
    ProGRP     [label="ProGRP\n(NE biomarker)" fillcolor="#B0BEC5"]
    BM_meta    [label="Brain Mets\n(CNS)" fillcolor="#607D8B"]
  }

  /* ============================================================
     CLUSTER 11: Bone Marrow & Myeloprotection
  ============================================================ */
  subgraph cluster_bm {
    label="Bone Marrow & Myeloprotection" bgcolor="#FFF8E1"
    fontname="Helvetica" fontsize=13 color="#F57F17" style="rounded,filled"

    HSC       [label="Hematopoietic\nStem Cells" fillcolor="#FFB300" fontcolor=white]
    Neutro_pre[label="Neutrophil\nPrecursors" fillcolor="#FFC107" fontcolor=white]
    Neutro    [label="Neutrophils\n(ANC)" fillcolor="#FFCA28"]
    Lympho    [label="Lymphocytes\n(ALC)" fillcolor="#FFD54F"]
    Platelet  [label="Platelets" fillcolor="#FFE082"]
    G_CSF     [label="G-CSF\n(support)" fillcolor="#FFB300" fontcolor=white]
    Febrile_N [label="Febrile\nNeutropenia" fillcolor="#FF8F00" fontcolor=white]
    Trila_prot[label="Trilaciclib\nMyeloprotection" fillcolor="#E65100" fontcolor=white shape=diamond]
  }

  /* ============================================================
     CLUSTER 12: SCLC Subtypes & Plasticity
  ============================================================ */
  subgraph cluster_plasticity {
    label="Subtype Plasticity & Resistance" bgcolor="#FCE4EC"
    fontname="Helvetica" fontsize=13 color="#880E4F" style="rounded,filled"

    NE_high   [label="NE-high\n(ASCL1/NEUROD1)" fillcolor="#E91E63" fontcolor=white]
    NE_low    [label="NE-low\n(YAP1/POU2F3)" fillcolor="#F06292"]
    Infl_sub  [label="Inflamed\nSubtype" fillcolor="#F48FB1"]
    Desert_sub[label="Desert\n(immune excluded)" fillcolor="#FCE4EC" color="#880E4F"]
    Lineage_sw[label="Lineage\nSwitching" fillcolor="#C2185B" fontcolor=white]
    EMT_sclc  [label="Epithelial-\nMesenchymal\nTransition" fillcolor="#AD1457" fontcolor=white]
    Chemo_res [label="Chemo\nResistance" fillcolor="#880E4F" fontcolor=white]
    IO_res    [label="IO\nResistance" fillcolor="#880E4F" fontcolor=white]
  }

  /* ============================================================
     EDGES — Genetic Alterations → Downstream
  ============================================================ */
  TP53      -> Apoptosis    [label="loss\n→ evasion" color="#CC0000" style=dashed arrowhead=tee]
  TP53      -> G2M_phase    [label="G2/M\ncheckpoint ↓" color="#CC0000" style=dashed arrowhead=tee]
  RB1       -> E2F_act      [label="Rb loss\n→ E2F free" color="#CC0000" style=dashed]
  RB1       -> CDK4_6       [label="Rb loss\nunrestricted" color="#CC0000" style=dashed arrowhead=tee]
  MYC       -> ASCL1        [label="drives NE\nphenotype" color="#FF4444"]
  MYC       -> Tumor_prol   [label="↑ proliferation" color="#FF4444"]
  MYCL      -> DLL3_NE      [label="↑ DLL3" color="#FF6666"]
  CREBBP    -> ASCL1        [label="epigenetic\nregulation" color="#FF9999"]
  SOX2_amp  -> ASCL1        [label="co-activates" color="#FF9999"]
  PIK3CA_mut -> PI3K        [label="constitutive" color="#FFCCCC"]
  PTEN_mut  -> PI3K         [label="PTEN loss\n→ PI3K ↑" color="#FFCCCC" style=dashed arrowhead=tee]

  /* ============================================================
     EDGES — Neuroendocrine Subtypes
  ============================================================ */
  ASCL1     -> DLL3_NE      [label="drives\nDLL3 expr." color="#2E7D32"]
  ASCL1     -> INSM1        [color="#2E7D32"]
  ASCL1     -> CHGA         [color="#2E7D32"]
  ASCL1     -> SYP          [color="#2E7D32"]
  ASCL1     -> NE_high      [color="#2E7D32" style=bold]
  NEUROD1   -> NE_high      [color="#4CAF50" style=bold]
  NEUROD1   -> MYC          [label="↑ MYCN" color="#66BB6A"]
  YAP1      -> NE_low       [color="#A5D6A7" style=bold]
  POU2F3    -> NE_low       [color="#C8E6C9" style=bold]
  REST      -> ASCL1        [label="represses\nNE program" color="#81C784" arrowhead=tee]
  DLL3_NE   -> DLL3_surf    [label="surface\ntrafficking" color="#4CAF50"]
  NE_high   -> Infl_sub     [label="some cases" color="#E91E63" style=dashed]
  NE_low    -> Desert_sub   [color="#F06292" style=dashed]

  /* ============================================================
     EDGES — DLL3/Notch
  ============================================================ */
  DLL3_surf -> Dll3_inh     [color="#1E88E5" arrowhead=none]
  DLL1      -> Notch1       [label="canonical\ntrans-act." color="#64B5F6"]
  DLL1      -> Notch2       [color="#64B5F6"]
  DLL3_surf -> Notch1       [label="inhibits in\ncis" color="#1E88E5" arrowhead=tee style=dashed]
  Notch1    -> ADAM10       [color="#90CAF9"]
  ADAM10    -> gamma_sec    [color="#BBDEFB"]
  gamma_sec -> NICD         [label="cleavage\n→ NICD" color="#42A5F5"]
  NICD      -> HES1         [color="#42A5F5"]
  NICD      -> HEY1         [color="#42A5F5"]
  HES1      -> ASCL1        [label="represses" color="#90CAF9" arrowhead=tee]
  DLL3_surf -> REST         [label="maintains\nNE identity" color="#1E88E5" arrowhead=tee]

  /* ============================================================
     EDGES — DNA Damage Response
  ============================================================ */
  Carbo_C   -> DSB          [label="DNA\ncrosslinking" color="#33691E"]
  Etop_T    -> Topo_inh     [color="#558B2F" arrowhead=none]
  Topo_inh  -> TOP2         [label="poison\ntrap" color="#558B2F"]
  TOP2      -> DSB          [label="stalled\ntopoisomerase" color="#FF8F00"]
  Lurbi_C   -> DSB          [label="alkylates\nDNA" color="#9E9D24"]
  Topo_C    -> SSB          [label="TOP1\npoison" color="#F9A825"]
  DSB       -> ATM_node     [color="#FF6F00"]
  SSB       -> ATR_node     [color="#FF8F00"]
  ATM_node  -> CHEK2        [color="#FFB74D"]
  ATR_node  -> CHEK1        [color="#FFB74D"]
  CHEK1     -> S_phase      [label="arrest" color="#FFB74D" arrowhead=tee]
  CHEK2     -> G1_phase     [label="arrest" color="#FFB74D" arrowhead=tee]
  CHEK2     -> p21_waf      [color="#FFCC80"]
  ATM_node  -> H2AX         [color="#FFCC80"]
  DSB       -> RAD51        [label="HR repair" color="#FFE082"]
  SSB       -> PARP1        [label="SSB repair" color="#FFA000"]
  PARP1     -> Apoptosis    [label="high\ndamage → death" color="#FFA000" style=dashed]
  DSB       -> Apoptosis    [label="lethal\ndamage" color="#FF6F00" style=bold]
  p21_waf   -> CDK4_6       [label="inhibits" color="#FFCC80" arrowhead=tee]

  /* ============================================================
     EDGES — Cell Cycle
  ============================================================ */
  CDK4_6    -> RB_phos      [color="#9C27B0"]
  CyclinD   -> CDK4_6       [label="activates" color="#CE93D8"]
  RB_phos   -> E2F_act      [label="releases E2F" color="#E1BEE7"]
  E2F_act   -> S_phase      [label="G1→S\ntransition" color="#D1C4E9"]
  CDK2      -> S_phase      [color="#BA68C8"]
  CyclinE   -> CDK2         [color="#CE93D8"]
  S_phase   -> G2M_phase    [color="#AB47BC"]
  G2M_phase -> Mitosis      [color="#9C27B0"]
  Mitosis   -> G1_phase     [label="daughter\ncells" color="#CE93D8"]
  Mitosis   -> Tumor_prol   [label="↑ tumor\ncells" color="#9C27B0"]
  CDK4_6i   -> CDK4_6       [label="block" color="#6A1B9A" arrowhead=tee style=bold]
  CDK4_6i   -> G1_phase     [label="→ G1\narrest" color="#6A1B9A" style=bold]
  CDK4_6i   -> HSC          [label="protects\nfrom chemo" color="#6A1B9A" style=bold]
  G1_phase  -> Tumor_arr    [color="#9C27B0"]

  /* ============================================================
     EDGES — Signaling
  ============================================================ */
  PI3K      -> AKT          [color="#FF7043"]
  AKT       -> mTOR         [color="#FF5722"]
  AKT       -> BCL2         [label="↑ survival" color="#FF5722"]
  AKT       -> MCL1         [color="#FF5722"]
  mTOR      -> Tumor_prol   [label="↑ growth" color="#E64A19"]
  MAPK      -> Tumor_prol   [color="#FF7043"]
  MEK       -> MAPK         [color="#FF8A65"]
  FGFR      -> MEK          [color="#FFAB91"]
  STAT3     -> BCL_XL       [label="↑ survival" color="#FFAB91"]
  STAT3     -> MCL1         [color="#FFAB91"]
  IFNg      -> STAT3        [label="JAK/STAT" color="#00BCD4"]
  BCL2      -> Apoptosis    [label="inhibits" color="#FF5722" arrowhead=tee]
  BCL_XL    -> Apoptosis    [label="inhibits" color="#FF7043" arrowhead=tee]
  Bax       -> Caspase      [label="MOMP" color="#FFAB91"]
  Caspase   -> Apoptosis    [label="executes" color="#BF360C"]
  VEGF      -> DC           [label="↓ DC\nmaturation" color="#FFCCBC" arrowhead=tee]

  /* ============================================================
     EDGES — Immune TME
  ============================================================ */
  MHC1      -> CD8T         [label="Ag presentation\n→ activation" color="#006064"]
  IFNg      -> MHC1         [label="↑ MHC-I" color="#00BCD4"]
  IFNg      -> PDL1         [label="IFN-γ\n→ PDL1 ↑" color="#00BCD4"]
  CD8T      -> IFNg         [label="secretes" color="#00ACC1"]
  CD8T      -> Tumor_apop   [label="cytotoxic\nkilling" color="#00ACC1" style=bold]
  NK_cell   -> Tumor_apop   [label="ADCC /\nnon-MHC" color="#00BCD4"]
  PDL1      -> PD1          [label="ligates\n→ exhaustion" color="#006064"]
  PD1       -> CD8T         [label="inhibits" color="#006064" arrowhead=tee]
  TIGIT     -> CD155        [label="ligates" color="#0097A7"]
  CD155     -> TIGIT        [label="TIGIT\nactivation" color="#0097A7"]
  TIGIT     -> CD8T         [label="inhibits" color="#0097A7" arrowhead=tee]
  CD47      -> SIRPa        [label="'don't eat\nme' signal" color="#26C6DA"]
  SIRPa     -> Macro_M1     [label="inhibits\nphagocytosis" color="#26C6DA" arrowhead=tee]
  Macro_M2  -> Tumor_prol   [label="tumor\npromotion" color="#80DEEA"]
  MDSC      -> CD8T         [label="suppresses" color="#80DEEA" arrowhead=tee]
  Treg      -> CD8T         [label="suppresses" color="#80DEEA" arrowhead=tee]
  Checkpoint -> PD1         [label="block" color="#006064" arrowhead=tee style=bold]
  Checkpoint -> TIGIT       [label="block" color="#006064" arrowhead=tee style=bold]
  TMB       -> CD8T         [label="neoantigen\nload" color="#80DEEA"]

  /* ============================================================
     EDGES — Immunotherapy PK → PD
  ============================================================ */
  Atezo_dose -> Atezo_C     [label="iv infusion" color="#5C6BC0"]
  Atezo_C   -> Atezo_P      [label="distribution" color="#7986CB"]
  Atezo_P   -> Atezo_C      [label="redistribution" color="#9FA8DA"]
  Atezo_C   -> Atezo_RO     [label="binds\nPD-L1" color="#5C6BC0"]
  Atezo_RO  -> Checkpoint   [label="RO → PD/PD" color="#283593" style=bold]
  Durva_dose -> Durva_C     [color="#3949AB"]
  Durva_C   -> Durva_RO     [label="binds\nPD-L1" color="#3949AB"]
  Durva_RO  -> Checkpoint   [color="#283593" style=bold]
  Tarlat_dose -> Tarlat_C   [color="#1A237E"]
  Tarlat_C  -> Tarlat_T     [label="tumor\ndistribution" color="#283593"]
  Tarlat_C  -> Tarlat_P     [label="peripheral" color="#303F9F"]
  Tarlat_T  -> Dll3_inh     [label="bispecific\nT-cell engager" color="#1A237E" style=bold]
  Dll3_inh  -> DLL3_surf    [label="blocks\nDLL3" color="#1A237E" arrowhead=tee]
  Dll3_inh  -> CD8T         [label="recruit T\ncells to tumor" color="#1A237E" style=bold]
  Nivo_dose -> Nivo_C       [color="#6D4C41"]
  Nivo_C    -> Checkpoint   [label="PD-1 block" color="#4E342E" style=bold]

  /* ============================================================
     EDGES — Chemotherapy PK → PD
  ============================================================ */
  Carbo_dose -> Carbo_C     [label="iv infusion" color="#689F38"]
  Carbo_C   -> DSB          [color="#558B2F"]
  Etop_dose -> Etop_C       [color="#33691E"]
  Etop_C    -> Etop_T       [label="tumor\ndistribution" color="#558B2F"]
  Etop_T    -> Topo_inh     [color="#558B2F"]
  Lurbi_dose -> Lurbi_C     [color="#827717"]
  Lurbi_C   -> DSB          [color="#9E9D24"]
  Lurbi_C   -> Macro_M2     [label="reprograms\nTME" color="#827717" style=dashed]
  Topo_dose -> Topo_C       [color="#F57F17"]
  Topo_C    -> SSB          [color="#F9A825"]
  Trila_dose -> Trila_C     [color="#E65100"]
  Trila_C   -> CDK4_6i      [label="CDK4/6\ninhibition" color="#EF6C00" style=bold]

  /* ============================================================
     EDGES — Bone Marrow
  ============================================================ */
  HSC       -> Neutro_pre   [color="#FFB300"]
  Neutro_pre -> Neutro      [color="#FFC107"]
  HSC       -> Lympho       [color="#FFB300"]
  HSC       -> Platelet     [color="#FFB300"]
  Carbo_C   -> HSC          [label="myelosuppression" color="#689F38" arrowhead=tee]
  Etop_C    -> HSC          [label="myelosuppression" color="#558B2F" arrowhead=tee]
  Topo_C    -> HSC          [label="myelosuppression" color="#F9A825" arrowhead=tee]
  Trila_prot -> HSC         [label="protects\nHSC" color="#E65100" style=bold]
  CDK4_6i   -> Trila_prot   [color="#6A1B9A"]
  Neutro    -> Febrile_N    [label="ANC<500\n→ risk" color="#FFCA28" style=dashed]
  G_CSF     -> Neutro_pre   [label="stimulates" color="#FFB300"]

  /* ============================================================
     EDGES — Tumor Dynamics → Clinical
  ============================================================ */
  Tumor_prol -> Tumor_Burd  [label="↑ SLD" color="#455A64"]
  Tumor_arr  -> Tumor_Burd  [label="reduces\ngrowth" color="#607D8B" arrowhead=tee]
  Tumor_apop -> Tumor_Burd  [label="cell death\n→ ↓ SLD" color="#78909C" arrowhead=tee]
  Tumor_res  -> Tumor_Burd  [label="escapes Rx" color="#263238"]
  Tumor_Burd -> ORR         [label="RECIST\nresponse" color="#546E7A"]
  Tumor_Burd -> PFS         [label="TTP\nprogression" color="#607D8B"]
  PFS        -> OS          [label="post-progression\nsurvival" color="#263238"]
  LDH        -> OS          [label="prognostic" color="#90A4AE"]
  NSE        -> Tumor_prol  [label="correlates" color="#90A4AE"]
  ProGRP     -> NE_high     [label="NE marker" color="#B0BEC5"]
  BM_meta    -> OS          [label="↓ OS" color="#607D8B"]
  Chemo_res  -> Tumor_res   [color="#880E4F"]
  IO_res     -> Tumor_res   [color="#880E4F"]
  Lineage_sw -> NE_low      [label="resistance\nmechanism" color="#C2185B" style=dashed]
  EMT_sclc   -> IO_res      [color="#AD1457" style=dashed]
  Apoptosis  -> Tumor_apop  [color="#7B1FA2"]
  CD8T       -> IO_res      [label="exhaustion\n→ resistance" color="#006064" style=dashed]

  /* ============================================================
     EDGES — Inter-cluster
  ============================================================ */
  Atezo_RO  -> PDL1         [label="block" color="#5C6BC0" arrowhead=tee]
  Durva_RO  -> PDL1         [label="block" color="#3949AB" arrowhead=tee]
  CD8T      -> Chemo_res    [label="prevent\nresistance" color="#00ACC1" arrowhead=tee]
  Tumor_prol -> PDL1        [label="↑ PD-L1\non tumor" color="#455A64"]
  IFNg      -> CHGA         [label="NE marker\nregulation" color="#00BCD4" style=dashed]
  BM_meta   -> ECOG         [label="impairs PS" color="#607D8B"]
  Tumor_Burd -> ECOG        [label="tumor\nburden effect" color="#546E7A"]
  Trila_C   -> Lympho       [label="preserves\nALC" color="#EF6C00" style=dashed]
  Neutro    -> ECOG         [label="ANC affects\nperformance" color="#FFCA28" style=dashed]
}
