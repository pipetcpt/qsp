  CENT_BRAF -> BRAF_V600K [arrowhead=tee, color="#1565C0"];
  CENT_BRAF -> CRAF [color="#FF6F00", style=dashed];

  // MEKi → MEK inhibition
  CENT_MEK -> MEK1 [arrowhead=tee, color="#2E7D32", style=bold];
  CENT_MEK -> MEK2 [arrowhead=tee, color="#2E7D32", style=bold];

  // ERK → transcription factors
  ERK_nuc -> MITF;
