digraph Melanoma_QSP {
  rankdir=LR;
  splines=ortho;
  nodesep=0.35;
  ranksep=1.0;
  fontname="Helvetica";
  node [fontname="Helvetica", fontsize=9, style=filled, shape=box, margin="0.08,0.04"];
  edge [fontsize=7, arrowsize=0.55];

  /* =====================================================================
     CLUSTER 0: BRAF Inhibitor PK
     ===================================================================== */
  subgraph cluster_braf_pk {
    label="BRAF Inhibitor PK\n(Vemurafenib / Dabrafenib)";
    style=filled; fillcolor="#E3F2FD"; color="#1565C0"; fontsize=10;

    DOSE_BRAF [label="BRAF Inhibitor\nDose\n(960mg BID / 150mg BID)", fillcolor="#90CAF9", shape=parallelogram];
    GUT_BRAF [label="GUT_BRAF\nGI Absorption\nCmpt", fillcolor="#BBDEFB"];
    CENT_BRAF [label="CENT_BRAF\nPlasma\nCmpt (µg/mL)", fillcolor="#90CAF9"];
    CYP3A4_BRAF [label="CYP3A4\nOxidation\n(major)", fillcolor="#E3F2FD", shape=diamond];
    CYP1A2_BRAF [label="CYP1A2\nSecondary\nmetabolism", fillcolor="#E3F2FD", shape=diamond];
    UGLU_BRAF [label="UGT1A1/1A3\nGlucuronidation", fillcolor="#E3F2FD", shape=diamond];
    OATP1B_BRAF [label="OATP1B1/1B3\nHepatic Uptake", fillcolor="#BBDEFB"];
    CLR_BRAF [label="Renal/Biliary\nExcretion", fillcolor="#BBDEFB"];
    Tmax_BRAF [label="Tmax ~4h (Vmfnb)\nTmax ~2h (Dbfnb)\nt½ ~57h / 8h", fillcolor="#E8EAF6", shape=ellipse];
    ka_BRAF [label="ka=0.42/h\nF=0.64\nVd=100L", fillcolor="#C5CAE9"];
    PPB_BRAF [label="Plasma Protein\nBinding >99%\n(albumin)", fillcolor="#BBDEFB"];
  }

  /* =====================================================================
     CLUSTER 1: MEK Inhibitor PK
     ===================================================================== */
  subgraph cluster_mek_pk {
    label="MEK Inhibitor PK\n(Trametinib / Cobimetinib)";
    style=filled; fillcolor="#E8F5E9"; color="#2E7D32"; fontsize=10;

    DOSE_MEK [label="MEK Inhibitor\nDose\n(2mg QD / 60mg 3/1)", fillcolor="#A5D6A7", shape=parallelogram];
    GUT_MEK [label="GUT_MEK\nGI Absorption\nCmpt", fillcolor="#C8E6C9"];
    CENT_MEK [label="CENT_MEK\nPlasma\nCmpt (ng/mL)", fillcolor="#A5D6A7"];
    CYP3A4_MEK [label="CYP3A4\nDeacetylation\n(major)", fillcolor="#E8F5E9", shape=diamond];
    UGLU_MEK [label="UGT1A1/1A3\nConjugation", fillcolor="#E8F5E9", shape=diamond];
    AMDAC_MEK [label="Amide hydrolysis\n(minor pathway)", fillcolor="#DCEDC8", shape=diamond];
    CLR_MEK [label="Fecal/Renal\nExcretion", fillcolor="#C8E6C9"];
    Tmax_MEK [label="Tmax ~1.5h\nt½ ~3.9d (Tram)\nt½ ~44h (Cobi)", fillcolor="#DCEDC8", shape=ellipse];
    ka_MEK [label="ka=0.35/h\nF=0.72\nVd=214L", fillcolor="#AED581"];
    PPB_MEK [label="Protein Binding\n~97.4% (Tram)\n~95% (Cobi)", fillcolor="#C8E6C9"];
  }

  /* =====================================================================
     CLUSTER 2: Immune Checkpoint Inhibitor PK
     ===================================================================== */
  subgraph cluster_ici_pk {
    label="Immune Checkpoint Inhibitor PK\n(Pembrolizumab · Nivolumab · Ipilimumab)";
    style=filled; fillcolor="#FCE4EC"; color="#880E4F"; fontsize=10;

    DOSE_PD1 [label="PD-1 mAb\n(Pembrolizumab 200mg\nor Nivolumab 240mg\nIV q3w)", fillcolor="#F48FB1", shape=parallelogram];
    DOSE_CTLA4 [label="CTLA-4 mAb\n(Ipilimumab 3mg/kg\nIV q3w × 4)", fillcolor="#F48FB1", shape=parallelogram];
    CENT_ICI [label="CENT_ICI\nCentral Cmpt\n(µg/mL)", fillcolor="#F48FB1"];
    PERI_ICI [label="PERI_ICI\nPeripheral Cmpt\n(tissue)", fillcolor="#F8BBD0"];
    RO_PD1 [label="PD-1 Receptor\nOccupancy\n(~70% at 2mg/kg)", fillcolor="#FCE4EC", shape=diamond];
    RO_CTLA4 [label="CTLA-4 Receptor\nOccupancy\n(~30-50%)", fillcolor="#FCE4EC", shape=diamond];
    TMDD_ICI [label="TMDD\nTarget-Mediated\nDisposition", fillcolor="#F8BBD0"];
    FcRn_ICI [label="FcRn\nIgG Recycling\n(pH-dependent)", fillcolor="#FCE4EC"];
    t_half_ICI [label="t½~27d (Pembro)\nt½~25d (Nivo)\nt½~15d (Ipi)", fillcolor="#FFDDE1", shape=ellipse];
    CLR_ICI [label="Proteolytic\nCatabolism\n(reticuloendothelial)", fillcolor="#F8BBD0"];
    ADA_ICI [label="Anti-drug Antibodies\n(rare, ~1% Pembro)", fillcolor="#FCE4EC"];
  }

  /* =====================================================================
     CLUSTER 3: MAPK Signaling Pathway
     ===================================================================== */
  subgraph cluster_mapk {
    label="MAPK Signaling Pathway\n(Core Oncogenic Driver)";
    style=filled; fillcolor="#FFFDE7"; color="#F57F17"; fontsize=10;

    RTK_input [label="RTK Ligands\n(EGF, FGF, HGF\nSCF, VEGF)", fillcolor="#FFF176"];
    RAS_WT [label="RAS (WT)\nGDP↔GTP\nGEF/GAP cycle", fillcolor="#FFF176"];
    NRAS_mut [label="NRAS Q61K/R/L\n(~20% melanoma)\nConstitutive GTP-bound", fillcolor="#FFCC02", shape=hexagon];
    KRAS_mut [label="KRAS (rare)\nMutation\n(<5% melanoma)", fillcolor="#FFE082", shape=diamond];
    NF1_loss [label="NF1 Loss\n(GAP function lost)\n(~15% melanoma)", fillcolor="#FFE082", shape=hexagon];
    BRAF_WT [label="BRAF (WT)\nDimer with CRAF\nRAS-dependent", fillcolor="#FFE082"];
    BRAF_V600E [label="BRAF V600E\n(~45–50% cutaneous\nmelanoma)\nConstitutive Ser/Thr kinase", fillcolor="#FFCA28", shape=hexagon];
    BRAF_V600K [label="BRAF V600K\n(~5% melanoma\nmore UV-assoc.)", fillcolor="#FFE082", shape=hexagon];
    CRAF [label="CRAF (RAF1)\nParadox activator\n(BRAFi in WT-BRAF)", fillcolor="#FFF9C4"];
    MEK1 [label="MEK1\n(MAP2K1)\nDual Ser/Thr/Tyr kinase", fillcolor="#FFECB3"];
    MEK2 [label="MEK2\n(MAP2K2)\nFunctionally redundant", fillcolor="#FFECB3"];
    ERK1 [label="ERK1\n(MAPK3)\nCytoplasmic", fillcolor="#FFD740"];
    ERK2 [label="ERK2\n(MAPK1)\nPredominant form", fillcolor="#FFD740"];
    RSK [label="RSK\n(p90 ribosomal\nS6 kinase)", fillcolor="#FFF176"];
    MNK1 [label="MNK1/2\n(eIF4E kinase\nprotein synthesis)", fillcolor="#FFF176"];
    DUSP6 [label="DUSP6\nERK phosphatase\nNegative feedback", fillcolor="#FFFDE7", shape=diamond];
    SPRY2 [label="SPRY2\nRAS inhibitor\nNeg feedback", fillcolor="#FFFDE7", shape=diamond];
    ERK_nuc [label="ERK (nuclear)\nTranscription\nactivation", fillcolor="#FFD740"];
    p38_MAPK [label="p38 MAPK\nStress-activated\n(Tram activates)", fillcolor="#FFF9C4"];
  }

  /* =====================================================================
     CLUSTER 4: Transcription Factors & Cell Cycle
     ===================================================================== */
  subgraph cluster_tfs_cc {
    label="Transcription Factors & Cell Cycle\n(Downstream of MAPK)";
    style=filled; fillcolor="#F3E5F5"; color="#6A1B9A"; fontsize=10;

    MITF [label="MITF\nMaster melanocyte TF\nERK→pMITF (degr)\nRSK→pMITF (stab)", fillcolor="#CE93D8"];
    MYC_tf [label="c-MYC\nProliferative TF\n(ERK/AKT target)", fillcolor="#CE93D8"];
    FOS_JUN [label="FOS/JUN\nAP-1 complex\nImmediate early genes", fillcolor="#E1BEE7"];
    ETS_fam [label="ETS1/ELK1\nERK nuclear\nsubstrates", fillcolor="#E1BEE7"];
    CCND1 [label="Cyclin D1\n(CCND1)\nG1 phase driver", fillcolor="#AB47BC"];
    CCNE1 [label="Cyclin E1\n(CCNE1)\nS-phase entry", fillcolor="#AB47BC"];
    CDK4 [label="CDK4\nG1/S kinase", fillcolor="#CE93D8"];
    CDK6 [label="CDK6\nG1/S kinase", fillcolor="#CE93D8"];
    CDK2 [label="CDK2\nS-phase kinase", fillcolor="#CE93D8"];
    RB1 [label="RB1\nTumor suppressor\nG1/S gatekeeper", fillcolor="#7B1FA2", fontcolor="white"];
    E2F_fam [label="E2F 1-3\nProliferative TFs\n(released from RB1)", fillcolor="#9C27B0", fontcolor="white"];
    CDKN2A [label="p16/CDKN2A\nCDK4/6 inhibitor\n(lost ~50% melanoma)", fillcolor="#7B1FA2", fontcolor="white", shape=hexagon];
    p21_cip1 [label="p21/CDKN1A\nCDK1/2/4/6 inhibitor\n(p53 target)", fillcolor="#BA68C8"];
    p27_kip1 [label="p27/CDKN1B\nCDK2/4 inhibitor", fillcolor="#BA68C8"];
    TP53 [label="TP53\nTumor suppressor\n(mut ~20% melanoma)", fillcolor="#7B1FA2", fontcolor="white", shape=hexagon];
    MDM2 [label="MDM2\np53 ubiquitin ligase\n(AKT activates)", fillcolor="#E1BEE7"];
  }

  /* =====================================================================
     CLUSTER 5: PI3K / AKT / mTOR
     ===================================================================== */
  subgraph cluster_pi3k {
    label="PI3K / AKT / mTOR Pathway\n(Survival · Resistance · Crosstalk)";
    style=filled; fillcolor="#E0F2F1"; color="#004D40"; fontsize=10;

    PTEN_ts [label="PTEN\nPhosphatase\n(lost ~30% melanoma)", fillcolor="#80CBC4", shape=hexagon];
    PI3K_cat [label="PI3K (p110α/β)\nClass I\nCatalyic subunit", fillcolor="#80CBC4"];
    PIP2 [label="PIP2\nPhospholipid\nsubstrate", fillcolor="#B2DFDB"];
    PIP3 [label="PIP3\nSecond\nmessenger", fillcolor="#4DB6AC"];
    PDK1 [label="PDK1\n(PDPK1)\nSer/Thr kinase", fillcolor="#80CBC4"];
    AKT1 [label="AKT1/2/3\n(PKB)\nAll 3 isoforms", fillcolor="#26A69A", fontcolor="white"];
    mTORC1 [label="mTORC1\n(RAPTOR)\nAnabolic complex", fillcolor="#00897B", fontcolor="white"];
    mTORC2 [label="mTORC2\n(RICTOR)\nAKT activator", fillcolor="#00897B", fontcolor="white"];
    S6K1 [label="S6K1\n(RPS6KB1)\nProtein synthesis", fillcolor="#4DB6AC"];
    EIF4EBP1 [label="4EBP1\nTranslation\ninitiation factor", fillcolor="#4DB6AC"];
    FOXO_tf [label="FOXO1/3a\nApoptosis TF\n(AKT excludes\nfrom nucleus)", fillcolor="#80CBC4"];
    GSK3B_k [label="GSK3β\nMULTI-substrate\nkinase", fillcolor="#B2DFDB"];
    BAD_pro [label="BAD\nPro-apoptotic\n(AKT phospho→14-3-3)", fillcolor="#B2DFDB"];
    MDM2_AKT [label="MDM2 phospho\n→ p53 degradation\n(AKT→MDM2→p53)", fillcolor="#B2DFDB"];
  }

  /* =====================================================================
     CLUSTER 6: Apoptosis
     ===================================================================== */
  subgraph cluster_apoptosis {
    label="Intrinsic Apoptosis\n(BCL-2 Family · Caspase Cascade)";
    style=filled; fillcolor="#FFEBEE"; color="#B71C1C"; fontsize=10;

    BCL2_prot [label="BCL-2\nAnti-apoptotic\n(MITF transcribes)", fillcolor="#EF9A9A"];
    BCLXL_prot [label="BCL-xL\nAnti-apoptotic\n(broad survival)", fillcolor="#EF9A9A"];
    MCL1_prot [label="MCL1\nAnti-apoptotic\n(acquired resistance\nto BRAFi)", fillcolor="#EF9A9A"];
    BIM_pro [label="BIM (BCL2L11)\nBH3-only\nPro-apoptotic\n(ERK phospho→degr)", fillcolor="#EF5350"];
    PUMA_pro [label="PUMA (BBC3)\nBH3-only\n(p53 target)", fillcolor="#EF5350"];
    NOXA_pro [label="NOXA\nBH3-only\n(MCL1 antagonist)", fillcolor="#EF5350"];
    BAX_pore [label="BAX\nMitochondrial\npore-former", fillcolor="#C62828", fontcolor="white"];
    BAK_pore [label="BAK\nMitochondrial\npore-former", fillcolor="#C62828", fontcolor="white"];
    CYTO_C [label="Cytochrome c\nMitochondrial\nRelease (MOMP)", fillcolor="#FFCDD2"];
    APAF1 [label="APAF1\nApoptosome\n(dATP-dependent)", fillcolor="#FFCDD2"];
    CASP9 [label="Caspase-9\nInitiator\ncaspase", fillcolor="#FFCDD2"];
    CASP3 [label="Caspase-3\nExecutioner\ncaspase", fillcolor="#EF9A9A"];
    CASP7 [label="Caspase-7\nExecutioner\ncaspase", fillcolor="#EF9A9A"];
    PARP_cleave [label="PARP cleavage\n(89kDa fragment)\nApoptosis marker", fillcolor="#FFCDD2"];
    SMAC [label="SMAC/DIABLO\nIAP antagonist\nreleased from mito", fillcolor="#FFCDD2"];
  }

  /* =====================================================================
     CLUSTER 7: Antigen Presentation & Immune Activation
     ===================================================================== */
  subgraph cluster_antigen {
    label="Antigen Presentation & T Cell Priming\n(Tumor → APC → T cell)";
    style=filled; fillcolor="#FFF3E0"; color="#E65100"; fontsize=10;

    TUM_AG [label="Tumor-Associated\nAntigens\n(MART-1, gp100\nNY-ESO-1, MAGE)", fillcolor="#FFE0B2"];
    PROTEASOME [label="Proteasome\n(26S)\nAntigen processing", fillcolor="#FFCC80"];
    TAP12 [label="TAP1/TAP2\nPeptide transporter\ninto ER", fillcolor="#FFCC80"];
    MHC_I [label="MHC class I\n(HLA-A,B,C)\nTumor expression\n(IFNγ↑)", fillcolor="#FFB74D"];
    MHC_II [label="MHC class II\n(HLA-DR,DP,DQ)\nAPC expression", fillcolor="#FFB74D"];
    CD8_TCR [label="CD8+ TCR\nRecognition\n(MHC-I:peptide)", fillcolor="#FF9800"];
    CD4_TCR [label="CD4+ TCR\nRecognition\n(MHC-II:peptide)", fillcolor="#FF9800"];
    CD28_co [label="CD28\nCo-stimulatory\nreceptor (T cell)", fillcolor="#FFB74D"];
    B7_1 [label="B7-1 (CD80)\nCo-stimulatory\nligand (APC)", fillcolor="#FFB74D"];
    B7_2 [label="B7-2 (CD86)\nCo-stimulatory\nligand (APC)", fillcolor="#FFB74D"];
    CTLA4_Tcell [label="CTLA-4 (CD152)\nCD28 competitor\nHigh affinity B7", fillcolor="#EF6C00", fontcolor="white"];
    CD40_L [label="CD40/CD40L\nAPC maturation\n→ B7↑ IL-12↑", fillcolor="#FFCC80"];
    IFNg_sig [label="IFN-γ Signaling\nJAK1/2 → STAT1\n→ IRF1 → PD-L1", fillcolor="#FFCC80"];
    PDL1_tum [label="PD-L1 (CD274)\nTumor-expressed\n(IFN-γ induced)", fillcolor="#FF6F00", fontcolor="white"];
    PDL2_APC [label="PD-L2 (CD273)\nAPC-expressed\nAlternate PD-1 L", fillcolor="#FFCC80"];
    IL12_DC [label="IL-12\nDendritic cell\nTH1 polarization", fillcolor="#FFE0B2"];
    DC_mat [label="Mature DC\n(CD83+, CCR7+)\nCross-presentation", fillcolor="#FFE0B2"];
  }

  /* =====================================================================
     CLUSTER 8: T Cell Biology & Checkpoints
     ===================================================================== */
  subgraph cluster_tcell {
    label="T Cell Biology & Checkpoint Regulation";
    style=filled; fillcolor="#E8EAF6"; color="#1A237E"; fontsize=10;

    CD8_naive [label="Naive CD8+\nT cell\n(lymph node)", fillcolor="#9FA8DA"];
    CD8_primed [label="Primed CD8+\n(pLN effector\nmemory precursor)", fillcolor="#9FA8DA"];
    CD8_eff [label="Effector CD8+\nCTL\n(blood)", fillcolor="#5C6BC0", fontcolor="white"];
    CD8_TIL [label="CD8+ TIL\nTumor-Infiltrating\nLymphocyte", fillcolor="#3949AB", fontcolor="white"];
    CD8_exhaust [label="Exhausted CD8+\n(TIM-3+/LAG-3+\nTIGIT+/TOX+)", fillcolor="#283593", fontcolor="white"];
    PD1_rcpt [label="PD-1 (CD279)\nInhibitory receptor\n(activation-induced)", fillcolor="#7986CB"];
    LAG3_rcpt [label="LAG-3\nCheckpoint\nreceptor", fillcolor="#7986CB"];
    TIM3_rcpt [label="TIM-3\n(HAVCR2)\nExhaustion marker", fillcolor="#7986CB"];
    TIGIT_rcpt [label="TIGIT\nCheckpoint\n(CD155 ligand)", fillcolor="#7986CB"];
    CD4_TH1 [label="CD4+ TH1\nHelper T cell\n(IFN-γ, IL-2)", fillcolor="#9FA8DA"];
    Treg_cell [label="Treg (FoxP3+)\nCD25+ CD4+\nSuppressive T cell", fillcolor="#7986CB"];
    NK_cell [label="NK cells\nCD56+CD16+\nInnate cytotoxic", fillcolor="#C5CAE9"];
    GrzB_mol [label="Granzyme B\nSer protease\nCaspase pathway", fillcolor="#5C6BC0", fontcolor="white"];
    Perfn [label="Perforin\nPore-forming\nprotein", fillcolor="#5C6BC0", fontcolor="white"];
    IL2_cyto [label="IL-2\nT cell growth\nfactor", fillcolor="#9FA8DA"];
    IFNg_cyto [label="IFN-γ\nAntitumor\ncytokine", fillcolor="#5C6BC0", fontcolor="white"];
    TNFa_cyto [label="TNF-α\nPro-inflammatory\ncytokine", fillcolor="#9FA8DA"];
    GZMK [label="Granzyme K\nAlt cytotoxic\npathway", fillcolor="#9FA8DA"];
    IL17 [label="IL-17\n(TH17)\nInflammatory", fillcolor="#C5CAE9"];
  }

  /* =====================================================================
     CLUSTER 9: Tumor Biology & Microenvironment
     ===================================================================== */
  subgraph cluster_tumor_bio {
    label="Tumor Biology & Microenvironment (TME)";
    style=filled; fillcolor="#F9FBE7"; color="#558B2F"; fontsize=10;

    MELANOCYTE [label="Normal\nMelanocyte\n(neural crest)", fillcolor="#F0F4C3"];
    PRIMARY_MEL [label="Primary\nMelanoma\n(Breslow depth)", fillcolor="#DCE775"];
    META_MEL [label="Metastatic\nMelanoma\n(M1a/b/c/d)", fillcolor="#C6E700"];
    TUMOR_VOL [label="Tumor Burden\n(SLD / SoD mm\nnormalized)", fillcolor="#AFB42B", fontcolor="white"];
    VEGFA_tum [label="VEGF-A\nAngiogenesis\npromoter", fillcolor="#F0F4C3"];
    VEGFR2 [label="VEGFR2 (KDR)\nEndothelial\nreceptor", fillcolor="#DCEDC8"];
    FGF_bypass [label="FGF1/2/4/5\nRTK bypass\n(BRAFi resistance)", fillcolor="#DCEDC8"];
    HGF_MET [label="HGF/MET\nScatter factor\nPI3K bypass", fillcolor="#DCEDC8"];
    PDGFR_byp [label="PDGFR-β\nBypass\nreceptor", fillcolor="#DCEDC8"];
    TGFB_tum [label="TGF-β1/2/3\nImmunosuppression\nEMT promotion", fillcolor="#DCEDC8"];
    IL6_tum [label="IL-6\nJAK2-STAT3\nImmunosuppressive", fillcolor="#DCEDC8"];
    IL10_tum [label="IL-10\nAnti-inflammatory\n(Treg/MDSC)", fillcolor="#DCEDC8"];
    MDSC_cell [label="MDSC\nMyeloid-derived\nSuppressor Cells", fillcolor="#F0F4C3"];
    TAM_M2 [label="TAM (M2)\nTumor-associated\nMacrophage", fillcolor="#F0F4C3"];
    EMT_prog [label="EMT\nEpithelial-Mesenchymal\nTransition", fillcolor="#F0F4C3"];
    INVASION [label="Invasion\n& Metastasis\n(MMP2/9, uPA)", fillcolor="#CDDC39"];
    HYPOXIA [label="Hypoxia\n(HIF-1α)\nAngiogenesis+", fillcolor="#DCEDC8"];
  }

  /* =====================================================================
     CLUSTER 10: Acquired Resistance Mechanisms
     ===================================================================== */
  subgraph cluster_resistance {
    label="Acquired Resistance to BRAF/MEK Inhibitors";
    style=filled; fillcolor="#EFEBE9"; color="#4E342E"; fontsize=10;

    RESIST_fac [label="Resistance Factor\n(R: 0→1)\nSlow accumulation\nunder BRAFi/MEKi", fillcolor="#BCAAA4"];
    BRAF_amp [label="BRAF V600E\nAmplification\n(copy number↑)\n~25% of resistance", fillcolor="#A1887F"];
    BRAF_splice [label="BRAF p61\nAlternate splice\nRAS-independent\ndimer", fillcolor="#A1887F"];
    NRAS_2nd [label="Secondary\nNRAS Q61 mut\n(~20% of cases)", fillcolor="#A1887F"];
    MEK12_mut [label="MEK1/2\n(MAP2K1/2) mut\nGain-of-function\n(~7%)", fillcolor="#A1887F"];
    COT1_MAP3K8 [label="COT1/MAP3K8\nBRAF-independent\nERK activation", fillcolor="#BCAAA4"];
    IGFR_byp [label="IGF1R / IRS\nPI3K bypass\nAKT-mediated", fillcolor="#BCAAA4"];
    PDGFRB_up [label="PDGFR-β\nUpregulation\nRTK bypass", fillcolor="#BCAAA4"];
    EGFR_up [label="EGFR\nUpregulation\nRAS→ERK bypass", fillcolor="#BCAAA4"];
    DUSP6_del [label="DUSP6 deletion\nERK phosphatase\nloss → ERK↑↑", fillcolor="#BCAAA4"];
    ERK_reactiv [label="ERK Reactivation\n(resistance endpoint)\nRestores proliferation", fillcolor="#795548", fontcolor="white"];
    WNT5A [label="WNT5A/β-catenin\nPhenotypic switch\nMITF-low invasive", fillcolor="#BCAAA4"];
    MCL1_amp [label="MCL1\nAmplification\n→ apoptosis resist\n(BH3-mimetic target)", fillcolor="#BCAAA4"];
    IMMUNE_escape [label="Immune Escape\n(MHC-I loss\nβ2M mut, JAK1/2 mut)", fillcolor="#795548", fontcolor="white"];
  }

  /* =====================================================================
     CLUSTER 11: Clinical Endpoints & Biomarkers
     ===================================================================== */
  subgraph cluster_endpoints {
    label="Clinical Endpoints & Biomarkers";
    style=filled; fillcolor="#ECEFF1"; color="#263238"; fontsize=10;

    ORR [label="ORR\nObjective Response\nRate (CR+PR)", fillcolor="#CFD8DC"];
    DCR [label="DCR\nDisease Control\nRate (CR+PR+SD)", fillcolor="#CFD8DC"];
    PFS_ep [label="PFS\nProgression-Free\nSurvival", fillcolor="#B0BEC5"];
    OS_ep [label="OS\nOverall Survival", fillcolor="#90A4AE"];
    DpR [label="Depth of Response\n(%ΔTumor volume\nfrom baseline)", fillcolor="#CFD8DC"];
    DoR_ep [label="DoR\nDuration of\nResponse", fillcolor="#CFD8DC"];
    LDH_ep [label="LDH (serum)\nTumor necrosis\nbiomarker (U/L)", fillcolor="#90A4AE"];
    S100B_ep [label="S100B\nMelanocyte\nmarker (µg/L)", fillcolor="#B0BEC5"];
    ctDNA_ep [label="ctDNA / cfDNA\nLiquid biopsy\n(early response)", fillcolor="#B0BEC5"];
    TMB_ep [label="TMB\nTumor Mutational\nBurden (mut/Mb)", fillcolor="#CFD8DC"];
    MSI_ep [label="MSI-H\nMicrosatellite\nInstability-High", fillcolor="#CFD8DC"];
    BENCH [label="Clinical Benchmarks:\nBRIM-3: ORR 48% (Vmfnb)\nCOMBI-d: mPFS 9.3mo\nCheckMate067: 5yr OS 52%\nKEYNOTE-006: mPFS 5.6mo", fillcolor="#546E7A", fontcolor="white", shape=note];
  }

  // =====================================================================
  // INTER-CLUSTER EDGES
  // =====================================================================

  // -- BRAF inhibitor PK --
  DOSE_BRAF -> GUT_BRAF;
  GUT_BRAF -> CENT_BRAF;
  CENT_BRAF -> CYP3A4_BRAF [style=dashed, color="#1565C0"];
  CENT_BRAF -> CYP1A2_BRAF [style=dashed, color="#1565C0"];
  CENT_BRAF -> UGLU_BRAF [style=dashed, color="#1565C0"];
  CENT_BRAF -> OATP1B_BRAF [style=dashed, color="#1565C0"];
  CENT_BRAF -> PPB_BRAF [style=dotted, color="#1565C0"];
  CYP3A4_BRAF -> CLR_BRAF;
  UGLU_BRAF -> CLR_BRAF;

  // -- MEK inhibitor PK --
  DOSE_MEK -> GUT_MEK;
  GUT_MEK -> CENT_MEK;
  CENT_MEK -> CYP3A4_MEK [style=dashed, color="#2E7D32"];
  CENT_MEK -> UGLU_MEK [style=dashed, color="#2E7D32"];
  CENT_MEK -> AMDAC_MEK [style=dashed, color="#2E7D32"];
  CYP3A4_MEK -> CLR_MEK;
  UGLU_MEK -> CLR_MEK;

  // -- ICI PK --
  DOSE_PD1 -> CENT_ICI;
  DOSE_CTLA4 -> CENT_ICI;
