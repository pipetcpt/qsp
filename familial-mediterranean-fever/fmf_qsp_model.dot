digraph FMF_QSP {
    graph [
        label="Familial Mediterranean Fever (FMF) — Quantitative Systems Pharmacology Map\nPYRIN Inflammasome & Autoinflammatory Pathways with Drug PK/PD"
        labelloc=t fontsize=20 fontname="Helvetica-Bold"
        bgcolor="#FAFAFA" rankdir=TB
        splines=true nodesep=0.35 ranksep=0.55
        compound=true
    ]
    node [fontname="Helvetica" fontsize=9 style=filled shape=box margin="0.12,0.06"]
    edge [fontname="Helvetica" fontsize=8 arrowsize=0.65]

    /* =====================================================================
       CLUSTER 1: GENETIC BASIS
       ===================================================================== */
    subgraph cluster_genetics {
        label="Genetic Basis — MEFV Mutations"
        style=filled fillcolor="#FFF3E0" color="#E65100" penwidth=2
        fontname="Helvetica-Bold" fontsize=12

        MEFV_gene  [label="MEFV Gene\nChromosome 16p13.3" fillcolor="#FFCC80"]
        MEFV_M694V [label="M694V Mutation\n(Severe, Mediterranean)" fillcolor="#FF8A65"]
        MEFV_M680I [label="M680I Mutation\n(Intermediate)" fillcolor="#FF8A65"]
        MEFV_V726A [label="V726A Mutation\n(Mild, Turkish)" fillcolor="#FFAB91"]
        MEFV_E148Q [label="E148Q Mutation\n(Common variant)" fillcolor="#FFAB91"]
        MEFV_M694I [label="M694I Mutation\n(Ashkenazi Jewish)" fillcolor="#FF8A65"]
        PYRIN_wt   [label="Normal PYRIN\nProtein (Marenostrin)" fillcolor="#FFE082"]
        PYRIN_mut  [label="Mutant PYRIN\n(Loss of inhibitory function)" fillcolor="#FF7043"]
        AR_inhert  [label="Autosomal Recessive\nInheritance (AR)" fillcolor="#FFCC80"]
        Carrier    [label="Heterozygous Carrier\n(may have mild symptoms)" fillcolor="#FFCC80"]
        HLA_assoc  [label="HLA Associations\n(B51, DR7)" fillcolor="#FFAB91"]
    }

    /* =====================================================================
       CLUSTER 2: PYRIN INFLAMMASOME PATHWAY
       ===================================================================== */
    subgraph cluster_inflammasome {
        label="PYRIN Inflammasome Complex"
        style=filled fillcolor="#FCE4EC" color="#880E4F" penwidth=2
        fontname="Helvetica-Bold" fontsize=12

        RhoA_GTPase [label="RhoA GTPase\nActivity" fillcolor="#F48FB1"]
        PKN1_PKN2   [label="PKN1/PKN2\nSerine Kinases" fillcolor="#EC407A"]
        PYRIN_phos  [label="PYRIN Phosphorylation\n(S208, S242 — inactive)" fillcolor="#E91E63" fontcolor="white"]
        PYRIN_dephos [label="PYRIN Dephosphorylation\n(active, unrestrained)" fillcolor="#AD1457" fontcolor="white"]
        ASC_speck   [label="ASC Speck Formation\n(CARD-PYD interaction)" fillcolor="#EC407A"]
        ASC_protein [label="ASC Adaptor\nProtein (PYCARD)" fillcolor="#F48FB1"]
        Caspase1_p  [label="Pro-Caspase-1\nRecruitment" fillcolor="#E91E63" fontcolor="white"]
        Caspase1_a  [label="Active Caspase-1\n(p10/p20 heterodimer)" fillcolor="#880E4F" fontcolor="white"]
        NLRP3_cprx  [label="NLRP3 Inflammasome\n(secondary activation)" fillcolor="#EC407A"]
        TxnIP       [label="Thioredoxin-interacting\nProtein (TxnIP)" fillcolor="#F48FB1"]
        NLRP1_cprx  [label="NLRP1 Inflammasome\n(alternative pathway)" fillcolor="#F8BBD0"]
        GSDMD       [label="Gasdermin D\n(Pyroptosis pore)" fillcolor="#C2185B" fontcolor="white"]
    }

    /* =====================================================================
       CLUSTER 3: INNATE IMMUNE ACTIVATION
       ===================================================================== */
    subgraph cluster_innate {
        label="Innate Immune Activation & Pattern Recognition"
        style=filled fillcolor="#E8F5E9" color="#2E7D32" penwidth=2
        fontname="Helvetica-Bold" fontsize=12

        Macro_tissue [label="Tissue Macrophage\n(Peritoneal, Synovial)" fillcolor="#A5D6A7"]
        Neutro_recr  [label="Neutrophil\nRecruitment" fillcolor="#81C784"]
        Neutro_act   [label="Activated Neutrophil\n(NET formation)" fillcolor="#66BB6A"]
        Mono_circ    [label="Circulating Monocyte\n(Ly6C+ classical)" fillcolor="#A5D6A7"]
        DC_innate    [label="Innate Dendritic Cell" fillcolor="#81C784"]
        DAMP_recog   [label="DAMP Recognition\n(uric acid, ATP crystals)" fillcolor="#A5D6A7"]
        TLR4_sign    [label="TLR4 Signaling\n(LPS, DAMPs)" fillcolor="#66BB6A"]
        TLR2_sign    [label="TLR2 Signaling\n(lipopeptides)" fillcolor="#66BB6A"]
        NKcell_innate [label="NK Cell\nActivation" fillcolor="#A5D6A7"]
        Mast_cell    [label="Mast Cell\nDegranulation" fillcolor="#81C784"]
        ROS_burst    [label="Reactive Oxygen\nSpecies (ROS) Burst" fillcolor="#43A047"]
        Tubulin_eff  [label="Tubulin Polymerization\n(Colchicine Target)" fillcolor="#66BB6A"]
    }

    /* =====================================================================
       CLUSTER 4: KEY CYTOKINES
       ===================================================================== */
    subgraph cluster_cytokines {
        label="Pro-inflammatory Cytokines & Mediators"
        style=filled fillcolor="#F3E5F5" color="#6A1B9A" penwidth=2
        fontname="Helvetica-Bold" fontsize=12

        IL1b_mat    [label="Mature IL-1beta\n(17 kDa)" fillcolor="#CE93D8"]
        IL18_mat    [label="Mature IL-18\n(18 kDa)" fillcolor="#CE93D8"]
        IL33_sign   [label="IL-33\nAlarmins" fillcolor="#AB47BC"]
        IL6_acute   [label="IL-6\nAcute Phase Response" fillcolor="#8E24AA" fontcolor="white"]
        TNFa_prod   [label="TNF-alpha\nProduction" fillcolor="#6A1B9A" fontcolor="white"]
        IL8_CXCL8   [label="IL-8/CXCL8\nNeutrophil Chemoattract" fillcolor="#CE93D8"]
        SAA_prod    [label="Serum Amyloid A\n(SAA) — acute phase" fillcolor="#9C27B0" fontcolor="white"]
        CRP_prod    [label="CRP Production\nHepatic" fillcolor="#AB47BC"]
        Fibrinogen  [label="Fibrinogen\nAcute Phase" fillcolor="#CE93D8"]
        IL1Ra       [label="IL-1 Receptor\nAntagonist (IL-1Ra)" fillcolor="#BA68C8"]
        IL10_reg    [label="IL-10\nRegulatory" fillcolor="#CE93D8"]
        NFkB_sign   [label="NF-kB\nActivation" fillcolor="#6A1B9A" fontcolor="white"]
        Pyroptosis  [label="Pyroptosis\nInflammatory Cell Death" fillcolor="#AD1457" fontcolor="white"]
        HMGB1       [label="HMGB1\nLate Mediator" fillcolor="#AB47BC"]
    }

    /* =====================================================================
       CLUSTER 5: SYSTEMIC INFLAMMATION — ATTACK
       ===================================================================== */
    subgraph cluster_attack {
        label="FMF Acute Attack Manifestations"
        style=filled fillcolor="#FFF8E1" color="#F57F17" penwidth=2
        fontname="Helvetica-Bold" fontsize=12

        Peritonitis  [label="Sterile Peritonitis\n(Abdominal Attack)" fillcolor="#FFE082"]
        Pleuritis    [label="Pleuritis\n(Chest Pain Attack)" fillcolor="#FFD54F"]
        Arthritis    [label="Monoarthritis\n(Hip, Knee, Ankle)" fillcolor="#FFE082"]
        Synovitis    [label="Synovial Inflammation\nTransient Effusion" fillcolor="#FFD54F"]
        Erysipelas   [label="Erysipelas-like\nSkin Lesion (ELE)" fillcolor="#FFAB40"]
        Pericarditis [label="Pericarditis\n(Cardiac Attack)" fillcolor="#FFD54F"]
        Scrotal_vascul [label="Scrotal Vasculitis\n(Males)" fillcolor="#FFE082"]
        Myalgia      [label="Myalgia\nFever Episode" fillcolor="#FFE082"]
        Fever_spike  [label="Fever (38-40°C)\nSelf-limiting 12-72h" fillcolor="#FF8F00" fontcolor="white"]
        Attack_freq  [label="Attack Frequency\n(days to months)" fillcolor="#FF8F00" fontcolor="white"]
        Attack_dur   [label="Attack Duration\n(12-72 hours)" fillcolor="#FFD54F"]
        Leukocytosis [label="Leukocytosis\n(WBC 15-30k)" fillcolor="#FFE082"]
    }

    /* =====================================================================
       CLUSTER 6: LONG-TERM COMPLICATIONS
       ===================================================================== */
    subgraph cluster_complications {
        label="Long-term Complications"
        style=filled fillcolor="#E8EAF6" color="#283593" penwidth=2
        fontname="Helvetica-Bold" fontsize=12

        AA_amyloid  [label="AA Amyloidosis\n(SAA deposition)" fillcolor="#9FA8DA"]
        Renal_amyl  [label="Renal Amyloidosis\nProteinuria→CKD" fillcolor="#5C6BC0" fontcolor="white"]
        Cardiac_amyl [label="Cardiac Amyloidosis\nRestrictive CMP" fillcolor="#7986CB"]
        GI_amyl     [label="GI Amyloidosis\nMalabsorption" fillcolor="#7986CB"]
        CKD_prog    [label="Chronic Kidney Disease\nProgression" fillcolor="#3949AB" fontcolor="white"]
        Spermatogen [label="Impaired Spermatogenesis\n(Scrotal vasculitis)" fillcolor="#9FA8DA"]
        Vasculitis_chr [label="Chronic Vasculitis\nHSP association" fillcolor="#7986CB"]
        SpA_assoc   [label="Spondyloarthropathy\nAssociation" fillcolor="#9FA8DA"]
        Psychosocial [label="Psychosocial Impact\nQoL impairment" fillcolor="#9FA8DA"]
    }

    /* =====================================================================
       CLUSTER 7: BIOMARKERS & ENDPOINTS
       ===================================================================== */
    subgraph cluster_biomarkers {
        label="Biomarkers & Clinical Endpoints"
        style=filled fillcolor="#E0F7FA" color="#006064" penwidth=2
        fontname="Helvetica-Bold" fontsize=12

        CRP_serum   [label="Serum CRP\n(attack >10 mg/L)" fillcolor="#80DEEA"]
        SAA_serum   [label="Serum SAA\n(>10 mg/L attack)" fillcolor="#4DD0E1"]
        ESR_val     [label="ESR\nElevated during attack" fillcolor="#80DEEA"]
        WBC_count   [label="WBC / PMN\nLeukocytosis" fillcolor="#80DEEA"]
        Fibrin_serum [label="Fibrinogen\nSerum level" fillcolor="#4DD0E1"]
        IL1b_serum  [label="Serum IL-1beta\n(attack biomarker)" fillcolor="#00BCD4"]
        Urine_prot  [label="Urine Protein\n(amyloidosis marker)" fillcolor="#00ACC1"]
        Creatinine  [label="Serum Creatinine\nGFR estimate" fillcolor="#00BCD4"]
        Attack_score [label="Attack Count\n(attacks/year)" fillcolor="#00ACC1"]
        AIDAI_score [label="AIDAI Score\nAutoinflam Activity" fillcolor="#006064" fontcolor="white"]
        PGA_score   [label="Physician Global\nAssessment (PGA)" fillcolor="#00BCD4"]
        SAA_chronic [label="Chronic SAA\n(>10 mg/L inter-attack)" fillcolor="#4DD0E1"]
    }

    /* =====================================================================
       CLUSTER 8: COLCHICINE PK
       ===================================================================== */
    subgraph cluster_col_pk {
        label="Colchicine Pharmacokinetics"
        style=filled fillcolor="#F1F8E9" color="#33691E" penwidth=2
        fontname="Helvetica-Bold" fontsize=12

        COL_dose    [label="Colchicine Dose\n(0.5-2 mg/day oral)" fillcolor="#C5E1A5"]
        COL_gut     [label="Colchicine Gut\nAbsorption (F~45%)" fillcolor="#AED581"]
        COL_cent    [label="Colchicine Central\nCmt (Vd~5-8 L/kg)" fillcolor="#9CCC65"]
        COL_peri    [label="Colchicine Peripheral\n(leukocyte uptake)" fillcolor="#8BC34A"]
        COL_CYP3A4  [label="CYP3A4/P-gp\nMetabolism" fillcolor="#AED581"]
        COL_renal   [label="Renal Elimination\n(t1/2~27h)" fillcolor="#C5E1A5"]
        COL_biliary [label="Biliary Excretion\n(enterohepatic)" fillcolor="#AED581"]
        COL_leukocyte [label="Leukocyte\nConcentration (10-20x)" fillcolor="#8BC34A"]
    }

    /* =====================================================================
       CLUSTER 9: IL-1 INHIBITOR PK
       ===================================================================== */
    subgraph cluster_il1_pk {
        label="IL-1 Inhibitor Pharmacokinetics"
        style=filled fillcolor="#FBE9E7" color="#BF360C" penwidth=2
        fontname="Helvetica-Bold" fontsize=12

        ANA_dose    [label="Anakinra (IL-1Ra)\n100mg SC daily" fillcolor="#FFAB91"]
        ANA_abs     [label="Anakinra SC Absorption\n(F~95%, Tmax~3-7h)" fillcolor="#FF7043"]
        ANA_cent    [label="Anakinra Central\n(Vd~18L, MW=17.3 kDa)" fillcolor="#FF5722"]
        ANA_elim    [label="Anakinra Elimination\n(renal, t1/2~4-6h)" fillcolor="#FF7043"]

        CAN_dose    [label="Canakinumab\n(anti-IL-1b mAb)\n150mg SC q8w" fillcolor="#FFAB91"]
        CAN_abs     [label="Canakinumab SC Absorption\n(F~66%, Tmax~7d)" fillcolor="#FF7043"]
        CAN_cent    [label="Canakinumab Central\n(Vd~6.9 L, MW=145 kDa)" fillcolor="#FF5722"]
        CAN_elim    [label="Canakinumab Elimination\n(t1/2~26 days)" fillcolor="#FF7043"]

        RIL_dose    [label="Rilonacept\n(IL-1 Trap)\n160mg SC weekly" fillcolor="#FFAB91"]
        RIL_cent    [label="Rilonacept Central\n(Vd~9.3 L, MW=251 kDa)" fillcolor="#FF5722"]
    }

    /* =====================================================================
       CLUSTER 10: DRUG PD
       ===================================================================== */
    subgraph cluster_pd {
        label="Drug Pharmacodynamics"
        style=filled fillcolor="#E3F2FD" color="#1565C0" penwidth=2
        fontname="Helvetica-Bold" fontsize=12

        COL_tubulin [label="Colchicine-Tubulin\nBinding (beta-tubulin)" fillcolor="#90CAF9"]
        COL_migr    [label="Neutrophil Migration\nInhibition" fillcolor="#42A5F5"]
        COL_adhes   [label="Neutrophil Adhesion\nInhibition" fillcolor="#64B5F6"]
        COL_PYRIN   [label="Colchicine PYRIN\nActivation Block" fillcolor="#1E88E5"]
        COL_NLRP3_inh [label="NLRP3 Activation\nReduction" fillcolor="#1565C0" fontcolor="white"]
        COL_IL1_red [label="IL-1beta\nSecretion Reduction" fillcolor="#1565C0" fontcolor="white"]
        COL_L_select [label="L-selectin Shedding\n(leukocyte)" fillcolor="#42A5F5"]

        ANA_IL1R    [label="Anakinra-IL-1R\nCompetitive Binding" fillcolor="#90CAF9"]
        ANA_block   [label="IL-1R Blockade\n(IL-1a and IL-1b)" fillcolor="#1E88E5"]

        CAN_IL1b    [label="Canakinumab-IL-1b\nHigh-affinity Binding" fillcolor="#90CAF9"]
        CAN_neut    [label="IL-1b Neutralization\n(>99% reduction)" fillcolor="#1565C0" fontcolor="white"]

        CAN_resp    [label="Canakinumab\nResponse (complete/partial)" fillcolor="#42A5F5"]
        ANA_resp    [label="Anakinra\nResponse" fillcolor="#64B5F6"]
    }

    /* =====================================================================
       EDGES — GENETICS → INFLAMMASOME
       ===================================================================== */

    MEFV_gene -> MEFV_M694V [label="variant"]
    MEFV_gene -> MEFV_M680I [label="variant"]
    MEFV_gene -> MEFV_V726A [label="variant"]
    MEFV_gene -> MEFV_E148Q [label="variant"]
    MEFV_gene -> MEFV_M694I [label="variant"]
    MEFV_M694V -> PYRIN_mut [label="severe loss"]
    MEFV_M680I -> PYRIN_mut
    MEFV_V726A -> PYRIN_mut [label="mild loss"]
    MEFV_E148Q -> PYRIN_wt [label="partial"]
    AR_inhert -> MEFV_gene [label="inheritance"]
    Carrier -> MEFV_gene [style=dashed]
    PYRIN_wt -> RhoA_GTPase [label="senses"]
    RhoA_GTPase -> PKN1_PKN2 [label="activates"]
    PKN1_PKN2 -> PYRIN_phos [label="phosphorylate"]
    PYRIN_phos -> ASC_speck [label="INACTIVE — prevents" color="red" arrowhead=tee]
    PYRIN_mut -> PYRIN_dephos [label="cannot be phosphorylated"]
    PYRIN_dephos -> ASC_speck [label="spontaneous assembly" color="#880E4F" penwidth=2]
    ASC_protein -> ASC_speck [label="forms"]
    ASC_speck -> Caspase1_p [label="recruits"]
    Caspase1_p -> Caspase1_a [label="autocatalytic"]
    Caspase1_a -> IL1b_mat [label="cleaves pro-IL-1b" color="#6A1B9A" penwidth=2]
    Caspase1_a -> IL18_mat [label="cleaves pro-IL-18" color="#6A1B9A"]
    Caspase1_a -> GSDMD [label="cleaves" color="#6A1B9A" penwidth=2]
    GSDMD -> Pyroptosis [label="pore formation" penwidth=2]
    NLRP3_cprx -> ASC_speck [label="alternative" style=dashed]
    TxnIP -> NLRP3_cprx [label="ROS-mediated"]

    /* =====================================================================
       EDGES — INNATE IMMUNITY
       ===================================================================== */

    DAMP_recog -> TLR4_sign
    DAMP_recog -> TLR2_sign
    TLR4_sign -> NFkB_sign [color="#6A1B9A"]
    TLR2_sign -> NFkB_sign
    NFkB_sign -> IL1b_mat [label="pro-IL-1b synthesis"]
    NFkB_sign -> TNFa_prod
    NFkB_sign -> IL6_acute
    NFkB_sign -> IL8_CXCL8
    NFkB_sign -> CRP_prod [label="hepatic" style=dashed]
    IL1b_mat -> NFkB_sign [label="amplify" style=dashed]
    Macro_tissue -> Caspase1_a [label="produces"]
    Mono_circ -> Caspase1_a [label="produces"]
    IL8_CXCL8 -> Neutro_recr [label="chemoattract"]
    Neutro_recr -> Neutro_act
    Neutro_act -> ROS_burst
    ROS_burst -> TxnIP [label="activate"]
    Tubulin_eff -> Neutro_recr [label="enables migration"]

    /* =====================================================================
       EDGES — CYTOKINES → INFLAMMATION
       ===================================================================== */

    IL1b_mat -> IL6_acute [label="induces" color="#6A1B9A"]
    IL1b_mat -> SAA_prod [label="acute phase"]
    IL1b_mat -> CRP_prod
    IL1b_mat -> Fibrinogen
    IL1b_mat -> Fever_spike [color="#F57F17" penwidth=2]
    IL18_mat -> IL6_acute
    IL6_acute -> SAA_prod [label="hepatic"]
    IL6_acute -> CRP_prod [label="hepatic"]
    SAA_prod -> AA_amyloid [label="chronic excess" color="#283593" penwidth=2]
    SAA_prod -> SAA_serum [color="#006064"]
    SAA_prod -> SAA_chronic [label="inter-attack"]
    CRP_prod -> CRP_serum [color="#006064"]
    Fibrinogen -> Fibrin_serum [color="#006064"]
    TNFa_prod -> NFkB_sign [label="amplify" style=dashed]
    Pyroptosis -> HMGB1 [label="releases"]
    HMGB1 -> NFkB_sign [label="late amplification"]
    IL1Ra -> IL1b_mat [label="compete" color="red" arrowhead=tee]

    /* =====================================================================
       EDGES — ATTACK MANIFESTATIONS
       ===================================================================== */

    IL1b_mat -> Peritonitis [label="serosal" color="#F57F17"]
    IL1b_mat -> Pleuritis [label="serosal" color="#F57F17"]
    IL1b_mat -> Arthritis [color="#F57F17"]
    IL1b_mat -> Erysipelas [color="#F57F17"]
    IL1b_mat -> Pericarditis [color="#F57F17"]
    IL1b_mat -> Myalgia [color="#F57F17"]
    Neutro_act -> Peritonitis [label="infiltrate"]
    Neutro_act -> Synovitis [label="infiltrate"]
    Fever_spike -> Attack_dur [label="12-72h"]
    Attack_dur -> Attack_freq [label="defines episode"]
    Leukocytosis -> WBC_count [color="#006064"]
    Peritonitis -> AIDAI_score [label="component"]
    Pleuritis -> AIDAI_score
    Arthritis -> AIDAI_score
    Fever_spike -> AIDAI_score
    AIDAI_score -> PGA_score
    Attack_freq -> Attack_score [color="#006064"]

    /* =====================================================================
       EDGES — LONG-TERM COMPLICATIONS
       ===================================================================== */

    AA_amyloid -> Renal_amyl [label="deposit"]
    AA_amyloid -> Cardiac_amyl
    AA_amyloid -> GI_amyl
    Renal_amyl -> Urine_prot [color="#006064"]
    Renal_amyl -> Creatinine [color="#006064"]
    Renal_amyl -> CKD_prog
    CKD_prog -> Creatinine [label="elevate"]
    Scrotal_vascul -> Spermatogen
    Vasculitis_chr -> SpA_assoc

    /* =====================================================================
       EDGES — COLCHICINE PK
       ===================================================================== */

    COL_dose -> COL_gut [color="#33691E"]
    COL_gut -> COL_cent [color="#33691E"]
    COL_cent -> COL_peri [color="#33691E"]
    COL_cent -> COL_CYP3A4 [color="#33691E"]
    COL_cent -> COL_renal [color="#33691E"]
    COL_cent -> COL_biliary [color="#33691E"]
    COL_peri -> COL_leukocyte [label="concentrate" color="#33691E"]

    /* =====================================================================
       EDGES — IL-1 INHIBITOR PK
       ===================================================================== */

    ANA_dose -> ANA_abs [color="#BF360C"]
    ANA_abs -> ANA_cent [color="#BF360C"]
    ANA_cent -> ANA_elim [color="#BF360C"]

    CAN_dose -> CAN_abs [color="#BF360C"]
    CAN_abs -> CAN_cent [color="#BF360C"]
    CAN_cent -> CAN_elim [color="#BF360C"]

    RIL_dose -> RIL_cent [color="#BF360C"]

    /* =====================================================================
       EDGES — COLCHICINE PD
       ===================================================================== */

    COL_leukocyte -> COL_tubulin [label="bind beta-tubulin" color="#1565C0"]
    COL_tubulin -> COL_migr [label="disrupt microtubule" color="#1565C0"]
    COL_tubulin -> COL_adhes [color="#1565C0"]
    COL_migr -> Neutro_recr [label="inhibit" color="red" arrowhead=tee]
    COL_adhes -> Neutro_act [label="reduce" color="red" arrowhead=tee]
    COL_leukocyte -> COL_PYRIN [label="colchicine→PYRIN" color="#1565C0"]
    COL_PYRIN -> PYRIN_dephos [label="partially block" color="red" arrowhead=tee]
    COL_PYRIN -> COL_NLRP3_inh [color="#1565C0"]
    COL_NLRP3_inh -> NLRP3_cprx [label="reduce" color="red" arrowhead=tee]
    COL_NLRP3_inh -> COL_IL1_red [color="#1565C0"]
    COL_IL1_red -> IL1b_mat [label="reduce secretion" color="red" arrowhead=tee]
    COL_tubulin -> COL_L_select [color="#1565C0"]
    COL_L_select -> Neutro_recr [label="reduce" color="red" arrowhead=tee]
    COL_IL1_red -> Fever_spike [label="prevent" color="red" arrowhead=tee]
    COL_IL1_red -> CRP_serum [label="normalize" color="#33691E"]
    COL_IL1_red -> SAA_serum [label="reduce" color="#33691E"]
    COL_IL1_red -> SAA_chronic [label="prevent" color="#33691E"]
    COL_IL1_red -> AA_amyloid [label="prevent" color="#33691E" penwidth=2]

    /* =====================================================================
       EDGES — IL-1 INHIBITOR PD
       ===================================================================== */

    ANA_cent -> ANA_IL1R [label="bind IL-1R1" color="#1565C0"]
    ANA_IL1R -> ANA_block [color="#1565C0"]
    ANA_block -> IL1b_mat [label="receptor block" color="red" arrowhead=tee]
    ANA_block -> IL6_acute [label="↓downstream" color="red" arrowhead=tee]
    ANA_block -> Fever_spike [label="prevent" color="red" arrowhead=tee]
    ANA_block -> ANA_resp [color="#1565C0"]

    CAN_cent -> CAN_IL1b [label="bind IL-1b" color="#1565C0"]
    CAN_IL1b -> CAN_neut [color="#1565C0"]
    CAN_neut -> IL1b_mat [label="neutralize" color="red" arrowhead=tee penwidth=2]
    CAN_neut -> IL6_acute [label="↓" color="red" arrowhead=tee]
    CAN_neut -> SAA_serum [label="↓" color="#33691E"]
    CAN_neut -> CRP_serum [label="normalize" color="#33691E"]
    CAN_neut -> Attack_freq [label="reduce" color="#33691E"]
    CAN_neut -> CAN_resp [color="#1565C0"]

    RIL_cent -> IL1b_mat [label="trap IL-1" color="red" arrowhead=tee]
    RIL_cent -> IL1Ra [label="IL-1 trap" color="#1565C0"]

    /* =====================================================================
       ADVERSE EVENTS
       ===================================================================== */
    COL_GI_AE    [label="GI Side Effects\nDiarrhea/Nausea\n(COL)" shape=diamond fillcolor="#FFCC80"]
    COL_Myo_AE   [label="Myopathy\nRhabdomyolysis Risk\n(COL + statin)" shape=diamond fillcolor="#FFCC80"]
    CAN_Infec_AE [label="Infection Risk\n(IL-1 blockade)" shape=diamond fillcolor="#FFCC80"]
    ANA_Inj_AE   [label="Injection Site\nReactions (Anakinra)" shape=diamond fillcolor="#FFCC80"]
    Neutropenia_AE [label="Neutropenia\n(Canakinumab)" shape=diamond fillcolor="#FFCC80"]

    COL_gut -> COL_GI_AE [label="dose-dependent" color="orange"]
    COL_leukocyte -> COL_Myo_AE [label="rare risk" color="orange"]
    CAN_neut -> CAN_Infec_AE [label="immunosuppression" color="orange"]
