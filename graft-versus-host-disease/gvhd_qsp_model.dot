digraph GvHD_QSP_Model {
    graph [
        label="Graft-versus-Host Disease (GvHD)\nQuantitative Systems Pharmacology Model\nChronic & Acute GvHD Mechanistic Map",
        labelloc=t, fontsize=22, fontname="Helvetica-Bold",
        bgcolor="#FAFAFA", rankdir=TB, splines=ortho,
        nodesep=0.45, ranksep=0.7, pad=0.5
    ]
    node [fontname="Helvetica", fontsize=10, style=filled, shape=box, margin="0.12,0.06"]
    edge [fontname="Helvetica", fontsize=8, penwidth=1.2]

    // =========================================================
    // CLUSTER 1: HSCT CONTEXT & CONDITIONING
    // =========================================================
    subgraph cluster_HSCT {
        label="Allogeneic HSCT Context & Conditioning"
        style=filled; fillcolor="#E8F4FD"; color="#1A5276"; penwidth=2; fontsize=13; fontname="Helvetica-Bold"

        HSCT_Donor     [label="Donor HSC\nGraft", shape=ellipse, fillcolor="#1A5276", fontcolor=white]
        HSCT_Recipient [label="Recipient\n(Host)", shape=ellipse, fillcolor="#922B21", fontcolor=white]
        Conditioning   [label="Conditioning\nRegimen\n(MAC/RIC/NMA)", fillcolor="#2E86C1", fontcolor=white]
        TBI            [label="Total Body\nIrradiation (TBI)", fillcolor="#5DADE2"]
        Chemo_Cond     [label="High-dose\nChemotherapy\n(Cy/Bu/Flu)", fillcolor="#5DADE2"]
        Tissue_Damage  [label="Host Tissue\nDamage & DAMP\nRelease", fillcolor="#F1948A"]
        Gut_Barrier    [label="Gut Barrier\nDisruption\n(Leaky Gut)", fillcolor="#F1948A"]
        LPS_Transloc   [label="LPS / Microbial\nTranslocation", fillcolor="#F1948A"]
        Allo_MHC       [label="Host Alloantigens\n(MHC I/II mismatch)", fillcolor="#FDEBD0"]
        Minor_HA       [label="Minor\nHistocompatibility\nAntigens (mHA)", fillcolor="#FDEBD0"]
    }

    // =========================================================
    // CLUSTER 2: ANTIGEN PRESENTATION & T CELL PRIMING
    // =========================================================
    subgraph cluster_APC {
        label="Antigen Presentation & T Cell Priming (Phase 1)"
        style=filled; fillcolor="#EBF5FB"; color="#1A5276"; penwidth=2; fontsize=13; fontname="Helvetica-Bold"

        Host_DC        [label="Host Dendritic\nCells (mDC)", shape=hexagon, fillcolor="#2980B9", fontcolor=white]
        Donor_DC       [label="Donor Dendritic\nCells", shape=hexagon, fillcolor="#2980B9", fontcolor=white]
        MHC_II_pep     [label="MHC II:\nPeptide\nComplex", fillcolor="#AED6F1"]
        MHC_I_pep      [label="MHC I:\nPeptide\nComplex", fillcolor="#AED6F1"]
        Direct_Path    [label="Direct Pathway\nAlloreactivity", fillcolor="#5DADE2"]
        Indirect_Path  [label="Indirect Pathway\nAlloreactivity", fillcolor="#5DADE2"]
        TCR_Engage     [label="TCR-MHC\nEngagement\n(Signal 1)", fillcolor="#1A5276", fontcolor=white]
        CD28_B7        [label="CD28-B7\nCo-stimulation\n(Signal 2)", fillcolor="#2471A3", fontcolor=white]
        CD40L_CD40     [label="CD40L-CD40\nInteraction", fillcolor="#2471A3", fontcolor=white]
        IL12_prod      [label="IL-12\nProduction\nby DC", fillcolor="#AED6F1"]
        Type_I_IFN     [label="Type I IFN\nSignaling", fillcolor="#AED6F1"]
        NLRP3          [label="NLRP3\nInflammasome\nActivation", fillcolor="#85C1E9"]
        IL1b_APC       [label="IL-1β Release\nby APC", fillcolor="#85C1E9"]
        IL18_APC       [label="IL-18 Release\nby APC", fillcolor="#85C1E9"]
    }

    // =========================================================
    // CLUSTER 3: DONOR T CELL ACTIVATION & DIFFERENTIATION
    // =========================================================
    subgraph cluster_Tcell {
        label="Donor T Cell Activation & Differentiation"
        style=filled; fillcolor="#FEF9E7"; color="#B7950B"; penwidth=2; fontsize=13; fontname="Helvetica-Bold"

        Naive_CD4      [label="Naive CD4+\nT Cell", shape=ellipse, fillcolor="#F4D03F"]
        Naive_CD8      [label="Naive CD8+\nT Cell", shape=ellipse, fillcolor="#F4D03F"]
        Activated_T    [label="Activated\nT Cell\n(Effector)", shape=ellipse, fillcolor="#E67E22", fontcolor=white]
        Th1_cell       [label="Th1 Cell\n(IFN-γ, TNF-α)", shape=ellipse, fillcolor="#E74C3C", fontcolor=white]
        Th2_cell       [label="Th2 Cell\n(IL-4, IL-13)", shape=ellipse, fillcolor="#F39C12"]
        Th17_cell      [label="Th17 Cell\n(IL-17A, IL-22)", shape=ellipse, fillcolor="#8E44AD", fontcolor=white]
        Treg_cell      [label="Regulatory\nT Cell (Treg)\n(FoxP3+)", shape=ellipse, fillcolor="#27AE60", fontcolor=white]
        CD8_Teff       [label="CD8+ CTL\n(Cytotoxic)", shape=ellipse, fillcolor="#C0392B", fontcolor=white]
        Memory_T       [label="Memory\nT Cell", shape=ellipse, fillcolor="#E59866"]
        Tfh_cell       [label="T Follicular\nHelper (Tfh)", shape=ellipse, fillcolor="#7FB3D3"]

        // Intracellular signaling
        NFAT_path      [label="NFAT Pathway\n(Calcineurin)", fillcolor="#FAD7A0"]
        NFkB_path      [label="NF-κB Pathway", fillcolor="#FAD7A0"]
        STAT4_path     [label="STAT4 Signaling\n(IL-12→Th1)", fillcolor="#FAD7A0"]
        STAT3_path     [label="STAT3 Signaling\n(IL-6/IL-23)", fillcolor="#FAD7A0"]
        mTOR_T         [label="mTOR Complex\n(Proliferation)", fillcolor="#FAD7A0"]
        JAK1_2_T       [label="JAK1/JAK2\nSignaling\n(Cytokine R)", fillcolor="#FDEBD0"]
        ROCK2_path     [label="ROCK2 Pathway\n(Th17/Treg\nBalance)", fillcolor="#FDEBD0"]
        BTK_path       [label="BTK Pathway\n(B cell / T cell)", fillcolor="#FDEBD0"]
    }

    // =========================================================
    // CLUSTER 4: CYTOKINE NETWORK
    // =========================================================
    subgraph cluster_Cytokine {
        label="Cytokine Network & Inflammatory Mediators"
        style=filled; fillcolor="#FDEDEC"; color="#922B21"; penwidth=2; fontsize=13; fontname="Helvetica-Bold"

        TNFa           [label="TNF-α\n(TNFSF2)", shape=diamond, fillcolor="#E74C3C", fontcolor=white]
        IFNg           [label="IFN-γ\n(IFNG)", shape=diamond, fillcolor="#E74C3C", fontcolor=white]
        IL6            [label="IL-6\n(IL6)", shape=diamond, fillcolor="#EC7063"]
        IL17A          [label="IL-17A\n(IL17A)", shape=diamond, fillcolor="#A569BD", fontcolor=white]
        IL22           [label="IL-22\n(IL22)", shape=diamond, fillcolor="#A569BD", fontcolor=white]
        IL2            [label="IL-2\n(IL2)", shape=diamond, fillcolor="#E59866"]
        IL10           [label="IL-10\n(IL10)\n[Anti-inflam]", shape=diamond, fillcolor="#27AE60", fontcolor=white]
        TGFb           [label="TGF-β\n(TGFB1)", shape=diamond, fillcolor="#2E86C1", fontcolor=white]
        IL4            [label="IL-4\n(IL4)", shape=diamond, fillcolor="#F7DC6F"]
        IL13           [label="IL-13\n(IL13)", shape=diamond, fillcolor="#F7DC6F"]
        IL23           [label="IL-23\n(IL23)", shape=diamond, fillcolor="#BFC9CA"]
        IL1b           [label="IL-1β\n(IL1B)", shape=diamond, fillcolor="#EC7063"]
        IL21           [label="IL-21\n(IL21)", shape=diamond, fillcolor="#AED6F1"]
        CXCL10         [label="CXCL10/IP-10\n(T cell chemo)", fillcolor="#F1948A"]
        CCL2_CCL5      [label="CCL2 / CCL5\n(Monocyte chemo)", fillcolor="#F1948A"]
        BAFF           [label="BAFF / APRIL\n(B cell survival)", fillcolor="#AED6F1"]
    }

    // =========================================================
    // CLUSTER 5: TARGET ORGAN - SKIN
    // =========================================================
    subgraph cluster_Skin {
        label="Target Organ: Skin"
        style=filled; fillcolor="#FDF2E9"; color="#D35400"; penwidth=2; fontsize=13; fontname="Helvetica-Bold"

        Skin_T_influx  [label="T Cell Infiltration\nSkin (CXCR3+)", fillcolor="#F0B27A"]
        Keratinocyte   [label="Keratinocyte\nApoptosis\n(Fas/FasL)", fillcolor="#FAD7A0"]
        Dermo_fibro    [label="Dermal\nFibroblast\nActivation", fillcolor="#FDEBD0"]
        Col_skin       [label="Collagen\nDeposition\nSkin", fillcolor="#FDEBD0"]
        mLSS_skin      [label="mLSS Score\n(Lichenoid/\nSclerotic)", fillcolor="#E59866"]
        Epid_damage    [label="Epidermal\nDamage Score", fillcolor="#E59866"]
        Pruritus       [label="Pruritus\n(IL-4/IL-13/SP)", fillcolor="#F8C471"]
        Dyspigment     [label="Dyspigmentation\nMelanocyte Loss", fillcolor="#F8C471"]
    }

    // =========================================================
    // CLUSTER 6: TARGET ORGAN - GUT
    // =========================================================
    subgraph cluster_Gut {
        label="Target Organ: Gastrointestinal Tract"
        style=filled; fillcolor="#EAFAF1"; color="#1E8449"; penwidth=2; fontsize=13; fontname="Helvetica-Bold"

        Gut_T_influx   [label="T Cell Infiltration\nGut (α4β7+)", fillcolor="#A9DFBF"]
        Enterocyte_apo [label="Enterocyte\nApoptosis\n(Caspase-3)", fillcolor="#FAD7A0"]
        Crypt_damage   [label="Crypt Cell\nDamage &\nAblation", fillcolor="#FAD7A0"]
        Goblet_loss    [label="Goblet Cell\nDepletion\n(Mucin loss)", fillcolor="#A9DFBF"]
        Gut_leak2      [label="Gut Barrier\nBreakdown\n(Phase 2 GvHD)", fillcolor="#F1948A"]
        Diarrhea       [label="Secretory\nDiarrhea\n(Stool vol)", fillcolor="#7DCEA0"]
        GI_bleeding    [label="GI Bleeding\n(Hematochezia)", fillcolor="#F1948A"]
        GI_GvHD_grade  [label="GI GvHD\nGrade (I-IV)", fillcolor="#27AE60", fontcolor=white]
        Gut_microbiome [label="Gut Microbiome\nDysbiosis\n(Enterococcus↑)", fillcolor="#A9DFBF"]
    }

    // =========================================================
    // CLUSTER 7: TARGET ORGAN - LIVER
    // =========================================================
    subgraph cluster_Liver {
        label="Target Organ: Liver"
        style=filled; fillcolor="#EBF5FB"; color="#1B4F72"; penwidth=2; fontsize=13; fontname="Helvetica-Bold"

        Liver_T_influx [label="T Cell Infiltration\nPortal Tract", fillcolor="#AED6F1"]
        Bile_duct_dmg  [label="Bile Duct\nEpithelial\nDamage", fillcolor="#AED6F1"]
        Cholestasis    [label="Cholestasis\n(Bile Stasis)", fillcolor="#5DADE2", fontcolor=white]
        Bili_rise      [label="Bilirubin\nElevation\n(>2 mg/dL)", fillcolor="#F8C471"]
        ALP_rise       [label="ALP / GGT\nElevation", fillcolor="#F8C471"]
        ALT_rise       [label="ALT / AST\nElevation", fillcolor="#F8C471"]
        Liver_fibr     [label="Hepatic\nFibrosis\n(TGF-β driven)", fillcolor="#5DADE2", fontcolor=white]
        Liver_GvHD_gr  [label="Liver GvHD\nGrade (I-IV)", fillcolor="#1B4F72", fontcolor=white]
    }

    // =========================================================
    // CLUSTER 8: TARGET ORGAN - LUNG
    // =========================================================
    subgraph cluster_Lung {
        label="Target Organ: Lung (Bronchiolitis Obliterans)"
        style=filled; fillcolor="#F4ECF7"; color="#6C3483"; penwidth=2; fontsize=13; fontname="Helvetica-Bold"

        Lung_T_influx  [label="T Cell Infiltration\nBronchial Epithelium", fillcolor="#D7BDE2"]
        Airway_inflam  [label="Airway\nInflammation\n(Neutrophil/Mac)", fillcolor="#D7BDE2"]
        BO_lesion      [label="Bronchiolitis\nObliterans Syndrome\n(BOS)", fillcolor="#8E44AD", fontcolor=white]
        FEV1_decline   [label="FEV1 Decline\n(Spirometry)", fillcolor="#D7BDE2"]
        CLAD_score     [label="Lung GvHD\nScore (BOS/RADS)", fillcolor="#8E44AD", fontcolor=white]
        Lung_fibr      [label="Pulmonary\nFibrosis\n(TGF-β driven)", fillcolor="#D7BDE2"]
        Hypox          [label="Hypoxemia\n(SpO2 decline)", fillcolor="#D7BDE2"]
    }

    // =========================================================
    // CLUSTER 9: B CELL PATHOLOGY (CHRONIC GvHD)
    // =========================================================
    subgraph cluster_Bcell {
        label="B Cell Dysregulation (Chronic GvHD)"
        style=filled; fillcolor="#E8F8F5"; color="#0E6655"; penwidth=2; fontsize=13; fontname="Helvetica-Bold"

        Naive_B        [label="Naive B Cell", shape=ellipse, fillcolor="#48C9B0"]
        Trans_B        [label="Transitional\nB Cell", shape=ellipse, fillcolor="#48C9B0"]
        Mem_B          [label="Memory B Cell\n(CD27+)", shape=ellipse, fillcolor="#17A589", fontcolor=white]
        Plasma_B       [label="Plasma Cell\n(Ab-producing)", shape=ellipse, fillcolor="#0E6655", fontcolor=white]
        Breg_cell      [label="Regulatory\nB Cell (Breg)\n(IL-10+)", shape=ellipse, fillcolor="#27AE60", fontcolor=white]
        AutoAb         [label="Autoantibodies\n(anti-dsDNA, PDGFR,\nplatelet glycoprotein)", fillcolor="#F1948A"]
        IgG_dysreg     [label="IgG\nDysregulation\n(Hypogamma)", fillcolor="#F1948A"]
        BTK_B          [label="BTK Activation\nB Cell Signaling", fillcolor="#ABEBC6"]
        GC_reaction    [label="Germinal Center\nReaction\n(Tfh-B interaction)", fillcolor="#76D7C4"]
    }

    // =========================================================
    // CLUSTER 10: FIBROSIS PATHWAY (TGF-β / ROCK)
    // =========================================================
    subgraph cluster_Fibrosis {
        label="Fibrosis Pathways (TGF-β / ROCK2 / EMT)"
        style=filled; fillcolor="#F2F3F4"; color="#566573"; penwidth=2; fontsize=13; fontname="Helvetica-Bold"

        TGFb_R1_R2    [label="TGFβR1/R2\nReceptor Complex", fillcolor="#ABB2B9"]
        SMAD23        [label="SMAD2/3\nPhosphorylation", fillcolor="#808B96"]
        SMAD4         [label="SMAD4\nCoSMAD", fillcolor="#808B96"]
        EMT           [label="Epithelial-\nMesenchymal\nTransition (EMT)", fillcolor="#566573", fontcolor=white]
        Fibro_activ   [label="Fibroblast\nActivation\n(Myofibroblast)", fillcolor="#566573", fontcolor=white]
        Col1_3_prod   [label="Collagen I/III\nProduction", fillcolor="#ABB2B9"]
        MMP_TIMP      [label="MMP/TIMP\nImbalance\n(ECM remodeling)", fillcolor="#ABB2B9"]
        ROCK2_signal  [label="ROCK2\nActivation\n(Downstream RhoA)", fillcolor="#7F8C8D"]
        IRF4_path     [label="IRF4 Regulation\n(Th17/Treg balance)", fillcolor="#7F8C8D"]
        Platelet_TGF  [label="Platelet-derived\nTGF-β Release", fillcolor="#ABB2B9"]
    }

    // =========================================================
    // CLUSTER 11: DRUG PK - CNI (Calcineurin Inhibitors)
    // =========================================================
    subgraph cluster_PK_CNI {
        label="Drug PK: Calcineurin Inhibitors (CsA / Tacrolimus)"
        style=filled; fillcolor="#EBF5FB"; color="#1F618D"; penwidth=2; fontsize=13; fontname="Helvetica-Bold"

        CsA_Dose       [label="CsA Dose\n(Cyclosporine A)\n3-5 mg/kg/day PO", shape=parallelogram, fillcolor="#2E86C1", fontcolor=white]
        CsA_gut        [label="CsA Gut\nAbsorption\n(F~30%)", fillcolor="#5DADE2"]
        CsA_central    [label="CsA Central\nCompartment\n(Blood conc.)", fillcolor="#5DADE2"]
        CsA_periph     [label="CsA Peripheral\nCompartment\n(Tissue)", fillcolor="#85C1E9"]
        CsA_CYP3A4     [label="CYP3A4\nMetabolism\n(Hepatic)", fillcolor="#AED6F1"]
        CsA_PGP        [label="P-gp Efflux\nTransporter", fillcolor="#AED6F1"]
        CsA_trough     [label="CsA Trough\n(C0: 100-300 ng/mL)", fillcolor="#D6EAF8"]

        TAC_Dose       [label="Tacrolimus Dose\n0.03 mg/kg/day PO", shape=parallelogram, fillcolor="#1A5276", fontcolor=white]
        TAC_gut        [label="TAC Gut\nAbsorption\n(F~25%)", fillcolor="#2471A3", fontcolor=white]
        TAC_central    [label="TAC Central\nCompartment", fillcolor="#2471A3", fontcolor=white]
        TAC_CYP3A5     [label="CYP3A5\nGenotype\nMetabolism", fillcolor="#5DADE2"]
        TAC_trough     [label="TAC Trough\n(C0: 5-15 ng/mL)", fillcolor="#85C1E9"]

        CN_inhib       [label="Calcineurin\nInhibition\n(Imax model)", fillcolor="#FAD7A0"]
        NFAT_block     [label="NFAT Nuclear\nTranslocation\nBlocked", fillcolor="#FAD7A0"]
        IL2_block      [label="IL-2 Transcription\nBlocked", fillcolor="#FAD7A0"]
    }

    // =========================================================
    // CLUSTER 12: DRUG PK/PD - JAK INHIBITOR (Ruxolitinib)
    // =========================================================
    subgraph cluster_PK_JAKi {
        label="Drug PK/PD: Ruxolitinib (JAK1/2 Inhibitor)"
        style=filled; fillcolor="#FEF9E7"; color="#B7950B"; penwidth=2; fontsize=13; fontname="Helvetica-Bold"

        Rux_Dose       [label="Ruxolitinib Dose\n10 mg BID PO", shape=parallelogram, fillcolor="#D4AC0D", fontcolor=white]
        Rux_central    [label="Rux Central\nCompartment\n(Vd~72 L)", fillcolor="#F9E79F"]
        Rux_periph     [label="Rux Peripheral\nCompartment", fillcolor="#FCF3CF"]
        Rux_CYP3A4     [label="Rux CYP3A4\nMetabolism\n(T½~3h)", fillcolor="#FDEBD0"]
        Rux_JAK1       [label="JAK1 Inhibition\n(Ki~3.3 nM)", fillcolor="#F4D03F"]
        Rux_JAK2       [label="JAK2 Inhibition\n(Ki~2.8 nM)", fillcolor="#F4D03F"]
        STAT5_block    [label="STAT5\nPhosphorylation\nBlocked", fillcolor="#F8C471"]
        STAT3_block    [label="STAT3\nPhosphorylation\nBlocked", fillcolor="#F8C471"]
        Treg_expan_rux [label="Treg Expansion\n(Ruxolitinib effect)", fillcolor="#ABEBC6"]
        Th17_suppress  [label="Th17 Suppression\n(Ruxolitinib effect)", fillcolor="#85C1E9"]
    }

    // =========================================================
    // CLUSTER 13: OTHER DRUGS (Steroids, Belumosudil, MMF)
    // =========================================================
    subgraph cluster_OtherDrugs {
        label="Other Drugs: Steroids, Belumosudil, MMF, Ibrutinib"
        style=filled; fillcolor="#FDEDEC"; color="#922B21"; penwidth=2; fontsize=13; fontname="Helvetica-Bold"

        Pred_Dose      [label="Prednisone Dose\n1 mg/kg/day PO\n(first-line)", shape=parallelogram, fillcolor="#C0392B", fontcolor=white]
        Pred_central   [label="Pred Central\n(MePred equiv.)", fillcolor="#EC7063"]
        GR_binding     [label="Glucocorticoid\nReceptor Binding\n(GRα)", fillcolor="#F1948A"]
        NFkB_inhib_GC  [label="NF-κB\nInhibition\n(GC)", fillcolor="#F1948A"]
        Cytokine_supp  [label="Broad Cytokine\nSuppression", fillcolor="#F8C471"]

        Belu_Dose      [label="Belumosudil\n200 mg QD PO\n(ROCK2i)", shape=parallelogram, fillcolor="#6C3483", fontcolor=white]
        Belu_central   [label="Belu Central\n(T½~20h)", fillcolor="#A569BD", fontcolor=white]
        ROCK2_inhib    [label="ROCK2 Selective\nInhibition\n(Belu)", fillcolor="#D7BDE2"]
        IRF4_suppres   [label="IRF4/STAT3\nSuppression\n(Belu)", fillcolor="#D7BDE2"]

        MMF_Dose       [label="MMF Dose\n1.5 g BID PO", shape=parallelogram, fillcolor="#17A589", fontcolor=white]
        MPA_active     [label="MPA (Active)\nIMPDH Inhibition", fillcolor="#48C9B0"]
        Prolif_block   [label="Lymphocyte\nProliferation\nBlocked", fillcolor="#76D7C4"]

        Ibru_Dose      [label="Ibrutinib\n420 mg QD PO\n(BTKi)", shape=parallelogram, fillcolor="#2E86C1", fontcolor=white]
        BTK_inhib_drug [label="BTK Covalent\nInhibition", fillcolor="#5DADE2"]
    }

    // =========================================================
    // CLUSTER 14: CLINICAL ENDPOINTS & BIOMARKERS
    // =========================================================
    subgraph cluster_Endpoints {
        label="Clinical Endpoints & Biomarkers"
        style=filled; fillcolor="#F0F3F4"; color="#1C2833"; penwidth=2; fontsize=13; fontname="Helvetica-Bold"

        Overall_GvHD   [label="Overall GvHD\nResponse\n(CR/PR/NR)", shape=ellipse, fillcolor="#1C2833", fontcolor=white]
        Glucksberg_gr  [label="Glucksberg\nGrade (I-IV)\nAcute GvHD", fillcolor="#2C3E50", fontcolor=white]
        NIH_cGvHD      [label="NIH Global\ncGvHD Score\n(Mild/Mod/Severe)", fillcolor="#2C3E50", fontcolor=white]
        Lee_score      [label="Lee Symptom\nScale (LSS)", fillcolor="#566573", fontcolor=white]
        ORR            [label="Overall Response\nRate (ORR)", fillcolor="#1ABC9C", fontcolor=white]
        FFS            [label="Failure-Free\nSurvival (FFS)", fillcolor="#1ABC9C", fontcolor=white]
        OS             [label="Overall\nSurvival (OS)", fillcolor="#27AE60", fontcolor=white]
        NRM            [label="Non-Relapse\nMortality (NRM)", fillcolor="#E74C3C", fontcolor=white]
        Relapse_rate   [label="Relapse Rate\n(GvL balance)", fillcolor="#E74C3C", fontcolor=white]
        KPS            [label="Karnofsky\nPerformance\nStatus (KPS)", fillcolor="#85C1E9"]

        // Lab biomarkers
        ST2_bio        [label="ST2 (IL-33 R)\nGI GvHD biomarker\n(>35 ng/mL)", fillcolor="#F8C471"]
        Reg3a_bio      [label="REG3α\nGI Epithelial\nBiomarker", fillcolor="#F8C471"]
        TNFR1_bio      [label="sTNFR1\nSkin/Systemic\nBiomarker", fillcolor="#F8C471"]
        IL2Ra_bio      [label="sCD25/sIL2Rα\nT cell activation", fillcolor="#F8C471"]
        Elafin_bio     [label="Elafin\nSkin/Lung\nBiomarker", fillcolor="#F8C471"]
        CXCL9_bio      [label="CXCL9\nT Cell Homing\nBiomarker", fillcolor="#F8C471"]
    }

    // =========================================================
    // EDGES: HSCT Context
    // =========================================================
    HSCT_Donor -> Activated_T [label="Donor T cells\nengrafted"]
    HSCT_Donor -> Naive_B [label="Donor B cells"]
    Conditioning -> TBI
    Conditioning -> Chemo_Cond
    TBI -> Tissue_Damage [color=red]
    Chemo_Cond -> Tissue_Damage [color=red]
    Tissue_Damage -> Gut_Barrier [color=red]
    Gut_Barrier -> LPS_Transloc [color=red]
    LPS_Transloc -> NLRP3 [color=red]
    NLRP3 -> IL1b_APC
    NLRP3 -> IL18_APC
    Tissue_Damage -> Host_DC [label="DAMP activation"]
    HSCT_Recipient -> Allo_MHC
    HSCT_Recipient -> Minor_HA

    // APC / Priming
    Allo_MHC -> Host_DC
    Minor_HA -> Host_DC
    Allo_MHC -> MHC_II_pep
    Allo_MHC -> MHC_I_pep
    Host_DC -> Direct_Path
    Donor_DC -> Indirect_Path
    Direct_Path -> TCR_Engage
    Indirect_Path -> TCR_Engage
    MHC_II_pep -> TCR_Engage
    MHC_I_pep -> TCR_Engage
    TCR_Engage -> NFAT_path
    TCR_Engage -> NFkB_path
    CD28_B7 -> NFAT_path [label="Signal 2"]
    CD28_B7 -> NFkB_path
    CD40L_CD40 -> Host_DC [label="T-DC\ncrosstalk"]
    Host_DC -> IL12_prod
    IL1b_APC -> Naive_CD4 [label="IL-1β stim"]
    IL18_APC -> Th1_cell [label="IL-18 stim"]
    IL12_prod -> STAT4_path
    LPS_Transloc -> Type_I_IFN
    Type_I_IFN -> Host_DC [label="IFN maturation"]

    // T cell differentiation
    Naive_CD4 -> NFAT_path
    Naive_CD8 -> NFAT_path
    NFAT_path -> IL2
    NFAT_path -> Activated_T
    NFkB_path -> Activated_T
