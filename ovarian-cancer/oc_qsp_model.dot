digraph OvarianCancer_QSP {
  graph [
    layout=fdp, K=1.2, splines=true, overlap=false,
    fontname="Helvetica", fontsize=11, bgcolor="#FAFAFA",
    label="난소암 (Ovarian Cancer) QSP 기계론적 지도\nHigh-Grade Serous Ovarian Carcinoma (HGSOC) · v1.0 · 2026-06-24\n10 clusters · 180+ nodes · PARPi / Platinum / Bevacizumab / ICI",
    labelloc=t, labeljust=c
  ];
  node [shape=box, style="filled,rounded", fontname="Helvetica", fontsize=8, margin="0.05,0.03"];
  edge [fontname="Helvetica", fontsize=7, arrowsize=0.65];

  // ============================================================
  // Cluster 1: DNA 손상반응 / BRCA 경로 (DDR / HRR)
  // ============================================================
  subgraph cluster_DDR {
    label="① DNA 손상반응 / BRCA-HRR 경로\n(DDR / Homologous Recombination Repair)";
    style=filled; fillcolor="#FFE4E1"; color="#C0392B";
    fontsize=9; fontcolor="#C0392B";

    BRCA1      [label="BRCA1\n(HRR gene)", fillcolor="#FF6B6B"];
    BRCA2      [label="BRCA2\n(HRR gene)", fillcolor="#FF6B6B"];
    PALB2      [label="PALB2\n(BRCA2 bridge)", fillcolor="#FFB3B3"];
    RAD51      [label="RAD51\n(recombinase)", fillcolor="#FF8C8C"];
    RAD52      [label="RAD52\n(backup HRR)", fillcolor="#FFB3B3"];
    RPA        [label="RPA\n(ssDNA binding)", fillcolor="#FFB3B3"];
    DSB        [label="DSBs\n(Double-Strand Breaks)", fillcolor="#FF8C8C"];
    SSB        [label="SSBs\n(Single-Strand Breaks)", fillcolor="#FFAAAA"];
    HRD_score  [label="HRD Score\n(≥42 = HRD positive)", fillcolor="#E74C3C", fontcolor=white];
    NHEJ       [label="NHEJ\n(error-prone backup)", fillcolor="#FFCCCC"];
    NER        [label="NER\n(nucleotide excision)", fillcolor="#FFCCCC"];
    ATM        [label="ATM\n(DDR kinase)", fillcolor="#FFB3B3"];
    ATR        [label="ATR\n(DDR kinase)", fillcolor="#FFB3B3"];
    CHK1       [label="CHK1\n(checkpoint kinase)", fillcolor="#FFB3B3"];
    CHK2       [label="CHK2\n(checkpoint kinase)", fillcolor="#FFB3B3"];
    TP53       [label="TP53\n(mutated in 96% HGSOC)", fillcolor="#C0392B", fontcolor=white];
    p21        [label="p21/CDKN1A\n(CDK inhibitor)", fillcolor="#FFCCCC"];
    PARP1      [label="PARP1\n(poly-ADP-ribosylation)", fillcolor="#FF7F7F"];
    PARP2      [label="PARP2\n(poly-ADP-ribosylation)", fillcolor="#FF7F7F"];
    PAR_chain  [label="PAR chain\n(DNA repair scaffold)", fillcolor="#FFB3B3"];
    XRCC1      [label="XRCC1\n(BER scaffold)", fillcolor="#FFCCCC"];
    repl_fork  [label="Replication Fork\n(stalled / collapsed)", fillcolor="#FFAAAA"];
    BRCAness   [label="BRCAness\n(HRD-like phenotype)", fillcolor="#FFB3B3"];
    EMSY       [label="EMSY\n(BRCA2 silencer)", fillcolor="#FFCCCC"];
    FANCA      [label="FANCA/FANCD2\n(Fanconi pathway)", fillcolor="#FFCCCC"];
  }

  // ============================================================
  // Cluster 2: PI3K / AKT / mTOR / MAPK 경로
  // ============================================================
  subgraph cluster_PI3K {
    label="② PI3K / AKT / mTOR / MAPK 경로\n(Proliferation & Survival Signaling)";
    style=filled; fillcolor="#E8F5E9"; color="#2E7D32";
    fontsize=9; fontcolor="#2E7D32";

    PIK3CA   [label="PIK3CA\n(PI3K cat. subunit)", fillcolor="#A5D6A7"];
    PTEN     [label="PTEN\n(tumor suppressor)", fillcolor="#A5D6A7"];
    PIP2     [label="PIP2\n(PI substrate)", fillcolor="#C8E6C9"];
    PIP3     [label="PIP3\n(second messenger)", fillcolor="#81C784"];
    AKT1     [label="AKT/PKB\n(serine-threonine kinase)", fillcolor="#4CAF50"];
    mTOR_c   [label="mTOR", fillcolor="#2E7D32", fontcolor=white];
    mTORC1   [label="mTORC1\n(RAPTOR complex)", fillcolor="#1B5E20", fontcolor=white];
    mTORC2   [label="mTORC2\n(RICTOR complex)", fillcolor="#1B5E20", fontcolor=white];
    S6K1     [label="p70 S6K1\n(protein synthesis)", fillcolor="#A5D6A7"];
    eIF4EBP1 [label="4EBP1\n(translation initiation)", fillcolor="#A5D6A7"];
    GSK3B    [label="GSK3β\n(glycogen synthesis)", fillcolor="#A5D6A7"];
    FOXO3    [label="FOXO3\n(pro-apoptotic TF)", fillcolor="#A5D6A7"];
    autophagy [label="Autophagy\n(survival/resistance)", fillcolor="#C8E6C9"];
    Everolimus [label="Everolimus\n(mTOR inhibitor)", fillcolor="#1B5E20", fontcolor=white, shape=diamond];
    RAS_gtp  [label="RAS (GTPase)\n(KRAS/NRAS/HRAS)", fillcolor="#81C784"];
    RAF_k    [label="RAF\n(MAPKK kinase)", fillcolor="#81C784"];
    MEK_k    [label="MEK1/2\n(ERK kinase)", fillcolor="#81C784"];
    ERK_k    [label="ERK1/2\n(proliferation MAPK)", fillcolor="#4CAF50"];
    EGFR_r   [label="EGFR/ErbB1\n(RTK)", fillcolor="#A5D6A7"];
    HER2_r   [label="HER2/ErbB2\n(RTK)", fillcolor="#A5D6A7"];
    CCND1    [label="Cyclin D1\n(G1 cell cycle)", fillcolor="#C8E6C9"];
    CDK46    [label="CDK4/6\n(G1/S kinase)", fillcolor="#C8E6C9"];
    RB1_p    [label="RB1\n(tumor suppressor)", fillcolor="#A5D6A7"];
    E2F_tf   [label="E2F\n(S-phase TF)", fillcolor="#81C784"];
  }

  // ============================================================
  // Cluster 3: VEGF / 혈관신생 (Angiogenesis)
  // ============================================================
  subgraph cluster_VEGF {
    label="③ VEGF / 혈관신생\n(Tumor Angiogenesis)";
    style=filled; fillcolor="#E8EAF6"; color="#283593";
    fontsize=9; fontcolor="#283593";

    HIF1A    [label="HIF-1α\n(hypoxia-inducible factor)", fillcolor="#9FA8DA"];
    HIF2A    [label="HIF-2α\n(EPAS1)", fillcolor="#9FA8DA"];
    VHL      [label="VHL\n(HIF ubiquitination)", fillcolor="#C5CAE9"];
    VEGFA    [label="VEGF-A\n(165/121 isoforms)", fillcolor="#7986CB"];
    VEGFB    [label="VEGF-B\n(vessel survival)", fillcolor="#9FA8DA"];
    VEGFC    [label="VEGF-C\n(lymphangiogenesis)", fillcolor="#9FA8DA"];
    VEGFR1   [label="VEGFR1/FLT1\n(decoy receptor)", fillcolor="#5C6BC0"];
    VEGFR2   [label="VEGFR2/KDR\n(main signaling)", fillcolor="#283593", fontcolor=white];
    PlGF_m   [label="PlGF\n(placental GF)", fillcolor="#9FA8DA"];
    Nrp1     [label="Neuropilin-1\n(VEGF co-receptor)", fillcolor="#9FA8DA"];
    endo_cell [label="Endothelial Cells\n(tip / stalk)", fillcolor="#7986CB"];
    pericyte [label="Pericytes\n(vessel stabilization)", fillcolor="#9FA8DA"];
    DLL4_n   [label="DLL4/Notch\n(tip cell selection)", fillcolor="#9FA8DA"];
    tumor_vasc [label="Tumor Vasculature\n(abnormal / leaky)", fillcolor="#3949AB", fontcolor=white];
    O2_delivery [label="O2 & Drug Delivery\n(perfusion)", fillcolor="#C5CAE9"];
    Bevacizumab [label="Bevacizumab\n(anti-VEGF mAb, 15mg/kg q3w)", fillcolor="#1A237E", fontcolor=white, shape=diamond];
    PDGF_b   [label="PDGF-B\n(pericyte recruitment)", fillcolor="#9FA8DA"];
    Ang12    [label="Ang-1/Ang-2\n(vessel remodeling)", fillcolor="#9FA8DA"];
    Tie2_r   [label="Tie2\n(angiopoietin receptor)", fillcolor="#9FA8DA"];
    hypoxia  [label="Tumor Hypoxia\n(pO2 <2mmHg)", fillcolor="#7986CB"];
  }

  // ============================================================
  // Cluster 4: 종양 미세환경 (Tumor Microenvironment)
  // ============================================================
  subgraph cluster_TME {
    label="④ 종양 미세환경\n(Tumor Microenvironment, TME)";
    style=filled; fillcolor="#FFF3E0"; color="#BF360C";
    fontsize=9; fontcolor="#BF360C";

    CAF      [label="CAFs\n(cancer-assoc. fibroblasts)", fillcolor="#FFB74D"];
    TAM_m2   [label="TAM (M2)\n(immunosuppressive)", fillcolor="#FFA726"];
    TAM_m1   [label="TAM (M1)\n(anti-tumor)", fillcolor="#FFCC02"];
    MDSC     [label="MDSCs\n(myeloid-derived suppressors)", fillcolor="#FF8A65"];
    NK_cell  [label="NK Cells\n(cytotoxic)", fillcolor="#66BB6A"];
    CD8T_eff [label="CD8+ T cells\n(effector CTL)", fillcolor="#43A047"];
    CD4T_h   [label="CD4+ T cells\n(helper)", fillcolor="#66BB6A"];
    Treg_c   [label="Tregs\n(immunosuppressive)", fillcolor="#FFA726"];
    B_cell   [label="B cells / TLS\n(antibody, tertiary lymphoid)", fillcolor="#A5D6A7"];
    IL6_c    [label="IL-6\n(pleiotropic cytokine)", fillcolor="#FF8A65"];
    IL10_c   [label="IL-10\n(anti-inflammatory)", fillcolor="#FF8A65"];
    TGFb_c   [label="TGF-β\n(immunosuppression / fibrosis)", fillcolor="#FF8A65"];
    TNFa_c   [label="TNF-α\n(inflammatory)", fillcolor="#FF8A65"];
    IFNg     [label="IFN-γ\n(anti-tumor cytokine)", fillcolor="#FFCA28"];
    MMP2     [label="MMP-2\n(matrix remodeling)", fillcolor="#FFB74D"];
    MMP9     [label="MMP-9\n(matrix remodeling)", fillcolor="#FFB74D"];
    TIMP12   [label="TIMP-1/2\n(MMP inhibitor)", fillcolor="#FFCCBC"];
    ECM_m    [label="ECM\n(extracellular matrix)", fillcolor="#FFCCBC"];
    ascites  [label="Ascites\n(peritoneal fluid accumulation)", fillcolor="#FF8A65"];
    LPA_m    [label="LPA\n(lysophosphatidic acid)", fillcolor="#FF7043"];
    STAT3    [label="STAT3\n(oncogenic TF)", fillcolor="#BF360C", fontcolor=white];
    NFkB     [label="NF-κB\n(inflammatory TF)", fillcolor="#BF360C", fontcolor=white];
    IL8_c    [label="IL-8/CXCL8\n(neutrophil recruit)", fillcolor="#FF8A65"];
    CXCL12   [label="CXCL12/SDF-1\n(homing chemokine)", fillcolor="#FF8A65"];
  }

  // ============================================================
  // Cluster 5: 면역회피 (Immune Evasion)
  // ============================================================
  subgraph cluster_immune {
    label="⑤ 면역회피 / 면역관문\n(Immune Evasion & Checkpoint)";
    style=filled; fillcolor="#F3E5F5"; color="#4A148C";
    fontsize=9; fontcolor="#4A148C";

    PDL1     [label="PD-L1\n(CD274)", fillcolor="#CE93D8"];
    PDL2     [label="PD-L2\n(CD273)", fillcolor="#E1BEE7"];
    PD1_r    [label="PD-1\n(CD279, T cell)", fillcolor="#CE93D8"];
    CTLA4    [label="CTLA-4\n(immune checkpoint)", fillcolor="#CE93D8"];
    CD28_r   [label="CD28\n(co-stimulatory receptor)", fillcolor="#E1BEE7"];
    B71_72   [label="B7-1/B7-2\n(CD80/CD86)", fillcolor="#E1BEE7"];
    IDO1     [label="IDO1\n(tryptophan catabolism)", fillcolor="#CE93D8"];
    Kynuren  [label="Kynurenine\n(immunosuppressive)", fillcolor="#E1BEE7"];
    MHC1     [label="MHC class I\n(antigen presentation)", fillcolor="#CE93D8"];
    neoAg    [label="Neoantigen\n(tumor mutational burden)", fillcolor="#BA68C8"];
    T_exhaust [label="T cell Exhaustion\n(chronic stimulation)", fillcolor="#AB47BC"];
    LAG3     [label="LAG-3\n(immune checkpoint)", fillcolor="#CE93D8"];
    TIM3_r   [label="TIM-3\n(exhaustion marker)", fillcolor="#CE93D8"];
    TIGIT    [label="TIGIT\n(T cell inhibition)", fillcolor="#CE93D8"];
    FoxP3    [label="FoxP3\n(Treg master TF)", fillcolor="#CE93D8"];
    Pembrolizumab [label="Pembrolizumab\n(anti-PD-1 mAb)", fillcolor="#4A148C", fontcolor=white, shape=diamond];
    Nivolumab [label="Nivolumab\n(anti-PD-1 mAb)", fillcolor="#4A148C", fontcolor=white, shape=diamond];
    Ipilimumab [label="Ipilimumab\n(anti-CTLA-4 mAb)", fillcolor="#4A148C", fontcolor=white, shape=diamond];
    Durvalumab [label="Durvalumab\n(anti-PD-L1 mAb)", fillcolor="#4A148C", fontcolor=white, shape=diamond];
    TLS_score [label="TLS\n(tertiary lymphoid structures)", fillcolor="#CE93D8"];
  }

  // ============================================================
  // Cluster 6: 복막 전이 / 병기 (Peritoneal Dissemination)
  // ============================================================
  subgraph cluster_peritoneal {
    label="⑥ 복막 전이 / 종양 전파\n(Peritoneal Dissemination & Staging)";
    style=filled; fillcolor="#E0F2F1"; color="#004D40";
    fontsize=9; fontcolor="#004D40";

    primary_OC  [label="Primary OC\n(ovary / fallopian tube)", fillcolor="#80CBC4"];
    cell_exfol  [label="Cell Exfoliation\n(active shedding)", fillcolor="#80CBC4"];
    meso_cell   [label="Mesothelial Cells\n(peritoneal lining)", fillcolor="#80CBC4"];
    CA125_node  [label="CA-125 / MUC16\n(glycoprotein biomarker)", fillcolor="#26A69A"];
    HE4_node    [label="HE4/WFDC2\n(secondary biomarker)", fillcolor="#26A69A"];
    integrin_n  [label="Integrin α5β1\n(adhesion to mesothelium)", fillcolor="#80CBC4"];
    omentum_m   [label="Omentum\n(metastatic niche)", fillcolor="#4DB6AC"];
    pelvic_imp  [label="Pelvic Implants\n(peritoneal seeding)", fillcolor="#4DB6AC"];
    liver_surf  [label="Liver Surface\n(capsular metastasis)", fillcolor="#4DB6AC"];
    retroperi_LN [label="Retroperitoneal LN\n(nodal spread)", fillcolor="#4DB6AC"];
    EpCAM_m     [label="EpCAM\n(epithelial marker)", fillcolor="#80CBC4"];
    Ecad        [label="E-cadherin\n(epithelial adhesion)", fillcolor="#80CBC4"];
    Ncad        [label="N-cadherin\n(mesenchymal marker)", fillcolor="#80CBC4"];
    EMT_proc    [label="EMT Process\n(plasticity)", fillcolor="#00897B", fontcolor=white];
    spheroids   [label="Tumor Spheroids\n(anchorage-independent)", fillcolor="#80CBC4"];
    LPAR1_r     [label="LPA-R1/3\n(LPA receptor)", fillcolor="#80CBC4"];
    FIGO_stage  [label="FIGO Stage\n(I–IV)", fillcolor="#00695C", fontcolor=white];
    debulk_R    [label="Cytoreductive Surgery\n(R0/R1/R2)", fillcolor="#00897B", fontcolor=white];
    BRCA_germ   [label="Germline BRCA1/2\n(hereditary ~15%)", fillcolor="#80CBC4"];
    somatic_mut [label="Somatic HRR Mutations\n(RAD51C, PALB2, etc.)", fillcolor="#80CBC4"];
  }

  // ============================================================
  // Cluster 7: 백금계 항암제 PK/PD (Platinum Chemotherapy)
  // ============================================================
  subgraph cluster_platinum {
    label="⑦ 백금계 항암제 PK/PD\n(Platinum-Taxane Chemotherapy)";
    style=filled; fillcolor="#FFF8E1"; color="#E65100";
    fontsize=9; fontcolor="#E65100";

    Carbo_dose  [label="Carboplatin\n(AUC 5–6 q3w IV)", fillcolor="#FFE082", shape=diamond];
    Pacli_dose  [label="Paclitaxel\n(175 mg/m² q3w 3h IV)", fillcolor="#FFE082", shape=diamond];
    Cisp_dose   [label="Cisplatin\n(75 mg/m² q3w)", fillcolor="#FFE082", shape=diamond];
    GFR_val     [label="GFR (mL/min)\n(Calvert formula AUC=Dose/(GFR+25))", fillcolor="#FFF9C4"];
    CAR_C1      [label="Carboplatin\n(central PK)", fillcolor="#FFC107"];
    CAR_C2      [label="Carboplatin\n(peripheral PK)", fillcolor="#FFC107"];
    PAC_C1      [label="Paclitaxel\n(central PK)", fillcolor="#FF8F00"];
    PAC_C2      [label="Paclitaxel\n(peripheral PK)", fillcolor="#FF8F00"];
    PAC_C3      [label="Paclitaxel\n(deep peripheral PK)", fillcolor="#FF8F00"];
    Pt_DNA_ad   [label="Pt-DNA Adducts\n(intra-strand cross-links)", fillcolor="#E65100", fontcolor=white];
    G2M_arrest  [label="G2/M Arrest\n(paclitaxel microtubule)", fillcolor="#FFB300"];
    MDR1_t      [label="MDR1/ABCB1\n(P-gp efflux)", fillcolor="#FFCA28"];
    ABCG2_t     [label="ABCG2/BCRP\n(efflux transporter)", fillcolor="#FFCA28"];
    GST_pi      [label="GST-π\n(platinum detoxification)", fillcolor="#FFCA28"];
    CTR1_t      [label="CTR1\n(copper transporter / Pt uptake)", fillcolor="#FFCA28"];
    OCT2_t      [label="OCT2\n(organic cation transporter)", fillcolor="#FFCA28"];
    chemo_apop  [label="Chemotherapy-Induced\nApoptosis", fillcolor="#BF360C", fontcolor=white];
    Pt_resist   [label="Platinum Resistance\n(multifactorial)", fillcolor="#FF6F00", fontcolor=white];
    plat_adduct_repair [label="Pt-Adduct Repair\n(NER / BER)", fillcolor="#FFCA28"];
    neoadj_NACT [label="Neoadjuvant Chemo (NACT)\n(3 cycles pre-op)", fillcolor="#FFE082"];
  }

  // ============================================================
  // Cluster 8: PARP 억제제 PK/PD (PARP Inhibitors)
  // ============================================================
  subgraph cluster_PARPi {
    label="⑧ PARP 억제제 PK/PD\n(PARP Inhibitor Therapy)";
    style=filled; fillcolor="#FCE4EC"; color="#880E4F";
    fontsize=9; fontcolor="#880E4F";

    Ola_dose    [label="Olaparib\n(300mg BID PO)", fillcolor="#F48FB1", shape=diamond];
    Nira_dose   [label="Niraparib\n(200–300mg QD PO)", fillcolor="#F48FB1", shape=diamond];
    Ruca_dose   [label="Rucaparib\n(600mg BID PO)", fillcolor="#F48FB1", shape=diamond];
    Tala_dose   [label="Talazoparib\n(1mg QD PO, strong trapper)", fillcolor="#F48FB1", shape=diamond];
    OLA_gut     [label="Olaparib\n(gut absorption, F≈77%)", fillcolor="#F48FB1"];
    OLA_C1      [label="Olaparib\n(central, Cmax≈5µM)", fillcolor="#E91E63"];
    OLA_C2      [label="Olaparib\n(peripheral)", fillcolor="#E91E63"];
    NIRA_C1     [label="Niraparib\n(central, t½≈36h)", fillcolor="#C2185B", fontcolor=white];
    NIRA_C2     [label="Niraparib\n(peripheral)", fillcolor="#C2185B", fontcolor=white];
    PARP_trap   [label="PARP Trapping\n(key cytotoxic mechanism)", fillcolor="#880E4F", fontcolor=white];
    synth_let   [label="Synthetic Lethality\n(HRD + PARPi → death)", fillcolor="#6A1B9A", fontcolor=white];
    PARPi_apop  [label="PARPi-Induced\nApoptosis", fillcolor="#880E4F", fontcolor=white];
    BRCA_rev    [label="BRCA Reversion\n(resistance mutation)", fillcolor="#F48FB1"];
    RAD51_up    [label="RAD51 Upregulation\n(HRR restoration)", fillcolor="#F48FB1"];
    ABCB1_Pi    [label="ABCB1\n(PARPi efflux, resistance)", fillcolor="#F48FB1"];
    PARP_restor [label="PARP Restoration\n(splice variant resist.)", fillcolor="#F48FB1"];
    combo_bev_ola [label="Olaparib + Bevacizumab\n(PAOLA-1 maintenance)", fillcolor="#880E4F", fontcolor=white, shape=diamond];
    niraparib_maint [label="Niraparib Maintenance\n(PRIMA, all-comer)", fillcolor="#C2185B", fontcolor=white, shape=diamond];
  }

  // ============================================================
  // Cluster 9: 종양 성장 / 세포 생물학 (Tumor Cell Biology)
  // ============================================================
  subgraph cluster_tumor {
    label="⑨ 종양 성장 / 세포 생물학\n(Ovarian Cancer Cell Biology)";
    style=filled; fillcolor="#EDE7F6"; color="#1A237E";
    fontsize=9; fontcolor="#1A237E";

    OC_cell     [label="HGSOC Cell\n(high-grade serous)", fillcolor="#7E57C2", fontcolor=white];
    LGSOC_cell  [label="LGSOC Cell\n(low-grade serous, MAPK-driven)", fillcolor="#9575CD"];
    CSC         [label="Cancer Stem Cells\n(therapy resistance, ALDH1+)", fillcolor="#283593", fontcolor=white];
    prolif_r    [label="Proliferation Rate\n(Ki-67, doubling time)", fillcolor="#7986CB"];
    TV_ode      [label="Tumor Volume\n(cm³, Gompertz model)", fillcolor="#3949AB", fontcolor=white];
    Wnt_b       [label="Wnt/β-catenin\n(stemness)", fillcolor="#7986CB"];
    Notch_s     [label="Notch\n(CSC maintenance)", fillcolor="#7986CB"];
    cMyc        [label="c-Myc\n(oncogene amplification)", fillcolor="#3949AB", fontcolor=white];
    apop_r      [label="Apoptosis Rate\n(Bcl-2/Bax balance)", fillcolor="#5C6BC0", fontcolor=white];
    BCL2        [label="BCL-2\n(anti-apoptotic)", fillcolor="#7986CB"];
    BAX         [label="BAX/BAK\n(pro-apoptotic)", fillcolor="#7986CB"];
    BCL_XL      [label="BCL-XL\n(anti-apoptotic)", fillcolor="#7986CB"];
    caspase_c   [label="Caspase-3/7/9\n(executioner cascade)", fillcolor="#3949AB", fontcolor=white];
    cytochrome_c [label="Cytochrome c\n(mitochondrial release)", fillcolor="#7986CB"];
    apaf1       [label="APAF-1 / Apoptosome\n(caspase-9 activator)", fillcolor="#7986CB"];
    dormancy    [label="Tumor Dormancy\n(quiescence)", fillcolor="#9FA8DA"];
    ALDH1A1     [label="ALDH1A1\n(CSC marker)", fillcolor="#9FA8DA"];
    FRa         [label="Folate Receptor α\n(drug target, LGSOC)", fillcolor="#9FA8DA"];
    MUC16       [label="MUC16/CA-125\n(cell surface form)", fillcolor="#7986CB"];
    WEE1        [label="WEE1 kinase\n(G2/M checkpoint)", fillcolor="#9FA8DA"];
    AXL_r       [label="AXL receptor\n(EMT/resistance)", fillcolor="#9FA8DA"];
    FGF_r       [label="FGF/FGFR\n(growth factor)", fillcolor="#9FA8DA"];
  }

  // ============================================================
  // Cluster 10: 임상 엔드포인트 / 바이오마커 (Clinical)
  // ============================================================
  subgraph cluster_clinical {
    label="⑩ 임상 엔드포인트 / 바이오마커\n(Clinical Endpoints & Biomarkers)";
    style=filled; fillcolor="#F9FBE7"; color="#33691E";
    fontsize=9; fontcolor="#33691E";

    CA125_s     [label="CA-125 Serum\n(U/mL; normal <35)", fillcolor="#AED581"];
    HE4_s       [label="HE4 Serum\n(pmol/L)", fillcolor="#AED581"];
    ROMA_s      [label="ROMA Score\n(CA-125 + HE4 + meno)", fillcolor="#AED581"];
    PFS_ep      [label="PFS\n(progression-free survival)", fillcolor="#8BC34A"];
    OS_ep       [label="OS\n(overall survival)", fillcolor="#33691E", fontcolor=white];
    ORR_ep      [label="ORR\n(CR + PR rate)", fillcolor="#7CB342"];
    RECIST_r    [label="RECIST 1.1\n(CR / PR / SD / PD)", fillcolor="#558B2F", fontcolor=white];
    PFI_ep      [label="PFI\n(platinum-free interval)", fillcolor="#AED581"];
    DOR_ep      [label="DOR\n(duration of response)", fillcolor="#AED581"];
    tox_grade   [label="Toxicity Grade\n(CTCAE v5.0)", fillcolor="#DCEDC8"];
    plat_sens   [label="Platinum Sensitivity\n(PFI >6 mo = sensitive)", fillcolor="#7CB342"];
    maint_tx    [label="Maintenance Therapy\n(PARPi / Bev / combo)", fillcolor="#33691E", fontcolor=white];
    QoL_ep      [label="QoL\n(FACT-O / EQ-5D)", fillcolor="#DCEDC8"];
    nausea_v    [label="Nausea/Vomiting\n(carboplatin toxicity)", fillcolor="#DCEDC8"];
    neurotox    [label="Peripheral Neuropathy\n(paclitaxel)", fillcolor="#DCEDC8"];
