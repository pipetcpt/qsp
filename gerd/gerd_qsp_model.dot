digraph GERD_QSP {
    graph [
        label="GERD (Gastroesophageal Reflux Disease) — QSP Mechanistic Map\nGastric acid secretion · LES dysfunction · Mucosal injury · Drug PK/PD (PPI/H2RA/P-CAB/Prokinetic)"
        labelloc=t fontsize=22 fontname="Helvetica-Bold"
        rankdir=TB bgcolor="#F8F9FA"
        splines=true nodesep=0.5 ranksep=0.8
        compound=true
    ]
    node [fontname="Helvetica" fontsize=11 style="filled,rounded" shape=box]
    edge [fontname="Helvetica" fontsize=9]

    /* ─────────────────────────────────────────────
       CLUSTER 1: Gastric Acid Secretion
    ───────────────────────────────────────────── */
    subgraph cluster_gastric {
        label="Gastric Acid Secretion" style=filled fillcolor="#FFF3E0"
        color="#E65100" penwidth=2 fontsize=14 fontname="Helvetica-Bold"

        HKATPase     [label="H⁺/K⁺-ATPase\n(Proton Pump)" fillcolor="#FF6F00" fontcolor=white]
        HKA_active   [label="Active Pumps\n(Secretory Canaliculus)" fillcolor="#FF8F00"]
        HKA_inactive [label="Inactive Pumps\n(Tubulovesicles)" fillcolor="#FFB300"]
        HKA_inhib    [label="Irreversibly Inhibited\nPumps (PPIs)" fillcolor="#FFCA28"]

        ParietalCell [label="Parietal Cell" fillcolor="#FFA000" fontcolor=white shape=ellipse]
        Acid_secrete [label="H⁺ Secretion\nRate (mmol/h)" fillcolor="#FF6F00" fontcolor=white]
        Gastric_pH   [label="Intragastric pH\n(1.5–6.5)" fillcolor="#FF8F00" fontcolor=white]
        Pepsin_act   [label="Pepsin Activation\n(pH < 4)" fillcolor="#FFB300"]
        Pepsin_inact [label="Pepsin Inactivation\n(pH > 4)" fillcolor="#FFCA28"]

        ECL_cell     [label="ECL Cell\n(Enterochromaffin-like)" fillcolor="#EF6C00" fontcolor=white shape=ellipse]
        Histamine    [label="Histamine\n(H2R agonist)" fillcolor="#FFA726"]
        H2_receptor  [label="H2 Receptor\n(Parietal Cell)" fillcolor="#FFB74D"]

        GCell        [label="G Cell (Antrum)" fillcolor="#F57C00" fontcolor=white shape=ellipse]
        Gastrin      [label="Gastrin\n(Serum, pmol/L)" fillcolor="#FFA000" fontcolor=white]
        CCK2_receptor[label="CCK2 Receptor\n(Parietal Cell)" fillcolor="#FFB300"]

        D_cell       [label="D Cell (Somatostatin)" fillcolor="#BF360C" fontcolor=white shape=ellipse]
        Somatostatin [label="Somatostatin\n(Paracrine)" fillcolor="#E64A19" fontcolor=white]

        AcChol_vasal [label="Acetylcholine\n(Vagal M3-R)" fillcolor="#FF7043"]
        M3_receptor  [label="Muscarinic M3R\n(Parietal Cell)" fillcolor="#FF8A65"]
        PKA_path     [label="cAMP/PKA Pathway\n(H2R→AC→cAMP)" fillcolor="#FFCCBC"]
        IP3_path     [label="IP3/Ca²⁺ Pathway\n(M3R/CCK2R→PLCβ)" fillcolor="#FFCCBC"]
    }

    /* ─────────────────────────────────────────────
       CLUSTER 2: LES Physiology & TLESRs
    ───────────────────────────────────────────── */
    subgraph cluster_les {
        label="Lower Esophageal Sphincter (LES) & TLESR" style=filled fillcolor="#E8F5E9"
        color="#2E7D32" penwidth=2 fontsize=14 fontname="Helvetica-Bold"

        LES_basal_P  [label="LES Basal Pressure\n(10–40 mmHg)" fillcolor="#43A047" fontcolor=white]
        LES_relaxed  [label="LES Relaxed\n(TLESR event)" fillcolor="#66BB6A"]
        TLESR_rate   [label="TLESR Rate\n(events/h)" fillcolor="#81C784"]
        TLESR_trigger[label="TLESR Triggers\n(Gastric distension\nFatty meal / Obesity)" fillcolor="#A5D6A7"]

        Gastric_vol  [label="Gastric Volume\n(Fundal Distension)" fillcolor="#4CAF50" fontcolor=white]
        Hiatus_hernia[label="Hiatus Hernia\n(Anatomical)" fillcolor="#388E3C" fontcolor=white shape=diamond]

        GABA_B       [label="GABA-B Receptor\n(Vagal → LES)" fillcolor="#2E7D32" fontcolor=white]
        Baclofen     [label="Baclofen\n(GABA-B agonist)" fillcolor="#1B5E20" fontcolor=white shape=parallelogram]
        mGluR5       [label="mGluR5\n(LES neural)" fillcolor="#388E3C" fontcolor=white]

        LES_smooth_m [label="LES Smooth Muscle\n(Circular)" fillcolor="#C8E6C9"]
        NO_LES       [label="Nitric Oxide\n(LES relaxation)" fillcolor="#DCEDC8"]
        VIP_LES      [label="VIP\n(LES relaxation)" fillcolor="#F1F8E9"]
        Motilin      [label="Motilin Receptor\n(LES contraction)" fillcolor="#CCFF90"]

        UES          [label="Upper Esophageal\nSphincter (UES)" fillcolor="#B9F6CA"]
        Crural_diaphragm[label="Crural Diaphragm\n(External barrier)" fillcolor="#69F0AE"]
    }

    /* ─────────────────────────────────────────────
       CLUSTER 3: Reflux Episode & Composition
    ───────────────────────────────────────────── */
    subgraph cluster_reflux {
        label="Reflux Events & Composition" style=filled fillcolor="#FCE4EC"
        color="#AD1457" penwidth=2 fontsize=14 fontname="Helvetica-Bold"

        Reflux_event [label="Reflux Episode\n(Acid/Mixed/Bile)" fillcolor="#E91E63" fontcolor=white]
        Acid_reflux  [label="Acid Reflux\n(pH < 4, volume)" fillcolor="#F06292"]
        Weakly_acid  [label="Weakly Acidic Reflux\n(pH 4–7)" fillcolor="#F48FB1"]
        NonAcid_refl [label="Non-Acid Reflux\n(pH > 7, bile)" fillcolor="#F8BBD9"]

        Bile_acid    [label="Bile Acids\n(Duodenogastric)" fillcolor="#AD1457" fontcolor=white]
        Deoxy_bile   [label="Deoxycholic Acid\n(Mucosal injury)" fillcolor="#C2185B" fontcolor=white]
        Trypsin_esoph[label="Pancreatic Enzymes\n(Trypsin, Lipase)" fillcolor="#D81B60" fontcolor=white]

        Esoph_acid_exp[label="Esophageal Acid\nExposure Time (%)" fillcolor="#E91E63" fontcolor=white]
        DeMeester    [label="DeMeester Score\n(pH-metry)" fillcolor="#F06292"]
        Esoph_vol    [label="Reflux Volume\n(mL/episode)" fillcolor="#F48FB1"]

        Prox_extent  [label="Proximal Extent\n(Thorax/Pharynx)" fillcolor="#FCE4EC"]
        Microaspirat [label="Micro-aspiration\n(Pulmonary)" fillcolor="#F8BBD9"]
    }

    /* ─────────────────────────────────────────────
       CLUSTER 4: Esophageal Mucosal Defense
    ───────────────────────────────────────────── */
    subgraph cluster_mucosal {
        label="Esophageal Mucosal Defense & Injury" style=filled fillcolor="#E3F2FD"
        color="#1565C0" penwidth=2 fontsize=14 fontname="Helvetica-Bold"

        Mucus_layer  [label="Mucus/Unstirred\nWater Layer" fillcolor="#1976D2" fontcolor=white]
        Bicarb_secret[label="Bicarbonate\nSecretion (Submucosal)" fillcolor="#42A5F5"]
        Esoph_epithel[label="Esophageal Epithelium\n(Stratified squamous)" fillcolor="#64B5F6"]

        TJ_proteins  [label="Tight Junction Proteins\n(Claudin, Occludin, E-Cad)" fillcolor="#90CAF9"]
        Paracellular [label="Paracellular Permeability\n(Dilated intercellular spaces)" fillcolor="#BBDEFB"]
        TEER         [label="Transepithelial Electrical\nResistance (TEER)" fillcolor="#E3F2FD"]

        Esoph_motility[label="Esophageal Peristalsis\n(Acid clearance)" fillcolor="#1565C0" fontcolor=white]
        Salivary_bicarb[label="Saliva Bicarbonate\n(Acid neutralization)" fillcolor="#1976D2" fontcolor=white]
        Swallow_freq [label="Swallow Frequency\n(Clearance)" fillcolor="#2196F3" fontcolor=white]

        Mucosal_blood[label="Mucosal Blood Flow\n(Defense)" fillcolor="#42A5F5"]
        EGF_mucosal  [label="EGF/TGF-α\n(Mucosal repair)" fillcolor="#64B5F6"]
        PGE2_protect [label="PGE2\n(Mucosal protection)" fillcolor="#90CAF9"]

        Mucosal_damage[label="Mucosal Damage Score\n(Erosive Esophagitis Grade)" fillcolor="#1565C0" fontcolor=white]
        Healing_rate [label="Mucosal Healing Rate\n(Weeks)" fillcolor="#1976D2" fontcolor=white]
    }

    /* ─────────────────────────────────────────────
       CLUSTER 5: Inflammatory Pathways
    ───────────────────────────────────────────── */
    subgraph cluster_inflammation {
        label="Inflammatory Signaling" style=filled fillcolor="#F3E5F5"
        color="#6A1B9A" penwidth=2 fontsize=14 fontname="Helvetica-Bold"

        IL8_esoph    [label="IL-8\n(Esophageal epithelial)" fillcolor="#7B1FA2" fontcolor=white]
        IL1b_esoph   [label="IL-1β\n(Mast cell/macrophage)" fillcolor="#8E24AA" fontcolor=white]
        TNFa_esoph   [label="TNF-α\n(Inflammatory mediator)" fillcolor="#9C27B0" fontcolor=white]
        IL33_esoph   [label="IL-33\n(Epithelial alarmin)" fillcolor="#AB47BC"]

        Eosinophil   [label="Eosinophils\n(>15/HPF → EoE)" fillcolor="#BA68C8"]
        Mast_cell    [label="Mast Cells\n(Substance P release)" fillcolor="#CE93D8"]
        Neutrophil_e [label="Neutrophils\n(Acute inflammation)" fillcolor="#E1BEE7"]
        T_lymphocyte [label="CD4+ T Cells\n(Th2 skew in EoE)" fillcolor="#F3E5F5"]

        NF_kB        [label="NF-κB\n(Transcription factor)" fillcolor="#6A1B9A" fontcolor=white]
        STAT3_esoph  [label="STAT3\n(IL-6 downstream)" fillcolor="#7B1FA2" fontcolor=white]
        MAPK_esoph   [label="MAPK/ERK\n(Cell proliferation)" fillcolor="#8E24AA" fontcolor=white]

        Substance_P  [label="Substance P\n(Pain sensitizer)" fillcolor="#9C27B0" fontcolor=white]
        CGRP_esoph   [label="CGRP\n(Neurogenic inflam)" fillcolor="#AB47BC"]
        Bradykinin   [label="Bradykinin\n(Mucosal pain)" fillcolor="#BA68C8"]
        PGE2_inflam  [label="PGE2 (Inflammatory)\n(EP1/EP3 receptors)" fillcolor="#CE93D8"]
    }

    /* ─────────────────────────────────────────────
       CLUSTER 6: Symptom Generation & Perception
    ───────────────────────────────────────────── */
    subgraph cluster_symptoms {
        label="Symptom Generation & Pain Perception" style=filled fillcolor="#FFFDE7"
        color="#F57F17" penwidth=2 fontsize=14 fontname="Helvetica-Bold"

        Heartburn    [label="Heartburn\n(Pyrosis)" fillcolor="#F57F17" fontcolor=white]
        Regurgitation[label="Regurgitation\n(Sour/bitter taste)" fillcolor="#F9A825" fontcolor=white]
        Dysphagia    [label="Dysphagia\n(Swallowing difficulty)" fillcolor="#FBC02D"]
        Chest_pain   [label="Non-Cardiac\nChest Pain (NCCP)" fillcolor="#F57F17" fontcolor=white]
        Laryngitis   [label="Laryngopharyngeal\nReflux (LPR)" fillcolor="#FDD835"]
        Cough_reflux [label="Chronic Cough\n(GERD-induced)" fillcolor="#FFEE58"]
        Regurg_vol   [label="Symptom Severity\n(GERD-Q Score)" fillcolor="#FFF176"]

        Afferent_C   [label="Esophageal C-fibers\n(TRPV1, ASICs)" fillcolor="#F9A825" fontcolor=white]
        Afferent_Adelta[label="Aδ-fibers\n(Mechanical pain)" fillcolor="#FBC02D"]
        TRPV1        [label="TRPV1 Receptor\n(Acid/heat sensor)" fillcolor="#F57F17" fontcolor=white]
        ASIC_channel [label="ASIC Channels\n(Acid-sensing)" fillcolor="#FDD835"]

        DRG_neuron   [label="Dorsal Root Ganglion\n(T1–T5)" fillcolor="#F9A825" fontcolor=white]
        Spinal_cord  [label="Spinal Cord\n(Dorsal horn)" fillcolor="#FBC02D"]
        NTS          [label="Nucleus Tractus\nSolitarius (NTS)" fillcolor="#FDD835"]
        Thalamus     [label="Thalamus\n(Pain relay)" fillcolor="#FFEE58"]
        ACC          [label="Anterior Cingulate\nCortex (ACC)" fillcolor="#FFF176"]
        Esoph_hypersen[label="Esophageal\nHypersensitivity" fillcolor="#F57F17" fontcolor=white]
    }

    /* ─────────────────────────────────────────────
       CLUSTER 7: Complications (Barrett's/EAC)
    ───────────────────────────────────────────── */
    subgraph cluster_complications {
        label="Long-term Complications" style=filled fillcolor="#EFEBE9"
        color="#4E342E" penwidth=2 fontsize=14 fontname="Helvetica-Bold"

        Erosive_esoph [label="Erosive Esophagitis\n(LA Grade A–D)" fillcolor="#6D4C41" fontcolor=white]
        Peptic_stric  [label="Peptic Stricture\n(Fibrosis)" fillcolor="#795548" fontcolor=white]
        Barretts_esoph[label="Barrett's Esophagus\n(Intestinal Metaplasia)" fillcolor="#4E342E" fontcolor=white]
        BE_no_dysplasia[label="Barrett's\n(Non-dysplastic)" fillcolor="#6D4C41" fontcolor=white]
        BE_low_grade  [label="Low-Grade\nDysplasia" fillcolor="#795548" fontcolor=white]
        BE_high_grade [label="High-Grade\nDysplasia" fillcolor="#8D6E63"]
        EAC           [label="Esophageal\nAdenocarcinoma (EAC)" fillcolor="#4E342E" fontcolor=white shape=diamond]

        CDX2_transcrip[label="CDX2 Transcription\n(Intestinal metaplasia)" fillcolor="#A1887F"]
        SOX2_loss     [label="SOX2 Loss\n(Squamous → columnar)" fillcolor="#BCAAA4"]
        BMP4_signaling[label="BMP4 Signaling\n(Columnar differentiation)" fillcolor="#D7CCC8"]

        p16_loss      [label="p16/CDKN2A Loss\n(Dysplasia driver)" fillcolor="#6D4C41" fontcolor=white]
        TP53_mut      [label="TP53 Mutation\n(HGD marker)" fillcolor="#795548" fontcolor=white]
        VEGF_EAC      [label="VEGF\n(Angiogenesis-EAC)" fillcolor="#8D6E63"]

        Aspirin_chemo [label="Aspirin\n(Chemoprevention)" fillcolor="#3E2723" fontcolor=white shape=parallelogram]
        Statins_chemo [label="Statins\n(Chemoprevention)" fillcolor="#4E342E" fontcolor=white shape=parallelogram]
    }

    /* ─────────────────────────────────────────────
       CLUSTER 8: Neural / Brain-Gut Axis
    ───────────────────────────────────────────── */
    subgraph cluster_neural {
        label="Neural Control & Brain-Gut Axis" style=filled fillcolor="#E0F7FA"
        color="#00695C" penwidth=2 fontsize=14 fontname="Helvetica-Bold"

        Vagus_nerve  [label="Vagus Nerve\n(X cranial nerve)" fillcolor="#00796B" fontcolor=white]
        ENS          [label="Enteric Nervous System\n(Myenteric/Submucosal)" fillcolor="#00897B" fontcolor=white]
        Splanchnic   [label="Splanchnic Nerves\n(Sympathetic efferents)" fillcolor="#009688" fontcolor=white]

        DMVN         [label="Dorsal Motor\nNucleus of Vagus" fillcolor="#00796B" fontcolor=white]
        Gut_motility [label="Gastric Emptying\n(t½ = 90–120 min)" fillcolor="#26A69A"]
        Duod_empty   [label="Duodenal Emptying\n(CCK-regulated)" fillcolor="#4DB6AC"]

        CCK          [label="CCK\n(I-cells, duodenum)" fillcolor="#80CBC4"]
        GLP1         [label="GLP-1\n(L-cells, ileum)" fillcolor="#B2DFDB"]
        Ghrelin      [label="Ghrelin\n(Fundal X/A cells)" fillcolor="#E0F2F1"]
        PYY          [label="PYY\n(Ileal brake)" fillcolor="#B2EBF2"]

        Serotonin_ENS[label="5-HT (Serotonin)\n(EC cells, ENS)" fillcolor="#00796B" fontcolor=white]
        SHT3_receptor[label="5-HT3 Receptor\n(Afferent sensitization)" fillcolor="#00897B" fontcolor=white]
        SHT4_receptor[label="5-HT4 Receptor\n(Prokinetic target)" fillcolor="#009688" fontcolor=white]

        Cortex_psych [label="Psychological Stress\n(Anxiety/Depression)" fillcolor="#26A69A"]
        HPA_axis     [label="HPA Axis\n(CRH → Cortisol)" fillcolor="#4DB6AC"]
        CRH          [label="CRH\n(Stress mediator)" fillcolor="#80CBC4"]
    }

    /* ─────────────────────────────────────────────
       CLUSTER 9: Drug PK
    ───────────────────────────────────────────── */
    subgraph cluster_drug_pk {
        label="Drug Pharmacokinetics" style=filled fillcolor="#EDE7F6"
        color="#4527A0" penwidth=2 fontsize=14 fontname="Helvetica-Bold"

        /* PPI */
        PPI_dose     [label="PPI Dose\n(Omeprazole/Esomeprazole\nLansoprazole/Pantoprazole)" fillcolor="#4527A0" fontcolor=white shape=parallelogram]
        PPI_gut      [label="PPI Gut\n(Enteric-coated absorption)" fillcolor="#512DA8" fontcolor=white]
        PPI_central  [label="PPI Plasma\n(Cmax ≈ 0.5–2 mg/L)" fillcolor="#5E35B1" fontcolor=white]
        PPI_liver    [label="PPI Liver\n(CYP2C19/CYP3A4)" fillcolor="#673AB7" fontcolor=white]
        PPI_metabolite[label="PPI Metabolites\n(Sulphone/Hydroxy)" fillcolor="#7E57C2"]
        CYP2C19_PM   [label="CYP2C19 Phenotype\n(EM/IM/PM/UM)" fillcolor="#9575CD"]
        Tmax_PPI     [label="Tmax PPI\n(1–4 h, t½ ~1.5 h)" fillcolor="#B39DDB"]

        /* H2RA */
        H2RA_dose    [label="H2RA Dose\n(Famotidine/Ranitidine)" fillcolor="#4527A0" fontcolor=white shape=parallelogram]
        H2RA_gut     [label="H2RA Gut\n(Rapid absorption)" fillcolor="#512DA8" fontcolor=white]
        H2RA_central [label="H2RA Plasma\n(t½ ≈ 2.5–3 h)" fillcolor="#5E35B1" fontcolor=white]
        H2RA_kidney  [label="H2RA Renal\nElimination" fillcolor="#673AB7" fontcolor=white]

        /* P-CAB */
        PCAB_dose    [label="P-CAB Dose\n(Vonoprazan 10–40 mg)" fillcolor="#4527A0" fontcolor=white shape=parallelogram]
        PCAB_gut     [label="P-CAB Gut\n(Rapid absorption, F≈60%)" fillcolor="#512DA8" fontcolor=white]
        PCAB_central [label="P-CAB Plasma\n(t½ ≈ 7–9 h)" fillcolor="#5E35B1" fontcolor=white]
        PCAB_liver   [label="P-CAB Liver\n(CYP3A4, partial)" fillcolor="#673AB7" fontcolor=white]

        /* Alginate / Antacid */
        Alginate_dose[label="Alginate\n(Gaviscon Advance)" fillcolor="#7E57C2" shape=parallelogram]
        Antacid_dose [label="Antacids\n(CaCO3/Al-Mg salts)" fillcolor="#9575CD" shape=parallelogram]
        Alginate_raft[label="Alginate Raft\n(pH barrier effect)" fillcolor="#B39DDB"]
    }

    /* ─────────────────────────────────────────────
       CLUSTER 10: Drug PD (Mechanisms)
    ───────────────────────────────────────────── */
    subgraph cluster_drug_pd {
        label="Drug Pharmacodynamics & Mechanisms" style=filled fillcolor="#E8EAF6"
        color="#283593" penwidth=2 fontsize=14 fontname="Helvetica-Bold"

        PPI_effect_site[label="PPI Effect Site\n(Secretory canaliculus)" fillcolor="#283593" fontcolor=white]
        PPI_covalent [label="PPI Covalent Binding\n(Cys813/892 on α-subunit)" fillcolor="#303F9F" fontcolor=white]
        PPI_onset    [label="PPI Onset Delay\n(2–5 days for full effect)" fillcolor="#3949AB" fontcolor=white]
        PPI_acid_req [label="PPI Requires\nAcid for Activation\n(Sulfenamide form)" fillcolor="#3F51B5" fontcolor=white]

        PCAB_mech    [label="P-CAB Ionic Binding\n(K+ site, reversible)" fillcolor="#283593" fontcolor=white]
        PCAB_no_acid [label="P-CAB No Acid\nRequired (immediate)" fillcolor="#303F9F" fontcolor=white]
        PCAB_night   [label="P-CAB Superior\nNocturnal Acid Control" fillcolor="#3949AB" fontcolor=white]

        H2RA_mech    [label="H2RA Competitive\nAntagonism (H2R)" fillcolor="#3F51B5" fontcolor=white]
        H2RA_tach    [label="H2RA Tachyphylaxis\n(Tolerance within days)" fillcolor="#5C6BC0"]

        Prokinetic_mech[label="Prokinetics\n(Domperidone/Metoclopramide\n5-HT4 agonist/D2 antagonist)" fillcolor="#7986CB" shape=parallelogram]
        Prokin_LES   [label="Prokinetic Effect on\nLES Pressure (+5 mmHg)" fillcolor="#9FA8DA"]
        Prokin_empty [label="Prokinetic Effect on\nGastric Emptying (↑)" fillcolor="#C5CAE9"]

        Sucralfate   [label="Sucralfate\n(Mucosal coating)" fillcolor="#3F51B5" fontcolor=white shape=parallelogram]
        Sucralfate_mech[label="Sucralfate: Al³⁺\nMucosal Adhesion" fillcolor="#5C6BC0"]
    }

    /* ─────────────────────────────────────────────
       CLUSTER 11: Clinical Endpoints & Outcomes
    ───────────────────────────────────────────── */
    subgraph cluster_endpoints {
        label="Clinical Endpoints & Risk Factors" style=filled fillcolor="#F1F8E9"
        color="#33691E" penwidth=2 fontsize=14 fontname="Helvetica-Bold"

        GERD_Q_score [label="GERD-Q Score\n(Validated questionnaire)" fillcolor="#33691E" fontcolor=white]
        RDQ_score    [label="Reflux Disease\nQuestionnaire (RDQ)" fillcolor="#558B2F" fontcolor=white]
        HRQL         [label="HRQL\n(SF-36/EQ-5D)" fillcolor="#689F38" fontcolor=white]

        EndoscopyGrade[label="Los Angeles\nGrade (A–D)" fillcolor="#7CB342" fontcolor=white]
        Impedance    [label="Esophageal Impedance-\npH Monitoring" fillcolor="#8BC34A"]
        HRM          [label="High-Resolution\nManometry (HRM)" fillcolor="#9CCC65"]

        BMI          [label="BMI (Obesity\nRisk Factor)" fillcolor="#AED581" shape=diamond]
        Obesity_GERD [label="Obesity → ↑ IAP\n↑ TLESR frequency" fillcolor="#C5E1A5"]
        Smoking      [label="Smoking\n(↓ LES pressure, ↓ saliva)" fillcolor="#DCEDC8" shape=diamond]
        Alcohol      [label="Alcohol\n(Mucosal injury)" fillcolor="#F1F8E9" shape=diamond]
        Pregnancy    [label="Pregnancy\n(↑ IAP, ↓ LES tone)" fillcolor="#CCFF90" shape=diamond]
        Diet_fat     [label="High-Fat Diet\n(Delayed emptying)" fillcolor="#B9F6CA" shape=diamond]

        H_pylori     [label="H. pylori\n(Complex GERD relation)" fillcolor="#558B2F" fontcolor=white shape=diamond]
        PPI_side_effects[label="PPI Side Effects\n(C.diff / Hypomagnesemia\nFracture / B12↓)" fillcolor="#33691E" fontcolor=white]
        Fundoplication[label="Laparoscopic Nissen\nFundoplication (Surgery)" fillcolor="#689F38" fontcolor=white shape=parallelogram]
        LINX_device  [label="LINX Magnetic\nSphincter Augmentation" fillcolor="#7CB342" fontcolor=white shape=parallelogram]
    }

    /* ════════════════════════════════════════
       EDGES — Gastric Acid Secretion
    ════════════════════════════════════════ */
    GCell -> Gastrin [label="secretion" color="#E65100"]
    Gastrin -> CCK2_receptor [label="binds" color="#E65100"]
    CCK2_receptor -> ParietalCell [label="activates" color="#E65100"]
    ECL_cell -> Histamine [label="releases" color="#FF8F00"]
    Histamine -> H2_receptor [label="binds" color="#FF8F00"]
    H2_receptor -> PKA_path [label="→cAMP" color="#FF8F00"]
    PKA_path -> HKATPase [label="phosphorylates/activates" color="#E65100"]
    AcChol_vasal -> M3_receptor [label="binds" color="#F44336"]
    M3_receptor -> IP3_path [label="→PLCβ/IP3" color="#F44336"]
    IP3_path -> HKATPase [label="Ca²⁺ activates" color="#F44336"]
    Somatostatin -> ECL_cell [label="inhibits" color="#B71C1C" style=dashed]
    Somatostatin -> GCell [label="inhibits" color="#B71C1C" style=dashed]
    Somatostatin -> ParietalCell [label="inhibits" color="#B71C1C" style=dashed]
    D_cell -> Somatostatin [label="secretes" color="#BF360C"]
    Gastric_pH -> D_cell [label="low pH stimulates" color="#BF360C"]
    HKATPase -> HKA_active [label="translocates" color="#FF6F00"]
    HKA_inactive -> HKA_active [label="vesicle fusion" color="#FF6F00"]
    HKA_active -> Acid_secrete [label="pumps H⁺" color="#FF6F00"]
    Acid_secrete -> Gastric_pH [label="lowers pH" color="#FF6F00"]
    Gastric_pH -> Pepsin_act [label="pH<4 activates" color="#E65100"]
    Gastric_pH -> Pepsin_inact [label="pH>4 inactivates" color="#9E9E9E" style=dashed]
    ParietalCell -> HKA_inactive [label="stores" color="#FF8F00"]

    /* ════════════════════════════════════════
       EDGES — LES & TLESR
    ════════════════════════════════════════ */
    Gastric_vol -> TLESR_trigger [label="distension" color="#2E7D32"]
