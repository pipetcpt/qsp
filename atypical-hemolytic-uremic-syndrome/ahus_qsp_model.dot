digraph aHUS_QSP {
  graph [rankdir=LR, fontname="Helvetica", fontsize=11, bgcolor="#F8F9FA",
         label="Atypical Hemolytic Uremic Syndrome (aHUS)\nQuantitative Systems Pharmacology Model\nComplement Dysregulation → TMA → Organ Damage",
         labelloc=t, labeljust=c, splines=true, nodesep=0.3, ranksep=0.7,
         margin=0.5];
  node [shape=box, style="filled,rounded", fontname="Helvetica", fontsize=8, margin="0.1,0.05"];
  edge [fontname="Helvetica", fontsize=7, arrowsize=0.7];

  // ─── Cluster 1: Genetic Risk Factors ─────────────────────────────────────────
  subgraph cluster_genetic {
    label="Genetic & Acquired Risk Factors";
    style=filled; color="#E8F4FD"; fontcolor="#1A5276"; fontsize=10; penwidth=2;

    CFH_mut   [label="CFH Mutation\n(factor H LOF)", fillcolor="#AED6F1"];
    CFI_mut   [label="CFI Mutation\n(factor I LOF)", fillcolor="#AED6F1"];
    CD46_mut  [label="CD46/MCP Mutation\n(membrane regulator)", fillcolor="#AED6F1"];
    C3_mut    [label="C3 Mutation\n(gain-of-function)", fillcolor="#F1948A"];
    CFB_mut   [label="CFB Mutation\n(gain-of-function)", fillcolor="#F1948A"];
    CFHR_del  [label="CFHR1/3 Deletion\n(anti-CFH Ab risk)", fillcolor="#D7BDE2"];
    THBD_mut  [label="THBD Mutation\n(thrombomodulin)", fillcolor="#AED6F1"];
    DGKE_mut  [label="DGKE Mutation\n(diacylglycerol kinase)", fillcolor="#AED6F1"];
    anti_CFH  [label="Anti-CFH Antibody\n(acquired aHUS ~10%)", fillcolor="#F9E79F"];
    trigger_infect [label="Infection Trigger\n(S. pneumoniae, STEC)", fillcolor="#FDEBD0"];
    trigger_preg   [label="Pregnancy / Drug\nComplement Stress", fillcolor="#FDEBD0"];
    genetic_penetrance [label="Penetrance ~50%\n(incomplete in CFH)", fillcolor="#D5F5E3"];
  }

  // ─── Cluster 2: Alternative Pathway ──────────────────────────────────────────
  subgraph cluster_AP {
    label="Complement Alternative Pathway (AP)";
    style=filled; color="#EBF5FB"; fontcolor="#1F618D"; fontsize=10; penwidth=2;

    C3        [label="C3 (1.0-1.8 g/L)\ncentral complement protein", fillcolor="#85C1E9"];
    C3_tickover [label="C3 Spontaneous\nHydrolysis (Tickover ~0.5%/h)", fillcolor="#AED6F1"];
    C3H2O     [label="C3(H2O)\nNascent C3b-like", fillcolor="#85C1E9"];
    CFB       [label="Factor B (CFB)\n~200 mg/L", fillcolor="#85C1E9"];
    CFD       [label="Factor D (CFD)\n~2 mg/L rate-limiting", fillcolor="#85C1E9"];
    Bb        [label="Bb\nactive serine protease", fillcolor="#5DADE2"];
    C3bBb     [label="AP C3 Convertase\nC3bBb (t1/2 ~90 sec)", fillcolor="#2980B9", fontcolor=white];
    Properdin [label="Properdin (CFP)\nC3bBb stabilizer", fillcolor="#1A5276", fontcolor=white];
    C3bBbP    [label="Stabilized AP C3 Conv\nC3bBbP (t1/2 ~30 min)", fillcolor="#1A5276", fontcolor=white];
    AP_amplify [label="Amplification Loop\n(C3b deposition x1000)", fillcolor="#D6EAF8"];
    C3b_depos  [label="C3b Surface Deposition\n(opsonization)", fillcolor="#5DADE2"];
    iC3b      [label="iC3b\n(inactive, CFI+CFH)", fillcolor="#A9CCE3"];
    C3dg      [label="C3dg/C3d\n(terminal fragment)", fillcolor="#D6EAF8"];
    C3a       [label="C3a\n(anaphylatoxin)", fillcolor="#F1948A"];
  }

  // ─── Cluster 3: Classical & Lectin Pathways ───────────────────────────────────
  subgraph cluster_CPLP {
    label="Classical & Lectin Pathways (CP/LP)";
    style=filled; color="#F4ECF7"; fontcolor="#6C3483"; fontsize=10; penwidth=2;

    C1q   [label="C1q\n(IgM/IgG immune complexes)", fillcolor="#D7BDE2"];
    C1r   [label="C1r (serine protease)", fillcolor="#C39BD3"];
    C1s   [label="C1s (cleaves C4, C2)", fillcolor="#C39BD3"];
    MBL   [label="MBL\n(mannose-binding lectin)", fillcolor="#D7BDE2"];
    MASP2 [label="MASP-2\n(cleaves C4, C2)", fillcolor="#BB8FCE"];
    C4    [label="C4 (~0.6 g/L)", fillcolor="#A569BD"];
    C4b   [label="C4b (covalent binding)", fillcolor="#8E44AD", fontcolor=white];
    C2    [label="C2 (CFB analog)", fillcolor="#A569BD"];
    C2a   [label="C2a (serine protease)", fillcolor="#8E44AD", fontcolor=white];
    C4b2a [label="CP/LP C3 Convertase\nC4b2a", fillcolor="#6C3483", fontcolor=white];
    IC_deposit [label="Immune Complex\nDeposition", fillcolor="#F4D03F"];
    PAMP  [label="PAMPs/MAMPs\n(microbial surfaces)", fillcolor="#FDEBD0"];
  }

  // ─── Cluster 4: Complement Regulation ────────────────────────────────────────
  subgraph cluster_reg {
    label="Complement Regulatory Proteins";
    style=filled; color="#EAFAF1"; fontcolor="#1E8449"; fontsize=10; penwidth=2;

    CFH_prot  [label="Factor H (CFH)\n150 kDa, 500 mg/L\nDAA + cofactor for CFI", fillcolor="#82E0AA"];
    CFI_prot  [label="Factor I (CFI)\nserine protease\nC3b -> iC3b -> C3dg", fillcolor="#82E0AA"];
    CD46_MCP  [label="CD46/MCP\nmembrane cofactor protein\ncell surface regulator", fillcolor="#58D68D"];
    CD55_DAF  [label="CD55/DAF\ndecay-accelerating factor", fillcolor="#58D68D"];
    CD59      [label="CD59 (protectin/MIRL)\nMAC assembly inhibitor", fillcolor="#27AE60", fontcolor=white];
    C4bp      [label="C4b-binding Protein\n(C4bp) CP/LP regulator", fillcolor="#82E0AA"];
    Vitronectin [label="Vitronectin (S-protein)\nMAC inhibitor (soluble)", fillcolor="#A9DFBF"];
    Clusterin [label="Clusterin\nMAC inhibitor", fillcolor="#A9DFBF"];
    CR1       [label="CR1 (CD35)\nC3b/C4b binding + DAA", fillcolor="#58D68D"];
    CFHR1     [label="CFHR1\n(plasma, competes CFH)", fillcolor="#F0B27A"];
    Thrombomod [label="Thrombomodulin (THBD)\ncofactor for CFI on EC", fillcolor="#73C6B6"];
  }

  // ─── Cluster 5: Terminal Complement Pathway ──────────────────────────────────
  subgraph cluster_terminal {
    label="Terminal Complement (C5-C9 / MAC Formation)";
    style=filled; color="#FEF9E7"; fontcolor="#9A7D0A"; fontsize=10; penwidth=2;

    C5       [label="C5 (~75 ug/mL, ~395 nM)\nKEY DRUG TARGET", fillcolor="#F9E79F"];
    C5conv   [label="C5 Convertase\nC3b2Bb (AP) or C4b2aC3b (CP)", fillcolor="#F4D03F"];
    C5a      [label="C5a (anaphylatoxin)\nEC50 ~0.1 nM\nPotent chemoattractant", fillcolor="#E74C3C", fontcolor=white];
    C5b      [label="C5b\n(initiates MAC)", fillcolor="#F39C12"];
    C6       [label="C6\n(MAC component)", fillcolor="#EB984E"];
    C7       [label="C7\n(amphiphilic, membrane insert)", fillcolor="#DC7633"];
    C8       [label="C8 (alpha+beta+gamma)\nC9 polymerization trigger", fillcolor="#CA6F1E"];
    C9       [label="C9\n(18 copies polymerize)", fillcolor="#BA4A00", fontcolor=white];
    MAC      [label="MAC (C5b-9)\nMembrane Attack Complex\n~10 nm pore", fillcolor="#922B21", fontcolor=white];
    sC5b9    [label="Soluble MAC (sC5b-9)\nBiomarker of activation\nnormal: <244 ng/mL", fillcolor="#CD6155"];
    C5aR1    [label="C5aR1 (CD88)\nGPCR on neutrophils/\nmacrophages/endothelium", fillcolor="#A93226", fontcolor=white];
    C5aR2    [label="C5aR2 (C5L2)\nanti-inflammatory?", fillcolor="#F1948A"];
    CH50_calc [label="CH50\nFunctional hemolytic\nactivity test", fillcolor="#FAD7A0"];
  }

  // ─── Cluster 6: Endothelial Injury & TMA ─────────────────────────────────────
  subgraph cluster_endothelium {
    label="Endothelial Injury & Thrombotic Microangiopathy (TMA)";
    style=filled; color="#FDEDEC"; fontcolor="#922B21"; fontsize=10; penwidth=2;

    EC_normal  [label="Normal Endothelium\n(anticoagulant surface)", fillcolor="#FDFEFE"];
    EC_activated [label="Activated Endothelium\n(pro-inflammatory)", fillcolor="#F5B7B1"];
    EC_injured   [label="Injured Endothelium\nMAC insertion -> pore", fillcolor="#EC7063"];
    EC_apoptosis [label="Endothelial Apoptosis\nCa2+ influx -> cell death", fillcolor="#E74C3C", fontcolor=white];
    P_selectin   [label="P-selectin\nExpression (platelet adhesion)", fillcolor="#F1948A"];
    ICAM1        [label="ICAM-1 Expression\n(leukocyte adhesion)", fillcolor="#F1948A"];
    vWF_release  [label="vWF Release\nWeibel-Palade bodies", fillcolor="#F5CBA7"];
    ULvWF        [label="Ultra-large vWF\n(ULvWF) platelet-binding", fillcolor="#E59866"];
    TF_exp       [label="Tissue Factor (TF)\nExpression\ncoagulation trigger", fillcolor="#DC7633"];
    eNOS_inhib   [label="eNOS Inhibition\nNO down -> vasoconstriction", fillcolor="#CA6F1E"];
    NO_reduce    [label="Nitric Oxide Reduction\nvasodilation impaired", fillcolor="#BA4A00", fontcolor=white];
    ROS_gen      [label="Reactive Oxygen Species\n(ROS) Generation", fillcolor="#E74C3C", fontcolor=white];
    subendo_exp  [label="Subendothelial Exposure\ncollagen, basement membrane", fillcolor="#F5CBA7"];
    fibrin_dep   [label="Fibrin Deposition\nmicrothrombus scaffold", fillcolor="#DC7633"];
  }

  // ─── Cluster 7: Platelet & Hematology ────────────────────────────────────────
  subgraph cluster_hema {
    label="Platelet & Hematological Compartment";
    style=filled; color="#F9EBEA"; fontcolor="#7B241C"; fontsize=10; penwidth=2;

    PLT_normal   [label="Normal Platelets\n150-400 x10e9/L", fillcolor="#FDFEFE"];
    PLT_activated [label="Platelet Activation\nGP Ib/IIb-IIIa", fillcolor="#FADBD8"];
    PLT_aggregate [label="Platelet Aggregation\nthrombus formation", fillcolor="#F1948A"];
    PLT_consumed  [label="Platelet Consumption\nTMA microthrombi", fillcolor="#E74C3C", fontcolor=white];
    thrombocytopenia [label="Thrombocytopenia\n<150 x10e9/L\nDefining TMA feature", fillcolor="#C0392B", fontcolor=white];
    ADAMTS13     [label="ADAMTS13\nvWF-cleaving protease\nNORMAL in aHUS (vs TTP)", fillcolor="#82E0AA"];
    RBC_fragment [label="RBC Fragmentation\nmechanical shear", fillcolor="#F1948A"];
    schistocytes [label="Schistocytes\n(helmet cells)\n>1% on blood smear", fillcolor="#E74C3C", fontcolor=white];
    hemolysis    [label="Intravascular Hemolysis\n(MAHA)", fillcolor="#C0392B", fontcolor=white];
    LDH_elev     [label="LDH Elevation (>ULN)\nhemolysis marker", fillcolor="#F5B7B1"];
    haptoglobin  [label="Haptoglobin Reduction\n<0.1 g/L\nFree Hgb scavenger", fillcolor="#FADBD8"];
    free_Hgb     [label="Free Hemoglobin\nhemoglobinuria\nhemosiderinuria", fillcolor="#E74C3C", fontcolor=white];
    anemia       [label="Microangiopathic\nHemolytic Anemia (MAHA)", fillcolor="#C0392B", fontcolor=white];
    transfusion  [label="Transfusion\nRequirement", fillcolor="#FDFEFE", style="dashed,filled,rounded"];
  }

  // ─── Cluster 8: Renal Pathophysiology ────────────────────────────────────────
  subgraph cluster_renal {
    label="Renal Pathophysiology";
    style=filled; color="#EBF5FB"; fontcolor="#1A5276"; fontsize=10; penwidth=2;

    glom_EC      [label="Glomerular Endothelium\n(complement-rich)", fillcolor="#AED6F1"];
    glom_TMA     [label="Glomerular TMA\ncapillary loop occlusion", fillcolor="#5DADE2"];
    mesangial_thick [label="Mesangial Expansion\nthickening", fillcolor="#85C1E9"];
    podocyte_inj [label="Podocyte Injury\nfoot process effacement", fillcolor="#F1948A"];
    GBM_damage   [label="GBM Damage\ndouble contour", fillcolor="#EC7063"];
    tubular_isch [label="Tubular Ischemia\nATN pattern", fillcolor="#E74C3C", fontcolor=white];
    GFR_reduced  [label="GFR Reduction\nAKI -> CKD risk", fillcolor="#C0392B", fontcolor=white];
    proteinuria  [label="Proteinuria\nnephrotic/nephritic", fillcolor="#F5B7B1"];
    hematuria    [label="Hematuria\nglomerular origin", fillcolor="#FADBD8"];
    renal_HTN    [label="Renal Hypertension\nRAAS activation", fillcolor="#F0B27A"];
    chronic_fibrosis [label="Interstitial Fibrosis\nlong-term progression", fillcolor="#BA4A00", fontcolor=white];
    ESRD         [label="ESRD / Dialysis\n30% if untreated", fillcolor="#922B21", fontcolor=white];
    dialysis     [label="Dialysis\nRequirement", fillcolor="#FDFEFE", style="dashed,filled,rounded"];
  }

  // ─── Cluster 9: Extrarenal Manifestations ────────────────────────────────────
  subgraph cluster_extrarenal {
    label="Extrarenal TMA Manifestations";
    style=filled; color="#F4ECF7"; fontcolor="#6C3483"; fontsize=10; penwidth=2;

    CNS_TMA   [label="CNS TMA (25%)\nseizures, stroke, coma", fillcolor="#C39BD3"];
    cardiac_TMA [label="Cardiac TMA\nmyocardial ischemia\ncardiomyopathy", fillcolor="#D7BDE2"];
    GI_TMA    [label="GI TMA\ndiarrhea, colitis\nbowel ischemia", fillcolor="#BB8FCE"];
    pulm_TMA  [label="Pulmonary TMA\nARDS, pulmonary HTN", fillcolor="#A569BD"];
    liver_TMA [label="Hepatic TMA\nelevated transaminases", fillcolor="#8E44AD", fontcolor=white];
    systemic_HTN [label="Systemic Hypertension\nmulti-factorial", fillcolor="#F0B27A"];
    fatigue   [label="Fatigue / QoL Reduction\nanemia + multi-organ TMA", fillcolor="#FDEBD0"];
    mortality  [label="Mortality\n25% acute episode\nif untreated", fillcolor="#922B21", fontcolor=white];
  }

  // ─── Cluster 10: Inflammatory Amplification ──────────────────────────────────
  subgraph cluster_inflam {
    label="Inflammatory & Coagulation Amplification";
    style=filled; color="#FEF5E7"; fontcolor="#784212"; fontsize=10; penwidth=2;

    C5a_neutrophil [label="C5a-mediated\nNeutrophil Activation\n(NET formation)", fillcolor="#F0B27A"];
    C5a_macrophage [label="C5a-mediated\nMacrophage Activation", fillcolor="#E59866"];
    neutrophil_ROS [label="Neutrophil ROS\noxidative burst", fillcolor="#E74C3C", fontcolor=white];
    IL1B   [label="IL-1beta\n(NLRP3 inflammasome)", fillcolor="#F39C12"];
    IL6    [label="IL-6\nacute phase / CRP up", fillcolor="#F39C12"];
    TNFa   [label="TNF-alpha\nendothelial activation", fillcolor="#F39C12"];
    CRP    [label="CRP\nacute phase marker", fillcolor="#FAD7A0"];
    C3a_effect [label="C3a Effects\nmast cell / basophil\ndegranulation", fillcolor="#F0B27A"];
    coag_cascade [label="Coagulation Cascade\nTF -> thrombin -> fibrin", fillcolor="#DC7633"];
    thrombin [label="Thrombin\nplatelet activator\nfibrin cross-linker", fillcolor="#CA6F1E"];
    RAAS_act [label="RAAS Activation\nangiotensin II up", fillcolor="#F0B27A"];
  }

  // ─── Cluster 11: Drug Mechanisms ─────────────────────────────────────────────
  subgraph cluster_drugs {
    label="Drug Mechanisms (PK/PD) - Anti-Complement Therapies";
    style=filled; color="#D5F5E3"; fontcolor="#1E8449"; fontsize=10; penwidth=2;

    Eculizumab   [label="Eculizumab\n(anti-C5 mAb, 148 kDa)\nIgG2/4kappa humanized\nSOLIRIS - 900mg/1200mg IV", fillcolor="#27AE60", fontcolor=white];
    Ravulizumab  [label="Ravulizumab\n(anti-C5 long-acting mAb)\nULTOMIRIS - q8w dosing\n(t1/2 ~50 days)", fillcolor="#1E8449", fontcolor=white];
    Iptacopan    [label="Iptacopan (oral fBi)\nFactor B inhibitor\n200 mg BID (FABHALTA)", fillcolor="#52BE80"];
    Danicopan    [label="Danicopan (oral fDi)\nFactor D inhibitor\nadd-on to anti-C5", fillcolor="#58D68D"];
    Avacopan     [label="Avacopan\n(C5aR1 antagonist oral)\n30 mg BID\n(for ANCA vasculitis)", fillcolor="#73C6B6"];
    Pegcetacoplan [label="Pegcetacoplan\n(anti-C3 PEGylated)\nC3 inhibitor SC\nbroad complement block", fillcolor="#76D7C4"];
    Crovalimab   [label="Crovalimab\n(anti-C5 SC recycling mAb)\nmonthly SC injection", fillcolor="#45B39D"];
    Plasma_EX    [label="Plasma Exchange\n(historical)\nremoves anti-CFH Ab\nreplenishes regulators", fillcolor="#A9DFBF"];
    Plasma_INF   [label="Plasma Infusion\n(historical)\nreplenishes CFH", fillcolor="#A9DFBF"];
    Meningococcal_vax [label="Meningococcal Vaccination\nN. meningitidis A,C,W,Y,B\nREQUIRED before eculizumab", fillcolor="#ABEBC6"];
    Drug_central [label="Drug PK - Central\n(V1 ~5.3 L eculizumab)", fillcolor="#27AE60", fontcolor=white];
    Drug_periph  [label="Drug PK - Peripheral\n(V2 ~4.1 L)", fillcolor="#52BE80"];
    Drug_TMDD    [label="TMDD\nTarget-Mediated Drug\nDisposition (C5-drug complex)", fillcolor="#82E0AA"];
    FcRn_recycle [label="FcRn-mediated Recycling\nt1/2 extension (~11-12 d)", fillcolor="#A9DFBF"];
  }

  // ─── Cluster 12: Clinical Endpoints ──────────────────────────────────────────
  subgraph cluster_endpoints {
    label="Clinical Endpoints & Biomarkers";
    style=filled; color="#FDFEFE"; fontcolor="#2C3E50"; fontsize=10; penwidth=2;

    EP_PLT    [label="Platelet Count\n(x10e9/L)\nTMA response", fillcolor="#FAD7A0"];
    EP_LDH    [label="LDH Normalization\n< 1.0 x ULN\nPrimary endpoint", fillcolor="#FAD7A0"];
    EP_Hgb    [label="Hemoglobin Recovery\nHgb >= 10 g/dL", fillcolor="#FAD7A0"];
    EP_Hpg    [label="Haptoglobin\nNormalization >= 0.1 g/L", fillcolor="#FAD7A0"];
    EP_GFR    [label="eGFR Improvement\nmL/min/1.73m2\nserial monitoring", fillcolor="#AED6F1"];
    EP_sC5b9  [label="sC5b-9 < 244 ng/mL\ncomplement control\nbiomarker", fillcolor="#F9E79F"];
    EP_CH50   [label="CH50 -> 0%\nfunctional complement\nblockade confirmed", fillcolor="#F9E79F"];
    EP_TMA    [label="TMA Event-Free\nSurvival\n(primary composite)", fillcolor="#A9DFBF"];
    EP_dialysis_free [label="Dialysis-Free\nSurvival", fillcolor="#A9DFBF"];
    EP_transfusion_free [label="Transfusion-Free\nSurvival", fillcolor="#A9DFBF"];
    EP_BSAS   [label="aHUS Activity Score\n(BSAS)\nPatient-Reported Outcome", fillcolor="#D7BDE2"];
    EP_CRP    [label="CRP Normalization\n< 10 mg/L", fillcolor="#FADBD8"];
  }

  // ─── Cluster 13: Clinical Management ─────────────────────────────────────────
  subgraph cluster_monitoring {
    label="Clinical Monitoring & Management";
    style=filled; color="#F2F3F4"; fontcolor="#2C3E50"; fontsize=10; penwidth=2;

    CBC_monitor   [label="CBC Monitoring\n(q2w initially)", fillcolor="#E8E8E8"];
    renal_monitor [label="Renal Function\nMonitoring (Cr, GFR)", fillcolor="#E8E8E8"];
    complement_monitor [label="Complement Panel\nC3, C4, CH50, sC5b-9", fillcolor="#E8E8E8"];
    genetic_test  [label="Genetic Testing\nCFH, CFI, CD46, C3\nCFB, CFHR, THBD", fillcolor="#BDC3C7"];
    anti_CFH_test [label="Anti-CFH Ab Screening\nELISA (guides Rx)", fillcolor="#BDC3C7"];
    treatment_decision [label="Treatment Decision\nEculizumab initiation\nwithin 24h of diagnosis", fillcolor="#2C3E50", fontcolor=white];
    discontinuation [label="Discontinuation\nConsideration\nGenotype-guided (CD46)", fillcolor="#7F8C8D", fontcolor=white];
    meningitis_ppx [label="Meningococcal Prophylaxis\nAntibiotics x2 weeks\nif urgent start pre-vax", fillcolor="#BDC3C7"];
  }

  // ═══════════════════════════════════════════════════════════════════════════
  // EDGES
  // ═══════════════════════════════════════════════════════════════════════════

  // Genetic factors
  CFH_mut -> CFH_prot [label="LOF", color="#C0392B", style=dashed];
  CFI_mut -> CFI_prot [label="LOF", color="#C0392B", style=dashed];
  CD46_mut -> CD46_MCP [label="LOF", color="#C0392B", style=dashed];
  C3_mut -> C3bBb [label="GOF stability", color="#E74C3C", style=dashed];
  CFB_mut -> C3bBb [label="GOF", color="#E74C3C", style=dashed];
  CFHR_del -> anti_CFH [label="predisposes", color="#9B59B6", style=dashed];
  THBD_mut -> Thrombomod [label="LOF", color="#C0392B", style=dashed];
  DGKE_mut -> EC_activated [label="phospholipid\ndysreg", color="#C0392B", style=dashed];
  anti_CFH -> CFH_prot [label="neutralizes", color="#C0392B", arrowhead=tee, penwidth=2];
  CFHR1 -> CFH_prot [label="competes at C3b\nbinding sites", color="#E67E22", style=dashed];
  trigger_infect -> AP_amplify [label="complement\nactivation", color="#E74C3C"];
  trigger_preg -> AP_amplify [label="systemic stress", color="#E74C3C"];

  // Alternative Pathway
  C3 -> C3_tickover [label="spontaneous\nhydrolysis"];
  C3_tickover -> C3H2O [label="~0.5%/h"];
  C3H2O -> CFB [label="binds", style=dashed];
  CFD -> Bb [label="cleaves CFB"];
  CFB -> Bb [label="cleaved by CFD"];
  C3H2O -> C3bBb [label="+ Bb forms"];
  Properdin -> C3bBb [label="stabilizes"];
  C3bBb -> Properdin [label="", style=invis];
  C3bBb -> C3bBbP [label="with Properdin"];
  C3bBb -> C3 [label="cleaves", color="#2980B9"];
  C3 -> C3b_depos [label="covalent\nbinding to surface"];
  C3 -> C3a [label="23 aa\nfragment released"];
  C3b_depos -> AP_amplify [label="positive feedback\nrecruit CFB+CFD", style=bold, color="#E74C3C"];
  AP_amplify -> C3bBb [label="more C3 convertase", color="#E74C3C", penwidth=2];
  C3b_depos -> iC3b [label="CFI + CFH/CD46", color="#27AE60"];
  iC3b -> C3dg [label="CFI + CR1"];

  // Classical/Lectin Pathway
  IC_deposit -> C1q [label="IgG/IgM\nbind C1q", style=dashed];
  PAMP -> MBL [label="mannose\nrecognition"];
  C1q -> C1r -> C1s;
  C1s -> C4 [label="cleaves"];
  C4 -> C4b [label="thioester\nbond opens"];
  C1s -> C2 [label="cleaves"];
  C2 -> C2a;
  C4b -> C4b2a [label="+ C2a"];
  C2a -> C4b2a;
  MBL -> MASP2 [label="activates"];
  MASP2 -> C4 [label="cleaves"];
  MASP2 -> C2 [label="cleaves"];

  // Complement Regulation
  CFH_prot -> C3bBb [label="DAA\n(decay)", arrowhead=tee, color="#27AE60", penwidth=2];
  CFH_prot -> C3b_depos [label="cofactor\n(C3b->iC3b)", color="#27AE60"];
  CFI_prot -> C3b_depos [label="cleaves C3b", arrowhead=tee, color="#27AE60"];
  CD46_MCP -> C3b_depos [label="membrane\ncofactor for CFI", color="#27AE60", arrowhead=tee];
  CD55_DAF -> C3bBb [label="accelerates\ndecay", arrowhead=tee, color="#27AE60"];
  CD55_DAF -> C4b2a [label="accelerates\ndecay", arrowhead=tee, color="#27AE60"];
  CD59 -> MAC [label="blocks C9\npolymerization", arrowhead=tee, color="#27AE60", penwidth=2];
  C4bp -> C4b [label="binds / cofactor\nfor CFI", arrowhead=tee, color="#27AE60"];
  CR1 -> C3b_depos [label="DAA + cofactor", arrowhead=tee];
  Vitronectin -> MAC [label="MAC inhibitor\n(soluble)", arrowhead=tee, color="#27AE60"];
  Clusterin -> MAC [label="inhibits", arrowhead=tee, color="#27AE60"];
  Thrombomod -> CFI_prot [label="cofactor on EC\n(THBD)", style=dashed];

  // Terminal Pathway
  C3b_depos -> C5conv [label="C3b2Bb forms\nC5 convertase"];
  C4b2a -> C5conv [label="+ C3b -> C5conv (CP)"];
  AP_amplify -> C5conv [label="high C3b\nburden", style=bold];
  C5conv -> C5 [label="CLEAVES", color="#E67E22", penwidth=2];
  C5 -> C5a [label="67 aa\nfragment", color="#E74C3C"];
  C5 -> C5b [label="large\nfragment", color="#F39C12"];
  C5b -> C6 [label="binds C6"];
  C6 -> C7 [label="+ C7"];
  C7 -> C8 [label="inserts\nmembrane"];
  C8 -> C9 [label="polymerizes\nC9 x18"];
  C9 -> MAC [label="10nm pore\nforms", penwidth=2, color="#922B21"];
  MAC -> sC5b9 [label="shed from\nsurface", style=dashed];
  C5a -> C5aR1 [label="binds\n(EC50~0.1nM)", color="#E74C3C"];
  C5a -> C5aR2 [label="alternate"];
  CH50_calc -> C5 [label="measures\nactivity", style=dashed];

  // Endothelial injury
  MAC -> EC_normal [label="inserts", color="#922B21", penwidth=2];
  EC_normal -> EC_activated [label="sub-lytic MAC"];
  EC_normal -> EC_injured [label="lytic MAC", color="#C0392B", penwidth=2];
  EC_activated -> P_selectin;
  EC_activated -> ICAM1;
  EC_activated -> vWF_release;
  EC_activated -> TF_exp;
  EC_injured -> EC_apoptosis [label="pore -> Ca2+"];
  EC_injured -> ROS_gen;
  EC_injured -> eNOS_inhib;
  eNOS_inhib -> NO_reduce;
  EC_apoptosis -> subendo_exp;
  subendo_exp -> PLT_activated [label="collagen/vWF"];
  TF_exp -> coag_cascade;
  coag_cascade -> thrombin [label="thrombin\ngeneration"];
  thrombin -> fibrin_dep [label="fibrin\npolymerization"];
  thrombin -> PLT_activated [label="PAR1/PAR4", color="#E74C3C"];
  vWF_release -> ULvWF [label="multimer\nanchor"];
  ULvWF -> PLT_activated [label="GP Ib binding"];
  ADAMTS13 -> ULvWF [label="normally\ncleaves", arrowhead=tee, color="#27AE60"];
  C5aR1 -> EC_activated [label="C5a signaling", color="#E74C3C"];

  // Platelet / Hematology
  PLT_activated -> PLT_aggregate [label="GP IIb/IIIa"];
  PLT_aggregate -> PLT_consumed [label="microthrombus\ntrapping"];
  PLT_consumed -> thrombocytopenia [label="count down", color="#C0392B"];
  thrombocytopenia -> transfusion [label="if <20x10e9/L", style=dashed];
  PLT_aggregate -> fibrin_dep;
  fibrin_dep -> RBC_fragment [label="shear stress", color="#C0392B", penwidth=2];
  RBC_fragment -> schistocytes;
  RBC_fragment -> hemolysis;
  hemolysis -> LDH_elev [label="LDH release", color="#E74C3C"];
  hemolysis -> free_Hgb;
  free_Hgb -> haptoglobin [label="Hgb-Hpg\ncomplex -> consume", arrowhead=tee];
  free_Hgb -> ROS_gen [label="Fenton", style=dashed];
  hemolysis -> anemia [label="MAHA", color="#C0392B"];
  anemia -> transfusion [label="symptomatic\nHgb <7-8", style=dashed];

  // Renal
  MAC -> glom_EC [label="complement\nattack", color="#922B21"];
  EC_injured -> glom_EC;
  glom_EC -> glom_TMA;
  fibrin_dep -> glom_TMA;
  PLT_aggregate -> glom_TMA;
  glom_TMA -> mesangial_thick;
  glom_TMA -> podocyte_inj;
  glom_TMA -> GBM_damage;
  glom_TMA -> GFR_reduced [label="capillary\nocclusion", color="#C0392B", penwidth=2];
  GFR_reduced -> proteinuria;
  GFR_reduced -> hematuria;
  GFR_reduced -> renal_HTN [label="RAAS up"];
  tubular_isch -> GFR_reduced [label="ATN", color="#C0392B"];
  GFR_reduced -> chronic_fibrosis [label="CKD progress", style=dashed];
  chronic_fibrosis -> ESRD [label="long-term", color="#922B21"];
  ESRD -> dialysis [label="RRT", style=dashed];

  // Extrarenal
  MAC -> CNS_TMA;
  MAC -> cardiac_TMA;
  MAC -> GI_TMA;
  MAC -> pulm_TMA;
  MAC -> liver_TMA;
  renal_HTN -> systemic_HTN;
  anemia -> fatigue;
  systemic_HTN -> fatigue [style=dashed];
  ESRD -> mortality [label="if untreated", style=dashed];
  CNS_TMA -> mortality [style=dashed];
  cardiac_TMA -> mortality [style=dashed];

  // Inflammation
  C5aR1 -> C5a_neutrophil;
  C5aR1 -> C5a_macrophage;
  C5a_neutrophil -> neutrophil_ROS;
  C5a_macrophage -> IL1B;
  C5a_macrophage -> IL6;
  C5a_macrophage -> TNFa;
  IL6 -> CRP;
  C3a -> C3a_effect;
  TNFa -> EC_activated [style=dashed];
  neutrophil_ROS -> EC_injured [style=dashed];
  RAAS_act -> renal_HTN;

  // Drug PK
  Eculizumab -> Drug_central [label="IV infusion\n900-1200 mg"];
  Drug_central -> Drug_periph [label="Q ~0.54 L/d"];
  Drug_periph -> Drug_central [label="redistrib"];
  Drug_central -> FcRn_recycle [label="endosomal"];
  FcRn_recycle -> Drug_central [label="t1/2 ~11-12d"];
  Drug_central -> Drug_TMDD [label="C5 binding\nKd ~10 pM"];

  // Drug effects on complement
  Eculizumab -> C5 [label="BLOCKS cleavage\n(Kd ~10 pM)", arrowhead=tee, color="#27AE60", penwidth=3];
  Ravulizumab -> C5 [label="BLOCKS C5\n(q8w dosing)", arrowhead=tee, color="#1E8449", penwidth=3];
  Iptacopan -> CFB [label="oral fBi\nblocks Bb formation", arrowhead=tee, color="#52BE80", penwidth=2];
  Danicopan -> CFD [label="oral fDi\nadd-on", arrowhead=tee, color="#58D68D", penwidth=2];
  Avacopan -> C5aR1 [label="C5aR1 antagonist\n30 mg BID", arrowhead=tee, color="#73C6B6", penwidth=2];
  Pegcetacoplan -> C3 [label="anti-C3\nbroad block", arrowhead=tee, color="#76D7C4", penwidth=2];
  Crovalimab -> C5 [label="SC anti-C5\nrecycling mAb", arrowhead=tee, color="#45B39D", penwidth=2];
  Plasma_EX -> anti_CFH [label="removes Ab", arrowhead=tee, color="#A9DFBF"];
  Plasma_INF -> CFH_prot [label="replenishes CFH", color="#A9DFBF"];
  Meningococcal_vax -> treatment_decision [label="prerequisite", style=dashed];

  // Drug -> clinical benefit
  Eculizumab -> MAC [label="reduces MAC\nformation", arrowhead=tee, color="#27AE60", penwidth=2];
  Eculizumab -> C5a [label="reduces C5a", arrowhead=tee, color="#27AE60"];

  // Clinical outcomes
  thrombocytopenia -> EP_PLT;
  LDH_elev -> EP_LDH;
  anemia -> EP_Hgb;
  haptoglobin -> EP_Hpg;
  GFR_reduced -> EP_GFR;
  sC5b9 -> EP_sC5b9;
  CH50_calc -> EP_CH50;
  ESRD -> EP_dialysis_free [label="prevention"];
  transfusion -> EP_transfusion_free [label="avoidance"];
  CRP -> EP_CRP;
  EP_PLT -> EP_TMA [label="composite"];
  EP_LDH -> EP_TMA;
  EP_GFR -> EP_TMA;
  EP_Hgb -> EP_TMA;
  fatigue -> EP_BSAS;

  // Monitoring
  EP_PLT -> CBC_monitor [style=dashed];
  EP_GFR -> renal_monitor [style=dashed];
  EP_sC5b9 -> complement_monitor [style=dashed];
  genetic_test -> CFH_mut [label="genotype\nguides Rx", style=dashed];
  anti_CFH_test -> anti_CFH [label="screening", style=dashed];
  treatment_decision -> Eculizumab [label="initiate ASAP", color="#27AE60", penwidth=2];
  complement_monitor -> treatment_decision [style=dashed];
  meningitis_ppx -> treatment_decision [style=dashed];
  discontinuation -> Eculizumab [label="relapse risk\n30-50%", style=dashed, arrowhead=tee];
}
