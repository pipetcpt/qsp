digraph NAFLD_QSP {
  graph [
    label="NAFLD/NASH Quantitative Systems Pharmacology Model\nNon-Alcoholic Fatty Liver Disease / Non-Alcoholic Steatohepatitis"
    labelloc=t
    fontsize=22
    fontname="Helvetica-Bold"
    rankdir=TB
    splines=curved
    nodesep=0.4
    ranksep=0.6
    bgcolor="#FAFAFA"
    compound=true
  ]
  node [fontname="Helvetica" fontsize=10 style=filled shape=box]
  edge [fontname="Helvetica" fontsize=8 color="#555555"]

  // ============================================================
  // CLUSTER 1: Dietary Input & Gut-Liver Axis
  // ============================================================
  subgraph cluster_diet {
    label="Dietary Input & Gut-Liver Axis"
    fontsize=14 fontname="Helvetica-Bold"
    style=filled fillcolor="#E8F5E9" color="#388E3C" penwidth=2

    DIET_FAT   [label="Dietary Fat\n(SFA/MUFA/PUFA)" fillcolor="#C8E6C9"]
    DIET_FRUCT [label="Dietary Fructose\n/ Sucrose"     fillcolor="#C8E6C9"]
    DIET_CHO   [label="Dietary\nCarbohydrates"          fillcolor="#C8E6C9"]
    INTESTINE  [label="Small Intestine\nAbsorption"     fillcolor="#A5D6A7"]
    CHYLOMICRON[label="Chylomicron\nFormation (apoB-48)" fillcolor="#81C784"]
    PORTAL_FFA [label="Portal Free Fatty\nAcids (FFAs)"  fillcolor="#66BB6A"]
    PORTAL_TG  [label="Portal Chylomicron\nRemnants (TG)" fillcolor="#66BB6A"]
    FRUCTOSE_P [label="Fructose-1-P\nMetabolism"        fillcolor="#A5D6A7"]
    BILE_POOL  [label="Bile Acid Pool\n(Primary/Secondary)" fillcolor="#A5D6A7"]
    BILE_EHC   [label="Enterohepatic\nCirculation"      fillcolor="#81C784"]
    GUTHARM    [label="Gut Permeability\n(Leaky Gut)"   fillcolor="#A5D6A7"]
    LPS_PORTAL [label="Portal LPS\n(Endotoxin)"         fillcolor="#EF9A9A"]
  }

  // ============================================================
  // CLUSTER 2: Gut Microbiome
  // ============================================================
  subgraph cluster_microbiome {
    label="Gut Microbiome"
    fontsize=14 fontname="Helvetica-Bold"
    style=filled fillcolor="#F3E5F5" color="#7B1FA2" penwidth=2

    MICROBIOME [label="Gut Microbiome\nComposition"     fillcolor="#E1BEE7"]
    DYSBIOSIS  [label="Dysbiosis\n(Firmicutes:Bacteroidetes ↑)" fillcolor="#CE93D8"]
    SCFA       [label="Short-Chain Fatty\nAcids (Butyrate/Propionate)" fillcolor="#BA68C8"]
    LPS_MICRO  [label="Gram-negative\nBacterial LPS"    fillcolor="#EF9A9A"]
    TRIMETHYL  [label="TMAO\n(Trimethylamine N-oxide)"  fillcolor="#CE93D8"]
    BILE_TRANS [label="Bile Acid\nTransformation\n(BSH enzymes)" fillcolor="#BA68C8"]
    TJP_LOSS   [label="Tight Junction\nProtein Loss\n(ZO-1, Occludin ↓)" fillcolor="#E1BEE7"]
    ETOH_MICRO [label="Ethanol Produced\nby Microbiome"  fillcolor="#CE93D8"]
  }

  // ============================================================
  // CLUSTER 3: Hepatic Lipid Metabolism
  // ============================================================
  subgraph cluster_lipid {
    label="Hepatic Lipid Metabolism (Steatosis)"
    fontsize=14 fontname="Helvetica-Bold"
    style=filled fillcolor="#E3F2FD" color="#1565C0" penwidth=2

    HEP_FFA    [label="Hepatic Free\nFatty Acid Pool"   fillcolor="#BBDEFB"]
    DNL        [label="De Novo Lipogenesis\n(DNL)"       fillcolor="#90CAF9"]
    SREBP1C    [label="SREBP-1c\n(Lipogenic TF)"        fillcolor="#64B5F6"]
    CHREBP     [label="ChREBP\n(Glucose-driven DNL)"    fillcolor="#64B5F6"]
    FASN       [label="Fatty Acid Synthase\n(FASN)"     fillcolor="#42A5F5"]
    FAO        [label="Fatty Acid Oxidation\n(β-oxidation)" fillcolor="#90CAF9"]
    CPT1A      [label="CPT1A\n(Mitochondrial Gateway)"  fillcolor="#64B5F6"]
    PPARA      [label="PPARα\n(FAO Activator)"          fillcolor="#42A5F5"]
    MALONYL    [label="Malonyl-CoA\n(CPT1 Inhibitor)"   fillcolor="#BBDEFB"]
    LIVER_TG   [label="Hepatic TG\nAccumulation"        fillcolor="#1E88E5"]
    VLDL_ASSEM [label="VLDL Assembly\n(apoB-100/MTP)"   fillcolor="#90CAF9"]
    VLDL_SECR  [label="VLDL-TG\nSecretion"              fillcolor="#64B5F6"]
    CERAMIDE   [label="Ceramide\n(Lipotoxic Mediator)"  fillcolor="#EF9A9A"]
    DAG        [label="Diacylglycerol\n(DAG / PKC-ε)"  fillcolor="#EF9A9A"]
    STEATOS    [label="Hepatic Steatosis\n(NAS ≥1)"     fillcolor="#1565C0" fontcolor=white]
  }

  // ============================================================
  // CLUSTER 4: Mitochondrial Dysfunction & Oxidative Stress
  // ============================================================
  subgraph cluster_mito {
    label="Mitochondrial Dysfunction & Oxidative Stress"
    fontsize=14 fontname="Helvetica-Bold"
    style=filled fillcolor="#FFF8E1" color="#F57F17" penwidth=2

    MITO_DYSFN [label="Mitochondrial\nDysfunction"      fillcolor="#FFE082"]
    ETC_LEAK   [label="Electron Transport\nChain Leak"  fillcolor="#FFD54F"]
    ROS        [label="Reactive Oxygen\nSpecies (ROS)"  fillcolor="#FFCA28"]
    LIPID_PERO [label="Lipid Peroxidation\n(4-HNE, MDA)" fillcolor="#FFB300"]
    ER_STRESS  [label="ER Stress\n(UPR Activation)"     fillcolor="#FFE082"]
    ATF6       [label="ATF6\n(UPR Branch)"              fillcolor="#FFD54F"]
    IRE1       [label="IRE1α/XBP1\n(UPR Branch)"       fillcolor="#FFD54F"]
    PERK       [label="PERK/eIF2α\n(UPR Branch)"       fillcolor="#FFD54F"]
    ANTIOXID   [label="Antioxidant Defense\n(SOD/GPx/Nrf2)" fillcolor="#FFE082"]
    NRF2       [label="Nrf2 Pathway\n(Antioxidant TF)"  fillcolor="#FFD54F"]
    MPTP       [label="Mitochondrial\nPermeability Pore" fillcolor="#FFCA28"]
    APOPTOSIS  [label="Hepatocyte\nApoptosis (TUNEL+)"  fillcolor="#F44336" fontcolor=white]
  }

  // ============================================================
  // CLUSTER 5: Inflammatory Signaling (NASH)
  // ============================================================
  subgraph cluster_inflam {
    label="Inflammatory Signaling (Necroinflammation — NASH)"
    fontsize=14 fontname="Helvetica-Bold"
    style=filled fillcolor="#FFEBEE" color="#B71C1C" penwidth=2

    TLR4       [label="TLR4 Signaling\n(LPS Receptor)"  fillcolor="#FFCDD2"]
    TLR2       [label="TLR2\n(Bacterial PAMPs)"         fillcolor="#FFCDD2"]
    NLRP3      [label="NLRP3\nInflammasome"             fillcolor="#EF9A9A"]
    KUPFFER    [label="Kupffer Cell\nActivation (M1)"   fillcolor="#E53935"]
    KUPFFER_M2 [label="Kupffer Cell\nPolarization (M2)" fillcolor="#EF9A9A"]
    NFKB       [label="NF-κB Pathway\n(p65/p50)"       fillcolor="#EF9A9A"]
    TNFA       [label="TNF-α\n(pro-inflammatory)"       fillcolor="#E53935" fontcolor=white]
    IL1B       [label="IL-1β\n(Inflammasome product)"   fillcolor="#E53935" fontcolor=white]
    IL6        [label="IL-6\n(Acute phase response)"    fillcolor="#EF9A9A"]
    IL8        [label="IL-8 / CXCL1\n(Neutrophil chemoattractant)" fillcolor="#FFCDD2"]
    IL10       [label="IL-10\n(Anti-inflammatory)"      fillcolor="#A5D6A7"]
    IL18       [label="IL-18\n(NLRP3 product)"         fillcolor="#FFCDD2"]
    NEUT_INFIL [label="Neutrophil\nInfiltration"        fillcolor="#EF9A9A"]
    MACRO_RECR [label="Monocyte-derived\nMacrophage Recruitment" fillcolor="#FFCDD2"]
    NLOB       [label="Hepatocyte\nBallooning (NAS ≥2)" fillcolor="#E53935" fontcolor=white]
  }

  // ============================================================
  // CLUSTER 6: Fibrosis Pathway
  // ============================================================
  subgraph cluster_fibrosis {
    label="Hepatic Fibrosis Pathway"
    fontsize=14 fontname="Helvetica-Bold"
    style=filled fillcolor="#E8EAF6" color="#283593" penwidth=2

    TGFB1      [label="TGF-β1\n(Master Fibrogenic)"    fillcolor="#9FA8DA"]
    TGFBR      [label="TGF-β Receptor\n(ALK5)"         fillcolor="#7986CB"]
    SMAD23     [label="SMAD2/3\nPhosphorylation"       fillcolor="#5C6BC0"]
    SMAD7      [label="SMAD7\n(Inhibitory)"             fillcolor="#9FA8DA"]
    HSC_QUIET  [label="Quiescent HSC\n(Vitamin A Storage)" fillcolor="#C5CAE9"]
    HSC_ACTIV  [label="Activated HSC\n(Myofibroblast)" fillcolor="#3949AB" fontcolor=white]
    ASMA       [label="α-SMA Expression\n(Activation marker)" fillcolor="#5C6BC0" fontcolor=white]
    COL1A1     [label="Collagen I\n(COL1A1)"           fillcolor="#3949AB" fontcolor=white]
    COL3A1     [label="Collagen III\n(COL3A1)"         fillcolor="#5C6BC0" fontcolor=white]
    PDGF       [label="PDGF-BB\n(HSC Proliferation)"   fillcolor="#9FA8DA"]
    CTGF       [label="CTGF/CCN2\n(Fibrosis amplifier)" fillcolor="#7986CB"]
    MMP2       [label="MMP-2/9\n(Matrix Remodeling)"   fillcolor="#9FA8DA"]
    TIMP1      [label="TIMP-1\n(MMP Inhibitor)"        fillcolor="#7986CB"]
    ECM        [label="Extracellular Matrix\nAccumulation" fillcolor="#283593" fontcolor=white]
    FIB_STAGE  [label="Fibrosis Stage\n(F0→F1→F2→F3→F4)" fillcolor="#1A237E" fontcolor=white]
  }

  // ============================================================
  // CLUSTER 7: Insulin Resistance & Adipose Axis
  // ============================================================
  subgraph cluster_ir {
    label="Insulin Resistance & Adipose-Liver Axis"
    fontsize=14 fontname="Helvetica-Bold"
    style=filled fillcolor="#E0F7FA" color="#00695C" penwidth=2

    ADIPOSE_VIS[label="Visceral Adipose\nTissue (VAT)"  fillcolor="#B2EBF2"]
    ADIPOSE_SAT[label="Subcutaneous\nAdipose Tissue"    fillcolor="#B2EBF2"]
    ADIPONECTIN[label="Adiponectin\n(AdipoR1/R2)"      fillcolor="#80DEEA"]
    LEPTIN     [label="Leptin\n(Satiety/Pro-inflam)"    fillcolor="#80DEEA"]
    FFA_ADIPOSE[label="Adipose FFA\nRelease (Lipolysis)" fillcolor="#4DD0E1"]
    INSULIN    [label="Circulating Insulin\n(Hyperinsulinemia)" fillcolor="#00ACC1"]
    IR_INDEX   [label="Insulin Resistance\n(HOMA-IR)"  fillcolor="#00838F" fontcolor=white]
    IRS1       [label="IRS-1\n(pSer307 — inactivated)"  fillcolor="#4DD0E1"]
    PI3K_AKT   [label="PI3K/Akt Pathway\n(Impaired)"   fillcolor="#80DEEA"]
    GLUT2      [label="GLUT2\n(Hepatic Glucose Uptake)" fillcolor="#B2EBF2"]
    GLUCONEOG  [label="Gluconeogenesis\n(PEPCK, G6Pase ↑)" fillcolor="#4DD0E1"]
    FOXO1      [label="FOXO1\n(Gluconeogenic TF)"       fillcolor="#80DEEA"]
    AMPK       [label="AMPK\n(Energy Sensor)"           fillcolor="#B2EBF2"]
    SIRT1      [label="SIRT1\n(Metabolic Regulator)"    fillcolor="#80DEEA"]
  }

  // ============================================================
  // CLUSTER 8: Drug PK/PD — Resmetirom & Other Agents
  // ============================================================
  subgraph cluster_drug {
    label="Drug PK/PD — Resmetirom (THRβ), OCA (FXR), Semaglutide (GLP-1R), SGLT2i"
    fontsize=14 fontname="Helvetica-Bold"
    style=filled fillcolor="#FCE4EC" color="#880E4F" penwidth=2

    // Resmetirom
    RSM_GUT    [label="Resmetirom\nGut Absorption"      fillcolor="#F8BBD9"]
    RSM_CENT   [label="Resmetirom\nCentral (Cp)"        fillcolor="#F48FB1"]
    RSM_PERI   [label="Resmetirom\nPeripheral (Ct)"     fillcolor="#F48FB1"]
    RSM_LIVER  [label="Resmetirom\nLiver Conc. (Cl)"    fillcolor="#E91E8C" fontcolor=white]
    THRB       [label="Thyroid Hormone\nReceptor β (THRβ)" fillcolor="#AD1457" fontcolor=white]
    THR_ACT    [label="THRβ Activation\n(RXR heterdimer)" fillcolor="#880E4F" fontcolor=white]

    // OCA / FXR
    OCA_CENT   [label="Obeticholic Acid\nCentral (Cp)"  fillcolor="#F8BBD9"]
    FXR        [label="Farnesoid X\nReceptor (FXR)"     fillcolor="#F48FB1"]
    FXR_ACT    [label="FXR Activation\n(SHP induction)"  fillcolor="#E91E8C" fontcolor=white]
    SHP        [label="SHP\n(CYP7A1 repressor)"         fillcolor="#F48FB1"]

    // Semaglutide
    SEMA_SC    [label="Semaglutide\nSC Absorption"      fillcolor="#F8BBD9"]
    SEMA_CENT  [label="Semaglutide\nCentral (Cp)"       fillcolor="#F48FB1"]
    GLP1R_LIV  [label="GLP-1 Receptor\n(Hepatic)"       fillcolor="#E91E8C" fontcolor=white]
    GLP1R_CNS  [label="GLP-1 Receptor\n(CNS / Appetite)" fillcolor="#F48FB1"]

    // SGLT2i
    SGLT2I_CEN [label="SGLT2 Inhibitor\nCentral (Cp)"   fillcolor="#F8BBD9"]
    SGLT2      [label="SGLT2\n(Renal Glucose Transport)" fillcolor="#F48FB1"]
    UGE        [label="Urinary Glucose\nExcretion (UGE)" fillcolor="#F8BBD9"]
  }

  // ============================================================
  // CLUSTER 9: Biomarkers & Clinical Endpoints
  // ============================================================
  subgraph cluster_endpoints {
    label="Biomarkers & Clinical Endpoints"
    fontsize=14 fontname="Helvetica-Bold"
    style=filled fillcolor="#F9FBE7" color="#558B2F" penwidth=2

    ALT        [label="ALT\n(Liver injury marker)"      fillcolor="#F0F4C3"]
    AST        [label="AST\n(Liver injury marker)"      fillcolor="#F0F4C3"]
    GGT        [label="GGT\n(Biliary marker)"           fillcolor="#F0F4C3"]
    PDFF       [label="MRI-PDFF\n(Hepatic Fat %)"       fillcolor="#DCE775"]
    LSM        [label="Liver Stiffness\n(kPa — FibroScan)" fillcolor="#DCE775"]
    NAS_SCORE  [label="NAFLD Activity\nScore (NAS 0-8)" fillcolor="#CDDC39"]
    FIB4       [label="FIB-4 Index\n(Non-invasive fibrosis)" fillcolor="#CDDC39"]
    ELF_SCORE  [label="ELF Score\n(PIIINP/TIMP1/HA)"   fillcolor="#DCE775"]
    PRO_C3     [label="PRO-C3\n(Type III collagen biomarker)" fillcolor="#F0F4C3"]
    LDL_C      [label="LDL-C\n(Atherogenic)"            fillcolor="#F0F4C3"]
    TRIG       [label="Triglycerides\n(Serum TG)"       fillcolor="#F0F4C3"]
    HDL_C      [label="HDL-C\n(Protective)"             fillcolor="#F0F4C3"]
    HBA1C      [label="HbA1c\n(Glycemic control)"       fillcolor="#CDDC39"]
    HOMA_IR    [label="HOMA-IR\n(Insulin resistance)"   fillcolor="#CDDC39"]
    CRP        [label="hs-CRP\n(Systemic inflammation)"  fillcolor="#F0F4C3"]
    NASH_RES   [label="NASH Resolution\n(Primary endpoint)" fillcolor="#558B2F" fontcolor=white]
    CIRRH      [label="Cirrhosis\n(F4 / Complications)" fillcolor="#33691E" fontcolor=white]
    HCC        [label="HCC Risk\n(Hepatocellular Carcinoma)" fillcolor="#1B5E20" fontcolor=white]
  }

  // ============================================================
  // CLUSTER 10: Systemic Metabolic Context
  // ============================================================
  subgraph cluster_metabolic {
    label="Systemic Metabolic Context"
    fontsize=14 fontname="Helvetica-Bold"
    style=filled fillcolor="#FFFDE7" color="#F57F17" penwidth=2

    BMI        [label="BMI / Obesity\n(Central adiposity)" fillcolor="#FFF9C4"]
    HYPERGL    [label="Hyperglycemia\n(Fasting glucose)"  fillcolor="#FFF176"]
    DYSLIPID   [label="Dyslipidemia\n(↑TG, ↓HDL)"       fillcolor="#FFF176"]
    HYPERTENS  [label="Hypertension\n(MetS component)"   fillcolor="#FFF9C4"]
    METAB_SYND [label="Metabolic Syndrome\n(Central)"    fillcolor="#FFEE58"]
    PCOS_RISK  [label="PCOS Association\n(Androgen ↑)"   fillcolor="#FFF9C4"]
    T2DM_COM   [label="T2DM Comorbidity\n(~50% NASH)"    fillcolor="#FFF176"]
    CVD_RISK   [label="Cardiovascular\nRisk (↑MACE)"     fillcolor="#FFCA28"]
    WEIGHT_LOSS[label="Body Weight\nReduction"           fillcolor="#FFF9C4"]
    CALORIC_RES[label="Caloric Restriction\n/ Exercise"  fillcolor="#FFF9C4"]
    FIBROSIS_REV[label="Fibrosis\nRegression"            fillcolor="#FFF176"]
  }

  // ============================================================
  // EDGES — Dietary Input & Gut-Liver Axis
  // ============================================================
  DIET_FAT    -> INTESTINE    [label="absorption"]
  DIET_FRUCT  -> INTESTINE    [label="absorption"]
  DIET_CHO    -> INTESTINE    [label="absorption"]
  INTESTINE   -> CHYLOMICRON  [label="packaging"]
  INTESTINE   -> FRUCTOSE_P   [label="fructolysis"]
  CHYLOMICRON -> PORTAL_TG    [label="lymph→portal"]
  PORTAL_TG   -> HEP_FFA      [label="LPL hydrolysis"]
  FRUCTOSE_P  -> DNL          [label="acetyl-CoA ↑"]
  FRUCTOSE_P  -> CHREBP        [label="induces"]
  DIET_FAT    -> PORTAL_FFA   [label="direct absorption"]
  PORTAL_FFA  -> HEP_FFA      [label="uptake (CD36)"]
  MICROBIOME  -> DYSBIOSIS    [label="imbalance"]
  DYSBIOSIS   -> LPS_MICRO    [label="↑LPS"]
  DYSBIOSIS   -> SCFA         [label="↓SCFA"]
  DYSBIOSIS   -> BILE_TRANS   [label="altered BSH"]
  DYSBIOSIS   -> TJP_LOSS     [label="epithelial damage"]
  TJP_LOSS    -> GUTHARM      [label="↑permeability"]
  GUTHARM     -> LPS_PORTAL   [label="LPS translocation"]
  LPS_MICRO   -> LPS_PORTAL   [label="systemic"]
  BILE_TRANS  -> BILE_EHC     [label="altered pool"]
  BILE_POOL   -> BILE_EHC     [label="recycling"]
  BILE_EHC    -> FXR          [label="bile acid sensing"]
  SCFA        -> AMPK         [label="AMPK activation"]
  ETOH_MICRO  -> HEP_FFA      [label="ethanol→fatty acids"]

  // ============================================================
  // EDGES — Hepatic Lipid Metabolism
  // ============================================================
  HEP_FFA     -> LIVER_TG     [label="esterification"]
  HEP_FFA     -> FAO          [label="β-oxidation (↑)"]
  HEP_FFA     -> CERAMIDE     [label="sphingolipid synth"]
  HEP_FFA     -> DAG          [label="DAG accumulation"]
  HEP_FFA     -> MITO_DYSFN   [label="lipotoxicity"]
  DNL         -> HEP_FFA      [label="new FA synthesis"]
  SREBP1C     -> DNL          [label="transcription ↑"]
  CHREBP      -> DNL          [label="transcription ↑"]
  INSULIN     -> SREBP1C      [label="Akt→SREBP ↑"]
  FASN        -> HEP_FFA      [label="catalysis"]
  SREBP1C     -> FASN         [label="induces"]
  CPT1A       -> FAO          [label="controls entry"]
  PPARA       -> CPT1A        [label="transcription ↑"]
  MALONYL     -> CPT1A        [label="inhibits"]
  DNL         -> MALONYL      [label="ACC product"]
  LIVER_TG    -> STEATOS      [label="fat accumulation\n≥5% hepatocytes"]
  LIVER_TG    -> VLDL_ASSEM   [label="substrate"]
  VLDL_ASSEM  -> VLDL_SECR    [label="secretion"]
  VLDL_SECR   -> TRIG         [label="serum TG ↑"]
  VLDL_SECR   -> LDL_C        [label="small dense LDL ↑"]
  CERAMIDE    -> APOPTOSIS    [label="caspase activation"]
  DAG         -> IR_INDEX     [label="PKC-ε→IR"]

  // ============================================================
  // EDGES — Mitochondrial & Oxidative Stress
  // ============================================================
  HEP_FFA     -> ETC_LEAK     [label="FAO overload"]
  ETC_LEAK    -> ROS          [label="superoxide"]
  ROS         -> LIPID_PERO   [label="peroxidation"]
  ROS         -> ER_STRESS    [label="oxidative damage"]
  ROS         -> APOPTOSIS    [label="cell death"]
  ROS         -> NFKB         [label="NF-κB activation"]
  LIPID_PERO  -> TNFA         [label="cytokine ↑"]
  LIPID_PERO  -> TGFB1        [label="HSC activation"]
  ER_STRESS   -> ATF6         [label="UPR branch"]
  ER_STRESS   -> IRE1         [label="UPR branch"]
  ER_STRESS   -> PERK         [label="UPR branch"]
  ER_STRESS   -> APOPTOSIS    [label="CHOP induction"]
  MITO_DYSFN  -> MPTP         [label="pore opening"]
  MPTP        -> APOPTOSIS    [label="cytochrome c"]
  ANTIOXID    -> ROS          [label="scavenges" style=dashed color="green"]
  NRF2        -> ANTIOXID     [label="induces"]

  // ============================================================
  // EDGES — Inflammatory Signaling
  // ============================================================
  LPS_PORTAL  -> TLR4         [label="ligand-receptor"]
  TLR4        -> NFKB         [label="MyD88/TRIF"]
  TLR2        -> NFKB         [label="PAMPs"]
  NFKB        -> TNFA         [label="transcription"]
  NFKB        -> IL6          [label="transcription"]
  NFKB        -> IL8          [label="transcription"]
  NFKB        -> IL1B         [label="pro-IL-1β"]
  NLRP3       -> IL1B         [label="cleavage"]
  NLRP3       -> IL18         [label="cleavage"]
  CERAMIDE    -> NLRP3        [label="activates"]
  ROS         -> NLRP3        [label="NLRP3 priming"]
  KUPFFER     -> TNFA         [label="secretes"]
  KUPFFER     -> IL1B         [label="secretes"]
  KUPFFER     -> IL6          [label="secretes"]
  KUPFFER     -> TGFB1        [label="secretes"]
  KUPFFER     -> PDGF         [label="secretes"]
  TLR4        -> KUPFFER      [label="activates"]
  TNFA        -> IR_INDEX     [label="IKK→IRS-1 pSer"]
  TNFA        -> APOPTOSIS    [label="caspase-8"]
  TNFA        -> NLOB         [label="hepatocyte\nballooning"]
  IL1B        -> HSC_ACTIV    [label="co-activates"]
  IL6         -> MACRO_RECR   [label="chemotaxis"]
  IL8         -> NEUT_INFIL   [label="chemotaxis"]
  NEUT_INFIL  -> ROS          [label="oxidative burst"]
  MACRO_RECR  -> KUPFFER      [label="replenish"]
  IL10        -> KUPFFER      [label="M2 shift" style=dashed color="blue"]
  IL10        -> KUPFFER_M2   [label="polarization"]
  KUPFFER_M2  -> IL10         [label="produces"]
  APOPTOSIS   -> NLOB         [label="ballooning\ncell death"]
  NLOB        -> NAS_SCORE    [label="NAS +2"]
  STEATOS     -> NAS_SCORE    [label="NAS +1–3"]

  // ============================================================
  // EDGES — Fibrosis Pathway
  // ============================================================
  TGFB1       -> TGFBR        [label="binding"]
  TGFBR       -> SMAD23       [label="phosphorylation"]
  SMAD23      -> COL1A1       [label="transcription"]
  SMAD23      -> COL3A1       [label="transcription"]
  SMAD23      -> CTGF         [label="transcription"]
  SMAD23      -> ASMA         [label="transcription"]
  SMAD7       -> TGFBR        [label="inhibits" style=dashed color="blue"]
  HSC_QUIET   -> HSC_ACTIV    [label="activation\n(TGF-β/PDGF)"]
  PDGF        -> HSC_ACTIV    [label="proliferation"]
  HSC_ACTIV   -> COL1A1       [label="produces"]
  HSC_ACTIV   -> COL3A1       [label="produces"]
  HSC_ACTIV   -> TIMP1        [label="produces"]
  HSC_ACTIV   -> MMP2         [label="produces"]
  COL1A1      -> ECM          [label="accumulates"]
  COL3A1      -> ECM          [label="accumulates"]
  TIMP1       -> MMP2         [label="inhibits" style=dashed color="blue"]
  ECM         -> FIB_STAGE    [label="progressive\ndeposition"]
  FIB_STAGE   -> LSM          [label="↑stiffness"]
  FIB_STAGE   -> FIB4         [label="correlates"]
  FIB_STAGE   -> ELF_SCORE    [label="correlates"]
  PRO_C3      -> ELF_SCORE    [label="component"]
  CTGF        -> ECM          [label="amplifies"]
