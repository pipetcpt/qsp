digraph Psoriasis_QSP {
    graph [
        label="Psoriasis QSP Mechanistic Map\nIL-23/IL-17 Axis · TNF · Keratinocyte Hyperproliferation · Drug PK/PD"
        labelloc=t
        fontsize=20
        fontname="Helvetica-Bold"
        rankdir=LR
        splines=true
        nodesep=0.35
        ranksep=0.65
        bgcolor="#FAFAFA"
        compound=true
        overlap=false
    ]
    node [fontname="Helvetica" fontsize=9 style="filled,rounded" shape=box margin="0.1,0.05"]
    edge [fontname="Helvetica" fontsize=8]

    //==========================================================
    // CLUSTER 1: GENETIC & ENVIRONMENTAL TRIGGERS
    //==========================================================
    subgraph cluster_trigger {
        label="Genetic & Environmental Triggers"
        style=filled fillcolor="#FFF3E0" color="#E65100" penwidth=2
        fontsize=12 fontname="Helvetica-Bold"

        HLA_Cw6  [label="HLA-Cw6\n(PSORS1)" fillcolor="#FFB74D"]
        IL23R_g  [label="IL23R\nrisk allele" fillcolor="#FFB74D"]
        CARD14   [label="CARD14\ngain-of-fn" fillcolor="#FFB74D"]
        Strep    [label="Strep\nInfection" fillcolor="#FF8A65"]
        Trauma   [label="Koebner\nPhenomenon" fillcolor="#FF8A65"]
        Stress   [label="Psycho-\nlogical Stress" fillcolor="#FF8A65"]
        Drugs_t  [label="Drug-Induced\n(Li, β-blocker)" fillcolor="#FF8A65"]
        Obesity_t [label="Obesity\nadipokins↑" fillcolor="#FF8A65"]
        Microbiome_t [label="Skin/Gut\nDysbiosis" fillcolor="#FF8A65"]
    }

    //==========================================================
    // CLUSTER 2: INNATE IMMUNE ACTIVATION
    //==========================================================
    subgraph cluster_innate {
        label="Innate Immune Activation"
        style=filled fillcolor="#E8F5E9" color="#1B5E20" penwidth=2
        fontsize=12 fontname="Helvetica-Bold"

        pDC      [label="pDC\n(IFN-α factory)" fillcolor="#81C784"]
        IFNa     [label="IFN-α\n(type I IFN)" fillcolor="#A5D6A7"]
        mDC      [label="Myeloid DC\n(mDC)" fillcolor="#81C784"]
        LC       [label="Langerhans\nCell (LC)" fillcolor="#81C784"]
        Macro    [label="Macrophage\n(M1)" fillcolor="#81C784"]
        Neutro   [label="Neutrophil\n(DEP)" fillcolor="#81C784"]
        LL37     [label="LL-37\ncathelicidin" fillcolor="#A5D6A7"]
        DNA_cmplx [label="LL37–DNA\nComplex" fillcolor="#A5D6A7"]
        TLR79    [label="TLR7/9\nActivation" fillcolor="#A5D6A7"]
        TLR24    [label="TLR2/4\nActivation" fillcolor="#A5D6A7"]
        NLRP3    [label="NLRP3\nInflammasome" fillcolor="#A5D6A7"]
        IL1b_i   [label="IL-1β\n(innate)" fillcolor="#A5D6A7"]
        IL6_i    [label="IL-6\n(innate)" fillcolor="#A5D6A7"]
        TNF_i    [label="TNF-α\n(innate)" fillcolor="#A5D6A7"]
        CXCL8    [label="CXCL8/IL-8\nneutro-chemo" fillcolor="#C8E6C9"]
        CCL20    [label="CCL20\nTh17 chemo" fillcolor="#C8E6C9"]
        CXCL10   [label="CXCL10\nTh1 chemo" fillcolor="#C8E6C9"]
        S100A8   [label="S100A8/A9\nalarmins" fillcolor="#C8E6C9"]
    }

    //==========================================================
    // CLUSTER 3: ADAPTIVE T CELL COMPARTMENT
    //==========================================================
    subgraph cluster_adaptive {
        label="Adaptive Immune — T Cell Compartment"
        style=filled fillcolor="#E3F2FD" color="#0D47A1" penwidth=2
        fontsize=12 fontname="Helvetica-Bold"

        Th0      [label="Naïve CD4+\nT Cell (Th0)" fillcolor="#90CAF9"]
        Th17     [label="Th17 Cell\n★ Central" fillcolor="#42A5F5" penwidth=3]
        Th1      [label="Th1 Cell\n(IFN-γ, TNF)" fillcolor="#64B5F6"]
        Th22     [label="Th22 Cell\n(IL-22)" fillcolor="#64B5F6"]
        Treg     [label="Treg\n(suppressive)" fillcolor="#90CAF9"]
        Tc1      [label="CD8+ Tc1\n(cytotoxic)" fillcolor="#64B5F6"]
        TRM      [label="Tissue-Resident\nMemory Tcell" fillcolor="#90CAF9"]
        ILC3     [label="ILC3\n(innate lymphoid)" fillcolor="#64B5F6"]
        IL23_ax  [label="IL-23\n(p19/p40)" fillcolor="#BBDEFB" penwidth=3]
        IL12_ax  [label="IL-12\n(p35/p40)" fillcolor="#BBDEFB"]
        STAT3_T  [label="STAT3\nActivation" fillcolor="#BBDEFB"]
        RORgt    [label="RORγt\nTh17 TF" fillcolor="#BBDEFB"]
        Tbet     [label="T-bet\nTh1 TF" fillcolor="#BBDEFB"]
    }

    //==========================================================
    // CLUSTER 4: CYTOKINE EFFECTORS
    //==========================================================
    subgraph cluster_cytokine {
        label="Key Effector Cytokines"
        style=filled fillcolor="#FCE4EC" color="#880E4F" penwidth=2
        fontsize=12 fontname="Helvetica-Bold"

        IL17A    [label="IL-17A ★\nKey effector" fillcolor="#F48FB1" penwidth=3]
        IL17F    [label="IL-17F" fillcolor="#F8BBD9"]
        IL22     [label="IL-22\nKC activator" fillcolor="#F48FB1" penwidth=2]
        IFNg     [label="IFN-γ\n(Th1)" fillcolor="#F48FB1"]
        TNFa     [label="TNF-α ★\nKey effector" fillcolor="#F48FB1" penwidth=3]
        IL17C    [label="IL-17C\nautocrine" fillcolor="#F8BBD9"]
        IL36     [label="IL-36α/β/γ\npustular pso" fillcolor="#F8BBD9"]
        IL33     [label="IL-33\nalarmin" fillcolor="#F8BBD9"]
        TSLP     [label="TSLP\nitch signal" fillcolor="#F8BBD9"]
    }

    //==========================================================
    // CLUSTER 5: KERATINOCYTE PATHOLOGY
    //==========================================================
    subgraph cluster_keratinocyte {
        label="Keratinocyte Hyperproliferation & Differentiation"
        style=filled fillcolor="#F3E5F5" color="#4A148C" penwidth=2
        fontsize=12 fontname="Helvetica-Bold"

        KC_basal [label="Basal KC\n(stratum basale)" fillcolor="#CE93D8"]
        KC_prolif [label="KC Hyperprolif\n↑Ki67, PCNA" fillcolor="#AB47BC" penwidth=2]
        KC_apop  [label="Reduced\nApoptosis (Bcl-2↑)" fillcolor="#CE93D8"]
        Parakeratosis [label="Parakeratosis\n(retained nuclei)" fillcolor="#CE93D8"]
        Acanthosis [label="Acanthosis\n(epidermal thick)" fillcolor="#AB47BC"]
        NF_kB_KC [label="NF-κB\nActivation (KC)" fillcolor="#CE93D8"]
        STAT3_KC [label="STAT3\nActivation (KC)" fillcolor="#CE93D8"]
        STAT1_KC [label="STAT1\n(IFN-γ signaling)" fillcolor="#CE93D8"]
        JAK1_KC  [label="JAK1\n(in KC)" fillcolor="#CE93D8"]
        IL17RC   [label="IL-17RA/RC\nReceptor" fillcolor="#CE93D8"]
        IL22R1   [label="IL-22R1\nReceptor" fillcolor="#CE93D8"]
        AMPs     [label="Antimicrobial Peptides\n(β-defensins, S100)" fillcolor="#E1BEE7"]
        VEGF_KC  [label="VEGF-A\nangiogenic signal" fillcolor="#E1BEE7"]
        Loricrin [label="Loricrin/Filaggrin↓\nbarrier defect" fillcolor="#E1BEE7"]
        CARD14_KC [label="CARD14/NF-κB\nrisk variant" fillcolor="#E1BEE7"]
    }

    //==========================================================
    // CLUSTER 6: VASCULAR REMODELING
    //==========================================================
    subgraph cluster_vascular {
        label="Vascular & Stromal Remodeling"
        style=filled fillcolor="#E0F7FA" color="#006064" penwidth=2
        fontsize=12 fontname="Helvetica-Bold"

        Angio    [label="Pathological\nAngiogenesis" fillcolor="#80DEEA"]
        Endothel [label="Endothelial\nCell Activation" fillcolor="#80DEEA"]
        ICAM1    [label="ICAM-1↑" fillcolor="#B2EBF2"]
        VCAM1    [label="VCAM-1↑" fillcolor="#B2EBF2"]
        E_sel    [label="E-Selectin\nrolling" fillcolor="#B2EBF2"]
        Leuko_x  [label="Leukocyte\nExtravasation" fillcolor="#80DEEA"]
        Fibrob   [label="Dermal\nFibroblast" fillcolor="#80DEEA"]
        MMP      [label="MMP-1/3/9\nmatrix remodel" fillcolor="#B2EBF2"]
        Dermis_i [label="Dermal\nInflammation" fillcolor="#80DEEA"]
    }

    //==========================================================
    // CLUSTER 7: CLINICAL ENDPOINTS
    //==========================================================
    subgraph cluster_clinical {
        label="Clinical Manifestations & Endpoints"
        style=filled fillcolor="#FFFDE7" color="#F57F17" penwidth=2
        fontsize=12 fontname="Helvetica-Bold"

        PASI     [label="PASI Score\n(Erythema+Induration\n+Desquamation×BSA)" fillcolor="#FFF176" penwidth=3]
        BSA_inv  [label="BSA\nInvolvement %" fillcolor="#FFF9C4"]
        PGA      [label="PGA\n(Physician Global)" fillcolor="#FFF9C4"]
        DLQI     [label="DLQI\nQuality of Life" fillcolor="#FFF9C4"]
        Plaque   [label="Plaque Psoriasis\n(most common)" fillcolor="#FFE082"]
        Guttate  [label="Guttate Pso\n(post-strep)" fillcolor="#FFE082"]
        Pustular [label="GPP\n(IL-36 driven)" fillcolor="#FFE082"]
        PsA      [label="Psoriatic\nArthritis ~30%" fillcolor="#FFCC02"]
        Nail_pso [label="Nail Psoriasis\n(pitting, onycho)" fillcolor="#FFE082"]
        Itch     [label="Pruritus\n(IL-31, CGRP)" fillcolor="#FFE082"]
        Comorbid [label="Comorbidities\n(CVD, MetS, IBD)" fillcolor="#FFCC02"]
    }

    //==========================================================
    // CLUSTER 8: BIOLOGIC DRUG PK
    //==========================================================
    subgraph cluster_bio_pk {
        label="Biologic Drug PK Compartments"
        style=filled fillcolor="#E8EAF6" color="#1A237E" penwidth=2
        fontsize=12 fontname="Helvetica-Bold"

        ADA_SC [label="Adalimumab SC\nanti-TNF mAb" fillcolor="#9FA8DA"]
        ADA_C  [label="Adalimumab\nCentral Cp" fillcolor="#7986CB"]
        ADA_P  [label="Adalimumab\nPeripheral Cq" fillcolor="#7986CB"]

        SEC_SC [label="Secukinumab SC\nanti-IL-17A mAb" fillcolor="#9FA8DA"]
        SEC_C  [label="Secukinumab\nCentral Cp" fillcolor="#7986CB"]
        SEC_P  [label="Secukinumab\nPeripheral Cq" fillcolor="#7986CB"]

        RSK_SC [label="Risankizumab SC\nanti-IL23-p19" fillcolor="#9FA8DA"]
        RSK_C  [label="Risankizumab\nCentral Cp" fillcolor="#7986CB"]

        UST_SC [label="Ustekinumab SC\nanti-p40 mAb" fillcolor="#9FA8DA"]
        UST_C  [label="Ustekinumab\nCentral Cp" fillcolor="#7986CB"]

        ADA_ab [label="Anti-Drug Ab (ADA)\nimmunogenicity" fillcolor="#C5CAE9"]
    }

    //==========================================================
    // CLUSTER 9: SMALL MOLECULE PK
    //==========================================================
    subgraph cluster_sm_pk {
        label="Small Molecule Drug PK"
        style=filled fillcolor="#F1F8E9" color="#33691E" penwidth=2
        fontsize=12 fontname="Helvetica-Bold"

        APR_GI [label="Apremilast GI\nPDE4i oral" fillcolor="#A5D6A7"]
        APR_C  [label="Apremilast Cp\nVd=87L" fillcolor="#66BB6A"]
        APR_P  [label="Apremilast Cq\nperipheral" fillcolor="#66BB6A"]

        TOF_GI [label="Tofacitinib GI\nJAKi oral" fillcolor="#A5D6A7"]
        TOF_C  [label="Tofacitinib Cp\nVd=87L" fillcolor="#66BB6A"]

        MTX_GI [label="Methotrexate GI\nantifolate" fillcolor="#A5D6A7"]
        MTX_C  [label="MTX Cp" fillcolor="#66BB6A"]
        MTX_PG [label="MTX-Polyglu\nintracellular" fillcolor="#66BB6A"]

        CsA_GI [label="Cyclosporine GI\nCNI oral" fillcolor="#A5D6A7"]
        CsA_C  [label="Cyclosporine Cp\nVd=4.5 L/kg" fillcolor="#66BB6A"]

        ACT_GI [label="Acitretin GI\nRetinoid" fillcolor="#A5D6A7"]
        ACT_C  [label="Acitretin Cp" fillcolor="#66BB6A"]
    }

    //==========================================================
    // CLUSTER 10: PHARMACODYNAMIC TARGETS
    //==========================================================
    subgraph cluster_pd {
        label="Drug Pharmacodynamic Targets"
        style=filled fillcolor="#FFF8E1" color="#FF6F00" penwidth=2
        fontsize=12 fontname="Helvetica-Bold"

        TNF_blk  [label="TNF-α Blockade\n(ADA, ETA, IFX, CZP)" fillcolor="#FFD54F" penwidth=2]
        IL17_blk [label="IL-17A Blockade\n(SEC, IXE, BIM)" fillcolor="#FFD54F" penwidth=2]
        IL17R_blk [label="IL-17RA Block\n(BRO)" fillcolor="#FFECB3"]
        IL23p19  [label="IL-23p19 Block\n(RSK, GUS, TIL)" fillcolor="#FFD54F" penwidth=2]
        IL23p40  [label="IL-12/23p40 Block\n(UST)" fillcolor="#FFECB3"]
        PDE4i_PD [label="PDE4 Inhib\ncAMP↑ (APR)" fillcolor="#FFD54F"]
        JAKi_PD  [label="JAK1/3 Inhib\nSTAT↓ (TOF)" fillcolor="#FFD54F"]
        TYK2i_PD [label="TYK2 Inhib\n(Deucravacitinib)" fillcolor="#FFECB3"]
        DHFR_PD  [label="DHFR Inhib\nfolate↓ (MTX)" fillcolor="#FFECB3"]
        CN_PD    [label="Calcineurin Inhib\nNFAT↓ (CsA)" fillcolor="#FFECB3"]
        RAR_PD   [label="RAR/RXR Agonism\nKC diff↑ (ACT)" fillcolor="#FFECB3"]
        cAMP     [label="cAMP↑\nanti-inflam" fillcolor="#FFF3E0"]
        Adenosine_PD [label="Adenosine\nanti-inflam (MTX)" fillcolor="#FFF3E0"]
    }

    //==========================================================
    // CLUSTER 11: BIOMARKERS
    //==========================================================
    subgraph cluster_bm {
        label="Disease Biomarkers"
        style=filled fillcolor="#F9FBE7" color="#827717" penwidth=2
        fontsize=12 fontname="Helvetica-Bold"

        CRP      [label="CRP\nsystemic inflam" fillcolor="#F0F4C3"]
        IL17A_BM [label="Serum IL-17A\ndisease activity" fillcolor="#F0F4C3"]
        IL22_BM  [label="Serum IL-22\nskin inflam" fillcolor="#F0F4C3"]
        TNFa_BM  [label="Serum TNF-α" fillcolor="#F0F4C3"]
        Krt16    [label="Keratin 16\npsoriasis marker" fillcolor="#F0F4C3"]
        PASI_BM  [label="PASI75/90/100\nresponse criteria" fillcolor="#DCE775" penwidth=2]
        IGA_BM   [label="IGA 0/1\nclear/almost clear" fillcolor="#F0F4C3"]
    }

    //========================================================
    // EDGES — TRIGGERS → INNATE
    //========================================================
    Strep -> LL37         [label="trigger" color="#E65100"]
    Strep -> Guttate      [label="→ guttate" color="#E65100"]
    Trauma -> KC_basal    [label="injure" color="#E65100"]
    Stress -> pDC         [label="activate" color="#E65100"]
    Drugs_t -> NF_kB_KC  [label="activate" color="#E65100"]
    Obesity_t -> TNF_i   [label="adipokines" color="#E65100"]
    Microbiome_t -> TLR24 [label="PAMPs" color="#E65100"]
    CARD14 -> NF_kB_KC   [label="gain-of-fn" color="#E65100"]
    CARD14 -> CARD14_KC  [label="variant" color="#E65100" style=dashed]
    HLA_Cw6 -> Th1       [label="risk" color="#E65100" style=dashed]
    IL23R_g -> Th17      [label="suscept" color="#E65100" style=dashed]

    //========================================================
    // EDGES — INNATE CASCADE
    //========================================================
    LL37 -> DNA_cmplx    [label="complex" color="#1B5E20"]
    DNA_cmplx -> TLR79   [label="activate" color="#1B5E20"]
    TLR79 -> pDC         [label="→ IFN-α" color="#1B5E20"]
    pDC -> IFNa          [label="produce" color="#1B5E20"]
    IFNa -> mDC          [label="mature" color="#1B5E20"]
    TLR24 -> mDC         [label="activate" color="#1B5E20"]
    mDC -> IL23_ax       [label="produce" color="#0D47A1" penwidth=2]
    mDC -> IL12_ax       [label="produce" color="#0D47A1"]
    mDC -> TNF_i         [label="produce" color="#1B5E20"]
    mDC -> CCL20         [label="secrete" color="#1B5E20"]
    mDC -> CXCL10        [label="secrete" color="#1B5E20"]
    LC -> mDC            [label="migrate" color="#1B5E20"]
    NLRP3 -> IL1b_i      [label="cleave" color="#1B5E20"]
    S100A8 -> NLRP3      [label="activate" color="#1B5E20"]
    Macro -> TNF_i       [label="secrete" color="#1B5E20"]
    Macro -> IL6_i       [label="secrete" color="#1B5E20"]
    Neutro -> S100A8     [label="release" color="#1B5E20"]
    Neutro -> CXCL8      [label="amplify" color="#1B5E20"]

    //========================================================
    // EDGES — T CELL DIFFERENTIATION
    //========================================================
    IL23_ax -> STAT3_T   [label="→JAK2→" color="#0D47A1" penwidth=2]
    STAT3_T -> RORgt     [label="induce" color="#0D47A1"]
    RORgt -> Th17        [label="differentiate" color="#0D47A1" penwidth=2]
    IL12_ax -> Tbet      [label="induce" color="#0D47A1"]
    Tbet -> Th1          [label="differentiate" color="#0D47A1"]
    Th0 -> Th17          [label="+IL-23\n+IL-1β\n+IL-6" color="#0D47A1"]
    Th0 -> Th1           [label="+IL-12" color="#0D47A1"]
    Th0 -> Th22          [label="+IL-6\n+TNF" color="#0D47A1"]
    Th0 -> Treg          [label="+TGFβ" color="#0D47A1"]
    CCL20 -> Th17        [label="recruit" color="#0D47A1"]
    CXCL10 -> Th1        [label="recruit" color="#0D47A1"]
    IFNa -> Th1          [label="promote" color="#0D47A1"]
    IL1b_i -> Th17       [label="amplify" color="#0D47A1"]
    IL6_i -> Th17        [label="amplify" color="#0D47A1"]
    ILC3 -> IL17A        [label="produce" color="#0D47A1"]
    TRM -> IL17A         [label="rapid" color="#0D47A1"]
    Tc1 -> IFNg          [label="produce" color="#0D47A1"]
    Treg -> Th17         [label="suppress" color="#9E9E9E" style=dashed constraint=false]

    //========================================================
    // EDGES — CYTOKINE PRODUCTION
    //========================================================
    Th17 -> IL17A        [label="★ produce" color="#880E4F" penwidth=3]
    Th17 -> IL17F        [label="produce" color="#880E4F"]
    Th17 -> IL22         [label="produce" color="#880E4F" penwidth=2]
    Th17 -> TNFa         [label="produce" color="#880E4F"]
    Th1  -> IFNg         [label="produce" color="#880E4F"]
    Th1  -> TNFa         [label="produce" color="#880E4F"]
    Th22 -> IL22         [label="produce" color="#880E4F"]
    KC_prolif -> IL17C   [label="autocrine" color="#880E4F"]
    KC_prolif -> IL36    [label="produce" color="#880E4F"]
    KC_prolif -> TSLP    [label="produce" color="#880E4F"]
    KC_prolif -> IL33    [label="produce" color="#880E4F"]
    IL17C -> NF_kB_KC   [label="→ amplify" color="#880E4F" style=dashed constraint=false]

    //========================================================
    // EDGES — KERATINOCYTE PATHOLOGY
    //========================================================
    IL17A -> IL17RC      [label="bind" color="#4A148C" penwidth=2]
    IL17RC -> NF_kB_KC   [label="activate" color="#4A148C"]
    NF_kB_KC -> KC_prolif [label="→ hyperprolif" color="#4A148C" penwidth=2]
    NF_kB_KC -> AMPs     [label="induce" color="#4A148C"]
    NF_kB_KC -> CXCL8   [label="produce" color="#4A148C"]
    NF_kB_KC -> CCL20   [label="produce" color="#4A148C"]
    CARD14_KC -> NF_kB_KC [label="activate" color="#4A148C"]
    IL22 -> IL22R1       [label="bind" color="#4A148C"]
    IL22R1 -> STAT3_KC   [label="activate" color="#4A148C"]
    STAT3_KC -> KC_prolif [label="proliferate" color="#4A148C"]
    STAT3_KC -> KC_apop  [label="inhibit apoptosis" color="#4A148C"]
    IFNg -> STAT1_KC     [label="activate" color="#4A148C"]
    STAT1_KC -> NF_kB_KC [label="synergy" color="#4A148C"]
    JAK1_KC -> STAT1_KC  [label="phospho" color="#4A148C"]
    TNFa -> NF_kB_KC     [label="activate" color="#4A148C" penwidth=2]
    KC_basal -> KC_prolif [label="→" color="#4A148C"]
    KC_prolif -> Acanthosis [label="→" color="#4A148C"]
    KC_prolif -> Parakeratosis [label="→" color="#4A148C"]
    KC_prolif -> VEGF_KC [label="secrete" color="#4A148C"]
    KC_prolif -> Loricrin [label="↓ barrier" color="#4A148C"]
    S100A8 -> KC_prolif  [label="amplify" color="#4A148C"]

    //========================================================
    // EDGES — VASCULAR REMODELING
    //========================================================
    VEGF_KC -> Angio     [label="drive" color="#006064" penwidth=2]
    VEGF_KC -> Endothel  [label="activate" color="#006064"]
    Endothel -> ICAM1    [label="upregulate" color="#006064"]
    Endothel -> VCAM1    [label="upregulate" color="#006064"]
    Endothel -> E_sel    [label="express" color="#006064"]
    TNFa -> Endothel     [label="activate" color="#006064"]
    IFNg -> Endothel     [label="activate" color="#006064"]
    ICAM1 -> Leuko_x    [label="→" color="#006064"]
    VCAM1 -> Leuko_x    [label="→" color="#006064"]
    E_sel -> Leuko_x    [label="rolling" color="#006064"]
    Leuko_x -> Th17     [label="skin entry" color="#006064" constraint=false]
    Leuko_x -> Neutro   [label="skin entry" color="#006064" constraint=false]
    Fibrob -> MMP       [label="produce" color="#006064"]
    TNFa -> Fibrob      [label="activate" color="#006064"]
    MMP -> Dermis_i     [label="remodel" color="#006064"]
    Angio -> Dermis_i   [label="dilated caps" color="#006064"]

    //========================================================
    // EDGES — CLINICAL OUTCOMES
    //========================================================
    Acanthosis -> PASI   [label="induration" color="#F57F17"]
    Parakeratosis -> PASI [label="desquam" color="#F57F17"]
    Dermis_i -> PASI    [label="erythema" color="#F57F17"]
    PASI -> PASI_BM     [label="PASI75/90/100" color="#F57F17"]
    PASI -> Plaque      [label="plaque pso" color="#F57F17"]
    IL36 -> Pustular    [label="drive GPP" color="#F57F17"]
    PASI -> BSA_inv     [label="component" color="#F57F17"]
    PASI -> PGA         [label="correlate" color="#F57F17"]
    PASI -> DLQI        [label="QoL impact" color="#F57F17"]
    IL17A -> PsA        [label="joint inflam" color="#F57F17"]
    TNFa -> PsA         [label="enthesitis" color="#F57F17"]
    KC_prolif -> Nail_pso [label="nail matrix" color="#F57F17"]
    TSLP -> Itch        [label="sensitize" color="#F57F17"]
    IL33 -> Itch        [label="pruritus" color="#F57F17"]
    Itch -> DLQI        [label="reduces QoL" color="#F57F17"]
    TNFa -> Comorbid    [label="systemic" color="#F57F17"]
    CRP -> Comorbid     [label="CVD risk" color="#F57F17"]

    //========================================================
    // EDGES — BIOLOGIC PK
    //========================================================
    ADA_SC -> ADA_C     [label="F=0.64\nka=0.013/h" color="#1A237E"]
    ADA_C  -> ADA_P     [label="Q=0.3 L/h" color="#1A237E"]
    ADA_P  -> ADA_C     [label="back" color="#1A237E" constraint=false]
