digraph AIH_QSP {
    // Global settings
    compound=true
    rankdir=TB
    splines=spline
    nodesep=0.4
    ranksep=0.6
    fontname="Helvetica"
    fontsize=10

    graph [bgcolor="#FAFAFA" label="Autoimmune Hepatitis (AIH)\nQuantitative Systems Pharmacology (QSP) Mechanistic Map"
           labelloc=t labeljust=c fontsize=18 fontname="Helvetica-Bold"]

    node [shape=box style="filled,rounded" fontname="Helvetica" fontsize=9 margin="0.1,0.05"]
    edge [fontname="Helvetica" fontsize=8 arrowsize=0.7]

    // ============================================================
    // CLUSTER 1: GENETICS
    // ============================================================
    subgraph cluster_genetics {
        label="Genetic Risk Factors"
        style=filled
        bgcolor="#E8F4E8"
        fontname="Helvetica-Bold"
        fontsize=11
        color="#5A9A5A"
        penwidth=2

        node [fillcolor="#A8D8A8" color="#5A9A5A"]

        HLA_DR3   [label="HLA-DR3\n(DRB1*03:01)\nType1 AIH risk"]
        HLA_DR4   [label="HLA-DR4\nType1 AIH\nolder onset"]
        HLA_DR7   [label="HLA-DR7\nType2 AIH\nassociation"]
        HLA_DQ2   [label="HLA-DQ2\nType2 AIH\nassociation"]
        PTPN22    [label="PTPN22\nR620W variant\nTCR signaling"]
        CTLA4_gene [label="CTLA4 gene\npolymorphism\nco-inhib deficit"]
        STAT4     [label="STAT4\nrs7574865\nIFN pathway"]
        IL10_promo [label="IL-10 promoter\npolymorphism\nlow IL-10 prod"]
        AIRE      [label="AIRE\nmutation\nthymic tolerance"]
        SH2B3     [label="SH2B3 (LNK)\nImmune cell\nsignaling"]
        TNFa_gene [label="TNF-alpha gene\n-308G/A poly\nhigh expression"]
        FCGR      [label="FcγRIIA/IIIA\npolymorphism\nADCC/IC clearance"]
    }

    // ============================================================
    // CLUSTER 2: TRIGGERS
    // ============================================================
    subgraph cluster_triggers {
        label="Environmental Triggers & Tolerance Breakdown"
        style=filled
        bgcolor="#FFF4E8"
        fontname="Helvetica-Bold"
        fontsize=11
        color="#D0854A"
        penwidth=2

        node [fillcolor="#FFD8A8" color="#D0854A"]

        HCV_mimicry   [label="HCV Molecular\nMimicry\nCYP2D6 cross-react"]
        EBV_mimicry   [label="EBV Mimicry\nEBNA-1 / SLA\ncross-reactivity"]
        HAV_HEV       [label="HAV/HEV\nInfection\nTrigger"]
        CMV           [label="CMV\nReactivation\nTrigger"]
        Drug_AIH      [label="Drug-induced AIH\nnitrofurantoin\nminocycline/statins\nmethyldopa"]
        Gut_dysbiosis [label="Gut Dysbiosis\nreduced diversity\naltered bile acids"]
        Leaky_gut     [label="Leaky Gut\nincreased\nintestinal permeability"]
        LPS_portal    [label="Portal LPS\nTLR4 activation\nKupffer priming"]
        DAMPs         [label="DAMPs\nHMGB1/ATP\nnuclear proteins"]
        Mol_mimicry   [label="Molecular Mimicry\nforeign Ag cross-react\nself-Ag"]
        Loss_central_tol [label="Central Tolerance\nLoss\nthymic deletion failure"]
        Loss_periph_tol  [label="Peripheral Tolerance\nLoss\nTreg failure"]
    }

    // ============================================================
    // CLUSTER 3: APC / ANTIGEN PRESENTATION
    // ============================================================
    subgraph cluster_APC {
        label="Antigen Presenting Cells & Autoantigens"
        style=filled
        bgcolor="#E8EAF8"
        fontname="Helvetica-Bold"
        fontsize=11
        color="#5A6ACF"
        penwidth=2

        node [fillcolor="#C8CCF8" color="#5A6ACF"]

        Kupffer       [label="Kupffer Cells\nresident liver\nmacrophage APC"]
        pDC           [label="Plasmacytoid DC\npDC\ntype I IFN prod"]
        mDC           [label="Myeloid DC\nmDC\nclassical APC"]
        Hepatocyte_MHCII [label="Hepatocyte\nMHC-II expression\nIFN-γ induced"]
        CD80_86       [label="CD80/CD86\ncostimulatory\nligands B7"]
        MHCII_complex [label="MHC-II\nPeptide Complex\nTCR recognition"]
        CYP2D6_Ag     [label="CYP2D6\nAutoantigen\nType2/LKM-1 target"]
        FTCD_Ag       [label="FTCD\nAutoantigen\nLC-1 target"]
        SepSecS_Ag    [label="SepSecS\nAutoantigen\nSLA-LP target"]
        Actin_Ag      [label="Actin (F-actin)\nAutoantigen\nASMA target"]
        dsDNA_Ag      [label="dsDNA\nAutoantigen\nANA target"]
        ASGPR_Ag      [label="ASGPR\nAutoantigen\nhepatic lectin"]
        SP170_Ag      [label="SP170 (IMPDH2)\nAutoantigen\nType1 target"]
    }

    // ============================================================
    // CLUSTER 4: CD4 T CELLS
    // ============================================================
    subgraph cluster_CD4 {
        label="CD4+ T Helper Cell Differentiation"
        style=filled
        bgcolor="#FFEAEA"
        fontname="Helvetica-Bold"
        fontsize=11
        color="#CF5A5A"
        penwidth=2

        node [fillcolor="#FFB8B8" color="#CF5A5A"]

        NaiveCD4      [label="Naive CD4+\nT Cell\nresting"]
        TCR_signal    [label="TCR Signaling\nZAP70/LAT/PLC\nactivation cascade"]
        CD28_B7       [label="CD28-B7\nCostimulation\nsignal 2"]
        CTLA4_inhib   [label="CTLA-4\nInhibitory signal\ncompetes CD28"]
        PD1_PDL1      [label="PD-1/PD-L1\nExhaustion\ncheckpoint"]
        Th1           [label="Th1 Cell\nT-bet/IFN-γ\ndominant in AIH"]
        Th17          [label="Th17 Cell\nRORγt/IL-17A\ninflammation"]
        Tfh           [label="Tfh Cell\nBCL6/IL-21\nGC reaction help"]
        IL12_Th1_polar [label="IL-12\nTh1 Polarization\nSTAT4 signaling"]
        IL6_Th17_polar [label="IL-6 + TGF-β\nTh17 Polarization\nRORγt induction"]
        ICOS_ICOSL    [label="ICOS-ICOSL\nco-stimulation\nTfh maintenance"]
        TNFa_effector [label="TNF-α\nEffector function\nhepatocyte injury"]
        IFNg_effector [label="IFN-γ\nEffector cytokine\nMHC-II induction"]
        IL17_effector [label="IL-17A\nEffector cytokine\nneutrophil recruit"]
        IL21_effector [label="IL-21\nEffector cytokine\nB cell help"]
    }

    // ============================================================
    // CLUSTER 5: TREGS
    // ============================================================
    subgraph cluster_Treg {
        label="Regulatory T Cells & Tolerance"
        style=filled
        bgcolor="#E8F8EE"
        fontname="Helvetica-Bold"
        fontsize=11
        color="#3A9A6A"
        penwidth=2

        node [fillcolor="#B8E8C8" color="#3A9A6A"]

        NaturalTreg   [label="Natural Treg\nthymic FoxP3+\nnTreg"]
        InducedTreg   [label="Induced Treg\niTreg peripheral\ninduction"]
        FoxP3_TF      [label="FoxP3\nTranscription Factor\nTreg master TF"]
        IL10_Treg     [label="IL-10 (Treg)\nsuppressive\ncytokine"]
        TGFb_Treg     [label="TGF-β (Treg)\nsuppressive\ncytokine"]
        CTLA4_Treg    [label="CTLA-4 (Treg)\ncontact suppression\nCD80/86 binding"]
        Treg_defect   [label="Treg Defect\nAIH hallmark:\nreduced # and function"]
        Th17_plasticity [label="Treg→Th17\nPlasticity\nIL-6 driven"]
        IL35_Tr35     [label="IL-35\nTr35 cells\nIL-12 family inhib"]
        Breg          [label="B Regulatory\nCell (Breg)\nIL-10+ B cells"]
    }

    // ============================================================
    // CLUSTER 6: CD8 / NK / NKT
    // ============================================================
    subgraph cluster_CD8 {
        label="Cytotoxic Effector Cells"
        style=filled
        bgcolor="#FFF0F8"
        fontname="Helvetica-Bold"
        fontsize=11
        color="#B05AB0"
        penwidth=2

        node [fillcolor="#F0C8F0" color="#B05AB0"]

        NaiveCD8      [label="Naive CD8+\nT Cell"]
        ActivatedCTL  [label="Activated CTL\nCD8+ cytotoxic\nT lymphocyte"]
        Perforin_GrB  [label="Perforin/\nGranzyme B\ncytotoxic granules"]
        FasL_CTL      [label="FasL\n(CTL expressed)\nFas-mediated kill"]
        CTL_hepato_kill [label="CTL-mediated\nHepatocyte Killing\ndirect cytolysis"]
        CD8_exhaustion [label="CD8 Exhaustion\nPD-1hi TOX+\nchronic AIH"]
        NKT_cells     [label="NKT Cells\nCD1d restricted\nnatural killer T"]
        NK_cells      [label="NK Cells\ninnate killer\nKIR regulated"]
        ADCC_NK       [label="NK ADCC\nFcγRIII (CD16)\nAb-dep. kill"]
    }

    // ============================================================
    // CLUSTER 7: B CELLS / AUTOANTIBODIES
    // ============================================================
    subgraph cluster_Bcell {
        label="B Cells & Autoantibody Production"
        style=filled
        bgcolor="#FFFAE0"
        fontname="Helvetica-Bold"
        fontsize=11
        color="#B09030"
        penwidth=2

        node [fillcolor="#FFE888" color="#B09030"]

        NaiveBcell     [label="Naive B Cell\nIgM+IgD+\nresting"]
        GermCenter     [label="Germinal Center\nsomatic hypermutation\naffinity maturation"]
        LongPlasmaCell [label="Long-lived\nPlasma Cell\nBM resident"]
        AutoAb_ANA    [label="ANA\n(Anti-nuclear Ab)\nType1 marker"]
        AutoAb_ASMA   [label="ASMA\n(Anti-smooth\nmuscle Ab) Type1"]
        AutoAb_LKM1   [label="Anti-LKM-1\n(anti-CYP2D6)\nType2 marker"]
        AutoAb_SLA    [label="Anti-SLA/LP\n(anti-SepSecS)\nboth types"]
        AutoAb_LC1    [label="Anti-LC-1\n(anti-FTCD)\nType2 marker"]
        IgG_hypergamma [label="IgG\nHypergammaglobulinemia\n>1.1x ULN"]
        Complement_classic [label="Complement\nClassical Pathway\nC1q/C4/C3"]
        ADCC_Fc       [label="ADCC\nFc-receptor\nmediated killing"]
        ImmunoComplex [label="Immune Complexes\ndeposition\ntissue damage"]
        RF_occasional [label="RF (Rheumatoid\nFactor) occasional\nin AIH"]
        BAFF_APRIL    [label="BAFF/APRIL\nB cell survival\nfactors"]
    }

    // ============================================================
    // CLUSTER 8: CYTOKINES
    // ============================================================
    subgraph cluster_cytokines {
        label="Cytokine & Chemokine Network"
        style=filled
        bgcolor="#F0F0FF"
        fontname="Helvetica-Bold"
        fontsize=11
        color="#6060C0"
        penwidth=2

        node [fillcolor="#CCCCFF" color="#6060C0"]

        IL1b          [label="IL-1β\nNLRP3/caspase-1\npro-inflammatory"]
        IL2           [label="IL-2\nT cell growth\nfactor"]
        IL4           [label="IL-4\nTh2 cytokine\nB cell switch IgG1"]
        IL6           [label="IL-6\npleiotropic\nacute phase"]
        IL10          [label="IL-10\nanti-inflammatory\nTreg/Breg product"]
        IL12          [label="IL-12\np70 heterodimer\nTh1 polarizer"]
        IL17A         [label="IL-17A\nTh17 effector\nneutrophil recruit"]
        IL21          [label="IL-21\nTfh product\nGC/B cell help"]
        IL23          [label="IL-23\np19/p40\nTh17 maintenance"]
        IFNg          [label="IFN-γ\nTh1/CTL product\nMHC-II induction"]
        TNFa          [label="TNF-α\nhepatocyte injury\nNF-κB activation"]
        TGFb1         [label="TGF-β1\nfibrogenic\nHSC activation"]
        CXCL9_10      [label="CXCL9/10\nCXCR3 ligands\nTh1 chemotaxis"]
        CCL2_MCP1     [label="CCL2 (MCP-1)\nmonocyte/\nmacrophage recruit"]
        CCL20         [label="CCL20\nCCR6 ligand\nTh17 chemotaxis"]
        IL33_ST2      [label="IL-33/ST2\ninnate alarm\nmast cell/ILC2"]
        BAFF_cytokine [label="BAFF\n(BLyS cytokine)\nB cell survival"]
        Neutrophil_recruit [label="Neutrophil\nRecruitment\nIL-17/CXCL8 driven"]
    }

    // ============================================================
    // CLUSTER 9: HEPATITIS / LIVER DAMAGE
    // ============================================================
    subgraph cluster_hepatitis {
        label="Hepatic Inflammation & Injury"
        style=filled
        bgcolor="#FFF4E8"
        fontname="Helvetica-Bold"
        fontsize=11
        color="#C07040"
        penwidth=2

        node [fillcolor="#FFD0A0" color="#C07040"]

        Interface_hepatitis [label="Interface Hepatitis\nperiportal\nnecroinflammation"]
        Periportal_inflam   [label="Periportal\nInflammation\nlymphocytic"]
        Lobular_hep         [label="Lobular\nHepatitis\nzone 3 damage"]
        Rosette_form        [label="Hepatocyte\nRosette Formation\nAIH hallmark"]
        Emperipolesis       [label="Emperipolesis\nHepatocyte-lymphocyte\npenetration"]
        PlasmaCell_infiltrate [label="Plasma Cell\nInfiltration\nAIH pathognomonic"]
        Bridging_necrosis   [label="Bridging\nNecrosis\nzone 1-3 connect"]
        Massive_necrosis    [label="Massive\nNecrosis\nacute liver failure"]
        Hepato_apoptosis    [label="Hepatocyte\nApoptosis\ncaspase-mediated"]
        Hepato_necroptosis  [label="Hepatocyte\nNecroptosis\nRIPK3/MLKL"]
        Caspase3_exec       [label="Caspase-3\nExecution\napoptosis effector"]
        Mitochondria_ROS    [label="Mitochondrial\nROS/Dysfunction\noxidative stress"]
        ALT_serum           [label="ALT\n(serum)\nbiomarker >10x ULN"]
        AST_serum           [label="AST\n(serum)\nbiomarker"]
        ALP_serum           [label="ALP\n(serum)\nusually normal AIH"]
        Bilirubin           [label="Bilirubin\n(total)\nliver function"]
        PT_INR              [label="PT/INR\ncoagulation\nliver function"]
        Albumin             [label="Albumin\nsynthesis\nliver function"]
        MELD_score          [label="MELD Score\nNa-MELD\nseverity index"]
    }

    // ============================================================
    // CLUSTER 10: FIBROSIS
    // ============================================================
    subgraph cluster_fibrosis {
        label="Hepatic Fibrosis & Cirrhosis Progression"
        style=filled
        bgcolor="#F4F0E8"
        fontname="Helvetica-Bold"
        fontsize=11
        color="#9A9060"
        penwidth=2

        node [fillcolor="#D8D4A0" color="#9A9060"]

        HSC_quiescent  [label="Quiescent HSC\nhepatic stellate\ncell resting"]
        HSC_activated  [label="Activated HSC\nmyofibroblast\nphenotype"]
        PDGF_BD        [label="PDGF-BB/DD\nHSC proliferation\nmigraton signal"]
        TGFb_fibrogenic [label="TGF-β1\nfibrogenic\nSmad2/3 pathway"]
        MMP1_13        [label="MMP-1/13\ncollagenase\nECM degradation"]
        MMP9           [label="MMP-9\ngelatinase B\nECM remodeling"]
        TIMP1_2        [label="TIMP-1/2\nMMP inhibitors\nfibrosis progression"]
        CollagenI_III  [label="Collagen I/III\nECM deposition\nhepatic fibrosis"]
        ECM_sinusoidal [label="Sinusoidal ECM\ncapillarization\nportal hypertension"]
        Fibrosis_F0    [label="Fibrosis F0\nno fibrosis\nnormal"]
        Fibrosis_F1    [label="Fibrosis F1\nportal fibrosis\nmild"]
        Fibrosis_F2    [label="Fibrosis F2\nperiportal fibrosis\nmoderate"]
        Fibrosis_F3    [label="Fibrosis F3\nbridging fibrosis\nsevere"]
        Fibrosis_F4    [label="Fibrosis F4\ncirrhosis\nadvanced"]
        Portal_HTN     [label="Portal\nHypertension\n>5 mmHg HVPG"]
        Varices_ascites [label="Varices &\nAscites\ndecompensation"]
        HCC_risk       [label="HCC Risk\nhepatocellular\ncarcinoma"]
        LT_endstage    [label="Liver Transplant\nEnd-stage liver\ndisease"]
        FibroScan_kPa  [label="FibroScan\n(kPa)\nnon-invasive staging"]
        ELF_score      [label="ELF Score\nEnhanced Liver\nFibrosis panel"]
    }

    // ============================================================
    // CLUSTER 11: DRUG PK
    // ============================================================
    subgraph cluster_PK {
        label="Drug PK/PD: AIH Pharmacotherapy"
        style=filled
        bgcolor="#E8F4FF"
        fontname="Helvetica-Bold"
        fontsize=11
        color="#4080C0"
        penwidth=2

        // Prednisolone (light blue)
        node [fillcolor="#A8C8F8" color="#4080C0"]
        Pred_dose    [label="Prednisolone\nDose\n(oral)" shape=oval]
        Pred_GI      [label="Prednisolone\nGI Absorption\nF~80%"]
        Pred_Cp      [label="Prednisolone\nPlasma Cp\nt1/2~3h"]
        Pred_Tissue  [label="Prednisolone\nTissue Distribution\nhigh Vd"]
        Pred_GR_liver [label="Prednisolone\nGR Occupancy\nliver"]

        // Budesonide (slightly different shade)
        node [fillcolor="#90C0F8" color="#4080C0"]
        BUD_dose     [label="Budesonide\nDose\n(oral)" shape=oval]
        BUD_GI       [label="Budesonide\nGI Absorption\nF~10% (1st pass)"]
        BUD_Cp       [label="Budesonide\nPlasma Cp\nt1/2~3h"]
        BUD_GR_liver [label="Budesonide\nGR Occupancy\nliver (high local)"]

        // AZA/6-TGN pathway
        node [fillcolor="#A8D8F8" color="#4080C0"]
        AZA_dose     [label="Azathioprine\nDose\n(oral)" shape=oval]
        AZA_GI       [label="AZA\nGI Absorption\nF~80%"]
        AZA_6MP      [label="6-MP\n(active)\nthiopurine"]
        TPMT_enzyme  [label="TPMT\nThiopurine\nS-methyltransf"]
        NUDT15_enzyme [label="NUDT15\nphosphatase\n6-TGN activation"]
        TGN_intracell [label="6-TGN\nIntracellular\nactive metabolite"]
        TGN_DNA_incorp [label="6-TGN\nDNA Incorporation\nDNA damage signal"]
        XO_path      [label="XO Pathway\nxanthine oxidase\n6-TU/6-MMP"]

        // MMF/MPA pathway
        node [fillcolor="#B8D0F8" color="#4080C0"]
        MMF_dose     [label="MMF\n(Mycophenolate\nMofetil) Dose" shape=oval]
        MMF_GI_MPA   [label="MMF→MPA\nGI hydrolysis\nF~94%"]
        MPA_Cp       [label="MPA\nPlasma Cp\nt1/2~17h"]
        IMPDH_inhib  [label="IMPDH Inhibition\nIMPDH1/2\nde novo guanosine"]
        GMP_deplete  [label="GMP Depletion\nguanosine\nnucleotide pool"]
        Lympho_inhib_MPA [label="Lymphocyte\nProliferation\nInhibition (MPA)"]

        // Rituximab
        node [fillcolor="#C8E8FF" color="#4080C0"]
        RTX_dose     [label="Rituximab\nDose\n(IV)" shape=oval]
        RTX_Cp       [label="Rituximab\nPlasma Cp\nt1/2~22d"]
        RTX_CD20_bind [label="RTX-CD20\nBinding\nFc-mediated"]
        CD20_Bcell   [label="CD20+\nB Cells\ntarget antigen"]
        Bcell_depletion [label="B Cell\nDepletion\n>95% reduction"]

        // Cyclosporine
        node [fillcolor="#A0D0FF" color="#4080C0"]
        CsA_dose     [label="Cyclosporine A\nDose\n(oral)" shape=oval]
        CsA_Cp       [label="CsA\nPlasma Cp\nt1/2~19h"]
        CN_inhib     [label="Calcineurin\nInhibition\nCsA-Cyclophilin"]
        NFAT_IL2_block [label="NFAT/IL-2\nBlockade\nT cell inhib"]
    }

    // ============================================================
    // CLUSTER 12: CLINICAL ENDPOINTS
    // ============================================================
    subgraph cluster_endpoints {
        label="Clinical Endpoints & Treatment Response"
        style=filled
        bgcolor="#F8F0FF"
        fontname="Helvetica-Bold"
        fontsize=11
        color="#8040C0"
        penwidth=2

        node [fillcolor="#D8C8F8" color="#8040C0"]

        GR_occupancy      [label="GR Occupancy\ngluccocorticoid\nreceptor binding"]
        NFkB_suppress     [label="NF-κB\nSuppression\ntrans-repression"]
        GR_transactivation [label="GR\nTransactivation\nanti-inflam genes"]
        Cytokine_suppress_PD [label="Cytokine\nSuppression\nPD effect"]
        Remission_IAIHG   [label="IAIHG Remission\nALT/AST <2x ULN\nIgG normal"]
        Complete_remission [label="Complete\nRemission\nALT norm + no Sx"]
        Partial_remission  [label="Partial\nRemission\nALT improved\nnot norm"]
        Treatment_failure  [label="Treatment\nFailure\nno response"]
        Relapse           [label="Relapse\nALT rise post-\ntaper/withdrawal"]
        DFR               [label="Drug-Free\nRemission (DFR)\n<20% long-term"]
        Simplified_score  [label="Simplified AIH\nScore\n6-8 points"]
        HAI_score         [label="HAI Score\nHistologic Activity\nIndex (Ishak)"]
        IgG_monitor       [label="IgG Monitoring\ntreatment response\nmarker"]
        Steroid_SE        [label="Steroid SE\nBMD loss/DM/\nHTN/Cushing"]
        AZA_SE            [label="AZA SE\nmyelosuppression\nhepatotox/nausea"]
        MMF_SE            [label="MMF SE\nGI symptoms\nteratogenicity"]
        LT_eval           [label="LT Evaluation\nMELD>15\nliver transplant"]
        PostLT_recurrence [label="Post-LT AIH\nRecurrence\n~20-30%"]
    }

    // ============================================================
    // EDGES: GENETICS → DOWNSTREAM
    // ============================================================

    // HLA → APC / CD4
    HLA_DR3 -> MHCII_complex [label="peptide\npresentation" color="#5A9A5A"]
    HLA_DR4 -> MHCII_complex [color="#5A9A5A"]
    HLA_DR7 -> CYP2D6_Ag [label="Type2 Ag\npresentation" color="#5A9A5A"]
    HLA_DQ2 -> FTCD_Ag [color="#5A9A5A"]

    // Genetic risk → Tolerance defects
    PTPN22 -> TCR_signal [label="enhanced\nTCR signaling" color="#5A9A5A"]
    CTLA4_gene -> CTLA4_inhib [label="reduced\nCTLA-4 function" color="#5A9A5A" style=dashed]
    STAT4 -> IL12_Th1_polar [label="enhanced IL-12\nresponse" color="#5A9A5A"]
    IL10_promo -> IL10_Treg [label="reduced IL-10\nproduction" color="#5A9A5A" style=dashed]
    AIRE -> Loss_central_tol [label="thymic\ntolerance failure" color="#5A9A5A"]
    TNFa_gene -> TNFa [label="increased TNF-α\nproduction" color="#5A9A5A"]
    FCGR -> ADCC_Fc [label="altered ADCC\nactivity" color="#5A9A5A"]
    SH2B3 -> NaiveCD4 [label="immune cell\nexpansion" color="#5A9A5A"]

    // ============================================================
    // EDGES: TRIGGERS → APC
    // ============================================================
    HCV_mimicry -> CYP2D6_Ag [label="cross-reactive\nT cell priming" color="#D0854A"]
    EBV_mimicry -> SepSecS_Ag [label="EBNA-1\nmimicry" color="#D0854A"]
    HAV_HEV -> Kupffer [label="viral\nactivation" color="#D0854A"]
    CMV -> pDC [label="type I IFN\ninduction" color="#D0854A"]
    Drug_AIH -> Hepato_apoptosis [label="drug-induced\ncell death DAMPs" color="#D0854A"]
    Gut_dysbiosis -> Leaky_gut [label="tight junction\nbreakdown" color="#D0854A"]
    Leaky_gut -> LPS_portal [label="bacterial\ntranslocation" color="#D0854A"]
    LPS_portal -> Kupffer [label="TLR4\nactivation" color="#D0854A"]
    DAMPs -> mDC [label="danger signal\nmaturation" color="#D0854A"]
    Mol_mimicry -> MHCII_complex [label="self Ag\npresentation" color="#D0854A"]
    Loss_central_tol -> NaiveCD4 [label="autoreactive\nclone escape" color="#D0854A"]
    Loss_periph_tol -> Treg_defect [label="peripheral\ntolerance failure" color="#D0854A"]

    // ============================================================
    // EDGES: APC → CD4 ACTIVATION
    // ============================================================
    Kupffer -> mDC [label="cytokine\npriming" color="#5A6ACF"]
    mDC -> MHCII_complex [label="Ag processing\npresentation" color="#5A6ACF"]
    pDC -> IL12 [label="type I IFN\nIL-12 production" color="#5A6ACF"]
    Hepatocyte_MHCII -> MHCII_complex [label="Ag presentation\nby hepatocytes" color="#5A6ACF"]
    IFNg -> Hepatocyte_MHCII [label="MHC-II\ninduction" color="#5A6ACF"]
    MHCII_complex -> TCR_signal [label="TCR\nengagement" color="#5A6ACF"]
    CD80_86 -> CD28_B7 [label="costimulation\nB7-CD28" color="#5A6ACF"]
    CYP2D6_Ag -> MHCII_complex [label="autoantigen\nloading" color="#5A6ACF"]
    FTCD_Ag -> MHCII_complex [color="#5A6ACF"]
    SepSecS_Ag -> MHCII_complex [color="#5A6ACF"]
    Actin_Ag -> MHCII_complex [color="#5A6ACF"]
    dsDNA_Ag -> MHCII_complex [color="#5A6ACF"]
    ASGPR_Ag -> MHCII_complex [color="#5A6ACF"]

    // ============================================================
