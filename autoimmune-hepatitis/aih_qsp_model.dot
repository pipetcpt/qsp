    Hepato_apoptosis -> AST_serum [label="hepatocyte\nlysis→AST" color="#C07040"]
    Hepato_necroptosis -> Mitochondria_ROS [label="ROS\nrelease" color="#C07040"]
    Mitochondria_ROS -> ALT_serum [label="hepato\ndamage" color="#C07040"]
    Interface_hepatitis -> Rosette_form [label="hepatocyte\nrosetting" color="#C07040"]
    Interface_hepatitis -> Emperipolesis [label="lymphocyte\npenetration" color="#C07040"]
    Interface_hepatitis -> PlasmaCell_infiltrate [label="plasma cell\ninfiltration" color="#C07040"]
    Interface_hepatitis -> Periportal_inflam [label="periportal\nnecroinflam" color="#C07040"]
    Periportal_inflam -> Lobular_hep [label="lobular\nextension" color="#C07040"]
    Lobular_hep -> Bridging_necrosis [label="confluent\nnecrosis" color="#C07040"]
    Bridging_necrosis -> Massive_necrosis [label="acute liver\nfailure risk" color="#C07040"]
    Caspase3_exec -> ALT_serum [label="caspase-cleaved\nkeratin" color="#C07040"]
    ALT_serum -> MELD_score [label="liver\nfunction" color="#C07040"]
    AST_serum -> MELD_score [color="#C07040"]
    Bilirubin -> MELD_score [label="MELD\ncomponent" color="#C07040"]
    PT_INR -> MELD_score [label="MELD\ncomponent" color="#C07040"]
    Albumin -> MELD_score [label="inverse\nMELD" color="#C07040" arrowhead=tee]
    DAMPs -> Interface_hepatitis [label="danger\nsignal" color="#C07040"]

    // ============================================================
    // EDGES: FIBROSIS PROGRESSION
    // ============================================================
    Interface_hepatitis -> HSC_activated [label="inflammation\nHSC activation" color="#9A9060"]
    HSC_quiescent -> HSC_activated [label="activation\nby TGF-β/PDGF" color="#9A9060"]
    PDGF_BD -> HSC_activated [label="HSC\nproliferation" color="#9A9060"]
    TGFb_fibrogenic -> CollagenI_III [label="collagen\nsynthesis" color="#9A9060"]
    TGFb_fibrogenic -> TIMP1_2 [label="TIMP\nupregulation" color="#9A9060"]
    HSC_activated -> PDGF_BD [label="autocrine\nPDGF loop" color="#9A9060"]
    HSC_activated -> CollagenI_III [label="collagen I/III\nsynthesis" color="#9A9060"]
    HSC_activated -> TGFb_fibrogenic [label="TGF-β1\nsecretion" color="#9A9060"]
    HSC_activated -> MMP9 [label="MMP-9\nproduction" color="#9A9060"]
    TIMP1_2 -> MMP1_13 [label="MMP-1/13\ninhibition" color="#9A9060" arrowhead=tee]
    CollagenI_III -> ECM_sinusoidal [label="sinusoidal\nECM deposition" color="#9A9060"]
    MMP1_13 -> CollagenI_III [label="collagen\ndegradation" color="#9A9060" arrowhead=tee]
    ECM_sinusoidal -> Portal_HTN [label="sinusoidal\nresistance" color="#9A9060"]
    Portal_HTN -> Varices_ascites [label="decompensation\nevents" color="#9A9060"]

    // Fibrosis stage progression
    Fibrosis_F0 -> Fibrosis_F1 [label="inflammation\nprogression" color="#9A9060"]
    Fibrosis_F1 -> Fibrosis_F2 [label="chronic\ninflammation" color="#9A9060"]
    Fibrosis_F2 -> Fibrosis_F3 [label="bridging\nfibrosis" color="#9A9060"]
    Fibrosis_F3 -> Fibrosis_F4 [label="cirrhosis\ndevelopment" color="#9A9060"]
    CollagenI_III -> Fibrosis_F1 [label="early\ndeposition" color="#9A9060"]
    Fibrosis_F4 -> Portal_HTN [color="#9A9060"]
    Fibrosis_F4 -> HCC_risk [label="cirrhosis→\nHCC" color="#9A9060"]
    Fibrosis_F4 -> LT_endstage [label="end-stage\nliver disease" color="#9A9060"]
    ECM_sinusoidal -> FibroScan_kPa [label="stiffness\nmeasurement" color="#9A9060"]
    CollagenI_III -> ELF_score [label="PIIINP\nELF component" color="#9A9060"]
    TIMP1_2 -> ELF_score [label="TIMP-1\nELF component" color="#9A9060"]
    TGFb1 -> TGFb_fibrogenic [label="TGF-β1\nfibrogenic arm" color="#9A9060"]
    Varices_ascites -> LT_endstage [label="decompensation\nto LT" color="#9A9060"]
    HCC_risk -> LT_endstage [label="HCC→LT\nindication" color="#9A9060"]

    // ============================================================
    // EDGES: DRUG PK CASCADES
    // ============================================================

    // Prednisolone PK chain
    Pred_dose -> Pred_GI [label="oral\nabsorption" color="#4080C0"]
    Pred_GI -> Pred_Cp [label="systemic\ncirculation" color="#4080C0"]
    Pred_Cp -> Pred_Tissue [label="tissue\ndistribution" color="#4080C0"]
    Pred_Tissue -> Pred_GR_liver [label="hepatic\nGR binding" color="#4080C0"]

    // Budesonide PK chain
    BUD_dose -> BUD_GI [label="oral\n1st pass 90%" color="#4080C0"]
    BUD_GI -> BUD_Cp [label="systemic\nexposure" color="#4080C0"]
    BUD_Cp -> BUD_GR_liver [label="high hepatic\nfirst-pass" color="#4080C0"]

    // AZA/6-TGN pathway
    AZA_dose -> AZA_GI [label="oral\nabsorption" color="#4080C0"]
    AZA_GI -> AZA_6MP [label="non-enzymatic\nconversion" color="#4080C0"]
    AZA_6MP -> TPMT_enzyme [label="TPMT\nmetabolism" color="#4080C0"]
    AZA_6MP -> NUDT15_enzyme [label="NUDT15\nactivation" color="#4080C0"]
    AZA_6MP -> XO_path [label="XO\ninactivation" color="#4080C0"]
    NUDT15_enzyme -> TGN_intracell [label="6-TGN\ngeneration" color="#4080C0"]
    TGN_intracell -> TGN_DNA_incorp [label="DNA\nincorporation" color="#4080C0"]
    TGN_DNA_incorp -> Lympho_inhib_MPA [label="lymphocyte\nproliferation inhib" color="#4080C0"]

    // MMF/MPA pathway
    MMF_dose -> MMF_GI_MPA [label="GI esterase\nhydrolysis" color="#4080C0"]
    MMF_GI_MPA -> MPA_Cp [label="systemic MPA\nexposure" color="#4080C0"]
    MPA_Cp -> IMPDH_inhib [label="IMPDH1/2\ninhibition" color="#4080C0"]
    IMPDH_inhib -> GMP_deplete [label="GMP pool\ndepletion" color="#4080C0"]
    GMP_deplete -> Lympho_inhib_MPA [label="selective\nlympho inhib" color="#4080C0"]

    // Rituximab pathway
    RTX_dose -> RTX_Cp [label="IV infusion\nPK" color="#4080C0"]
    RTX_Cp -> RTX_CD20_bind [label="CD20\nbinding Fc" color="#4080C0"]
    CD20_Bcell -> RTX_CD20_bind [label="target antigen\nexpression" color="#4080C0"]
    RTX_CD20_bind -> Bcell_depletion [label="ADCC/CDC/\napoptosis" color="#4080C0"]

    // Cyclosporine pathway
    CsA_dose -> CsA_Cp [label="oral\nabsorption" color="#4080C0"]
    CsA_Cp -> CN_inhib [label="Cyc-CsA\ncomplex" color="#4080C0"]
    CN_inhib -> NFAT_IL2_block [label="NFAT\ndephosphorylation\nblocked" color="#4080C0"]

    // ============================================================
    // EDGES: DRUG PD → DISEASE ATTENUATION
    // ============================================================
    Pred_GR_liver -> GR_occupancy [label="GR\noccupancy" color="#8040C0"]
    BUD_GR_liver -> GR_occupancy [label="GR\noccupancy" color="#8040C0"]
    GR_occupancy -> NFkB_suppress [label="GR\ntrans-repression" color="#8040C0"]
    GR_occupancy -> GR_transactivation [label="anti-inflam\ngene expression" color="#8040C0"]
    NFkB_suppress -> Cytokine_suppress_PD [label="NF-κB\ncytokine block" color="#8040C0"]
    GR_transactivation -> Cytokine_suppress_PD [label="MKP-1/\nAnnexin-1" color="#8040C0"]
    Cytokine_suppress_PD -> TNFa [label="TNF-α\nsuppression" color="#8040C0" arrowhead=tee]
    Cytokine_suppress_PD -> IL6 [label="IL-6\nsuppression" color="#8040C0" arrowhead=tee]
    Cytokine_suppress_PD -> IFNg [label="IFN-γ\nsuppression" color="#8040C0" arrowhead=tee]
    Cytokine_suppress_PD -> Interface_hepatitis [label="inflammation\nresolution" color="#8040C0" arrowhead=tee]
    Lympho_inhib_MPA -> NaiveCD4 [label="lymphocyte\nproliferation inhib" color="#8040C0" arrowhead=tee]
    Lympho_inhib_MPA -> NaiveBcell [label="B cell\nproliferation inhib" color="#8040C0" arrowhead=tee]
    Bcell_depletion -> AutoAb_ANA [label="autoAb\nreduction" color="#8040C0" arrowhead=tee]
    Bcell_depletion -> IgG_hypergamma [label="IgG\nnormalization" color="#8040C0" arrowhead=tee]
    NFAT_IL2_block -> IL2 [label="IL-2\nblockade" color="#8040C0" arrowhead=tee]
    NFAT_IL2_block -> NaiveCD4 [label="T cell\nactivation inhib" color="#8040C0" arrowhead=tee]
    TGN_DNA_incorp -> NaiveCD4 [label="T cell\nproliferation inhib" color="#8040C0" arrowhead=tee]

    // ============================================================
    // EDGES: BIOMARKERS → CLINICAL SCORING → TREATMENT DECISIONS
    // ============================================================
    ALT_serum -> Remission_IAIHG [label="ALT <2x ULN\ncriterion" color="#8040C0"]
    IgG_hypergamma -> IgG_monitor [label="IgG level\nmonitoring" color="#8040C0"]
    IgG_monitor -> Remission_IAIHG [label="IgG norm\ncriterion" color="#8040C0"]
