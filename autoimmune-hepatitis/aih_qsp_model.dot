    Tfh -> IL21_effector [label="IL-21\nproduction" color="#CF5A5A"]
    IL12 -> IL12_Th1_polar [label="IL-12\nsignaling" color="#CF5A5A"]
    IL6 -> IL6_Th17_polar [label="IL-6\ncontribution" color="#CF5A5A"]

    // ============================================================
    // EDGES: TREG BIOLOGY
    // ============================================================
    NaturalTreg -> FoxP3_TF [label="FoxP3\nexpression" color="#3A9A6A"]
    InducedTreg -> FoxP3_TF [color="#3A9A6A"]
    FoxP3_TF -> IL10_Treg [label="Treg\nsuppression" color="#3A9A6A"]
    FoxP3_TF -> TGFb_Treg [label="Treg\nsuppression" color="#3A9A6A"]
    FoxP3_TF -> CTLA4_Treg [label="CTLA-4\nexpression" color="#3A9A6A"]
    IL10_Treg -> IL10 [label="Treg-derived\nIL-10" color="#3A9A6A"]
    TGFb_Treg -> TGFb1 [label="Treg-derived\nTGF-β" color="#3A9A6A"]
    CTLA4_Treg -> CD80_86 [label="CD80/86\ndownregulation" color="#3A9A6A" arrowhead=tee]
    Treg_defect -> Loss_periph_tol [label="Treg failure\nAIH pathology" color="#3A9A6A"]
    IL6 -> Th17_plasticity [label="IL-6\nTreg destabilization" color="#3A9A6A"]
    Th17_plasticity -> Th17 [label="Treg→Th17\nconversion" color="#3A9A6A"]
    Breg -> IL10 [label="Breg-derived\nIL-10" color="#3A9A6A"]
    IL35_Tr35 -> NaturalTreg [label="IL-35\nTreg support" color="#3A9A6A"]
    NaturalTreg -> Treg_defect [label="reduced in\nAIH" color="#3A9A6A" style=dashed]

    // ============================================================
    // EDGES: CD8/NK → HEPATOCYTE KILLING
    // ============================================================
    NaiveCD8 -> ActivatedCTL [label="antigen\nactivation" color="#B05AB0"]
    ActivatedCTL -> Perforin_GrB [label="granule\nexocytosis" color="#B05AB0"]
    ActivatedCTL -> FasL_CTL [label="FasL\nexpression" color="#B05AB0"]
    Perforin_GrB -> CTL_hepato_kill [label="direct\ncytolysis" color="#B05AB0"]
    FasL_CTL -> CTL_hepato_kill [label="Fas-mediated\napoptosis" color="#B05AB0"]
    PD1_PDL1 -> CD8_exhaustion [label="chronic\nexhaustion" color="#B05AB0"]
    NKT_cells -> IL4 [label="NKT\nIL-4 prod" color="#B05AB0"]
    NKT_cells -> IFNg [label="NKT\nIFN-γ prod" color="#B05AB0"]
    NK_cells -> ADCC_NK [label="ADCC\nfacilitation" color="#B05AB0"]
    AutoAb_LKM1 -> ADCC_NK [label="Ab-dependent\nNK activation" color="#B05AB0"]
    ADCC_NK -> CTL_hepato_kill [label="NK-mediated\nkilling" color="#B05AB0"]

    // ============================================================
    // EDGES: B CELLS → AUTOANTIBODIES
    // ============================================================
    NaiveBcell -> GermCenter [label="Tfh help\nGC reaction" color="#B09030"]
    GermCenter -> LongPlasmaCell [label="plasma cell\ndifferentiation" color="#B09030"]
    LongPlasmaCell -> AutoAb_ANA [label="ANA\nproduction" color="#B09030"]
    LongPlasmaCell -> AutoAb_ASMA [label="ASMA\nproduction" color="#B09030"]
    LongPlasmaCell -> AutoAb_LKM1 [label="anti-LKM1\nproduction" color="#B09030"]
    LongPlasmaCell -> AutoAb_SLA [label="anti-SLA\nproduction" color="#B09030"]
    LongPlasmaCell -> AutoAb_LC1 [label="anti-LC1\nproduction" color="#B09030"]
    LongPlasmaCell -> IgG_hypergamma [label="polyclonal\nIgG rise" color="#B09030"]
    IL21_effector -> GermCenter [label="Tfh IL-21\nGC help" color="#B09030"]
    BAFF_APRIL -> NaiveBcell [label="B cell\nsurvival" color="#B09030"]
    AutoAb_ANA -> ImmunoComplex [label="IC formation\ncomplement" color="#B09030"]
    ImmunoComplex -> Complement_classic [label="C1q\nactivation" color="#B09030"]
    Complement_classic -> Interface_hepatitis [label="complement-mediated\ntissue damage" color="#B09030"]
    AutoAb_ASMA -> ADCC_Fc [label="IgG Fc-mediated\nADCC" color="#B09030"]
    Breg -> NaiveBcell [label="Breg\nregulation" color="#B09030" arrowhead=tee]
    BAFF_cytokine -> BAFF_APRIL [label="cytokine\nexpression" color="#B09030"]

    // ============================================================
    // EDGES: CYTOKINES → HEPATOCYTE DAMAGE
    // ============================================================
    IFNg_effector -> IFNg [label="into cytokine\npool" color="#6060C0"]
    TNFa_effector -> TNFa [label="into cytokine\npool" color="#6060C0"]
    IL17_effector -> IL17A [label="into cytokine\npool" color="#6060C0"]
    IL21_effector -> IL21 [label="into cytokine\npool" color="#6060C0"]

    TNFa -> Hepato_apoptosis [label="TNFR1\napoptosis" color="#6060C0"]
    IFNg -> Interface_hepatitis [label="IFN-γ\nnecroinflam" color="#6060C0"]
    IL6 -> IL6_Th17_polar [label="Th17\npolarization" color="#6060C0"]
    IL12 -> IL12_Th1_polar [label="Th1\npolarization" color="#6060C0"]
    IL17A -> Neutrophil_recruit [label="CXCL8 induction\nneutrophil chemo" color="#6060C0"]
    IL21 -> GermCenter [label="GC reaction\nB cell help" color="#6060C0"]
    IL23 -> Th17 [label="Th17\nmaintenance" color="#6060C0"]
    IL10 -> Th1 [label="Th1\ninhibition" color="#6060C0" arrowhead=tee]
    IL10 -> TNFa [label="TNF-α\nsuppression" color="#6060C0" arrowhead=tee]
    TGFb1 -> HSC_activated [label="HSC\nactivation" color="#6060C0"]
    CXCL9_10 -> Th1 [label="CXCR3\nchemotaxis" color="#6060C0"]
    CCL2_MCP1 -> Kupffer [label="macrophage\nrecruitment" color="#6060C0"]
    CCL20 -> Th17 [label="Th17\nrecruitment" color="#6060C0"]
    IL1b -> IL6 [label="IL-1β\nIL-6 induction" color="#6060C0"]
    IL33_ST2 -> IL1b [label="inflammasome\nactivation" color="#6060C0"]
    IL2 -> NaiveCD4 [label="T cell\ngrowth factor" color="#6060C0"]
    Neutrophil_recruit -> Interface_hepatitis [label="neutrophil\ninfiltration" color="#6060C0"]

    // ============================================================
    // EDGES: HEPATITIS BIOMARKERS
    // ============================================================
    CTL_hepato_kill -> Hepato_apoptosis [label="CTL-mediated\napoptosis" color="#C07040"]
    CTL_hepato_kill -> Hepato_necroptosis [label="necroptosis\npath" color="#C07040"]
