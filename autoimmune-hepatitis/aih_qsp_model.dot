    IL6_Th17_polar -> Th17 [label="RORγt\ninduction" color="#CF5A5A"]
    ICOS_ICOSL -> Tfh [label="Tfh\nmaintenance" color="#CF5A5A"]

    // Th1/Th17/Tfh → Cytokine production
    Th1 -> IFNg_effector [label="IFN-γ\nproduction" color="#CF5A5A"]
    Th1 -> TNFa_effector [label="TNF-α\nproduction" color="#CF5A5A"]
