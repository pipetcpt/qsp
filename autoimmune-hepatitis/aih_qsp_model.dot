    Remission_IAIHG -> Partial_remission [label="incomplete\nresponse" color="#8040C0"]
    Complete_remission -> DFR [label="taper attempt\n<20% success" color="#8040C0"]
    Partial_remission -> Treatment_failure [label="no further\nresponse" color="#8040C0"]
    DFR -> Relapse [label="post-taper\nrelapse risk" color="#8040C0"]
    Relapse -> AZA_dose [label="AZA\nmaintenance" color="#8040C0" style=dashed]
    ALT_serum -> Simplified_score [label="Simplified\nAIH score" color="#8040C0"]
    IgG_hypergamma -> Simplified_score [label="IgG\ncomponent" color="#8040C0"]
    AutoAb_ANA -> Simplified_score [label="autoAb\ncomponent" color="#8040C0"]
    HAI_score -> Complete_remission [label="histologic\nresolution" color="#8040C0"]
    MELD_score -> LT_eval [label="MELD >15\nLT evaluation" color="#8040C0"]
    FibroScan_kPa -> LT_eval [label="advanced\nfibrosis" color="#8040C0"]
    LT_eval -> LT_endstage [label="LT\nindication" color="#8040C0"]
    LT_endstage -> PostLT_recurrence [label="post-LT\nAIH recurrence" color="#8040C0"]
    Pred_dose -> Steroid_SE [label="corticosteroid\nadverse effects" color="#8040C0" style=dashed]
    AZA_dose -> AZA_SE [label="AZA\nadverse effects" color="#8040C0" style=dashed]
    MMF_dose -> MMF_SE [label="MMF\nadverse effects" color="#8040C0" style=dashed]
    TPMT_enzyme -> AZA_SE [label="TPMT-low\nmyelosuppression" color="#8040C0"]
    NUDT15_enzyme -> AZA_SE [label="NUDT15\npolymorphism" color="#8040C0"]
    Treatment_failure -> RTX_dose [label="refractory AIH\nRTX salvage" color="#8040C0" style=dashed]
    Treatment_failure -> MMF_dose [label="2nd line\nMMF therapy" color="#8040C0" style=dashed]

    // ============================================================
    // ADDITIONAL CROSS-CLUSTER EDGES
    // ============================================================

    // Genetics → Treg
    CTLA4_gene -> CTLA4_Treg [label="CTLA-4\nTreg function" color="#5A9A5A" style=dashed]
    IL10_promo -> Breg [label="Breg IL-10\nproduction" color="#5A9A5A" style=dashed]

    // Triggers → Cytokines
    LPS_portal -> IL1b [label="TLR4\nNLRP3 activation" color="#D0854A"]
    LPS_portal -> TNFa [label="TLR4\nNF-κB TNF-α" color="#D0854A"]
    DAMPs -> IL33_ST2 [label="HMGB1\nIL-33 release" color="#D0854A"]

    // APC → Cytokines
    Kupffer -> IL1b [label="Kupffer\nIL-1β prod" color="#5A6ACF"]
    Kupffer -> TNFa [label="Kupffer\nTNF-α prod" color="#5A6ACF"]
    mDC -> IL12 [label="DC\nIL-12 prod" color="#5A6ACF"]
    mDC -> IL23 [label="DC\nIL-23 prod" color="#5A6ACF"]
    mDC -> CCL2_MCP1 [label="DC\nMCP-1 prod" color="#5A6ACF"]
    Kupffer -> CXCL9_10 [label="Kupffer CXCL9/10\nTh1 chemotaxis" color="#5A6ACF"]
    Kupffer -> CCL20 [label="Kupffer\nCCL20 prod" color="#5A6ACF"]

    // CD4 → B cells
    Tfh -> NaiveBcell [label="Tfh help\nB cell activation" color="#CF5A5A"]
    IL21_effector -> NaiveBcell [label="IL-21\nB cell activation" color="#CF5A5A"]

    // B cells → Cytokines
    NaiveBcell -> BAFF_cytokine [label="BAFF demand\nsurvival" color="#B09030"]
    LongPlasmaCell -> IL6 [label="plasma cell\nIL-6 prod" color="#B09030"]

    // Treg → CD4
    IL10_Treg -> Th17 [label="Th17\ninhib by IL-10" color="#3A9A6A" arrowhead=tee]
    TGFb_Treg -> Th1 [label="Th1\ninhib by TGF-β" color="#3A9A6A" arrowhead=tee]
    CTLA4_Treg -> mDC [label="DC\ndeactivation" color="#3A9A6A" arrowhead=tee]

    // CD8 → Cytokines
    ActivatedCTL -> IFNg [label="CTL\nIFN-γ prod" color="#B05AB0"]
    ActivatedCTL -> TNFa [label="CTL\nTNF-α prod" color="#B05AB0"]
    NK_cells -> IFNg [label="NK\nIFN-γ prod" color="#B05AB0"]

    // Fibrosis ↔ Hepatitis feedback
    Fibrosis_F3 -> Portal_HTN [label="bridging\nHTN" color="#9A9060"]
    Hepato_apoptosis -> DAMPs [label="necrotic\nDAMP release" color="#C07040"]
    Massive_necrosis -> MELD_score [label="acute\nliver failure" color="#C07040"]

    // IgG → HAI
    IgG_hypergamma -> HAI_score [label="histologic\ncorrelation" color="#B09030"]
    PlasmaCell_infiltrate -> HAI_score [label="plasma cell\nscoring" color="#C07040"]
    Interface_hepatitis -> HAI_score [label="histologic\nactivity" color="#C07040"]
}
