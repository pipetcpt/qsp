        Peripheral_AVD     [label="Peripheral Arterial\nDisease (PAD)", fillcolor="#FFCDD2"];
        HF_risk            [label="Heart Failure\nRisk", fillcolor="#FFCDD2"];
        ASCVD_risk         [label="ASCVD Risk Score\n(10-yr Framingham/\nPCE)", fillcolor="#EF9A9A"];

        Vulnerable_plaque -> Plaque_rupture  [label="mechanical\nstress"];
        Plaque_rupture  -> Thrombus          [label="platelet\naggregation\n+ coagulation", color="#B71C1C", penwidth=2];
        Thrombus        -> MI                [label="coronary\nocclusion"];
        Thrombus        -> Stroke            [label="cerebral\nembolism"];
