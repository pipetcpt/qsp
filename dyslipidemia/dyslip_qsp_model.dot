digraph DyslipidemiaQSP {
    // =========================================================
    // Dyslipidemia QSP Mechanistic Map
    // Quantitative Systems Pharmacology Model
    // Covers: cholesterol synthesis, lipoprotein metabolism,
    // reverse cholesterol transport, bile acid enterohepatic
    // circulation, drug mechanisms (statins, ezetimibe, PCSK9i,
    // inclisiran, bempedoic acid, fibrates, niacin, omega-3,
    // bile acid sequestrants), clinical endpoints, biomarkers
    // =========================================================

    graph [
        rankdir=LR,
        fontname="Helvetica",
        fontsize=11,
        label="Dyslipidemia QSP Mechanistic Map\nCholesterol Synthesis · Lipoprotein Metabolism · Reverse Cholesterol Transport · Drug Mechanisms",
        labelloc=t,
        labeljust=c,
        nodesep=0.4,
        ranksep=0.8,
        splines=true,
        overlap=false,
        bgcolor="#FAFAFA"
    ];

    node [
        fontname="Helvetica",
        fontsize=9,
        style="filled,rounded",
        shape=box,
        margin="0.1,0.05"
    ];

    edge [
        fontname="Helvetica",
        fontsize=8,
        arrowsize=0.7
    ];

    // =========================================================
    // CLUSTER 1: HEPATIC CHOLESTEROL SYNTHESIS
    // =========================================================
    subgraph cluster_hepatic_synthesis {
        label="Hepatic Cholesterol Synthesis\n(Mevalonate Pathway)";
        style=filled;
        fillcolor="#FFF3E0";
        color="#E65100";
        fontsize=11;
        fontcolor="#E65100";

        Acetyl_CoA         [label="Acetyl-CoA", fillcolor="#FFE0B2"];
        Acetoacetyl_CoA    [label="Acetoacetyl-CoA", fillcolor="#FFE0B2"];
        HMG_CoA            [label="HMG-CoA\n(3-hydroxy-3-methylglutaryl-CoA)", fillcolor="#FFCC80", shape=ellipse];
        HMGCoA_Reductase   [label="HMG-CoA Reductase\n(HMGCR)", fillcolor="#FF9800", shape=diamond];
        Mevalonate         [label="Mevalonate", fillcolor="#FFE0B2"];
        Mevalonate_5P      [label="Mevalonate-5-phosphate", fillcolor="#FFE0B2"];
        Mevalonate_PP      [label="Mevalonate-pyrophosphate", fillcolor="#FFE0B2"];
        Isopentenyl_PP     [label="Isopentenyl-PP (IPP)", fillcolor="#FFE0B2"];
        Geranyl_PP         [label="Geranyl-PP (GPP)", fillcolor="#FFE0B2"];
        Farnesyl_PP        [label="Farnesyl-PP (FPP)", fillcolor="#FFCC80"];
        Squalene           [label="Squalene", fillcolor="#FFE0B2"];
        Lanosterol         [label="Lanosterol", fillcolor="#FFE0B2"];
        Zymosterol         [label="Zymosterol", fillcolor="#FFE0B2"];
        Desmosterol        [label="Desmosterol", fillcolor="#FFE0B2"];
        Hepatic_Cholesterol [label="Hepatic Free\nCholesterol", fillcolor="#FF6F00", fontcolor="white", shape=ellipse];
        Hepatic_CE         [label="Cholesteryl Ester\n(Hepatic CE)", fillcolor="#FFAB40"];
        ACAT               [label="ACAT\n(SOAT1/2)", fillcolor="#FF9800", shape=diamond];
        CoQ10              [label="Coenzyme Q10\n(Ubiquinone)", fillcolor="#FFE0B2"];
        Dolichol           [label="Dolichol\n(glycosylation)", fillcolor="#FFE0B2"];
        Geranylgeranyl_PP  [label="Geranylgeranyl-PP\n(GGPP)", fillcolor="#FFE0B2"];

        Acetyl_CoA      -> Acetoacetyl_CoA  [label="thiolase"];
        Acetoacetyl_CoA -> HMG_CoA          [label="HMG-CoA\nsynthase"];
        HMG_CoA         -> Mevalonate       [label="HMGCR\n(rate-limiting)", color="#E65100", penwidth=2];
        HMGCoA_Reductase -> HMG_CoA        [arrowhead=tee, label="catalyzes", color="#E65100"];
        Mevalonate      -> Mevalonate_5P    [label="mevalonate\nkinase"];
        Mevalonate_5P   -> Mevalonate_PP    [label="phospho-\nmevalonate\nkinase"];
        Mevalonate_PP   -> Isopentenyl_PP   [label="diphospho-\nmevalonate\ndecarboxylase"];
        Isopentenyl_PP  -> Geranyl_PP       [label="FPP synthase"];
        Geranyl_PP      -> Farnesyl_PP      [label="FPP synthase"];
        Farnesyl_PP     -> Squalene         [label="squalene\nsynthase"];
        Squalene        -> Lanosterol       [label="oxidosqualene\ncyclase"];
        Lanosterol      -> Zymosterol       [label="multiple\nsteps"];
        Zymosterol      -> Desmosterol      [label="DHCR24"];
        Desmosterol     -> Hepatic_Cholesterol [label="DHCR24\n(final step)"];
        Hepatic_Cholesterol -> Hepatic_CE   [label="ACAT\n(esterification)"];
        ACAT            -> Hepatic_CE       [arrowhead=tee, color="#E65100"];
        Isopentenyl_PP  -> CoQ10            [label="non-sterol\nbranch"];
        Farnesyl_PP     -> Dolichol         [label="non-sterol\nbranch"];
        Isopentenyl_PP  -> Geranylgeranyl_PP [label="GGPPS"];
    }

    // =========================================================
    // CLUSTER 2: LDL RECEPTOR BIOLOGY & PCSK9
    // =========================================================
    subgraph cluster_LDLR_PCSK9 {
        label="LDL Receptor Regulation & PCSK9 Biology";
        style=filled;
        fillcolor="#E8F5E9";
        color="#1B5E20";
        fontsize=11;
        fontcolor="#1B5E20";

        LDLR_gene          [label="LDLR Gene\n(19p13.2)", fillcolor="#C8E6C9", shape=parallelogram];
        LDLR_mRNA          [label="LDLR mRNA", fillcolor="#C8E6C9"];
        LDLR_protein       [label="LDL Receptor\nProtein (LDLR)", fillcolor="#4CAF50", fontcolor="white", shape=ellipse];
        LDLR_surface       [label="LDLR (cell surface)", fillcolor="#2E7D32", fontcolor="white", shape=ellipse];
        LDLR_complex       [label="LDLR-LDL\nComplex", fillcolor="#66BB6A"];
        LDLR_endosome      [label="LDLR-LDL\n(endosome)", fillcolor="#81C784"];
        LDLR_recycled      [label="LDLR Recycled\nto surface", fillcolor="#A5D6A7"];
        LDL_degraded       [label="LDL Degraded\n(lysosome)", fillcolor="#C8E6C9"];

        PCSK9_gene         [label="PCSK9 Gene\n(1p32.3)", fillcolor="#C8E6C9", shape=parallelogram];
        PCSK9_mRNA         [label="PCSK9 mRNA", fillcolor="#C8E6C9"];
        PCSK9_pro          [label="PCSK9 Proprotein", fillcolor="#A5D6A7"];
        PCSK9_secreted     [label="PCSK9\n(secreted, plasma)", fillcolor="#66BB6A", shape=ellipse];
        PCSK9_LDLR_complex [label="PCSK9-LDLR\nComplex", fillcolor="#FF8A65"];
        LDLR_lysosome      [label="LDLR\n(lysosomal\ndegradation)", fillcolor="#EF9A9A"];

        SREBP2             [label="SREBP-2\n(active form)", fillcolor="#F9A825", shape=diamond];
        SREBP2_precursor   [label="SREBP-2\n(precursor, ER)", fillcolor="#FFF9C4"];
        SCAP               [label="SCAP\n(chaperon)", fillcolor="#FFF9C4"];
        Insig1             [label="Insig-1/2\n(ER retention)", fillcolor="#FFF9C4"];
        SRE                [label="Sterol Response\nElement (SRE)", fillcolor="#FFF176", shape=parallelogram];

        PCSK9_gene  -> PCSK9_mRNA         [label="transcription"];
        PCSK9_mRNA  -> PCSK9_pro          [label="translation"];
        PCSK9_pro   -> PCSK9_secreted     [label="autocatalytic\ncleavage + secretion"];
        PCSK9_secreted -> PCSK9_LDLR_complex [label="binds EGF-A\ndomain"];
        PCSK9_LDLR_complex -> LDLR_lysosome [label="prevents LDLR\nrecycling", color="#B71C1C", penwidth=2];

        LDLR_gene   -> LDLR_mRNA          [label="transcription"];
        LDLR_mRNA   -> LDLR_protein       [label="translation"];
        LDLR_protein -> LDLR_surface      [label="trafficking\nto surface"];
        LDLR_surface -> LDLR_complex      [label="binds apoB-100\non LDL"];
        LDLR_complex -> LDLR_endosome     [label="endocytosis\n(clathrin-coated pit)"];
        LDLR_endosome -> LDLR_recycled    [label="pH drop → LDL\nreleased (normal)", color="#2E7D32"];
        LDLR_recycled -> LDLR_surface     [label="recycling"];
        LDLR_endosome -> LDL_degraded     [label="lysosomal\nhydrolysis"];

        SREBP2_precursor -> SREBP2        [label="SCAP escorts to\nGolgi → S1P/S2P\ncleavage"];
        SCAP -> SREBP2_precursor          [arrowhead=none, style=dashed];
        Insig1 -> SCAP                    [arrowhead=tee, label="sterol-sensor\nretains in ER"];
        Hepatic_Cholesterol -> Insig1     [arrowhead=tee, label="high sterol\nactivates Insig", style=dashed, color="#E65100"];
        SREBP2 -> SRE                     [label="binds SRE"];
        SRE -> LDLR_gene                  [label="↑ transcription", color="#1B5E20", penwidth=2];
        SRE -> PCSK9_gene                 [label="↑ transcription\n(co-regulated)", color="#795548"];
        SRE -> HMGCoA_Reductase           [label="↑ expression", style=dashed, color="#1B5E20"];
    }

    // =========================================================
    // CLUSTER 3: LIPOPROTEIN METABOLISM (VLDL/IDL/LDL/HDL/Lp(a))
    // =========================================================
    subgraph cluster_lipoprotein_metabolism {
        label="Lipoprotein Metabolism & Plasma Transport";
        style=filled;
        fillcolor="#E3F2FD";
        color="#0D47A1";
        fontsize=11;
        fontcolor="#0D47A1";

        TG_pool            [label="Hepatic TG Pool", fillcolor="#BBDEFB"];
        ApoB100_synth      [label="apoB-100\n(synthesis)", fillcolor="#90CAF9"];
        MTP                [label="MTP\n(microsomal TG\ntransfer protein)", fillcolor="#64B5F6", shape=diamond];
        VLDL               [label="VLDL\n(apoB-100, TG-rich)", fillcolor="#1565C0", fontcolor="white", shape=ellipse];
        VLDL_TG            [label="VLDL-TG\n(triglycerides)", fillcolor="#BBDEFB"];
        IDL                [label="IDL\n(intermediate\ndensity lipoprotein)", fillcolor="#1976D2", fontcolor="white", shape=ellipse];
        LDL_particle       [label="LDL Particle\n(apoB-100, CE-rich)", fillcolor="#0D47A1", fontcolor="white", shape=ellipse];
        sdLDL              [label="Small Dense LDL\n(sdLDL)", fillcolor="#1565C0", fontcolor="white"];
        oxLDL              [label="Oxidized LDL\n(oxLDL)", fillcolor="#B71C1C", fontcolor="white", shape=ellipse];

        LPL                [label="Lipoprotein Lipase\n(LPL)", fillcolor="#42A5F5", shape=diamond];
        HL                 [label="Hepatic Lipase\n(LIPC)", fillcolor="#42A5F5", shape=diamond];
        CETP               [label="CETP\n(cholesteryl ester\ntransfer protein)", fillcolor="#29B6F6", shape=diamond];
        ApoC2              [label="apoC-II\n(LPL activator)", fillcolor="#90CAF9"];
        ApoC3              [label="apoC-III\n(LPL inhibitor)", fillcolor="#EF9A9A"];
        ApoE               [label="apoE\n(receptor ligand)", fillcolor="#90CAF9"];

        Lpa_particle       [label="Lp(a) Particle\n(apoB-100 + apo(a))", fillcolor="#4A148C", fontcolor="white", shape=ellipse];
        Apoa_small         [label="apo(a)\n(kringle domains)", fillcolor="#7B1FA2", fontcolor="white"];
        LPA_gene           [label="LPA Gene\n(6q26-q27)", fillcolor="#CE93D8", shape=parallelogram];

        FFA_plasma         [label="Plasma FFA\n(free fatty acids)", fillcolor="#BBDEFB"];
        Glycerol           [label="Glycerol", fillcolor="#BBDEFB"];

        TG_pool     -> MTP             [label="provides TG"];
        ApoB100_synth -> MTP           [label="core protein"];
        MTP         -> VLDL            [label="lipidation\nassembly", color="#0D47A1", penwidth=2];
        VLDL        -> VLDL_TG         [label="carries TG"];
        VLDL        -> IDL             [label="LPL hydrolysis\n(peripheral)", color="#0D47A1"];
        LPL         -> VLDL            [arrowhead=tee, label="hydrolyzes TG"];
        ApoC2       -> LPL             [label="activates", color="#2E7D32"];
        ApoC3       -> LPL             [arrowhead=tee, label="inhibits", color="#B71C1C"];
        VLDL_TG     -> FFA_plasma      [label="hydrolysis\nby LPL"];
        FFA_plasma  -> Glycerol        [style=dashed];
        IDL         -> LDL_particle    [label="HL further\nhydrolysis"];
        IDL         -> LDLR_surface    [label="hepatic\nclearance\n(via apoE)"];
        HL          -> IDL             [arrowhead=tee, label="hydrolyzes\nIDL TG/PL"];
        LDL_particle -> sdLDL          [label="further\nremodeling\n(HTG states)"];
        LDL_particle -> oxLDL          [label="oxidative\nstress"];
        CETP        -> LDL_particle    [label="transfers CE\nfrom HDL→LDL", arrowhead=tee, style=dashed];

        LPA_gene    -> Apoa_small      [label="transcription/\ntranslation"];
        Apoa_small  -> Lpa_particle    [label="covalent link\nto apoB-100", color="#4A148C"];
        LDL_particle -> Lpa_particle   [style=dashed, label="structural\ntemplate"];

        ApoE -> IDL                    [arrowhead=none, label="targets\nto hepatic\nreceptors"];
    }

    // =========================================================
    // CLUSTER 4: HDL METABOLISM & REVERSE CHOLESTEROL TRANSPORT
    // =========================================================
    subgraph cluster_RCT {
        label="HDL Metabolism & Reverse Cholesterol Transport (RCT)";
        style=filled;
        fillcolor="#F3E5F5";
        color="#4A148C";
        fontsize=11;
        fontcolor="#4A148C";

        PreBeta_HDL        [label="Pre-β HDL\n(nascent)", fillcolor="#E1BEE7"];
        HDL3               [label="HDL3\n(discoidal)", fillcolor="#CE93D8"];
        HDL2               [label="HDL2\n(spherical,\nCE-rich)", fillcolor="#AB47BC", fontcolor="white", shape=ellipse];
        ApoAI              [label="apoA-I\n(ABCA1 ligand,\nLCAT activator)", fillcolor="#9C27B0", fontcolor="white", shape=ellipse];
        ApoAII             [label="apoA-II", fillcolor="#E1BEE7"];

        ABCA1              [label="ABCA1\n(macrophage/hepatic)", fillcolor="#8E24AA", fontcolor="white", shape=diamond];
        ABCG1              [label="ABCG1\n(foam cell efflux)", fillcolor="#8E24AA", fontcolor="white", shape=diamond];
        LCAT               [label="LCAT\n(lecithin:cholesterol\nacyltransferase)", fillcolor="#BA68C8", shape=diamond];
        SR_BI              [label="SR-BI\n(hepatic HDL\nreceptor)", fillcolor="#7B1FA2", fontcolor="white", shape=diamond];
        Cholesterol_efflux [label="Cholesterol Efflux\n(from peripheral)", fillcolor="#E1BEE7"];
        HDL_CE             [label="HDL-Cholesteryl\nEster (CE)", fillcolor="#CE93D8"];
        Hepatic_CE_uptake  [label="Selective CE Uptake\n(liver via SR-BI)", fillcolor="#CE93D8"];

        LXR                [label="LXR\n(Liver X Receptor)", fillcolor="#F3E5F5", shape=diamond];
        FXR_liver          [label="FXR\n(Farnesoid X\nReceptor, liver)", fillcolor="#F3E5F5", shape=diamond];
        PPARalpha          [label="PPARα\n(peroxisome\nproliferator-activated)", fillcolor="#F8BBD9", shape=diamond];

        ApoAI           -> PreBeta_HDL     [label="lipid-poor\nnascent HDL"];
        ABCA1           -> PreBeta_HDL     [label="phospholipid\n+ cholesterol\nefflux", color="#4A148C", penwidth=2];
        Cholesterol_efflux -> ABCA1        [label="cellular\ncholesterol"];
        PreBeta_HDL     -> HDL3            [label="LCAT\nmaturation"];
        LCAT            -> HDL3            [arrowhead=tee, label="esterifies\ncholesterol"];
        HDL3            -> HDL2            [label="cholesterol\nenrichment"];
        HDL2            -> HDL_CE          [label="CE-enriched\ncore"];
        ABCG1           -> HDL3            [label="further\ncholesterol\nefflux"];
        CETP            -> HDL_CE          [label="extracts CE\nfrom HDL", arrowhead=tee, color="#795548", style=dashed];
        HDL2            -> Hepatic_CE_uptake [label="SR-BI\nselective\nuptake"];
        SR_BI           -> Hepatic_CE_uptake [arrowhead=tee, label="mediates"];
        Hepatic_CE_uptake -> Hepatic_Cholesterol [label="delivers to liver"];

        LXR             -> ABCA1           [label="↑ expression\n(oxysterol\nsensor)", color="#4A148C"];
        LXR             -> ApoAI           [label="↑ apoA-I\ntranscription"];
        FXR_liver       -> ApoAI           [arrowhead=tee, label="represses\napoA-I"];
        PPARalpha       -> ApoAI           [label="↑ expression", color="#880E4F"];
        PPARalpha       -> ApoAII          [label="↑ expression"];
    }

    // =========================================================
    // CLUSTER 5: INTESTINAL CHOLESTEROL ABSORPTION
    // =========================================================
    subgraph cluster_intestinal_absorption {
        label="Intestinal Cholesterol Absorption & Exogenous Pathway";
        style=filled;
        fillcolor="#E8EAF6";
        color="#1A237E";
        fontsize=11;
        fontcolor="#1A237E";

        Dietary_Cholesterol [label="Dietary Cholesterol\n(~300 mg/day)", fillcolor="#C5CAE9"];
        Biliary_Cholesterol_int [label="Biliary Cholesterol\n(~800 mg/day)", fillcolor="#C5CAE9"];
        Micellar_Cholesterol [label="Micellar\nCholesterol\n(solubilized)", fillcolor="#9FA8DA"];
        NPC1L1             [label="NPC1L1\n(Niemann-Pick C1-like 1)\nbrush border transporter", fillcolor="#3949AB", fontcolor="white", shape=diamond];
        ABCG5              [label="ABCG5/G8\n(sterol efflux\nback to lumen)", fillcolor="#5C6BC0", fontcolor="white", shape=diamond];
        Enterocyte_Chol    [label="Enterocyte\nFree Cholesterol", fillcolor="#9FA8DA"];
        ACAT2              [label="ACAT2\n(intestinal\nesterification)", fillcolor="#5C6BC0", fontcolor="white", shape=diamond];
        Enterocyte_CE      [label="Enterocyte CE", fillcolor="#9FA8DA"];
        ApoB48             [label="apoB-48\n(intestinal)", fillcolor="#9FA8DA"];
        Chylomicron        [label="Chylomicron\n(apoB-48, TG-rich)", fillcolor="#1A237E", fontcolor="white", shape=ellipse];
        Chylomicron_rem    [label="Chylomicron\nRemnant", fillcolor="#3949AB", fontcolor="white", shape=ellipse];
        Dietary_TG         [label="Dietary TG\n(fat)", fillcolor="#C5CAE9"];
        Bile_Acids_lumen   [label="Bile Acids\n(intestinal lumen)", fillcolor="#C8E6C9"];
        Bile_Salt_transporter [label="ASBT\n(ileal bile acid\ntransporter)", fillcolor="#66BB6A", shape=diamond];
        Portal_Bile_Acids  [label="Portal Bile Acids\n(enterohepatic)", fillcolor="#A5D6A7"];

        Dietary_Cholesterol -> Micellar_Cholesterol [label="emulsification\nby bile acids"];
        Biliary_Cholesterol_int -> Micellar_Cholesterol [label="mixed micelles"];
        Bile_Acids_lumen -> Micellar_Cholesterol    [label="bile acid\nsolubilization"];
        Micellar_Cholesterol -> NPC1L1              [label="substrate"];
        NPC1L1 -> Enterocyte_Chol                   [label="uptake", color="#1A237E", penwidth=2];
        ABCG5  -> Enterocyte_Chol                   [arrowhead=tee, label="efflux\nback to lumen", color="#B71C1C"];
        Enterocyte_Chol -> ACAT2                    [label="substrate"];
        ACAT2  -> Enterocyte_CE                     [label="esterification"];
        Enterocyte_CE -> ApoB48                     [label="lipidation\nwith MTP"];
        ApoB48 -> Chylomicron                       [label="chylomicron\nassembly"];
        Dietary_TG -> Chylomicron                   [label="TG core"];
        Chylomicron -> Chylomicron_rem              [label="LPL hydrolysis\n(peripheral\ntissues)"];
        Chylomicron_rem -> LDLR_surface             [label="hepatic clearance\n(apoE mediated)"];
        Chylomicron_rem -> Hepatic_Cholesterol      [label="delivers\ncholesterol\nto liver"];
        Bile_Acids_lumen -> Bile_Salt_transporter   [label="ileal\nreabsorption"];
        Bile_Salt_transporter -> Portal_Bile_Acids  [label="portal vein\nreturn"];
        Portal_Bile_Acids -> FXR_liver              [label="activates FXR\n(sensor)", color="#2E7D32"];
    }

    // =========================================================
    // CLUSTER 6: BILE ACID METABOLISM & ENTEROHEPATIC CIRCULATION
    // =========================================================
    subgraph cluster_bile_acid_metabolism {
        label="Bile Acid Metabolism & Enterohepatic Circulation";
        style=filled;
        fillcolor="#E0F2F1";
        color="#004D40";
        fontsize=11;
        fontcolor="#004D40";

        Cholesterol_BA     [label="Cholesterol\n(substrate)", fillcolor="#B2DFDB"];
        CYP7A1             [label="CYP7A1\n(cholesterol 7α-hydroxylase)\nrate-limiting step", fillcolor="#00897B", fontcolor="white", shape=diamond];
        CYP8B1             [label="CYP8B1\n(12α-hydroxylase)\ncholic acid branch", fillcolor="#26A69A", shape=diamond];
        CYP27A1            [label="CYP27A1\n(alternative\npathway)", fillcolor="#26A69A", shape=diamond];
        Primary_BA         [label="Primary Bile Acids\n(CA + CDCA)", fillcolor="#80CBC4"];
        Conjugated_BA      [label="Conjugated Bile Acids\n(glyco/tauro conjugates)", fillcolor="#80CBC4"];
        Bile_pool          [label="Bile Pool\n(hepatic)", fillcolor="#4DB6AC"];
        Bile_canaliculus   [label="Bile Canaliculus\n(BSEP export)", fillcolor="#80CBC4"];
        BSEP               [label="BSEP\n(bile salt export\npump, ABCB11)", fillcolor="#00897B", fontcolor="white", shape=diamond];
        Secondary_BA       [label="Secondary Bile Acids\n(DCA, LCA)\n(bacterial conversion)", fillcolor="#A5D6A7"];
        FXR_SHP            [label="SHP\n(small heterodimer\npartner)", fillcolor="#B2DFDB", shape=diamond];
        FGF19              [label="FGF-19/15\n(ileal hormone)", fillcolor="#80CBC4"];
        FGFR4              [label="FGFR4\n(hepatic receptor)", fillcolor="#4DB6AC", shape=diamond];
        TGR5               [label="TGR5\n(intestinal\nbile acid receptor)", fillcolor="#80CBC4", shape=diamond];
        GLP1               [label="GLP-1\n(incretin)", fillcolor="#A5D6A7"];

        Cholesterol_BA  -> CYP7A1          [label="classical\npathway"];
        CYP7A1          -> Primary_BA      [label="7α-OH\ncholesterol\n→ bile acids"];
        CYP8B1          -> Primary_BA      [label="cholic acid\nbranch"];
        CYP27A1         -> Primary_BA      [label="alternative\npathway"];
        Primary_BA      -> Conjugated_BA   [label="BAAT\nconjugation"];
        Conjugated_BA   -> Bile_pool       [label="stored in\ngallbladder"];
        Bile_pool       -> BSEP            [label="canalicular\nexcretion"];
        BSEP            -> Bile_canaliculus [label="secretion\ninto bile"];
        Bile_canaliculus -> Bile_Acids_lumen [label="enters\nduodenum"];
        Bile_Acids_lumen -> Secondary_BA   [label="gut bacteria\ndeconjugation"];
        Portal_Bile_Acids -> Bile_pool     [label="portal return\n(~95% recirculated)"];
        FXR_liver       -> FXR_SHP         [label="induces SHP"];
        FXR_SHP         -> CYP7A1          [arrowhead=tee, label="represses\nCYP7A1\n(feedback)", color="#B71C1C", penwidth=2];
        FXR_liver       -> FGF19           [label="induces FGF-19\n(in ileum)"];
        FGF19           -> FGFR4           [label="endocrine\nsignaling"];
        FGFR4           -> CYP7A1          [arrowhead=tee, label="represses", color="#B71C1C"];
        TGR5            -> GLP1            [label="stimulates\nGLP-1 secretion"];
        Hepatic_Cholesterol -> Cholesterol_BA [label="substrate for\nbile synthesis"];
    }

    // =========================================================
    // CLUSTER 7: DRUG MECHANISMS & PHARMACOLOGY
    // =========================================================
    subgraph cluster_drug_mechanisms {
        label="Drug Mechanisms of Action";
        style=filled;
        fillcolor="#FFF8E1";
        color="#F57F17";
        fontsize=11;
        fontcolor="#F57F17";

        // Statins
        Statin_drug        [label="STATIN\n(Rosuvastatin/\nAtorvastatin/\nSimvastatin)", fillcolor="#FF6F00", fontcolor="white", shape=octagon];
        Statin_HMGCoA_inh  [label="Statin-HMG-CoA\nBinding (active site)", fillcolor="#FFE0B2"];

        // Ezetimibe
        Ezetimibe_drug     [label="EZETIMIBE\n(Zetia®)", fillcolor="#F57F17", fontcolor="white", shape=octagon];
        Ezetimibe_NPC1L1   [label="Ezetimibe-NPC1L1\nBinding", fillcolor="#FFF3E0"];

        // PCSK9 Inhibitors (mAbs)
        Evolocumab         [label="EVOLOCUMAB\n(Repatha®)\nmAb", fillcolor="#E64A19", fontcolor="white", shape=octagon];
        Alirocumab         [label="ALIROCUMAB\n(Praluent®)\nmAb", fillcolor="#E64A19", fontcolor="white", shape=octagon];
        PCSK9i_complex     [label="PCSK9-mAb\nComplex\n(neutralized)", fillcolor="#FFCCBC"];

        // Inclisiran
        Inclisiran_drug    [label="INCLISIRAN\n(Leqvio®)\nsiRNA", fillcolor="#BF360C", fontcolor="white", shape=octagon];
        PCSK9_mRNA_silenced [label="PCSK9 mRNA\n(silenced)", fillcolor="#FFAB91"];

        // Bempedoic Acid
        Bempedoic_acid     [label="BEMPEDOIC ACID\n(Nexletol®)", fillcolor="#E65100", fontcolor="white", shape=octagon];
        ACL                [label="ATP-Citrate Lyase\n(ACL/ACLY)", fillcolor="#FFB74D", shape=diamond];
        Citrate_to_AcCoA   [label="Citrate → Acetyl-CoA\n(blocked by BA)", fillcolor="#FFE0B2"];

        // Fibrates
        Fibrate_drug       [label="FIBRATE\n(Fenofibrate/\nGemfibrozil)", fillcolor="#FF8F00", fontcolor="white", shape=octagon];

        // Niacin
        Niacin_drug        [label="NIACIN\n(Nicotinic Acid)", fillcolor="#FF6D00", fontcolor="white", shape=octagon];
        GPR109A            [label="GPR109A\n(niacin receptor\nadipocyte)", fillcolor="#FFE082", shape=diamond];
        DGAT2_inh          [label="DGAT2 Inhibition\n(hepatic TG synthesis)", fillcolor="#FFE082"];
        HSL_inh            [label="HSL Inhibition\n(adipose lipolysis)", fillcolor="#FFE082", shape=diamond];

        // Omega-3 FA
        Omega3_drug        [label="OMEGA-3 FA\n(EPA/DHA)\nIcosapent ethyl", fillcolor="#FF6F00", fontcolor="white", shape=octagon];
        SREBP1c            [label="SREBP-1c\n(hepatic lipogenesis)", fillcolor="#FFE082", shape=diamond];
        DNL_pathway        [label="De Novo Lipogenesis\n(DNL)", fillcolor="#FFE0B2"];

        // Bile Acid Sequestrants
        BAS_drug           [label="BILE ACID\nSEQUESTRANT\n(Cholestyramine/\nColesevelam)", fillcolor="#EF6C00", fontcolor="white", shape=octagon];
        BAS_BA_complex     [label="BAS-Bile Acid\nComplex (feces)", fillcolor="#FFE0B2"];

        // Drug → Target connections
        Statin_drug     -> Statin_HMGCoA_inh  [label="competitive\ninhibition"];
        Statin_HMGCoA_inh -> HMGCoA_Reductase [arrowhead=tee, label="blocks\nHMGCR", color="#B71C1C", penwidth=2];
        Statin_drug     -> SREBP2             [label="↓intracellular\ncholesterol\n→ activates SREBP2", style=dashed, color="#1B5E20"];

        Ezetimibe_drug  -> Ezetimibe_NPC1L1   [label="binds\nNPC1L1"];
        Ezetimibe_NPC1L1 -> NPC1L1            [arrowhead=tee, label="blocks\ncholesterol\nuptake", color="#B71C1C", penwidth=2];

        Evolocumab      -> PCSK9i_complex     [label="binds PCSK9"];
        Alirocumab      -> PCSK9i_complex     [label="binds PCSK9"];
        PCSK9i_complex  -> PCSK9_secreted     [arrowhead=tee, label="neutralizes\nPCSK9", color="#B71C1C", penwidth=2];

        Inclisiran_drug -> PCSK9_mRNA_silenced [label="RNAi\nsilencing"];
        PCSK9_mRNA_silenced -> PCSK9_secreted  [arrowhead=tee, label="↓ PCSK9\nproduction", color="#B71C1C", penwidth=2];

        Bempedoic_acid  -> ACL                [arrowhead=tee, label="inhibits ACL"];
        ACL             -> Citrate_to_AcCoA   [label="normally\ngenerates Acetyl-CoA"];
        Citrate_to_AcCoA -> Acetyl_CoA        [style=dashed, label="hepatic source"];
        Bempedoic_acid  -> SREBP2             [label="↓ hepatic\ncholesterol\n→ activates SREBP2", style=dashed, color="#1B5E20"];

        Fibrate_drug    -> PPARalpha          [label="agonist\nactivation", color="#880E4F", penwidth=2];
        PPARalpha       -> LPL               [label="↑ LPL\nexpression", color="#2E7D32"];
        PPARalpha       -> ApoC3             [arrowhead=tee, label="↓ apoC-III\n(removes LPL\ninhibitor)", color="#2E7D32"];

        Niacin_drug     -> GPR109A           [label="activates\nGPR109A\n(adipocyte)"];
        GPR109A         -> HSL_inh           [label="↓ cAMP\n→ inhibits HSL"];
        HSL_inh         -> FFA_plasma        [arrowhead=tee, label="↓ FFA\nrelease\nfrom adipose", color="#B71C1C"];
        FFA_plasma      -> TG_pool           [label="FFA substrate\nfor hepatic TG", style=dashed];
        Niacin_drug     -> DGAT2_inh         [label="inhibits hepatic\nTG assembly", color="#B71C1C"];

        Omega3_drug     -> SREBP1c           [arrowhead=tee, label="↓ SREBP-1c\nactivation"];
        SREBP1c         -> DNL_pathway       [label="drives\nde novo\nlipogenesis"];
        Omega3_drug     -> PPARalpha         [label="partial agonist", style=dashed];

        BAS_drug        -> BAS_BA_complex    [label="ionic binding\nin intestine"];
        BAS_BA_complex  -> Portal_Bile_Acids [arrowhead=tee, label="prevents\nreabsorption", color="#B71C1C", penwidth=2];
        BAS_drug        -> CYP7A1            [label="↑ CYP7A1\n(bile acid\ndepletion)", style=dashed, color="#2E7D32"];
    }

