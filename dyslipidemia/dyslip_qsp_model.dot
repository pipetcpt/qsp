        Beta_oxidation  -> Ketogenesis     [label="excess\nacetyl-CoA"];
        FFA_plasma      -> Muscle_FA       [label="skeletal muscle\noxidation"];
        VLDL_assembly   -> TG_pool         [label="hepatic TG\ncontribution"];
        Niacin_drug     -> HSL_enzyme      [arrowhead=tee, label="↓ HSL via\nGPR109A/↓cAMP", color="#F57F17", style=dashed];
        GPR109A         -> cAMP_adip       [arrowhead=tee, label="↓ cAMP", color="#F57F17"];
    }

