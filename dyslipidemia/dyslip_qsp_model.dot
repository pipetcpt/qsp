        Lactone_form       [label="Statin Lactone\n(inactive pro-drug\nform)", fillcolor="#F8BBD9"];
        Biliary_excretion  [label="Biliary Excretion\n(MRP2/BCRP)", fillcolor="#F48FB1"];
        Fecal_elimination  [label="Fecal Elimination", fillcolor="#F8BBD9"];
        Renal_excretion    [label="Renal Excretion\n(minor)", fillcolor="#F8BBD9"];
        Myopathy_risk      [label="Myopathy Risk\n(muscle exposure\nto statin)", fillcolor="#FF1744", fontcolor="white", shape=ellipse];
        Rhabdomyolysis     [label="Rhabdomyolysis\n(rare, severe)", fillcolor="#D50000", fontcolor="white"];
        CK_elevation       [label="CK Elevation\n(biomarker)", fillcolor="#FF8A80"];

        Oral_dose       -> GI_absorption    [label="dissolution\n& absorption"];
        GI_absorption   -> First_pass       [label="portal vein\n→ liver"];
        GI_absorption   -> Statin_plasma    [label="systemic\ncirculation"];
        First_pass      -> Statin_liver     [label="hepatic\nextraction"];
        OATP1B1         -> Statin_liver     [label="uptake\ntransporter", color="#880E4F", penwidth=2];
        OATP1B3         -> Statin_liver     [label="uptake\ntransporter"];
        Statin_liver    -> Statin_HMGCoA_inh [label="active form\nat target"];
        Statin_liver    -> CYP3A4           [label="substrate\n(simva/atorva)"];
        Statin_liver    -> CYP2C9           [label="substrate\n(rosuva)"];
        CYP3A4          -> Active_metabolite [label="generates\nhydroxyl\nmetabolite"];
        CYP2C9          -> Active_metabolite [label="metabolism"];
        Lactone_form    -> Statin_liver     [label="hydrolysis\nto open-acid", style=dashed];
        Statin_liver    -> Biliary_excretion [label="MRP2/BCRP\nbiliary secretion"];
        Biliary_excretion -> Fecal_elimination [label="gut elimination\n(~70%)"];
        Statin_plasma   -> Renal_excretion  [label="urinary\nelimination\n(~10%)"];
        Statin_plasma   -> Myopathy_risk    [label="muscle\nexposure"];
        Myopathy_risk   -> Rhabdomyolysis   [label="severe\ntoxicity\n(rare)"];
        Myopathy_risk   -> CK_elevation     [label="elevated\ncreatine kinase"];
    }

    // =========================================================
    // CLUSTER 9: MACROPHAGE / FOAM CELL / ATHEROSCLEROSIS
    // =========================================================
    subgraph cluster_atherosclerosis {
        label="Arterial Wall — Foam Cell Formation & Atherosclerosis";
        style=filled;
        fillcolor="#FFEBEE";
        color="#B71C1C";
        fontsize=11;
        fontcolor="#B71C1C";

        Endothelial_dysfunction [label="Endothelial\nDysfunction", fillcolor="#FFCDD2"];
        Monocyte_recruit  [label="Monocyte\nRecruitment\n(CCL2/MCP-1)", fillcolor="#EF9A9A"];
        Macrophage        [label="Macrophage\n(intimal)", fillcolor="#E57373"];
        SRs               [label="Scavenger Receptors\n(SR-A, CD36)", fillcolor="#EF5350", fontcolor="white", shape=diamond];
        oxLDL_uptake      [label="oxLDL Uptake\n(unregulated)", fillcolor="#E53935", fontcolor="white"];
        Foam_cell         [label="Foam Cell\n(lipid-laden\nmacrophage)", fillcolor="#C62828", fontcolor="white", shape=ellipse];
        Fatty_streak      [label="Fatty Streak\n(early lesion)", fillcolor="#FFCDD2"];
        Fibrous_cap       [label="Fibrous Cap\n(SMC, collagen)", fillcolor="#EF9A9A"];
        Necrotic_core     [label="Necrotic Core\n(lipid pool)", fillcolor="#E57373"];
        Vulnerable_plaque [label="Vulnerable Plaque\n(thin cap, lipid-rich)", fillcolor="#C62828", fontcolor="white", shape=ellipse];
        Stable_plaque     [label="Stable Plaque\n(thick cap, calcified)", fillcolor="#FFCDD2"];
        VCAM1             [label="VCAM-1/ICAM-1\n(adhesion molecules)", fillcolor="#FFCDD2"];
        NLRP3             [label="NLRP3\nInflammasome", fillcolor="#EF9A9A", shape=diamond];
        IL1beta           [label="IL-1β\n(inflammatory)", fillcolor="#E57373"];
        hsCRP_marker      [label="hsCRP\n(inflammation\nbiomarker)", fillcolor="#FFCDD2"];
        ABCA1_mac         [label="ABCA1\n(macrophage\nefflux)", fillcolor="#81C784", shape=diamond];
        RCT_efflux        [label="Cholesterol Efflux\n(RCT, protective)", fillcolor="#C8E6C9"];

        oxLDL           -> Endothelial_dysfunction [label="oxidative\nstress", color="#B71C1C"];
        Endothelial_dysfunction -> VCAM1  [label="upregulates\nadhesion\nmolecules"];
        VCAM1           -> Monocyte_recruit [label="recruits\nmonocytes"];
        Monocyte_recruit -> Macrophage    [label="differentiation"];
        Macrophage      -> SRs            [label="expresses"];
        SRs             -> oxLDL_uptake   [label="unregulated\nuptake\n(no feedback)", color="#B71C1C", penwidth=2];
        oxLDL_uptake    -> Foam_cell      [label="CE accumulation", color="#B71C1C", penwidth=2];
        Foam_cell       -> Fatty_streak   [label="accumulation"];
        Fatty_streak    -> Fibrous_cap    [label="progression"];
        Fatty_streak    -> Necrotic_core  [label="foam cell\napoptosis"];
        Fibrous_cap     -> Vulnerable_plaque [label="thinning\n(MMPs)"];
        Fibrous_cap     -> Stable_plaque  [label="thickening\n(statins\nstabilize)", color="#2E7D32"];
        Necrotic_core   -> Vulnerable_plaque [label="enlarging"];
        Foam_cell       -> NLRP3          [label="cholesterol\ncrystals"];
        NLRP3           -> IL1beta        [label="caspase-1\nactivation"];
        IL1beta         -> hsCRP_marker   [label="induces CRP\n(hepatic)", style=dashed];
        ABCA1_mac       -> RCT_efflux     [label="efflux to\napoA-I/HDL", color="#1B5E20", penwidth=2];
        RCT_efflux      -> Foam_cell      [arrowhead=tee, label="protective:\nreduces CE\naccumulation", color="#1B5E20"];
        oxLDL           -> Macrophage     [style=dashed, label="chemoattractant"];
        LXR             -> ABCA1_mac      [label="LXR induces\nABCA1 in\nmacrophage", color="#4A148C"];
    }

