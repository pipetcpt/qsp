        Catecholamine   -> cAMP_adip       [label="β-adrenergic\nreceptor → adenylyl\ncyclase"];
        cAMP_adip       -> HSL_enzyme      [label="PKA phospho-\nrylation activates HSL"];
        Insulin_sig     -> cAMP_adip       [arrowhead=tee, label="↓ cAMP\n(PDE activation)"];
        HSL_enzyme      -> TG_storage      [label="hydrolyzes\nDAG → MAG"];
        ATGL            -> TG_storage      [label="hydrolyzes\nTG → DAG"];
        TG_storage      -> FFA_release     [label="complete\nlipolysis"];
        FFA_release     -> Albumin_FFA     [label="albumin\nbinding"];
        Albumin_FFA     -> FFA_plasma      [label="circulates"];
        FFA_plasma      -> Hepatic_FFA_uptake [label="liver\nuptake"];
