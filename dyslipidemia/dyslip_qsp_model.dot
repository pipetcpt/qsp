        CYP3A4             [label="CYP3A4\n(simva/atorva\nmetabolism)", fillcolor="#EC407A", fontcolor="white", shape=diamond];
        CYP2C9             [label="CYP2C9\n(rosuvastatin\nmetabolism)", fillcolor="#EC407A", fontcolor="white", shape=diamond];
        OATP1B1            [label="OATP1B1\n(hepatic uptake\ntransporter)", fillcolor="#F48FB1", shape=diamond];
        OATP1B3            [label="OATP1B3\n(hepatic uptake)", fillcolor="#F48FB1", shape=diamond];
        Statin_liver       [label="Statin (liver)\n[active site]", fillcolor="#E91E63", fontcolor="white"];
        Statin_plasma      [label="Statin (plasma)\n[Cmax, AUC]", fillcolor="#AD1457", fontcolor="white"];
