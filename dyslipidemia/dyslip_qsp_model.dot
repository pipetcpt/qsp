    // =========================================================
    // CLUSTER 13: HEPATIC LIPID INTEGRATION
    // =========================================================
    subgraph cluster_hepatic_integration {
        label="Hepatic Lipid Integration & VLDL Assembly";
        style=filled;
        fillcolor="#FFF3E0";
        color="#BF360C";
        fontsize=11;
        fontcolor="#BF360C";

        Hepatic_TG_syn     [label="Hepatic TG\nSynthesis (DGAT1/2)", fillcolor="#FFE0B2"];
        GPAT               [label="GPAT\n(glycerophosphate\nacyltransferase)", fillcolor="#FFCC80", shape=diamond];
        DGAT               [label="DGAT1/2\n(diacylglycerol\nacyltransferase)", fillcolor="#FFCC80", shape=diamond];
        ApoB100_deg        [label="apoB-100\nDegradation\n(proteasome, if\nnot lipidated)", fillcolor="#FFE0B2"];
        VLDL1              [label="VLDL1\n(large, TG-rich)", fillcolor="#EF6C00", fontcolor="white"];
        VLDL2              [label="VLDL2\n(smaller, less TG)", fillcolor="#E65100", fontcolor="white"];
        Lipin1             [label="Lipin-1\n(phosphatase)", fillcolor="#FFCC80", shape=diamond];
        ChREBP             [label="ChREBP\n(carbohydrate\nresponse element\nbinding protein)", fillcolor="#FFE082", shape=diamond];
        Insulin_liver      [label="Insulin\n(hepatic signaling)", fillcolor="#C8E6C9", shape=diamond];
        Glucagon           [label="Glucagon\n(counterregulatory)", fillcolor="#FFF9C4", shape=diamond];

        Acetyl_CoA      -> DNL_pathway     [label="substrate for\nde novo\nlipogenesis"];
        DNL_pathway     -> Hepatic_TG_syn  [label="fatty acids\n→ TG synthesis"];
        GPAT            -> Hepatic_TG_syn  [label="first\nacylation\nstep"];
        DGAT            -> Hepatic_TG_syn  [label="final\nTG assembly"];
        Hepatic_TG_syn  -> TG_pool         [label="fills hepatic\nTG pool"];
        TG_pool         -> VLDL1           [label="large VLDL\nassembly"];
        TG_pool         -> VLDL2           [label="smaller VLDL"];
        ApoB100_synth   -> ApoB100_deg     [label="if not protected\nby lipidation"];
        ApoB100_synth   -> VLDL1           [label="structural\nscaffold"];
        VLDL1           -> VLDL            [label="secreted\ninto plasma"];
        VLDL2           -> VLDL            [label="secreted\ninto plasma"];
        Insulin_liver   -> SREBP1c         [label="activates\nSREBP-1c", color="#2E7D32"];
        SREBP1c         -> Hepatic_TG_syn  [label="upregulates\nlipogenic\ngenes"];
        ChREBP          -> DNL_pathway     [label="glucose-driven\nlipogenesis"];
        Glucagon        -> VLDL            [label="↑ VLDL\nsecretion\n(fasted)", style=dashed];
        Lipin1          -> DGAT            [label="phosphatidic\nacid\nphosphohydrolase"];
        Hepatic_FFA_uptake -> Hepatic_TG_syn [label="esterification\nof excess FFA"];
        Omega3_drug     -> DGAT2_inh       [arrowhead=tee, label="↓ TG\nincorporation\ninto VLDL", style=dashed];
    }

    // =========================================================
    // INTER-CLUSTER CONNECTIONS
    // (links that cross cluster boundaries)
    // =========================================================

    // Hepatic cholesterol → LDLR feedback
    Hepatic_Cholesterol -> SREBP2_precursor [arrowhead=tee, label="high cholesterol\nblocks SREBP-2\nactivation", style=dashed, color="#B71C1C"];

    // LDLR clears LDL from plasma
    LDLR_surface -> LDL_particle    [arrowhead=tee, label="clears LDL\nfrom circulation", color="#1B5E20", penwidth=2];

    // Plasma LDL drives biomarker
    LDL_particle -> LDL_C           [label="mass\nmeasured as\nLDL-C"];

    // LDL in arterial wall
    LDL_particle -> oxLDL           [label="oxidation in\narterial wall\nsubtintima", color="#B71C1C"];

    // PCSK9 inhibitors → more LDLR → lower LDL-C
    PCSK9i_complex -> LDLR_surface  [label="more LDLR\nsurvive\n→ ↓ LDL-C", style=dashed, color="#1B5E20", penwidth=2];
    PCSK9_mRNA_silenced -> LDLR_surface [label="↑ LDLR\ndensity", style=dashed, color="#1B5E20", penwidth=2];

    // Statin → LDLR upregulation (via SREBP2)
    Statin_drug -> LDLR_surface     [label="↑ LDLR\n(via ↓ cholesterol\n→ ↑ SREBP2)", style=dashed, color="#1B5E20", penwidth=2];

    // Bile acid sequestrant → cholesterol consumption
    BAS_drug -> Hepatic_Cholesterol [arrowhead=tee, label="↓ hepatic\ncholesterol\nreturning from gut", style=dashed, color="#1B5E20"];

    // Ezetimibe → intestinal → hepatic effect
    Ezetimibe_drug -> Hepatic_Cholesterol [arrowhead=tee, label="↓ intestinal\ndelivery → liver\nmust upregulate LDLR", style=dashed, color="#1B5E20"];

    // Reverse cholesterol transport delivers CE to liver
    Hepatic_CE_uptake -> Cholesterol_BA [label="hepatic CE\nfor bile acid\nsynthesis"];

    // HDL → macrophage efflux
    ApoAI -> Cholesterol_efflux     [label="acceptor for\nmacrophage\ncholesterol\nefflux"];

    // Clinical outcome chain: LDL → plaque → MACE
    LDL_C -> Atherosclerosis_prog   [label="causal\nrelationship\n(Mendelian\nrandomization)", color="#B71C1C", penwidth=2];
    HDL_C -> Atherosclerosis_prog   [arrowhead=tee, label="inverse\nassociation", color="#1B5E20"];
    TG_marker -> Atherosclerosis_prog [label="residual\nrisk\n(TRL remnants)", style=dashed, color="#795548"];
    Atherosclerosis_prog -> Vulnerable_plaque [label="advanced\natheroma"];

    // Drug effects on biomarkers (key outcomes)
    Statin_drug -> LDL_C            [arrowhead=tee, label="↓ LDL-C\n40-55%", color="#E65100", penwidth=2, style=dashed];
    Ezetimibe_drug -> LDL_C         [arrowhead=tee, label="↓ LDL-C\nadditional ~18%", color="#F57F17", penwidth=2, style=dashed];
    Evolocumab -> LDL_C             [arrowhead=tee, label="↓ LDL-C\n60%", color="#E64A19", penwidth=2, style=dashed];
    Inclisiran_drug -> LDL_C        [arrowhead=tee, label="↓ LDL-C\n~50%", color="#BF360C", penwidth=2, style=dashed];
    Fibrate_drug -> TG_marker       [arrowhead=tee, label="↓ TG 30-50%\n↑ HDL-C 10-15%", color="#FF8F00", penwidth=2, style=dashed];
    Omega3_drug -> TG_marker        [arrowhead=tee, label="↓ TG 20-30%", color="#FF6F00", style=dashed];
    Niacin_drug -> HDL_C            [label="↑ HDL-C 15-35%", color="#FF6D00", style=dashed];
    Bempedoic_acid -> LDL_C         [arrowhead=tee, label="↓ LDL-C ~18%\n(add-on)", color="#E65100", style=dashed];

    // Statin → plaque stabilization
    Statin_drug -> Stable_plaque    [label="pleiotropic\neffects\n(inflammation↓,\nstabilization)", style=dashed, color="#2E7D32"];
    Statin_drug -> hsCRP_bm         [arrowhead=tee, label="↓ hsCRP\n(anti-\ninflammatory)", style=dashed, color="#2E7D32"];

    // JUPITER trial connection (statin in elevated hsCRP)
    hsCRP_bm -> MACE                [label="residual\nrisk\n(JUPITER trial)", style=dashed, color="#B71C1C"];

    // Omega-3 REDUCE-IT trial (CV benefit)
    Omega3_drug -> MACE             [arrowhead=tee, label="↓ MACE 25%\n(REDUCE-IT,\nICOSAPENT)", style=dashed, color="#2E7D32", penwidth=2];

    // Lp(a) → MACE (pleiotropic risk)
    Lpa_particle -> oxLDL           [label="Lp(a) has\noxidized\nphospholipids", style=dashed, color="#B71C1C"];
    Lpa_particle -> Plaque_rupture  [label="pro-thrombotic\nvia apo(a)\ninhibits\nplasminogen", style=dashed, color="#B71C1C"];

}
