digraph AATD_QSP_Model {
    graph [
        label = "Alpha-1 Antitrypsin Deficiency (AATD)\nQSP Mechanistic Map — Genetic, Hepatic, Pulmonary & Pharmacological Pathways"
        labelloc = t
        fontsize = 20
        fontname = "Helvetica-Bold"
        rankdir = LR
        compound = true
        splines = ortho
        nodesep = 0.45
        ranksep = 1.1
        bgcolor = "#FAFAFA"
        overlap = false
    ]
    node [fontname="Helvetica" fontsize=9 style=filled shape=box]
    edge [fontname="Helvetica" fontsize=8 arrowsize=0.6]

    /* ─────────────────────────────────────────────
       Cluster 1: Genetics & Genotypes
    ───────────────────────────────────────────── */
    subgraph cluster_genetics {
        label = "① Genetics & Genotype Spectrum"
        style = filled
        color = "#E8F4FD"
        fontcolor = "#1A5276"
        fontsize = 13

        SERPINA1 [label="SERPINA1 Gene\n(Chr 14q32.13)\n52 kDa Serine Protease Inhibitor" fillcolor="#2E86AB" fontcolor=white shape=octagon]
        M_allele  [label="M Allele\n(Wild-type)\n~95% population" fillcolor="#A8D8EA" shape=diamond]
        Z_allele  [label="Z Allele\n(Glu342Lys)\nMost pathogenic" fillcolor="#FF6B6B" shape=diamond]
        S_allele  [label="S Allele\n(Glu264Val)" fillcolor="#FFA07A" shape=diamond]
        Null_allele [label="Null Alleles\n(Truncation/Deletion)\nNo protein" fillcolor="#B0BEC5" shape=diamond]

        MM_geno [label="MM Genotype\n(Normal)\nAAT: 150-300 mg/dL" fillcolor="#C8E6C9" shape=ellipse]
        MZ_geno [label="MZ Genotype\n(Carrier)\nAAT: 90-130 mg/dL" fillcolor="#FFE0B2" shape=ellipse]
        SZ_geno [label="SZ Genotype\n(Moderate deficiency)\nAAT: 75-120 mg/dL" fillcolor="#FFCC80" shape=ellipse]
        ZZ_geno [label="ZZ Genotype\n(Severe deficiency)\nAAT: 20-50 mg/dL\n(~6-7 µM vs normal 20-53 µM)" fillcolor="#EF5350" fontcolor=white shape=ellipse]
        SS_geno [label="SS Genotype\n(Moderate)\nAAT ~100 mg/dL" fillcolor="#FFB74D" shape=ellipse]
        Prevalence [label="Global Prevalence\nZZ: ~1 in 3000-5000\nAutosomal Codominant" fillcolor="#AB47BC" fontcolor=white shape=note]

        SERPINA1 -> M_allele [label="Normal Tx"]
        SERPINA1 -> Z_allele [label="Missense Mut."]
        SERPINA1 -> S_allele [label="Missense Mut."]
        SERPINA1 -> Null_allele [label="Trunc/Del"]
        Z_allele -> ZZ_geno [label="Homozygous"]
        Z_allele -> MZ_geno [label="Heterozygous"]
        Z_allele -> SZ_geno [label="Compound Het."]
        S_allele -> SZ_geno
        S_allele -> SS_geno
        M_allele -> MM_geno
        ZZ_geno -> Prevalence
    }

    /* ─────────────────────────────────────────────
       Cluster 2: ER Protein Quality Control
    ───────────────────────────────────────────── */
    subgraph cluster_er {
        label = "② ER Protein Quality Control"
        style = filled
        color = "#FEF9E7"
        fontcolor = "#7D6608"
        fontsize = 13

        MAAT_synth   [label="M-AAT Synthesis\n(Normal β-sheet folding)\n→ Secretion 24 mg/kg/day" fillcolor="#A8D8EA" shape=box3d]
        ZAAT_synth   [label="Z-AAT Synthesis\n(Misfolded Conformation)\nGlu342Lys disrupts s4A strand" fillcolor="#EF5350" fontcolor=white shape=box3d]
        Calnexin     [label="Calnexin\n(ER Lectin Chaperone)" fillcolor="#FFF176"]
        BiP_GRP78    [label="BiP / GRP78\n(Hsp70 Chaperone)" fillcolor="#FFF176"]
        GRP94        [label="GRP94\n(Hsp90-class Chaperone)" fillcolor="#FFF176"]
        ZAATM_mono   [label="Z-AAT Monomer\n(Partially Folded Intermediate)" fillcolor="#FF8A65"]
        LoopSheet    [label="Loop-Sheet Polymer\n(Pathological Intracellular\nZ-AAT Accumulation)" fillcolor="#D32F2F" fontcolor=white shape=trapezium]
        ER_retention [label="ER Retention of\nZ-AAT Polymers\nInclusionbodies" fillcolor="#C62828" fontcolor=white shape=cylinder]
        UPR          [label="Unfolded Protein Response\n(IRE1α · PERK · ATF6)\nTriad Sensors" fillcolor="#FF9800" shape=parallelogram]
        IRE1_XBP1    [label="IRE1α / XBP1s\nBranch → ERAD\nExpansion" fillcolor="#F57C00"]
        PERK_eIF2a   [label="PERK / eIF2α\nBranch → Translation\nAttenuation" fillcolor="#E65100"]
        ATF6_chap    [label="ATF6 Branch\n→ Chaperone\nUpregulation" fillcolor="#BF360C"]
        ERAD         [label="ERAD\n(ER-Associated Degradation)\nHRD1 / UBE2J1 E3 Ligase" fillcolor="#9C27B0" fontcolor=white]
        Ubiq_26S     [label="Ubiquitin-26S Proteasome\nDegradation" fillcolor="#7B1FA2" fontcolor=white]
        Autophagy    [label="Selective Autophagy\n(LC3-II / p62 / Beclin-1)\nAggrephagy" fillcolor="#3F51B5" fontcolor=white]
        Lysosome_deg [label="Lysosomal Degradation\nZ-AAT Clearance" fillcolor="#283593" fontcolor=white]
        mTOR_path    [label="mTORC1 Pathway\n(Autophagy Suppressor)" fillcolor="#5C6BC0" fontcolor=white]

        MAAT_synth -> Calnexin [label="Glycan-mediated\nfolding cycle"]
        Calnexin -> GRP94
        GRP94 -> MAAT_synth [style=dashed label="Successful fold\n→ Golgi export"]
        ZAAT_synth -> ZAATM_mono
        ZAATM_mono -> BiP_GRP78 [label="Binds\nmisfolded"]
        BiP_GRP78 -> UPR [label="Prolonged\nbinding → UPR"]
        ZAATM_mono -> LoopSheet [label="Polymerization\nkinetics"]
        LoopSheet -> ER_retention [label="Accumulates in\nheptocyte ER"]
        UPR -> IRE1_XBP1
        UPR -> PERK_eIF2a
        UPR -> ATF6_chap
        IRE1_XBP1 -> ERAD
        ERAD -> Ubiq_26S
        LoopSheet -> Autophagy [label="Aggregate\nsequestration"]
        Autophagy -> Lysosome_deg
        mTOR_path -> Autophagy [label="Inhibits" style=dashed arrowhead=tee]
    }

    /* ─────────────────────────────────────────────
       Cluster 3: Hepatic Pathology
    ───────────────────────────────────────────── */
    subgraph cluster_liver {
        label = "③ Hepatic Pathology (Gain-of-Function Toxicity)"
        style = filled
        color = "#FDEDEC"
        fontcolor = "#7B241C"
        fontsize = 13

        Hepatocyte_inj [label="Hepatocyte Injury\n(ER Protein Toxicity)" fillcolor="#E53935" fontcolor=white]
        ER_stress_chron [label="Chronic ER Stress\n(Sustained UPR activation)" fillcolor="#C62828" fontcolor=white]
        Apoptosis_cas   [label="Hepatocyte Apoptosis\n(Caspase-3/8/9)" fillcolor="#B71C1C" fontcolor=white]
        NF_kB_liver     [label="NF-κB (Liver)\nTranscription Factor" fillcolor="#FF5722"]
        TNFa_liver      [label="TNF-α (Liver)\nPro-inflammatory" fillcolor="#FF7043"]
        IL6_liver       [label="IL-6 (Liver)\nAcute Phase" fillcolor="#FF8A65"]
        ROS_liver       [label="ROS (Mitochondrial)\nOxidative Stress" fillcolor="#FF8F00" shape=star]
        HSC_quiescent   [label="Hepatic Stellate Cell\n(Quiescent / Fat-Storing)" fillcolor="#A5D6A7"]
        HSC_activated   [label="Hepatic Stellate Cell\n(Activated / Myofibroblast)" fillcolor="#EF5350" fontcolor=white]
        TGFb1_liver     [label="TGF-β1 (Liver)\nMaster Fibrogenic\nCytokine" fillcolor="#D84315"]
        PDGF_liver      [label="PDGF-BB (Liver)\nProliferative Stimulus" fillcolor="#BF360C"]
        Coll_I_III      [label="Collagen I/III\nDeposition\n(ECM Remodeling)" fillcolor="#8D6E63" fontcolor=white]
        TIMP1_liver     [label="TIMP-1\n(Fibrosis Promoter)" fillcolor="#795548"]
        MMP2_liver      [label="MMP-2/9\n(ECM Turnover)" fillcolor="#6D4C41"]
        Liver_fibrosis  [label="Hepatic Fibrosis\nMetavir F0 → F4" fillcolor="#4E342E" fontcolor=white shape=hexagon]
        Cirrhosis       [label="Liver Cirrhosis\n(Portal Hypertension\nHepatic Failure)" fillcolor="#3E2723" fontcolor=white shape=hexagon]
        HCC_risk        [label="HCC Risk\n(10-40× ↑ in PIZZZ)\nLifetime risk ~28%" fillcolor="#311B92" fontcolor=white shape=octagon]
        DNA_damage_liv  [label="DNA Oxidative Damage\n(8-OHdG, 4-HNE adducts)" fillcolor="#4A148C" fontcolor=white]
        ALT_AST         [label="ALT / AST\n(Hepatocyte Damage Marker)" fillcolor="#F48FB1" shape=note]
        GGT_marker      [label="GGT\n(Cholestasis Marker)" fillcolor="#F8BBD0" shape=note]
        Bilirubin       [label="Bilirubin\n(Liver Function Marker)" fillcolor="#FCE4EC" shape=note]
        FIB4_score      [label="FIB-4 Score\n(Non-invasive Fibrosis)" fillcolor="#E91E63" shape=note]
        Liver_stiffness [label="Liver Stiffness\n(FibroScan, kPa)" fillcolor="#880E4F" fontcolor=white shape=note]

        ER_retention -> Hepatocyte_inj
        Hepatocyte_inj -> ER_stress_chron
        ER_stress_chron -> NF_kB_liver
        ER_stress_chron -> ROS_liver
        NF_kB_liver -> TNFa_liver
        NF_kB_liver -> IL6_liver
        Hepatocyte_inj -> Apoptosis_cas
        ROS_liver -> DNA_damage_liv
        DNA_damage_liv -> HCC_risk
        Apoptosis_cas -> DNA_damage_liv
        TNFa_liver -> HSC_activated [label="Activation"]
        IL6_liver -> HSC_activated
        TGFb1_liver -> HSC_activated
        HSC_quiescent -> HSC_activated [label="Paracrine\nactivation"]
        HSC_activated -> TGFb1_liver
        HSC_activated -> PDGF_liver
        HSC_activated -> Coll_I_III
        HSC_activated -> TIMP1_liver
        TIMP1_liver -> MMP2_liver [label="Inhibits" style=dashed arrowhead=tee]
        Coll_I_III -> Liver_fibrosis
        Liver_fibrosis -> Cirrhosis
        Cirrhosis -> HCC_risk
        Hepatocyte_inj -> ALT_AST
        Liver_fibrosis -> FIB4_score
        Liver_fibrosis -> Liver_stiffness
        Cirrhosis -> GGT_marker
        Cirrhosis -> Bilirubin
    }

    /* ─────────────────────────────────────────────
       Cluster 4: AAT Biology & Serum Distribution
    ───────────────────────────────────────────── */
    subgraph cluster_aat {
        label = "④ AAT Biology & Systemic Distribution"
        style = filled
        color = "#E8F5E9"
        fontcolor = "#1B5E20"
        fontsize = 13

        MAAT_sec    [label="M-AAT Secretion\nNormal: 150-300 mg/dL\n(~18-53 µM)" fillcolor="#A5D6A7"]
        ZAAT_sec    [label="Z-AAT Secretion\nZZ: only 10-15% of M-AAT\n(~2-7 µM)" fillcolor="#EF5350" fontcolor=white]
        Plasma_AAT  [label="Plasma AAT\nProtective Threshold: >11 µM\nHalf-life: 4-5 days\nVd: 3.76 L/kg" fillcolor="#43A047" fontcolor=white shape=cylinder]
        ELF_AAT     [label="Epithelial Lining Fluid AAT\n(ELF/Plasma ratio ~0.1)\n→ Key Lung Compartment" fillcolor="#388E3C" fontcolor=white shape=cylinder]
        BAL_AAT     [label="BAL Fluid AAT\nAlveolar Compartment" fillcolor="#2E7D32" fontcolor=white]
        Interstitial_AAT [label="Lung Interstitial AAT\nMatrix-Bound Fraction" fillcolor="#1B5E20" fontcolor=white]
        Fn_NE_inhib [label="NE Inhibition Function\n(Reactive Center Loop\nMet358-Ser359 Bait)" fillcolor="#004D40" fontcolor=white shape=diamond]
        Fn_PR3_inhib [label="PR3 / Cathepsin G\nInhibition Function" fillcolor="#00695C" fontcolor=white shape=diamond]
        Fn_anti_inflam [label="Non-inhibitory\nAnti-inflammatory Functions\n(IL-8↓, LTB4↓, NF-κB↓,\nApoptosis↓, IL-10↑)" fillcolor="#00796B" fontcolor=white shape=diamond]
        Fn_ePC       [label="Ceramide-1-Phosphate / ePC\n(Cell Survival Signal)" fillcolor="#00897B" fontcolor=white shape=diamond]
        Acute_phase  [label="Acute Phase Response\n(IL-6/TNF-α → Liver AAT ↑2-4×\nInflammation → AAT ↑)" fillcolor="#C8E6C9"]

        MAAT_synth -> MAAT_sec [ltail=cluster_er label="Golgi Export\n→ Secretion"]
        ZAAT_synth -> ZAAT_sec [ltail=cluster_er label="~10% of M-AAT\nsecretion rate"]
        MAAT_sec -> Plasma_AAT
        ZAAT_sec -> Plasma_AAT
        Plasma_AAT -> ELF_AAT [label="ELF/Plasma = 0.09\nto 0.12"]
        ELF_AAT -> BAL_AAT
        ELF_AAT -> Interstitial_AAT
        Plasma_AAT -> Fn_NE_inhib
        ELF_AAT -> Fn_NE_inhib
        Plasma_AAT -> Fn_PR3_inhib
        Plasma_AAT -> Fn_anti_inflam
        Plasma_AAT -> Fn_ePC
        IL6_liver -> Acute_phase
        TNFa_liver -> Acute_phase
        Acute_phase -> MAAT_sec [label="↑ synthesis 2-4×\n(Insufficient in ZZ)"]
    }

    /* ─────────────────────────────────────────────
       Cluster 5: Protease-Antiprotease Balance
    ───────────────────────────────────────────── */
    subgraph cluster_protease {
        label = "⑤ Pulmonary Protease-Antiprotease Balance"
        style = filled
        color = "#EDE7F6"
        fontcolor = "#4A148C"
        fontsize = 13

        Neutro_recruit [label="Neutrophil Recruitment\n(IL-8/CXCL8, LTB4, fMLP\nComplement C5a)" fillcolor="#CE93D8"]
        PMN_lung       [label="Lung Neutrophils (PMN)\nBurden ↑ in AATD" fillcolor="#AB47BC" fontcolor=white]
        NE_total       [label="Neutrophil Elastase (NE)\nTotal Pool\n(Azurophilic Granules)" fillcolor="#9C27B0" fontcolor=white shape=diamond]
        NE_active      [label="Free / Active NE\n→ Unchecked Proteolysis\n(ZZ: AAT insufficient)" fillcolor="#6A1B9A" fontcolor=white shape=diamond]
        MPO_ox         [label="MPO / HOCI\nOxidative Burst\n→ Inactivates AAT" fillcolor="#7B1FA2" fontcolor=white]
        PR3_active     [label="Proteinase 3 (PR3)\nActive Enzyme" fillcolor="#8E24AA" fontcolor=white shape=diamond]
        CathG          [label="Cathepsin G\nSerine Protease" fillcolor="#9C27B0" fontcolor=white shape=diamond]
        AirMac         [label="Alveolar Macrophages\n(Phagocytosis Impaired\nin AATD)" fillcolor="#CE93D8"]
        MMP12          [label="MMP-12\n(Macrophage Elastase)\nKey Enzyme in AATD" fillcolor="#BA68C8"]
        MMP9_lung      [label="MMP-9 (Gelatinase B)\nNeutrophil + Macrophage" fillcolor="#9575CD"]
        MMP2_lung      [label="MMP-2 (Gelatinase A)\nMatrix Remodeling" fillcolor="#7E57C2" fontcolor=white]
        AAT_NE_cplx    [label="AAT-NE Covalent Complex\n(1:1 Michaelis Inhibition)\n→ Clearance" fillcolor="#4CAF50" fontcolor=white shape=diamond]
        SLPI           [label="SLPI\n(Secretory Leukocyte\nProtease Inhibitor)" fillcolor="#81C784"]
        Elafin_SKALP   [label="Elafin / SKALP\n(Elastase Specific Inhibitor)" fillcolor="#66BB6A"]
        TIMP3_lung     [label="TIMP-3 / TIMP-1\n(MMP Inhibitors in Lung)" fillcolor="#43A047" fontcolor=white]
        ROS_lung       [label="ROS\n(H2O2, HOCl, O2·-)\nfrom MPO/NOX" fillcolor="#FF8F00" shape=star]
        Met_oxidized   [label="Oxidized AAT\n(Met358-SO)\n→ 2000× ↓ NE inhibition" fillcolor="#FF6F00" shape=star]
        NE_bound_ECM   [label="ECM-Bound NE\n(Protected from inhibitors)" fillcolor="#E65100" fontcolor=white shape=diamond]

        Neutro_recruit -> PMN_lung
        PMN_lung -> NE_total
        PMN_lung -> MPO_ox
        PMN_lung -> PR3_active
        PMN_lung -> CathG
        NE_total -> NE_active [label="Released upon\nactivation"]
        NE_active -> AAT_NE_cplx [label="Inhibited by AAT\n(k_assoc ~6×10⁷ M⁻¹s⁻¹)"]
        Fn_NE_inhib -> AAT_NE_cplx [ltail=cluster_aat label="AAT inhibits NE"]
        SLPI -> NE_active [label="Secondary inhibition" style=dashed arrowhead=tee]
        Elafin_SKALP -> NE_active [label="Inhibits" style=dashed arrowhead=tee]
        MPO_ox -> ROS_lung
        ROS_lung -> Met_oxidized [label="Oxidation of\nMet358 in AAT"]
        Met_oxidized -> AAT_NE_cplx [label="Cannot form\n(loss of function)" style=dashed arrowhead=tee]
        NE_active -> NE_bound_ECM [label="Binds ECM\nelastin/fibronectin"]
        NE_bound_ECM -> AAT_NE_cplx [label="Partially protected" style=dashed arrowhead=tee]
        AirMac -> MMP12
        AirMac -> MMP9_lung
        AirMac -> MMP2_lung
        TIMP3_lung -> MMP12 [label="Inhibits" style=dashed arrowhead=tee]
        TIMP3_lung -> MMP9_lung [label="Inhibits" style=dashed arrowhead=tee]
        Fn_PR3_inhib -> PR3_active [ltail=cluster_aat label="AAT inhibits PR3" style=dashed arrowhead=tee]
    }

    /* ─────────────────────────────────────────────
       Cluster 6: Lung Pathology (Emphysema)
    ───────────────────────────────────────────── */
    subgraph cluster_lung {
        label = "⑥ Pulmonary Pathology — Emphysema & Airflow Obstruction"
        style = filled
        color = "#FFF8E1"
        fontcolor = "#E65100"
        fontsize = 13

        Elastin_deg    [label="Elastin Degradation\n(Alveolar Wall)\nby NE + MMP-12" fillcolor="#FFE082"]
        Fibronectin_deg [label="Fibronectin Degradation\n(Alveolar ECM)\nby NE" fillcolor="#FFD54F"]
        Coll_lung_deg  [label="Lung Collagen Degradation\n(Type IV/I/III)\nby MMP-2/9" fillcolor="#FFCC02"]
        Laminin_deg    [label="Laminin Degradation\n(Basement Membrane)" fillcolor="#FFB300"]
        ECM_dest       [label="Alveolar ECM Destruction\nPanacinar Emphysema\n(Lower Lobe > Upper Lobe)" fillcolor="#FF8F00" shape=hexagon]
        Alveolar_dest  [label="Alveolar Wall Destruction\n→ Airspace Enlargement\n→ Alveolar Simplification" fillcolor="#E65100" fontcolor=white]
        Surface_loss   [label="Alveolar Surface Area Loss\n(↓ Gas Exchange Efficiency)" fillcolor="#BF360C" fontcolor=white]
        AirTrap        [label="Air Trapping\n(↑ RV, ↑ FRC, ↑ TLC)" fillcolor="#FF7043"]
        Panlobular_emph [label="CT Emphysema Index\n(CT-PD15, LAA-950)\n% Lung Volume < -950 HU" fillcolor="#C62828" fontcolor=white shape=note]
        Airway_inflam  [label="Chronic Airway Inflammation\nMucus Hypersecretion" fillcolor="#FF5722"]
        Bronchiec_AATD [label="Bronchiectasis\n(~30-50% of PIZZZ\npatients)" fillcolor="#E64A19" fontcolor=white]
        FEV1           [label="FEV1 (% Predicted)\nNatural decline:\n• Non-smoker ZZ: 50-80 mL/yr\n• Smoker ZZ: 100-200 mL/yr\n• Normal: 25-30 mL/yr" fillcolor="#D84315" fontcolor=white shape=note]
        FVC_lung       [label="FVC (% Predicted)\n↓ in Severe Disease" fillcolor="#BF360C" fontcolor=white shape=note]
        FEV1FVC        [label="FEV1/FVC Ratio\nObstructive Pattern (<0.70)" fillcolor="#B71C1C" fontcolor=white shape=note]
        DLCO           [label="DLCO (KCO)\n↓ in Emphysema\n(Proportional to surface loss)" fillcolor="#880E4F" fontcolor=white shape=note]
        RV_TLC         [label="RV/TLC Ratio\n↑ Air Trapping" fillcolor="#AD1457" fontcolor=white shape=note]
        Pulm_HTN       [label="Secondary Pulmonary\nHTN (mPAP >25 mmHg)\n~30% advanced AATD" fillcolor="#C2185B" fontcolor=white]
        Exacerbation   [label="COPD Exacerbations\n(AECOPDs)\nHospitalization Risk ↑" fillcolor="#E91E63" fontcolor=white shape=note]
        Transplant     [label="Lung Transplant\nFEV1 <20% predicted\nMedian age ~55-60 yrs (PIZZZ)" fillcolor="#7B1FA2" fontcolor=white shape=octagon]

        NE_active -> Elastin_deg [ltail=cluster_protease label="Unchecked NE\n→ Elastolysis"]
        MMP12 -> Elastin_deg [ltail=cluster_protease]
        NE_active -> Fibronectin_deg [ltail=cluster_protease]
        MMP9_lung -> Coll_lung_deg [ltail=cluster_protease]
        NE_active -> Laminin_deg [ltail=cluster_protease]
        Elastin_deg -> ECM_dest
        Fibronectin_deg -> ECM_dest
        Coll_lung_deg -> ECM_dest
        Laminin_deg -> ECM_dest
        ECM_dest -> Alveolar_dest
        Alveolar_dest -> Surface_loss
        Surface_loss -> DLCO [label="DLCO ↓"]
        Alveolar_dest -> AirTrap
        AirTrap -> RV_TLC
        ECM_dest -> Panlobular_emph
        Alveolar_dest -> FEV1 [label="FEV1 ↓"]
        ECM_dest -> FEV1
        FEV1 -> FEV1FVC
        FEV1 -> FVC_lung
        Airway_inflam -> FEV1 [label="Airflow\nLimitation"]
        Airway_inflam -> Bronchiec_AATD
        NE_active -> Airway_inflam [ltail=cluster_protease]
        FEV1 -> Exacerbation [label="FEV1 <50%\n→ High Risk"]
        Exacerbation -> FEV1 [label="Each exacerbation\n→ FEV1 step decline"]
        Pulm_HTN -> FVC_lung [style=dashed]
        FEV1 -> Transplant [label="FEV1 <20%"]
    }

    /* ─────────────────────────────────────────────
       Cluster 7: Inflammatory Cascade
    ───────────────────────────────────────────── */
    subgraph cluster_inflammation {
        label = "⑦ Pulmonary Inflammatory Cascade"
        style = filled
        color = "#FCE4EC"
        fontcolor = "#880E4F"
        fontsize = 13

        IL8_lung   [label="IL-8 / CXCL8\n(Neutrophil Chemoattractant)\n↑↑ in AATD BAL" fillcolor="#F48FB1"]
        LTB4_lung  [label="LTB4 (5-LOX pathway)\nNeutrophil Activator" fillcolor="#F06292"]
        TNFa_lung  [label="TNF-α (Lung)\nMacrophage-Derived" fillcolor="#EC407A"]
        IL1b_lung  [label="IL-1β\n(NLRP3 Inflammasome)" fillcolor="#E91E63"]
        IL17_lung  [label="IL-17A/F\n(Th17-Driven Neutrophilia)" fillcolor="#D81B60"]
        IFNg_lung  [label="IFN-γ (Th1 cells)\nAnti-viral / Macrophage\nActivation" fillcolor="#C2185B" fontcolor=white]
        IL10_anti  [label="IL-10 (Anti-inflammatory)\n↓ in AATD\n(AAT induces IL-10↑)" fillcolor="#66BB6A"]
        Complement_C5a [label="Complement C5a\n(Potent Neutrophil\nChemoattractant)" fillcolor="#CE93D8"]
        CD8_T      [label="CD8+ T Cells\n(Cytotoxic T Lymphocytes)\n↑ in AATD BAL" fillcolor="#9C27B0" fontcolor=white]
        Th17_T     [label="Th17 Cells\n(IL-17 Producers)" fillcolor="#8E24AA" fontcolor=white]
        NK_cells   [label="NK Cells\n(Innate Cytotoxicity)" fillcolor="#7B1FA2" fontcolor=white]
        NF_kB_lung [label="NF-κB (Lung)\nMaster Inflammatory\nRegulator" fillcolor="#880E4F" fontcolor=white]
        AP1_lung   [label="AP-1 (c-Jun/c-Fos)\nOxidative Stress-Driven" fillcolor="#AD1457" fontcolor=white]
        Desmosine  [label="Desmosine / Isodesmosine\n(Elastin Degradation Marker)\nUrine & Plasma Biomarker" fillcolor="#CE93D8" shape=note]
        NE_act_IL8 [label="NE Cleaves Epithelial\nSurface → IL-8 Release" fillcolor="#F48FB1"]

        IL8_lung -> Neutro_recruit [lhead=cluster_protease]
        LTB4_lung -> Neutro_recruit [lhead=cluster_protease]
        Complement_C5a -> Neutro_recruit [lhead=cluster_protease]
        NF_kB_lung -> IL8_lung
        NF_kB_lung -> IL1b_lung
        NF_kB_lung -> TNFa_lung
        NF_kB_lung -> LTB4_lung
        TNFa_lung -> NF_kB_lung [label="Autoamplification"]
        IL1b_lung -> IL17_lung [label="Th17\nPolarization"]
        ROS_lung -> NF_kB_lung [ltail=cluster_protease]
        ROS_lung -> AP1_lung [ltail=cluster_protease]
        CD8_T -> TNFa_lung
        Th17_T -> IL17_lung
        NK_cells -> IFNg_lung
        Fn_anti_inflam -> NF_kB_lung [ltail=cluster_aat label="AAT inhibits" style=dashed arrowhead=tee color=green]
        Fn_anti_inflam -> IL8_lung [ltail=cluster_aat label="AAT ↓ IL-8" style=dashed arrowhead=tee color=green]
        Fn_anti_inflam -> IL10_anti [ltail=cluster_aat label="AAT ↑ IL-10" color=green]
        NE_active -> NE_act_IL8 [ltail=cluster_protease]
        NE_act_IL8 -> IL8_lung
        Elastin_deg -> Desmosine [ltail=cluster_lung label="Elastin fragment\n→ systemic marker"]
    }

    /* ─────────────────────────────────────────────
       Cluster 8: Pharmacological Interventions
    ───────────────────────────────────────────── */
    subgraph cluster_drugs {
        label = "⑧ Pharmacological Interventions (PK/PD)"
        style = filled
        color = "#E3F2FD"
        fontcolor = "#0D47A1"
        fontsize = 13

        // Augmentation Therapy
        Prolastin_C  [label="Prolastin-C\n(α1PI, Talecris)\n60 mg/kg IV weekly" fillcolor="#1565C0" fontcolor=white shape=component]
        Zemaira      [label="Zemaira\n(α1-Proteinase Inhibitor)\n60 mg/kg IV weekly" fillcolor="#1976D2" fontcolor=white shape=component]
        Aralast_NP   [label="Aralast NP\n(Baxter α1PI)\n60 mg/kg IV weekly" fillcolor="#1E88E5" fontcolor=white shape=component]
        Glassia      [label="Glassia\n(Liquid IV α1PI)\n60 mg/kg IV weekly" fillcolor="#2196F3" fontcolor=white shape=component]
        Aug_Central  [label="Augmentation Drug\nCentral Compartment (V1)\nCL: 0.22 L/h, Vd: 3.76 L/kg" fillcolor="#42A5F5" shape=cylinder]
        Aug_Periph   [label="Augmentation Drug\nPeripheral Compartment (V2)\nQ: 0.15 L/h" fillcolor="#64B5F6" shape=cylinder]
        AAT_trough   [label="Trough Serum AAT\n(Week-end Level)\nTarget: >11 µM (57 mg/dL)\nRAPID Trial threshold" fillcolor="#90CAF9" shape=note]

        // siRNA / ASO
        Fazirsiran   [label="Fazirsiran (ARO-AAT)\nGalNAc-siRNA → Hepatocytes\n200 mg SQ q12 weeks" fillcolor="#0097A7" fontcolor=white shape=component]
        Belcesiran   [label="Belcesiran (DCR-A1AT)\nsiRNA SERPINA1 mRNA\n→ Z-AAT ↓↓" fillcolor="#00ACC1" fontcolor=white shape=component]
        siRNA_liver  [label="siRNA Hepatic Effect\n→ SERPINA1 mRNA ↓70-90%\n→ Z-AAT Polymer ↓\n→ Liver ALT normalize" fillcolor="#00BCD4" shape=cylinder]

        // Small-Molecule Correctors
        VX864        [label="VX-864\n(CFTR Corrector Analog)\n→ Z-AAT Folding\n(Phase 2, Discontinued)" fillcolor="#7986CB" shape=component]
        GSK3117391   [label="GSK3117391\n(Z-AAT Corrector)\n→ Serum AAT ↑ ~2-4×\n(Preclinical/Phase 1)" fillcolor="#5C6BC0" fontcolor=white shape=component]
        ARIDAG       [label="AR-42 / HDAC Inhibitor\n→ Autophagy ↑\n→ Z-AAT Polymer ↓" fillcolor="#3F51B5" fontcolor=white shape=component]
        Corr_effect  [label="Corrector PD Effect\n→ Polymer Formation ↓\n→ Secretion of Z-AAT ↑\n→ Serum AAT partial ↑" fillcolor="#7986CB" shape=cylinder]

        // NE Inhibitors
        Alvelestat   [label="Alvelestat (AZD9668)\nOral NE Inhibitor\n(60 mg BID, Phase 2)" fillcolor="#26A69A" fontcolor=white shape=component]
        Lonodelestat [label="Lonodelestat (POL6014)\nInhaled NE Inhibitor\n(Phase 2, AATD)" fillcolor="#2E7D32" fontcolor=white shape=component]
        Brensocatib  [label="Brensocatib\n(DPP1 Inhibitor → ↓NE/PR3\nMaturation, Insmed)" fillcolor="#388E3C" fontcolor=white shape=component]
        NE_inhib_eff [label="NE Inhibitor PD Effect\n→ Active NE ↓ 60-80%\n→ Elastin Protection\n→ FEV1 Decline ↓" fillcolor="#43A047" fontcolor=white shape=cylinder]

        // Antioxidants
        NAC_aatd     [label="N-Acetylcysteine (NAC)\nGSH Precursor\n→ Oxidized AAT ↓" fillcolor="#8D6E63" shape=component]
        Antioxid_eff [label="Antioxidant Effect\n→ ROS ↓\n→ AAT Oxidation ↓" fillcolor="#6D4C41" fontcolor=white shape=cylinder]

        // Gene Therapy
        AAV_AAT      [label="rAAV1-SERPINA1\nMuscle-Directed Gene Therapy\n(AlphaCore, Phase 1-2)" fillcolor="#795548" fontcolor=white shape=component]
        AAV8_liver   [label="AAV8-SERPINA1\nLiver-Directed Gene Therapy\n(Sustained M-AAT expression)" fillcolor="#6D4C41" fontcolor=white shape=component]
        CRISPR_corr  [label="CRISPR/Cas9\nZ→M Base Editing\n(Hepatic, Research)" fillcolor="#5D4037" fontcolor=white shape=component]
        mRNA_therapy [label="mRNA Therapy\n(Translate Bio / Moderna)\nLNP-formulated SERPINA1" fillcolor="#4E342E" fontcolor=white shape=component]
        Gene_eff     [label="Gene Therapy Effect\n→ Sustained M-AAT ↑\n→ Normal serum AAT\n→ ELF AAT protective" fillcolor="#3E2723" fontcolor=white shape=cylinder]

        // COPD Symptomatic
        LABA_LAMA    [label="LABA/LAMA\n(Bronchodilators)\nSalmeterol/Tiotropium" fillcolor="#5E35B1" fontcolor=white shape=component]
        ICS_AATD     [label="ICS\n(Inhaled Corticosteroids)\nFluticasone/Budesonide" fillcolor="#512DA8" fontcolor=white shape=component]
        Roflumilast  [label="Roflumilast\n(PDE4 Inhibitor)\nAnti-inflammatory COPD" fillcolor="#4527A0" fontcolor=white shape=component]
        BRONDILAT_eff [label="Bronchodilator Effect\n→ FEV1 ↑ 100-200 mL\n→ Dyspnea ↓\n(Symptomatic only)" fillcolor="#7E57C2" fontcolor=white shape=cylinder]

        Prolastin_C -> Aug_Central [label="IV 60 mg/kg\n~7-day dosing"]
        Zemaira -> Aug_Central
        Aralast_NP -> Aug_Central
        Glassia -> Aug_Central
        Aug_Central -> Aug_Periph [label="Distribution\nQ12h"]
        Aug_Periph -> Aug_Central [label="Redistribution"]
        Aug_Central -> AAT_trough [label="Cmin at day 7"]
        Fazirsiran -> siRNA_liver [label="GalNAc targeting\n→ Hepatocyte uptake"]
        Belcesiran -> siRNA_liver
        VX864 -> Corr_effect [label="Oral Corrector"]
        GSK3117391 -> Corr_effect
        ARIDAG -> Corr_effect [label="Autophagy\nInduction"]
        Alvelestat -> NE_inhib_eff [label="Oral PO\nk_on: competitive"]
        Lonodelestat -> NE_inhib_eff [label="Inhaled\nLocal effect"]
        Brensocatib -> NE_inhib_eff [label="DPP1 → ↓\nNE maturation"]
        NAC_aatd -> Antioxid_eff
        AAV_AAT -> Gene_eff [label="IM/IV vector"]
        AAV8_liver -> Gene_eff [label="Liver-directed"]
        CRISPR_corr -> Gene_eff
        mRNA_therapy -> Gene_eff [label="Repeated dosing\nLNP delivery"]
        LABA_LAMA -> BRONDILAT_eff
        ICS_AATD -> BRONDILAT_eff [label="Anti-inflam\ncomponent"]
        Roflumilast -> BRONDILAT_eff [label="PDE4i\nEffect"]
    }

    /* ─────────────────────────────────────────────
       Cluster 9: Treatment Pharmacodynamic Outputs
    ───────────────────────────────────────────── */
    subgraph cluster_pd_outputs {
        label = "⑨ Treatment PD Effects on Disease"
        style = filled
        color = "#F1F8E9"
        fontcolor = "#33691E"
        fontsize = 13

        Serum_raise  [label="Serum AAT ↑ to >11 µM\n→ Protective Threshold\n→ Anti-NE, Anti-inflam" fillcolor="#8BC34A" fontcolor=white]
        ELF_raise    [label="ELF AAT ↑\n→ Lung Protection\n→ NE Inhibitory Capacity ↑" fillcolor="#7CB342" fontcolor=white]
        NE_reduce    [label="Lung Free NE ↓\n→ Elastin Preservation\n→ Less Emphysema Progression" fillcolor="#689F38" fontcolor=white]
        Polymer_red  [label="Z-AAT Polymer ↓\n→ ER Stress ↓\n→ Hepatocyte Injury ↓" fillcolor="#558B2F" fontcolor=white]
        FEV1_stab    [label="FEV1 Decline Attenuation\n(RAPID Trial: -0.55 vs\n-0.95 g/L/yr lung density)" fillcolor="#33691E" fontcolor=white]
        CT_dens_pres [label="CT Lung Density\nPreservation\n(Primary endpoint RAPID)" fillcolor="#1B5E20" fontcolor=white]
        Exacer_red   [label="Exacerbation Rate ↓\n30-50% vs Placebo\n(AATD+Augmentation)" fillcolor="#F9A825"]
        Liver_norm   [label="Liver Enzyme\nNormalization\nALT/AST → Normal" fillcolor="#F57F17"]
        QoL_improve  [label="QoL Improvement\nSGRQ ↓ 4+ units\n(Clinically significant)" fillcolor="#FF8F00"]

        Aug_Central -> Serum_raise [ltail=cluster_drugs label="Augmentation\ntherapy"]
        Gene_eff -> Serum_raise [ltail=cluster_drugs]
        Corr_effect -> Serum_raise [ltail=cluster_drugs label="Partial ↑"]
        Serum_raise -> ELF_raise [label="ELF/Plasma\n~0.1 ratio"]
        ELF_raise -> NE_reduce [label="AAT inhibits\nNE in ELF"]
        NE_inhib_eff -> NE_reduce [ltail=cluster_drugs label="Direct NE\ninhibition"]
        Antioxid_eff -> NE_reduce [ltail=cluster_drugs label="Prevent\nAAT oxidation"]
        NE_reduce -> FEV1_stab
        NE_reduce -> CT_dens_pres
        siRNA_liver -> Polymer_red [ltail=cluster_drugs]
        Polymer_red -> Liver_norm
        FEV1_stab -> Exacer_red
        FEV1_stab -> QoL_improve
        BRONDILAT_eff -> QoL_improve [ltail=cluster_drugs]
    }

    /* ─────────────────────────────────────────────
       Cluster 10: Clinical Endpoints & Outcomes
    ───────────────────────────────────────────── */
    subgraph cluster_outcomes {
        label = "⑩ Clinical Endpoints & Patient Outcomes"
        style = filled
        color = "#ECEFF1"
        fontcolor = "#263238"
        fontsize = 13

        Disease_sev  [label="AATD Disease Severity\nMild · Moderate · Severe\n(Lung + Liver Assessment)" fillcolor="#546E7A" fontcolor=white shape=hexagon]
        SGRQ         [label="SGRQ Score\n(St George's Respiratory Q)\n0-100, ↑ = worse QoL" fillcolor="#78909C" fontcolor=white shape=note]
        CAT_outcome  [label="CAT Score\n(COPD Assessment Test)\n0-40" fillcolor="#90A4AE" shape=note]
        mMRC         [label="mMRC Dyspnea Scale\n0 (None) → 4 (Severe)" fillcolor="#B0BEC5" shape=note]
        SixMWT       [label="6-Minute Walk Distance\n(6MWD, meters)\n↓ with severe disease" fillcolor="#546E7A" fontcolor=white shape=note]
        VO2max       [label="Peak VO2 (mL/kg/min)\nExercise Tolerance" fillcolor="#455A64" fontcolor=white shape=note]
        Serum_AAT_bio [label="Serum AAT Level\n(µM or mg/dL)\nKey Monitoring Biomarker" fillcolor="#607D8B" fontcolor=white shape=note]
        ELF_bio      [label="ELF AAT / NE·AAT Ratio\n(Bronchoscopic Sampling)\nResearch Biomarker" fillcolor="#78909C" fontcolor=white shape=note]
        CT_emph_bio  [label="CT Emphysema Index\nLung Density (g/L)\n15th Percentile Density" fillcolor="#90A4AE" shape=note]
        Liver_bio    [label="Liver Biomarkers\nALT · AST · GGT · Bilirubin\nFIB-4 · Liver Stiffness" fillcolor="#B0BEC5" shape=note]
        Mortality    [label="AATD Mortality\n• Respiratory (Primary)\n• Hepatic\nMedian survival ~55 yrs (ZZ)" fillcolor="#263238" fontcolor=white shape=octagon]
        Lung_dom     [label="Lung-Dominant Phenotype\n~80% of PIZZZ adults\n(Emphysema >> Liver)" fillcolor="#4FC3F7"]
        Liver_dom    [label="Liver-Dominant Phenotype\nNeonatal cholestasis\n+ genotype modifiers" fillcolor="#F06292"]
        Combined_ph  [label="Combined Phenotype\nLung + Liver disease\n(More severe)" fillcolor="#AB47BC" fontcolor=white]

        FEV1 -> Disease_sev [ltail=cluster_lung]
        Panlobular_emph -> Disease_sev [ltail=cluster_lung]
        DLCO -> Disease_sev [ltail=cluster_lung]
        Liver_fibrosis -> Disease_sev [ltail=cluster_liver]
        Disease_sev -> SGRQ
        Disease_sev -> CAT_outcome
        Disease_sev -> mMRC
        Disease_sev -> SixMWT
        Disease_sev -> VO2max
        Plasma_AAT -> Serum_AAT_bio [ltail=cluster_aat]
        ELF_AAT -> ELF_bio [ltail=cluster_aat]
        Panlobular_emph -> CT_emph_bio [ltail=cluster_lung]
        ALT_AST -> Liver_bio [ltail=cluster_liver]
        Liver_stiffness -> Liver_bio [ltail=cluster_liver]
        Disease_sev -> Mortality
        Transplant -> Mortality [ltail=cluster_lung]
        Cirrhosis -> Mortality [ltail=cluster_liver]
        Lung_dom -> Disease_sev
        Liver_dom -> Disease_sev
        Combined_ph -> Disease_sev
        FEV1_stab -> Disease_sev [ltail=cluster_pd_outputs style=dashed color=green label="Treatment\nImprovement"]
        Liver_norm -> Disease_sev [ltail=cluster_pd_outputs style=dashed color=green]
    }

    /* Cross-cluster edges */
    ZZ_geno -> ZAAT_synth [ltail=cluster_genetics lhead=cluster_er label="Translation →\nMisfolded Z protein"]
    MM_geno -> MAAT_synth [ltail=cluster_genetics lhead=cluster_er label="Translation →\nNormal M protein"]
    ER_retention -> Hepatocyte_inj [lhead=cluster_liver label="Z-AAT polymer\ngain-of-toxicity"]
    MAAT_sec -> Plasma_AAT [ltail=cluster_aat label="Normal AAT\nPool"]
    ELF_AAT -> Fn_NE_inhib [ltail=cluster_aat label="ELF-AAT\nInhibits NE"]
    Fn_NE_inhib -> AAT_NE_cplx [ltail=cluster_aat lhead=cluster_protease label="Inhibitory\nActivity"]
    NE_active -> Elastin_deg [ltail=cluster_protease lhead=cluster_lung label="Unchecked\nproteolysis"]
    NE_active -> Airway_inflam [ltail=cluster_protease lhead=cluster_lung]
    IL8_lung -> Neutro_recruit [ltail=cluster_inflammation lhead=cluster_protease label="Recruits PMN"]
    LTB4_lung -> Neutro_recruit [ltail=cluster_inflammation lhead=cluster_protease]
}
