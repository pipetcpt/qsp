digraph ObesityQSP {

  graph [
    label = "Obesity QSP Mechanistic Map\nDrug Targets: GLP-1RA (Semaglutide) · Dual GIP/GLP-1RA (Tirzepatide) · Lipase Inhibitor (Orlistat) · CNS Agents (Phentermine/Topiramate · Naltrexone/Bupropion)"
    labelloc = t
    fontsize = 18
    fontname  = "Helvetica-Bold"
    rankdir   = LR
    bgcolor   = "#FAFAFA"
    pad       = 0.8
    nodesep   = 0.32
    ranksep   = 1.1
    splines   = ortho
    overlap   = false
  ]

  node [fontname="Helvetica" fontsize=9 style=filled shape=box width=1.4 height=0.45]
  edge [fontname="Helvetica" fontsize=7.5 arrowsize=0.65]

  // ─────────────────────────────────────────────────────────────────────
  // CLUSTER 1 — Hypothalamic Energy Regulation
  // ─────────────────────────────────────────────────────────────────────
  subgraph cluster_hypothalamus {
    label     = "① Hypothalamic Energy Regulation"
    style     = filled
    fillcolor = "#E8F0FE"
    color     = "#4285F4"
    penwidth  = 2.0

    ARC      [label="Arcuate Nucleus\n(ARC)" fillcolor="#4285F4" fontcolor=white]
    PVN      [label="Paraventricular\nNucleus (PVN)"  fillcolor="#4285F4" fontcolor=white]
    VMH      [label="Ventromedial\nHypothalamus (VMH)" fillcolor="#4285F4" fontcolor=white]
    LHA      [label="Lateral Hypothalamic\nArea (LHA)"  fillcolor="#4285F4" fontcolor=white]
    NTS      [label="Nucleus Tractus\nSolitarius (NTS)" fillcolor="#5C85D6"]

    NPY_N    [label="NPY/AgRP Neurons\n(Orexigenic)"   fillcolor="#FFF3E0"]
    POMC_N   [label="POMC/CART Neurons\n(Anorexigenic)" fillcolor="#E8F5E9"]
    MSH_P    [label="α-MSH Peptide\n(MC4R agonist)"   fillcolor="#E8F5E9"]
    AGRP_P   [label="AgRP Peptide\n(MC4R antagonist)" fillcolor="#FFF3E0"]
    MC4R     [label="Melanocortin-4\nReceptor (MC4R)" fillcolor="#C8E6C9"]
    CART_P   [label="CART Peptide\n(Anorexigenic)"    fillcolor="#E8F5E9"]

    LEPR_H   [label="Leptin Receptor\n(LepRb, ARC)"   fillcolor="#F3E5F5"]
    INSR_H   [label="Insulin Receptor\n(Brain)"        fillcolor="#F3E5F5"]
    GLP1R_H  [label="GLP-1 Receptor\n(Hypothalamus)"  fillcolor="#E1F5FE"]
    GIPR_H   [label="GIP Receptor\n(Hypothalamus)"    fillcolor="#E1F5FE"]
    GHSRL    [label="Ghrelin Receptor\n(GHSR1a, ARC)" fillcolor="#FFF9C4"]

    STAT3_H  [label="JAK2/STAT3\nSignaling (Leptin)"  fillcolor="#F3E5F5"]
    PI3K_H   [label="PI3K-Akt\n(Brain)"               fillcolor="#F3E5F5"]
    cAMP_H   [label="cAMP/PKA\n(Incretin Signaling)"  fillcolor="#E1F5FE"]

    FOOD_IN  [label="Food Intake\nRegulation" fillcolor="#FFEB3B" shape=diamond]
    EE_CTR   [label="Energy Expenditure\n(Central)" fillcolor="#FFEB3B" shape=diamond]
  }

  // ─────────────────────────────────────────────────────────────────────
  // CLUSTER 2 — Gut-Brain Axis & Incretin Hormones
  // ─────────────────────────────────────────────────────────────────────
  subgraph cluster_gut {
    label     = "② Gut–Brain Axis & Incretin Hormones"
    style     = filled
    fillcolor = "#FFF8E1"
    color     = "#F9A825"
    penwidth  = 2.0

    LCELLS   [label="Intestinal L-Cells\n(GLP-1 · PYY)" fillcolor="#F9A825" fontcolor=white]
    KCELLS   [label="Intestinal K-Cells\n(GIP)"          fillcolor="#F9A825" fontcolor=white]
    ICELLS   [label="I-Cells\n(CCK)"                     fillcolor="#F9A825" fontcolor=white]
    XCELLS   [label="X/A Cells\n(Ghrelin, Stomach)"      fillcolor="#F9A825" fontcolor=white]

    GLP1_G   [label="Active GLP-1\nt½ ≈ 2 min (plasma)" fillcolor="#FFF3E0"]
    GIP_G    [label="Active GIP\nt½ ≈ 5 min (plasma)"   fillcolor="#FFF3E0"]
    PYY_G    [label="PYY3-36\n(Appetite ↓)"              fillcolor="#FFF3E0"]
    CCK_G    [label="Cholecystokinin\n(CCK)"             fillcolor="#FFF3E0"]
    GHRELIN  [label="Active Ghrelin\n(Appetite ↑)"       fillcolor="#FFFDE7"]

    DPP4     [label="DPP-4 Enzyme\n(GLP-1/GIP Cleavage)" fillcolor="#FFCCBC"]

    VAGUS    [label="Vagus Nerve\n(Afferent → NTS)"       fillcolor="#FFE0B2"]
    GUT_MIC  [label="Gut Microbiome\n(SCFA production)"   fillcolor="#FFF9C4"]
    SCFA     [label="Short-Chain\nFatty Acids (SCFA)"     fillcolor="#FFF9C4"]
    BILE     [label="Bile Acids\n(TGR5/FXR Signaling)"    fillcolor="#FFF9C4"]
    TGR5     [label="TGR5 Receptor\n(L-cell GLP-1↑)"      fillcolor="#FFF9C4"]
    FXR      [label="FXR\n(Bile Acid Sensor)"             fillcolor="#FFF9C4"]

    GAS_EMP  [label="Gastric Emptying\nRate (↓ by GLP-1)" fillcolor="#FFE0B2" shape=diamond]
    SATIETY  [label="Satiety\nSignaling"                   fillcolor="#FFEB3B" shape=diamond]
  }

  // ─────────────────────────────────────────────────────────────────────
  // CLUSTER 3 — Adipose Tissue Biology
  // ─────────────────────────────────────────────────────────────────────
  subgraph cluster_adipose {
    label     = "③ Adipose Tissue Biology"
    style     = filled
    fillcolor = "#FCE4EC"
    color     = "#E91E63"
    penwidth  = 2.0

    WAT      [label="White Adipose\nTissue (WAT)"          fillcolor="#E91E63" fontcolor=white]
    BAT      [label="Brown Adipose\nTissue (BAT)"          fillcolor="#AD1457" fontcolor=white]
    BEIGE    [label="Beige/Brite\nAdipocytes (WAT)"        fillcolor="#F48FB1"]
    VISC     [label="Visceral\nAdipose (VAT)"              fillcolor="#C2185B" fontcolor=white]
    SUBCUT   [label="Subcutaneous\nAdipose (SAT)"          fillcolor="#E91E63" fontcolor=white]

    PPARg    [label="PPARγ\n(Master Adipogenic TF)"        fillcolor="#FCE4EC"]
    CEBPa    [label="C/EBPα\n(Adipogenic TF)"              fillcolor="#FCE4EC"]
    SREBP1C  [label="SREBP-1c\n(Lipogenic TF)"             fillcolor="#FCE4EC"]
    ADIPOGEN [label="Adipogenesis\n(Differentiation)"      fillcolor="#FCE4EC"]

    HSL      [label="Hormone-Sensitive\nLipase (HSL)"      fillcolor="#FCE4EC"]
    ATGL     [label="Adipose TG\nLipase (ATGL)"            fillcolor="#FCE4EC"]
    FFA_A    [label="Free Fatty Acids\n(NEFA from adipose)" fillcolor="#F8BBD9"]
    GLYCEROL [label="Glycerol\nRelease"                    fillcolor="#F8BBD9"]
    FAS_E    [label="Fatty Acid\nSynthase (FAS)"           fillcolor="#FCE4EC"]
    ACC_E    [label="Acetyl-CoA\nCarboxylase (ACC)"        fillcolor="#FCE4EC"]

    LEPTIN   [label="Leptin\n(ob Gene Product)"            fillcolor="#F48FB1"]
    ADIPOQ   [label="Adiponectin\n(Anti-inflammatory)"     fillcolor="#F8BBD9"]
    RESISTIN [label="Resistin\n(Pro-inflammatory)"         fillcolor="#FFCCBC"]
    VISFATIN [label="Visfatin/NAMPT\n(Visceral marker)"    fillcolor="#FFCCBC"]
    RBP4     [label="RBP4\n(Insulin Resistance ↑)"         fillcolor="#FFCCBC"]

    UCP1     [label="UCP-1\n(Proton Uncoupling)"           fillcolor="#FFCCBC"]
    UCP3     [label="UCP-3\n(Muscle thermogen.)"           fillcolor="#FFCCBC"]
    THERMO   [label="Non-Shivering\nThermogenesis"         fillcolor="#FFCCBC" shape=diamond]

    ADIP_M   [label="Adipose Tissue\nMass (kg)"            fillcolor="#E91E63" fontcolor=white shape=diamond]
  }

  // ─────────────────────────────────────────────────────────────────────
  // CLUSTER 4 — Hepatic Metabolism
  // ─────────────────────────────────────────────────────────────────────
  subgraph cluster_liver {
    label     = "④ Hepatic Metabolism"
    style     = filled
    fillcolor = "#E8F5E9"
    color     = "#388E3C"
    penwidth  = 2.0

    HEPATO   [label="Hepatocytes"                          fillcolor="#388E3C" fontcolor=white]
    KUPFFER  [label="Kupffer Cells\n(Hepatic Macrophages)" fillcolor="#E8F5E9"]

    GLUCO_HEP [label="Gluconeogenesis\n(PEPCK, G6Pase)"   fillcolor="#E8F5E9"]
    GLYCS_HEP [label="Glycogen Synthesis\n(GS enzyme)"    fillcolor="#E8F5E9"]
    GLYCOL_H  [label="Glycogenolysis\n(Glycogen Phosph.)" fillcolor="#E8F5E9"]

    HEPTG    [label="Hepatic TG\nSynthesis (DNL)"          fillcolor="#E8F5E9"]
    VLDL_SEC [label="VLDL\nSecretion"                      fillcolor="#C8E6C9"]
    BETA_OX  [label="β-Oxidation\n(FAO)"                   fillcolor="#E8F5E9"]

    GLP1R_L  [label="GLP-1 Receptor\n(Liver, portal)"      fillcolor="#E1F5FE"]
    INSR_L   [label="Insulin Receptor\n(Liver)"            fillcolor="#E8F5E9"]
    FOXO1    [label="FOXO1\n(Gluconeogenesis ↑)"           fillcolor="#FFCCBC"]
    AMPK_L   [label="AMPK\n(Liver Energy Sensor)"          fillcolor="#E8F5E9"]
    SIRT1_L  [label="SIRT1/PGC-1α\n(Liver FAO↑)"          fillcolor="#E8F5E9"]

    HSTEAT   [label="Hepatic Steatosis\nGrade (0–3)"       fillcolor="#FF8A65" shape=diamond]
    HGP      [label="Hepatic Glucose\nProduction (EGP)"    fillcolor="#FFEB3B" shape=diamond]

    CHOL_S   [label="Cholesterol Synth.\n(HMG-CoA Red.)"  fillcolor="#E8F5E9"]
    LDLR     [label="LDL Receptor\n(Liver)"               fillcolor="#E8F5E9"]
    APOB100  [label="ApoB-100\n(VLDL structural)"         fillcolor="#E8F5E9"]
    APOE     [label="ApoE\n(Lipoprotein clearance)"       fillcolor="#E8F5E9"]
    HDLPROD  [label="ApoA-I/HDL\nProduction (Liver)"      fillcolor="#E8F5E9"]
  }

  // ─────────────────────────────────────────────────────────────────────
  // CLUSTER 5 — Pancreatic Endocrine Function
  // ─────────────────────────────────────────────────────────────────────
  subgraph cluster_pancreas {
    label     = "⑤ Pancreatic Endocrine Function"
    style     = filled
    fillcolor = "#E0F7FA"
    color     = "#0097A7"
    penwidth  = 2.0

    BETA_C   [label="Pancreatic β-Cells\n(Insulin Secretion)" fillcolor="#0097A7" fontcolor=white]
    ALPHA_C  [label="Pancreatic α-Cells\n(Glucagon)"          fillcolor="#00838F" fontcolor=white]
    DELTA_C  [label="δ-Cells\n(Somatostatin)"                 fillcolor="#E0F7FA"]

    KATP     [label="K_ATP Channels\n(Glucose Sensing)"       fillcolor="#E0F7FA"]
    GLP1R_P  [label="GLP-1R (β-Cell)\n(Incretin target)"      fillcolor="#E1F5FE"]
    GIPR_P   [label="GIPR (β-Cell)\n(Incretin target)"        fillcolor="#E1F5FE"]
    GLUT2    [label="GLUT2\n(β-Cell Glucose Import)"          fillcolor="#E0F7FA"]

    INS_SEC  [label="Insulin Secretion\n(GSIS + Incretin)"    fillcolor="#E0F7FA"]
    GLUCAGON [label="Glucagon\n(EGP ↑)"                       fillcolor="#E0F7FA"]
    SOMAT    [label="Somatostatin\n(Inhibits Ins/Glucagon)"    fillcolor="#E0F7FA"]

    INSULIN  [label="Plasma Insulin\n[I] (μU/mL)"             fillcolor="#0097A7" fontcolor=white shape=diamond]

    BETA_M   [label="β-Cell Mass\n& Secretory Function"       fillcolor="#80DEEA"]
    BETA_PR  [label="β-Cell Proliferation\n(GLP-1 → ↑)"      fillcolor="#E0F7FA"]
    BETA_AP  [label="β-Cell Apoptosis\n(Glucolipotoxicity ↑)" fillcolor="#FFCCBC"]

    CPEPTIDE [label="C-Peptide\n(Endogenous INS marker)"      fillcolor="#E0F7FA"]
    PROINSULIN [label="Proinsulin\n(β-Cell Stress marker)"    fillcolor="#E0F7FA"]
  }

  // ─────────────────────────────────────────────────────────────────────
  // CLUSTER 6 — Skeletal Muscle & Insulin Resistance
  // ─────────────────────────────────────────────────────────────────────
  subgraph cluster_muscle {
    label     = "⑥ Skeletal Muscle & Peripheral Insulin Resistance"
    style     = filled
    fillcolor = "#FFF3E0"
    color     = "#E65100"
    penwidth  = 2.0

    MUSCLE   [label="Skeletal Muscle\n(~40% body mass)"   fillcolor="#E65100" fontcolor=white]

    INSR_M   [label="Insulin Receptor\n(Muscle)"          fillcolor="#FFF3E0"]
    IRS1     [label="IRS-1\n(Insulin Signaling Hub)"      fillcolor="#FFF3E0"]
    PI3K_M   [label="PI3K-Akt\n(Muscle)"                  fillcolor="#FFF3E0"]
    GLUT4    [label="GLUT4\nTranslocation"                fillcolor="#FFF3E0"]
    AS160    [label="AS160/TBC1D4\n(GLUT4 Tethering)"    fillcolor="#FFF3E0"]

    GLUC_UP  [label="Glucose Uptake\n(Muscle)"            fillcolor="#FFF3E0" shape=diamond]
    GLYC_M   [label="Glycogen Synthesis\n(Muscle)"        fillcolor="#FFF3E0"]
    GLYCOLYS [label="Glycolysis\n(ATP generation)"        fillcolor="#FFF3E0"]

    IMCL     [label="Intramyocellular\nLipid (IMCL)"      fillcolor="#FFCCBC"]
    CERAMIDE [label="Ceramide\n(DAG, Lipotoxicity)"       fillcolor="#FFCCBC"]
    PKCE_M   [label="PKCε/θ\n(IRS-1 Ser307 Phosph.)"     fillcolor="#FFCCBC"]
    DIACYLG  [label="Diacylglycerol\n(DAG)"               fillcolor="#FFCCBC"]

    MITO_M   [label="Mitochondrial\nFunction & ETC"       fillcolor="#FFF3E0"]
    PGC1A    [label="PGC-1α\n(Mito. Biogenesis)"          fillcolor="#FFF3E0"]
    AMPK_M   [label="AMPK\n(Muscle Energy Sensor)"        fillcolor="#FFF3E0"]
    MYOKINE  [label="Myokines (IL-6, FNDC5)\n(Exercise)"  fillcolor="#FFF3E0"]
    IRISIN   [label="Irisin\n(WAT→BAT Browning)"          fillcolor="#FFF3E0"]

    IR_M     [label="Skeletal Muscle\nInsulin Resistance"  fillcolor="#E65100" fontcolor=white shape=diamond]
    REE      [label="Resting Energy\nExpenditure (REE)"    fillcolor="#FFEB3B" shape=diamond]
  }

  // ─────────────────────────────────────────────────────────────────────
  // CLUSTER 7 — Drug PK/PD
  // ─────────────────────────────────────────────────────────────────────
  subgraph cluster_drugs {
    label     = "⑦ Drug PK/PD — Semaglutide · Tirzepatide · Orlistat · CNS Agents"
    style     = filled
    fillcolor = "#EDE7F6"
    color     = "#5E35B1"
    penwidth  = 2.0

    // Semaglutide
    SEMA_D   [label="Semaglutide\nSC Depot (nmol)"         fillcolor="#7E57C2" fontcolor=white]
    SEMA_C   [label="Semaglutide\nPlasma [Cp] (nmol/L)"    fillcolor="#7E57C2" fontcolor=white]
    SEMA_R   [label="Sema→GLP-1R\nTarget Engagement (%)"   fillcolor="#9575CD"]

    // Tirzepatide
    TIRZ_D   [label="Tirzepatide\nSC Depot (nmol)"         fillcolor="#5E35B1" fontcolor=white]
    TIRZ_C   [label="Tirzepatide\nPlasma [Cp] (nmol/L)"    fillcolor="#5E35B1" fontcolor=white]
    TIRZ_G1  [label="Tirz→GLP-1R\nEngagement (%)"          fillcolor="#7E57C2"]
    TIRZ_GIP [label="Tirz→GIPR\nEngagement (%)"            fillcolor="#7E57C2"]

    // Orlistat
    ORL_GUT  [label="Orlistat\nGut Lumen (mg)"             fillcolor="#9C27B0" fontcolor=white]
    ORL_LIP  [label="Gastric/Pancreatic\nLipase Inhibition" fillcolor="#CE93D8"]
    FAT_ABS  [label="Dietary Fat\nAbsorption (% of intake)" fillcolor="#CE93D8" shape=diamond]

    // Phentermine + Topiramate
    PHENT_C  [label="Phentermine\nPlasma (ng/mL)"          fillcolor="#8E24AA" fontcolor=white]
    TOPI_C   [label="Topiramate\nPlasma (μg/mL)"           fillcolor="#8E24AA" fontcolor=white]
    NE_REL   [label="Norepinephrine\nRelease (CNS ↑)"      fillcolor="#CE93D8"]
    GABA_ENH [label="GABA-A Receptor\nEnhancement"         fillcolor="#CE93D8"]

    // Naltrexone + Bupropion
    NALTX_C  [label="Naltrexone\nPlasma (ng/mL)"           fillcolor="#6A1B9A" fontcolor=white]
    BUPR_C   [label="Bupropion\nPlasma (ng/mL)"            fillcolor="#6A1B9A" fontcolor=white]
    OPRM_BLK [label="μ-Opioid Receptor\nBlockade (NAL)"    fillcolor="#CE93D8"]
    DAT_NET  [label="DAT/NET Inhibition\n(Bupropion)"      fillcolor="#CE93D8"]

    PD_WT    [label="PD Weight\nEffect Magnitude (%)"      fillcolor="#5E35B1" fontcolor=white shape=diamond]
  }

  // ─────────────────────────────────────────────────────────────────────
  // CLUSTER 8 — Adipose Tissue Inflammation
  // ─────────────────────────────────────────────────────────────────────
  subgraph cluster_inflammation {
    label     = "⑧ Adipose Inflammation & Immune Dysregulation"
    style     = filled
    fillcolor = "#FFEBEE"
    color     = "#C62828"
    penwidth  = 2.0

    ATM      [label="Adipose Tissue\nMacrophages (ATM)"    fillcolor="#C62828" fontcolor=white]
    M1_MAC   [label="M1 Macrophages\n(Pro-inflammatory)"   fillcolor="#EF9A9A"]
    M2_MAC   [label="M2 Macrophages\n(Anti-inflammatory)"  fillcolor="#A5D6A7"]
    CROWN    [label="Crown-Like Structures\n(CLS, dead adipocytes)" fillcolor="#FFCCBC"]

    TNF_A    [label="TNF-α\n(IR ↑, Adiponectin ↓)"        fillcolor="#EF9A9A"]
    IL6_A    [label="IL-6\n(Systemic Inflammation)"        fillcolor="#EF9A9A"]
    IL1B_A   [label="IL-1β\n(NLRP3 Inflammasome)"         fillcolor="#EF9A9A"]
    MCP1     [label="MCP-1/CCL2\n(Macrophage Recruit.)"   fillcolor="#EF9A9A"]
    IL10_A   [label="IL-10\n(Anti-inflammatory)"           fillcolor="#A5D6A7"]
    IL4_A    [label="IL-4/IL-13\n(M2 Polarization)"       fillcolor="#A5D6A7"]

    NLRP3    [label="NLRP3 Inflammasome\n(Activation)"    fillcolor="#EF9A9A"]
    NF_KB    [label="NF-κB\n(Master Inflammatory TF)"     fillcolor="#EF9A9A"]
    JNK1     [label="JNK1\n(IRS-1 Ser307 Phosph.)"        fillcolor="#EF9A9A"]
    IKK_B   [label="IKKβ\n(NF-κB Activator)"              fillcolor="#EF9A9A"]
    TLR4     [label="TLR4\n(FFA/LPS Pattern Recog.)"      fillcolor="#EF9A9A"]

    CRP_S    [label="hsCRP\n(Systemic Marker)"             fillcolor="#FFCCBC" shape=diamond]
    INFLAM_I [label="Inflammation\nIndex (composite)"      fillcolor="#C62828" fontcolor=white shape=diamond]
  }

  // ─────────────────────────────────────────────────────────────────────
  // CLUSTER 9 — Glucose & Energy Homeostasis
  // ─────────────────────────────────────────────────────────────────────
  subgraph cluster_glucose {
    label     = "⑨ Glucose & Energy Homeostasis"
    style     = filled
    fillcolor = "#F9FBE7"
    color     = "#827717"
    penwidth  = 2.0

    GLUCOSE  [label="Plasma Glucose\n[G] (mg/dL)"         fillcolor="#827717" fontcolor=white shape=diamond]
    HBA1C    [label="HbA1c\n(%)"                          fillcolor="#AFB42B" shape=diamond]

    EGP_F    [label="Endogenous Glucose\nProduction (EGP)" fillcolor="#F9FBE7"]
    GUT_ABS  [label="Gut Glucose\nAbsorption Rate"        fillcolor="#F9FBE7"]
    RAGLUC   [label="Peripheral Glucose\nDisposal (Rd)"   fillcolor="#F9FBE7"]
    URINE_G  [label="Urinary Glucose\nExcretion (SGLT2)"  fillcolor="#F9FBE7"]

    HOMA_IR  [label="HOMA-IR\n(Insulin Resistance Index)" fillcolor="#FFEB3B" shape=diamond]
    HOMA_B   [label="HOMA-β\n(β-Cell Function Index)"     fillcolor="#FFEB3B" shape=diamond]

    E_INTAKE [label="Energy Intake\n(kcal/day)"           fillcolor="#FFEB3B" shape=diamond]
    E_EXPEND [label="Total Energy\nExpenditure (TEE)"     fillcolor="#FFEB3B" shape=diamond]
    E_BALANC [label="Energy Balance\n(kcal/day, neg=loss)" fillcolor="#827717" fontcolor=white shape=diamond]

    PAL      [label="Physical Activity\nLevel (PAL)"      fillcolor="#F9FBE7"]
    DIT      [label="Diet-Induced\nThermogenesis (DIT)"   fillcolor="#F9FBE7"]
  }

  // ─────────────────────────────────────────────────────────────────────
  // CLUSTER 10 — Lipid Metabolism & Dyslipidemia
  // ─────────────────────────────────────────────────────────────────────
  subgraph cluster_lipids {
    label     = "⑩ Lipid Metabolism & Atherogenic Dyslipidemia"
    style     = filled
    fillcolor = "#E8EAF6"
    color     = "#283593"
    penwidth  = 2.0

    TRIG_P   [label="Plasma TG\n(mg/dL)"                  fillcolor="#283593" fontcolor=white shape=diamond]
    LDL_C    [label="LDL-C\n(mg/dL)"                      fillcolor="#3F51B5" fontcolor=white shape=diamond]
    HDL_C    [label="HDL-C\n(mg/dL)"                      fillcolor="#5C6BC0" shape=diamond]
    APOB_P   [label="ApoB\n(Atherogenic Particles)"       fillcolor="#E8EAF6" shape=diamond]
    SDLDL    [label="Small Dense LDL\n(sdLDL)"            fillcolor="#E8EAF6" shape=diamond]

    VLDL_P   [label="VLDL Particle\n(TG-rich)"            fillcolor="#E8EAF6"]
    IDL_P    [label="IDL\n(VLDL Remnant)"                 fillcolor="#E8EAF6"]
    LPL_E    [label="LPL\n(TG Hydrolysis)"                fillcolor="#E8EAF6"]
    CETP_E   [label="CETP\n(CE Transfer)"                 fillcolor="#E8EAF6"]
    LCAT     [label="LCAT\n(HDL Maturation)"              fillcolor="#E8EAF6"]

    ECTOP_F  [label="Ectopic Fat\nDeposition (muscle/liver)" fillcolor="#FFCCBC"]
    PERICARD [label="Pericardial/\nEpicardial Fat"          fillcolor="#FFCCBC"]
    PANCREAT_F [label="Pancreatic Fat\n(β-cell Lipotox.)"   fillcolor="#FFCCBC"]
  }

  // ─────────────────────────────────────────────────────────────────────
  // CLUSTER 11 — Clinical Endpoints & Cardiovascular Risk
  // ─────────────────────────────────────────────────────────────────────
  subgraph cluster_endpoints {
    label     = "⑪ Clinical Endpoints & Cardiometabolic Risk"
    style     = filled
    fillcolor = "#F1F8E9"
    color     = "#33691E"
    penwidth  = 2.0

    BMI      [label="BMI\n(kg/m²)"                        fillcolor="#33691E" fontcolor=white shape=diamond]
    BWT      [label="Body Weight\n(kg)"                   fillcolor="#33691E" fontcolor=white shape=diamond]
    WAIST_C  [label="Waist Circumference\n(cm)"           fillcolor="#33691E" fontcolor=white shape=diamond]
    BODY_FAT [label="Body Fat %\n(DEXA/BIA)"              fillcolor="#558B2F" shape=diamond]
    LEAN_M   [label="Lean Body Mass\n(kg)"                fillcolor="#558B2F" shape=diamond]

    SBP      [label="Systolic BP\n(mmHg)"                 fillcolor="#F1F8E9" shape=diamond]
    DBP      [label="Diastolic BP\n(mmHg)"                fillcolor="#F1F8E9" shape=diamond]
    HR       [label="Heart Rate\n(bpm)"                   fillcolor="#F1F8E9" shape=diamond]

    MACE     [label="MACE Risk\n(MI/Stroke/CV Death)"     fillcolor="#FF6F00" fontcolor=white shape=diamond]
    ASCVD    [label="10-yr ASCVD Risk\n(Pooled Cohort)"   fillcolor="#FF6F00" fontcolor=white shape=diamond]

    NASH_S   [label="NASH Activity\nScore (NAS 0–8)"      fillcolor="#F1F8E9" shape=diamond]
    OSA_AHI  [label="Apnea-Hypopnea\nIndex (AHI)"         fillcolor="#F1F8E9" shape=diamond]
