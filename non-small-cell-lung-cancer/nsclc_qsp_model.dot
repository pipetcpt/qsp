digraph NSCLC_QSP {
    rankdir=LR;
    splines=curved;
    fontname="Helvetica";
    fontsize=10;
    node [fontname="Helvetica", fontsize=9, style=filled, shape=box];
    edge [fontsize=8];

    /* =========================================================
       CLUSTER 1: Driver Mutations & Oncogenic Signaling
    ========================================================= */
    subgraph cluster_oncogene {
        label="Driver Mutations & Oncogenic Signaling";
        style=filled;
        color=red;
        fillcolor="#FFE0E0";
        fontcolor=darkred;
        fontsize=11;
        node [fillcolor="#FF9999", color=red];

        EGFR_activating   [label="EGFR Activating\n(ex19del, L858R)"];
        KRAS_G12C         [label="KRAS G12C"];
        KRAS_G12D         [label="KRAS G12D"];
        ALK_fusion        [label="ALK Fusion\n(EML4-ALK)"];
        ROS1_fusion       [label="ROS1 Fusion"];
        BRAF_V600E        [label="BRAF V600E"];
        MET_exon14        [label="MET Exon14 Skip"];
        HER2_mut          [label="HER2 Mutation\n(exon20ins)"];
        RET_fusion        [label="RET Fusion"];
        NTRK_fusion       [label="NTRK Fusion"];
        NRG1_fusion       [label="NRG1 Fusion"];
        PI3K_mut          [label="PIK3CA Mutation"];
        STK11_mut         [label="STK11/LKB1 Mut"];
        KEAP1_mut         [label="KEAP1 Mutation"];
        TP53_mut_onc      [label="TP53 Mutation"];
    }

    /* =========================================================
       CLUSTER 2: Core Oncogenic Signaling Pathways
    ========================================================= */
    subgraph cluster_signaling {
        label="Core Oncogenic Signaling Pathways";
        style=filled;
        color=orange;
        fillcolor="#FFF0D0";
        fontcolor=darkorange;
        fontsize=11;
        node [fillcolor="#FFCC88", color=darkorange];

        GRB2              [label="GRB2"];
        SOS               [label="SOS (GEF)"];
        RAS_GDP           [label="RAS-GDP\n(inactive)"];
        RAS_GTP           [label="RAS-GTP\n(active)"];
        RAF               [label="RAF (CRAF/BRAF)"];
        MEK1              [label="MEK1/2"];
        ERK1              [label="ERK1/2"];
        PI3K              [label="PI3K\n(p110/p85)"];
        PTEN              [label="PTEN\n(phosphatase)"];
        AKT               [label="AKT (pS473)"];
        mTOR_C1           [label="mTORC1"];
        mTOR_C2           [label="mTORC2"];
        S6K               [label="S6K1"];
        X4EBP1            [label="4E-BP1"];
        TSC1              [label="TSC1/TSC2\ncomplex"];
        Rheb              [label="Rheb GTPase"];
        IRS1              [label="IRS1/IRS2"];
        STAT3             [label="STAT3"];
        STAT1             [label="STAT1"];
        JAK1              [label="JAK1"];
        JAK2              [label="JAK2"];
        SRC               [label="SRC kinase"];
        FAK               [label="FAK"];
        PIP2              [label="PIP2"];
        PIP3              [label="PIP3"];
        PDK1              [label="PDK1"];
    }

    /* =========================================================
       CLUSTER 3: Tumor Biology & Hallmarks
    ========================================================= */
    subgraph cluster_tumor_biology {
        label="Tumor Biology & Hallmarks";
        style=filled;
        color=darkorange;
        fillcolor="#FFE8CC";
        fontcolor="#7A3900";
        fontsize=11;
        node [fillcolor="#FFBB66", color=darkorange];

        HIF1a             [label="HIF-1α"];
        VEGF              [label="VEGF-A"];
        Angiogenesis      [label="Angiogenesis"];
        EMT_TF            [label="EMT Transcription\nFactors (SNAI/ZEB)"];
        Vimentin          [label="Vimentin"];
        E_Cadherin_loss   [label="E-Cadherin Loss"];
        N_Cadherin        [label="N-Cadherin"];
        MMP2              [label="MMP-2"];
        MMP9              [label="MMP-9"];
        ECM_degradation   [label="ECM Degradation"];
        MYC               [label="c-MYC"];
        CDK4              [label="CDK4"];
        CDK6              [label="CDK6"];
        Cyclin_D1         [label="Cyclin D1"];
        RB1               [label="RB1 (pRb)"];
        E2F               [label="E2F\nTranscription"];
        p53_mut           [label="p53 (mutant)"];
        MDM2              [label="MDM2"];
        BCL2              [label="BCL-2"];
        BCL_XL            [label="BCL-XL"];
        BAX               [label="BAX/BAK"];
        Caspase9          [label="Caspase-9"];
        Apoptosis_block   [label="Apoptosis Block"];
        TERT              [label="TERT\n(Telomerase)"];
        Telomere_maint    [label="Telomere\nMaintenance"];
        NRF2              [label="NRF2"];
        Autophagy         [label="Autophagy"];
        AMPK              [label="AMPK"];
    }

    /* =========================================================
       CLUSTER 4: Tumor Immune Evasion / Immune Checkpoint
    ========================================================= */
    subgraph cluster_immune_checkpoint {
        label="Tumor Immune Evasion & Checkpoint";
        style=filled;
        color=steelblue;
        fillcolor="#D0E8FF";
        fontcolor=darkblue;
        fontsize=11;
        node [fillcolor="#88BBFF", color=steelblue];

        PD_L1_tumor       [label="PD-L1 (CD274)\non Tumor"];
        PD_1_T_cell       [label="PD-1 on\nT cell"];
        CTLA4             [label="CTLA-4"];
        B7_1              [label="B7-1 (CD80)"];
        B7_2              [label="B7-2 (CD86)"];
        CD28              [label="CD28\n(T cell costim)"];
        CD8_T_cell        [label="CD8+ T cell\n(Cytotoxic)"];
        NK_cell           [label="NK Cell"];
        Treg              [label="Treg (CD4+FOXP3+)"];
        M2_macro          [label="M2 Macrophage\n(TAM)"];
        IDO1              [label="IDO1\n(Trp catabolism)"];
        TGFb_immune       [label="TGF-β\n(Immunosuppressive)"];
        IFN_gamma         [label="IFN-γ"];
        MHC_I             [label="MHC Class I"];
        Beta2M            [label="β2-Microglobulin"];
        JAK_STAT_IFN      [label="JAK/STAT\n(IFN signaling)"];
        CXCL9             [label="CXCL9"];
        CXCL10            [label="CXCL10"];
        TMB               [label="TMB (Tumor\nMutational Burden)"];
        MSI_H             [label="MSI-H /\ndMMR"];
        TIL_density       [label="TIL Density"];
        LAG3              [label="LAG-3"];
        TIM3              [label="TIM-3"];
        TIGIT             [label="TIGIT"];
        IL2               [label="IL-2"];
        IL6               [label="IL-6"];
        TNFa              [label="TNF-α"];
    }

    /* =========================================================
       CLUSTER 5: Drug PK/PD
    ========================================================= */
    subgraph cluster_drug_pkpd {
        label="Drug PK/PD (Targeted + Immuno + Chemo)";
        style=filled;
        color=darkgreen;
        fillcolor="#D0FFD8";
        fontcolor=darkgreen;
        fontsize=11;
        node [fillcolor="#88DD99", color=darkgreen];

        /* EGFR TKI (osimertinib) */
        Abs_EGFR_TKI      [label="EGFR TKI Oral\nAbsorption (Gut)"];
        EGFR_TKI_plasma   [label="EGFR TKI\nPlasma (Cp)"];
        EGFR_TKI_tissue   [label="EGFR TKI\nTissue (Ct)"];
        EGFR_TKI_elim     [label="EGFR TKI\nElimination (CYP3A4)"];
        EGFR_TKI_bound    [label="EGFR-TKI\nBound Complex"];

        /* ALK inhibitor (alectinib) */
        Abs_ALK_inh       [label="ALK Inh Oral\nAbsorption"];
        ALK_inh_plasma    [label="ALK Inh\nPlasma (Cp)"];
        ALK_inh_tissue    [label="ALK Inh\nTissue (Ct)"];
        ALK_inh_elim      [label="ALK Inh\nElimination"];
        ALK_inh_bound     [label="ALK-Inhibitor\nBound Complex"];

        /* KRAS G12C inhibitor (sotorasib) */
        Abs_KRAS_inh      [label="KRAS G12C Inh\nOral Absorption"];
        KRAS_inh_plasma   [label="KRAS G12C Inh\nPlasma (Cp)"];
        KRAS_inh_target   [label="KRAS G12C Inh\nTarget Tissue"];
        KRAS_inh_elim     [label="KRAS G12C Inh\nElimination"];
        KRAS_inh_bound    [label="KRAS G12C-Inh\nCovalent Complex"];

        /* PD-1 inhibitor (pembrolizumab) IV */
        IV_PD1            [label="Pembrolizumab\nIV Dose"];
        PD1_inh_plasma    [label="Pembro\nPlasma (Cp)"];
        PD1_inh_elim      [label="Pembro\nElimination (FcRn)"];
        PD1_target_binding [label="PD1:Pembro\nBound Complex"];

        /* PD-L1 inhibitor (atezolizumab) IV */
        IV_PDL1           [label="Atezolizumab\nIV Dose"];
        PDL1_inh_plasma   [label="Atezo\nPlasma (Cp)"];
        PDL1_inh_elim     [label="Atezo\nElimination"];
        PDL1_bound        [label="PDL1:Atezo\nBound Complex"];

        /* Platinum chemotherapy (carboplatin) */
        IV_plat           [label="Platinum\nIV Dose (AUC dosing)"];
        Plat_plasma       [label="Platinum\nPlasma (Free Pt)"];
        Plat_tissue       [label="Platinum\nTissue Distribution"];
        Plat_elim         [label="Platinum\nRenal Elimination"];
        DNA_adducts       [label="Pt-DNA Adducts\n(Crosslinks)"];

        /* Pemetrexed */
        Abs_pem           [label="Pemetrexed\nIV Dose"];
        Pem_plasma        [label="Pemetrexed\nPlasma (Cp)"];
        Pem_tissue        [label="Pemetrexed\nTissue (polyglut)"];
        Pem_elim          [label="Pemetrexed\nRenal Elimination"];
        DHFR_inh          [label="DHFR Inhibition\n(Folate pathway)"];
        TS_inh            [label="TS Inhibition\n(dTMP synthesis)"];
    }

    /* =========================================================
       CLUSTER 6: Drug Resistance Mechanisms
    ========================================================= */
    subgraph cluster_resistance {
        label="Drug Resistance Mechanisms";
        style=filled;
        color=crimson;
        fillcolor="#FFD0D8";
        fontcolor=darkred;
        fontsize=11;
        node [fillcolor="#FF8899", color=crimson];

        T790M_EGFR        [label="T790M EGFR\n(2nd gen resistance)"];
        C797S_EGFR        [label="C797S EGFR\n(3rd gen resistance)"];
        Amplification_bypass [label="Bypass Amplification"];
        MET_amplification [label="MET Amplification\n(bypass)"];
        HER2_amplification [label="HER2 Amplification\n(bypass)"];
        KRAS_secondary    [label="KRAS Secondary\nMutation"];
        EMT_resistance    [label="EMT-mediated\nResistance"];
        Small_cell_transform [label="Small Cell\nTransformation"];
        HistoneAc_change  [label="Epigenetic\n(Histone Ac change)"];
        BIM_deletion      [label="BIM Deletion\nPolymorphism"];
        Off_target_activ  [label="Off-target\nActivation"];
        MAPK_reactivation [label="MAPK\nReactivation"];
        AXL_upregul       [label="AXL Upregulation"];
        IGF1R_activ       [label="IGF1R Activation\n(bypass)"];
        FGFR_activ        [label="FGFR Activation\n(bypass)"];
        mTOR_resist       [label="mTOR\nReactivation"];
    }

    /* =========================================================
       CLUSTER 7: Clinical Biomarkers & Staging
    ========================================================= */
    subgraph cluster_biomarkers {
        label="Clinical Biomarkers & Staging";
        style=filled;
        color=purple;
        fillcolor="#EED8FF";
        fontcolor=purple;
        fontsize=11;
        node [fillcolor="#CC99FF", color=purple];

        PD_L1_TPS         [label="PD-L1 TPS\n(IHC score %)"];
        TMB_score         [label="TMB Score\n(mut/Mb)"];
        EGFR_ctDNA        [label="EGFR ctDNA\n(liquid biopsy)"];
        ALK_FISH          [label="ALK FISH /\nIHC / NGS"];
        KRAS_G12C_PCR     [label="KRAS G12C\nNGS / PCR"];
        MSI_status        [label="MSI / MMR\nstatus"];
        Tumor_size        [label="Tumor Size\n(CT, mm)"];
        SUV_PET           [label="SUV (PET-CT\nFDG uptake)"];
        CTC_count         [label="CTC Count\n(CircTumor Cells)"];
        CEA               [label="CEA\n(serum)"];
        CYFRA_211         [label="CYFRA 21-1\n(serum)"];
        NSE               [label="NSE\n(neuroendocrine)"];
        OS_months         [label="OS (median, mo)"];
        PFS_months        [label="PFS (median, mo)"];
        ORR_pct           [label="ORR (%)"];
        DCR_pct           [label="DCR (%)"];
        DLT_grade         [label="DLT Grade\n(CTCAE v5)"];
        NGS_panel         [label="NGS Panel\n(comprehensive)"];
        STK11_biomarker   [label="STK11/KEAP1\nBiomarker Status"];
    }

    /* =========================================================
       CLUSTER 8: Tumor Growth Dynamics & Treatment Response
    ========================================================= */
    subgraph cluster_tumor_dynamics {
        label="Tumor Growth Dynamics & Treatment Response";
        style=filled;
        color=darkgreen;
        fillcolor="#CCFFCC";
        fontcolor="#004400";
        fontsize=11;
        node [fillcolor="#66DD88", color=darkgreen];

        Tumor_volume_baseline [label="Tumor Volume\nBaseline (V0)"];
        Tumor_volume_t    [label="Tumor Volume\nat time t (V(t))"];
        Tumor_cells_sensitive [label="Sensitive\nTumor Cells (Cs)"];
        Tumor_cells_resistant [label="Resistant\nTumor Cells (Cr)"];
        Cell_growth_rate  [label="Net Growth Rate\n(kg - kd)"];
        Cell_kill_rate_TKI [label="TKI-mediated\nCell Kill (Emax)"];
        Cell_kill_rate_chemo [label="Chemo-mediated\nCell Kill"];
        Cell_kill_rate_immuno [label="Immuno-mediated\nCell Kill"];
        Tumor_shrinkage   [label="Tumor Shrinkage\n(RECIST)"];
        PR_response       [label="Partial Response\n(PR ≥30% shrink)"];
        SD_response       [label="Stable Disease\n(SD)"];
        PD_progression    [label="Progressive Disease\n(PD ≥20% growth)"];
        Nadir_volume      [label="Nadir Volume\n(minimum)"];
        Regrowth_phase    [label="Regrowth Phase\n(post-nadir)"];
        Gompertz_growth   [label="Gompertz Growth\nKinetics"];
        Carrying_capacity [label="Carrying Capacity\n(Vmax)"];
        Clonal_evolution  [label="Clonal Evolution\n(selection)"];
    }

    /* =========================================================
       CLUSTER 9: Drug Toxicity & Safety
    ========================================================= */
    subgraph cluster_toxicity {
        label="Drug Toxicity & Safety";
        style=filled;
        color=deeppink;
        fillcolor="#FFD8E8";
        fontcolor=darkred;
        fontsize=11;
        node [fillcolor="#FF99BB", color=deeppink];

        Rash_EGFR_TKI     [label="Acneiform Rash\n(EGFR TKI)"];
        Diarrhea_TKI      [label="Diarrhea\n(TKI, Grade 1-3)"];
        ILD_TKI           [label="ILD/Pneumonitis\n(TKI, ~3%)"];
        Pneumonitis_immuno [label="Immune Pneumonitis\n(irAE, ~5%)"];
        Colitis_immuno    [label="Immune Colitis\n(irAE)"];
        Nephritis_immuno  [label="Immune Nephritis\n(irAE)"];
        Neuropathy_plat   [label="Peripheral Neuropathy\n(Platinum)"];
        Nephrotox_plat    [label="Nephrotoxicity\n(Cisplatin, GFR↓)"];
        Myelosuppression_chemo [label="Myelosuppression\n(Chemo)"];
        ANC_nadir         [label="ANC Nadir\n(G-CSF trigger)"];
        Plt_nadir         [label="Platelet Nadir\n(thrombocytopenia)"];
        Hgb_drop          [label="Hemoglobin Drop\n(anemia)"];
        Hepatotox_TKI     [label="Hepatotoxicity\n(TKI, ALT/AST↑)"];
        QTc_prolongation  [label="QTc Prolongation\n(Vandetanib)"];
        Cardiac_irAE      [label="Cardiac irAE\n(myocarditis)"];
        Fatigue_tox       [label="Fatigue\n(systemic)"];
        Mucositis_pem     [label="Mucositis\n(Pemetrexed)"];
    }

    /* =========================================================
       CLUSTER 10: Clinical Endpoints & Outcomes
    ========================================================= */
    subgraph cluster_clinical_endpoints {
        label="Clinical Endpoints & Outcomes";
        style=filled;
        color=steelblue;
        fillcolor="#D8F0FF";
        fontcolor=darkblue;
        fontsize=11;
        node [fillcolor="#99DDFF", color=steelblue];

        Overall_Survival      [label="Overall Survival\n(OS)"];
        Progression_Free_Surv [label="Progression-Free\nSurvival (PFS)"];
        Objective_Response    [label="Objective Response\nRate (ORR)"];
        Disease_Control       [label="Disease Control\nRate (DCR)"];
        Duration_Response     [label="Duration of\nResponse (DoR)"];
        Time_to_Progression   [label="Time to\nProgression (TTP)"];
        ECOG_PS               [label="ECOG Performance\nStatus (0-4)"];
        QoL_score             [label="Quality of Life\n(FACT-L / EQ-5D)"];
        RECIST_CR             [label="RECIST CR\n(Complete Response)"];
        RECIST_PR             [label="RECIST PR\n(Partial Response)"];
        RECIST_SD             [label="RECIST SD\n(Stable Disease)"];
        RECIST_PD             [label="RECIST PD\n(Progression)"];
        Brain_metastasis      [label="Brain Metastasis\n(CNS)"];
        Bone_metastasis       [label="Bone Metastasis"];
        Stage_IIIA            [label="Stage IIIA\n(resectable)"];
        Stage_IIIB            [label="Stage IIIB\n(unresectable)"];
        Stage_IVA             [label="Stage IVA\n(1 met site)"];
        Stage_IVB             [label="Stage IVB\n(multiple mets)"];
        CNS_PFS               [label="CNS PFS\n(intracranial)"];
        Depth_of_Response     [label="Depth of Response\n(% max shrinkage)"];
    }

    /* =========================================================
       EDGES: CLUSTER 1 → CLUSTER 2 (Oncogene → Signaling)
    ========================================================= */
    EGFR_activating   -> GRB2         [label="receptor dimerize", color=red];
    EGFR_activating   -> PI3K         [label="direct p85 bind", color=red];
    EGFR_activating   -> JAK1         [label="transactivate", color=red];
    EGFR_activating   -> SRC          [label="activate SRC", color=red];
    HER2_mut          -> GRB2         [label="HER2/HER3 signal", color=red];
    HER2_mut          -> PI3K         [label="p110α activation", color=red];
    KRAS_G12C         -> RAS_GTP      [label="constitutive GTP", color=red, style=bold];
    KRAS_G12D         -> RAS_GTP      [label="constitutive GTP", color=red, style=bold];
    ALK_fusion        -> JAK1         [label="ALK→JAK", color=red];
    ALK_fusion        -> RAS_GTP      [label="ALK→RAS", color=red];
    ALK_fusion        -> PI3K         [label="ALK→PI3K", color=red];
    ROS1_fusion       -> PI3K         [label="ROS1→PI3K", color=red];
    ROS1_fusion       -> RAS_GTP      [label="ROS1→RAS", color=red];
    BRAF_V600E        -> MEK1         [label="direct MEK activ", color=red, style=bold];
    MET_exon14        -> GRB2         [label="MET scaffold", color=red];
    MET_exon14        -> PI3K         [label="MET→PI3K", color=red];
    RET_fusion        -> RAS_GTP      [label="RET→RAS", color=red];
    NTRK_fusion       -> RAS_GTP      [label="NTRK→RAS", color=red];
    PI3K_mut          -> PI3K         [label="activating mut", color=red];
    STK11_mut         -> AMPK         [label="loss of LKB1", color=red, style=dashed];
    KEAP1_mut         -> NRF2         [label="NRF2 stabilize", color=red];
    TP53_mut_onc      -> p53_mut      [label="dominant neg", color=red];

    /* CLUSTER 2 Internal Signaling Cascade */
    GRB2              -> SOS          [label="recruit", color=darkorange];
    SOS               -> RAS_GDP      [label="GEF exchange", color=darkorange];
    RAS_GDP           -> RAS_GTP      [label="GDP→GTP", color=darkorange];
    RAS_GTP           -> RAF          [label="recruit/activate", color=darkorange];
    RAF               -> MEK1         [label="phospho-MEK", color=darkorange];
    MEK1              -> ERK1         [label="phospho-ERK", color=darkorange];
    ERK1              -> MYC          [label="Myc stabilize", color=darkorange];
    ERK1              -> STAT3        [label="ERK→STAT3", color=darkorange];
    PI3K              -> PIP2         [label="PIP2→PIP3", color=darkorange, style=dashed];
    PIP2              -> PIP3         [label="PI3K phosph", color=darkorange];
    PTEN              -> PIP3         [label="PIP3 deplete", color=darkblue, style=dashed, arrowhead=tee];
    PIP3              -> PDK1         [label="recruit PDK1", color=darkorange];
    PDK1              -> AKT          [label="pT308", color=darkorange];
    mTOR_C2           -> AKT          [label="pS473", color=darkorange];
    AKT               -> TSC1         [label="inhibit TSC", color=darkorange, arrowhead=tee, style=dashed];
    AKT               -> MDM2         [label="MDM2 activ", color=darkorange];
    TSC1              -> Rheb         [label="GAP→Rheb-GDP", color=darkorange, arrowhead=tee, style=dashed];
    Rheb              -> mTOR_C1      [label="Rheb-GTP→mTOR", color=darkorange];
    mTOR_C1           -> S6K          [label="phospho-S6K", color=darkorange];
    mTOR_C1           -> X4EBP1       [label="phospho-4EBP1", color=darkorange];
    S6K               -> IRS1         [label="neg feedback", color=red, arrowhead=tee, style=dashed];
    IRS1              -> PI3K         [label="p85 bind", color=darkorange];
    JAK1              -> STAT3        [label="STAT3 pY705", color=darkorange];
    JAK2              -> STAT1        [label="STAT1 pY701", color=darkorange];
    JAK1              -> STAT1        [label="STAT1 activ", color=darkorange];
    SRC               -> FAK          [label="FAK pY397", color=darkorange];
    SRC               -> STAT3        [label="SRC→STAT3", color=darkorange];

    /* =========================================================
       EDGES: CLUSTER 2 → CLUSTER 3 (Signaling → Tumor Biology)
    ========================================================= */
    ERK1              -> CDK4         [label="cyclin induction", color=orange];
    ERK1              -> Cyclin_D1    [label="transcription", color=orange];
    AKT               -> BCL2         [label="survival signal", color=orange];
    AKT               -> BCL_XL       [label="antiapoptotic", color=orange];
    mTOR_C1           -> HIF1a        [label="HIF-1α transl", color=orange];
    STAT3             -> BCL2         [label="STAT3→BCL2", color=orange];
    STAT3             -> VEGF         [label="VEGF transcr", color=orange];
    STAT3             -> MYC          [label="c-Myc synergy", color=orange];
    MYC               -> CDK4         [label="CDK4 induce", color=orange];
    MYC               -> TERT         [label="TERT transcr", color=orange];
    HIF1a             -> VEGF         [label="VEGF-A upreg", color=darkorange, style=bold];
    VEGF              -> Angiogenesis [label="neovasc stimul", color=darkorange, style=bold];
    HIF1a             -> EMT_TF       [label="EMT induction", color=darkorange];
    EMT_TF            -> Vimentin     [label="Vim upreg", color=darkorange];
    EMT_TF            -> E_Cadherin_loss [label="E-cad repress", color=darkorange];
    EMT_TF            -> N_Cadherin   [label="N-cad upreg", color=darkorange];
    EMT_TF            -> MMP2         [label="MMP2 transcr", color=darkorange];
    EMT_TF            -> MMP9         [label="MMP9 transcr", color=darkorange];
    MMP2              -> ECM_degradation [label="collagen IV", color=darkorange];
    MMP9              -> ECM_degradation [label="gelatin degrad", color=darkorange];
    ECM_degradation   -> Angiogenesis [label="VEGF release", color=darkorange];
    CDK4              -> RB1          [label="pRb phosphoryl", color=orange, arrowhead=tee, style=dashed];
    CDK6              -> RB1          [label="pRb phosphoryl", color=orange, arrowhead=tee, style=dashed];
    Cyclin_D1         -> CDK4         [label="CDK4 activate", color=orange];
    Cyclin_D1         -> CDK6         [label="CDK6 activate", color=orange];
    RB1               -> E2F          [label="E2F release", color=orange];
    E2F               -> MYC          [label="Myc transcr", color=orange];
    MDM2              -> p53_mut      [label="MDM2→p53 degrad", color=orange, arrowhead=tee, style=dashed];
    p53_mut           -> MDM2         [label="p53→MDM2 (WT)", color=orange];
    BCL2              -> BAX          [label="BAX sequester", color=orange, arrowhead=tee, style=dashed];
    BCL_XL            -> Caspase9     [label="Casp9 inhibit", color=orange, arrowhead=tee, style=dashed];
    BAX               -> Caspase9     [label="cytoC release", color=orange];
    Caspase9          -> Apoptosis_block [label="blocked by BCL2", color=orange, arrowhead=tee, style=dashed];
    TERT              -> Telomere_maint [label="elongation", color=orange];
    AMPK              -> mTOR_C1      [label="mTOR inhibit", color=blue, arrowhead=tee, style=dashed];
    AMPK              -> Autophagy    [label="autophagy activ", color=blue];
    NRF2              -> Autophagy    [label="antioxidant prog", color=blue];

    /* =========================================================
       EDGES: CLUSTER 4 — Immune Evasion
    ========================================================= */
    IFN_gamma         -> JAK_STAT_IFN [label="JAK1/2 activ", color=steelblue];
    JAK_STAT_IFN      -> PD_L1_tumor  [label="PD-L1 upreg", color=steelblue, style=bold];
    JAK_STAT_IFN      -> MHC_I        [label="MHC-I upreg", color=steelblue];
    MHC_I             -> Beta2M       [label="β2M assoc", color=steelblue];
    PD_L1_tumor       -> PD_1_T_cell  [label="inhibit T cell", color=steelblue, arrowhead=tee, style=dashed];
    PD_1_T_cell       -> CD8_T_cell   [label="exhaust CTL", color=steelblue, arrowhead=tee, style=dashed];
    CTLA4             -> B7_1         [label="CTLA4 competes", color=steelblue, arrowhead=tee, style=dashed];
    CTLA4             -> B7_2         [label="CTLA4 competes", color=steelblue, arrowhead=tee, style=dashed];
    B7_1              -> CD28         [label="costim signal", color=steelblue];
    B7_2              -> CD28         [label="costim signal", color=steelblue];
    CD28              -> CD8_T_cell   [label="T cell activat", color=steelblue];
    CD8_T_cell        -> IFN_gamma    [label="IFN-γ secrete", color=steelblue];
    CD8_T_cell        -> TNFa         [label="TNF-α secrete", color=steelblue];
    NK_cell           -> IFN_gamma    [label="innate IFN-γ", color=steelblue];
    Treg              -> CD8_T_cell   [label="Treg suppress", color=steelblue, arrowhead=tee, style=dashed];
    Treg              -> TGFb_immune  [label="TGFβ secrete", color=steelblue];
    M2_macro          -> TGFb_immune  [label="TAM → TGFβ", color=steelblue];
    M2_macro          -> IL6          [label="IL-6 secrete", color=steelblue];
    IDO1              -> Treg         [label="Trp→Kyn expands Treg", color=steelblue];
    TGFb_immune       -> EMT_TF       [label="TGFβ→EMT", color=steelblue];
    TGFb_immune       -> Treg         [label="Treg expand", color=steelblue];
    CXCL9             -> CD8_T_cell   [label="CTL recruit", color=steelblue];
    CXCL10            -> CD8_T_cell   [label="CTL recruit", color=steelblue];
    IFN_gamma         -> CXCL9        [label="chemokine upreg", color=steelblue];
    IFN_gamma         -> CXCL10       [label="chemokine upreg", color=steelblue];
    IL6               -> STAT3        [label="IL6→JAK→STAT3", color=steelblue];
    IL2               -> CD8_T_cell   [label="IL-2 proliferat", color=steelblue];
    TMB               -> TIL_density  [label="neoAg → TIL", color=steelblue];
    MSI_H             -> TMB          [label="dMMR→high TMB", color=steelblue];
    LAG3              -> CD8_T_cell   [label="LAG3 suppress", arrowhead=tee, style=dashed, color=steelblue];
    TIM3              -> CD8_T_cell   [label="TIM3 exhaust", arrowhead=tee, style=dashed, color=steelblue];
    TIGIT             -> NK_cell      [label="TIGIT suppress NK", arrowhead=tee, style=dashed, color=steelblue];

    /* =========================================================
       EDGES: CLUSTER 5 — PK/PD Drug Flows
    ========================================================= */
    /* EGFR TKI PK */
    Abs_EGFR_TKI      -> EGFR_TKI_plasma  [label="ka (oral abs)", color=darkgreen];
    EGFR_TKI_plasma   -> EGFR_TKI_tissue  [label="Kp distribution", color=darkgreen];
    EGFR_TKI_plasma   -> EGFR_TKI_elim    [label="CL/F (CYP3A4)", color=darkgreen];
    EGFR_TKI_tissue   -> EGFR_TKI_bound   [label="kon (EGFR bind)", color=darkgreen];
    EGFR_TKI_bound    -> EGFR_activating   [label="EGFR inhibit", color=darkgreen, arrowhead=tee, style=dashed];

    /* ALK inhibitor PK */
    Abs_ALK_inh       -> ALK_inh_plasma    [label="ka absorption", color=darkgreen];
    ALK_inh_plasma    -> ALK_inh_tissue    [label="distribution", color=darkgreen];
    ALK_inh_plasma    -> ALK_inh_elim      [label="CL elimination", color=darkgreen];
    ALK_inh_tissue    -> ALK_inh_bound     [label="ALK binding", color=darkgreen];
    ALK_inh_bound     -> ALK_fusion        [label="ALK inhibit", color=darkgreen, arrowhead=tee, style=dashed];

    /* KRAS G12C inhibitor PK */
    Abs_KRAS_inh      -> KRAS_inh_plasma   [label="oral absorption", color=darkgreen];
    KRAS_inh_plasma   -> KRAS_inh_target   [label="tissue distribut", color=darkgreen];
    KRAS_inh_plasma   -> KRAS_inh_elim     [label="hepatic CL", color=darkgreen];
    KRAS_inh_target   -> KRAS_inh_bound    [label="covalent C12 bond", color=darkgreen, style=bold];
    KRAS_inh_bound    -> KRAS_G12C         [label="G12C lock GDP", color=darkgreen, arrowhead=tee, style=dashed];
    KRAS_inh_bound    -> RAS_GTP           [label="RAS-GTP block", color=darkgreen, arrowhead=tee, style=dashed];

    /* PD-1 inhibitor PK */
    IV_PD1            -> PD1_inh_plasma    [label="IV infusion", color=darkgreen];
    PD1_inh_plasma    -> PD1_inh_elim      [label="FcRn recycling/CL", color=darkgreen];
    PD1_inh_plasma    -> PD1_target_binding [label="PD1 occupy", color=darkgreen];
    PD1_target_binding -> PD_1_T_cell      [label="PD1 block", color=darkgreen, arrowhead=tee, style=dashed];

    /* PD-L1 inhibitor PK */
    IV_PDL1           -> PDL1_inh_plasma   [label="IV infusion", color=darkgreen];
    PDL1_inh_plasma   -> PDL1_inh_elim     [label="linear CL", color=darkgreen];
    PDL1_inh_plasma   -> PDL1_bound        [label="PDL1 occupy", color=darkgreen];
    PDL1_bound        -> PD_L1_tumor       [label="PDL1 block", color=darkgreen, arrowhead=tee, style=dashed];

    /* Platinum PK */
    IV_plat           -> Plat_plasma       [label="IV (AUC target)", color=darkgreen];
    Plat_plasma       -> Plat_tissue       [label="distribution Vd", color=darkgreen];
    Plat_plasma       -> Plat_elim         [label="GFR-dep renal CL", color=darkgreen];
    Plat_tissue       -> DNA_adducts       [label="Pt-DNA crosslink", color=darkgreen, style=bold];
    DNA_adducts       -> Caspase9          [label="DNA damage→apop", color=darkgreen];
    DNA_adducts       -> Apoptosis_block   [label="overcome BCL2", color=darkgreen, arrowhead=tee, style=dashed];

    /* Pemetrexed PK */
    Abs_pem           -> Pem_plasma        [label="IV bolus", color=darkgreen];
    Pem_plasma        -> Pem_tissue        [label="polyglutamation", color=darkgreen];
    Pem_plasma        -> Pem_elim          [label="renal elim ~70%", color=darkgreen];
    Pem_tissue        -> DHFR_inh          [label="DHFR compete", color=darkgreen, arrowhead=tee, style=dashed];
    Pem_tissue        -> TS_inh            [label="TS compete", color=darkgreen, arrowhead=tee, style=dashed];
    DHFR_inh          -> Caspase9          [label="nucleotide deplct", color=darkgreen];
    TS_inh            -> Caspase9          [label="dTMP deplete", color=darkgreen];

    /* Drug → signaling inhibition */
    EGFR_TKI_bound    -> RAS_GTP           [label="upstream block", color=green, arrowhead=tee, style=dashed];
    EGFR_TKI_bound    -> PI3K              [label="PI3K block", color=green, arrowhead=tee, style=dashed];
    EGFR_TKI_bound    -> STAT3             [label="STAT3 block", color=green, arrowhead=tee, style=dashed];
    ALK_inh_bound     -> RAS_GTP           [label="ALK-RAS block", color=green, arrowhead=tee, style=dashed];
    ALK_inh_bound     -> PI3K              [label="ALK-PI3K block", color=green, arrowhead=tee, style=dashed];

    /* =========================================================
       EDGES: CLUSTER 6 — Resistance
    ========================================================= */
    T790M_EGFR        -> EGFR_TKI_bound   [label="1st/2nd gen overcome", color=crimson, arrowhead=tee, style=dashed];
    C797S_EGFR        -> EGFR_TKI_bound   [label="3rd gen overcome", color=crimson, arrowhead=tee, style=dashed];
    MET_amplification -> GRB2             [label="bypass EGFR", color=crimson];
    MET_amplification -> PI3K             [label="bypass PI3K", color=crimson];
    HER2_amplification -> GRB2            [label="bypass signal", color=crimson];
    AXL_upregul       -> GRB2             [label="AXL bypass", color=crimson];
    IGF1R_activ       -> PI3K             [label="IGF1R bypass", color=crimson];
    FGFR_activ        -> RAS_GTP          [label="FGFR bypass", color=crimson];
    MAPK_reactivation -> MEK1             [label="MEK reactivate", color=crimson];
    mTOR_resist       -> mTOR_C1          [label="mTOR reactivate", color=crimson];
    EMT_resistance    -> Apoptosis_block  [label="EMT antiapoptosis", color=crimson];
    BIM_deletion      -> Apoptosis_block  [label="BIM loss", color=crimson];
    HistoneAc_change  -> EMT_resistance   [label="epigenetic EMT", color=crimson];
    Small_cell_transform -> p53_mut       [label="SCLC transform", color=crimson];
    KRAS_secondary    -> RAS_GTP          [label="RAS reactivate", color=crimson];
    Off_target_activ  -> RAS_GTP          [label="bypass mutations", color=crimson];
    Amplification_bypass -> RAS_GTP       [label="amplification", color=crimson];

    /* Resistance to specific drugs */
    T790M_EGFR        -> EGFR_activating  [label="T790M blocks gefitinib", color=crimson];
    C797S_EGFR        -> EGFR_activating  [label="C797S blocks osimertinib", color=crimson];
    KRAS_secondary    -> KRAS_G12C        [label="secondary KRAS mut", color=crimson];

    /* =========================================================
       EDGES: CLUSTER 7 — Biomarkers → Treatment Selection
    ========================================================= */
    PD_L1_tumor       -> PD_L1_TPS        [label="IHC measure", color=purple];
    TMB               -> TMB_score        [label="WES/panel calc", color=purple];
    EGFR_activating   -> EGFR_ctDNA       [label="ctDNA detect", color=purple];
    ALK_fusion        -> ALK_FISH         [label="FISH/IHC", color=purple];
    KRAS_G12C         -> KRAS_G12C_PCR    [label="NGS detect", color=purple];
    MSI_H             -> MSI_status       [label="MMR IHC", color=purple];
    Tumor_volume_t    -> Tumor_size       [label="RECIST meas", color=purple];
    Tumor_volume_t    -> SUV_PET          [label="metabolic activ", color=purple];
    PD_L1_TPS         -> IV_PD1           [label="TPS≥50% → pembro", color=purple, style=bold];
    PD_L1_TPS         -> IV_PDL1          [label="guide atezo use", color=purple];
    TMB_score         -> IV_PD1           [label="high TMB→IO", color=purple];
    EGFR_ctDNA        -> Abs_EGFR_TKI     [label="EGFR+ → TKI", color=purple, style=bold];
    ALK_FISH          -> Abs_ALK_inh      [label="ALK+ → alectinib", color=purple, style=bold];
    KRAS_G12C_PCR     -> Abs_KRAS_inh     [label="G12C+ → sotorasib", color=purple, style=bold];
    STK11_biomarker   -> PD_L1_TPS        [label="STK11 predicts IO resist", color=purple, style=dashed];
    NGS_panel         -> EGFR_ctDNA       [label="comprehensive NGS", color=purple];
    NGS_panel         -> KRAS_G12C_PCR    [label="panel NGS", color=purple];
    NGS_panel         -> ALK_FISH         [label="RNA fusion detect", color=purple];

    /* =========================================================
       EDGES: CLUSTER 8 — Tumor Dynamics
    ========================================================= */
    Cell_growth_rate  -> Tumor_volume_t   [label="dV/dt = kg*V", color=darkgreen];
    Gompertz_growth   -> Cell_growth_rate [label="Gompertz model", color=darkgreen];
    Carrying_capacity -> Gompertz_growth  [label="Vmax constraint", color=darkgreen];
    Tumor_volume_baseline -> Tumor_volume_t [label="V(0)=V0", color=darkgreen];
    Tumor_cells_sensitive -> Cell_growth_rate [label="sensitive pool", color=darkgreen];
    Tumor_cells_resistant -> Regrowth_phase   [label="resist expand", color=darkgreen, style=bold];
    Cell_kill_rate_TKI    -> Cell_growth_rate [label="TKI kill rate", color=darkgreen, arrowhead=tee, style=dashed];
    Cell_kill_rate_chemo  -> Cell_growth_rate [label="chemo kill", color=darkgreen, arrowhead=tee, style=dashed];
    Cell_kill_rate_immuno -> Cell_growth_rate [label="immuno kill", color=darkgreen, arrowhead=tee, style=dashed];
    Tumor_volume_t    -> Tumor_shrinkage  [label="RECIST change%", color=darkgreen];
    Tumor_shrinkage   -> PR_response      [label="≥30% shrinkage", color=darkgreen];
    Tumor_shrinkage   -> SD_response      [label="<30% change", color=darkgreen];
    Tumor_volume_t    -> PD_progression   [label="≥20% growth", color=darkgreen];
    Tumor_shrinkage   -> Nadir_volume     [label="minimum V", color=darkgreen];
    Nadir_volume      -> Regrowth_phase   [label="resist emerge", color=darkgreen];
    Clonal_evolution  -> Tumor_cells_resistant [label="selection pressure", color=darkgreen, style=bold];
    Clonal_evolution  -> T790M_EGFR       [label="T790M arise", color=crimson, style=dashed];

    /* Drug → cell kill */
    EGFR_TKI_bound    -> Cell_kill_rate_TKI   [label="TKI Emax PD", color=green, style=bold];
    ALK_inh_bound     -> Cell_kill_rate_TKI   [label="ALK kill PD", color=green, style=bold];
    KRAS_inh_bound    -> Cell_kill_rate_TKI   [label="G12C kill PD", color=green, style=bold];
    DNA_adducts       -> Cell_kill_rate_chemo [label="Pt adduct kill", color=green, style=bold];
    DHFR_inh          -> Cell_kill_rate_chemo [label="Pem kill", color=green];
    CD8_T_cell        -> Cell_kill_rate_immuno [label="CTL cytotoxic", color=steelblue, style=bold];
    NK_cell           -> Cell_kill_rate_immuno [label="NK cytotoxic", color=steelblue];
    PD1_target_binding -> Cell_kill_rate_immuno [label="release CTL", color=green, style=bold];
    PDL1_bound        -> Cell_kill_rate_immuno [label="release CTL", color=green, style=bold];

    /* =========================================================
       EDGES: CLUSTER 9 — Toxicity
    ========================================================= */
    EGFR_TKI_plasma   -> Rash_EGFR_TKI    [label="skin EGFR inh", color=deeppink];
    EGFR_TKI_plasma   -> Diarrhea_TKI     [label="GI EGFR inh", color=deeppink];
    EGFR_TKI_plasma   -> ILD_TKI          [label="lung toxicity", color=deeppink];
    EGFR_TKI_plasma   -> Hepatotox_TKI    [label="ALT/AST rise", color=deeppink];
    ALK_inh_plasma    -> Hepatotox_TKI    [label="ALK inh hepatox", color=deeppink];
    IV_PD1            -> Pneumonitis_immuno [label="irAE lung", color=deeppink];
    IV_PD1            -> Colitis_immuno    [label="irAE GI", color=deeppink];
    IV_PD1            -> Nephritis_immuno  [label="irAE kidney", color=deeppink];
    IV_PD1            -> Cardiac_irAE     [label="rare myocarditis", color=deeppink];
    IV_PDL1           -> Pneumonitis_immuno [label="PDL1-irAE", color=deeppink];
    Plat_plasma       -> Nephrotox_plat    [label="cis nephrotox", color=deeppink];
    Plat_plasma       -> Neuropathy_plat   [label="oxali neuropath", color=deeppink];
    Plat_plasma       -> Myelosuppression_chemo [label="bone marrow", color=deeppink];
    Pem_plasma        -> Myelosuppression_chemo [label="pem myelosupp", color=deeppink];
    Pem_plasma        -> Mucositis_pem     [label="mucositis", color=deeppink];
    Myelosuppression_chemo -> ANC_nadir    [label="neutropenia", color=deeppink];
    Myelosuppression_chemo -> Plt_nadir    [label="thrombocytopen", color=deeppink];
    Myelosuppression_chemo -> Hgb_drop     [label="anemia", color=deeppink];
    Fatigue_tox       -> QoL_score         [label="QoL impact", color=deeppink, arrowhead=normal];
    Rash_EGFR_TKI     -> DLT_grade        [label="CTCAE grade", color=deeppink];
    Pneumonitis_immuno -> DLT_grade        [label="CTCAE grade", color=deeppink];
    Nephrotox_plat    -> DLT_grade        [label="CTCAE grade", color=deeppink];

    /* =========================================================
       EDGES: CLUSTER 8 → CLUSTER 10 — Tumor Dynamics → Endpoints
    ========================================================= */
    PR_response       -> RECIST_PR         [label="RECIST criteria", color=steelblue];
    SD_response       -> RECIST_SD         [label="RECIST criteria", color=steelblue];
    PD_progression    -> RECIST_PD         [label="RECIST criteria", color=steelblue];
    Tumor_shrinkage   -> RECIST_CR         [label="complete clear", color=steelblue];
    Tumor_volume_t    -> Depth_of_Response [label="max% change", color=steelblue];
    Regrowth_phase    -> Time_to_Progression [label="time of PD", color=steelblue];
    Nadir_volume      -> Duration_Response  [label="DoR from resp", color=steelblue];
    PR_response       -> Progression_Free_Surv [label="PFS landmark", color=steelblue, style=bold];
    SD_response       -> Disease_Control    [label="DCR = CR+PR+SD", color=steelblue];
    RECIST_CR         -> Objective_Response [label="ORR = CR+PR", color=steelblue];
    RECIST_PR         -> Objective_Response [label="ORR component", color=steelblue];
    Progression_Free_Surv -> Overall_Survival [label="surrogate OS", color=steelblue, style=bold];
    PD_progression    -> Overall_Survival  [label="PD → death", color=steelblue, arrowhead=tee, style=dashed];
    ECOG_PS           -> Tumor_volume_baseline [label="PS guides dose", color=steelblue];
    ECOG_PS           -> Overall_Survival  [label="PS → OS", color=steelblue];
    Brain_metastasis  -> Stage_IVB         [label="M1c → IVB", color=steelblue];
    Bone_metastasis   -> Stage_IVA         [label="M1b → IVA", color=steelblue];
    Stage_IIIA        -> Tumor_volume_baseline [label="resectable", color=steelblue];
    Stage_IVA         -> Tumor_volume_baseline [label="metastatic", color=steelblue];
    Stage_IVB         -> Overall_Survival  [label="poor prognosis", color=steelblue, arrowhead=tee, style=dashed];
    DLT_grade         -> ECOG_PS           [label="toxicity→PS", color=deeppink];
    QoL_score         -> Overall_Survival  [label="QoL → survival", color=steelblue];
    CNS_PFS           -> Progression_Free_Surv [label="CNS control", color=steelblue];
    Depth_of_Response -> Objective_Response [label="ORR threshold", color=steelblue];

    /* =========================================================
       CROSS-CLUSTER EDGES — Additional mechanistic links
    ========================================================= */
    /* Tumor biology → immune */
    PD_L1_tumor       -> PD_L1_TPS        [label="TPS %", color=purple];
    VEGF              -> M2_macro          [label="VEGF recruit TAM", color=steelblue];
    VEGF              -> Treg              [label="VEGF → Treg", color=steelblue];
    TGFb_immune       -> E_Cadherin_loss   [label="TGFβ-EMT", color=steelblue];
    TGFb_immune       -> MMP2             [label="TGFβ→MMP2", color=steelblue];
    IDO1              -> TGFb_immune       [label="IDO1 axis", color=steelblue];

    /* Signaling → tumor biology cross */
    AKT               -> HIF1a            [label="AKT→HIF1α", color=orange];
    ERK1              -> HIF1a            [label="ERK→HIF1α", color=orange];
    AKT               -> EMT_TF           [label="AKT→SNAIL", color=orange];

    /* Resistance → biomarkers */
    T790M_EGFR        -> EGFR_ctDNA       [label="T790M ctDNA", color=crimson];
    C797S_EGFR        -> EGFR_ctDNA       [label="C797S ctDNA", color=crimson];
    MET_amplification -> NGS_panel        [label="MET amp detect", color=crimson];

    /* Tumor dynamics → biomarkers */
    Tumor_volume_t    -> CEA              [label="CEA correlate", color=purple];
    Tumor_volume_t    -> CYFRA_211        [label="CYFRA correlate", color=purple];
    Tumor_cells_sensitive -> CTC_count    [label="CTC from tumor", color=purple];

    /* Endpoints → biomarkers feedback */
    Overall_Survival  -> OS_months        [label="OS measurement", color=purple];
    Progression_Free_Surv -> PFS_months   [label="PFS measurement", color=purple];
    Objective_Response -> ORR_pct         [label="ORR %", color=purple];
    Disease_Control   -> DCR_pct          [label="DCR %", color=purple];

    /* Drug → biomarker response */
    IV_PD1            -> TIL_density      [label="IO → TIL expand", color=darkgreen];
    EGFR_TKI_bound    -> EGFR_ctDNA       [label="ctDNA clearance", color=darkgreen, arrowhead=tee, style=dashed];

    /* Oncogene → tumor dynamics */
    KRAS_G12C         -> Cell_growth_rate  [label="KRAS drive growth", color=red];
    EGFR_activating   -> Cell_growth_rate  [label="EGFR drive prolif", color=red];
    MYC               -> Cell_growth_rate  [label="Myc → proliferat", color=orange];

    /* Resistance → tumor dynamics */
    Tumor_cells_resistant -> Cell_growth_rate [label="resist pool grows", color=crimson];
    EMT_resistance    -> Tumor_cells_resistant [label="EMT → resist", color=crimson];
    Small_cell_transform -> Tumor_cells_resistant [label="SCLC resist", color=crimson];
    AXL_upregul       -> EMT_resistance   [label="AXL→EMT", color=crimson];

    /* NRF2/STK11 cross */
    KEAP1_mut         -> STK11_biomarker  [label="co-mutation", color=purple];
    STK11_mut         -> STK11_biomarker  [label="LKB1 mut", color=purple];
    NRF2              -> PD_L1_tumor      [label="NRF2→PDL1", color=orange];
}
