digraph ME_CFS_QSP_Model {
  graph [
    label = "ME/CFS (Myalgic Encephalomyelitis / Chronic Fatigue Syndrome)\nComprehensive QSP Mechanistic Map"
    labelloc = "t"
    fontsize = 22
    fontname = "Helvetica-Bold"
    bgcolor = "#F8F9FA"
    rankdir = TB
    splines = ortho
    nodesep = 0.45
    ranksep = 0.65
    compound = true
    overlap = false
  ]

  node [fontname="Helvetica" fontsize=9 style="filled" shape=box margin="0.1,0.05"]
  edge [fontname="Helvetica" fontsize=7 arrowsize=0.7]

  // ============================================================
  // CLUSTER 1: Triggering Events & Viral Persistence
  // ============================================================
  subgraph cluster_triggers {
    label = "1. Triggering Events & Viral Persistence"
    style = filled
    color = "#CC2200"
    fillcolor = "#FFF0EE"
    fontcolor = "#8B0000"
    fontsize = 13
    fontname = "Helvetica-Bold"

    EBV [label="EBV\n(Epstein-Barr Virus)" fillcolor="#FFAAAA" shape=ellipse]
    HHV6 [label="HHV-6\n(Human Herpesvirus 6)" fillcolor="#FFAAAA" shape=ellipse]
    SARS_CoV2 [label="SARS-CoV-2" fillcolor="#FFAAAA" shape=ellipse]
    Enterovirus [label="Enterovirus\n(Coxsackievirus)" fillcolor="#FFAAAA" shape=ellipse]
    Retrovirus [label="Retroviruses\n(XMRV, MLV)" fillcolor="#FFAAAA" shape=ellipse]
    Bacterial_trigger [label="Bacterial\nInfection Trigger" fillcolor="#FFAAAA" shape=ellipse]
    Physical_trauma [label="Physical/\nPsychological Trauma" fillcolor="#FFCC99" shape=ellipse]
    Stress_trigger [label="Severe Stress\nTrigger Event" fillcolor="#FFCC99" shape=ellipse]
    Viral_persistence [label="Viral Persistence\n& Reactivation" fillcolor="#FF5555" fontcolor="white" style="filled,bold"]
    Latent_reservoir [label="Latent Viral\nReservoir (CNS/Gut)" fillcolor="#CC2200" fontcolor="white"]
  }

  // ============================================================
  // CLUSTER 2: Pattern Recognition & Innate Immune
  // ============================================================
  subgraph cluster_innate {
    label = "2. Innate Immune Activation (Pattern Recognition)"
    style = filled
    color = "#CC5500"
    fillcolor = "#FFF3E0"
    fontcolor = "#7B3F00"
    fontsize = 13
    fontname = "Helvetica-Bold"

    TLR3 [label="TLR3\n(dsRNA sensor)" fillcolor="#FFB347"]
    TLR4 [label="TLR4\n(LPS/DAMP sensor)" fillcolor="#FFB347"]
    TLR7 [label="TLR7/8\n(ssRNA sensor)" fillcolor="#FFB347"]
    TLR9 [label="TLR9\n(CpG DNA sensor)" fillcolor="#FFB347"]
    RIG_I [label="RIG-I / MDA5\n(cytosolic RNA)" fillcolor="#FFB347"]
    cGAS [label="cGAS\n(cytosolic DNA sensor)" fillcolor="#FFB347"]
    STING [label="STING\n(cGAMP receptor)" fillcolor="#FF8800" fontcolor="white" style="filled,bold"]
    NFkB [label="NF-κB\nActivation" fillcolor="#CC5500" fontcolor="white" style="filled,bold"]
    IRF3 [label="IRF3 / IRF7\nActivation" fillcolor="#CC5500" fontcolor="white" style="filled,bold"]
    IFN_I [label="Type I IFN\n(IFN-α/β) ↑" fillcolor="#FF8800" fontcolor="white" style="filled,bold"]
    IFN_signature [label="Interferon\nSignature ↑" fillcolor="#CC5500" fontcolor="white" style="filled,bold"]
    NLRP3 [label="NLRP3\nInflammasome" fillcolor="#FF5500" fontcolor="white" style="filled,bold"]
    IL_1beta [label="IL-1β ↑" fillcolor="#FFB347"]
    IL_18 [label="IL-18 ↑" fillcolor="#FFB347"]
    IL_33 [label="IL-33\n(Alarmin) ↑" fillcolor="#FFB347"]
    Pyroptosis [label="Pyroptosis\n(Inflammatory Cell Death)" fillcolor="#CC5500" fontcolor="white"]
    NK_cell [label="NK Cells\n(Count ↓)" fillcolor="#FFD700"]
    NK_dysfunction [label="NK Cell\nDysfunction\n(Cytotoxicity ↓)" fillcolor="#CC5500" fontcolor="white" style="filled,bold"]
    pDC [label="Plasmacytoid DC\n(IFN factory)" fillcolor="#FFB347"]
    Monocyte [label="Monocytes\n(Activated)" fillcolor="#FFB347"]
    M1_mac [label="M1 Macrophage\n(Pro-inflammatory)" fillcolor="#FF5500" fontcolor="white"]
    M2_mac [label="M2 Macrophage\n(Anti-inflam.)" fillcolor="#90EE90"]
    Mac_imbalance [label="M1/M2\nImbalance" fillcolor="#CC5500" fontcolor="white" style="filled,bold"]
    Complement [label="Complement System\nActivation (C3a, C5a)" fillcolor="#FFB347"]
  }

  // ============================================================
  // CLUSTER 3: Adaptive Immune Dysregulation
  // ============================================================
  subgraph cluster_adaptive {
    label = "3. Adaptive Immune Dysregulation"
    style = filled
    color = "#7B00AA"
    fillcolor = "#F3E5F5"
    fontcolor = "#4A0072"
    fontsize = 13
    fontname = "Helvetica-Bold"

    CD4_Th1 [label="CD4+ Th1\n(IFN-γ, IL-2)" fillcolor="#CE93D8"]
    CD4_Th2 [label="CD4+ Th2\n(IL-4, IL-13)" fillcolor="#CE93D8"]
    CD4_Th17 [label="CD4+ Th17\n(IL-17, IL-22)" fillcolor="#CE93D8"]
    Treg [label="CD4+ Treg\n↓Reduced Function" fillcolor="#AB47BC" fontcolor="white"]
    CD8_cytotoxic [label="CD8+ Cytotoxic T\n(Impaired function)" fillcolor="#CE93D8"]
    CD8_exhausted [label="CD8+ T Cell\nExhaustion" fillcolor="#7B00AA" fontcolor="white" style="filled,bold"]
    PD1 [label="PD-1 ↑\n(Exhaustion marker)" fillcolor="#BA68C8"]
    LAG3 [label="LAG-3 ↑\n(Exhaustion marker)" fillcolor="#BA68C8"]
    TIM3 [label="TIM-3 ↑\n(Exhaustion marker)" fillcolor="#BA68C8"]
    B_activation [label="B Cell\nActivation" fillcolor="#CE93D8"]
    B_exhaustion [label="B Cell\nExhaustion ↑" fillcolor="#7B00AA" fontcolor="white"]
    Plasma_cell [label="Plasma Cell\n(Autoantibodies)" fillcolor="#BA68C8"]
    IgG [label="IgG\n(IgG1/IgG3 ↓)" fillcolor="#CE93D8"]
    Auto_Ab_beta2 [label="Auto-Ab:\nβ2-Adrenergic Receptor" fillcolor="#4A0072" fontcolor="white" style="filled,bold"]
    Auto_Ab_M1 [label="Auto-Ab:\nM1-Muscarinic Receptor" fillcolor="#4A0072" fontcolor="white" style="filled,bold"]
    Auto_Ab_H2 [label="Auto-Ab:\nH2 Histamine Receptor" fillcolor="#7B00AA" fontcolor="white"]
    Auto_Ab_5HT [label="Auto-Ab:\n5-HT Serotonin Receptor" fillcolor="#7B00AA" fontcolor="white"]
    Molecular_mimicry [label="Molecular\nMimicry" fillcolor="#7B00AA" fontcolor="white"]
    GC_failure [label="Germinal Center\nDysfunction" fillcolor="#AB47BC" fontcolor="white"]
  }

  // ============================================================
  // CLUSTER 4: Cytokine Network
  // ============================================================
  subgraph cluster_cytokines {
    label = "4. Cytokine Network"
    style = filled
    color = "#AA0022"
    fillcolor = "#FFEBEE"
    fontcolor = "#7B0000"
    fontsize = 13
    fontname = "Helvetica-Bold"

    IL_6 [label="IL-6 ↑\n(Elevated)" fillcolor="#EF9A9A" style="filled,bold"]
    IL_10 [label="IL-10 ↑\n(Compensatory)" fillcolor="#FFCDD2"]
    TNF_alpha [label="TNF-α ↑\n(Elevated)" fillcolor="#EF9A9A" style="filled,bold"]
    TGF_beta [label="TGF-β ↑\n(Fibrosis/suppression)" fillcolor="#EF9A9A"]
    IL_8 [label="IL-8 / CXCL8\n(Neutrophil chemo)" fillcolor="#FFCDD2"]
    CXCL10 [label="CXCL10 / IP-10 ↑\n(IFN marker)" fillcolor="#EF9A9A"]
    IL_17 [label="IL-17\n(Variable)" fillcolor="#FFCDD2"]
    IL_4 [label="IL-4\n(Th2 bias)" fillcolor="#FFCDD2"]
    IL_13 [label="IL-13\n(Th2 bias)" fillcolor="#FFCDD2"]
    CCL2 [label="CCL2 / MCP-1\n(Monocyte chemo)" fillcolor="#FFCDD2"]
    CCL5 [label="CCL5 / RANTES\n(T cell chemo)" fillcolor="#FFCDD2"]
    IFN_gamma [label="IFN-γ ↑\n(T cell / NK derived)" fillcolor="#EF9A9A" style="filled,bold"]
    Cytokine_dysreg [label="Cytokine\nDysregulation" fillcolor="#880011" fontcolor="white" style="filled,bold"]
    Inflammasome_loop [label="Inflammasome-\nCytokine Loop" fillcolor="#AA0022" fontcolor="white" style="filled,bold"]
  }

  // ============================================================
  // CLUSTER 5: Mast Cell Activation Syndrome (MCAS)
  // ============================================================
  subgraph cluster_mcas {
    label = "5. Mast Cell Activation (MCAS)"
    style = filled
    color = "#AA0055"
    fillcolor = "#FCE4EC"
    fontcolor = "#880033"
    fontsize = 13
    fontname = "Helvetica-Bold"

    Mast_cell [label="Mast Cell\n(Activated)" fillcolor="#F48FB1" style="filled,bold"]
    IgE_receptor [label="FcεRI\n(IgE Receptor)" fillcolor="#F8BBD0"]
    SCF [label="Stem Cell Factor\n(c-Kit ligand)" fillcolor="#F8BBD0"]
    Tryptase [label="Tryptase ↑\n(Serum biomarker)" fillcolor="#F48FB1" style="filled,bold"]
    Histamine [label="Histamine ↑\n(H1/H2/H4R)" fillcolor="#F48FB1" style="filled,bold"]
    PGD2 [label="Prostaglandin D2\n(PGD2)" fillcolor="#F8BBD0"]
    Leukotrienes [label="Leukotrienes\n(LTC4, LTD4, LTE4)" fillcolor="#F8BBD0"]
    PAF [label="PAF\n(Platelet Activating Factor)" fillcolor="#F8BBD0"]
    Heparin_MC [label="Heparin\n(Released by MC)" fillcolor="#F8BBD0"]
    MC_degranulation [label="Mast Cell\nDegranulation" fillcolor="#C2185B" fontcolor="white" style="filled,bold"]
    MCAS [label="MCAS\n(Mast Cell Act. Syndrome)" fillcolor="#880033" fontcolor="white" style="filled,bold"]
    H1_receptor [label="H1 Receptor\n(Allergic response)" fillcolor="#F8BBD0"]
    H2_receptor [label="H2 Receptor\n(Gastric / Immune)" fillcolor="#F8BBD0"]
    MRGPRX2 [label="MRGPRX2\n(MC activation receptor)" fillcolor="#F8BBD0"]
  }

  // ============================================================
  // CLUSTER 6: HPA Axis & Neuroendocrine
  // ============================================================
  subgraph cluster_hpa {
    label = "6. HPA Axis & Neuroendocrine Dysregulation"
    style = filled
    color = "#005522"
    fillcolor = "#E8F5E9"
    fontcolor = "#1B5E20"
    fontsize = 13
    fontname = "Helvetica-Bold"

    Hypothalamus [label="Hypothalamus\n(Dysfunctional)" fillcolor="#A5D6A7"]
    CRH [label="CRH\n(Corticotropin-Releasing H.)" fillcolor="#81C784"]
    Pituitary [label="Anterior Pituitary\n(Altered response)" fillcolor="#A5D6A7"]
    ACTH [label="ACTH ↓\n(Reduced output)" fillcolor="#66BB6A"]
    Adrenal [label="Adrenal Cortex\n(Hypo-responsive)" fillcolor="#A5D6A7"]
    Cortisol [label="Cortisol ↓\n(Hypocortisolism)" fillcolor="#2E7D32" fontcolor="white" style="filled,bold"]
    GR [label="Glucocorticoid\nReceptor (GR)" fillcolor="#81C784"]
    GR_resistance [label="GR Resistance\n(Immune cells)" fillcolor="#1B5E20" fontcolor="white" style="filled,bold"]
    CAR [label="Cortisol Awakening\nResponse ↓ (CAR)" fillcolor="#2E7D32" fontcolor="white" style="filled,bold"]
    HPA_suppression [label="HPA Axis\nSuppression" fillcolor="#1B5E20" fontcolor="white" style="filled,bold"]
    Serotonin [label="Serotonin\n(5-HT, Altered)" fillcolor="#81C784"]
    SERT [label="SERT\n(5-HT Transporter)" fillcolor="#A5D6A7"]
    Dopamine [label="Dopamine ↓\n(Reward / Energy)" fillcolor="#66BB6A"]
    BDNF [label="BDNF ↓\n(Neuroprotection)" fillcolor="#81C784"]
    Melatonin [label="Melatonin\n(Circadian Disruption)" fillcolor="#A5D6A7"]
    HPG_axis [label="HPG Axis\n(Hormonal dysregulation)" fillcolor="#A5D6A7"]
    Circadian_rhythm [label="Circadian Rhythm\nDisruption" fillcolor="#2E7D32" fontcolor="white"]
  }

  // ============================================================
  // CLUSTER 7: Autonomic Nervous System & Cardiovascular
  // ============================================================
  subgraph cluster_ans {
    label = "7. Autonomic Nervous System & Cardiovascular Dysregulation"
    style = filled
    color = "#003388"
    fillcolor = "#E3F2FD"
    fontcolor = "#0D47A1"
    fontsize = 13
    fontname = "Helvetica-Bold"

    Sympathetic [label="Sympathetic\nHyperactivation" fillcolor="#90CAF9" style="filled,bold"]
    Parasympathetic [label="Parasympathetic\nWithdrawal ↓" fillcolor="#90CAF9"]
    Norepinephrine [label="Norepinephrine ↑\n(Plasma, urine)" fillcolor="#64B5F6"]
    Epinephrine [label="Epinephrine\n(Stress response)" fillcolor="#64B5F6"]
    HRV [label="HRV ↓\n(Reduced variability)" fillcolor="#003388" fontcolor="white" style="filled,bold"]
    POTS [label="POTS\n(Postural Orthostatic\nTachycardia Syndrome)" fillcolor="#0D47A1" fontcolor="white" style="filled,bold"]
    Orthostatic_intol [label="Orthostatic\nIntolerance" fillcolor="#003388" fontcolor="white" style="filled,bold"]
    Beta2AR [label="β2-Adrenergic R\n(AutoAb target)" fillcolor="#90CAF9"]
    M1R [label="M1-Muscarinic R\n(AutoAb target)" fillcolor="#90CAF9"]
    Baroreceptor [label="Baroreceptor\n(Impaired reflex)" fillcolor="#BBDEFB"]
    RAAS [label="RAAS\nActivation" fillcolor="#64B5F6"]
    Renin [label="Renin ↑" fillcolor="#BBDEFB"]
    AngII [label="Angiotensin II\n(Vasoconstriction)" fillcolor="#64B5F6"]
    Aldosterone [label="Aldosterone ↑\n(Na+ retention)" fillcolor="#BBDEFB"]
    Low_blood_vol [label="Low Blood Volume\n(Hypovolemia)" fillcolor="#0D47A1" fontcolor="white"]
    Cardiac_output [label="Cardiac Output ↓\n(Reduced)" fillcolor="#0D47A1" fontcolor="white"]
    Small_fiber_neuro [label="Small Fiber\nNeuropathy" fillcolor="#003388" fontcolor="white" style="filled,bold"]
    Vagal_tone [label="Vagal Tone ↓\n(Parasympathetic)" fillcolor="#64B5F6"]
  }

  // ============================================================
  // CLUSTER 8: Mitochondrial Dysfunction & Energy Metabolism
  // ============================================================
  subgraph cluster_mito {
    label = "8. Mitochondrial Dysfunction & Energy Metabolism"
    style = filled
    color = "#AA4400"
    fillcolor = "#FFF8E1"
    fontcolor = "#7B2C00"
    fontsize = 13
    fontname = "Helvetica-Bold"

    Complex_I [label="Complex I ↓\n(NADH dehydrogenase)" fillcolor="#FFE082"]
    Complex_II [label="Complex II\n(Succinate dehydrog.)" fillcolor="#FFE082"]
    Complex_III [label="Complex III\n(bc1 complex)" fillcolor="#FFE082"]
    Complex_IV [label="Complex IV ↓\n(Cytochrome c oxidase)" fillcolor="#FFE082"]
    ATP_synthase [label="ATP Synthase\n(Complex V)" fillcolor="#FFD54F"]
    ROS [label="ROS ↑\n(Reactive Oxygen Species)" fillcolor="#E65100" fontcolor="white" style="filled,bold"]
    Superoxide [label="Superoxide (O2•⁻) ↑" fillcolor="#FF8F00" fontcolor="white"]
    H2O2 [label="H2O2 ↑\n(Hydrogen peroxide)" fillcolor="#FF8F00" fontcolor="white"]
    SOD [label="SOD ↓\n(Superoxide dismutase)" fillcolor="#FFB74D"]
    Catalase [label="Catalase ↓\n(Antioxidant)" fillcolor="#FFB74D"]
    Glutathione [label="Glutathione ↓\n(GSH redox buffer)" fillcolor="#FFB74D"]
    PDH [label="PDH ↓\n(Pyruvate Dehydrogenase\nInhibited)" fillcolor="#BF360C" fontcolor="white" style="filled,bold"]
    PDK1 [label="PDK1 ↑\n(PDH Kinase 1\nUpregulated)" fillcolor="#E65100" fontcolor="white" style="filled,bold"]
    AMPK [label="AMPK\n(Energy sensor)" fillcolor="#FFB74D"]
    mTOR [label="mTOR\n(Dysregulated)" fillcolor="#FFB74D"]
    PGC1a [label="PGC-1α ↓\n(Mitochond. biogenesis)" fillcolor="#BF360C" fontcolor="white" style="filled,bold"]
    NAD_pool [label="NAD+/NADH ↓\n(Redox imbalance)" fillcolor="#E65100" fontcolor="white"]
    CoQ10 [label="CoQ10 ↓\n(Coenzyme Q10)" fillcolor="#FFB74D"]
    L_carnitine [label="L-Carnitine ↓\n(FA transport)" fillcolor="#FFB74D"]
    Acetyl_CoA [label="Acetyl-CoA ↓\n(TCA entry)" fillcolor="#FFE082"]
    TCA_cycle [label="TCA Cycle ↓\n(Impaired)" fillcolor="#E65100" fontcolor="white"]
    NADH [label="NADH ↓\n(Reduced production)" fillcolor="#FFE082"]
    Oxidative_phos [label="Oxidative Phosphorylation ↓\n(Severely Impaired)" fillcolor="#7B2C00" fontcolor="white" style="filled,bold"]
    Glycolysis [label="Glycolysis ↑\n(Compensatory)" fillcolor="#FFE082"]
    Lactate [label="Lactate ↑\n(Elevated post-exercise)" fillcolor="#E65100" fontcolor="white" style="filled,bold"]
    Pyruvate [label="Pyruvate\n(Diverted to lactate)" fillcolor="#FFE082"]
    ATP_deficit [label="ATP Deficit\n(Cellular Energy Crisis)" fillcolor="#7B2C00" fontcolor="white" style="filled,bold"]
    Mito_biogenesis [label="Mitochondrial\nBiogenesis ↓" fillcolor="#BF360C" fontcolor="white"]
    Succinate_accum [label="Succinate\nAccumulation" fillcolor="#FFB74D"]
    PPAR_gamma [label="PPAR-γ\n(Metabolic regulator ↓)" fillcolor="#FFB74D"]
  }

  // ============================================================
  // CLUSTER 9: Neuroinflammation & CNS
  // ============================================================
  subgraph cluster_neuro {
    label = "9. Neuroinflammation & Central Nervous System"
    style = filled
    color = "#263238"
    fillcolor = "#ECEFF1"
    fontcolor = "#263238"
    fontsize = 13
    fontname = "Helvetica-Bold"

    Microglia_rest [label="Microglia\n(Resting M0)" fillcolor="#B0BEC5"]
    Microglia_act [label="Microglia ↑\n(Activated M1)" fillcolor="#37474F" fontcolor="white" style="filled,bold"]
    Astrocyte_act [label="Astrocytes\n(Reactive A1)" fillcolor="#546E7A" fontcolor="white"]
    Neuroinflammation [label="Neuroinflammation ↑\n(PET confirmed)" fillcolor="#263238" fontcolor="white" style="filled,bold"]
    TSPO [label="TSPO ↑\n(11C-PK11195 PET marker)" fillcolor="#37474F" fontcolor="white"]
    IL_6_brain [label="IL-6 ↑\n(Brain compartment)" fillcolor="#78909C" fontcolor="white"]
    TNF_brain [label="TNF-α ↑\n(Brain compartment)" fillcolor="#78909C" fontcolor="white"]
    NO_brain [label="Nitric Oxide ↑\n(iNOS activation)" fillcolor="#37474F" fontcolor="white"]
    iNOS [label="iNOS ↑\n(Inducible NOS)" fillcolor="#546E7A" fontcolor="white"]
    BBB_disruption [label="Blood-Brain Barrier\nDisruption" fillcolor="#263238" fontcolor="white" style="filled,bold"]
    Glutamate_exc [label="Glutamate\nExcitotoxicity ↑" fillcolor="#37474F" fontcolor="white"]
    GABA_deficiency [label="GABA ↓\n(Inhibitory deficiency)" fillcolor="#78909C" fontcolor="white"]
    Central_sens [label="Central\nSensitization" fillcolor="#263238" fontcolor="white" style="filled,bold"]
    Substance_P [label="Substance P ↑\n(Pain amplification)" fillcolor="#546E7A" fontcolor="white"]
    CGRP [label="CGRP ↑\n(Pain sensitization)" fillcolor="#78909C" fontcolor="white"]
    Hippocampal_damage [label="Hippocampal\nDamage ↓ Volume" fillcolor="#37474F" fontcolor="white"]
    Cognitive_impair [label="Cognitive Impairment\n'Brain Fog'" fillcolor="#263238" fontcolor="white" style="filled,bold"]
    Sleep_disturbance [label="Sleep Disturbance\n↓ REM / Stage 3" fillcolor="#37474F" fontcolor="white"]
    NMDA_sensitivity [label="NMDA Receptor\nHypersensitivity" fillcolor="#546E7A" fontcolor="white"]
    Kynurenine_path [label="Kynurenine Pathway\n(IDO1 upregulation)" fillcolor="#78909C" fontcolor="white"]
    Tryptophan_depl [label="Tryptophan\nDepletion" fillcolor="#90A4AE"]
    Quinolinic_acid [label="Quinolinic Acid ↑\n(Neurotoxic)" fillcolor="#37474F" fontcolor="white"]
  }

  // ============================================================
  // CLUSTER 10: Post-Exertional Malaise (PEM)
  // ============================================================
  subgraph cluster_pem {
    label = "10. Post-Exertional Malaise (PEM) — Pathological Hallmark"
    style = filled
    color = "#4A0090"
    fillcolor = "#EDE7F6"
    fontcolor = "#4A148C"
    fontsize = 13
    fontname = "Helvetica-Bold"

    Exercise_challenge [label="Physical / Cognitive\nChallenge" fillcolor="#CE93D8"]
    PEM_threshold [label="PEM Threshold ↓\n(Anaerobic Threshold)" fillcolor="#6A1B9A" fontcolor="white" style="filled,bold"]
    Post_exertion_immune [label="Post-Exertional\nImmune Flare" fillcolor="#7B1FA2" fontcolor="white" style="filled,bold"]
    Oxidative_burst [label="Oxidative Burst\n(Excessive ROS)" fillcolor="#6A1B9A" fontcolor="white"]
    Metabolic_collapse [label="Metabolic Collapse\n(Post-PEM)" fillcolor="#4A0090" fontcolor="white" style="filled,bold"]
    IFN_surge [label="IFN-γ Surge\n(Post-exertion)" fillcolor="#7B1FA2" fontcolor="white"]
    IL_6_surge [label="IL-6 Surge\n(Post-exertion)" fillcolor="#7B1FA2" fontcolor="white"]
    CPET_abnormal [label="CPET Abnormality\n(Day 2: VO2max ↓)" fillcolor="#6A1B9A" fontcolor="white" style="filled,bold"]
    Anaerobic_threshold [label="Anaerobic Threshold ↓\n(VT1 reduced)" fillcolor="#7B1FA2" fontcolor="white"]
    VO2max [label="VO2max ↓\n(Severely Reduced)" fillcolor="#4A0090" fontcolor="white" style="filled,bold"]
    Worsening_24_72h [label="Symptom Worsening\n24-72h Post-Exertion" fillcolor="#311B92" fontcolor="white" style="filled,bold"]
    Exertion_crash_cycle [label="Activity-Crash\nCycle" fillcolor="#4A0090" fontcolor="white"]
    Pacing_strategy [label="Pacing / Energy\nEnvelope Strategy" fillcolor="#CE93D8"]
  }

  // ============================================================
  // CLUSTER 11: Clinical Endpoints & Biomarkers
  // ============================================================
  subgraph cluster_endpoints {
    label = "11. Clinical Endpoints & Diagnostic Biomarkers"
    style = filled
    color = "#005544"
    fillcolor = "#E0F2F1"
    fontcolor = "#004D40"
    fontsize = 13
    fontname = "Helvetica-Bold"

    Fatigue_score [label="Fatigue Severity Scale\n(FSS ≥ 36)" fillcolor="#80CBC4" style="filled,bold"]
    PEM_score [label="PEM Severity &\nDuration Score" fillcolor="#80CBC4" style="filled,bold"]
    Cognitive_score [label="Cognitive Score\n(MoCA, Brain Fog)" fillcolor="#4DB6AC"]
    Sleep_score [label="Sleep Quality\n(PSQI)" fillcolor="#4DB6AC"]
    Orthostatic_HR [label="Orthostatic HR Change\n(>30 bpm = POTS)" fillcolor="#4DB6AC"]
    Exercise_capacity [label="Exercise Capacity\n(6MWT, CPET)" fillcolor="#4DB6AC"]
    SF36_PF [label="SF-36\nPhysical Function" fillcolor="#80CBC4" style="filled,bold"]
    NK_cytotox [label="NK Cytotoxicity ↓\n(Biomarker)" fillcolor="#4DB6AC"]
    Serum_tryptase [label="Serum Tryptase ↑\n(MCAS marker)" fillcolor="#4DB6AC"]
    Morning_cortisol [label="Morning Cortisol ↓\n(Hypocortisolism)" fillcolor="#4DB6AC"]
    HRV_RMSSD [label="HRV RMSSD ↓\n(Autonomic marker)" fillcolor="#4DB6AC"]
    Cytokine_panel [label="Cytokine Panel\n(IL-6, TNF-α, IFN-γ)" fillcolor="#4DB6AC"]
    Lactate_exercise [label="Lactate ↑\n(Post-exercise peak)" fillcolor="#4DB6AC"]
    NAD_level [label="NAD+ Level ↓\n(PBMC measure)" fillcolor="#4DB6AC"]
    IgG_subclass [label="IgG Subclass\n(IgG3 ↓)" fillcolor="#4DB6AC"]
    Auto_Ab_level [label="Autoantibody Levels\n(β2AR, M1R ELISA)" fillcolor="#80CBC4" style="filled,bold"]
