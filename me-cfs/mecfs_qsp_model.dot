  TLR3_modulation -> Viral_persistence [label="↓ Reduces\nviral load" color="#283593" style=dashed]

  // Aripiprazole
  Aripiprazole -> D2_partial_agonist [label="Low-dose D2\npartial agonism" color="#001588"]
  D2_partial_agonist -> Dopamine [label="Stabilizes\ndopamine" color="#283593" style=dashed]
  D2_partial_agonist -> ATP_deficit [label="Reduces\nenergy deficit" color="#283593" style=dashed]
  D2_partial_agonist -> Fatigue_score [label="↓ Improves" color="#005544" style=dashed]

  // Mast cell stabilizers
  Cromolyn -> MC_stabilization [label="Mast cell\nstabilizer" color="#001588"]
  H1_antihistamine -> Histamine [label="H1 blockade ↓" color="#283593" style=dashed]
  MC_stabilization -> MC_degranulation [label="Reduces ↓" color="#283593" style=dashed]
  MC_stabilization -> MCAS [label="Treats MCAS" color="#283593" style=dashed]

  // Mitochondrial support
  CoQ10_supp -> Mito_support [label="CoQ10\nsupplementation" color="#001588"]
  LCarnitine_supp -> Mito_support [label="L-Carnitine\nsupplementation"]
  Mito_support -> CoQ10 [label="Restores ↑" color="#283593" style=dashed]
  Mito_support -> L_carnitine [label="Restores ↑" color="#283593" style=dashed]
  Mito_support -> ATP_deficit [label="Reduces ↓" color="#283593" style=dashed penwidth=2]
  Mito_support -> Oxidative_phos [label="Improves ↑" color="#283593" style=dashed]

  // IVIG
  IVIG -> IVIG_effect [label="IV infusion" color="#001588"]
  IVIG_effect -> NK_dysfunction [label="Improves NK\nfunction" color="#283593" style=dashed]
  IVIG_effect -> Auto_Ab_beta2 [label="Fc receptor\nmodulation" color="#283593" style=dashed]
  IVIG_effect -> Cytokine_dysreg [label="Modulates\ncytokines" color="#283593" style=dashed]

  // Cross-system connections
  Cytokine_dysreg -> ATP_deficit [label="Cytokine-\nmito crosstalk" color="#AA4400" penwidth=2]
  Cytokine_dysreg -> Neuroinflammation [label="Systemic →\nbrain" color="#263238" penwidth=2]
  ATP_deficit -> Post_exertion_immune [label="Metabolic\nstress trigger" color="#4A0090"]
  Cortisol -> NK_dysfunction [label="Immunosuppression" dir=back]
  HRV -> Fatigue_score [label="Low HRV →\nfatigue" color="#005544"]
  Cognitive_impair -> Fatigue_score [label="Cognitive\nfatigue" color="#005544"]
}
