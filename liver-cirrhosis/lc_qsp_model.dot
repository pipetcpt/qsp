digraph LiverCirrhosis_QSP {
    graph [
        label="Liver Cirrhosis: Comprehensive QSP Mechanistic Map\nHepatic Fibrosis · Portal Hypertension · Systemic Complications · Drug PK/PD"
        labelloc="t"
        fontsize=22
        fontname="Helvetica-Bold"
        bgcolor="#FAFAFA"
        rankdir=TB
        splines=ortho
        nodesep=0.4
        ranksep=0.7
        pad=0.5
        compound=true
    ]
    node [fontname="Helvetica" fontsize=10 style="filled,rounded" shape=box]
    edge [fontname="Helvetica" fontsize=8]

    // ===================================================
    // SUBGRAPH 1: INITIAL INJURY & TRIGGERS
    // ===================================================
    subgraph cluster_injury {
        label="Hepatic Injury & Triggers"
        style="filled,rounded"
        fillcolor="#FFF3E0"
        color="#E65100"
        fontcolor="#E65100"
        fontsize=13
        fontname="Helvetica-Bold"

        ETOH [label="Alcohol (Ethanol)" fillcolor="#FFAB40" color="#E65100"]
        HBV [label="HBV Infection" fillcolor="#FFD180" color="#E65100"]
        HCV [label="HCV Infection" fillcolor="#FFD180" color="#E65100"]
        NASH_trig [label="NASH/NAFLD" fillcolor="#FFD180" color="#E65100"]
        ALD [label="Alcoholic Liver Disease" fillcolor="#FFAB40" color="#E65100"]
        PBC_trig [label="PBC/PSC/AIH" fillcolor="#FFD180" color="#E65100"]
        Hemo [label="Hemochromatosis\nWilson Disease" fillcolor="#FFD180" color="#E65100"]
        Drug_tox [label="Drug/Toxin Injury" fillcolor="#FFD180" color="#E65100"]
        Acetald [label="Acetaldehyde" fillcolor="#FFCC02" color="#E65100"]
        ROS_etoh [label="ROS (Ethanol)" fillcolor="#FF7043" color="#E65100"]
    }

    // ===================================================
    // SUBGRAPH 2: HEPATOCYTE DAMAGE & APOPTOSIS
    // ===================================================
    subgraph cluster_hepatocyte {
        label="Hepatocyte Damage & Death"
        style="filled,rounded"
        fillcolor="#FCE4EC"
        color="#AD1457"
        fontcolor="#AD1457"
        fontsize=13
        fontname="Helvetica-Bold"

        HepatoInj [label="Hepatocyte Injury" fillcolor="#F48FB1" color="#AD1457"]
        Apoptosis [label="Hepatocyte Apoptosis" fillcolor="#F06292" color="#AD1457"]
        Necrosis [label="Hepatocyte Necrosis" fillcolor="#F06292" color="#AD1457"]
        DAMP [label="DAMPs Release\n(HMGB1, mtDNA)" fillcolor="#EC407A" color="#AD1457" shape=ellipse]
        Caspase [label="Caspase 3/7\nActivation" fillcolor="#F48FB1" color="#AD1457"]
        MitoDys [label="Mitochondrial\nDysfunction" fillcolor="#FCE4EC" color="#AD1457"]
        ER_stress [label="ER Stress\nUPR Activation" fillcolor="#FCE4EC" color="#AD1457"]
        Balloon [label="Hepatocyte\nBallooning" fillcolor="#F48FB1" color="#AD1457"]
        LipidAccum [label="Lipid Accumulation\n(Steatosis)" fillcolor="#FFB3C1" color="#AD1457"]
        CytocP450 [label="CYP450\nDysfunction" fillcolor="#FFB3C1" color="#AD1457"]
    }

    // ===================================================
    // SUBGRAPH 3: INNATE IMMUNE RESPONSE & INFLAMMATION
    // ===================================================
    subgraph cluster_immune {
        label="Innate Immunity & Hepatic Inflammation"
        style="filled,rounded"
        fillcolor="#E8EAF6"
        color="#283593"
        fontcolor="#283593"
        fontsize=13
        fontname="Helvetica-Bold"

        KupfferAct [label="Kupffer Cell\nActivation" fillcolor="#7986CB" color="#283593"]
        TLR4 [label="TLR4 / LPS\nSignaling" fillcolor="#9FA8DA" color="#283593"]
        TLR9 [label="TLR9 / CpG DNA\nSignaling" fillcolor="#9FA8DA" color="#283593"]
        NLRP3 [label="NLRP3\nInflammasome" fillcolor="#7986CB" color="#283593" shape=ellipse]
        IL1B [label="IL-1β" fillcolor="#3F51B5" color="#283593" fontcolor="white"]
        IL6 [label="IL-6" fillcolor="#3F51B5" color="#283593" fontcolor="white"]
        TNFa [label="TNF-α" fillcolor="#3F51B5" color="#283593" fontcolor="white"]
        IL17 [label="IL-17" fillcolor="#9FA8DA" color="#283593"]
        IL33 [label="IL-33" fillcolor="#9FA8DA" color="#283593"]
        NFkB [label="NF-κB\nActivation" fillcolor="#5C6BC0" color="#283593" fontcolor="white" shape=ellipse]
        STAT3 [label="STAT3 Pathway" fillcolor="#9FA8DA" color="#283593"]
        Neutrophil [label="Neutrophil\nInfiltration" fillcolor="#C5CAE9" color="#283593"]
        NKcell [label="NK / NKT\nCells" fillcolor="#C5CAE9" color="#283593"]
        MoMac [label="Monocyte-derived\nMacrophages" fillcolor="#9FA8DA" color="#283593"]
        CXCL2 [label="CXCL2 / IL-8\nChemotaxis" fillcolor="#C5CAE9" color="#283593"]
        ROS_imm [label="ROS / Oxidative\nStress" fillcolor="#7986CB" color="#283593"]
    }

    // ===================================================
    // SUBGRAPH 4: HEPATIC STELLATE CELL ACTIVATION
    // ===================================================
    subgraph cluster_hsc {
        label="Hepatic Stellate Cell (HSC) Activation"
        style="filled,rounded"
        fillcolor="#E8F5E9"
        color="#1B5E20"
        fontcolor="#1B5E20"
        fontsize=13
        fontname="Helvetica-Bold"

        qHSC [label="Quiescent HSC\n(Vitamin A stores)" fillcolor="#A5D6A7" color="#1B5E20"]
        aHSC [label="Activated HSC\n(Myofibroblast)" fillcolor="#43A047" color="#1B5E20" fontcolor="white"]
        HSCapop [label="HSC Apoptosis\n(Resolution)" fillcolor="#C8E6C9" color="#1B5E20"]
        TGFB1 [label="TGF-β1\n(Key Fibrogenic Cytokine)" fillcolor="#2E7D32" color="#1B5E20" fontcolor="white" shape=ellipse]
        PDGF [label="PDGF-BB\n(Proliferation)" fillcolor="#388E3C" color="#1B5E20" fontcolor="white" shape=ellipse]
        CTGF [label="CTGF / CCN2" fillcolor="#66BB6A" color="#1B5E20"]
        Smad23 [label="Smad2/3\nPhosphorylation" fillcolor="#81C784" color="#1B5E20"]
        Smad7 [label="Smad7\n(Negative feedback)" fillcolor="#C8E6C9" color="#1B5E20"]
        TIMP1 [label="TIMP-1\n(MMP inhibitor)" fillcolor="#66BB6A" color="#1B5E20"]
        MMP2 [label="MMP-2 / MMP-9\n(Matrix degradation)" fillcolor="#A5D6A7" color="#1B5E20"]
        aActin [label="α-SMA\nExpression" fillcolor="#4CAF50" color="#1B5E20" fontcolor="white"]
        Wnt [label="Wnt / β-Catenin\nSignaling" fillcolor="#C8E6C9" color="#1B5E20"]
        Hedgehog [label="Hedgehog\nSignaling (Shh)" fillcolor="#C8E6C9" color="#1B5E20"]
        YAP [label="YAP / TAZ\nMechanotransduction" fillcolor="#A5D6A7" color="#1B5E20"]
        LOXL2 [label="LOXL2\n(Collagen crosslinking)" fillcolor="#81C784" color="#1B5E20"]
        HSCresolve [label="HSC Senescence\n(p21/p53)" fillcolor="#C8E6C9" color="#1B5E20"]
    }

    // ===================================================
    // SUBGRAPH 5: EXTRACELLULAR MATRIX & FIBROSIS
    // ===================================================
    subgraph cluster_fibrosis {
        label="Extracellular Matrix Remodeling & Fibrosis"
        style="filled,rounded"
        fillcolor="#FFF9C4"
        color="#F57F17"
        fontcolor="#F57F17"
        fontsize=13
        fontname="Helvetica-Bold"

        Col1A1 [label="Collagen I/III\nDeposition" fillcolor="#FFF176" color="#F57F17"]
        Fibronect [label="Fibronectin\nDeposition" fillcolor="#FFF9C4" color="#F57F17"]
        Laminin [label="Laminin /\nCollagen IV" fillcolor="#FFF9C4" color="#F57F17"]
        Capillar [label="Sinusoidal\nCapillarization" fillcolor="#FFD54F" color="#F57F17"]
        SeptoForm [label="Fibrous Septa\nFormation" fillcolor="#FFB300" color="#F57F17" fontcolor="white"]
        Nodule [label="Regenerative\nNodule Formation" fillcolor="#FFA000" color="#F57F17" fontcolor="white"]
        FibrIndex [label="Fibrosis Index\n(Ishak/METAVIR F0-F4)" fillcolor="#FF6F00" color="#F57F17" fontcolor="white"]
        Metafib [label="Liver Stiffness\n(kPa, FibroScan)" fillcolor="#FF8F00" color="#F57F17" fontcolor="white"]
        Hyaluro [label="Hyaluronic Acid\n(Serum biomarker)" fillcolor="#FFF9C4" color="#F57F17"]
        PIIINP [label="PIIINP\n(Procollagen marker)" fillcolor="#FFF9C4" color="#F57F17"]
        ELF_score [label="ELF Score\n(Biomarker panel)" fillcolor="#FFD54F" color="#F57F17"]
    }

    // ===================================================
    // SUBGRAPH 6: PORTAL HYPERTENSION
    // ===================================================
    subgraph cluster_portal {
        label="Portal Hypertension Pathophysiology"
        style="filled,rounded"
        fillcolor="#E3F2FD"
        color="#0D47A1"
        fontcolor="#0D47A1"
        fontsize=13
        fontname="Helvetica-Bold"

        PortPress [label="Portal Pressure\n(HVPG mmHg)" fillcolor="#42A5F5" color="#0D47A1" fontcolor="white"]
        IntraHep [label="Intrahepatic\nVascular Resistance" fillcolor="#90CAF9" color="#0D47A1"]
        eNOS_red [label="eNOS Reduction\n(NO deficiency)" fillcolor="#90CAF9" color="#0D47A1"]
        ET1 [label="Endothelin-1\n(Vasoconstriction)" fillcolor="#42A5F5" color="#0D47A1" fontcolor="white"]
        Rho_ROCK [label="RhoA/ROCK\nPathway" fillcolor="#90CAF9" color="#0D47A1"]
        Angio [label="Angiogenesis\n(VEGF, Angiopoietin)" fillcolor="#BBDEFB" color="#0D47A1"]
        PortoSys [label="Portosystemic\nCollaterals" fillcolor="#64B5F6" color="#0D47A1" fontcolor="white"]
        Splenomeg [label="Splenomegaly\n(Portal congestion)" fillcolor="#90CAF9" color="#0D47A1"]
        Varices [label="Esophageal/Gastric\nVarices" fillcolor="#1565C0" color="#0D47A1" fontcolor="white"]
        VaricBleed [label="Variceal Hemorrhage\n(HVPG >12 mmHg)" fillcolor="#0D47A1" color="#0D47A1" fontcolor="white"]
        SBP_risk [label="Spontaneous\nBacterial Peritonitis" fillcolor="#1976D2" color="#0D47A1" fontcolor="white"]
        Hyperdyn [label="Hyperdynamic\nCirculation" fillcolor="#64B5F6" color="#0D47A1" fontcolor="white"]
        SplanchVaso [label="Splanchnic\nVasodilation" fillcolor="#90CAF9" color="#0D47A1"]
        NO_splanchnic [label="NO (Splanchnic)\nOverproduction" fillcolor="#BBDEFB" color="#0D47A1"]
        CO_increase [label="Cardiac Output\nIncrease" fillcolor="#BBDEFB" color="#0D47A1"]
    }

    // ===================================================
    // SUBGRAPH 7: HEPATIC SYNTHETIC FUNCTION
    // ===================================================
    subgraph cluster_synthetic {
        label="Hepatic Synthetic & Metabolic Function"
        style="filled,rounded"
        fillcolor="#F3E5F5"
        color="#6A1B9A"
        fontcolor="#6A1B9A"
        fontsize=13
        fontname="Helvetica-Bold"

        AlbSyn [label="Albumin\nSynthesis" fillcolor="#CE93D8" color="#6A1B9A"]
        AlbConc [label="Serum Albumin\n(g/dL)" fillcolor="#AB47BC" color="#6A1B9A" fontcolor="white"]
        CoagFact [label="Clotting Factors\n(II,V,VII,IX,X)" fillcolor="#CE93D8" color="#6A1B9A"]
        INR [label="Prothrombin Time\n/ INR" fillcolor="#9C27B0" color="#6A1B9A" fontcolor="white"]
        BiliConj [label="Bilirubin\nConjugation" fillcolor="#CE93D8" color="#6A1B9A"]
        TotalBili [label="Total Bilirubin\n(mg/dL)" fillcolor="#9C27B0" color="#6A1B9A" fontcolor="white"]
        GlucMet [label="Glucose\nMetabolism" fillcolor="#E1BEE7" color="#6A1B9A"]
        NH3met [label="Ammonia\nDetoxification" fillcolor="#CE93D8" color="#6A1B9A"]
        Urea [label="Urea Cycle\nReduction" fillcolor="#E1BEE7" color="#6A1B9A"]
        GlutSyn [label="Glutamine\nSynthetase" fillcolor="#E1BEE7" color="#6A1B9A"]
        DrugMet [label="Drug Metabolism\n(CYP reduction)" fillcolor="#CE93D8" color="#6A1B9A"]
        ChildPugh [label="Child-Pugh Score\n(A/B/C)" fillcolor="#6A1B9A" color="#6A1B9A" fontcolor="white"]
        MELD [label="MELD Score\n(6-40)" fillcolor="#6A1B9A" color="#6A1B9A" fontcolor="white"]
        MELD_Na [label="MELD-Na Score" fillcolor="#7B1FA2" color="#6A1B9A" fontcolor="white"]
    }

    // ===================================================
    // SUBGRAPH 8: ASCITES & FLUID DYNAMICS
    // ===================================================
    subgraph cluster_ascites {
        label="Ascites & Sodium-Water Retention"
        style="filled,rounded"
        fillcolor="#E0F2F1"
        color="#004D40"
        fontcolor="#004D40"
        fontsize=13
        fontname="Helvetica-Bold"

        AscitesVol [label="Ascites Volume\n(Liters)" fillcolor="#80CBC4" color="#004D40"]
        StarlingForce [label="Starling Forces\nImbalance" fillcolor="#B2DFDB" color="#004D40"]
        LymphForm [label="Hepatic Lymph\nFormation ↑" fillcolor="#B2DFDB" color="#004D40"]
        RAAS_act [label="RAAS Activation\n(Aldosterone ↑)" fillcolor="#4DB6AC" color="#004D40" fontcolor="white"]
        Renin [label="Renin ↑\n(JUXTA cells)" fillcolor="#80CBC4" color="#004D40"]
        AngII [label="Angiotensin II ↑" fillcolor="#26A69A" color="#004D40" fontcolor="white"]
        Aldo [label="Aldosterone ↑\n(Na/K retention)" fillcolor="#00897B" color="#004D40" fontcolor="white"]
        AVP [label="AVP / ADH ↑\n(Free water retention)" fillcolor="#4DB6AC" color="#004D40" fontcolor="white"]
        SNS_act [label="Sympathetic NS\nActivation" fillcolor="#80CBC4" color="#004D40"]
        NaRetain [label="Renal Na+\nRetention" fillcolor="#00796B" color="#004D40" fontcolor="white"]
        WaterRetain [label="Free Water\nRetention" fillcolor="#80CBC4" color="#004D40"]
        HypoNa [label="Hyponatremia\n(< 130 mEq/L)" fillcolor="#004D40" color="#004D40" fontcolor="white"]
        OncoPres [label="Oncotic Pressure ↓\n(Low albumin)" fillcolor="#B2DFDB" color="#004D40"]
    }

    // ===================================================
    // SUBGRAPH 9: RENAL COMPLICATIONS (HRS)
    // ===================================================
    subgraph cluster_renal {
        label="Renal Complications (HRS / AKI)"
        style="filled,rounded"
        fillcolor="#FBE9E7"
        color="#BF360C"
        fontcolor="#BF360C"
        fontsize=13
        fontname="Helvetica-Bold"

        GFR_dec [label="GFR Decline\n(eGFR mL/min)" fillcolor="#FFAB91" color="#BF360C"]
        RenalVasoconst [label="Renal\nVasoconstriction" fillcolor="#FF7043" color="#BF360C" fontcolor="white"]
        HRS1 [label="HRS Type 1\n(Acute, Creatinine ×2)" fillcolor="#BF360C" color="#BF360C" fontcolor="white"]
        HRS2 [label="HRS Type 2\n(Moderate, refractory)" fillcolor="#D84315" color="#BF360C" fontcolor="white"]
        CreatRise [label="Creatinine ↑\n(mg/dL)" fillcolor="#FF8A65" color="#BF360C"]
        ATN [label="Acute Tubular\nNecrosis (ATN)" fillcolor="#FFAB91" color="#BF360C"]
        RenalNO [label="Renal NO\nDeficiency" fillcolor="#FFCCBC" color="#BF360C"]
        KidneyPG [label="Prostaglandins\n(Renal protective)" fillcolor="#FFCCBC" color="#BF360C"]
        Oliguria [label="Oliguria / Anuria" fillcolor="#FF5722" color="#BF360C" fontcolor="white"]
        BUN_rise [label="BUN / Urea\nElevation" fillcolor="#FFAB91" color="#BF360C"]
    }

    // ===================================================
    // SUBGRAPH 10: HEPATIC ENCEPHALOPATHY
    // ===================================================
    subgraph cluster_he {
        label="Hepatic Encephalopathy (HE)"
        style="filled,rounded"
        fillcolor="#EDE7F6"
        color="#311B92"
        fontcolor="#311B92"
        fontsize=13
        fontname="Helvetica-Bold"

        NH3_serum [label="Serum Ammonia ↑\n(μmol/L)" fillcolor="#B39DDB" color="#311B92"]
        GutFlora [label="Gut Bacteria\nAmmonia Production" fillcolor="#CE93D8" color="#311B92"]
        BactTrans [label="Bacterial\nTranslocation" fillcolor="#9575CD" color="#311B92" fontcolor="white"]
        BBB_perm [label="BBB Permeability ↑" fillcolor="#7E57C2" color="#311B92" fontcolor="white"]
        Astrocyte [label="Astrocyte\nSwelling / Dysfunction" fillcolor="#9575CD" color="#311B92" fontcolor="white"]
        GABA_sys [label="GABA-ergic\nSystem Enhancement" fillcolor="#B39DDB" color="#311B92"]
        BenzRecp [label="Endogenous\nBenzodiazepines" fillcolor="#C5CAE9" color="#311B92"]
        NeurInfl [label="Neuroinflammation\n(IL-1β, TNF-α)" fillcolor="#9575CD" color="#311B92" fontcolor="white"]
        HE_grade [label="HE Grade\n(West Haven 0-IV)" fillcolor="#311B92" color="#311B92" fontcolor="white"]
        CovertHE [label="Covert HE\n(Psychometric)" fillcolor="#5E35B1" color="#311B92" fontcolor="white"]
        Glutamine_brain [label="Brain Glutamine\nAccumulation" fillcolor="#B39DDB" color="#311B92"]
    }

    // ===================================================
    // SUBGRAPH 11: SYSTEMIC COMPLICATIONS
    // ===================================================
    subgraph cluster_systemic {
        label="Systemic Complications"
        style="filled,rounded"
        fillcolor="#ECEFF1"
        color="#37474F"
        fontcolor="#37474F"
        fontsize=13
        fontname="Helvetica-Bold"

        HPS [label="Hepatopulmonary\nSyndrome (HPS)" fillcolor="#B0BEC5" color="#37474F"]
        Porto_pulm [label="Portopulmonary\nHTN (PPH)" fillcolor="#B0BEC5" color="#37474F"]
        HCC [label="Hepatocellular\nCarcinoma (HCC)" fillcolor="#546E7A" color="#37474F" fontcolor="white"]
        ACLF [label="ACLF\n(Acute-on-Chronic LF)" fillcolor="#37474F" color="#37474F" fontcolor="white"]
        Coagulopathy [label="Coagulopathy &\nThrombocytopenia" fillcolor="#90A4AE" color="#37474F"]
        Malnutrit [label="Malnutrition &\nSarcopenia" fillcolor="#90A4AE" color="#37474F"]
        CirrhCard [label="Cirrhotic\nCardiomyopathy" fillcolor="#90A4AE" color="#37474F"]
        QTprolonged [label="QTc Prolongation" fillcolor="#B0BEC5" color="#37474F"]
        Adrenal_insuf [label="Adrenal\nInsufficiency" fillcolor="#B0BEC5" color="#37474F"]
        Infection_risk [label="Infection Risk ↑\n(Immune paresis)" fillcolor="#78909C" color="#37474F" fontcolor="white"]
        SIRS_inf [label="SIRS /\nSepsis Risk" fillcolor="#546E7A" color="#37474F" fontcolor="white"]
        Portal_throm [label="Portal Vein\nThrombosis" fillcolor="#78909C" color="#37474F" fontcolor="white"]
    }

    // ===================================================
    // SUBGRAPH 12: DRUG PK - NON-SELECTIVE BETA-BLOCKER (Propranolol/Carvedilol)
    // ===================================================
    subgraph cluster_nsbb {
        label="Drug PK/PD: Non-selective Beta-blocker (Propranolol/Carvedilol)"
        style="filled,rounded"
        fillcolor="#E8F5E9"
        color="#1A237E"
        fontcolor="#1A237E"
        fontsize=13
        fontname="Helvetica-Bold"

        NSBB_dose [label="Propranolol\nOral Dose" fillcolor="#A5D6A7" color="#1A237E" shape=hexagon]
        NSBB_abs [label="GI Absorption\n(F ~25%)" fillcolor="#C8E6C9" color="#1A237E"]
        NSBB_C1 [label="Central PK\nCompartment (C1)" fillcolor="#81C784" color="#1A237E"]
        NSBB_C2 [label="Peripheral PK\nCompartment (C2)" fillcolor="#A5D6A7" color="#1A237E"]
        NSBB_met [label="Hepatic 1st-Pass\nMetabolism (CYP2D6)" fillcolor="#66BB6A" color="#1A237E" fontcolor="white"]
        NSBB_beta1 [label="β1-Receptor\nBlockade (HR ↓)" fillcolor="#388E3C" color="#1A237E" fontcolor="white"]
        NSBB_beta2 [label="β2-Receptor\nBlockade (Splanchnic)" fillcolor="#388E3C" color="#1A237E" fontcolor="white"]
        NSBB_alpha [label="α1-Blockade\n(Carvedilol only)" fillcolor="#81C784" color="#1A237E"]
        NSBB_HR [label="Heart Rate ↓\n(Target 55-60 bpm)" fillcolor="#2E7D32" color="#1A237E" fontcolor="white"]
        NSBB_CO [label="Cardiac Output ↓\n(Splanchnic flow)" fillcolor="#1B5E20" color="#1A237E" fontcolor="white"]
        NSBB_HVPG [label="HVPG Reduction\n(Target ≥20% or <12 mmHg)" fillcolor="#004D40" color="#1A237E" fontcolor="white"]
    }

    // ===================================================
    // SUBGRAPH 13: DRUG PK - DIURETICS
    // ===================================================
    subgraph cluster_diuretics {
        label="Drug PK/PD: Diuretics (Spironolactone/Furosemide)"
        style="filled,rounded"
        fillcolor="#E3F2FD"
        color="#1565C0"
        fontcolor="#1565C0"
        fontsize=13
        fontname="Helvetica-Bold"

        Spiro_dose [label="Spironolactone\nOral Dose" fillcolor="#90CAF9" color="#1565C0" shape=hexagon]
        Furo_dose [label="Furosemide\nOral/IV Dose" fillcolor="#90CAF9" color="#1565C0" shape=hexagon]
        Spiro_abs [label="Spiro Absorption\n(F ~90%)" fillcolor="#BBDEFB" color="#1565C0"]
        Furo_abs [label="Furo Absorption\n(F ~60%)" fillcolor="#BBDEFB" color="#1565C0"]
        Spiro_met [label="Canrenone\n(Active Metabolite)" fillcolor="#64B5F6" color="#1565C0" fontcolor="white"]
        Spiro_MR [label="Aldosterone Receptor\nBlockade (MR)" fillcolor="#1565C0" color="#1565C0" fontcolor="white"]
        Furo_loop [label="Na-K-2Cl\nCotransporter Block" fillcolor="#42A5F5" color="#1565C0" fontcolor="white"]
        NaExcrete [label="Urinary Na+\nExcretion ↑" fillcolor="#64B5F6" color="#1565C0" fontcolor="white"]
        WtLoss [label="Body Weight\nReduction (kg)" fillcolor="#0D47A1" color="#1565C0" fontcolor="white"]
        AscitesReduction [label="Ascites Volume\nReduction" fillcolor="#0D47A1" color="#1565C0" fontcolor="white"]
        HyperK [label="Hyperkalemia Risk\n(Spiro)" fillcolor="#90CAF9" color="#1565C0"]
        HypoK [label="Hypokalemia Risk\n(Furosemide)" fillcolor="#90CAF9" color="#1565C0"]
    }

    // ===================================================
    // SUBGRAPH 14: DRUG PK - TERLIPRESSIN / VASOCONSTRICTORS
    // ===================================================
    subgraph cluster_vaso {
        label="Drug PK/PD: Vasoconstrictors (Terlipressin/Somatostatin)"
        style="filled,rounded"
        fillcolor="#FFF3E0"
        color="#E65100"
        fontcolor="#BF360C"
        fontsize=13
        fontname="Helvetica-Bold"

        Terlip_dose [label="Terlipressin IV\n(1-2 mg/4-6h)" fillcolor="#FFCC80" color="#BF360C" shape=hexagon]
        Somato_dose [label="Somatostatin/\nOctreotide Infusion" fillcolor="#FFCC80" color="#BF360C" shape=hexagon]
        Terlip_conv [label="Lysine-Vasopressin\n(Active form)" fillcolor="#FFB74D" color="#BF360C"]
        V1R [label="V1 Receptor\n(Splanchnic, renal)" fillcolor="#FF9800" color="#BF360C" fontcolor="white"]
        SSTR [label="Somatostatin\nReceptors (SSTR2)" fillcolor="#F57C00" color="#BF360C" fontcolor="white"]
        SplanchConst [label="Splanchnic\nVasoconstriction" fillcolor="#E65100" color="#BF360C" fontcolor="white"]
        PortalFlow_red [label="Portal Blood Flow ↓" fillcolor="#BF360C" color="#BF360C" fontcolor="white"]
        HVPG_red [label="HVPG Reduction\n(Acute)" fillcolor="#7F0000" color="#BF360C" fontcolor="white"]
