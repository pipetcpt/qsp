digraph AOSD_QSP {
    // Global graph settings
    rankdir=TB;
    splines=ortho;
    fontname="Helvetica";
    fontsize=11;
    nodesep=0.4;
    ranksep=0.6;
    compound=true;
    bgcolor="white";

    // Default node style
    node [fontname="Helvetica", fontsize=9, style=filled, shape=box];
    edge [fontname="Helvetica", fontsize=8];

    // =========================================================
    // CLUSTER 1: Innate Immune Triggers (DAMP/PAMP/TLR/RAGE)
    // =========================================================
    subgraph cluster_triggers {
        label="Innate Immune Triggers";
        style=filled;
        fillcolor="#FFF9C4";
        color="#F9A825";
        fontsize=12;
        fontname="Helvetica-Bold";

        DAMP [label="DAMPs\n(HMGB1, S100A8/A9\nHistones, HSP)", fillcolor="#FFEE58", color="#F9A825"];
        PAMP [label="PAMPs\n(LPS, dsRNA\nBacterial DNA)", fillcolor="#FFEE58", color="#F9A825"];
        S100A8 [label="S100A8/A9\n(Myeloid-Related\nProtein)", fillcolor="#FFD54F", color="#F9A825"];
        HMGB1 [label="HMGB1\n(High Mobility\nGroup Box 1)", fillcolor="#FFD54F", color="#F9A825"];
        URIC_ACID [label="Uric Acid\nCrystals (MSU)", fillcolor="#FFD54F", color="#F9A825"];

        TLR2 [label="TLR2\n(Toll-Like\nReceptor 2)", fillcolor="#FFA726", color="#E65100", shape=ellipse];
        TLR4 [label="TLR4\n(Toll-Like\nReceptor 4)", fillcolor="#FFA726", color="#E65100", shape=ellipse];
        TLR7 [label="TLR7\n(Toll-Like\nReceptor 7)", fillcolor="#FFA726", color="#E65100", shape=ellipse];
        TLR9 [label="TLR9\n(Toll-Like\nReceptor 9)", fillcolor="#FFA726", color="#E65100", shape=ellipse];
        RAGE [label="RAGE\n(Receptor for\nAdvanced Glycation\nEnd-products)", fillcolor="#FF8F00", color="#E65100", shape=ellipse];
        IL1R_TLR [label="IL-1R/TLR\nSignaling Complex", fillcolor="#FFB300", color="#E65100", shape=ellipse];

        MyD88 [label="MyD88\nAdaptor", fillcolor="#FF8F00", color="#E65100"];
        TRIF [label="TRIF\nAdaptor", fillcolor="#FF8F00", color="#E65100"];
        TRAF6 [label="TRAF6", fillcolor="#FFB74D", color="#E65100"];
        IRAK4 [label="IRAK4", fillcolor="#FFB74D", color="#E65100"];

        DAMP -> TLR2 [label="activates"];
        DAMP -> TLR4 [label="activates"];
        DAMP -> RAGE [label="binds"];
        PAMP -> TLR4 [label="activates"];
        PAMP -> TLR7 [label="activates"];
        PAMP -> TLR9 [label="activates"];
        S100A8 -> RAGE [label="binds"];
        S100A8 -> TLR4 [label="activates"];
        HMGB1 -> RAGE [label="binds"];
        HMGB1 -> TLR2 [label="binds"];
        HMGB1 -> TLR4 [label="binds"];
        URIC_ACID -> NLRP3 [label="activates", lhead=cluster_inflammasome];
        TLR4 -> MyD88 [label="recruits"];
        TLR4 -> TRIF [label="recruits"];
        TLR2 -> MyD88 [label="recruits"];
        TLR7 -> MyD88 [label="recruits"];
        TLR9 -> MyD88 [label="recruits"];
        MyD88 -> IRAK4 [label="activates"];
        IRAK4 -> TRAF6 [label="activates"];
        RAGE -> IL1R_TLR [label="co-activates"];
    }

    // =========================================================
    // CLUSTER 2: NLRP3 Inflammasome
    // =========================================================
    subgraph cluster_inflammasome {
        label="NLRP3 Inflammasome";
        style=filled;
        fillcolor="#FCE4EC";
        color="#C62828";
        fontsize=12;
        fontname="Helvetica-Bold";

        NLRP3 [label="NLRP3\n(Sensor)", fillcolor="#EF9A9A", color="#C62828", shape=ellipse];
        ASC [label="ASC\n(Adaptor)", fillcolor="#EF9A9A", color="#C62828"];
        CASP1 [label="Caspase-1\n(Effector)", fillcolor="#E57373", color="#C62828"];
        pro_IL1B [label="Pro-IL-1β\n(Precursor)", fillcolor="#FFCDD2", color="#C62828"];
        pro_IL18 [label="Pro-IL-18\n(Precursor)", fillcolor="#FFCDD2", color="#C62828"];
        GASDERMIN [label="Gasdermin D\n(Pyroptosis\nExecutor)", fillcolor="#EF5350", color="#B71C1C"];
        PYROPTOSIS [label="Pyroptosis\n(Cell Death)", fillcolor="#D32F2F", color="#B71C1C", fontcolor="white"];
        K_EFFLUX [label="K+ Efflux\n(NLRP3 Signal)", fillcolor="#FFCDD2", color="#C62828"];
        ROS_INFL [label="Mitochondrial\nROS", fillcolor="#FFCDD2", color="#C62828"];
        LYSOSOME [label="Lysosome\nDestabilization", fillcolor="#FFCDD2", color="#C62828"];
        NEK7 [label="NEK7\n(NLRP3\nActivator)", fillcolor="#F48FB1", color="#C62828"];

        K_EFFLUX -> NLRP3 [label="activates"];
        ROS_INFL -> NLRP3 [label="activates"];
        LYSOSOME -> NLRP3 [label="activates"];
        NEK7 -> NLRP3 [label="binds/activates"];
        NLRP3 -> ASC [label="nucleates"];
        ASC -> CASP1 [label="activates"];
        CASP1 -> pro_IL1B [label="cleaves"];
        CASP1 -> pro_IL18 [label="cleaves"];
        CASP1 -> GASDERMIN [label="cleaves/activates"];
        GASDERMIN -> PYROPTOSIS [label="induces"];
    }

    // =========================================================
    // CLUSTER 3: Macrophage / Monocyte Biology
    // =========================================================
    subgraph cluster_macrophage {
        label="Macrophage / Monocyte Activation";
        style=filled;
        fillcolor="#E8F5E9";
        color="#2E7D32";
        fontsize=12;
        fontname="Helvetica-Bold";

        MONO [label="Monocyte\n(Circulating)", fillcolor="#A5D6A7", color="#2E7D32", shape=ellipse];
        MACRO_M1 [label="M1 Macrophage\n(Pro-inflammatory)", fillcolor="#66BB6A", color="#2E7D32", shape=ellipse];
        MACRO_M2 [label="M2 Macrophage\n(Anti-inflammatory)", fillcolor="#81C784", color="#1B5E20", shape=ellipse];
        HEMOPHAGO [label="Hemophagocytic\nMacrophage\n(MAS)", fillcolor="#EF5350", color="#B71C1C", fontcolor="white", shape=ellipse];
        pDC [label="Plasmacytoid DC\n(pDC)", fillcolor="#C8E6C9", color="#2E7D32", shape=ellipse];
        mDC [label="Myeloid DC\n(mDC)", fillcolor="#C8E6C9", color="#2E7D32", shape=ellipse];
        NEUTROPHIL [label="Neutrophil\nActivation", fillcolor="#DCEDC8", color="#33691E", shape=ellipse];
        MAST [label="Mast Cell\nActivation", fillcolor="#DCEDC8", color="#33691E", shape=ellipse];
        NF_KB [label="NF-κB\n(Transcription\nFactor)", fillcolor="#43A047", color="#1B5E20", fontcolor="white"];
        AP1 [label="AP-1\n(Transcription\nFactor)", fillcolor="#43A047", color="#1B5E20", fontcolor="white"];
        IRF3 [label="IRF3\n(Interferon\nReg. Factor)", fillcolor="#43A047", color="#1B5E20", fontcolor="white"];
        IRF7 [label="IRF7\n(Interferon\nReg. Factor)", fillcolor="#43A047", color="#1B5E20", fontcolor="white"];
        FERRITIN_MAC [label="Ferritin\nSecretion\n(Macrophage)", fillcolor="#A5D6A7", color="#2E7D32"];
        PHAGOCYTOSIS [label="Enhanced\nPhagocytosis", fillcolor="#C8E6C9", color="#2E7D32"];

        MONO -> MACRO_M1 [label="differentiates\n(pro-inflam signal)"];
        MONO -> MACRO_M2 [label="differentiates\n(IL-4/IL-13)"];
        MACRO_M1 -> HEMOPHAGO [label="polarizes\n(cytokine storm)"];
        MACRO_M1 -> NF_KB [label="activates"];
        MACRO_M1 -> AP1 [label="activates"];
        MACRO_M1 -> FERRITIN_MAC [label="secretes"];
        NF_KB -> IRF3 [label="co-activates"];
        NF_KB -> IRF7 [label="co-activates"];
        pDC -> IRF7 [label="expresses"];
        mDC -> NF_KB [label="activates"];
        MACRO_M1 -> NEUTROPHIL [label="recruits"];
        MACRO_M1 -> PHAGOCYTOSIS [label="enhances"];
        HEMOPHAGO -> PHAGOCYTOSIS [label="excessive\nphagocytosis"];
    }

    // =========================================================
    // CLUSTER 4: Cytokine Network
    // =========================================================
    subgraph cluster_cytokines {
        label="Cytokine Network";
        style=filled;
        fillcolor="#E3F2FD";
        color="#1565C0";
        fontsize=12;
        fontname="Helvetica-Bold";

        IL1B [label="IL-1β\n(Interleukin-1β)", fillcolor="#90CAF9", color="#1565C0", shape=ellipse];
        IL6 [label="IL-6\n(Interleukin-6)", fillcolor="#64B5F6", color="#1565C0", shape=ellipse];
        IL18 [label="IL-18\n(Interleukin-18)", fillcolor="#42A5F5", color="#1565C0", shape=ellipse];
        IFNG [label="IFN-γ\n(Interferon-γ)", fillcolor="#2196F3", color="#0D47A1", fontcolor="white", shape=ellipse];
        TNF [label="TNF-α\n(Tumor Necrosis\nFactor-α)", fillcolor="#1E88E5", color="#0D47A1", fontcolor="white", shape=ellipse];
        IL12 [label="IL-12\n(Interleukin-12)", fillcolor="#90CAF9", color="#1565C0", shape=ellipse];
        IL15 [label="IL-15\n(Interleukin-15)", fillcolor="#90CAF9", color="#1565C0", shape=ellipse];
        IL2 [label="IL-2\n(T Cell Growth\nFactor)", fillcolor="#BBDEFB", color="#1565C0", shape=ellipse];
        IL10 [label="IL-10\n(Anti-inflammatory)", fillcolor="#B3E5FC", color="#0277BD", shape=ellipse];
        IL4 [label="IL-4\n(Th2/Anti-inflam)", fillcolor="#B3E5FC", color="#0277BD", shape=ellipse];
        IL17 [label="IL-17A\n(Interleukin-17A)", fillcolor="#81D4FA", color="#0277BD", shape=ellipse];
        IL23 [label="IL-23\n(Th17 Maintenance)", fillcolor="#81D4FA", color="#0277BD", shape=ellipse];
        MCSF [label="M-CSF\n(Macrophage\nCol.-Stim. Factor)", fillcolor="#BBDEFB", color="#1565C0", shape=ellipse];
        GM_CSF [label="GM-CSF\n(Granulocyte-Mac\nCSF)", fillcolor="#BBDEFB", color="#1565C0", shape=ellipse];
        IL1RA [label="IL-1Ra\n(IL-1 Receptor\nAntagonist)", fillcolor="#E1F5FE", color="#0277BD", shape=ellipse];
        IL33 [label="IL-33\n(Alarmin)", fillcolor="#90CAF9", color="#1565C0", shape=ellipse];
        MIF [label="MIF\n(Migration Inhib.\nFactor)", fillcolor="#BBDEFB", color="#1565C0", shape=ellipse];

        // Cytokine interactions
        IL1B -> IL6 [label="induces"];
        IL1B -> TNF [label="synergizes"];
        IL6 -> IL1B [label="amplifies"];
        IL18 -> IFNG [label="induces (with IL-12)"];
        IL12 -> IFNG [label="induces"];
        IL15 -> IFNG [label="induces"];
        IFNG -> TNF [label="synergizes"];
        TNF -> NF_KB [label="activates", lhead=cluster_macrophage];
        IL10 -> IL1B [label="inhibits"];
        IL10 -> TNF [label="inhibits"];
        IL4 -> IL6 [label="inhibits"];
        IL1RA -> IL1B [label="competes/blocks"];
        IL33 -> IL1B [label="amplifies\n(via ST2)"];
        MIF -> NF_KB [label="activates", lhead=cluster_macrophage];
        IL23 -> IL17 [label="maintains"];
    }

    // =========================================================
    // CLUSTER 5: JAK-STAT Signaling
    // =========================================================
    subgraph cluster_jak_stat {
        label="JAK-STAT Signaling";
        style=filled;
        fillcolor="#EDE7F6";
        color="#4527A0";
        fontsize=12;
        fontname="Helvetica-Bold";

        IL6R [label="IL-6R / gp130\n(Receptor)", fillcolor="#CE93D8", color="#4527A0", shape=ellipse];
        IFNGR [label="IFN-γR\n(Receptor)", fillcolor="#CE93D8", color="#4527A0", shape=ellipse];
        IL1R [label="IL-1R1\n(Receptor)", fillcolor="#CE93D8", color="#4527A0", shape=ellipse];
        IL18R [label="IL-18R\n(Receptor)", fillcolor="#CE93D8", color="#4527A0", shape=ellipse];
        JAK1 [label="JAK1", fillcolor="#AB47BC", color="#4527A0", fontcolor="white"];
        JAK2 [label="JAK2", fillcolor="#AB47BC", color="#4527A0", fontcolor="white"];
        TYK2 [label="TYK2", fillcolor="#AB47BC", color="#4527A0", fontcolor="white"];
        STAT1 [label="STAT1", fillcolor="#9C27B0", color="#4527A0", fontcolor="white"];
        STAT3 [label="STAT3", fillcolor="#9C27B0", color="#4527A0", fontcolor="white"];
        STAT4 [label="STAT4", fillcolor="#9C27B0", color="#4527A0", fontcolor="white"];
        SOCS1 [label="SOCS1\n(Suppressor of\nCytokine Signal)", fillcolor="#E1BEE7", color="#4527A0"];
        SOCS3 [label="SOCS3\n(Suppressor of\nCytokine Signal)", fillcolor="#E1BEE7", color="#4527A0"];
        PIAS [label="PIAS\n(STAT Inhibitor)", fillcolor="#E1BEE7", color="#4527A0"];
        JAK_GENES [label="Pro-inflammatory\nGene Expression\n(IRF1, GBP, CXCL)", fillcolor="#7B1FA2", color="#4527A0", fontcolor="white"];
        ACUTE_PHASE_GENES [label="Acute Phase\nProtein Genes\n(CRP, SAA, Fibrin)", fillcolor="#7B1FA2", color="#4527A0", fontcolor="white"];

        IL6 -> IL6R [label="binds", ltail=cluster_cytokines];
        IFNG -> IFNGR [label="binds", ltail=cluster_cytokines];
        IL1B -> IL1R [label="binds", ltail=cluster_cytokines];
        IL18 -> IL18R [label="binds", ltail=cluster_cytokines];
        IL6R -> JAK1 [label="activates"];
        IL6R -> TYK2 [label="activates"];
        IFNGR -> JAK1 [label="activates"];
        IFNGR -> JAK2 [label="activates"];
        JAK1 -> STAT3 [label="phosphorylates"];
        JAK1 -> STAT1 [label="phosphorylates"];
        JAK2 -> STAT4 [label="phosphorylates"];
        TYK2 -> STAT1 [label="phosphorylates"];
        STAT3 -> ACUTE_PHASE_GENES [label="transactivates"];
        STAT1 -> JAK_GENES [label="transactivates"];
        STAT4 -> IFNG [label="induces", lhead=cluster_cytokines];
        STAT3 -> SOCS3 [label="induces\n(feedback)"];
        STAT1 -> SOCS1 [label="induces\n(feedback)"];
        SOCS3 -> JAK1 [label="inhibits"];
        SOCS1 -> JAK2 [label="inhibits"];
        PIAS -> STAT1 [label="inhibits"];
        IL1R -> IRAK4 [label="recruits", lhead=cluster_triggers];
    }

    // =========================================================
    // CLUSTER 6: Adaptive Immunity (T/NK Cells)
    // =========================================================
    subgraph cluster_adaptive {
        label="Adaptive Immunity: T Cells / NK Cells";
        style=filled;
        fillcolor="#FFF3E0";
        color="#E65100";
        fontsize=12;
        fontname="Helvetica-Bold";

        NAIVE_T [label="Naive CD4+\nT Cell", fillcolor="#FFCC80", color="#E65100", shape=ellipse];
        TH1 [label="Th1 Cell\n(IL-12/IFN-γ\ndriven)", fillcolor="#FFA726", color="#E65100", shape=ellipse];
        TH17 [label="Th17 Cell\n(IL-23/IL-17\ndriven)", fillcolor="#FF9800", color="#E65100", shape=ellipse];
        TREG [label="Treg\n(Regulatory\nT Cell)", fillcolor="#FFE0B2", color="#BF360C", shape=ellipse];
        CD8 [label="CD8+\nCytotoxic T Cell\n(CTL)", fillcolor="#FFAB40", color="#E65100", shape=ellipse];
        NK [label="NK Cell\n(Natural Killer)", fillcolor="#FF8F00", color="#E65100", shape=ellipse];
        NKT [label="NKT Cell\n(Invariant)", fillcolor="#FF8F00", color="#E65100", shape=ellipse];
        PERFORIN [label="Perforin /\nGranzyme B\n(Cytotoxicity)", fillcolor="#EF6C00", color="#BF360C", fontcolor="white"];
        TBET [label="T-bet\n(Th1 TF)", fillcolor="#FFCC80", color="#E65100"];
        RORGT [label="RORγt\n(Th17 TF)", fillcolor="#FFCC80", color="#E65100"];
        FOXP3 [label="FOXP3\n(Treg TF)", fillcolor="#FFEE58", color="#F9A825"];
        NK_DEGEN [label="NK Cell\nDysfunction\n(MAS hallmark)", fillcolor="#D84315", color="#BF360C", fontcolor="white"];
        CD163 [label="CD163+\nHemophagocytic\nMarker", fillcolor="#FFB74D", color="#E65100"];

        NAIVE_T -> TH1 [label="IL-12/IL-18\ndifferentiation"];
        NAIVE_T -> TH17 [label="IL-23/TGF-β\ndifferentiation"];
        NAIVE_T -> TREG [label="TGF-β/IL-2\ndifferentiation"];
        TH1 -> TBET [label="expresses"];
        TH17 -> RORGT [label="expresses"];
        TREG -> FOXP3 [label="expresses"];
        TH1 -> IFNG [label="secretes", lhead=cluster_cytokines];
        TH1 -> TNF [label="secretes", lhead=cluster_cytokines];
        TH17 -> IL17 [label="secretes", lhead=cluster_cytokines];
        TREG -> IL10 [label="secretes", lhead=cluster_cytokines];
        TREG -> TH1 [label="suppresses"];
        TREG -> TH17 [label="suppresses"];
        NK -> PERFORIN [label="releases"];
        NK -> IFNG [label="secretes", lhead=cluster_cytokines];
        NKT -> IFNG [label="secretes", lhead=cluster_cytokines];
        NK -> NK_DEGEN [label="becomes\n(in MAS)"];
        CD8 -> PERFORIN [label="releases"];
        MACRO_M1 -> CD163 [label="upregulates", ltail=cluster_macrophage];
        HEMOPHAGO -> CD163 [label="expresses", ltail=cluster_macrophage];
    }

    // =========================================================
    // CLUSTER 7: Acute Phase Response
    // =========================================================
    subgraph cluster_acute_phase {
        label="Acute Phase Response";
        style=filled;
        fillcolor="#F3E5F5";
        color="#6A1B9A";
        fontsize=12;
        fontname="Helvetica-Bold";

        CRP [label="CRP\n(C-Reactive\nProtein)", fillcolor="#CE93D8", color="#6A1B9A"];
        SAA [label="SAA\n(Serum Amyloid A)", fillcolor="#CE93D8", color="#6A1B9A"];
        FERRITIN [label="Ferritin\n(Hyperferritinemia\n>1000 ng/mL)", fillcolor="#BA68C8", color="#6A1B9A", fontcolor="white"];
        FIBRINOGEN [label="Fibrinogen\n(Coagulation)", fillcolor="#CE93D8", color="#6A1B9A"];
        HEPCIDIN [label="Hepcidin\n(Iron Regulation)", fillcolor="#CE93D8", color="#6A1B9A"];
        ALBUMIN_LOW [label="Albumin ↓\n(Negative APP)", fillcolor="#E1BEE7", color="#6A1B9A"];
        COMPLEMENT [label="Complement\nActivation\n(C3/C4/CH50)", fillcolor="#CE93D8", color="#6A1B9A"];
        ESR [label="ESR\n(Erythrocyte\nSedimentation\nRate)", fillcolor="#E1BEE7", color="#6A1B9A"];
        WBC [label="Leukocytosis\n(WBC >10K\nneutrophilia)", fillcolor="#E1BEE7", color="#6A1B9A"];
        GLYCO_FERRITIN [label="Glycosylated\nFerritin <20%\n(AOSD marker)", fillcolor="#7B1FA2", color="#4A148C", fontcolor="white"];
        LIVER_ENZ [label="Liver Enzymes ↑\n(AST/ALT/LDH)", fillcolor="#E1BEE7", color="#6A1B9A"];
        COAG [label="Coagulopathy\n(DIC in MAS)", fillcolor="#AB47BC", color="#6A1B9A", fontcolor="white"];

        ACUTE_PHASE_GENES -> CRP [label="induces", ltail=cluster_jak_stat];
        ACUTE_PHASE_GENES -> SAA [label="induces", ltail=cluster_jak_stat];
        ACUTE_PHASE_GENES -> FIBRINOGEN [label="induces", ltail=cluster_jak_stat];
        IL6 -> CRP [label="induces", ltail=cluster_cytokines];
        IL6 -> SAA [label="induces", ltail=cluster_cytokines];
        IL6 -> FERRITIN [label="induces", ltail=cluster_cytokines];
        IL6 -> HEPCIDIN [label="induces", ltail=cluster_cytokines];
        IL1B -> FERRITIN [label="induces", ltail=cluster_cytokines];
        TNF -> FERRITIN [label="induces", ltail=cluster_cytokines];
        FERRITIN -> GLYCO_FERRITIN [label="glycosylation\n(AOSD: decreased)"];
        IL6 -> ALBUMIN_LOW [label="suppresses", ltail=cluster_cytokines];
        CRP -> COMPLEMENT [label="activates"];
        CRP -> ESR [label="elevates"];
        IL1B -> WBC [label="promotes", ltail=cluster_cytokines];
        GM_CSF -> WBC [label="stimulates", ltail=cluster_cytokines];
        HEMOPHAGO -> COAG [label="triggers", ltail=cluster_macrophage];
        HEMOPHAGO -> LIVER_ENZ [label="elevates", ltail=cluster_macrophage];
    }

    // =========================================================
    // CLUSTER 8: Clinical Manifestations
    // =========================================================
    subgraph cluster_clinical {
        label="Clinical Manifestations";
        style=filled;
        fillcolor="#E8EAF6";
        color="#283593";
        fontsize=12;
        fontname="Helvetica-Bold";

        FEVER [label="Quotidian Fever\n(≥39°C, daily\nevening spike)", fillcolor="#7986CB", color="#283593", fontcolor="white"];
        RASH [label="Salmon-Colored\nEvanescent Rash\n(maculopapular)", fillcolor="#9FA8DA", color="#283593"];
        ARTHRITIS [label="Arthritis /\nArthralgia\n(polyarticular)", fillcolor="#7986CB", color="#283593", fontcolor="white"];
        LYMPH [label="Lymphadenopathy\n(generalized)", fillcolor="#9FA8DA", color="#283593"];
        SPLEENO [label="Splenomegaly", fillcolor="#9FA8DA", color="#283593"];
        HEPTO [label="Hepatomegaly", fillcolor="#9FA8DA", color="#283593"];
        SERO [label="Serositis\n(pleuritis/\npericarditis)", fillcolor="#7986CB", color="#283593", fontcolor="white"];
        PHARYNGITIS [label="Sore Throat /\nPharyngitis", fillcolor="#9FA8DA", color="#283593"];
        MYALGIA [label="Myalgia", fillcolor="#C5CAE9", color="#283593"];
        JOINT_DEST [label="Joint Destruction\n(chronic articular\ndisease)", fillcolor="#3949AB", color="#283593", fontcolor="white"];
        AMYLOID [label="Reactive\nAmyloidosis\n(AA amyloid, rare)", fillcolor="#C5CAE9", color="#283593"];

        IL1B -> FEVER [label="induces\n(hypothalamic\nPGE2)", ltail=cluster_cytokines];
        IL6 -> FEVER [label="induces", ltail=cluster_cytokines];
        TNF -> FEVER [label="induces", ltail=cluster_cytokines];
        IL1B -> RASH [label="contributes", ltail=cluster_cytokines];
        IL1B -> ARTHRITIS [label="mediates\ninflammation", ltail=cluster_cytokines];
        TNF -> ARTHRITIS [label="mediates", ltail=cluster_cytokines];
        IL17 -> ARTHRITIS [label="amplifies", ltail=cluster_cytokines];
        IL1B -> SERO [label="induces", ltail=cluster_cytokines];
        IL6 -> LYMPH [label="drives\nlymphocyte\nproliferation", ltail=cluster_cytokines];
        MCSF -> SPLEENO [label="drives\nmyeloid\nexpansion", ltail=cluster_cytokines];
        TNF -> JOINT_DEST [label="causes\ncartilage/bone\nerosion", ltail=cluster_cytokines];
        IL17 -> JOINT_DEST [label="osteoclast\nactivation", ltail=cluster_cytokines];
        SAA -> AMYLOID [label="deposits as\nAA amyloid", ltail=cluster_acute_phase];
        FERRITIN -> HEPTO [label="iron\noverload", ltail=cluster_acute_phase];
        WBC -> PHARYNGITIS [label="associates", ltail=cluster_acute_phase];
        IL6 -> MYALGIA [label="contributes", ltail=cluster_cytokines];
    }

    // =========================================================
    // CLUSTER 9: Macrophage Activation Syndrome (MAS)
    // =========================================================
    subgraph cluster_mas {
        label="Macrophage Activation Syndrome (MAS)";
        style=filled;
        fillcolor="#FFEBEE";
        color="#B71C1C";
        fontsize=12;
        fontname="Helvetica-Bold";

        MAS_TRIGGER [label="MAS Trigger\n(infection/drug/\ndisease flare)", fillcolor="#FFCDD2", color="#B71C1C"];
        CYTOKINE_STORM [label="Cytokine Storm\n(IL-1β/IL-6/IL-18/\nIFN-γ surge)", fillcolor="#EF9A9A", color="#B71C1C"];
        NK_FAIL [label="NK/CTL\nCytotoxicity\nFailure\n(PRF1/HAVC2\ndefects)", fillcolor="#EF9A9A", color="#B71C1C"];
        HYPER_FERRIT [label="Extreme\nHyperferritinemia\n(>10,000 ng/mL)", fillcolor="#E57373", color="#B71C1C", fontcolor="white"];
        PANCYTO [label="Pancytopenia\n(BM hemophagocytosis)", fillcolor="#E53935", color="#B71C1C", fontcolor="white"];
        HLAB_OVEREXP [label="HLA-DR+CD163+\nMacrophage\nExpansion", fillcolor="#EF9A9A", color="#B71C1C"];
        ORGAN_FAIL [label="Multi-organ\nFailure\n(liver/CNS/kidney)", fillcolor="#C62828", color="#B71C1C", fontcolor="white"];
        DIC [label="DIC\n(Disseminated\nIntravascular\nCoagulation)", fillcolor="#C62828", color="#B71C1C", fontcolor="white"];
        IL18_HIGH [label="IL-18 Extreme\nElevation\n(MAS biomarker)", fillcolor="#EF9A9A", color="#B71C1C"];
        CXCL9 [label="CXCL9\n(IFN-γ biomarker,\nMAS indicator)", fillcolor="#FFCDD2", color="#B71C1C"];
        PRF1_MUT [label="PRF1/UNC13D\nMutations\n(genetic risk)", fillcolor="#FFCDD2", color="#B71C1C"];

        MAS_TRIGGER -> CYTOKINE_STORM [label="precipitates"];
        MAS_TRIGGER -> NK_FAIL [label="aggravates"];
        PRF1_MUT -> NK_FAIL [label="causes"];
        NK_FAIL -> CYTOKINE_STORM [label="uncontrolled\nactivation"];
        CYTOKINE_STORM -> HYPER_FERRIT [label="drives"];
        CYTOKINE_STORM -> PANCYTO [label="induces\nhemophagocytosis"];
        CYTOKINE_STORM -> ORGAN_FAIL [label="causes"];
        CYTOKINE_STORM -> DIC [label="induces"];
        HEMOPHAGO -> PANCYTO [label="causes", ltail=cluster_macrophage];
        HEMOPHAGO -> HLAB_OVEREXP [label="upregulates", ltail=cluster_macrophage];
        IL18 -> IL18_HIGH [label="extreme\nelevation", ltail=cluster_cytokines];
        IFNG -> CXCL9 [label="induces", ltail=cluster_cytokines];
        IL18_HIGH -> CYTOKINE_STORM [label="amplifies"];
        CXCL9 -> NK_FAIL [label="marker\nof failed\nsuppression"];
    }

    // =========================================================
    // CLUSTER 10: Drug PK/PD — NSAIDs & Corticosteroids
    // =========================================================
    subgraph cluster_drugs_cs {
        label="Drug PK/PD: NSAIDs & Corticosteroids";
        style=filled;
        fillcolor="#E0F2F1";
        color="#00695C";
        fontsize=12;
        fontname="Helvetica-Bold";

        NSAID [label="NSAIDs\n(Naproxen\nIndomethacin)", fillcolor="#80CBC4", color="#00695C", shape=parallelogram];
        COX1 [label="COX-1\n(Cyclooxygenase-1)", fillcolor="#B2DFDB", color="#00695C", shape=ellipse];
        COX2 [label="COX-2\n(Cyclooxygenase-2)", fillcolor="#B2DFDB", color="#00695C", shape=ellipse];
        PGE2 [label="PGE2\n(Prostaglandin E2\nfever mediator)", fillcolor="#4DB6AC", color="#00695C"];
        NSAID_GI [label="GI Toxicity\n(NSAID side\neffect)", fillcolor="#80CBC4", color="#00695C"];

        PRED [label="Prednisone /\nPrednisolone\n(CS)", fillcolor="#26A69A", color="#004D40", fontcolor="white", shape=parallelogram];
        DEXA [label="Dexamethasone\n(pulse CS)", fillcolor="#26A69A", color="#004D40", fontcolor="white", shape=parallelogram];
        GR [label="Glucocorticoid\nReceptor (GR)", fillcolor="#B2DFDB", color="#00695C", shape=ellipse];
        GRE [label="GRE\n(Glucocorticoid\nResponse Element)", fillcolor="#80CBC4", color="#00695C"];
        GC_EFFECT [label="GC Anti-inflam\nEffects\n(NF-κB inhibition\nAPP suppression)", fillcolor="#00796B", color="#004D40", fontcolor="white"];
        GC_SE [label="GC Side Effects\n(hyperglycemia\nosteoporosis\ninfection)", fillcolor="#4DB6AC", color="#00695C"];
        HPA_AXIS [label="HPA Axis\nSuppression", fillcolor="#80CBC4", color="#00695C"];

        NSAID -> COX1 [label="inhibits"];
        NSAID -> COX2 [label="inhibits"];
        COX1 -> PGE2 [label="produces"];
        COX2 -> PGE2 [label="produces"];
        PGE2 -> FEVER [label="mediates\nhypothalamic\nfever", lhead=cluster_clinical];
        NSAID -> PGE2 [label="reduces\n(via COX inhibition)"];
        NSAID -> NSAID_GI [label="causes"];
        PRED -> GR [label="binds/activates"];
        DEXA -> GR [label="binds/activates"];
        GR -> GRE [label="translocates/binds"];
        GRE -> GC_EFFECT [label="drives"];
        GC_EFFECT -> NF_KB [label="inhibits", lhead=cluster_macrophage];
        GC_EFFECT -> IL1B [label="inhibits", lhead=cluster_cytokines];
        GC_EFFECT -> IL6 [label="inhibits", lhead=cluster_cytokines];
        GC_EFFECT -> TNF [label="inhibits", lhead=cluster_cytokines];
        GR -> HPA_AXIS [label="suppresses"];
        PRED -> GC_SE [label="causes\n(chronic)"];
    }

    // =========================================================
    // CLUSTER 11: Drug PK/PD — DMARDs (MTX / CsA)
    // =========================================================
    subgraph cluster_drugs_dmard {
        label="Drug PK/PD: DMARDs (MTX / CsA)";
        style=filled;
        fillcolor="#FFF8E1";
        color="#F57F17";
        fontsize=12;
        fontname="Helvetica-Bold";

        MTX [label="Methotrexate\n(MTX, low-dose)", fillcolor="#FFE082", color="#F57F17", shape=parallelogram];
        MTX_PLY [label="MTX-Polyglutamates\n(active metabolite,\nintracellular)", fillcolor="#FFD54F", color="#F57F17"];
        DHFR [label="DHFR\n(Dihydrofolate\nReductase)", fillcolor="#FFE0B2", color="#F57F17", shape=ellipse];
        AICAR [label="AICAR\n(adenosine-mediated\nanti-inflam)", fillcolor="#FFD54F", color="#F57F17"];
        ADENOSINE [label="Adenosine\n(anti-inflammatory)", fillcolor="#FFC107", color="#F57F17"];
        MTX_TOX [label="MTX Toxicity\n(hepatotoxicity\npneumonitis\nGI)", fillcolor="#FFE082", color="#F57F17"];

        CSA [label="Cyclosporine A\n(CsA, MAS use)", fillcolor="#FFB300", color="#E65100", fontcolor="white", shape=parallelogram];
        CYCLOPHILIN [label="Cyclophilin\n(CsA receptor)", fillcolor="#FFE0B2", color="#F57F17", shape=ellipse];
        CALCINEURIN [label="Calcineurin\n(phosphatase)", fillcolor="#FFE0B2", color="#F57F17", shape=ellipse];
        NFAT [label="NFAT\n(T Cell TF)", fillcolor="#FFD54F", color="#F57F17"];
        IL2_INHIB [label="IL-2 Inhibition\n(T cell\nsuppression)", fillcolor="#FFC107", color="#F57F17"];
        CSA_TOX [label="CsA Toxicity\n(nephrotoxicity\nhypertension)", fillcolor="#FFE082", color="#F57F17"];

        MTX -> MTX_PLY [label="converted to\n(liver)"];
        MTX_PLY -> DHFR [label="inhibits"];
        MTX_PLY -> AICAR [label="accumulates"];
        AICAR -> ADENOSINE [label="increases"];
        ADENOSINE -> IL1B [label="inhibits", lhead=cluster_cytokines];
        ADENOSINE -> TNF [label="inhibits", lhead=cluster_cytokines];
        DHFR -> MTX_TOX [label="folate\ndepletion\ncauses"];
        MTX -> MACRO_M1 [label="suppresses\nactivation", lhead=cluster_macrophage];
        CSA -> CYCLOPHILIN [label="binds"];
        CYCLOPHILIN -> CALCINEURIN [label="inhibits"];
        CALCINEURIN -> NFAT [label="cannot\ndephosphorylate"];
        NFAT -> IL2_INHIB [label="transcription\nblocked"];
        IL2_INHIB -> TH1 [label="suppresses", lhead=cluster_adaptive];
        IL2_INHIB -> TH17 [label="suppresses", lhead=cluster_adaptive];
        CSA -> NK [label="partially\nrestores\ncytotoxicity\n(MAS)", lhead=cluster_adaptive];
        CSA -> CSA_TOX [label="causes"];
    }

    // =========================================================
    // CLUSTER 12: Drug PK/PD — Biologics (IL-1/IL-6 Inhibitors)
    // =========================================================
    subgraph cluster_drugs_biologic {
        label="Drug PK/PD: Biologics (Anti-IL-1 / Anti-IL-6)";
        style=filled;
        fillcolor="#E8EAF6";
        color="#1A237E";
        fontsize=12;
        fontname="Helvetica-Bold";

        ANAKINRA [label="Anakinra\n(IL-1Ra, recombinant\nsc daily, t1/2=4-6h)", fillcolor="#7986CB", color="#1A237E", fontcolor="white", shape=parallelogram];
        CANAKIN [label="Canakinumab\n(anti-IL-1β mAb\nsc q8w, t1/2=26d)", fillcolor="#5C6BC0", color="#1A237E", fontcolor="white", shape=parallelogram];
        RILONACEPT [label="Rilonacept\n(IL-1 Trap\nsc weekly)", fillcolor="#7986CB", color="#1A237E", fontcolor="white", shape=parallelogram];
        TCZ [label="Tocilizumab\n(anti-IL-6R mAb\niv/sc, t1/2=13d)", fillcolor="#3949AB", color="#1A237E", fontcolor="white", shape=parallelogram];
        SARIL [label="Sarilumab\n(anti-IL-6R mAb)", fillcolor="#3949AB", color="#1A237E", fontcolor="white", shape=parallelogram];
        SILI [label="Siltuximab\n(anti-IL-6 mAb)", fillcolor="#3F51B5", color="#1A237E", fontcolor="white", shape=parallelogram];

        ANA_PK [label="Anakinra PK\nCmax: rapid\nt1/2: 4-6h\nrenal clearance", fillcolor="#9FA8DA", color="#1A237E"];
        CAN_PK [label="Canakinumab PK\nt1/2: ~26 days\nlinear PK\nlow clearance", fillcolor="#9FA8DA", color="#1A237E"];
        TCZ_PK [label="Tocilizumab PK\nt1/2: 8-14 days\nnon-linear PK\nIL-6R mediated", fillcolor="#9FA8DA", color="#1A237E"];

        ANAKINRA -> IL1R [label="competes with\nIL-1β (blocks)", lhead=cluster_jak_stat];
        CANAKIN -> IL1B [label="neutralizes\n(high affinity)", lhead=cluster_cytokines];
        RILONACEPT -> IL1B [label="sequesters", lhead=cluster_cytokines];
        TCZ -> IL6R [label="blocks\n(soluble+membrane)", lhead=cluster_jak_stat];
        SARIL -> IL6R [label="blocks", lhead=cluster_jak_stat];
        SILI -> IL6 [label="neutralizes", lhead=cluster_cytokines];
        ANAKINRA -> ANA_PK [label="describes"];
        CANAKIN -> CAN_PK [label="describes"];
        TCZ -> TCZ_PK [label="describes"];
        ANA_PK -> FEVER [label="rapid\nonset\ncontrol", lhead=cluster_clinical];
        CAN_PK -> FEVER [label="sustained\ncontrol", lhead=cluster_clinical];
        TCZ_PK -> ACUTE_PHASE_GENES [label="blocks\n(CRP/SAA\nnormalize)", lhead=cluster_jak_stat];
    }

    // =========================================================
    // CLUSTER 13: Drug PK/PD — JAK Inhibitors
    // =========================================================
    subgraph cluster_drugs_jaki {
        label="Drug PK/PD: JAK Inhibitors & Anti-TNF";
        style=filled;
        fillcolor="#F1F8E9";
        color="#33691E";
        fontsize=12;
        fontname="Helvetica-Bold";

        TOFACITINIB [label="Tofacitinib\n(JAK1/3 inhib\npo BID, t1/2=3h)", fillcolor="#AED581", color="#33691E", shape=parallelogram];
        BARICITINIB [label="Baricitinib\n(JAK1/2 inhib\npo OD, t1/2=12h)", fillcolor="#AED581", color="#33691E", shape=parallelogram];
        RUXOLITINIB [label="Ruxolitinib\n(JAK1/2 inhib\nMAS rescue)", fillcolor="#9CCC65", color="#33691E", shape=parallelogram];
        UPADACITINIB [label="Upadacitinib\n(JAK1-selective\npo OD)", fillcolor="#AED581", color="#33691E", shape=parallelogram];

        TOFA_PK [label="Tofacitinib PK\nTmax: 0.5-1h\nt1/2: ~3h\nCYP3A4 metab", fillcolor="#DCEDC8", color="#33691E"];
        JAKI_EFFECT [label="JAK Inhibition\nEffects\n(pan-cytokine\nsuppression)", fillcolor="#7CB342", color="#33691E", fontcolor="white"];
        JAKI_SE [label="JAKi Side Effects\n(infections, VTE\nlipid changes)", fillcolor="#DCEDC8", color="#33691E"];

        TOFACITINIB -> TOFA_PK [label="describes"];
        TOFACITINIB -> JAK1 [label="inhibits", lhead=cluster_jak_stat];
        BARICITINIB -> JAK1 [label="inhibits", lhead=cluster_jak_stat];
        BARICITINIB -> JAK2 [label="inhibits", lhead=cluster_jak_stat];
        RUXOLITINIB -> JAK1 [label="inhibits\n(MAS)", lhead=cluster_jak_stat];
        RUXOLITINIB -> JAK2 [label="inhibits\n(MAS)", lhead=cluster_jak_stat];
        UPADACITINIB -> JAK1 [label="selectively\ninhibits", lhead=cluster_jak_stat];
        TOFACITINIB -> JAKI_EFFECT [label="exerts"];
        BARICITINIB -> JAKI_EFFECT [label="exerts"];
        JAKI_EFFECT -> STAT1 [label="reduces\nphosphorylation", lhead=cluster_jak_stat];
        JAKI_EFFECT -> STAT3 [label="reduces\nphosphorylation", lhead=cluster_jak_stat];
        JAKI_EFFECT -> IFNG [label="reduces\nproduction", lhead=cluster_cytokines];
        JAKI_EFFECT -> IL6 [label="reduces\ndownstream", lhead=cluster_cytokines];
        JAKI_EFFECT -> JAKI_SE [label="associated\nrisks"];
        RUXOLITINIB -> CYTOKINE_STORM [label="controls\n(MAS rescue)", lhead=cluster_mas];
    }

    // =========================================================
    // Cross-cluster connections (major pathways)
    // =========================================================

    // Triggers → NLRP3
    TRAF6 -> NF_KB [label="activates", lhead=cluster_macrophage];
    TRAF6 -> NLRP3 [label="primes\n(signal 1)", lhead=cluster_inflammasome];

    // NLRP3 products → Cytokines
    pro_IL1B -> IL1B [label="matures to", lhead=cluster_cytokines];
    pro_IL18 -> IL18 [label="matures to", lhead=cluster_cytokines];

    // Macrophage → NF-κB → cytokines
    NF_KB -> IL1B [label="transcribes", lhead=cluster_cytokines];
    NF_KB -> IL6 [label="transcribes", lhead=cluster_cytokines];
    NF_KB -> TNF [label="transcribes", lhead=cluster_cytokines];
    NF_KB -> pro_IL1B [label="transcribes\n(Signal 1)", lhead=cluster_inflammasome];
    NF_KB -> NLRP3 [label="primes\n(Signal 1)", lhead=cluster_inflammasome];

    // Macrophage → Cytokines
    MACRO_M1 -> IL12 [label="secretes", ltail=cluster_macrophage, lhead=cluster_cytokines];
    MACRO_M1 -> IL18 [label="secretes", ltail=cluster_macrophage, lhead=cluster_cytokines];
    MACRO_M1 -> IL15 [label="secretes", ltail=cluster_macrophage, lhead=cluster_cytokines];
    MACRO_M1 -> MCSF [label="secretes", ltail=cluster_macrophage, lhead=cluster_cytokines];
    MACRO_M1 -> GM_CSF [label="secretes", ltail=cluster_macrophage, lhead=cluster_cytokines];
    MACRO_M1 -> IL1B [label="secretes", ltail=cluster_macrophage, lhead=cluster_cytokines];
    MACRO_M1 -> TNF [label="secretes", ltail=cluster_macrophage, lhead=cluster_cytokines];

    // Adaptive → Macrophage feedback
    IFNG -> MACRO_M1 [label="activates\n(M1 polarization)", ltail=cluster_adaptive, lhead=cluster_macrophage];
    TNF -> MACRO_M1 [label="activates", ltail=cluster_cytokines, lhead=cluster_macrophage];
    IL4 -> MACRO_M2 [label="promotes", ltail=cluster_cytokines, lhead=cluster_macrophage];

    // Cytokines → Adaptive
    IL12 -> TH1 [label="drives", ltail=cluster_cytokines, lhead=cluster_adaptive];
    IL18 -> TH1 [label="co-stimulates", ltail=cluster_cytokines, lhead=cluster_adaptive];
    IL12 -> NK [label="activates", ltail=cluster_cytokines, lhead=cluster_adaptive];
    IL15 -> NK [label="maintains", ltail=cluster_cytokines, lhead=cluster_adaptive];
    IL2 -> TREG [label="supports", ltail=cluster_cytokines, lhead=cluster_adaptive];
    IL23 -> TH17 [label="maintains", ltail=cluster_cytokines, lhead=cluster_adaptive];

    // MAS connection
    CYTOKINE_STORM -> HEMOPHAGO [label="drives\nhemophagocytosis", lhead=cluster_macrophage];
    IFNG -> HEMOPHAGO [label="activates", ltail=cluster_cytokines, lhead=cluster_macrophage];
    IL18 -> MAS_TRIGGER [label="extreme\nelevation\nprecedes", ltail=cluster_cytokines, lhead=cluster_mas];

    // Acute phase → Clinical
    FERRITIN -> FEVER [label="marker\n(not causal)", ltail=cluster_acute_phase, lhead=cluster_clinical];
    COAG -> DIC [label="progresses to", ltail=cluster_acute_phase, lhead=cluster_mas];

    // Drug effects on inflammasome
    ANAKINRA -> CASP1 [label="downstream\nblockade", ltail=cluster_drugs_biologic, lhead=cluster_inflammasome];
    CANAKIN -> CASP1 [label="downstream\nblockade", ltail=cluster_drugs_biologic, lhead=cluster_inflammasome];
}
