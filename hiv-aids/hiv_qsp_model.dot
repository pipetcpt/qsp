digraph HIV_QSP_Model {
    rankdir=TB;
    compound=true;
    splines=ortho;
    nodesep=0.35;
    ranksep=0.55;
    fontname="Helvetica";
    node [fontname="Helvetica", fontsize=9, style="filled,rounded", shape=box];
    edge [fontname="Helvetica", fontsize=7, arrowsize=0.7];

    // ─────────────────────────────────────────────────────────
    // CLUSTER 1: VIRAL ENTRY & CORECEPTOR TROPISM
    // ─────────────────────────────────────────────────────────
    subgraph cluster_viral_entry {
        label="① Viral Entry & Coreceptor Tropism";
        style="filled,rounded";
        fillcolor="#FFF0F5";
        color="#CC0044";
        fontsize=11; fontcolor="#CC0044";

        CD4_receptor     [label="CD4 Receptor\n(主受容体)", fillcolor="#FFB3C6"];
        CCR5_coreceptor  [label="CCR5 Coreceptor\n(R5-tropic)", fillcolor="#FFB3C6"];
        CXCR4_coreceptor [label="CXCR4 Coreceptor\n(X4-tropic)", fillcolor="#FFB3C6"];
        gp120_envelope   [label="gp120 Envelope\nProtein (SU)", fillcolor="#FF99BB"];
        gp41_TM          [label="gp41 TM Protein\n(Fusion peptide)", fillcolor="#FF99BB"];
        V3_loop          [label="V3 Loop\n(Tropism determinant)", fillcolor="#FFCCDD"];
        gp120_CD4_complex[label="gp120-CD4\nComplex", fillcolor="#FFB3C6"];
        conformational_change [label="Conformational\nChange gp41", fillcolor="#FFCCDD"];
        Fusion_pore      [label="Membrane Fusion\nPore Formation", fillcolor="#FF8899"];
        Viral_uncoating  [label="Viral Uncoating\n& Core Release", fillcolor="#FFB3C6"];
        CD4_downreg      [label="CD4 Down-\nregulation (Nef/Vpu)", fillcolor="#FFCCDD"];
        CXCR4_downreg    [label="CXCR4/CCR5\nDown-regulation", fillcolor="#FFCCDD"];
        Tropism_switch   [label="R5→X4 Tropism\nSwitch (Late Disease)", fillcolor="#FF8899"];
    }

    // ─────────────────────────────────────────────────────────
    // CLUSTER 2: VIRAL REPLICATION CYCLE
    // ─────────────────────────────────────────────────────────
    subgraph cluster_viral_replication {
        label="② HIV Replication Cycle";
        style="filled,rounded";
        fillcolor="#FFF8EE";
        color="#CC6600";
        fontsize=11; fontcolor="#CC6600";

        HIV_RNA          [label="HIV RNA Genome\n(+ssRNA, 9.7 kb)", fillcolor="#FFD599"];
        Reverse_transcriptase [label="Reverse Transcriptase\n(RT p51/p66)", fillcolor="#FFB347"];
        ssDNA_minus      [label="(-) ssDNA\nIntermediate", fillcolor="#FFCC88"];
        dsDNA            [label="dsDNA\n(Linear)", fillcolor="#FFCC88"];
        PIC              [label="Pre-Integration\nComplex (PIC)", fillcolor="#FFB347"];
        Integrase        [label="HIV Integrase\n(IN p32)", fillcolor="#FFB347"];
        Proviral_DNA     [label="Proviral DNA\n(Integrated)", fillcolor="#FF9900"];
        HIV_LTR          [label="HIV LTR\nPromoter (5'/3')", fillcolor="#FFD599"];
        Tat_Trans        [label="Tat Transactivation\n(TAR-Tat-P-TEFb)", fillcolor="#FFB347"];
        Rev_export       [label="Rev-RRE Nuclear\nExport (Unspliced RNA)", fillcolor="#FFB347"];
        Nef_protein      [label="Nef Protein\n(CD4/MHC down)", fillcolor="#FFCC88"];
        Vif_protein      [label="Vif Protein\n(APOBEC3G degradation)", fillcolor="#FFCC88"];
        Vpr_protein      [label="Vpr Protein\n(G2 arrest/nuclear import)", fillcolor="#FFCC88"];
        Vpu_protein      [label="Vpu Protein\n(BST-2/Tetherin antag)", fillcolor="#FFCC88"];
        Gag_precursor    [label="Gag Pr55\nPrecursor", fillcolor="#FFB347"];
        Pol_precursor    [label="Gag-Pol Pr160\nPolyprotein", fillcolor="#FFB347"];
        HIV_Protease     [label="HIV Protease\n(PR p11 dimer)", fillcolor="#FF9900"];
        Capsid_assembly  [label="Capsid & Virion\nAssembly", fillcolor="#FFB347"];
        Budding          [label="Virion Budding\n& Release", fillcolor="#FFB347"];
        Mature_virus     [label="Mature HIV\nVirion", fillcolor="#FF8800"];
        APOBEC3G_effect  [label="APOBEC3G\nhypermutation", fillcolor="#FFCC88"];
    }

    // ─────────────────────────────────────────────────────────
    // CLUSTER 3: CD4+ T CELL DYNAMICS
    // ─────────────────────────────────────────────────────────
    subgraph cluster_cd4_dynamics {
        label="③ CD4⁺ T Cell Dynamics";
        style="filled,rounded";
        fillcolor="#F0FFF4";
        color="#006633";
        fontsize=11; fontcolor="#006633";

        Naive_CD4        [label="Naive CD4⁺\nT Cells (TN)", fillcolor="#99DDAA"];
        Central_Mem_CD4  [label="Central Memory\nCD4⁺ (TCM)", fillcolor="#77CC99"];
        Effector_Mem_CD4 [label="Effector Memory\nCD4⁺ (TEM)", fillcolor="#77CC99"];
        Activated_CD4    [label="Activated CD4⁺\n(TACT)", fillcolor="#55BB88"];
        Infected_CD4     [label="Productively\nInfected CD4⁺ (T*)", fillcolor="#33AA66"];
        Apoptotic_CD4    [label="Apoptotic CD4⁺\n(Bystander/Infected)", fillcolor="#BBDDCC"];
        Thymic_output    [label="Thymic Output\n(s_T naive)", fillcolor="#CCEECC"];
        CD4_proliferation[label="CD4 Homeostatic\nProliferation", fillcolor="#AADDBB"];
        TCR_signaling    [label="TCR Signal\n(Antigen-MHC-II)", fillcolor="#77CC99"];
        CD28_costimulation [label="CD28 Co-\nstimulation (B7)", fillcolor="#99DDAA"];
        PD1_CD4_exhaust  [label="PD-1/PD-L1\nCD4 Exhaustion", fillcolor="#CCEECC"];
        IL2_CD4          [label="IL-2 T Cell\nGrowth Factor", fillcolor="#AADDBB"];
        Th1_CD4          [label="Th1 Subset\n(IFN-γ prod.)", fillcolor="#88CC99"];
        Tfh_CD4          [label="Tfh (T follicular\nHelper)", fillcolor="#88CC99"];
    }

    // ─────────────────────────────────────────────────────────
    // CLUSTER 4: LATENT RESERVOIR
    // ─────────────────────────────────────────────────────────
    subgraph cluster_latent_reservoir {
        label="④ Latent HIV Reservoir";
        style="filled,rounded";
        fillcolor="#F5F0FF";
        color="#440088";
        fontsize=11; fontcolor="#440088";

        Resting_CD4_lat  [label="Resting Memory\nCD4⁺ (Latent HIV)", fillcolor="#CC99EE"];
        HDAC1_2          [label="HDAC1/HDAC2\n(Epigenetic silencing)", fillcolor="#BB88DD"];
        NF_kB_latency    [label="NF-κB\nLatency Regulation", fillcolor="#CC99EE"];
        LTR_silenced     [label="HIV LTR\nSilenced State", fillcolor="#BB88DD"];
        Epigenetic_block [label="H3K9me3/H3K27me3\nEpigenetic Barriers", fillcolor="#CCAAEE"];
        Reservoir_size   [label="Integrated HIV DNA\nReservoir Size", fillcolor="#AA77CC"];
        Clonal_expansion [label="Clonal Expansion\n(Homeostatic prolif.)", fillcolor="#CC99EE"];
        LRA              [label="Latency Reversing\nAgents (LRA)", fillcolor="#DDBBFF"];
        Vorinostat_HDACi [label="Vorinostat\n(HDACi LRA)", fillcolor="#EECCFF"];
        Reactivation     [label="Viral Reactivation\n(Rebound)", fillcolor="#AA77CC"];
        Clonal_size      [label="Clone Size\n(Cells/clone)", fillcolor="#CCAAEE"];
    }

    // ─────────────────────────────────────────────────────────
    // CLUSTER 5: CD8+ CTL RESPONSE
    // ─────────────────────────────────────────────────────────
    subgraph cluster_ctl_response {
        label="⑤ CD8⁺ CTL Immune Response";
        style="filled,rounded";
        fillcolor="#EEF8FF";
        color="#003388";
        fontsize=11; fontcolor="#003388";

        Naive_CD8        [label="Naive CD8⁺\nT Cells", fillcolor="#99BBEE"];
        Primed_CD8       [label="Primed CD8⁺\n(Antigen-specific)", fillcolor="#77AADD"];
        CTL_effector     [label="CTL Effector\n(HIV-specific)", fillcolor="#5599CC"];
        CTL_memory       [label="CTL Memory\n(Long-lived)", fillcolor="#77AADD"];
        Granzyme_B       [label="Granzyme B\nRelease", fillcolor="#AACCEE"];
        Perforin         [label="Perforin\n(Pore formation)", fillcolor="#AACCEE"];
        IFN_gamma_CTL    [label="IFN-γ (CTL)\nAntiviral cytokine", fillcolor="#88BBDD"];
        PD1_CD8_exhaust  [label="PD-1/Tim-3/Lag-3\nCTL Exhaustion", fillcolor="#BBCCEE"];
        TCR_CD8          [label="TCR CD8⁺\n(MHC-I:peptide)", fillcolor="#99BBEE"];
        IL15_CD8         [label="IL-15 CD8\nHomeostatic Signal", fillcolor="#AACCEE"];
        Killing_rate     [label="CTL Killing\nRate (k_CTL)", fillcolor="#5599CC"];
        HIV_peptide_MHC1 [label="HIV Peptide/\nMHC-I Complex", fillcolor="#88BBDD"];
    }

    // ─────────────────────────────────────────────────────────
    // CLUSTER 6: INNATE IMMUNITY
    // ─────────────────────────────────────────────────────────
    subgraph cluster_innate {
        label="⑥ Innate Immunity & Restriction Factors";
        style="filled,rounded";
        fillcolor="#FFFFF0";
        color="#888800";
        fontsize=11; fontcolor="#888800";

        NK_cell          [label="NK Cells\n(ADCC/Direct kill)", fillcolor="#DDDD99"];
        pDC              [label="Plasmacytoid DC\n(Type I IFN production)", fillcolor="#CCCC77"];
        mDC              [label="Myeloid DC\n(Antigen presentation)", fillcolor="#CCCC77"];
        Macrophage_inf   [label="Infected Macrophage\n(Reservoir)", fillcolor="#BBBB55"];
        Type_I_IFN       [label="Type I IFN\n(IFN-α/β)", fillcolor="#EEEE88"];
        cGAS_STING       [label="cGAS-STING\n(DNA sensing)", fillcolor="#DDDD77"];
        IRF3_IRF7        [label="IRF3/IRF7\nActivation", fillcolor="#CCCC66"];
        APOBEC3G_innate  [label="APOBEC3G/3F\nRestriction", fillcolor="#DDDD99"];
        TRIM5alpha       [label="TRIM5α\nCapsid restriction", fillcolor="#CCCC88"];
        SAMHD1           [label="SAMHD1 dNTP\nDepletion", fillcolor="#CCCC88"];
        Tetherin_BST2    [label="BST-2/Tetherin\nVirus tethering", fillcolor="#DDDD99"];
        MX2_restriction  [label="MX2 Nuclear\nPore block", fillcolor="#EEEEAA"];
    }

    // ─────────────────────────────────────────────────────────
    // CLUSTER 7: ANTIRETROVIRAL DRUG PK
    // ─────────────────────────────────────────────────────────
    subgraph cluster_drug_pk {
        label="⑦ Antiretroviral Drug PK";
        style="filled,rounded";
        fillcolor="#F0EEFF";
        color="#330088";
        fontsize=11; fontcolor="#330088";

        TDF_dose         [label="TDF (Tenofovir DF)\n300 mg QD oral", fillcolor="#CCBBEE"];
        TDF_plasma       [label="TDF Plasma\nConc. (TFV)", fillcolor="#BBAADD"];
        TFV_DP_intracell [label="TFV-DP Intracell\n(Active metabolite)", fillcolor="#AA99CC"];
        FTC_dose         [label="FTC (Emtricitabine)\n200 mg QD oral", fillcolor="#CCBBEE"];
        FTC_plasma       [label="FTC Plasma\nConc.", fillcolor="#BBAADD"];
        FTC_TP_intracell [label="FTC-TP Intracell\n(Active metabolite)", fillcolor="#AA99CC"];
        TAF_dose         [label="TAF (Tenofovir AF)\n25 mg QD (Biktarvy)", fillcolor="#CCBBEE"];
        TAF_plasma       [label="TAF Plasma\n(Prodrug)", fillcolor="#BBAADD"];
        DTG_dose         [label="DTG (Dolutegravir)\n50 mg QD oral", fillcolor="#DDCCFF"];
        DTG_plasma       [label="DTG Plasma\nConc.", fillcolor="#CCBBEE"];
        BIC_dose         [label="BIC (Bictegravir)\n50 mg QD (Biktarvy)", fillcolor="#DDCCFF"];
        BIC_plasma       [label="BIC Plasma\nConc.", fillcolor="#CCBBEE"];
        EFV_dose         [label="EFV (Efavirenz)\n600 mg QD oral", fillcolor="#DDCCFF"];
        EFV_plasma       [label="EFV Plasma\nConc.", fillcolor="#CCBBEE"];
        CAB_IM           [label="CAB-LA IM\n(600 mg loading\nthen q2mo)", fillcolor="#DDCCFF"];
        RPV_IM           [label="RPV-LA IM\n(900 mg loading\nthen q2mo)", fillcolor="#DDCCFF"];
        DRV_dose         [label="DRV/r (Darunavir\n/ritonavir) 800/100 mg", fillcolor="#EEDDFF"];
        DRV_plasma       [label="DRV Plasma\nConc.", fillcolor="#DDCCEE"];
        CYP3A4_HIV       [label="CYP3A4/5\n(EFV/DRV/Cob metab)", fillcolor="#CCBBDD"];
        UGT1A1_HIV       [label="UGT1A1\n(DTG/BIC metab)", fillcolor="#CCBBDD"];
    }

    // ─────────────────────────────────────────────────────────
    // CLUSTER 8: DRUG PD / ANTIVIRAL MECHANISMS
    // ─────────────────────────────────────────────────────────
    subgraph cluster_drug_pd {
        label="⑧ Antiretroviral Drug PD & Mechanisms";
        style="filled,rounded";
        fillcolor="#EEF8EE";
        color="#004400";
        fontsize=11; fontcolor="#004400";

        NRTI_efficacy    [label="NRTI Efficacy\n(RT chain termination)", fillcolor="#88CC88"];
        NNRTI_efficacy   [label="NNRTI Efficacy\n(RT allosteric)", fillcolor="#77BB77"];
        PI_efficacy      [label="PI Efficacy\n(Protease inhibition)", fillcolor="#88CC88"];
        INSTI_efficacy   [label="INSTI Efficacy\n(Strand transfer inhibit)", fillcolor="#77BB77"];
        CCR5_block       [label="CCR5 Antagonism\n(Maraviroc/MVC)", fillcolor="#99DD99"];
        Inhibition_RT    [label="% RT Inhibition\n(IC50 NRTI/NNRTI)", fillcolor="#AADDAA"];
        Inhibition_INT   [label="% Integrase\nInhibition (IC50 INSTI)", fillcolor="#AADDAA"];
        Inhibition_PR    [label="% Protease\nInhibition (IC50 PI)", fillcolor="#AADDAA"];
        Overall_efficacy [label="Overall Antiviral\nEfficacy η_total", fillcolor="#55AA55"];
        Viral_suppression[label="Viral Load\nSuppression (VL<50)", fillcolor="#33AA33"];
        TFV_IC50         [label="TFV IC50\n(0.04-0.3 µM)", fillcolor="#BBEEAA"];
        DTG_IC50         [label="DTG IC50\n(0.002-0.005 µM)", fillcolor="#BBEEAA"];
        Drug_synergy     [label="Drug Synergy\n(2-drug/3-drug comb)", fillcolor="#99DD99"];
    }

    // ─────────────────────────────────────────────────────────
    // CLUSTER 9: DRUG RESISTANCE
    // ─────────────────────────────────────────────────────────
    subgraph cluster_resistance {
        label="⑨ HIV Drug Resistance";
        style="filled,rounded";
        fillcolor="#FFF5F0";
        color="#884400";
        fontsize=11; fontcolor="#884400";

        Viral_replication_error [label="Viral Replication\nError Rate (3×10⁻⁵)", fillcolor="#FFCC99"];
        Quasispecies     [label="HIV Quasispecies\nCloud", fillcolor="#FFBB77"];
        M184V_mut        [label="M184V Mutation\n(FTC/3TC resistance)", fillcolor="#FF9944"];
        K65R_mut         [label="K65R Mutation\n(TDF/TAF resistance)", fillcolor="#FF9944"];
        K103N_mut        [label="K103N Mutation\n(EFV/NVP resistance)", fillcolor="#FF9944"];
        INSTI_resist     [label="Q148H/G140S/\nN155H (INSTI resist.)", fillcolor="#FF9944"];
        R263K_DTG        [label="R263K (DTG\nHigh barrier)", fillcolor="#FFB866"];
        PI_resist_muts   [label="V82A/I84V/D30N\n(PI resistance)", fillcolor="#FF9944"];
        MDR_HIV          [label="Multi-Drug\nResistance HIV", fillcolor="#FF7722"];
        Fitness_cost     [label="Fitness Cost\n(Resist. mutations)", fillcolor="#FFCC88"];
        Pre_exist_resist [label="Pre-Existing\nResistance (TDR)", fillcolor="#FFBB66"];
        Archival_resist  [label="Archival\nResistance (Reservoir)", fillcolor="#FF9944"];
    }

    // ─────────────────────────────────────────────────────────
    // CLUSTER 10: INFLAMMATION & COMORBIDITIES
    // ─────────────────────────────────────────────────────────
    subgraph cluster_inflammation {
        label="⑩ Chronic Inflammation & Comorbidities";
        style="filled,rounded";
        fillcolor="#FFFCE8";
        color="#886600";
        fontsize=11; fontcolor="#886600";

        LPS_translocation[label="Microbial\nTranslocation (sCD14)", fillcolor="#EEDD88"];
        sCD14            [label="sCD14 Monocyte\nActivation Marker", fillcolor="#DDCC77"];
        TNF_alpha_HIV    [label="TNF-α\nChronic inflammation", fillcolor="#EEBB55"];
        IL6_HIV          [label="IL-6 Systemic\nInflammation", fillcolor="#EEBB55"];
        IL1b_HIV         [label="IL-1β\nInflammasome", fillcolor="#EEBB55"];
        hsCRP            [label="hsCRP\nCardiovascular risk", fillcolor="#DDCC77"];
        D_dimer          [label="D-dimer\nCoagulation marker", fillcolor="#DDCC77"];
        Immune_activation[label="Immune Activation\nScore (HLA-DR/CD38)", fillcolor="#CCAA55"];
        CV_risk          [label="Cardiovascular\nRisk (ASCVD)", fillcolor="#FFDD55"];
        Neurocognitive   [label="HIV-Associated\nNeurocognitive Disorder", fillcolor="#EECC66"];
        Liver_HIV        [label="HCV Coinfection\nLiver Fibrosis", fillcolor="#DDBB44"];
        Bone_loss        [label="Bone Mineral\nDensity Loss", fillcolor="#DDCC77"];
        Kidney_disease_HIV [label="HIV Nephropathy\n(HIVAN)", fillcolor="#DDCC77"];
    }

    // ─────────────────────────────────────────────────────────
    // INTRA-CLUSTER EDGES
    // ─────────────────────────────────────────────────────────

    // Cluster 1: Viral Entry
    gp120_envelope -> CD4_receptor [label="Binding"];
    gp120_envelope -> V3_loop;
    V3_loop -> CCR5_coreceptor [label="R5-tropic"];
    V3_loop -> CXCR4_coreceptor [label="X4-tropic"];
    gp120_envelope -> gp120_CD4_complex;
    CD4_receptor -> gp120_CD4_complex;
    gp120_CD4_complex -> conformational_change;
    conformational_change -> gp41_TM;
    gp41_TM -> Fusion_pore;
    Fusion_pore -> Viral_uncoating;
    Nef_protein -> CD4_downreg [style=dashed];
    Vpu_protein -> CD4_downreg [style=dashed];
    Nef_protein -> CXCR4_downreg [style=dashed];
    Tropism_switch -> CXCR4_coreceptor [label="Disease progression"];

    // Cluster 2: Viral Replication
    Viral_uncoating -> HIV_RNA;
    HIV_RNA -> Reverse_transcriptase [label="Endogenous RT"];
    Reverse_transcriptase -> ssDNA_minus;
    ssDNA_minus -> dsDNA;
    dsDNA -> PIC;
    PIC -> Integrase;
    Integrase -> Proviral_DNA [label="Strand transfer"];
    Proviral_DNA -> HIV_LTR;
    HIV_LTR -> Tat_Trans;
    Tat_Trans -> Rev_export [label="Full-length RNA"];
    Rev_export -> Gag_precursor;
    Rev_export -> Pol_precursor;
    Pol_precursor -> HIV_Protease;
    HIV_Protease -> Gag_precursor [label="Cleavage"];
    Gag_precursor -> Capsid_assembly;
    Capsid_assembly -> Budding;
    Budding -> Mature_virus;
    Vif_protein -> APOBEC3G_effect [label="Degrades APOBEC3G", style=dashed];
    Vpu_protein -> Tetherin_BST2 [style=dashed, lhead=cluster_innate];

    // Cluster 3: CD4 dynamics
    Thymic_output -> Naive_CD4;
    Naive_CD4 -> Central_Mem_CD4 [label="Differentiation"];
    Central_Mem_CD4 -> Effector_Mem_CD4;
    TCR_signaling -> Activated_CD4;
    CD28_costimulation -> Activated_CD4;
    Activated_CD4 -> Infected_CD4 [label="HIV infection"];
    Infected_CD4 -> Apoptotic_CD4;
    CD4_proliferation -> Naive_CD4;
    IL2_CD4 -> Activated_CD4;
    PD1_CD4_exhaust -> Activated_CD4 [label="Inhibits", style=dashed, arrowhead=tee];
    Activated_CD4 -> Th1_CD4;
    Activated_CD4 -> Tfh_CD4;

    // Cluster 4: Latent Reservoir
    Central_Mem_CD4 -> Resting_CD4_lat [label="Latent infection"];
    Resting_CD4_lat -> HDAC1_2;
    HDAC1_2 -> LTR_silenced;
    Epigenetic_block -> LTR_silenced;
    NF_kB_latency -> LTR_silenced [style=dashed];
    LTR_silenced -> Reservoir_size;
    Clonal_expansion -> Reservoir_size;
    LRA -> Reactivation [label="Reverses"];
    Vorinostat_HDACi -> HDAC1_2 [label="Inhibits", style=dashed, arrowhead=tee];
    Reactivation -> Mature_virus [lhead=cluster_viral_replication];
    Clonal_size -> Clonal_expansion;

    // Cluster 5: CTL
    Naive_CD8 -> Primed_CD8 [label="Priming"];
    Primed_CD8 -> CTL_effector;
    CTL_effector -> CTL_memory;
    TCR_CD8 -> Primed_CD8;
    HIV_peptide_MHC1 -> TCR_CD8;
    CTL_effector -> Granzyme_B;
    CTL_effector -> Perforin;
    CTL_effector -> IFN_gamma_CTL;
    Granzyme_B -> Killing_rate;
    Perforin -> Killing_rate;
    PD1_CD8_exhaust -> CTL_effector [label="Exhaustion", style=dashed, arrowhead=tee];
    IL15_CD8 -> CTL_memory;

    // Cluster 6: Innate
    pDC -> Type_I_IFN [label="Sensing viral RNA"];
    cGAS_STING -> IRF3_IRF7;
    IRF3_IRF7 -> Type_I_IFN;
    Type_I_IFN -> APOBEC3G_innate [label="ISG induction"];
    Type_I_IFN -> MX2_restriction;
    APOBEC3G_innate -> HIV_RNA [style=dashed, arrowhead=tee, label="G→A hypermut"];
    TRIM5alpha -> Viral_uncoating [style=dashed, arrowhead=tee];
    SAMHD1 -> Reverse_transcriptase [style=dashed, arrowhead=tee, label="dNTP depletion"];
    Tetherin_BST2 -> Budding [style=dashed, arrowhead=tee, label="Tether virions"];
    NK_cell -> Infected_CD4 [style=dashed, label="ADCC kill"];
    mDC -> Primed_CD8 [lhead=cluster_ctl_response, label="Cross-present"];

    // Cluster 7: Drug PK
    TDF_dose -> TDF_plasma [label="Gut absorption\nF=25%"];
    TDF_plasma -> TFV_DP_intracell [label="Phosphorylation\n(t½ 150h)"];
    FTC_dose -> FTC_plasma [label="F=93%"];
    FTC_plasma -> FTC_TP_intracell [label="Phosphorylation\n(t½ 39h)"];
    TAF_dose -> TAF_plasma [label="F=32%\nCYP3A4"];
    TAF_plasma -> TFV_DP_intracell [label="Intracell activation\n(10×TDF)"];
    DTG_dose -> DTG_plasma [label="F=~50%"];
    BIC_dose -> BIC_plasma [label="F>95% (+ food)"];
    EFV_dose -> EFV_plasma [label="F=40-45%\nCYP2B6"];
    CAB_IM -> DTG_plasma [label="Long-acting\n(Vd=15.6L)", style=dashed];
    RPV_IM -> EFV_plasma [label="NNRTI class\n(Vd=141L)", style=dashed];
    DRV_dose -> DRV_plasma [label="RTV boost\nF=82%"];
    CYP3A4_HIV -> EFV_plasma [label="Metabolism\n(CYP2B6 also)"];
    CYP3A4_HIV -> DRV_plasma [label="Booster"];
    UGT1A1_HIV -> DTG_plasma [label="Glucuronid."];
    UGT1A1_HIV -> BIC_plasma [label="Glucuronid."];

    // Cluster 8: Drug PD
    TFV_DP_intracell -> NRTI_efficacy [label="TFV-DP"];
    FTC_TP_intracell -> NRTI_efficacy [label="FTC-TP"];
    DTG_plasma -> INSTI_efficacy [label="IC50 0.002µM"];
    BIC_plasma -> INSTI_efficacy [label="IC50 0.001µM"];
    EFV_plasma -> NNRTI_efficacy [label="IC50 3µM"];
    DRV_plasma -> PI_efficacy [label="IC50 0.001µM"];
    CCR5_coreceptor -> CCR5_block [lhead=cluster_drug_pd];
    NRTI_efficacy -> Inhibition_RT;
    NNRTI_efficacy -> Inhibition_RT;
    PI_efficacy -> Inhibition_PR;
    INSTI_efficacy -> Inhibition_INT;
    Inhibition_RT -> Overall_efficacy;
    Inhibition_INT -> Overall_efficacy;
    Inhibition_PR -> Overall_efficacy;
    Drug_synergy -> Overall_efficacy;
    Overall_efficacy -> Viral_suppression;
    TFV_IC50 -> Inhibition_RT;
    DTG_IC50 -> Inhibition_INT;

    // Cluster 9: Resistance
    Viral_replication_error -> Quasispecies;
    Quasispecies -> M184V_mut;
    Quasispecies -> K65R_mut;
    Quasispecies -> K103N_mut;
    Quasispecies -> INSTI_resist;
    Quasispecies -> R263K_DTG;
    Quasispecies -> PI_resist_muts;
    INSTI_resist -> MDR_HIV;
    M184V_mut -> MDR_HIV;
    K65R_mut -> MDR_HIV;
    PI_resist_muts -> MDR_HIV;
    Pre_exist_resist -> Quasispecies;
    Archival_resist -> Resting_CD4_lat [lhead=cluster_latent_reservoir];
    Fitness_cost -> Quasispecies [style=dashed];

    // Cluster 10: Inflammation
    LPS_translocation -> sCD14;
    sCD14 -> Immune_activation;
    Immune_activation -> TNF_alpha_HIV;
    Immune_activation -> IL6_HIV;
    Immune_activation -> IL1b_HIV;
    IL6_HIV -> hsCRP;
    IL6_HIV -> D_dimer;
    Immune_activation -> CV_risk;
    Immune_activation -> Neurocognitive;
    Liver_HIV -> Immune_activation;
    Bone_loss -> CV_risk [style=dashed];
    Kidney_disease_HIV -> Immune_activation [style=dashed];

    // ─────────────────────────────────────────────────────────
    // INTER-CLUSTER EDGES
    // ─────────────────────────────────────────────────────────

    // Entry → Replication
    Viral_uncoating -> HIV_RNA [ltail=cluster_viral_entry, lhead=cluster_viral_replication];

    // Replication → CD4
    Mature_virus -> Activated_CD4 [label="Infects CD4", ltail=cluster_viral_replication, lhead=cluster_cd4_dynamics];
    Infected_CD4 -> Mature_virus [label="Virion prod.", ltail=cluster_cd4_dynamics, lhead=cluster_viral_replication];

    // CD4 → Reservoir
    Central_Mem_CD4 -> Resting_CD4_lat [ltail=cluster_cd4_dynamics, lhead=cluster_latent_reservoir, style=dashed, label="Latent integrate"];

    // Reservoir → Replication
    Reactivation -> Proviral_DNA [ltail=cluster_latent_reservoir, lhead=cluster_viral_replication, label="LTR reactivation"];

    // CTL → CD4 (killing)
    Killing_rate -> Infected_CD4 [ltail=cluster_ctl_response, lhead=cluster_cd4_dynamics, style=dashed, arrowhead=tee, label="CTL kill"];

    // CD4 → CTL (antigen presentation)
    Infected_CD4 -> HIV_peptide_MHC1 [ltail=cluster_cd4_dynamics, lhead=cluster_ctl_response, label="MHC-I present"];

    // Innate → Replication
    Type_I_IFN -> HIV_RNA [ltail=cluster_innate, lhead=cluster_viral_replication, style=dashed, arrowhead=tee, label="ISG restrict"];

    // Drug PK → Drug PD
    TFV_DP_intracell -> NRTI_efficacy [ltail=cluster_drug_pk, lhead=cluster_drug_pd];
    DTG_plasma -> INSTI_efficacy [ltail=cluster_drug_pk, lhead=cluster_drug_pd];

    // Drug PD → Replication (Antiviral effect)
    Overall_efficacy -> Mature_virus [ltail=cluster_drug_pd, lhead=cluster_viral_replication, style=dashed, arrowhead=tee, label="η suppress prod."];

    // Resistance → Drug PD
    M184V_mut -> NRTI_efficacy [ltail=cluster_resistance, lhead=cluster_drug_pd, style=dashed, arrowhead=tee, label="Reduce efficacy"];
    INSTI_resist -> INSTI_efficacy [ltail=cluster_resistance, lhead=cluster_drug_pd, style=dashed, arrowhead=tee];

    // Replication → Resistance
    HIV_RNA -> Viral_replication_error [ltail=cluster_viral_replication, lhead=cluster_resistance, style=dashed];

    // CD4 → Inflammation
    Infected_CD4 -> TNF_alpha_HIV [ltail=cluster_cd4_dynamics, lhead=cluster_inflammation, label="Pyroptosis\ncytokine release"];

    // Replication → Inflammation
    Mature_virus -> LPS_translocation [ltail=cluster_viral_replication, lhead=cluster_inflammation, style=dashed];

    // CTL → Inflammation
    IFN_gamma_CTL -> Immune_activation [ltail=cluster_ctl_response, lhead=cluster_inflammation, label="IFN-γ"];

    // Inflammation → CD4 (depletion)
    TNF_alpha_HIV -> Apoptotic_CD4 [ltail=cluster_inflammation, lhead=cluster_cd4_dynamics, style=dashed, label="Bystander death"];

    // Innate → CTL
    Type_I_IFN -> IL15_CD8 [ltail=cluster_innate, lhead=cluster_ctl_response, style=dashed];

    // Entry drug targets
    CCR5_coreceptor -> CCR5_block [lhead=cluster_drug_pd];

    // Macrophage reservoir
    Macrophage_inf -> Resting_CD4_lat [ltail=cluster_innate, lhead=cluster_latent_reservoir, style=dashed, label="Reservoir"];

    // Replication → CTL (antigen shedding)
    Mature_virus -> HIV_peptide_MHC1 [ltail=cluster_viral_replication, lhead=cluster_ctl_response, style=dashed];

    // Inflammation → Resistance (NF-kB)
    TNF_alpha_HIV -> NF_kB_latency [ltail=cluster_inflammation, lhead=cluster_latent_reservoir, style=dashed, label="Reactivation"];

    // Drug resistance effect on viral fitness
    MDR_HIV -> Mature_virus [ltail=cluster_resistance, lhead=cluster_viral_replication, style=dashed, label="Resistant virus"];

    // ─────────────────────────────────────────────────────────
    // CLINICAL OUTCOME NODES (outside clusters)
    // ─────────────────────────────────────────────────────────

    subgraph cluster_clinical {
        label="⑪ Clinical Outcomes & Endpoints";
        style="filled,rounded";
        fillcolor="#F0F0FF";
        color="#000066";
        fontsize=11; fontcolor="#000066";

        VL_plasma        [label="Plasma Viral Load\n(copies/mL, log10)", fillcolor="#9999EE"];
        CD4_count        [label="CD4+ Count\n(cells/µL)", fillcolor="#7777CC"];
        VL_50            [label="Virologic\nSuppression (VL<50)", fillcolor="#5555BB"];
        CD4_200          [label="CD4 Nadir\n(<200 → AIDS)", fillcolor="#7777CC"];
        AIDS_event       [label="AIDS-Defining\nIllness (OI/malignancy)", fillcolor="#4444AA"];
        Time_to_AIDS     [label="Time to AIDS\n(Years)", fillcolor="#5555BB"];
        Mortality        [label="HIV-Related\nMortality", fillcolor="#3333AA"];
        PrEP_efficacy    [label="PrEP Efficacy\n(Prevention HIV)", fillcolor="#9999EE"];
        SVR_analog       [label="Sustained\nVirologic Response", fillcolor="#7777CC"];
        Resistance_test  [label="Genotypic\nResistance Test", fillcolor="#8888DD"];
        HIVDR_score      [label="Stanford HIVDB\nResistance Score", fillcolor="#8888DD"];
        HAARTresponse    [label="Immunologic\nResponse (CD4 rise)", fillcolor="#7777CC"];
    }

    // Inter-cluster → Clinical
    Mature_virus -> VL_plasma [ltail=cluster_viral_replication, lhead=cluster_clinical];
    Infected_CD4 -> CD4_count [ltail=cluster_cd4_dynamics, lhead=cluster_clinical, style=dashed, arrowhead=tee];
    Naive_CD4 -> CD4_count [ltail=cluster_cd4_dynamics, lhead=cluster_clinical];
    Viral_suppression -> VL_50 [ltail=cluster_drug_pd, lhead=cluster_clinical];
    VL_plasma -> CD4_200;
    CD4_200 -> AIDS_event;
    AIDS_event -> Time_to_AIDS;
    AIDS_event -> Mortality;
    MDR_HIV -> Resistance_test [ltail=cluster_resistance, lhead=cluster_clinical];
    Resistance_test -> HIVDR_score;
    VL_50 -> SVR_analog;
    HAARTresponse -> CD4_count;
    PrEP_efficacy -> Mature_virus [ltail=cluster_clinical, lhead=cluster_viral_replication, style=dashed, arrowhead=tee];
    CV_risk -> Mortality [ltail=cluster_inflammation, lhead=cluster_clinical];
}
