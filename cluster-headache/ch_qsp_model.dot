/*
 * Cluster Headache (CH) — Quantitative Systems Pharmacology (QSP) mechanistic map
 * Trigeminal Autonomic Cephalalgia · Hypothalamus → Trigeminovascular → CGRP/PACAP/VIP
 * Pharmacology: O2, SC sumatriptan, zolmitriptan nasal, octreotide,
 *               verapamil, lithium, topiramate, galcanezumab (CGRP mAb),
 *               GON block (steroid+anesthetic), SPG stimulation, civamide.
 */
digraph cluster_headache_qsp {
    graph [rankdir=LR, splines=spline, overlap=false, nodesep=0.32, ranksep=0.55,
           fontname="Helvetica", fontsize=11, label="Cluster Headache · QSP Map (HC: hypothalamus → trigeminovascular → CGRP/PACAP, autonomic Horner's)\nDrugs: O2, SC sumatriptan, zolmitriptan-IN, verapamil, lithium, topiramate, galcanezumab (CGRP mAb), GON block, SPG-stim",
           labelloc="t", fontsize=14];
    node  [shape=box, style="rounded,filled", fontname="Helvetica", fontsize=10, fillcolor="#FFFFFF"];
    edge  [color="#666666", arrowsize=0.75, fontname="Helvetica", fontsize=8];

    /* ===== 1. Genetic / chronobiologic predisposition ===== */
    subgraph cluster_genetics {
        label="1) Genetic & Chronobiologic Susceptibility";
        style="rounded,filled"; fillcolor="#FFF6E5"; color="#E0A800";
        HCRTR2  [label="HCRTR2 rs2653349\norexin-2 receptor", fillcolor="#FFE8B0"];
        ADH4    [label="ADH4 (alcohol)\nrs1126671", fillcolor="#FFE8B0"];
        MTNR1A  [label="MTNR1A melatonin\nreceptor 1A", fillcolor="#FFE8B0"];
        PACAP_g [label="ADCYAP1 / PAC1\n(CH GWAS)", fillcolor="#FFE8B0"];
        CLOCK_g [label="CLOCK / BMAL1\ncircadian genes", fillcolor="#FFE8B0"];
        FamHx   [label="Family Hx ×5-18\n(first-degree)", fillcolor="#FFE8B0"];
        Male    [label="Male:Female ≈3:1\n(post-CGRP era)", fillcolor="#FFE8B0"];
        Smoking [label="Smoking >85%\n(triggers, not cause)", fillcolor="#FFE8B0"];
    }

    /* ===== 2. Hypothalamic generator ===== */
    subgraph cluster_hypothalamus {
        label="2) Hypothalamic Circadian Generator (Posterior hypothalamic gray)";
        style="rounded,filled"; fillcolor="#FFE5E5"; color="#C0392B";
        SCN     [label="SCN\nsuprachiasmatic nucleus", fillcolor="#FFCCCC"];
        PVN     [label="PVN\nparaventricular", fillcolor="#FFCCCC"];
        ARC     [label="Arcuate / TMN\nhistamine, neuropeptides", fillcolor="#FFCCCC"];
        Hypo_post [label="Posterior hypothalamus\nMay PET 1998 BOLD", fillcolor="#FFAAAA", penwidth=2];
        Orexin  [label="Orexin (Hcrt) A/B\nlateral hypo.", fillcolor="#FFCCCC"];
        Melat_sec [label="Melatonin (pineal)\nnocturnal trough in CH", fillcolor="#FFCCCC"];
        Cortisol_circ [label="Cortisol rhythm\nblunted in cluster", fillcolor="#FFCCCC"];
        Testos  [label="Testosterone↓\n(REM hours)", fillcolor="#FFCCCC"];
        Cluster_bout [label="Active bout\n(weeks–months)", fillcolor="#FFAAAA", penwidth=2];
        Remission [label="Remission\n(months–years)", fillcolor="#FFCCCC"];
    }

    /* ===== 3. Trigeminovascular activation ===== */
    subgraph cluster_trigemino {
        label="3) Trigeminovascular Activation (V1, ophthalmic division)";
        style="rounded,filled"; fillcolor="#E6F2FF"; color="#1F77B4";
        TG      [label="Trigeminal ganglion\n(V1 neurons)", fillcolor="#CCDFFF", penwidth=2];
        TNC     [label="Trigeminocervical\ncomplex (TCC, C1-C2)", fillcolor="#CCDFFF"];
        Dura    [label="Dural meninges\nMMA branches", fillcolor="#CCDFFF"];
        ICA     [label="Internal carotid\ncavernous segment", fillcolor="#CCDFFF"];
        Pial    [label="Pial vessels\n(dilated in attack)", fillcolor="#CCDFFF"];
        CGRP    [label="CGRP release\n(serum CGRP↑ in attack)", fillcolor="#CCDFFF", penwidth=2];
        PACAP   [label="PACAP-38 (ADCYAP1)\nPAC1/VPAC1/2 receptors", fillcolor="#CCDFFF", penwidth=2];
        VIP     [label="VIP\n(autonomic marker)", fillcolor="#CCDFFF"];
        SubP    [label="Substance P\nNK1 receptor", fillcolor="#CCDFFF"];
        NeuroInflam [label="Neurogenic inflammation\ndural mast cells, MMP-9", fillcolor="#CCDFFF"];
        Nox     [label="Nitric oxide (NO)\nGTN trigger Ph2 model", fillcolor="#CCDFFF"];
        CGRP_R  [label="CGRP receptor\n(CLR + RAMP1)", fillcolor="#CCDFFF"];
    }

    /* ===== 4. Parasympathetic / SPG limb ===== */
    subgraph cluster_parasym {
        label="4) Parasympathetic Outflow (Trigeminal-Autonomic Reflex)";
        style="rounded,filled"; fillcolor="#E6FFE6"; color="#2E8B57";
        SSN     [label="Superior salivatory n.\n(pons)", fillcolor="#CCFFCC"];
        GSPN    [label="Greater superficial\npetrosal nerve", fillcolor="#CCFFCC"];
        SPG     [label="Sphenopalatine ganglion\n(SPG · pterygopalatine)", fillcolor="#CCFFCC", penwidth=2];
        Lacrimal[label="Lacrimal gland → tearing", fillcolor="#CCFFCC"];
        Nasal_g [label="Nasal mucosa → rhinorrhea/congestion", fillcolor="#CCFFCC"];
        ConjV   [label="Conjunctival vasodilation\n(injection)", fillcolor="#CCFFCC"];
        Facial_sweat [label="Forehead/face sweat", fillcolor="#CCFFCC"];
        VIPnerve[label="VIP-ergic fibres", fillcolor="#CCFFCC"];
        ACh_p   [label="ACh / NO (postgang.)", fillcolor="#CCFFCC"];
    }

    /* ===== 5. Sympathetic disruption → Horner's ===== */
    subgraph cluster_sympath {
        label="5) Sympathetic Limb · Partial Horner's";
        style="rounded,filled"; fillcolor="#F0E6FF"; color="#7B3FBF";
        ICA_per [label="Pericarotid sympathetic\nplexus (irritated)", fillcolor="#E0CCFF"];
        Ptosis  [label="Ptosis (Müller m.)", fillcolor="#E0CCFF"];
        Miosis  [label="Miosis (radial dilator)", fillcolor="#E0CCFF"];
        Anhid   [label="Forehead anhidrosis\n(if pre-gang lesion)", fillcolor="#E0CCFF"];
        SCG     [label="Superior cervical\nganglion", fillcolor="#E0CCFF"];
        Horner  [label="Partial Horner's\nipsilateral", fillcolor="#E0CCFF", penwidth=2];
    }

    /* ===== 6. Pain processing / central sensitization ===== */
    subgraph cluster_pain {
        label="6) Central Pain Processing & Sensitization";
        style="rounded,filled"; fillcolor="#FFE6F0"; color="#C0399B";
        Glu_TNC [label="Glutamate (NMDA/AMPA)\nin TCC", fillcolor="#FFCCDD"];
        Thal_VPM[label="Thalamus VPM/Po\n(ipsilateral)", fillcolor="#FFCCDD"];
        S1_inso [label="S1 / insula / ACC\npain matrix", fillcolor="#FFCCDD"];
        Allodyn [label="Periorbital allodynia\n(<10%, vs migraine)", fillcolor="#FFCCDD"];
        Restless[label="Restlessness/agitation\n(distinguishes from migraine)", fillcolor="#FFCCDD"];
        Pain_attack [label="Attack pain\nVAS 9-10/10, 15-180 min", fillcolor="#FFAACC", penwidth=2];
        Periorb [label="Periorbital / temporal\nipsilateral", fillcolor="#FFCCDD"];
    }

    /* ===== 7. Receptor pharmacology ===== */
    subgraph cluster_receptors {
        label="7) Receptor Pharmacology Targets";
        style="rounded,filled"; fillcolor="#FFFFE0"; color="#B8860B";
        HT1B    [label="5-HT 1B receptor\n(vascular)", fillcolor="#FFF8C5"];
        HT1D    [label="5-HT 1D receptor\n(neuronal)", fillcolor="#FFF8C5"];
        HT1F    [label="5-HT 1F receptor\n(ditans)", fillcolor="#FFF8C5"];
        CaV     [label="L-type Ca²⁺ ch.\n(verapamil target)", fillcolor="#FFF8C5"];
        GSK3    [label="GSK-3β / IMPase\n(lithium target)", fillcolor="#FFF8C5"];
        OxR2    [label="Orexin OX2R\n(filorexant trial)", fillcolor="#FFF8C5"];
        SSTR    [label="SST receptor 2/5\noctreotide target", fillcolor="#FFF8C5"];
        TRPV1   [label="TRPV1 (civamide)\ncapsaicinoid", fillcolor="#FFF8C5"];
        CGRP_mAb[label="CGRP / receptor mAb\ngalcanezumab target", fillcolor="#FFF8C5"];
    }

    /* ===== 8. Drugs (acute · transitional · preventive · neuromod) ===== */
    subgraph cluster_drugs {
        label="8) Drugs — Acute, Transitional, Preventive, Device";
        style="rounded,filled"; fillcolor="#E6FFFF"; color="#138D75";
        O2_high [label="High-flow O2 12 L/min\nnonrebreather mask", fillcolor="#CCFFFF", penwidth=2];
        Suma_SC [label="Sumatriptan 6 mg SC\nF=96%, tmax 12 min", fillcolor="#CCFFFF", penwidth=2];
        Zolmi_IN[label="Zolmitriptan 5/10 mg IN\nF≈40%", fillcolor="#CCFFFF"];
        Lido_IN [label="Intranasal lidocaine 4%", fillcolor="#CCFFFF"];
        Octreo  [label="Octreotide 100 µg SC", fillcolor="#CCFFFF"];
        Pred    [label="Prednisone 60 mg→taper\n(bridge ≤2 wk)", fillcolor="#CCFFFF"];
        GON     [label="GON block\nmethylprednisolone + lidocaine", fillcolor="#CCFFFF"];
        Vera    [label="Verapamil 240-960 mg/d\nPR mandatory", fillcolor="#CCFFFF", penwidth=2];
        Li      [label="Lithium 600-1200 mg/d\ntrough 0.6-0.8 mEq/L", fillcolor="#CCFFFF"];
        Topi    [label="Topiramate 25-200 mg/d", fillcolor="#CCFFFF"];
        Melat   [label="Melatonin 10 mg HS", fillcolor="#CCFFFF"];
        Galca   [label="Galcanezumab 300 mg SC\nCGRP-IgG4 mAb", fillcolor="#CCFFFF", penwidth=2];
        Erenu   [label="Erenumab\nCGRP-R mAb (off-label)", fillcolor="#CCFFFF"];
        Civamide[label="Civamide IN\nTRPV1 modulator", fillcolor="#CCFFFF"];
        SPG_stim[label="SPG stimulator\nPathway-CH-1 trial", fillcolor="#CCFFFF"];
        VNS_nc  [label="nVNS gammaCore\nACT-1/ACT-2/PREVA", fillcolor="#CCFFFF"];
        DBS     [label="Posterior hypothalamic\nDBS (refractory CCH)", fillcolor="#CCFFFF"];
        Psilo_lsd [label="Psilocybin / LSA\nspecialist research", fillcolor="#CCFFFF"];
    }

    /* ===== 9. PK / disposition ===== */
    subgraph cluster_pk {
        label="9) Pharmacokinetics";
        style="rounded,filled"; fillcolor="#F0F0F0"; color="#5D6D7E";
        Suma_PK [label="Sumatriptan SC\nCL 18 L/h, V 9 L,\nt½ ≈2 h", fillcolor="#E0E0E0"];
        Zol_PK  [label="Zolmitriptan IN\nCL 9 L/h, t½ 2.5 h\nN-desmethyl active", fillcolor="#E0E0E0"];
        Vera_PK [label="Verapamil PR\nCYP3A4, t½ 5-12 h\nactive norverapamil", fillcolor="#E0E0E0"];
        Li_PK   [label="Lithium\n100% renal CL ≈25 mL/min\nTI narrow", fillcolor="#E0E0E0"];
        Topi_PK [label="Topiramate\nCL 1.2 L/h, t½ 21 h\n70% renal", fillcolor="#E0E0E0"];
        Galca_PK[label="Galcanezumab\nCL 0.008 L/h, t½ 27 d\nlinear, FcRn recycled", fillcolor="#E0E0E0"];
        Pred_PK [label="Prednisolone\nactive, t½ 3 h\nbiologic 18-36 h", fillcolor="#E0E0E0"];
    }

    /* ===== 10. PD / clinical endpoints ===== */
    subgraph cluster_pd {
        label="10) Clinical Endpoints & Biomarkers";
        style="rounded,filled"; fillcolor="#FDEDEC"; color="#922B21";
        Attack_freq [label="Attacks/week\nprimary endpoint", fillcolor="#F5B7B1", penwidth=2];
        Duration_min[label="Attack duration min", fillcolor="#F5B7B1"];
        VAS_pain[label="VAS pain 0-10", fillcolor="#F5B7B1"];
        Pain_free15 [label="Pain-free 15 min\n(triptan trials)", fillcolor="#F5B7B1"];
        Mean_red[label="Mean weekly attack\nreduction (CGRP mAb wk1-3 = 8.7 vs 5.2 placebo)", fillcolor="#F5B7B1"];
        Resp50  [label="≥50% responder rate", fillcolor="#F5B7B1"];
        CGRP_ser[label="Serum CGRP\n(jugular sample peak)", fillcolor="#F5B7B1"];
        VIP_ser [label="Serum VIP", fillcolor="#F5B7B1"];
        PR_QT   [label="PR/QT, AV block\n(verapamil safety)", fillcolor="#F5B7B1"];
        Li_tox  [label="Tremor/nausea\nthyroid/renal/Li level", fillcolor="#F5B7B1"];
        Cog_topi[label="Cognitive AE/weight↓\n(topiramate)", fillcolor="#F5B7B1"];
        Inj_site[label="Injection-site rxn\n(galcanezumab)", fillcolor="#F5B7B1"];
        Suic_id [label="Suicidality\n(highest of all pain disorders)", fillcolor="#F5B7B1"];
    }

    /* ===== 11. Triggers / lifestyle ===== */
    subgraph cluster_trigger {
        label="11) Episodic Triggers & Lifestyle";
        style="rounded,filled"; fillcolor="#FFF0E0"; color="#D35400";
        EtOH    [label="Alcohol (during bout)", fillcolor="#FFE0C0"];
        Histamine_tr [label="Histamine SC test\nprovocation", fillcolor="#FFE0C0"];
        GTN_tr  [label="GTN (sublingual)\nphase-2 model", fillcolor="#FFE0C0"];
        Nitrites[label="Nitrites/MSG", fillcolor="#FFE0C0"];
        Altitude[label="High altitude / flights", fillcolor="#FFE0C0"];
        Strong_odors [label="Strong odors", fillcolor="#FFE0C0"];
        Heat    [label="Heat / hot showers", fillcolor="#FFE0C0"];
        Naps    [label="Daytime naps (REM)", fillcolor="#FFE0C0"];
    }

    /* ===== 12. Comorbidity / impact ===== */
    subgraph cluster_comorb {
        label="12) Comorbidity, Disability, Cost";
        style="rounded,filled"; fillcolor="#EBF5FB"; color="#1A5276";
        MDD     [label="Depression / suicidality\n55-65% lifetime", fillcolor="#D6EAF8"];
        Anx     [label="Anxiety / PTSD", fillcolor="#D6EAF8"];
        Sleep_apn [label="OSA association", fillcolor="#D6EAF8"];
        CV      [label="CV risk (verapamil ECG)", fillcolor="#D6EAF8"];
        Work    [label="Lost work / disability\nLockNess survey", fillcolor="#D6EAF8"];
        HRQOL   [label="HIT-6 / CH-NDI\nCH-specific QoL", fillcolor="#D6EAF8"];
        Suicide [label="Suicide headache\n20-25% ideation", fillcolor="#D6EAF8"];
        EpCH    [label="Episodic CH\n80-90% of patients", fillcolor="#D6EAF8"];
        ChCH    [label="Chronic CH\nno remission >1y", fillcolor="#D6EAF8"];
        HypoVol [label="Hypothalamic\ngray matter↑ (Sprenger 2007)", fillcolor="#D6EAF8"];
        Indo_neg[label="Indomethacin NON-response\n(vs hemicrania continua)", fillcolor="#D6EAF8"];
        MastTry [label="Mast cell tryptase↑\ndural degranulation", fillcolor="#D6EAF8"];
        PGE2    [label="Prostaglandin E2/D2\n(neurogenic)", fillcolor="#D6EAF8"];
        nNOS    [label="nNOS / L-Arg → NO", fillcolor="#D6EAF8"];
        ONS     [label="Occipital nerve\nstimulator (ONS)", fillcolor="#D6EAF8"];
    }

    /* ===== EDGES — pathophysiology ===== */
    HCRTR2 -> Orexin; MTNR1A -> Melat_sec; CLOCK_g -> SCN; PACAP_g -> PACAP;
    FamHx -> Hypo_post; Male -> Hypo_post; Smoking -> Hypo_post;
    ADH4 -> EtOH; EtOH -> Hypo_post; GTN_tr -> Nox; Histamine_tr -> Hypo_post;
    Nitrites -> Nox; Altitude -> Hypo_post; Strong_odors -> TG;
    Heat -> Pial; Naps -> Hypo_post;

    SCN -> Hypo_post; PVN -> Hypo_post; ARC -> Hypo_post;
    Orexin -> Hypo_post; Melat_sec -> Hypo_post [label="trough", style=dashed];
    Cortisol_circ -> Hypo_post; Testos -> Hypo_post;
    Hypo_post -> Cluster_bout; Cluster_bout -> Remission [style=dotted];

    Hypo_post -> TG [label="drive", color="#C0392B", penwidth=1.6];
    Hypo_post -> SSN [label="parasym drive", color="#2E8B57"];
    Hypo_post -> ICA_per [label="symp disruption", color="#7B3FBF"];

    TG -> Dura; TG -> ICA; TG -> Pial;
    TG -> CGRP; TG -> PACAP; TG -> SubP; CGRP -> CGRP_R; CGRP_R -> Pial;
    Pial -> NeuroInflam; Dura -> NeuroInflam; Nox -> CGRP;
    PACAP -> VIP; PACAP -> Pial; Pial -> Pain_attack;

    TG -> TNC; TNC -> Glu_TNC; Glu_TNC -> Thal_VPM; Thal_VPM -> S1_inso;
    S1_inso -> Pain_attack; Pain_attack -> Periorb; Pain_attack -> Allodyn;
    Pain_attack -> Restless;

    SSN -> GSPN -> SPG; SPG -> Lacrimal -> ConjV; SPG -> Nasal_g;
    SPG -> Facial_sweat; SPG -> VIPnerve -> ACh_p; ACh_p -> Pial;
    VIP -> SPG;

    ICA_per -> SCG; SCG -> Ptosis; SCG -> Miosis; SCG -> Anhid;
    Ptosis -> Horner; Miosis -> Horner; Anhid -> Horner;

    /* ===== EDGES — drugs to receptors ===== */
    Suma_SC -> HT1B; Suma_SC -> HT1D; Suma_SC -> HT1F;
    Zolmi_IN -> HT1B; Zolmi_IN -> HT1D;
    Galca -> CGRP [label="binds α/β", color="#138D75", penwidth=1.5];
    Erenu -> CGRP_R [color="#138D75"];
    Vera -> CaV; Vera -> PR_QT;
    Li -> GSK3; Li -> Hypo_post [label="stabilise", style=dashed];
    Topi -> Glu_TNC [label="↓AMPA"]; Topi -> CaV;
    O2_high -> Pial [label="vasoconstr.", color="#138D75"];
    O2_high -> SPG [label="↓parasymp", color="#138D75"];
    Octreo -> SSTR; SSTR -> CGRP [label="↓release", color="#138D75"];
    Lido_IN -> SPG;
    Pred -> NeuroInflam [label="↓", color="#138D75"];
    GON -> TNC [label="↓afferent"];
    Melat -> SCN; Melat -> Hypo_post;
    Civamide -> TRPV1; TRPV1 -> TG;
    SPG_stim -> SPG [label="modulate"]; VNS_nc -> TNC; DBS -> Hypo_post;
    Psilo_lsd -> SCN [label="phase reset?"];

    /* ===== Receptors → physiology (acute abortion) ===== */
    HT1B -> Pial [label="vasoconstr.", color="#1F77B4"];
    HT1D -> CGRP [label="↓ release", color="#1F77B4"];
    HT1F -> TG  [label="↓ neurogenic", color="#1F77B4"];

    /* ===== PK to drug nodes ===== */
    Suma_PK -> Suma_SC; Zol_PK -> Zolmi_IN; Vera_PK -> Vera;
    Li_PK -> Li; Topi_PK -> Topi; Galca_PK -> Galca; Pred_PK -> Pred;

    /* ===== Clinical endpoints ===== */
    Pain_attack -> VAS_pain; Pain_attack -> Duration_min;
    Cluster_bout -> Attack_freq;
    Suma_SC -> Pain_free15 [label="74% @15 min", color="#138D75"];
    O2_high -> Pain_free15 [label="78% @15 min", color="#138D75"];
    Galca -> Mean_red [label="ECH (Goadsby NEJM 2019)", color="#138D75"];
    Vera -> Attack_freq [label="↓", color="#138D75"];
    Li -> Attack_freq [label="↓ (chronic)", color="#138D75"];
    Topi -> Attack_freq [label="↓"];
    GON -> Attack_freq [label="bridge ↓"];
    SPG_stim -> Attack_freq [label="device"];

    /* ===== AE/safety ===== */
    Vera -> PR_QT; Li -> Li_tox; Topi -> Cog_topi; Galca -> Inj_site;
    Pain_attack -> Suic_id; Suic_id -> Suicide;
    Pain_attack -> MDD; MDD -> Anx; Pain_attack -> HRQOL; Pain_attack -> Work;
    Sleep_apn -> Hypo_post; CV -> Vera;

    /* ===== Biomarkers ===== */
    CGRP -> CGRP_ser; VIP -> VIP_ser;
    CGRP_ser -> Resp50 [style=dashed]; VIP_ser -> Resp50 [style=dashed];

    /* ===== Mean weekly reduction synthesis ===== */
    Attack_freq -> Mean_red; Mean_red -> Resp50;

    /* ===== Additional pathophysiology edges ===== */
    nNOS -> Nox; Nox -> Pial [label="cGMP·NO"]; Nox -> Pain_attack;
    PGE2 -> Pial; PGE2 -> NeuroInflam;
    MastTry -> NeuroInflam; MastTry -> Pial;
    Cluster_bout -> EpCH; EpCH -> ChCH [style=dotted, label="evolution 10-15%"];
    Hypo_post -> HypoVol [style=dashed];
    Indo_neg -> Pain_attack [style=dotted, color="#999999"];
    ONS -> TNC [label="modulate"];
    Pred -> PGE2 [label="↓", color="#138D75"];
    Pred -> MastTry [label="↓ stabilise", color="#138D75"];
}
