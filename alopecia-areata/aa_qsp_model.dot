/* ============================================================
   Alopecia Areata — QSP Mechanistic Map
   JAK/STAT Signaling · Immune Privilege Loss · Drug PK/PD
   Nodes: 142  |  Clusters: 11  |  Edges: 200+
   ============================================================ */

digraph AA_QSP {

  graph [
    label="Alopecia Areata — QSP Mechanistic Map\nImmune Privilege Loss · JAK/STAT Signaling · Drug PK/PD (Baricitinib · Ritlecitinib · Tofacitinib)"
    labelloc=t
    fontname="Helvetica-Bold"
    fontsize=20
    bgcolor="#F8F9FA"
    rankdir=LR
    splines=ortho
    nodesep=0.35
    ranksep=0.75
    compound=true
    overlap=false
  ]

  node [fontname="Helvetica" fontsize=9 style="filled,rounded" shape=box margin="0.08,0.04"]
  edge [fontname="Helvetica" fontsize=7 arrowsize=0.6 penwidth=0.8]

  /* ==========================================
     Cluster 1: Genetic & Environmental Risk
     ========================================== */
  subgraph cluster_genetics {
    label="① Genetic & Environmental Risk"
    style=filled
    fillcolor="#FFFDE7"
    color="#F57F17"
    fontname="Helvetica-Bold"
    fontsize=11

    HLA_DRB1   [label="HLA-DRB1*04:01\n(susceptibility allele)"  fillcolor="#FFF176"]
    HLA_DQB1   [label="HLA-DQB1*03:02\n(susceptibility allele)"  fillcolor="#FFF176"]
    HLA_A      [label="HLA-A*02:01\n(CD8+ presentation)"        fillcolor="#FFF176"]
    CTLA4_G    [label="CTLA4 +49G>A\n(T cell regulation)"       fillcolor="#FFCC02"]
    PTPN22_G   [label="PTPN22 R620W\n(T/B cell activation)"     fillcolor="#FFCC02"]
    IL2RA_G    [label="IL-2Rα (CD25)\npolymorphism"             fillcolor="#FFCC02"]
    ULBP3_G    [label="ULBP3/6 locus\n(NKG2D ligand gene)"      fillcolor="#FFB300"]
    ERAP1_G    [label="ERAP1\n(MHC-I peptide trimming)"         fillcolor="#FFCC02"]
    SH2B3_G    [label="SH2B3/LNK\n(JAK2 suppressor gene)"       fillcolor="#FFCC02"]
    AIRE_G     [label="AIRE\n(central tolerance)"               fillcolor="#FFCC02"]
    STRESS_ENV [label="Psychological Stress\n(HPA axis trigger)"  fillcolor="#FFD54F"]
    VIRAL_TRIG [label="Viral Infection\n(molecular mimicry)"      fillcolor="#FFD54F"]
    POLYG_RISK [label="Polygenic\nRisk Score"                    fillcolor="#FF8F00" fontcolor=white shape=diamond]

    HLA_DRB1   -> POLYG_RISK
    HLA_DQB1   -> POLYG_RISK
    HLA_A      -> POLYG_RISK
    CTLA4_G    -> POLYG_RISK
    PTPN22_G   -> POLYG_RISK
    IL2RA_G    -> POLYG_RISK
    ULBP3_G    -> POLYG_RISK
    ERAP1_G    -> POLYG_RISK
    SH2B3_G    -> POLYG_RISK
    AIRE_G     -> POLYG_RISK
    STRESS_ENV -> POLYG_RISK [style=dashed]
    VIRAL_TRIG -> POLYG_RISK [style=dashed]
  }

  /* ==========================================
     Cluster 2: Hair Follicle Biology & Immune Privilege
     ========================================== */
  subgraph cluster_hf_biology {
    label="② Hair Follicle Biology & Immune Privilege"
    style=filled
    fillcolor="#E8F5E9"
    color="#2E7D32"
    fontname="Helvetica-Bold"
    fontsize=11

    ANAGEN     [label="Anagen Phase\n(active growth, 2–7 yr)"   fillcolor="#66BB6A"]
    CATAGEN    [label="Catagen Phase\n(involution, 2–3 wk)"     fillcolor="#FF9800"]
    TELOGEN    [label="Telogen Phase\n(resting, 3 mo)"          fillcolor="#9E9E9E"]
    EXOGEN     [label="Exogen\n(shedding)"                      fillcolor="#EF5350"]
    HF_STEM    [label="Bulge Stem Cells\n(CD34+K15+)"           fillcolor="#A5D6A7"]
    DP_CELLS   [label="Dermal Papilla Cells\n(growth regulator)" fillcolor="#81C784"]
    MATRIX     [label="Matrix Cells\n(rapidly proliferating)"   fillcolor="#81C784"]
    MELANOCYTE [label="Melanocytes\n(pigmentation)"             fillcolor="#5C6BC0" fontcolor=white]

    IP_CD200   [label="CD200/CD200R\n(inhibitory checkpoint)"   fillcolor="#A5D6A7"]
    IP_PDCD1LG [label="PD-L1 (B7-H1)\n(immune checkpoint)"     fillcolor="#A5D6A7"]
    IP_TGFb    [label="TGF-β1/β2\n(local immunosuppression)"   fillcolor="#A5D6A7"]
    IP_aMSH    [label="α-MSH / POMC\n(ACTH-related peptide)"   fillcolor="#A5D6A7"]
    IP_IDO     [label="IDO / TDO\n(tryptophan catabolism)"      fillcolor="#A5D6A7"]
    IP_MHCI    [label="MHC-I\n(normally absent in bulb)"        fillcolor="#FFCDD2"]
    IP_MHCII   [label="MHC-II\n(normally absent)"              fillcolor="#FFCDD2"]
    IP_MICA    [label="MICA/MICB\n(NKG2D ligands ↑AA)"         fillcolor="#FFCDD2"]
    IP_LOSS    [label="IMMUNE PRIVILEGE\nLOSS"                  fillcolor="#D32F2F" fontcolor=white shape=diamond]

    ANAGEN     -> CATAGEN   [label="regression"]
    CATAGEN    -> TELOGEN
    TELOGEN    -> ANAGEN    [label="re-entry"]
    TELOGEN    -> EXOGEN    [label="shedding"]
    HF_STEM    -> MATRIX    [label="→transit amplifying"]
    MATRIX     -> ANAGEN    [label="drives"]
    DP_CELLS   -> HF_STEM   [label="niche signal"]
    ANAGEN     -> IP_LOSS   [label="anagen\nvulnerability" style=dashed]
    IP_CD200   -> IP_LOSS   [label="↓preserves" color="#2E7D32" arrowhead=tee]
    IP_PDCD1LG -> IP_LOSS   [label="↓preserves" color="#2E7D32" arrowhead=tee]
    IP_TGFb    -> IP_LOSS   [label="↓preserves" color="#2E7D32" arrowhead=tee]
    IP_aMSH    -> IP_LOSS   [label="↓preserves" color="#2E7D32" arrowhead=tee]
    IP_IDO     -> IP_LOSS   [label="↓preserves" color="#2E7D32" arrowhead=tee]
    IP_MICA    -> IP_LOSS   [label="↑triggers" color="#C62828"]
    IP_MHCI    -> IP_LOSS   [label="↑triggers" color="#C62828"]
    IP_LOSS    -> CATAGEN   [label="forces entry" color="#C62828" penwidth=2]
  }

  /* ==========================================
     Cluster 3: Innate Immunity
     ========================================== */
  subgraph cluster_innate {
    label="③ Innate Immunity"
    style=filled
    fillcolor="#E3F2FD"
    color="#1565C0"
    fontname="Helvetica-Bold"
    fontsize=11

    NK_CELL    [label="NK Cells\n(CD56+NKG2D+)"                 fillcolor="#1E88E5" fontcolor=white]
    NKT_CELL   [label="NKT Cells\n(CD4+NKG2D+)"                fillcolor="#1976D2" fontcolor=white]
    PDC        [label="Plasmacytoid DCs\n(pDC, type I IFN)"     fillcolor="#42A5F5"]
    MDC        [label="Myeloid DCs\n(Ag presentation)"          fillcolor="#64B5F6"]
    MACRO      [label="Macrophages\n(M1 polarized)"             fillcolor="#1565C0" fontcolor=white]
    MAST       [label="Mast Cells\n(perifollicular infiltrate)"  fillcolor="#90CAF9"]
    ILC1       [label="ILC1 / ILC2\n(innate lymphoid cells)"    fillcolor="#64B5F6"]
    NKG2D_R    [label="NKG2D Receptor\n(activating, C-type lectin)" fillcolor="#0D47A1" fontcolor=white]
    NKG2D_LIG  [label="MICA/MICB/ULBP3/6\n(NKG2D ligands)"     fillcolor="#BBDEFB"]
    TYPE_I_IFN [label="Type I IFN\n(IFN-α/IFN-β)"              fillcolor="#42A5F5"]
    IFN_G_INN  [label="IFN-γ (innate)\n(from NK/NKT early)"    fillcolor="#0D47A1" fontcolor=white]
    COMPLEMENT [label="Complement\n(C3, C5a)"                   fillcolor="#90CAF9"]
    DAMP       [label="DAMPs / HSPs\n(danger signals)"          fillcolor="#BBDEFB"]

    NKG2D_LIG  -> NKG2D_R   [label="binds\n& activates"]
    NKG2D_R    -> NK_CELL   [label="activates"]
    NKG2D_R    -> NKT_CELL  [label="activates"]
    PDC        -> TYPE_I_IFN [label="produces"]
    TYPE_I_IFN -> MDC       [label="matures"]
    MDC        -> NKT_CELL  [label="cross-primes"]
    MACRO      -> IFN_G_INN [label="secretes"]
    NK_CELL    -> IFN_G_INN [label="secretes"]
    NKT_CELL   -> IFN_G_INN [label="secretes"]
    ILC1       -> IFN_G_INN [label="secretes"]
    DAMP       -> PDC       [label="activates"]
    COMPLEMENT -> MAST      [label="activates"]
    MAST       -> IFN_G_INN [label="contributes"]
  }

  /* ==========================================
     Cluster 4: Adaptive Immunity — T Cells
     ========================================== */
  subgraph cluster_adaptive {
    label="④ Adaptive Immunity — T Cells"
    style=filled
    fillcolor="#FCE4EC"
    color="#880E4F"
    fontname="Helvetica-Bold"
    fontsize=11

    CD8_NAIVE  [label="CD8+ Naïve T\n(peripheral blood)"       fillcolor="#F8BBD0"]
    CD8_EFF    [label="CD8+ Effector T\n(NKG2D+ peribulbar)"   fillcolor="#E91E63" fontcolor=white]
    CD8_MEM    [label="CD8+ Memory T\n(skin-resident TRM)"     fillcolor="#AD1457" fontcolor=white]
    CD4_TH1    [label="CD4+ Th1\n(IFN-γ/IL-2 producer)"       fillcolor="#C2185B" fontcolor=white]
    CD4_TH2    [label="CD4+ Th2\n(IL-4/IL-13)"                fillcolor="#EC407A"]
    CD4_TH17   [label="CD4+ Th17\n(IL-17A/F producer)"        fillcolor="#F06292"]
    TREG       [label="Regulatory T\n(CD4+Foxp3+CD25hi)"      fillcolor="#66BB6A"]
    TFH        [label="T Follicular Helper\n(Tfh, CXCR5+)"    fillcolor="#F48FB1"]
    TCR_SIG    [label="TCR Activation\n(MHC-I–peptide)"       fillcolor="#880E4F" fontcolor=white]
    CD28_COS   [label="CD28\nCo-stimulation"                   fillcolor="#AD1457" fontcolor=white]
    CTLA4_INH  [label="CTLA-4\n(checkpoint, inhibitory)"      fillcolor="#81C784"]
    PD1_INH    [label="PD-1 / PD-L1\n(checkpoint)"            fillcolor="#81C784"]
    GRANZYME_B [label="Granzyme B\n(cytotoxic granule)"        fillcolor="#B71C1C" fontcolor=white]
    PERFORIN   [label="Perforin\n(pore-forming protein)"       fillcolor="#B71C1C" fontcolor=white]
    FAS_FASL   [label="Fas / FasL\n(apoptosis pathway)"        fillcolor="#D32F2F" fontcolor=white]

    CD8_NAIVE  -> CD8_EFF   [label="activation\n& expansion"]
    CD8_EFF    -> CD8_MEM   [label="→memory"]
    TCR_SIG    -> CD8_EFF   [label="drives\nactivation"]
    CD28_COS   -> CD8_EFF   [label="co-stimulates"]
    CTLA4_INH  -> CD8_EFF   [label="inhibits" arrowhead=tee color="#2E7D32"]
    PD1_INH    -> CD8_EFF   [label="inhibits" arrowhead=tee color="#2E7D32"]
    TREG       -> CD8_EFF   [label="suppresses" arrowhead=tee color="#2E7D32"]
    TREG       -> CD4_TH1   [label="suppresses" arrowhead=tee color="#2E7D32"]
    CD4_TH1    -> CD8_EFF   [label="IL-2\nhelp"]
    CD8_EFF    -> GRANZYME_B [label="releases"]
    CD8_EFF    -> PERFORIN  [label="releases"]
    CD8_EFF    -> FAS_FASL  [label="expresses"]
    CD8_MEM    -> CD8_EFF   [label="re-activation"]
  }

  /* ==========================================
     Cluster 5: Cytokine & Chemokine Network
     ========================================== */
  subgraph cluster_cytokines {
    label="⑤ Cytokine & Chemokine Network"
    style=filled
    fillcolor="#FFF3E0"
    color="#E65100"
    fontname="Helvetica-Bold"
    fontsize=11

    IFNG       [label="IFN-γ\n(master pathogenic cytokine)"    fillcolor="#E65100" fontcolor=white]
    IL15       [label="IL-15\n(NK & CD8+ activation)"          fillcolor="#F57C00" fontcolor=white]
    IL2        [label="IL-2\n(T cell growth & Treg)"           fillcolor="#FF8F00"]
    IL21       [label="IL-21\n(Tfh/B cell support)"            fillcolor="#FFA000"]
    IL4        [label="IL-4\n(Th2, IgE switch)"               fillcolor="#FFC107"]
    IL13       [label="IL-13\n(Th2, fibrosis)"                fillcolor="#FFCA28"]
    IL17A      [label="IL-17A\n(neutrophil recruit)"           fillcolor="#FFB300"]
    TNFA       [label="TNF-α\n(pro-inflammatory)"              fillcolor="#F44336" fontcolor=white]
    IL6        [label="IL-6\n(acute phase, Th17)"              fillcolor="#FF7043"]
    IL10       [label="IL-10\n(anti-inflammatory, Treg)"       fillcolor="#66BB6A"]
    TGFB       [label="TGF-β\n(Treg induction, fibrosis)"     fillcolor="#81C784"]
    IL33       [label="IL-33 / TSLP\n(type 2, atopic overlap)" fillcolor="#FFCC80"]
    CXCL9      [label="CXCL9 (MIG)\n(CXCR3 ligand)"           fillcolor="#FF8F00"]
    CXCL10     [label="CXCL10 (IP-10)\n(CXCR3 ligand, serum biomarker)" fillcolor="#FF6F00" fontcolor=white]
    CXCL11     [label="CXCL11 (I-TAC)\n(CXCR3 ligand)"        fillcolor="#FF8F00"]
    CXCL3      [label="CXCL3/CCL2\n(monocyte recruit)"        fillcolor="#FFB74D"]
    CXCR3      [label="CXCR3\n(receptor: CD8+/Th1)"           fillcolor="#BF360C" fontcolor=white]

    IFNG       -> CXCL9    [label="induces"]
    IFNG       -> CXCL10   [label="induces (primary)"]
    IFNG       -> CXCL11   [label="induces"]
    CXCL9      -> CXCR3    [label="binds"]
    CXCL10     -> CXCR3    [label="binds (high affinity)"]
    CXCL11     -> CXCR3    [label="binds"]
    IL10       -> IFNG     [label="inhibits" arrowhead=tee color="#2E7D32"]
    TGFB       -> IL10     [label="induces"]
    IL6        -> IL17A    [label="with TGF-β\nTh17 axis"]
    TGFB       -> IL17A    [label="with IL-6"]
    IL33       -> IL4      [label="promotes\ntype 2"]
    IL15       -> IL2      [label="synergy"]
  }

  /* ==========================================
     Cluster 6: JAK/STAT Signaling
     ========================================== */
  subgraph cluster_jak_stat {
    label="⑥ JAK/STAT Signaling — Core Drug Target"
    style=filled
    fillcolor="#EDE7F6"
    color="#4527A0"
    fontname="Helvetica-Bold"
    fontsize=11

    JAK1       [label="JAK1\n(IFN-γR1, IL-2Rβ, IL-15Rβ)"    fillcolor="#6A1B9A" fontcolor=white]
    JAK2       [label="JAK2\n(IFN-γR2, IL-15Rβ, cytokines)"  fillcolor="#7B1FA2" fontcolor=white]
    JAK3       [label="JAK3\n(γc: IL-2Rγ, IL-15Rγ)"         fillcolor="#4A148C" fontcolor=white]
    TYK2       [label="TYK2\n(IFNAR1/2, IL-12Rβ1)"           fillcolor="#7B1FA2" fontcolor=white]
    STAT1_MOL  [label="STAT1\n(IFN-γ→homodimer GAS element)"  fillcolor="#9C27B0" fontcolor=white]
    STAT3_MOL  [label="STAT3\n(IL-6, IL-21, gp130)"          fillcolor="#8E24AA" fontcolor=white]
    STAT4_MOL  [label="STAT4\n(IL-12, IL-23)"                fillcolor="#AB47BC"]
    STAT5_MOL  [label="STAT5a/5b\n(IL-2, IL-15, PRL)"        fillcolor="#CE93D8"]
    STAT6_MOL  [label="STAT6\n(IL-4, IL-13)"                 fillcolor="#E1BEE7"]
    IRF1       [label="IRF1\n(STAT1 target → MHC-I ↑)"       fillcolor="#9C27B0" fontcolor=white]
    IRF7       [label="IRF7\n(type I IFN amplification)"      fillcolor="#AB47BC"]
    NFKB_JAK   [label="NF-κB\n(TNFA, inflammatory genes)"    fillcolor="#7B1FA2" fontcolor=white]
    SOCS1      [label="SOCS1\n(negative feedback JAK1/2)"    fillcolor="#A5D6A7"]
    SOCS3      [label="SOCS3\n(negative feedback JAK2)"      fillcolor="#C8E6C9"]
    GAS_ELEM   [label="GAS/ISRE Elements\n(promoter binding)" fillcolor="#CE93D8"]
    CIITA      [label="CIITA / NLRC5\n(MHC-I/II transactivator)" fillcolor="#E1BEE7"]
    PIM1K      [label="PIM1/PIM2\n(STAT5 target, survival)"  fillcolor="#E1BEE7"]
    PI3K_AKT   [label="PI3K / Akt\n(JAK-coupled survival)"   fillcolor="#D1C4E9"]
    MAPK_ERK   [label="MAPK / ERK1/2\n(proliferation)"       fillcolor="#D1C4E9"]

    JAK1       -> STAT1_MOL [label="pY701"]
    JAK1       -> STAT3_MOL [label="pY705"]
    JAK2       -> STAT1_MOL [label="pY701"]
    JAK2       -> STAT5_MOL [label="pY694"]
    JAK3       -> STAT5_MOL [label="pY694"]
    TYK2       -> STAT1_MOL [label="type I IFN\npath"]
    TYK2       -> STAT3_MOL [label="IL-6 type"]
    STAT1_MOL  -> IRF1      [label="transcribes"]
    STAT1_MOL  -> NFKB_JAK  [label="cooperates"]
    STAT1_MOL  -> GAS_ELEM  [label="GAS element"]
    STAT3_MOL  -> SOCS3     [label="induces"]
    STAT5_MOL  -> PIM1K     [label="transcribes"]
    STAT5_MOL  -> SOCS1     [label="induces"]
    IRF1       -> CIITA     [label="transactivates"]
    CIITA      -> IP_MHCI   [label="↑MHC-I" lhead=cluster_hf_biology]
    SOCS1      -> JAK1      [label="inhibits" arrowhead=tee color="#2E7D32"]
    SOCS1      -> JAK2      [label="inhibits" arrowhead=tee color="#2E7D32"]
    SOCS3      -> JAK2      [label="inhibits" arrowhead=tee color="#2E7D32"]
    PI3K_AKT   -> MAPK_ERK  [label="crosstalk"]
  }

  /* ==========================================
     Cluster 7: Drug PK — Baricitinib, Ritlecitinib, Tofacitinib, Duplimab
     ========================================== */
  subgraph cluster_pk {
    label="⑦ Drug Pharmacokinetics"
    style=filled
    fillcolor="#E0F2F1"
    color="#004D40"
    fontname="Helvetica-Bold"
    fontsize=11

    BARI_DOSE  [label="Baricitinib Dose\n2 mg or 4 mg QD PO"   fillcolor="#00695C" fontcolor=white]
    BARI_GUT   [label="Baricitinib GUT\n(ka=1.35/h, F=79%)"    fillcolor="#00796B" fontcolor=white]
    BARI_CENT  [label="Baricitinib CENT\n(Vc=19.3 L)"          fillcolor="#00897B" fontcolor=white]
    BARI_PERI  [label="Baricitinib PERI\n(Vp=29.4 L)"          fillcolor="#009688" fontcolor=white]
    BARI_ELIM  [label="Baricitinib ELIM\n(CL=6.2 L/h, 75% renal)" fillcolor="#4DB6AC"]

    RITL_DOSE  [label="Ritlecitinib Dose\n50 mg or 200 mg QD PO" fillcolor="#006064" fontcolor=white]
    RITL_GUT   [label="Ritlecitinib GUT\n(ka=2.0/h, F=70%)"    fillcolor="#00838F" fontcolor=white]
    RITL_CENT  [label="Ritlecitinib CENT\n(Vc=110 L, t½≈2h)"   fillcolor="#0097A7" fontcolor=white]
    RITL_META  [label="Ritlecitinib META\n(CYP3A4, 50 mg→100%)" fillcolor="#4DD0E1"]
    RITL_JAK3B [label="Ritlecitinib Bound\n(JAK3 covalent adduct)" fillcolor="#006064" fontcolor=white]

    TOFA_DOSE  [label="Tofacitinib Dose\n5 mg BID PO"          fillcolor="#00695C" fontcolor=white]
    TOFA_GUT   [label="Tofacitinib GUT\n(ka=2.5/h, F=74%)"    fillcolor="#00796B" fontcolor=white]
    TOFA_CENT  [label="Tofacitinib CENT\n(Vc=29 L, t½=3h)"    fillcolor="#00897B" fontcolor=white]
    TOFA_META  [label="Tofacitinib META\n(CYP3A4/2C19, 70%)"   fillcolor="#4DB6AC"]

    DUPIL_DOSE [label="Dupilumab Dose\n300 mg SC Q2W"          fillcolor="#006064" fontcolor=white]
    DUPIL_SC   [label="Dupilumab SC\n(Fsc=64%, Tmax=7d)"       fillcolor="#26C6DA"]
    DUPIL_CENT [label="Dupilumab CENT\n(Vc=4.8 L, t½=22d)"    fillcolor="#0097A7" fontcolor=white]

    BARI_DOSE  -> BARI_GUT   [label="oral"]
    BARI_GUT   -> BARI_CENT  [label="ka·AGUT"]
    BARI_CENT  <-> BARI_PERI [label="CLD=3.1 L/h" dir=both]
    BARI_CENT  -> BARI_ELIM  [label="CL/V"]

    RITL_DOSE  -> RITL_GUT   [label="oral"]
    RITL_GUT   -> RITL_CENT  [label="ka·AGUT"]
    RITL_CENT  -> RITL_META  [label="CL=66 L/h"]
    RITL_CENT  -> RITL_JAK3B [label="covalent\nbinding"]

    TOFA_DOSE  -> TOFA_GUT   [label="oral"]
    TOFA_GUT   -> TOFA_CENT  [label="ka·AGUT"]
    TOFA_CENT  -> TOFA_META  [label="CL=30 L/h"]

    DUPIL_DOSE -> DUPIL_SC   [label="SC injection"]
    DUPIL_SC   -> DUPIL_CENT [label="absorption"]
  }

  /* ==========================================
     Cluster 8: Drug PD / Target Engagement
     ========================================== */
  subgraph cluster_pd {
    label="⑧ Drug Pharmacodynamics & Target Engagement"
    style=filled
    fillcolor="#E8EAF6"
    color="#283593"
    fontname="Helvetica-Bold"
    fontsize=11

    BARI_JAK1I [label="Baricitinib\nJAK1 IC50=5.9 nM"          fillcolor="#3949AB" fontcolor=white]
    BARI_JAK2I [label="Baricitinib\nJAK2 IC50=5.7 nM"          fillcolor="#303F9F" fontcolor=white]
    BARI_TYK2I [label="Baricitinib\nTYK2 IC50=53 nM"           fillcolor="#3949AB" fontcolor=white]
    RITL_JAK3I [label="Ritlecitinib\nJAK3 (covalent Cys909)"   fillcolor="#1A237E" fontcolor=white]
    RITL_TECI  [label="Ritlecitinib\nTEC/BTK/BMX inhibition"   fillcolor="#283593" fontcolor=white]
    TOFA_JAK1I [label="Tofacitinib\nJAK1 IC50=3.2 nM"          fillcolor="#3F51B5" fontcolor=white]
    TOFA_JAK3I [label="Tofacitinib\nJAK3 IC50=1.6 nM"          fillcolor="#3F51B5" fontcolor=white]
    DUPIL_IL4RI[label="Dupilumab\nIL-4Rα blockade (IL-4/IL-13)" fillcolor="#7986CB"]

    PSTAT1_INH [label="p-STAT1\nInhibition (%)"                 fillcolor="#7986CB"]
    PSTAT3_INH [label="p-STAT3\nInhibition (%)"                 fillcolor="#7986CB"]
    PSTAT5_INH [label="p-STAT5\nInhibition (%)"                 fillcolor="#9FA8DA"]
    IFN_SIG_INH[label="IFN-γ Signature\nInhibition (%)"         fillcolor="#9FA8DA"]
    NKG2D_RED  [label="NKG2D+ T cell\nReduction (%)"            fillcolor="#9FA8DA"]
    CD8_RED    [label="Perifollicular\nCD8+ T Reduction (%)"    fillcolor="#9FA8DA"]
    CXCL10_RED [label="Serum CXCL10\nReduction (%)"             fillcolor="#C5CAE9"]

    BARI_CENT  -> BARI_JAK1I [label="Hill Emax" ltail=cluster_pk]
    BARI_CENT  -> BARI_JAK2I [label="Hill Emax" ltail=cluster_pk]
    BARI_CENT  -> BARI_TYK2I [label="Hill Emax" ltail=cluster_pk]
    RITL_CENT  -> RITL_JAK3I [label="covalent" ltail=cluster_pk]
    RITL_CENT  -> RITL_TECI  [label="covalent" ltail=cluster_pk]
    TOFA_CENT  -> TOFA_JAK1I [label="Hill Emax" ltail=cluster_pk]
    TOFA_CENT  -> TOFA_JAK3I [label="Hill Emax" ltail=cluster_pk]
    DUPIL_CENT -> DUPIL_IL4RI[label="competitive\nbinding" ltail=cluster_pk]

    BARI_JAK1I -> PSTAT1_INH
    BARI_JAK2I -> PSTAT5_INH
    BARI_TYK2I -> IFN_SIG_INH
    RITL_JAK3I -> PSTAT5_INH
    RITL_TECI  -> NKG2D_RED
    TOFA_JAK1I -> PSTAT1_INH
    TOFA_JAK3I -> PSTAT5_INH
    DUPIL_IL4RI-> PSTAT3_INH [label="IL-4/13\nSTAT3 axis"]
    PSTAT1_INH -> IFN_SIG_INH
    PSTAT5_INH -> CD8_RED
    IFN_SIG_INH-> CXCL10_RED
  }

  /* ==========================================
     Cluster 9: Hair Loss Pathology
     ========================================== */
  subgraph cluster_pathology {
    label="⑨ Hair Loss Pathology"
    style=filled
    fillcolor="#FFEBEE"
    color="#B71C1C"
    fontname="Helvetica-Bold"
    fontsize=11

    PERIBULBAR [label="Peribulbar\nInfiltrate ('swarm of bees')" fillcolor="#E53935" fontcolor=white]
    CYTOTOX    [label="Cytotoxic Attack\n(CD8+ on bulb)"         fillcolor="#C62828" fontcolor=white]
    MELANOLOSS [label="Melanocyte\nDepletion (canitities)"       fillcolor="#D32F2F" fontcolor=white]
    DYSTROPHIC [label="Dystrophic Anagen\n(exclamation hairs)"   fillcolor="#EF9A9A"]
    TEL_ENTRY  [label="Premature\nTelogen Entry"                 fillcolor="#FFCDD2"]
    MINIATUR   [label="Follicle\nMiniaturization"                fillcolor="#EF9A9A"]
    FIBROUS    [label="Perifollicular\nFibrosis (late)"          fillcolor="#FFCDD2"]
    AA_PATCH   [label="ALOPECIA\nPATCH"                          fillcolor="#B71C1C" fontcolor=white shape=diamond]
    REGROWTH   [label="Hair Regrowth\n(vellus→terminal)"         fillcolor="#81C784"]
    RELAPSE    [label="Disease\nRelapse"                         fillcolor="#EF9A9A" shape=diamond]

    PERIBULBAR -> CYTOTOX   [label="CD8+\nexecution"]
    CYTOTOX    -> MELANOLOSS
    CYTOTOX    -> DYSTROPHIC
    CYTOTOX    -> TEL_ENTRY [label="forces"]
    TEL_ENTRY  -> MINIATUR
    MINIATUR   -> FIBROUS   [label="chronic"]
    DYSTROPHIC -> AA_PATCH
    MINIATUR   -> AA_PATCH
    TEL_ENTRY  -> AA_PATCH
    REGROWTH   -> RELAPSE   [label="off-drug\nrecurrence" style=dashed]
    AA_PATCH   -> REGROWTH  [label="treatment\nrecovery" color=blue style=dashed]
  }

  /* ==========================================
     Cluster 10: Clinical Endpoints & Disease Classification
     ========================================== */
  subgraph cluster_clinical {
    label="⑩ Clinical Endpoints & Disease Classification"
    style=filled
    fillcolor="#F3E5F5"
    color="#4A148C"
    fontname="Helvetica-Bold"
    fontsize=11

    SALT       [label="SALT Score\n(0=no loss, 100=complete)" fillcolor="#6A1B9A" fontcolor=white]
    SALT20     [label="SALT20\n(≥20% improvement)"            fillcolor="#7B1FA2" fontcolor=white]
    SALT50     [label="SALT50\n(≥50% improvement)"            fillcolor="#8E24AA" fontcolor=white]
    SALT90     [label="SALT90\n(≥90% improvement, near-complete)" fillcolor="#9C27B0" fontcolor=white]
    OLSS_EL    [label="OLSS\n(eyebrow & eyelash regrowth)"    fillcolor="#AB47BC"]
    AT_CLASS   [label="Alopecia Totalis\n(AT, 100% scalp)"    fillcolor="#CE93D8"]
    AU_CLASS   [label="Alopecia Universalis\n(AU, all body)"  fillcolor="#CE93D8"]
    PATCHY     [label="Patchy AA\n(S1=<25% to S5=75-99%)"    fillcolor="#E1BEE7"]
    NAIL_DIST  [label="Nail Dystrophy\n(20-nail dystrophy)"   fillcolor="#CE93D8"]
    PRURITUS_S [label="Pruritus\n(trichodynia, pre-shed sign)" fillcolor="#E1BEE7"]
    DLQI_QOL   [label="DLQI / Skindex-29\n(dermatology QoL)"  fillcolor="#BA68C8"]
    PSYCH_COMOR[label="Anxiety / Depression\n(psychiatric comorbidity)" fillcolor="#CE93D8"]
    THYROID_CO [label="Thyroid Disease\n(comorbidity 14-30%)" fillcolor="#E1BEE7"]
    ATOPY_CO   [label="Atopic Dermatitis\n(comorbidity ≈25%)" fillcolor="#E1BEE7"]
    VITILIGO_CO[label="Vitiligo\n(comorbidity)"               fillcolor="#E1BEE7"]
    HAIR_PULL  [label="Hair Pull Test\n(+ve in active AA)"    fillcolor="#E1BEE7"]
    DERMOSCOPY2[label="Dermoscopy\n(yellow dots, black dots,\nexcl. mark hairs)" fillcolor="#E8D5F5"]

    AA_PATCH   -> SALT       [ltail=cluster_pathology]
    SALT       -> PATCHY     [label="<100% scalp"]
    SALT       -> AT_CLASS   [label="100% scalp"]
    AT_CLASS   -> AU_CLASS   [label="body hair\nloss"]
    SALT       -> SALT20
    SALT       -> SALT50
    SALT       -> SALT90
    SALT       -> OLSS_EL    [label="brow/lash\nextension"]
    SALT       -> DLQI_QOL
    DLQI_QOL   -> PSYCH_COMOR
    NAIL_DIST  -> DLQI_QOL
    DERMOSCOPY2-> HAIR_PULL
  }

  /* ==========================================
     Cluster 11: B Cells & Humoral Immunity
     ========================================== */
  subgraph cluster_bcell {
    label="⑪ B Cell & Humoral Immunity (Secondary)"
    style=filled
    fillcolor="#E0F7FA"
    color="#006064"
    fontname="Helvetica-Bold"
    fontsize=11

    BCELL_NAIVE[label="B Cell Naïve\n(follicular)"            fillcolor="#00ACC1"]
    BCELL_ACT  [label="B Cell Activated\n(GC reaction)"       fillcolor="#00838F" fontcolor=white]
    PLASMA     [label="Plasma Cell\n(Ig secreting)"           fillcolor="#006064" fontcolor=white]
    IgG_AA     [label="Anti-follicle IgG\n(role debated)"     fillcolor="#80DEEA"]
    IgE_AA     [label="IgE\n(atopic overlap)"                 fillcolor="#80DEEA"]
    MELAN_AB   [label="Anti-melanocyte Ab\n(TYRP1/TYRP2)"     fillcolor="#B2EBF2"]
    GC_REACT   [label="Germinal Center\nReaction"             fillcolor="#00838F" fontcolor=white]
    SOMATIC_HM [label="Somatic\nHypermutation"                fillcolor="#4DD0E1"]

    BCELL_NAIVE-> BCELL_ACT
    BCELL_ACT  -> GC_REACT
    GC_REACT   -> SOMATIC_HM
    GC_REACT   -> PLASMA
    PLASMA     -> IgG_AA
    PLASMA     -> IgE_AA
    PLASMA     -> MELAN_AB
  }

  /* ==========================================
     Cross-cluster Edges
     ========================================== */

  // Genetics → downstream
  POLYG_RISK  -> IP_MICA    [label="ULBP3/6 ↑\ngene effect" lhead=cluster_hf_biology color="#F57F17"]
  POLYG_RISK  -> NKG2D_LIG  [label="ULBP3/6" lhead=cluster_innate color="#F57F17"]
  CTLA4_G     -> CTLA4_INH  [label="reduces\nexpression" lhead=cluster_adaptive color="#F57F17"]
  IL2RA_G     -> TREG       [label="Treg number\n↓" lhead=cluster_adaptive color="#F57F17"]

  // Immune privilege loss → innate activation
  IP_MICA     -> NKG2D_LIG  [label="upregulates" lhead=cluster_innate color="#B71C1C"]
  IP_MHCI     -> TCR_SIG    [label="CD8+ recognition" lhead=cluster_adaptive color="#B71C1C"]
  IP_LOSS     -> PERIBULBAR [label="allows\nimmune access" lhead=cluster_pathology color="#B71C1C" penwidth=2]

  // Innate → cytokines
  IFN_G_INN   -> IFNG       [label="amplifies" lhead=cluster_cytokines color="#1565C0"]
  NKG2D_R     -> NK_CELL    [ltail=cluster_innate]
  NKG2D_R     -> NKT_CELL   [ltail=cluster_innate]

  // Innate → adaptive
  MDC         -> CD8_NAIVE  [label="Ag-cross\npresentation" lhead=cluster_adaptive color="#1565C0"]
  TYPE_I_IFN  -> CD8_EFF    [label="enhances\ncytotoxicity" lhead=cluster_adaptive color="#1565C0"]

  // Cytokines → JAK/STAT
  IFNG        -> JAK1       [label="IFN-γR1/R2\nactivation" lhead=cluster_jak_stat color="#E65100" penwidth=1.5]
  IFNG        -> JAK2       [label="IFN-γR2" lhead=cluster_jak_stat color="#E65100" penwidth=1.5]
  IL15        -> JAK1       [label="IL-15Rβ" lhead=cluster_jak_stat color="#E65100"]
  IL15        -> JAK3       [label="γc chain" lhead=cluster_jak_stat color="#E65100"]
  IL2         -> JAK1       [label="IL-2Rβ" lhead=cluster_jak_stat color="#E65100"]
  IL2         -> JAK3       [label="γc chain" lhead=cluster_jak_stat color="#E65100"]
  IL4         -> TYK2       [label="IL-4R\n→STAT6" lhead=cluster_jak_stat color="#E65100"]
  IL6         -> JAK1       [label="gp130" lhead=cluster_jak_stat color="#E65100"]
  IL6         -> TYK2       [label="gp130/TYK2" lhead=cluster_jak_stat color="#E65100"]
  TYPE_I_IFN  -> TYK2       [label="IFNAR1" lhead=cluster_jak_stat color="#1565C0"]

  // JAK/STAT → effects
  STAT1_MOL   -> IP_MHCI    [label="MHC-I ↑\nvia IRF1" lhead=cluster_hf_biology color="#4527A0"]
  STAT5_MOL   -> CD8_EFF    [label="survival &\nproliferation" lhead=cluster_adaptive color="#4527A0"]

  // Cytokines → T cells
  CXCR3       -> CD8_EFF    [label="recruits to\nfollicle" lhead=cluster_adaptive color="#E65100"]
  IL15        -> NK_CELL    [label="activates" lhead=cluster_innate color="#E65100"]
  IL15        -> CD8_EFF    [label="drives\nCD8 expansion" lhead=cluster_adaptive color="#E65100" penwidth=1.5]
  IL2         -> TREG       [label="Treg\nsurvival" lhead=cluster_adaptive color="#2E7D32"]
  TGFB        -> TREG       [label="Treg\ninduction" lhead=cluster_adaptive color="#2E7D32"]

  // Adaptive → cytokines (amplification loop)
  CD8_EFF     -> IFNG       [label="major source\n(amplification)" lhead=cluster_cytokines color="#880E4F" penwidth=2 style=dashed]
  CD4_TH1     -> IFNG       [label="secretes" lhead=cluster_cytokines color="#880E4F"]
  NK_CELL     -> IFNG       [label="innate IFN-γ" lhead=cluster_cytokines color="#1565C0"]

  // T cells → pathology
  CD8_EFF     -> PERIBULBAR [label="infiltrates\nfollicle" lhead=cluster_pathology color="#880E4F" penwidth=2]
  GRANZYME_B  -> CYTOTOX    [label="granule\nexocytosis" lhead=cluster_pathology color="#880E4F"]
  PERFORIN    -> CYTOTOX    [label="pore\nformation" lhead=cluster_pathology color="#880E4F"]
  FAS_FASL    -> CYTOTOX    [label="apoptosis\npathway" lhead=cluster_pathology color="#880E4F"]
  IFNG        -> MELANOLOSS [label="direct\ntoxicity" lhead=cluster_pathology color="#E65100"]

  // Drug PD → JAK/STAT
  BARI_JAK1I  -> JAK1       [label="inhibits\n(reversible)" arrowhead=tee color="#0D47A1" penwidth=2 lhead=cluster_jak_stat ltail=cluster_pd]
  BARI_JAK2I  -> JAK2       [label="inhibits\n(reversible)" arrowhead=tee color="#0D47A1" penwidth=2 lhead=cluster_jak_stat ltail=cluster_pd]
  RITL_JAK3I  -> JAK3       [label="inhibits\n(irreversible)" arrowhead=tee color="#0D47A1" penwidth=2 lhead=cluster_jak_stat ltail=cluster_pd]
  TOFA_JAK1I  -> JAK1       [label="inhibits" arrowhead=tee color="#0D47A1" penwidth=2 lhead=cluster_jak_stat ltail=cluster_pd]
  TOFA_JAK3I  -> JAK3       [label="inhibits" arrowhead=tee color="#0D47A1" lhead=cluster_jak_stat ltail=cluster_pd]
  DUPIL_IL4RI -> IL4        [label="IL-4Rα\nblockade" arrowhead=tee color="#0D47A1" lhead=cluster_cytokines ltail=cluster_pd]

  // Drug PD → outcomes
  PSTAT1_INH  -> IFNG       [label="↓ IFN-γ\nsignaling" arrowhead=tee color="#0D47A1" lhead=cluster_cytokines ltail=cluster_pd]
  CD8_RED     -> PERIBULBAR [label="↓ infiltrate" arrowhead=tee color="#0D47A1" lhead=cluster_pathology ltail=cluster_pd]
  CXCL10_RED  -> CXCL10     [label="serum\nbiomarker ↓" arrowhead=tee color="#0D47A1" lhead=cluster_cytokines ltail=cluster_pd]
  NKG2D_RED   -> NK_CELL    [label="↓ NK\nactivation" arrowhead=tee color="#0D47A1" lhead=cluster_innate ltail=cluster_pd]

  // Clinical outcomes from pathology
  SALT        -> SALT50     [ltail=cluster_clinical]
  SALT50      -> DLQI_QOL   [ltail=cluster_clinical]
  REGROWTH    -> SALT       [label="SALT ↓\n(improvement)" ltail=cluster_pathology lhead=cluster_clinical color="blue" penwidth=2]

  // B cells
  TFH         -> GC_REACT   [label="help" lhead=cluster_bcell ltail=cluster_adaptive]
  IL21        -> BCELL_ACT  [label="Tfh cytokine" lhead=cluster_bcell ltail=cluster_cytokines]
  IL4         -> IgE_AA     [label="class switch" lhead=cluster_bcell ltail=cluster_cytokines]
}
