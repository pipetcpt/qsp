digraph AMD_QSP_Model {
    graph [
        label="Age-related Macular Degeneration (AMD)\nQuantitative Systems Pharmacology Model\nDrug Targets: Anti-VEGF (Ranibizumab/Aflibercept/Bevacizumab/Faricimab), Complement Inhibitors, Neuroprotection"
        fontsize=22 fontname="Helvetica-Bold" labelloc=t
        rankdir=TB bgcolor="#F8F9FA" splines=ortho nodesep=0.5 ranksep=0.8
        compound=true
    ]
    node [fontname="Helvetica" fontsize=10 style="filled,rounded" shape=box]
    edge [fontname="Helvetica" fontsize=9]

    /* ============================================================
       CLUSTER 1: DRUG PK — SYSTEMIC
       ============================================================ */
    subgraph cluster_pk_systemic {
        label="Drug PK — Systemic" style="filled,rounded"
        bgcolor="#E8F4FD" color="#2980B9" penwidth=2 fontsize=14 fontcolor="#1A5276"

        RNB_dose [label="Ranibizumab\nIVT Dose\n(0.5mg)" fillcolor="#AED6F1" shape=cylinder]
        AFL_dose [label="Aflibercept\nIVT Dose\n(2mg)" fillcolor="#AED6F1" shape=cylinder]
        BEV_dose [label="Bevacizumab\nIVT Dose\n(1.25mg)" fillcolor="#AED6F1" shape=cylinder]
        FAR_dose [label="Faricimab\nIVT Dose\n(6mg)" fillcolor="#AED6F1" shape=cylinder]
        BRO_dose [label="Brolucizumab\nIVT Dose\n(6mg)" fillcolor="#AED6F1" shape=cylinder]

        RNB_vit [label="Ranibizumab\nVitreous\n[Fab, 48kDa]" fillcolor="#5DADE2"]
        AFL_vit [label="Aflibercept\nVitreous\n[Fusion, 115kDa]" fillcolor="#5DADE2"]
        BEV_vit [label="Bevacizumab\nVitreous\n[IgG, 149kDa]" fillcolor="#5DADE2"]
        FAR_vit [label="Faricimab\nVitreous\n[IgG-like, 150kDa]" fillcolor="#5DADE2"]
        BRO_vit [label="Brolucizumab\nVitreous\n[scFv, 26kDa]" fillcolor="#5DADE2"]

        RNB_ret [label="Ranibizumab\nRetina/RPE" fillcolor="#2E86C1"]
        AFL_ret [label="Aflibercept\nRetina/RPE" fillcolor="#2E86C1"]
        BEV_ret [label="Bevacizumab\nRetina/RPE" fillcolor="#2E86C1"]
        FAR_ret [label="Faricimab\nRetina/RPE" fillcolor="#2E86C1"]
        BRO_ret [label="Brolucizumab\nRetina/RPE" fillcolor="#2E86C1"]

        SYS_circ [label="Systemic\nCirculation\n(Plasma)" fillcolor="#D6EAF8"]

        RNB_dose -> RNB_vit [label="IVT injection"]
        AFL_dose -> AFL_vit [label="IVT injection"]
        BEV_dose -> BEV_vit [label="IVT injection"]
        FAR_dose -> FAR_vit [label="IVT injection"]
        BRO_dose -> BRO_vit [label="IVT injection"]

        RNB_vit -> RNB_ret [label="Diffusion\n(t1/2~3d)"]
        AFL_vit -> AFL_ret [label="Diffusion\n(t1/2~7d)"]
        BEV_vit -> BEV_ret [label="Diffusion\n(t1/2~9d)"]
        FAR_vit -> FAR_ret [label="Diffusion\n(t1/2~7d)"]
        BRO_vit -> BRO_ret [label="Diffusion\n(t1/2~4d)"]

        RNB_vit -> SYS_circ [label="AH drainage\nkaq", style=dashed]
        AFL_vit -> SYS_circ [label="AH drainage", style=dashed]
        BEV_vit -> SYS_circ [label="AH drainage", style=dashed]
    }

    /* ============================================================
       CLUSTER 2: VEGF / ANGIOGENESIS PATHWAY
       ============================================================ */
    subgraph cluster_vegf {
        label="VEGF / Angiogenesis Pathway" style="filled,rounded"
        bgcolor="#FDEBD0" color="#E67E22" penwidth=2 fontsize=14 fontcolor="#784212"

        HIF1a [label="HIF-1α\nHypoxia\nInducible Factor" fillcolor="#FAD7A0"]
        HIF2a [label="HIF-2α" fillcolor="#FAD7A0"]
        VEGF_mRNA [label="VEGF-A\nmRNA\ntranscription" fillcolor="#F0B27A"]
        VEGFA165 [label="VEGF-A165\n(free)\n[pro-angiogenic]" fillcolor="#E59866" fontcolor="white"]
        VEGFA121 [label="VEGF-A121\n(isoform)" fillcolor="#F0B27A"]
        PlGF [label="PlGF\n(Placental GF)" fillcolor="#FAD7A0"]
        VEGFB [label="VEGF-B" fillcolor="#FAD7A0"]
        VEGFC [label="VEGF-C\n(lymphangiogenic)" fillcolor="#FAD7A0"]

        VEGFR1 [label="VEGFR-1\n(Flt-1)\n[decoy receptor]" fillcolor="#E59866"]
        VEGFR2 [label="VEGFR-2\n(KDR/Flk-1)\n[signaling receptor]" fillcolor="#CA6F1E" fontcolor="white"]
        VEGFR2_act [label="pVEGFR-2\n(phosphorylated)\n[active]" fillcolor="#A04000" fontcolor="white"]
        NRP1 [label="Neuropilin-1\nco-receptor" fillcolor="#FAD7A0"]

        PI3K [label="PI3K\nactivation" fillcolor="#F0B27A"]
        AKT [label="Akt\n(pAkt)" fillcolor="#F0B27A"]
        mTOR [label="mTOR\npathway" fillcolor="#F0B27A"]
        ERK [label="ERK1/2\nMAPK" fillcolor="#F0B27A"]
        PLC_gamma [label="PLCγ / PKC\npathway" fillcolor="#F0B27A"]

        EC_prolif [label="Endothelial Cell\nProliferation" fillcolor="#E59866"]
        EC_migr [label="Endothelial Cell\nMigration" fillcolor="#E59866"]
        EC_survival [label="EC Survival\nAnti-apoptosis" fillcolor="#E59866"]
        VasoPerm [label="Vascular\nPermeability↑\n(fluid leakage)" fillcolor="#CA6F1E" fontcolor="white"]

        VEGF_RNB [label="VEGF:Ranibizumab\nComplex\n(inactive)" fillcolor="#D5DBDB" style="dashed,filled"]
        VEGF_AFL [label="VEGF:Aflibercept\nComplex\n(inactive)" fillcolor="#D5DBDB" style="dashed,filled"]
        VEGF_BEV [label="VEGF:Bevacizumab\nComplex\n(inactive)" fillcolor="#D5DBDB" style="dashed,filled"]
        VEGF_FAR [label="VEGF:Faricimab\nComplex\n(VEGF arm)" fillcolor="#D5DBDB" style="dashed,filled"]
        VEGF_BRO [label="VEGF:Brolucizumab\nComplex\n(inactive)" fillcolor="#D5DBDB" style="dashed,filled"]

        HIF1a -> VEGF_mRNA [label="transcription"]
        HIF2a -> VEGF_mRNA [label="transcription"]
        VEGF_mRNA -> VEGFA165 [label="translation/secretion"]
        VEGF_mRNA -> VEGFA121
        VEGFA165 -> VEGFR2 [label="binding\nKd~0.1nM"]
        VEGFA165 -> VEGFR1 [label="binding\nKd~10pM"]
        VEGFA165 -> NRP1 [label="co-binding"]
        PlGF -> VEGFR1
        VEGFB -> VEGFR1
        VEGFC -> VEGFR2 [style=dashed]

        VEGFR2 -> VEGFR2_act [label="dimerization\nphosphorylation"]
        VEGFR2_act -> PI3K
        VEGFR2_act -> ERK
        VEGFR2_act -> PLC_gamma
        PI3K -> AKT
        AKT -> mTOR
        AKT -> EC_survival
        ERK -> EC_prolif
        ERK -> EC_migr
        PLC_gamma -> VasoPerm
        mTOR -> EC_prolif

        RNB_ret -> VEGF_RNB [label="binding\nKd~0.04nM" color="#2E86C1"]
        AFL_ret -> VEGF_AFL [label="binding\nKd~0.5pM" color="#2E86C1"]
        BEV_ret -> VEGF_BEV [label="binding\nKd~0.2nM" color="#2E86C1"]
        FAR_ret -> VEGF_FAR [label="VEGF arm\nKd~0.3pM" color="#2E86C1"]
        BRO_ret -> VEGF_BRO [label="binding\nKd~0.06nM" color="#2E86C1"]

        VEGF_RNB -> VEGFR2 [label="blocked" style=dashed color=red arrowhead=tee]
        VEGF_AFL -> VEGFR2 [label="blocked" style=dashed color=red arrowhead=tee]
        VEGF_BEV -> VEGFR2 [label="blocked" style=dashed color=red arrowhead=tee]
        VEGF_FAR -> VEGFR2 [label="blocked" style=dashed color=red arrowhead=tee]
        VEGF_BRO -> VEGFR2 [label="blocked" style=dashed color=red arrowhead=tee]
    }

    /* ============================================================
       CLUSTER 3: ANG-2 / TIE2 PATHWAY (FARICIMAB TARGET)
       ============================================================ */
    subgraph cluster_ang2_tie2 {
        label="Ang-2 / Tie2 Pathway (Faricimab second target)" style="filled,rounded"
        bgcolor="#E8DAEF" color="#8E44AD" penwidth=2 fontsize=14 fontcolor="#4A235A"

        ANG1 [label="Angiopoietin-1\n(stabilizing)" fillcolor="#D2B4DE"]
        ANG2 [label="Angiopoietin-2\n(destabilizing)\n[upregulated in AMD]" fillcolor="#A569BD" fontcolor="white"]
        TIE2_rec [label="Tie2 Receptor\n(endothelial)" fillcolor="#D2B4DE"]
        TIE2_act [label="pTie2\n(phosphorylated)" fillcolor="#A569BD"]
        TIE2_inhib [label="Tie2 Inhibition\n(by Ang-2)" fillcolor="#C39BD3"]

        FOXO1 [label="FOXO1\ntranscription\nfactor" fillcolor="#D2B4DE"]
        Vessel_stab [label="Vessel\nStabilization" fillcolor="#A569BD" fontcolor="white"]
        Vessel_destab [label="Vessel\nDestabilization\nLeakage" fillcolor="#7D3C98" fontcolor="white"]

        ANG2_FAR [label="Ang-2:Faricimab\nComplex\n(Ang-2 arm)" fillcolor="#D5DBDB" style="dashed,filled"]

        ANG1 -> TIE2_rec [label="activating\nbinding"]
        ANG2 -> TIE2_rec [label="competitive\ninhibition" color=red]
        TIE2_rec -> TIE2_act [label="ANG1-mediated"]
        TIE2_act -> Vessel_stab [label="PI3K/Akt"]
        TIE2_rec -> TIE2_inhib [label="ANG2-mediated"]
        TIE2_inhib -> FOXO1 [label="activation"]
        FOXO1 -> ANG2 [label="↑expression" style=dashed]
        TIE2_inhib -> Vessel_destab
        Vessel_destab -> VasoPerm [lhead=cluster_vegf]

        FAR_ret -> ANG2_FAR [label="Ang-2 arm\nKd~0.9pM" color="#7D3C98"]
        ANG2_FAR -> TIE2_rec [label="blocked" style=dashed color=red arrowhead=tee]
    }

    /* ============================================================
       CLUSTER 4: COMPLEMENT PATHWAY
       ============================================================ */
    subgraph cluster_complement {
        label="Complement System" style="filled,rounded"
        bgcolor="#D5F5E3" color="#27AE60" penwidth=2 fontsize=14 fontcolor="#145A32"

        C1q [label="C1q\n(classical pathway)" fillcolor="#A9DFBF"]
        C3 [label="C3\n(central hub)" fillcolor="#52BE80" fontcolor="white"]
        C3a [label="C3a\n(anaphylatoxin)" fillcolor="#27AE60" fontcolor="white"]
        C3b [label="C3b\n(opsonin)" fillcolor="#27AE60" fontcolor="white"]
        C5 [label="C5" fillcolor="#A9DFBF"]
        C5a [label="C5a\n(anaphylatoxin)" fillcolor="#52BE80" fontcolor="white"]
        C5b [label="C5b" fillcolor="#A9DFBF"]
        MAC [label="MAC\n(C5b-9)\nMembrane Attack\nComplex" fillcolor="#1E8449" fontcolor="white" shape=hexagon]

        CFH [label="CFH\n(Complement\nFactor H)\n[key AMD gene]" fillcolor="#ABEBC6"]
        CFB [label="CFB\n(Factor B)" fillcolor="#A9DFBF"]
        CFD [label="CFD\n(Factor D)" fillcolor="#A9DFBF"]
        CFI [label="CFI\n(Factor I)" fillcolor="#ABEBC6"]
        C3_conv_alt [label="C3 Convertase\n(Alternative)" fillcolor="#52BE80" fontcolor="white"]
        C5_conv [label="C5 Convertase" fillcolor="#52BE80" fontcolor="white"]
        properdin [label="Properdin\n(Factor P)\n[stabilizer]" fillcolor="#A9DFBF"]

        C3aR [label="C3aR\n(C3a Receptor)\nMicroglia/RPE" fillcolor="#A9DFBF"]
        C5aR1 [label="C5aR1\nMicroglia/RPE" fillcolor="#A9DFBF"]

        Drusen_comp [label="Drusen Complement\nDeposition\n(iC3b, C3d, CFH)" fillcolor="#82E0AA"]
        RPE_stress_c [label="RPE Oxidative\nStress via\nComplement" fillcolor="#27AE60" fontcolor="white"]

        pegcetacoplan [label="Pegcetacoplan\n(C3 inhibitor)" fillcolor="#FDFEFE" style="filled,rounded,dashed" shape=diamond]
        avacoplantx [label="Avacopan\n(C5aR1 inhib)" fillcolor="#FDFEFE" style="filled,rounded,dashed" shape=diamond]

        C3 -> C3a [label="cleavage\nby C3conv"]
        C3 -> C3b [label="cleavage"]
        C3b -> C3_conv_alt [label="+CFB\n+CFD"]
        CFB -> C3_conv_alt
        CFD -> C3_conv_alt
        properdin -> C3_conv_alt [label="stabilizes"]
        C3_conv_alt -> C5 [label="cleaves"]
        C5 -> C5a
        C5 -> C5b
        C5b -> MAC [label="C6,C7,C8\nC9 polymerization"]
        C5_conv -> C5
        C3a -> C3aR [label="binding"]
        C5a -> C5aR1 [label="binding"]
        C3aR -> RPE_stress_c [label="activation"]
        C5aR1 -> RPE_stress_c [label="activation"]
        C3b -> Drusen_comp
        CFH -> C3b [label="cleavage\n(inactivation)" style=dashed color=green]
        CFI -> C3b [label="degrades" color=green]

        pegcetacoplan -> C3 [label="inhibits" color=red arrowhead=tee]
        avacoplantx -> C5aR1 [label="blocks" color=red arrowhead=tee]

        C1q -> C3 [label="classical\npathway"]
    }

    /* ============================================================
       CLUSTER 5: RPE / BRUCH'S MEMBRANE BIOLOGY
       ============================================================ */
    subgraph cluster_rpe {
        label="RPE / Bruch's Membrane / Photoreceptor" style="filled,rounded"
        bgcolor="#FEF9E7" color="#F39C12" penwidth=2 fontsize=14 fontcolor="#784212"

        RPE_normal [label="RPE Cells\n(Normal)\nPhagocytosis\nVEGF secretion" fillcolor="#FAD7A0"]
        RPE_dysfx [label="RPE Dysfunction\nOxidative damage\nLipofuscin accum." fillcolor="#F0B27A"]
        RPE_death [label="RPE Cell\nDeath\n(Geographic\nAtrophy)" fillcolor="#CA6F1E" fontcolor="white"]

        Lipofuscin [label="Lipofuscin\nA2E accumulation\n(phototoxic)" fillcolor="#FDEBD0"]
        BM_normal [label="Bruch's Membrane\n(Normal)" fillcolor="#FAD7A0"]
        BM_thick [label="Bruch's Membrane\nThickening &\nCalcification" fillcolor="#F0B27A"]
        Drusen_soft [label="Soft Drusen\n(>63μm)\n[AMD hallmark]" fillcolor="#E59866"]
        Drusen_hard [label="Hard Drusen\n(<63μm)" fillcolor="#FAD7A0"]
        Drusen_large [label="Large Drusen\n(>125μm)\nHigh-risk" fillcolor="#CA6F1E" fontcolor="white"]

        OS_outer [label="Outer\nPhotoreceptors\n(OS rods/cones)" fillcolor="#FAD7A0"]
        IS_inner [label="Inner\nPhotoreceptors\nIS / cell body" fillcolor="#FAD7A0"]
        PR_loss [label="Photoreceptor\nLoss\n(Secondary)" fillcolor="#CA6F1E" fontcolor="white"]

        mtDNA_damage [label="mtDNA Damage\nOxidative Stress\nROS accumulation" fillcolor="#F0B27A"]
        NLRP3 [label="NLRP3\nInflammasome\nactivation" fillcolor="#E59866"]
        IL1b_rpe [label="IL-1β secretion\n(RPE)" fillcolor="#F0B27A"]
        Autophagy [label="Autophagy\ndysfunction" fillcolor="#F0B27A"]

        RPE_normal -> Lipofuscin [label="failed\nphagocytosis\naccumulation"]
        Lipofuscin -> RPE_dysfx [label="phototoxicity"]
        RPE_dysfx -> mtDNA_damage
        mtDNA_damage -> NLRP3
        NLRP3 -> IL1b_rpe
        RPE_dysfx -> Autophagy [label="impairs"]
        RPE_dysfx -> RPE_death [label="apoptosis\nnecroptosis"]
        RPE_normal -> BM_normal
        BM_normal -> BM_thick [label="lipid\ndeposition\naging"]
        BM_thick -> Drusen_hard
        Drusen_hard -> Drusen_soft [label="confluence"]
        Drusen_soft -> Drusen_large [label="growth"]
        Drusen_large -> RPE_dysfx [label="RPE stress"]
        RPE_death -> PR_loss [label="secondary\ndegeneration"]
        OS_outer -> RPE_normal [label="daily shed OS\nphagocytosis"]
    }

    /* ============================================================
       CLUSTER 6: CHOROIDAL NEOVASCULARIZATION (CNV / wet AMD)
       ============================================================ */
    subgraph cluster_cnv {
        label="Choroidal Neovascularization (Wet AMD)" style="filled,rounded"
        bgcolor="#FDEDEC" color="#E74C3C" penwidth=2 fontsize=14 fontcolor="#78281F"

        Choroid [label="Choroidal\nCapillary\n(Choriocapillaris)" fillcolor="#FADBD8"]
        CNV_init [label="CNV Initiation\n(Membrane breach)" fillcolor="#F1948A"]
        CNV_type1 [label="Type 1 CNV\n(Sub-RPE)\n[occult]" fillcolor="#EC7063"]
        CNV_type2 [label="Type 2 CNV\n(Sub-retinal)\n[classic]" fillcolor="#E74C3C" fontcolor="white"]
        CNV_type3 [label="Type 3 CNV\n(RAP lesion)" fillcolor="#E74C3C" fontcolor="white"]
        CNV_area [label="CNV\nLesion Area\n(mm²)" fillcolor="#C0392B" fontcolor="white" shape=ellipse]

        Fluid_SRF [label="Subretinal\nFluid (SRF)\n(OCT-detectable)" fillcolor="#F1948A"]
        Fluid_IRF [label="Intraretinal\nFluid (IRF)\n(cystoid spaces)" fillcolor="#EC7063"]
        Fluid_PED [label="Pigment\nEpithelial\nDetachment (PED)" fillcolor="#F1948A"]
        CST [label="Central Subfield\nThickness (CST)\n[OCT, μm]" fillcolor="#E74C3C" fontcolor="white" shape=ellipse]

        Fibrin [label="Fibrin\nExudate" fillcolor="#FADBD8"]
        Fibrous_scar [label="Disciform\nFibrous Scar\n[end-stage]" fillcolor="#C0392B" fontcolor="white"]

        matrix_MMP [label="MMP-2, MMP-9\nMatrix degradation" fillcolor="#F1948A"]

        Choroid -> CNV_init [label="BM breach\n(Drusen,complement)"]
        CNV_init -> CNV_type1
        CNV_init -> CNV_type2
        CNV_init -> CNV_type3
        CNV_type1 -> CNV_area
        CNV_type2 -> CNV_area
        CNV_type3 -> CNV_area
        EC_prolif -> CNV_init [lhead=cluster_vegf style=dashed]
        EC_migr -> CNV_init [lhead=cluster_vegf style=dashed]
        VasoPerm -> Fluid_SRF [lhead=cluster_vegf]
        VasoPerm -> Fluid_IRF
        VasoPerm -> Fluid_PED
        Fluid_SRF -> CST
        Fluid_IRF -> CST
        Fluid_PED -> CST
        Fibrin -> Fibrous_scar [label="organization"]
        CNV_area -> Fibrous_scar [label="chronic\nuntreated"]
        matrix_MMP -> CNV_init [label="enables\ninvasion"]
    }

    /* ============================================================
       CLUSTER 7: NEURO-INFLAMMATION / IMMUNE CELLS
       ============================================================ */
    subgraph cluster_neuroinflamm {
        label="Neuroinflammation / Immune Response" style="filled,rounded"
        bgcolor="#EBF5FB" color="#2471A3" penwidth=2 fontsize=14 fontcolor="#1A5276"

        Microglia_rest [label="Resting\nMicroglia\n(homeostatic)" fillcolor="#AED6F1"]
        Microglia_act [label="Activated\nMicroglia\n(M1/M2)" fillcolor="#5DADE2"]
        Macrophage_inf [label="Infiltrating\nMacrophages\nChoroidal" fillcolor="#2E86C1" fontcolor="white"]
        NK_cells [label="NK Cells\nRetinal" fillcolor="#AED6F1"]
        Mast_cells [label="Mast Cells\nChoroidal" fillcolor="#AED6F1"]
        Neutrophils [label="Neutrophils\n(early response)" fillcolor="#AED6F1"]

        IL6 [label="IL-6\n[pleotropic]" fillcolor="#5DADE2"]
        TNFa [label="TNF-α" fillcolor="#5DADE2"]
        IL8 [label="IL-8\n[chemokine]" fillcolor="#5DADE2"]
        MCP1 [label="MCP-1/CCL2\n[monocyte\nrecruitment]" fillcolor="#5DADE2"]
        PEDF [label="PEDF\n(Pigment\nEpithelium-Derived\nFactor)\n[anti-angiogenic]" fillcolor="#AED6F1"]
        TGFb [label="TGF-β\n[fibrosis,\nimmunosuppress]" fillcolor="#85C1E9"]

        Oxidative_stress [label="Oxidative Stress\nROS (H₂O₂, •OH)\nCarbonyl stress" fillcolor="#5DADE2"]
        NRF2 [label="NRF2\nAntioxidant\nResponse" fillcolor="#AED6F1"]
        SOD [label="SOD / Catalase\nGPx (antioxidants)" fillcolor="#AED6F1"]

        C3aR -> Microglia_act [lhead=cluster_complement]
        C5aR1 -> Microglia_act [lhead=cluster_complement]
        IL1b_rpe -> Microglia_act [lhead=cluster_rpe]
        Microglia_rest -> Microglia_act [label="activation\nstimuli"]
        Microglia_act -> IL6
        Microglia_act -> TNFa
        Microglia_act -> IL8
        Macrophage_inf -> MCP1 [label="secretion"]
        MCP1 -> Macrophage_inf [label="recruitment"]
        IL6 -> VEGFA165 [lhead=cluster_vegf label="↑VEGF\n(IL-6→JAK/STAT)"]
        TNFa -> VEGFA165 [lhead=cluster_vegf label="↑VEGF" style=dashed]
        PEDF -> VEGFA165 [label="antagonizes\nangiogenesis" color=green arrowhead=tee]
        TGFb -> Fibrous_scar [lhead=cluster_cnv label="fibrosis"]
        Oxidative_stress -> mtDNA_damage [lhead=cluster_rpe]
        Oxidative_stress -> HIF1a [lhead=cluster_vegf label="activates"]
        NRF2 -> SOD [label="induces"]
        SOD -> Oxidative_stress [label="scavenges" color=green arrowhead=tee]
    }

    /* ============================================================
       CLUSTER 8: GENETIC / RISK FACTORS
       ============================================================ */
    subgraph cluster_genetics {
        label="Genetic & Environmental Risk Factors" style="filled,rounded"
        bgcolor="#F4F6F7" color="#717D7E" penwidth=2 fontsize=14 fontcolor="#2C3E50"

        CFH_Y402H [label="CFH Y402H\nvariant\n(rs1061170)\nHigh risk" fillcolor="#BFC9CA"]
        ARMS2_A69S [label="ARMS2 A69S\n(rs10490924)\nHigh risk" fillcolor="#BFC9CA"]
        CFB_R32Q [label="CFB R32Q\nProtective" fillcolor="#D5DBDB"]
        C3_R102G [label="C3 R102G\nRisk variant" fillcolor="#BFC9CA"]
        VEGF_poly [label="VEGF-A\npolymorphisms" fillcolor="#BFC9CA"]
        HTRA1 [label="HTRA1\nserine protease\ngene variant" fillcolor="#BFC9CA"]
        APOE [label="APOE\ngenotype\n(e4 protective?)" fillcolor="#D5DBDB"]

        Aging [label="Aging\n(>50yr, >65yr\nhighest risk)" fillcolor="#BFC9CA"]
        Smoking [label="Cigarette\nSmoke\n(RR~4x wet AMD)" fillcolor="#AEB6BF"]
        UV_light [label="UV/Blue Light\nExposure" fillcolor="#BFC9CA"]
        Diet_ox [label="Oxidant-rich\nDiet / Low\nAntioxidants" fillcolor="#D5DBDB"]
        Cardiovasc_RF [label="Cardiovascular\nRisk Factors\n(HTN, dyslipidemia)" fillcolor="#BFC9CA"]

        AREDS [label="AREDS\nSupplements\n(Vit C/E, Zn, β-Car\nor Lutein/Zea)" fillcolor="#FDFEFE" shape=diamond style="filled,rounded,dashed"]

        CFH_Y402H -> CFH [label="reduces\nfunction" color=red lhead=cluster_complement]
        ARMS2_A69S -> mtDNA_damage [label="mitochondrial\ndysfunction" lhead=cluster_rpe]
        C3_R102G -> C3 [label="altered\nactivity" lhead=cluster_complement]
        Smoking -> Oxidative_stress [lhead=cluster_neuroinflamm label="↑ROS"]
        UV_light -> Oxidative_stress [lhead=cluster_neuroinflamm]
        Aging -> RPE_dysfx [lhead=cluster_rpe label="↓lysosomal\nfunction"]
        Cardiovasc_RF -> BM_thick [lhead=cluster_rpe label="vascular\nchanges"]
        Diet_ox -> Oxidative_stress [lhead=cluster_neuroinflamm]
        AREDS -> Oxidative_stress [label="reduces\nROS" color=green arrowhead=tee]
    }

    /* ============================================================
       CLUSTER 9: VISUAL FUNCTION / CLINICAL ENDPOINTS
       ============================================================ */
    subgraph cluster_endpoints {
        label="Clinical Endpoints / Visual Function" style="filled,rounded"
        bgcolor="#F9EBEA" color="#C0392B" penwidth=2 fontsize=14 fontcolor="#78281F"

        BCVA [label="BCVA\n(Best-Corrected\nVisual Acuity)\nETDRS letters" fillcolor="#F1948A" shape=ellipse]
        VA_gain [label="VA Gain\n≥15 letters\n(responder)" fillcolor="#E74C3C" fontcolor="white" shape=ellipse]
        GA_area [label="Geographic\nAtrophy Area\n(mm², FAF)" fillcolor="#EC7063" shape=ellipse]
        LLVA [label="Low Luminance\nVisual Acuity\nLLVA deficit" fillcolor="#F1948A" shape=ellipse]
        Reading_speed [label="Reading Speed\n(words/min)" fillcolor="#F1948A" shape=ellipse]
        Contrast_sense [label="Contrast\nSensitivity" fillcolor="#F1948A" shape=ellipse]
        Microperimetry [label="Microperimetry\n(retinal sensitivity\ndB)" fillcolor="#F1948A" shape=ellipse]

        AMD_stage_early [label="Early AMD\nDrusen <125μm\nNo GA/CNV" fillcolor="#FAD7A0" shape=box]
        AMD_stage_inter [label="Intermediate AMD\nLarge drusen\nor pigment\nabnormality" fillcolor="#F0B27A" shape=box]
        AMD_stage_late [label="Late AMD\n(GA or\nwet AMD)" fillcolor="#E74C3C" fontcolor="white" shape=box]

        Inj_freq [label="Treatment Burden\nInjections/Year\n(PRN vs T&E)" fillcolor="#FADBD8" shape=ellipse]
        BCVA_stability [label="BCVA Stability\n(no loss\n≥15 letters)" fillcolor="#F1948A" shape=ellipse]

        CNV_area -> BCVA [lhead=cluster_cnv label="vision loss\n(R²~0.6)"]
        GA_area -> BCVA [label="vision loss\n(central GA)"]
        CST -> BCVA [lhead=cluster_cnv label="fluid → distortion"]
        PR_loss -> BCVA [lhead=cluster_rpe label="cell loss"]
        BCVA -> VA_gain [label="ΔfromBL >15"]
        BCVA -> BCVA_stability [label="change\nassessment"]
        AMD_stage_early -> AMD_stage_inter [label="progression\n~12%/yr"]
        AMD_stage_inter -> AMD_stage_late [label="progression\n~18%/yr"]
        Drusen_large -> AMD_stage_inter [lhead=cluster_rpe]
        RPE_death -> GA_area [lhead=cluster_rpe]
        GA_area -> AMD_stage_late
        CNV_area -> AMD_stage_late [lhead=cluster_cnv]
        BCVA -> Reading_speed [label="correlates"]
        BCVA -> Contrast_sense [label="correlates"]
        GA_area -> Microperimetry [label="reduced\nsensitivity\nat GA boundary"]
    }

    /* ============================================================
       CLUSTER 10: PHARMACOLOGICAL INTERVENTIONS
       ============================================================ */
    subgraph cluster_pharma {
        label="Pharmacological Interventions & Dosing" style="filled,rounded"
        bgcolor="#E8F8F5" color="#1ABC9C" penwidth=2 fontsize=14 fontcolor="#0E6655"

        dosing_q4w [label="Monthly (q4w)\nLoading Phase\n×3 injections" fillcolor="#A2D9CE"]
        dosing_q8w [label="Every 8 Weeks\n(q8w)\nMaintenance" fillcolor="#A2D9CE"]
        dosing_q12w [label="Every 12 Weeks\n(q12w)\nAfter stability" fillcolor="#A2D9CE"]
        dosing_PRN [label="PRN (as-needed)\ndosing" fillcolor="#76D7C4"]
        dosing_TE [label="Treat & Extend\n(T&E)\ndosing protocol" fillcolor="#76D7C4"]

        PORT_delivery [label="Port Delivery\nSystem (PDS)\nSustained release" fillcolor="#45B39D" fontcolor="white"]
        gene_therapy [label="Gene Therapy\n(AAV.sFlt-1\nAAV2-VEGF-trap)" fillcolor="#A2D9CE"]
        photodyn [label="Photodynamic\nTherapy (PDT)\n(verteporfin)" fillcolor="#A2D9CE"]
        laser_tx [label="Laser\nPhotocoagulation\n(thermal)" fillcolor="#A2D9CE"]

        CATT [label="CATT Trial\nBEV vs RNB\n(2011)" fillcolor="#D1F2EB"]
        VIEW12 [label="VIEW 1&2 Trials\nAFL vs RNB\n(2012)" fillcolor="#D1F2EB"]
        TENAYA [label="TENAYA/LUCERNE\nFAR vs AFL\n(2022)" fillcolor="#D1F2EB"]
        HAWK [label="HAWK/HARRIER\nBRO vs AFL\n(2018)" fillcolor="#D1F2EB"]

        dosing_q4w -> dosing_q8w [label="→ after loading"]
        dosing_q8w -> dosing_q12w [label="→ if stable"]
        dosing_q4w -> dosing_PRN [label="alternative"]
        dosing_q4w -> dosing_TE [label="alternative"]
    }

    /* ============================================================
       CROSS-CLUSTER CONNECTIONS
       ============================================================ */
    VEGFA165 -> HIF1a [label="autocrine\nloop" style=dashed color=gray]
    MAC -> RPE_dysfx [label="sublytic MAC\nRPE stress" lhead=cluster_rpe]
    Drusen_comp -> C3_conv_alt [label="local complement\nactivation" lhead=cluster_complement]
    RPE_dysfx -> VEGFA165 [label="↑secretion\nbasolateral" lhead=cluster_vegf]
    RPE_death -> VEGFA165 [label="↑VEGF\nwound signal" lhead=cluster_vegf style=dashed]
    IL1b_rpe -> C3 [label="↑C3 expression" lhead=cluster_complement style=dashed]
    BM_thick -> CNV_init [label="barrier\nbreakdown" lhead=cluster_cnv]
    Drusen_soft -> CNV_init [label="subretinal\nmilieu" lhead=cluster_cnv]
    CFH_Y402H -> Drusen_comp [label="↑drusen\ncomplement" lhead=cluster_rpe style=dashed]
    ARMS2_A69S -> RPE_dysfx [label="mitochondrial\nimpairment" lhead=cluster_rpe]

    /* ============================================================
       LEGEND
       ============================================================ */
    subgraph cluster_legend {
        label="Legend" style=rounded bgcolor="#FDFEFE" color="#AAB7B8" fontsize=12

        L1 [label="Disease\nMechanism" fillcolor="#F1948A" shape=box]
        L2 [label="Drug/Intervention" fillcolor="#FDFEFE" style="filled,dashed,rounded" shape=diamond]
        L3 [label="Drug-Target\nComplex (inactive)" fillcolor="#D5DBDB" style="dashed,filled"]
        L4 [label="Clinical\nEndpoint" fillcolor="#F1948A" shape=ellipse]
        L5 [label="Inhibitory\nedge" fillcolor="white" shape=plaintext]

        L1 -> L2 [style=invis]
        L2 -> L3 [style=invis]
        L3 -> L4 [style=invis]
    }
}
