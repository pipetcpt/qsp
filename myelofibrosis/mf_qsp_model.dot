digraph myelofibrosis_qsp {

    graph [
        label="Myelofibrosis (MF) Quantitative Systems Pharmacology Model\nMechanistic Map: Genetic Drivers → JAK/STAT Signaling → BM Microenvironment → Clinical Endpoints",
        labelloc=t,
        fontname="Helvetica",
        fontsize=22,
        fontcolor="#1a1a2e",
        rankdir=LR,
        splines=ortho,
        nodesep=0.45,
        ranksep=0.85,
        bgcolor="#f8f9fa",
        pad=0.6,
        compound=true
    ]

    node [
        fontname="Helvetica",
        fontsize=10,
        style="filled,rounded",
        penwidth=1.5
    ]

    edge [
        fontname="Helvetica",
        fontsize=8,
        penwidth=1.2,
        arrowsize=0.8
    ]

    // =========================================================
    // CLUSTER 1: Genetic / Mutational Drivers
    // =========================================================
    subgraph cluster_genetics {
        label="① Genetic & Mutational Drivers"
        labeljust=l
        fontname="Helvetica Bold"
        fontsize=13
        fontcolor="#1b1464"
        style="filled,rounded"
        fillcolor="#e8eaf6"
        color="#3949ab"
        penwidth=2.0

        // Driver mutations — ellipse
        node [shape=ellipse, fillcolor="#7986cb", fontcolor="white"]
        JAK2V617F   [label="JAK2 V617F\n(somatic mutation)"]
        CALR_T1     [label="CALR Type 1\n(del 52bp)"]
        CALR_T2     [label="CALR Type 2\n(ins 5bp)"]
        MPL_W515L   [label="MPL W515L"]
        MPL_W515K   [label="MPL W515K"]

        // Epigenetic / splicing mutations
        node [shape=ellipse, fillcolor="#9fa8da", fontcolor="#1a1a2e"]
        ASXL1_mut   [label="ASXL1\nmutation"]
        EZH2_mut    [label="EZH2\nmutation"]
        SRSF2_mut   [label="SRSF2\nmutation"]
        IDH1_mut    [label="IDH1/2\nmutation"]
        TP53_mut    [label="TP53\nmutation"]
        TET2_mut    [label="TET2\nmutation"]
        DNMT3A_mut  [label="DNMT3A\nmutation"]
        CBL_mut     [label="CBL\nmutation"]
        SF3B1_mut   [label="SF3B1\nmutation"]
        U2AF1_mut   [label="U2AF1\nmutation"]

        // Allele burden
        node [shape=diamond, fillcolor="#5c6bc0", fontcolor="white"]
        JAK2_allele_burden [label="JAK2V617F\nAllele Burden (%)"]
        mutational_complexity [label="Mutational\nComplexity Score"]

        // DIPSS
        node [shape=box, fillcolor="#3949ab", fontcolor="white"]
        DIPSS_score [label="DIPSS / DIPSS+\nRisk Score"]
        MIPSS70     [label="MIPSS70+v2.0\nMolecular Score"]
    }

    // =========================================================
    // CLUSTER 2: JAK/STAT Signaling Pathway
    // =========================================================
    subgraph cluster_jak_stat {
        label="② JAK/STAT Signaling Pathway"
        labeljust=l
        fontname="Helvetica Bold"
        fontsize=13
        fontcolor="#1b3a1b"
        style="filled,rounded"
        fillcolor="#e8f5e9"
        color="#388e3c"
        penwidth=2.0

        // Receptors
        node [shape=box, fillcolor="#66bb6a", fontcolor="white"]
        EPOR    [label="EPOR\n(Erythropoietin R)"]
        TPOR    [label="TPOR / MPL\n(Thrombopoietin R)"]
        GCSFR   [label="G-CSFR\n(IL-3Rβ)"]
        GP130   [label="gp130\n(IL-6 co-R)"]

        // JAK kinases
        node [shape=box, fillcolor="#43a047", fontcolor="white"]
        JAK1    [label="JAK1"]
        JAK2    [label="JAK2\n(constitutively active)"]
        JAK2_p  [label="JAK2-pY1007\n(phospho-active)"]
        TYK2    [label="TYK2"]

        // STAT transcription factors
        node [shape=box, fillcolor="#2e7d32", fontcolor="white"]
        STAT1   [label="STAT1"]
        STAT3   [label="STAT3"]
        STAT5a  [label="STAT5a"]
        STAT5b  [label="STAT5b"]
        pSTAT3  [label="pSTAT3\n(activated)"]
        pSTAT5  [label="pSTAT5\n(activated)"]

        // Negative regulators
        node [shape=box, fillcolor="#a5d6a7", fontcolor="#1a1a2e"]
        SOCS1   [label="SOCS1\n(neg. feedback)"]
        SOCS3   [label="SOCS3\n(neg. feedback)"]
        PIAS1   [label="PIAS1\n(STAT inhibitor)"]
        SHP2    [label="SHP2\n(phosphatase)"]

        // Downstream targets
        node [shape=box, fillcolor="#1b5e20", fontcolor="white"]
        BCL2_jak [label="BCL-2/BCL-xL\n(anti-apoptosis)"]
        MCL1     [label="MCL-1\n(survival)"]
        CCND1    [label="Cyclin D1\n(proliferation)"]
        MYC_jak  [label="c-MYC\n(oncogene)"]
        PIM1     [label="PIM1/2\nkinase"]
    }

    // =========================================================
    // CLUSTER 3: HSC Niche
    // =========================================================
    subgraph cluster_hsc_niche {
        label="③ Hematopoietic Stem Cell (HSC) Niche"
        labeljust=l
        fontname="Helvetica Bold"
        fontsize=13
        fontcolor="#4a1a00"
        style="filled,rounded"
        fillcolor="#fff3e0"
        color="#e65100"
        penwidth=2.0

        // HSC hierarchy
        node [shape=ellipse, fillcolor="#ff8f00", fontcolor="white"]
        LT_HSC   [label="LT-HSC\n(Long-term)"]
        ST_HSC   [label="ST-HSC\n(Short-term)"]
        MPP      [label="MPP\n(Multipotent\nProgenitor)"]

        node [shape=ellipse, fillcolor="#ffa726", fontcolor="white"]
        CMP      [label="CMP\n(Common Myeloid\nProgenitor)"]
        GMP      [label="GMP\n(Granulocyte-\nMacrophage P)"]
        MEP      [label="MEP\n(Megakaryocyte-\nErythroid P)"]
        MkP      [label="MkP\n(Megakaryocyte\nProgenitor)"]
        BFU_E    [label="BFU-E\n(Erythroid P)"]

        // Niche signals
        node [shape=box, fillcolor="#ffcc02", fontcolor="#1a1a2e"]
        CXCL12   [label="CXCL12\n(SDF-1)"]
        CXCR4    [label="CXCR4\n(receptor)"]
        SCF      [label="SCF\n(c-KIT ligand)"]
        cKIT     [label="c-KIT\n(CD117)"]
        TPO      [label="TPO\n(Thrombopoietin)"]
        EPO_sig  [label="EPO\n(Erythropoietin)"]
        ANGPT1   [label="ANGPT1\n(Angiopoietin-1)"]

        // HSC pool dynamics
        node [shape=diamond, fillcolor="#e65100", fontcolor="white"]
        HSC_pool      [label="HSC Pool\n(bone marrow)"]
        clone_fraction [label="MF Clone\nFraction (%)"]
        CD34_BM       [label="CD34+ cells\n(BM resident)"]
        HSC_selfrenewal [label="HSC\nSelf-renewal rate"]
        HSC_apoptosis  [label="HSC\nApoptosis rate"]
    }

    // =========================================================
    // CLUSTER 4: BM Microenvironment & Fibrosis
    // =========================================================
    subgraph cluster_fibrosis {
        label="④ Bone Marrow Microenvironment & Fibrosis"
        labeljust=l
        fontname="Helvetica Bold"
        fontsize=13
        fontcolor="#3e0000"
        style="filled,rounded"
        fillcolor="#fce4ec"
        color="#c62828"
        penwidth=2.0

        // Stromal / cellular components
        node [shape=box, fillcolor="#ef9a9a", fontcolor="#1a1a2e"]
        MSC      [label="Mesenchymal\nStromal Cell (MSC)"]
        OB       [label="Osteoblast"]
        OC       [label="Osteoclast"]
        CAF      [label="Cancer-Associated\nFibroblast (CAF)"]
        MF_MK    [label="Abnormal\nMegakaryocyte"]

        // Fibrogenic mediators
        node [shape=box, fillcolor="#e57373", fontcolor="white"]
        TGFb1    [label="TGF-β1\n(fibrogenic)"]
        PDGF_AB  [label="PDGF-AB/BB\n(mitogen)"]
        bFGF     [label="bFGF / FGF2\n(angiogenic)"]
        VEGF_f   [label="VEGF\n(angiogenesis)"]
        CTGF     [label="CTGF/CCN2\n(fibrosis)"]
        OPN      [label="OPN\n(Osteopontin)"]
        CXCL4    [label="CXCL4 / PF4\n(fibrosis)"]

        // ECM components
        node [shape=box, fillcolor="#c62828", fontcolor="white"]
        collagen_I  [label="Collagen I/III\ndeposition"]
        reticulin   [label="Reticulin Fiber\n(MF grade 0-3)"]
        fibronectin [label="Fibronectin"]
        MMP9        [label="MMP-9\n(matrix remodel)"]
        TIMP1       [label="TIMP-1\n(MMP inhibitor)"]

        // Fibrosis grading
        node [shape=diamond, fillcolor="#8d1f1f", fontcolor="white"]
        MF_grade    [label="Fibrosis Grade\n(MF-0 → MF-3)"]
        osteosclerosis [label="Osteosclerosis\nscore"]
        BM_cellularity [label="BM Cellularity\n(%)"]
    }

    // =========================================================
    // CLUSTER 5: Cytokine Storm & Inflammation
    // =========================================================
    subgraph cluster_cytokines {
        label="⑤ Cytokine Storm & Systemic Inflammation"
        labeljust=l
        fontname="Helvetica Bold"
        fontsize=13
        fontcolor="#1a237e"
        style="filled,rounded"
        fillcolor="#e8eaf6"
        color="#283593"
        penwidth=2.0

        // Pro-inflammatory cytokines
        node [shape=box, fillcolor="#7986cb", fontcolor="white"]
        IL1b    [label="IL-1β\n(inflammasome)"]
        IL6     [label="IL-6\n(systemic inflam.)"]
        IL8     [label="IL-8 / CXCL8\n(neutrophil chemo.)"]
        IL13    [label="IL-13\n(fibrosis driver)"]
        TNFa    [label="TNF-α\n(pro-inflammatory)"]
        IFNg    [label="IFN-γ\n(immune activat.)"]
        CXCL10  [label="CXCL10 / IP-10"]
        CCL2    [label="CCL2 / MCP-1\n(monocyte recrui.)"]
        IL10    [label="IL-10\n(anti-inflam.)"]
        IL12    [label="IL-12\n(Th1 polariz.)"]

        // Signaling hubs
        node [shape=diamond, fillcolor="#3949ab", fontcolor="white"]
        NFkB    [label="NF-κB\n(transcription)"]
        mTOR    [label="mTOR\nComplex 1/2"]
        PI3K    [label="PI3K/AKT\npathway"]
        RAS_ERK [label="RAS/ERK/MAPK\npathway"]
        NLRP3   [label="NLRP3\nInflammasome"]

        // Constitutional symptoms
        node [shape=box, fillcolor="#1a237e", fontcolor="white"]
        fever      [label="Constitutional\nFever"]
        night_sweat [label="Night Sweats"]
        weight_loss [label="Weight Loss\n(cachexia)"]
        fatigue_cyt [label="Fatigue\n(cytokine-driven)"]
    }

    // =========================================================
    // CLUSTER 6: Extramedullary Hematopoiesis
    // =========================================================
    subgraph cluster_emh {
        label="⑥ Extramedullary Hematopoiesis (EMH)"
        labeljust=l
        fontname="Helvetica Bold"
        fontsize=13
        fontcolor="#1a3040"
        style="filled,rounded"
        fillcolor="#e0f2f1"
        color="#00695c"
        penwidth=2.0

        // Circulating progenitors
        node [shape=ellipse, fillcolor="#4db6ac", fontcolor="white"]
        CD34_circ    [label="Circulating CD34+\nProgenitors"]
        circ_MK      [label="Circulating\nMegakaryocytes"]
        immature_gran [label="Immature\nGranulocytes"]
        NRBCs        [label="NRBCs\n(leukoerythroblastosis)"]

        // Spleen
        node [shape=box, fillcolor="#00897b", fontcolor="white"]
        spleen_HSC   [label="Splenic HSC\nEngraftment"]
        spleen_myeloid [label="Splenic Myeloid\nExpansion"]
        spleen_MK    [label="Splenic\nMegakaryopoiesis"]
        spleen_volume [label="Spleen Volume\n(mL)"]
        splenomegaly [label="Splenomegaly\n(grade)"]

        // Liver
        node [shape=box, fillcolor="#00695c", fontcolor="white"]
        liver_HSC    [label="Hepatic HSC\nEngraftment"]
        liver_volume [label="Liver Volume\n(mL)"]
        hepatomegaly [label="Hepatomegaly"]

        // Mechanisms of mobilization
        node [shape=diamond, fillcolor="#004d40", fontcolor="white"]
        BM_failure   [label="BM Failure\n(niche disruption)"]
        CXCR4_down   [label="CXCR4\nDownregulation"]
        MMP_increase [label="MMP-9 / MMP-2\nIncrease"]
    }

    // =========================================================
    // CLUSTER 7: Hematological Consequences
    // =========================================================
    subgraph cluster_heme {
        label="⑦ Hematological Consequences"
        labeljust=l
        fontname="Helvetica Bold"
        fontsize=13
        fontcolor="#1a0030"
        style="filled,rounded"
        fillcolor="#f3e5f5"
        color="#6a1b9a"
        penwidth=2.0

        // RBC / Anemia
        node [shape=box, fillcolor="#ba68c8", fontcolor="white"]
        RBC_prod    [label="RBC Production\nrate"]
        RBC_destroy [label="RBC Destruction\n(hemolysis / splenic)"]
        Hgb         [label="Hemoglobin\n(g/dL)"]
        MCV         [label="MCV / Teardrop\ncells"]
        retic_count [label="Reticulocyte\nCount"]
        EPO_level   [label="Serum EPO\n(endogenous)"]

        // Platelet
        node [shape=box, fillcolor="#9c27b0", fontcolor="white"]
        PLT_prod    [label="Platelet Production\n(thrombopoiesis)"]
        PLT_destroy [label="Platelet\nDestruction"]
        PLT_count   [label="Platelet Count\n(×10⁹/L)"]
        thrombo_risk [label="Thrombocytopenia\nRisk"]

        // WBC
        node [shape=box, fillcolor="#7b1fa2", fontcolor="white"]
        WBC_count   [label="WBC Count\n(×10⁹/L)"]
        neutrophil  [label="Neutrophil\nCount"]
        blast_pct   [label="Circulating\nBlasts (%)"]
        leuko_state [label="Leukocytosis\nor Leukopenia"]

        // Transfusion
        node [shape=diamond, fillcolor="#4a148c", fontcolor="white"]
        transfusion_dep [label="Transfusion\nDependence"]
        anemia_severity [label="Anemia Severity\n(grade)"]
        allele_dyn      [label="JAK2V617F\nAllele Dynamics"]
    }

    // =========================================================
    // CLUSTER 8: Thrombosis & Vascular Complications
    // =========================================================
    subgraph cluster_thrombosis {
        label="⑧ Thrombosis & Vascular Complications"
        labeljust=l
        fontname="Helvetica Bold"
        fontsize=13
        fontcolor="#1a0000"
        style="filled,rounded"
        fillcolor="#fff8e1"
        color="#f57f17"
        penwidth=2.0

        node [shape=box, fillcolor="#ffca28", fontcolor="#1a1a2e"]
        PLT_activation [label="Platelet\nActivation"]
        TXA2           [label="TXA2\n(thromboxane)"]
        vWF_ultra      [label="Ultra-large vWF\nmultimers"]
        fibrin_clot    [label="Fibrin Clot\nFormation"]

        node [shape=box, fillcolor="#ffb300", fontcolor="#1a1a2e"]
        thrombin_gen   [label="Thrombin\nGeneration"]
        FXa_activ      [label="Factor Xa\nActivation"]
        TF_expr        [label="Tissue Factor\nExpression"]
        PAI1           [label="PAI-1\n(fibrinolysis inhib.)"]

        node [shape=box, fillcolor="#ff8f00", fontcolor="white"]
        endothel_dysfunc [label="Endothelial\nDysfunction"]
        VCAM1            [label="VCAM-1\nadhesion"]
        eNOS_reduc       [label="eNOS\nReduction"]

        node [shape=diamond, fillcolor="#e65100", fontcolor="white"]
        thrombotic_event [label="Thrombotic Event\n(DVT/PE/stroke)"]
        bleeding_risk    [label="Bleeding Risk\n(GI/CNS)"]
        portal_HTN       [label="Portal Hypertension\n(BCS/PVT)"]
    }

    // =========================================================
    // CLUSTER 9: Drug PK — JAK Inhibitors
    // =========================================================
    subgraph cluster_pk {
        label="⑨ Drug PK — JAK Inhibitors (2-Compartment Model)"
        labeljust=l
        fontname="Helvetica Bold"
        fontsize=13
        fontcolor="#002060"
        style="filled,rounded"
        fillcolor="#e3f2fd"
        color="#1565c0"
        penwidth=2.0

        // Ruxolitinib PK
        node [shape=hexagon, fillcolor="#1e88e5", fontcolor="white"]
        ruxo_dose  [label="Ruxolitinib\nDose (mg BID)"]
        ruxo_gut   [label="Ruxo Gut\nAbsorption (A_gut)"]
        ruxo_C1    [label="Ruxo Central\nCompartment (C1)"]
        ruxo_C2    [label="Ruxo Peripheral\nCompartment (C2)"]

        node [shape=box, fillcolor="#90caf9", fontcolor="#1a1a2e"]
        ruxo_ka    [label="ka_ruxo\n(absorption rate)"]
        ruxo_CL    [label="CL_ruxo\n(clearance)"]
        ruxo_V1    [label="V1_ruxo\n(central vol.)"]
        ruxo_V2    [label="V2_ruxo\n(periph. vol.)"]
        ruxo_Q     [label="Q_ruxo\n(intercomp. CL)"]
        ruxo_F1    [label="F1_ruxo\n(bioavailability)"]

        // Fedratinib PK
        node [shape=hexagon, fillcolor="#42a5f5", fontcolor="white"]
        fedr_dose  [label="Fedratinib\nDose (mg QD)"]
        fedr_C1    [label="Fedr Central\nCompartment"]

        node [shape=box, fillcolor="#bbdefb", fontcolor="#1a1a2e"]
        fedr_ka    [label="ka_fedr"]
        fedr_CL    [label="CL_fedr"]
        fedr_F1    [label="F1_fedr\n(food effect ↑)"]

        // Pacritinib PK
        node [shape=hexagon, fillcolor="#1565c0", fontcolor="white"]
        pacr_dose  [label="Pacritinib\n200mg BID"]
        pacr_C1    [label="Pacr Central\nCompartment"]

        // Momelotinib PK
        node [shape=hexagon, fillcolor="#0d47a1", fontcolor="white"]
        mome_dose  [label="Momelotinib\n200mg QD"]
        mome_C1    [label="Mome Central\nCompartment"]
        mome_ACVR1 [label="ACVR1/ALK2\nInhibition (PD)"]
    }

    // =========================================================
    // CLUSTER 10: Drug PD — Pharmacodynamic Effects
    // =========================================================
    subgraph cluster_pd {
        label="⑩ Drug PD — Pharmacodynamic Effects"
        labeljust=l
        fontname="Helvetica Bold"
        fontsize=13
        fontcolor="#1a2a00"
        style="filled,rounded"
        fillcolor="#f1f8e9"
        color="#558b2f"
        penwidth=2.0

        // PD biomarkers
        node [shape=diamond, fillcolor="#8bc34a", fontcolor="white"]
        JAK1_inhib   [label="JAK1 Inhibition\n(IC50, Emax)"]
        JAK2_inhib   [label="JAK2 Inhibition\n(IC50, Emax)"]
        pSTAT3_supp  [label="pSTAT3\nSuppression (%)"]
        pSTAT5_supp  [label="pSTAT5\nSuppression (%)"]
        FLT3_inhib   [label="FLT3 Inhibition\n(fedratinib)"]
        IRAK1_inhib  [label="IRAK1/4\nInhibition (pacr.)"]
        ACVR1_inhib  [label="ACVR1\nInhibition (mome.)"]

        // Efficacy outputs
        node [shape=box, fillcolor="#558b2f", fontcolor="white"]
        spleen_reduc   [label="Spleen Volume\nReduction (%)"]
        SVR35          [label="SVR35 Response\n(≥35% reduction)"]
        TSS_improv     [label="TSS Improvement\n(symptom score %)"]
        TSS50          [label="TSS50 Response\n(≥50% reduction)"]
        cytokine_reduc [label="Cytokine Level\nReduction (%)"]
        allele_reduc   [label="Allele Burden\nReduction (%)"]

        // Adverse effects
        node [shape=box, fillcolor="#33691e", fontcolor="white"]
        anemia_AE      [label="Drug-induced\nAnemia (AE)"]
        thrombo_AE     [label="Drug-induced\nThrombocytopenia (AE)"]
        infection_risk [label="Infection Risk\n(immunosuppression)"]
        ruxo_withdrawal [label="Ruxolitinib\nWithdrawal Syndrome"]

        // PK-PD link (Emax model)
        node [shape=diamond, fillcolor="#1b5e20", fontcolor="white"]
        Emax_model     [label="Emax/EC50\nPK-PD Model"]
        hill_coeff     [label="Hill Coefficient\n(γ)"]
        Imax_model     [label="Imax/IC50\nInhibition Model"]
    }

    // =========================================================
    // CLUSTER 11: Clinical Endpoints
    // =========================================================
    subgraph cluster_endpoints {
        label="⑪ Clinical Endpoints & Outcomes"
        labeljust=l
        fontname="Helvetica Bold"
        fontsize=13
        fontcolor="#2a0a00"
        style="filled,rounded"
        fillcolor="#fbe9e7"
        color="#bf360c"
        penwidth=2.0

        node [shape=box, fillcolor="#ff7043", fontcolor="white"]
        SVR35_endpoint  [label="Primary Endpoint:\nSVR35 (Week 24)"]
        TSS50_endpoint  [label="Symptom Endpoint:\nTSS50 (Week 24)"]
        BM_response     [label="BM Histological\nResponse"]
        CHR             [label="Complete\nHematological Response"]
        CR_endpoint     [label="Complete\nRemission (CR)"]

        node [shape=box, fillcolor="#e64a19", fontcolor="white"]
        OS_endpoint     [label="Overall Survival\n(OS)"]
        PFS_endpoint    [label="Progression-Free\nSurvival (PFS)"]
        AML_transform   [label="Transformation\nto AML (%)"]
        HSCT_need       [label="Allogeneic HSCT\nNeed / Bridging"]

        node [shape=diamond, fillcolor="#bf360c", fontcolor="white"]
        IWG_MRT_2013    [label="IWG-MRT 2013\nResponse Criteria"]
        ELN_response    [label="ELN 2023\nResponse Criteria"]
        QoL_score       [label="Quality of Life\n(MF-SAF / EORTC)"]
    }

    // =========================================================
    // INTER-CLUSTER EDGES
    // =========================================================

    // --- Genetics → JAK/STAT ---
    JAK2V617F   -> JAK2     [label="constitutive\nactivation", color="#388e3c", style=bold]
    JAK2V617F   -> JAK2_p   [label="auto-phospho", color="#388e3c"]
    CALR_T1     -> TPOR     [label="TpoR binding\n(non-canonical)", color="#388e3c", style=dashed]
    CALR_T2     -> TPOR     [label="TpoR binding", color="#388e3c", style=dashed]
    MPL_W515L   -> TPOR     [label="constitutive\nactivation", color="#388e3c"]
    MPL_W515K   -> TPOR     [label="constitutive\nactivation", color="#388e3c"]
    TPOR        -> JAK2     [label="transphospho", color="#388e3c"]
    EPOR        -> JAK2     [label="Jak2 coupling", color="#388e3c"]
    JAK2_p      -> STAT5a   [label="pY activation", color="#2e7d32", style=bold]
    JAK2_p      -> STAT5b   [label="pY activation", color="#2e7d32"]
    JAK2_p      -> STAT3    [label="pY activation", color="#2e7d32"]
    JAK1        -> STAT3    [label="co-activation", color="#2e7d32"]
    TYK2        -> STAT1    [label="activation", color="#2e7d32"]
    STAT3       -> pSTAT3   [label="dimerization\n& nuclear", color="#1b5e20", style=bold]
    STAT5a      -> pSTAT5   [label="dimerization\n& nuclear", color="#1b5e20", style=bold]
    STAT5b      -> pSTAT5   [label="dimerization", color="#1b5e20"]
    pSTAT3      -> SOCS3    [label="transcription\n(neg feedback)", color="#c62828", arrowhead=tee]
    pSTAT5      -> SOCS1    [label="transcription\n(neg feedback)", color="#c62828", arrowhead=tee]
    SOCS1       -> JAK2     [label="inhibits", color="#c62828", arrowhead=tee]
    SOCS3       -> JAK1     [label="inhibits", color="#c62828", arrowhead=tee]
    SHP2        -> JAK2_p   [label="dephospho\n(inactivation)", color="#c62828", arrowhead=tee]
    pSTAT3      -> BCL2_jak [label="transcription", color="#2e7d32"]
    pSTAT3      -> MCL1     [label="transcription", color="#2e7d32"]
    pSTAT5      -> CCND1    [label="transcription", color="#2e7d32"]
    pSTAT5      -> MYC_jak  [label="transcription", color="#2e7d32"]
    pSTAT5      -> PIM1     [label="transcription", color="#2e7d32"]

    // --- Genetics → Epigenetic consequences ---
    ASXL1_mut   -> mutational_complexity [label="adds score", color="#5c6bc0"]
    EZH2_mut    -> mutational_complexity [label="adds score", color="#5c6bc0"]
    IDH1_mut    -> mutational_complexity [label="adds score", color="#5c6bc0"]
    TP53_mut    -> mutational_complexity [label="adds score", color="#5c6bc0"]
    TET2_mut    -> mutational_complexity [label="adds score", color="#5c6bc0"]
    DNMT3A_mut  -> mutational_complexity [label="adds score", color="#5c6bc0"]
    SRSF2_mut   -> mutational_complexity [label="adds score", color="#5c6bc0"]
    JAK2V617F   -> JAK2_allele_burden    [label="clonal\nexpansion", color="#5c6bc0"]
    JAK2_allele_burden -> DIPSS_score    [label="input", color="#3949ab"]
    mutational_complexity -> MIPSS70     [label="input", color="#3949ab"]
    MIPSS70     -> DIPSS_score           [label="refines", color="#3949ab"]

    // --- JAK/STAT → HSC Niche ---
    pSTAT5      -> LT_HSC   [label="drives\nself-renewal", color="#e65100", style=bold]
    pSTAT5      -> clone_fraction [label="clonal advantage", color="#e65100"]
    MYC_jak     -> HSC_selfrenewal [label="up-regulates", color="#e65100"]
    BCL2_jak    -> HSC_apoptosis  [label="inhibits\napoptosis", color="#e65100", arrowhead=tee]
    SCF         -> cKIT     [label="ligand-receptor", color="#ff8f00"]
    cKIT        -> JAK2     [label="c-Kit→Jak2", color="#388e3c"]
    TPO         -> TPOR     [label="TPO binding", color="#ff8f00"]
    CXCL12      -> CXCR4    [label="retention\nsignal", color="#ff8f00"]
    CXCR4       -> HSC_pool [label="BM anchoring", color="#e65100"]
    LT_HSC      -> ST_HSC   [label="differentiation", color="#ffa726"]
    ST_HSC      -> MPP      [label="differentiation", color="#ffa726"]
    MPP         -> CMP      [label="commitment", color="#ffa726"]
    CMP         -> GMP      [label="granulocyte\nlineage", color="#ffa726"]
    CMP         -> MEP      [label="MK/erythroid\nlineage", color="#ffa726"]
    MEP         -> MkP      [label="MK\ncommitment", color="#ffa726"]
    MEP         -> BFU_E    [label="erythroid\ncommitment", color="#ffa726"]
    HSC_pool    -> clone_fraction [label="MF clone\ndominance", color="#e65100"]
    HSC_pool    -> CD34_BM  [label="populates", color="#e65100"]

    // --- HSC / BM environment → Fibrosis ---
    MkP         -> MF_MK    [label="aberrant\ndifferentiation", color="#c62828", style=bold]
    MF_MK       -> TGFb1    [label="secretes", color="#c62828", style=bold]
    MF_MK       -> PDGF_AB  [label="secretes", color="#c62828"]
    MF_MK       -> bFGF     [label="secretes", color="#c62828"]
    MF_MK       -> CXCL4    [label="secretes α-granule", color="#c62828"]
    TGFb1       -> MSC      [label="activates", color="#c62828"]
    TGFb1       -> CAF      [label="activates", color="#c62828"]
    TGFb1       -> collagen_I [label="↑ synthesis", color="#c62828", style=bold]
    PDGF_AB     -> MSC      [label="proliferation", color="#e57373"]
    bFGF        -> CAF      [label="activates", color="#e57373"]
    CTGF        -> collagen_I [label="↑ deposition", color="#c62828"]
    MSC         -> CTGF     [label="produces", color="#c62828"]
    MSC         -> fibronectin [label="produces", color="#c62828"]
    OPN         -> collagen_I  [label="promotes", color="#c62828"]
    collagen_I  -> reticulin   [label="forms\nreticulin", color="#8d1f1f", style=bold]
    reticulin   -> MF_grade    [label="histological\ngrading", color="#8d1f1f", style=bold]
    MF_grade    -> osteosclerosis [label="advanced MF", color="#8d1f1f"]
    MMP9        -> fibronectin    [label="degrades", color="#c62828", arrowhead=tee]
    TIMP1       -> MMP9           [label="inhibits", color="#c62828", arrowhead=tee]
    OB          -> osteosclerosis [label="osteoblastic\nactivity", color="#8d1f1f"]
    OC          -> osteosclerosis [label="coupled", color="#8d1f1f"]

    // --- Cytokines: production routes ---
    pSTAT3      -> IL6      [label="transcription", color="#3949ab"]
    NRBCs       -> IL1b     [label="produces", color="#3949ab"]
    MF_MK       -> IL13     [label="secretes", color="#3949ab"]
    TGFb1       -> CTGF     [label="induces", color="#3949ab"]
    IL6         -> GP130    [label="receptor", color="#3949ab"]
    GP130       -> JAK1     [label="Jak1 signal", color="#388e3c"]
    IL1b        -> NFkB     [label="activates", color="#3949ab", style=bold]
    TNFa        -> NFkB     [label="activates", color="#3949ab"]
    NFkB        -> IL6      [label="transcription", color="#3949ab"]
    NFkB        -> IL8      [label="transcription", color="#3949ab"]
    NFkB        -> TNFa     [label="auto-feed", color="#3949ab"]
    IL6         -> mTOR     [label="via PI3K/Akt", color="#3949ab"]
    mTOR        -> PI3K     [label="feedback", color="#3949ab"]
    PI3K        -> RAS_ERK  [label="cross-talk", color="#3949ab"]
    NLRP3       -> IL1b     [label="processes\npro-IL1β", color="#3949ab", style=bold]
    IL6         -> fever    [label="hypothalamus", color="#283593"]
    TNFa        -> weight_loss [label="cachexia", color="#283593"]
    IL6         -> night_sweat [label="autonomic\nstimulation", color="#283593"]
    IL13        -> TGFb1    [label="induces", color="#c62828"]
    IFNg        -> SOCS1    [label="induces", color="#c62828"]
    CXCL10      -> fatigue_cyt [label="neurological", color="#283593"]
    CCL2        -> MSC      [label="recruits\nmonocytes", color="#c62828"]

    // --- HSC → EMH ---
    BM_failure  -> CD34_circ [label="forces\nmobilization", color="#00695c", style=bold]
    CXCR4_down  -> CD34_circ [label="releases", color="#00695c"]
    MMP_increase -> CXCR4_down [label="cleaves CXCR4", color="#00695c"]
    MF_grade    -> BM_failure  [label="drives", color="#00695c"]
    CD34_circ   -> spleen_HSC  [label="engraft", color="#00695c", style=bold]
    CD34_circ   -> liver_HSC   [label="engraft", color="#00695c"]
    spleen_HSC  -> spleen_myeloid [label="myeloid\nexpansion", color="#00895c"]
    spleen_HSC  -> spleen_MK    [label="MK\nexpansion", color="#00895c"]
    spleen_myeloid -> spleen_volume [label="↑ volume", color="#00695c"]
    spleen_MK   -> spleen_volume   [label="↑ volume", color="#00695c"]
    spleen_volume -> splenomegaly  [label="classification", color="#00695c"]
    liver_HSC   -> liver_volume   [label="↑ volume", color="#00695c"]
    liver_volume -> hepatomegaly  [label="classification", color="#00695c"]
    circ_MK     -> spleen_MK   [label="lodges in\nspleen", color="#00895c"]
    immature_gran -> spleen_myeloid [label="contributes", color="#00695c"]
    NRBCs       -> spleen_volume   [label="erythroid EMH", color="#00695c"]
    MMP9        -> MMP_increase    [label="is", color="#00695c"]

    // --- Hematological consequences ---
    BFU_E       -> RBC_prod    [label="erythropoiesis", color="#7b1fa2"]
    EPO_level   -> BFU_E       [label="stimulates", color="#7b1fa2"]
    TGFb1       -> BFU_E       [label="suppresses\nerythropoiesis", color="#c62828", arrowhead=tee]
    spleen_volume -> RBC_destroy [label="hypersplenism", color="#c62828"]
    RBC_prod    -> Hgb         [label="contributes", color="#7b1fa2"]
    RBC_destroy -> Hgb         [label="reduces", color="#c62828", arrowhead=tee]
    Hgb         -> MCV         [label="morphology", color="#9c27b0"]
    Hgb         -> retic_count [label="drives", color="#9c27b0"]
    Hgb         -> anemia_severity [label="defines", color="#4a148c"]
    anemia_severity -> transfusion_dep [label="drives\nneed", color="#4a148c"]
    MkP         -> PLT_prod    [label="thrombopoiesis", color="#9c27b0"]
    spleen_volume -> PLT_destroy [label="sequestration", color="#c62828"]
    PLT_prod    -> PLT_count   [label="contributes", color="#9c27b0"]
    PLT_destroy -> PLT_count   [label="reduces", color="#c62828", arrowhead=tee]
    PLT_count   -> thrombo_risk [label="low PLT", color="#9c27b0"]
    GMP         -> WBC_count   [label="granulopoiesis", color="#7b1fa2"]
    WBC_count   -> neutrophil  [label="differential", color="#7b1fa2"]
    blast_pct   -> AML_transform [label="blast excess\n>20%", color="#bf360c", style=bold]
    JAK2V617F   -> allele_dyn  [label="clonal\nexpansion", color="#4a148c"]
    allele_dyn  -> JAK2_allele_burden [label="tracks\ndisease", color="#4a148c"]

    // --- Thrombosis ---
    PLT_activation -> TXA2     [label="arachidonate\npathway", color="#e65100"]
    PLT_activation -> fibrin_clot [label="platelet\nthrombus", color="#e65100"]
    TXA2           -> thrombin_gen [label="amplifies", color="#e65100"]
    TF_expr        -> FXa_activ   [label="coagulation\ncascade", color="#e65100"]
    FXa_activ      -> thrombin_gen [label="prothrombinase", color="#e65100"]
    thrombin_gen   -> fibrin_clot  [label="fibrinogen→fibrin", color="#e65100", style=bold]
    PAI1           -> fibrin_clot  [label="stabilizes\n(anti-fibrinolysis)", color="#e65100"]
    vWF_ultra      -> PLT_activation [label="tethers\nplatelets", color="#e65100"]
    endothel_dysfunc -> TF_expr   [label="expresses TF", color="#e65100"]
    endothel_dysfunc -> VCAM1     [label="up-regulates", color="#e65100"]
    eNOS_reduc     -> endothel_dysfunc [label="less NO\nprotection", color="#e65100"]
    JAK2V617F      -> PLT_activation  [label="hyperactives\nplatelets", color="#e65100"]
    fibrin_clot    -> thrombotic_event [label="occlusion", color="#bf360c", style=bold]
    thrombo_risk   -> bleeding_risk    [label="anti-platelet\ntx risk", color="#e65100"]
    fibrin_clot    -> portal_HTN       [label="BCS/PVT", color="#e65100"]

    // --- Drug PK internal ---
    ruxo_dose   -> ruxo_gut  [label="oral dose", color="#1565c0"]
    ruxo_gut    -> ruxo_C1   [label="absorption\nka_ruxo", color="#1565c0"]
    ruxo_C1     -> ruxo_C2   [label="distribution Q", color="#1565c0"]
    ruxo_C2     -> ruxo_C1   [label="redistribution Q", color="#1565c0"]
    ruxo_C1     -> ruxo_CL   [label="elimination", color="#1565c0"]
    ruxo_ka     -> ruxo_gut  [label="parameter", color="#90caf9", style=dashed]
    ruxo_V1     -> ruxo_C1   [label="volume", color="#90caf9", style=dashed]
    ruxo_V2     -> ruxo_C2   [label="volume", color="#90caf9", style=dashed]
    ruxo_F1     -> ruxo_gut  [label="bioavail.", color="#90caf9", style=dashed]
    fedr_dose   -> fedr_C1   [label="oral dose", color="#1565c0"]
    fedr_ka     -> fedr_C1   [label="absorption", color="#1565c0"]
    fedr_F1     -> fedr_C1   [label="bioavail.\n(+food)", color="#1565c0", style=dashed]
    pacr_dose   -> pacr_C1   [label="oral dose", color="#1565c0"]
    mome_dose   -> mome_C1   [label="oral dose", color="#1565c0"]
    mome_C1     -> mome_ACVR1 [label="ACVR1\ntarget engagement", color="#1565c0"]

    // --- Drug PK → PD ---
    ruxo_C1     -> JAK1_inhib  [label="concentration-\neffect", color="#558b2f", style=bold]
    ruxo_C1     -> JAK2_inhib  [label="concentration-\neffect", color="#558b2f", style=bold]
    fedr_C1     -> JAK2_inhib  [label="FLT3 + JAK2\ninh.", color="#558b2f"]
    fedr_C1     -> FLT3_inhib  [label="potent FLT3\ninh.", color="#558b2f"]
    pacr_C1     -> JAK2_inhib  [label="JAK2/FLT3\ninh.", color="#558b2f"]
    pacr_C1     -> IRAK1_inhib [label="IRAK1/4\ninh.", color="#558b2f"]
    mome_C1     -> JAK1_inhib  [label="JAK1/2 inh.", color="#558b2f"]
    Emax_model  -> pSTAT3_supp [label="links Cp→ΔpSTAT3", color="#558b2f", style=dashed]
    Imax_model  -> pSTAT5_supp [label="links Cp→ΔpSTAT5", color="#558b2f", style=dashed]
    JAK1_inhib  -> pSTAT3_supp [label="reduces", color="#558b2f", style=bold]
    JAK2_inhib  -> pSTAT5_supp [label="reduces", color="#558b2f", style=bold]
    hill_coeff  -> Emax_model  [label="steepness", color="#1b5e20", style=dashed]

    // --- PD → Disease Effects ---
    pSTAT3_supp -> cytokine_reduc   [label="anti-inflammatory", color="#558b2f", style=bold]
    pSTAT5_supp -> allele_reduc     [label="clone\nsuppression", color="#558b2f"]
    cytokine_reduc -> TSS_improv    [label="symptom relief", color="#558b2f", style=bold]
    cytokine_reduc -> spleen_reduc  [label="cytokine-driven\nsplenomegaly↓", color="#558b2f"]
    pSTAT3_supp -> spleen_reduc     [label="via MK/myeloid\nreduction", color="#558b2f", style=bold]
    spleen_reduc -> SVR35           [label="≥35% reduction\ncriterion", color="#33691e", style=bold]
    TSS_improv  -> TSS50            [label="≥50% reduction\ncriterion", color="#33691e", style=bold]
    pSTAT5_supp -> anemia_AE        [label="on-target\nEPOR inhibition", color="#c62828"]
    JAK2_inhib  -> thrombo_AE       [label="MkP\nsuppression", color="#c62828"]
    mome_ACVR1  -> anemia_AE        [label="ACVR1→hepcidin\nreduction", color="#558b2f", arrowhead=tee]
    IRAK1_inhib -> NFkB             [label="reduces\nNF-κB", color="#558b2f", arrowhead=tee]
    allele_reduc -> allele_dyn      [label="reduces", color="#558b2f", arrowhead=tee]

    // --- PD → Clinical Endpoints ---
    SVR35        -> SVR35_endpoint   [label="measured\nWeek 24", color="#bf360c", style=bold]
    TSS50        -> TSS50_endpoint   [label="measured\nWeek 24", color="#bf360c", style=bold]
    MF_grade     -> BM_response      [label="histological\nimprovement", color="#bf360c"]
    Hgb          -> CHR              [label="Hgb ≥10 g/dL", color="#bf360c"]
    PLT_count    -> CHR              [label="PLT norm.", color="#bf360c"]
    WBC_count    -> CHR              [label="WBC norm.", color="#bf360c"]
    allele_reduc -> BM_response      [label="molecular\nresponse", color="#bf360c"]
    IWG_MRT_2013 -> SVR35_endpoint   [label="defines", color="#e64a19", style=dashed]
    IWG_MRT_2013 -> TSS50_endpoint   [label="defines", color="#e64a19", style=dashed]
    ELN_response -> BM_response      [label="defines", color="#e64a19", style=dashed]
    OS_endpoint  -> IWG_MRT_2013     [label="secondary\nendpoint", color="#bf360c"]
    AML_transform -> OS_endpoint     [label="negatively\naffects", color="#bf360c", style=bold]
    DIPSS_score  -> OS_endpoint      [label="predicts", color="#bf360c", style=bold]
    DIPSS_score  -> HSCT_need        [label="high-risk → HSCT\nbridging therapy", color="#bf360c"]
    blast_pct    -> AML_transform    [label="blast crisis", color="#bf360c", style=bold]
    BM_response  -> PFS_endpoint     [label="deep response\n→ PFS benefit", color="#bf360c"]
    QoL_score    -> TSS50_endpoint   [label="correlated", color="#e64a19", style=dashed]
    ruxo_withdrawal -> OS_endpoint   [label="withdrawal syndrome\nworsen survival", color="#c62828", style=dashed]

    // --- Cross-links: Fibrosis → Cytokines ---
    TGFb1        -> IL6     [label="induces", color="#3949ab", style=dashed]
    TGFb1        -> CCL2    [label="induces", color="#3949ab", style=dashed]
    NFkB         -> IL13    [label="transcription", color="#3949ab"]
    IL13         -> collagen_I [label="pro-fibrotic\nTGFb-independent", color="#c62828"]

    // --- Cross-links: EMH ↔ Heme ---
    spleen_volume -> PLT_destroy [label="hypersplenism\nsequestration", color="#c62828"]
    spleen_volume -> RBC_destroy [label="hypersplenism", color="#c62828"]
    CD34_circ    -> blast_pct   [label="immature\nprogenitors", color="#7b1fa2"]
    NRBCs        -> leuko_state [label="leukoerythroblastosis", color="#7b1fa2"]
    leuko_state  -> WBC_count   [label="abnormal WBC", color="#7b1fa2"]

    // --- Cross-links: Thrombosis ↔ EMH ---
    portal_HTN   -> splenomegaly    [label="congestion", color="#e65100"]
    splenomegaly -> PLT_destroy     [label="platelet\nsequestration", color="#c62828"]

    // --- EPO / Anemia therapy note ---
    EPO_level    -> EPOR    [label="endogenous\nstimulation", color="#388e3c"]
    anemia_AE    -> transfusion_dep [label="worsens\nneed", color="#c62828"]
    transfusion_dep -> QoL_score    [label="impairs", color="#c62828", arrowhead=tee]
    fatigue_cyt  -> QoL_score       [label="impairs", color="#c62828", arrowhead=tee]

    // =========================================================
    // LEGEND (invisible cluster, placed far right)
    // =========================================================
    subgraph cluster_legend {
        label="Legend"
        fontname="Helvetica Bold"
        fontsize=11
        style="filled,rounded"
        fillcolor="#fffff0"
        color="#555555"
        penwidth=1.5

        node [shape=ellipse, fillcolor="#9fa8da", fontcolor="#1a1a2e", width=1.0]
        leg_gene  [label="Gene /\nMutation"]

        node [shape=box, fillcolor="#66bb6a", fontcolor="white", width=1.0]
        leg_prot  [label="Protein /\nReceptor"]

        node [shape=diamond, fillcolor="#e57373", fontcolor="#1a1a2e", width=1.0]
        leg_proc  [label="Process /\nState"]

        node [shape=hexagon, fillcolor="#1e88e5", fontcolor="white", width=1.0]
        leg_drug  [label="Drug /\nDose"]

        node [shape=box, fillcolor="#ff7043", fontcolor="white", width=1.0]
        leg_endpt [label="Clinical\nEndpoint"]

        leg_gene -> leg_prot [label="activation →", color="#388e3c", style=bold]
        leg_prot -> leg_proc [label="inhibition ⊣", color="#c62828", arrowhead=tee]
    }

}
