digraph COPD_QSP {
  graph [
    label="COPD Quantitative Systems Pharmacology Model\nPathogenesis · Inflammation · Remodeling · Drug PK/PD · Clinical Endpoints"
    fontsize=22 fontname="Helvetica-Bold"
    bgcolor="#F8F9FA" rankdir=LR
    splines=true overlap=false
    nodesep=0.35 ranksep=0.9
    pad=0.6
  ]
  node [fontname="Helvetica" fontsize=9 style=filled shape=box]
  edge [fontname="Helvetica" fontsize=7]

  // ─────────────────────────────────────────────────────
  // CLUSTER 1: Environmental Triggers & Oxidative Stress
  // ─────────────────────────────────────────────────────
  subgraph cluster_env {
    label="Environmental Triggers & Oxidative Stress"
    fontsize=13 fontname="Helvetica-Bold"
    style=filled fillcolor="#FFF3E0" color="#E65100" penwidth=2

    CS   [label="Cigarette Smoke" fillcolor="#FF8F00" fontcolor=white]
    AP   [label="Air Pollution\n(PM2.5, NO2, O3)" fillcolor="#FF8F00" fontcolor=white]
    Bio  [label="Biomass Smoke\nOccupational Dust" fillcolor="#FF8F00" fontcolor=white]
    ROS  [label="Reactive Oxygen Species\n(ROS / H2O2 / OH•)" fillcolor="#FF6F00" fontcolor=white]
    RNS  [label="Reactive Nitrogen Species\n(ONOO⁻ / NO)" fillcolor="#FF6F00" fontcolor=white]
    Acr  [label="Acrolein / Aldehydes\n(Carbonyl stress)" fillcolor="#FFA000"]
    PAH  [label="PAHs / Nitrosamines\n(DNA adducts)" fillcolor="#FFA000"]
    NRF2 [label="NRF2\n(Keap1 inhibited)" fillcolor="#FFD54F"]
    HO1  [label="HO-1 / NQO1\n(Cytoprotective)" fillcolor="#FFE082"]
    GSH  [label="Glutathione (GSH)\nSOD / Catalase" fillcolor="#FFE082"]
    OxStress [label="Oxidative Stress\n(Protein carbonylation\nDNA 8-OHdG↑)" fillcolor="#FF5722" fontcolor=white]
    SIRT1 [label="SIRT1↓ / HDAC2↓\n(Histone deacetylase)" fillcolor="#FFCCBC"]
  }

  // ─────────────────────────────────────────────────────
  // CLUSTER 2: Epithelial Barrier & Mucus
  // ─────────────────────────────────────────────────────
  subgraph cluster_epithelial {
    label="Airway Epithelium & Mucociliary Clearance"
    fontsize=13 fontname="Helvetica-Bold"
    style=filled fillcolor="#E8F5E9" color="#1B5E20" penwidth=2

    Ep   [label="Bronchial Epithelium\n(Ciliated / Goblet / Club)" fillcolor="#66BB6A" fontcolor=white]
    Tigh [label="Tight Junction Loss\n(E-cadherin↓, occludin↓)" fillcolor="#AED581"]
    EMT  [label="EMT\n(E-cad→N-cad switch)" fillcolor="#AED581"]
    Goblet [label="Goblet Cell Hyperplasia\nMUC5AC/MUC5B↑" fillcolor="#81C784"]
    Cil  [label="Ciliary Dysfunction\n(Cilia beat freq↓)" fillcolor="#81C784"]
    PCL  [label="Periciliary Liquid↓\n(Airway Surface Dehydration)" fillcolor="#A5D6A7"]
    Muc  [label="Mucus Hypersecretion\n(Mucus plugging)" fillcolor="#A5D6A7"]
    MCC  [label="Mucociliary Clearance↓" fillcolor="#C8E6C9"]
    TSLP_ep [label="TSLP / IL-33 / IL-25\n(Epithelial alarmins)" fillcolor="#E8F5E9" color="#1B5E20"]
    DAMP [label="DAMPs: HMGB1, S100A8/9\nATP, Uric acid, dsDNA" fillcolor="#E8F5E9" color="#1B5E20"]
    TLR  [label="TLR2/4/7/9\nNLRP3 / RAGE\nP2X7R" fillcolor="#C8E6C9"]
    CS_prot [label="CS-induced Proteolysis\nof Epithelial Proteins" fillcolor="#A5D6A7"]
  }

  // ─────────────────────────────────────────────────────
  // CLUSTER 3: Innate Immunity — Macrophage & Neutrophil
  // ─────────────────────────────────────────────────────
  subgraph cluster_innate {
    label="Innate Immunity — Macrophage & Neutrophil Inflammation"
    fontsize=13 fontname="Helvetica-Bold"
    style=filled fillcolor="#E3F2FD" color="#0D47A1" penwidth=2

    AM   [label="Alveolar Macrophage\n(M1 polarized)" fillcolor="#1976D2" fontcolor=white]
    MoM  [label="Monocyte-derived Macrophage\n(Recruited)" fillcolor="#1565C0" fontcolor=white]
    NFkB [label="NF-κB\n(RelA/p65 activation)" fillcolor="#42A5F5"]
    AP1  [label="AP-1\n(c-Jun / c-Fos)" fillcolor="#42A5F5"]
    IL8  [label="IL-8 (CXCL8)\nCXCL1/CXCL5" fillcolor="#90CAF9"]
    IL1b [label="IL-1β\n(NLRP3/Caspase-1)" fillcolor="#90CAF9"]
    IL6  [label="IL-6\nGP130/JAK2/STAT3" fillcolor="#90CAF9"]
    TNFa [label="TNF-α\nTNFR1/TNFR2" fillcolor="#90CAF9"]
    MMP12 [label="MMP-12\n(Macrophage elastase)" fillcolor="#BBDEFB"]
    MMP9  [label="MMP-9 / MMP-1\n(Type IV collagenase)" fillcolor="#BBDEFB"]
    NLRP3 [label="NLRP3 Inflammasome\n(ASC / Pro-IL-1β)" fillcolor="#64B5F6"]
    Neut  [label="Neutrophil\n(CXCR1/CXCR2)" fillcolor="#1E88E5" fontcolor=white]
    NE    [label="Neutrophil Elastase (NE)\n(SERPINA1 antagonist)" fillcolor="#42A5F5"]
    PR3   [label="Proteinase 3 / CatG\nLeucolysin (MMP-8)" fillcolor="#42A5F5"]
    MPO   [label="Myeloperoxidase\n(HOCl / ROS)" fillcolor="#64B5F6"]
    NET   [label="NETs\n(citrullinated histones\n+ DNA traps)" fillcolor="#7986CB"]
    ILC3  [label="ILC3\n(IL-17/IL-22 secretor)" fillcolor="#90CAF9"]
    DC    [label="Dendritic Cell\n(mDC / pDC)" fillcolor="#5C6BC0" fontcolor=white]
    Mast  [label="Mast Cell\n(IgE-FcεRI / cKit)" fillcolor="#7E57C2" fontcolor=white]
  }

  // ─────────────────────────────────────────────────────
  // CLUSTER 4: Adaptive Immunity
  // ─────────────────────────────────────────────────────
  subgraph cluster_adaptive {
    label="Adaptive Immunity — T & B Lymphocytes"
    fontsize=13 fontname="Helvetica-Bold"
    style=filled fillcolor="#F3E5F5" color="#4A148C" penwidth=2

    CD8  [label="CD8+ T Cell (Tc1)\n(Major driver in COPD)" fillcolor="#7B1FA2" fontcolor=white]
    IFNg [label="IFN-γ\n(Tc1 / Th1 cytokine)" fillcolor="#AB47BC"]
    Th1  [label="CD4+ Th1\n(IFN-γ / IL-2)" fillcolor="#8E24AA" fontcolor=white]
    Th17 [label="CD4+ Th17\n(IL-17A/F / IL-22)" fillcolor="#8E24AA" fontcolor=white]
    IL17 [label="IL-17A/F\n(Neutrophil recruitment)" fillcolor="#CE93D8"]
    Treg [label="CD4+ Treg\n(IL-10 / TGFβ)\n(Suppressed in COPD)" fillcolor="#BA68C8"]
    Bcell [label="B Cell / Plasma Cell\n(Lymphoid follicles)" fillcolor="#9C27B0" fontcolor=white]
    AutoAb [label="Auto-antibodies\n(Anti-elastin, Anti-EP)" fillcolor="#E1BEE7"]
    IL10 [label="IL-10\n(Anti-inflammatory)" fillcolor="#CE93D8"]
    CXCL13 [label="CXCL13\n(B-cell chemoattractant)" fillcolor="#E1BEE7"]
    GM_CSF [label="GM-CSF\n(Myeloid differentiation)" fillcolor="#D1C4E9"]
  }

  // ─────────────────────────────────────────────────────
  // CLUSTER 5: Protease-Antiprotease Imbalance
  // ─────────────────────────────────────────────────────
  subgraph cluster_protease {
    label="Protease-Antiprotease Imbalance & ECM Destruction"
    fontsize=13 fontname="Helvetica-Bold"
    style=filled fillcolor="#FBE9E7" color="#BF360C" penwidth=2

    A1AT [label="α1-Antitrypsin (SERPINA1)\n(NE inhibitor)\n[Z/S alleles → deficiency]" fillcolor="#E64A19" fontcolor=white]
    SLPI [label="SLPI / Elafin\n(Secretory Leukocyte\nProtease Inhibitor)" fillcolor="#FF7043"]
    TIMP1 [label="TIMP-1 / TIMP-2\n(MMP inhibitors)" fillcolor="#FF7043"]
    ECM_E  [label="Elastin Degradation\n(Desmosine / Isodesmosine↑)" fillcolor="#FFAB91"]
    ECM_C  [label="Collagen I/III/IV Degradation\n(Hydroxyproline↑)" fillcolor="#FFAB91"]
    ECM_FN [label="Fibronectin / Laminin\nDegradation" fillcolor="#FFCCBC"]
    Emph   [label="Emphysema\n(Alveolar Enlargement\nDestruction of septa)" fillcolor="#FF5722" fontcolor=white]
    AirTrap [label="Air Trapping\nHyperinflation\n(RV↑ / TLC↑)" fillcolor="#FF8A65"]
    FEV1dec [label="FEV1↓\n(Irreversible airflow\nlimitation)" fillcolor="#FF7043" fontcolor=white]
    Cath   [label="Cathepsin B/L/S/K\n(Lysosomal cysteine\nproteases)" fillcolor="#FFCCBC"]
  }

  // ─────────────────────────────────────────────────────
  // CLUSTER 6: Airway Remodeling & Fibrosis
  // ─────────────────────────────────────────────────────
  subgraph cluster_remodel {
    label="Small Airway Disease & Fibrotic Remodeling"
    fontsize=13 fontname="Helvetica-Bold"
    style=filled fillcolor="#E8EAF6" color="#1A237E" penwidth=2

    TGFb1 [label="TGF-β1\n(Fibrogenic master)" fillcolor="#3949AB" fontcolor=white]
    Smad23 [label="SMAD2/3\n(Canonical signaling)" fillcolor="#5C6BC0" fontcolor=white]
    Smad7  [label="SMAD7\n(Inhibitory)" fillcolor="#7986CB"]
    mTOR  [label="PI3K/AKT/mTOR\n(Non-canonical TGF-β)" fillcolor="#7986CB"]
    Fibro  [label="Fibroblast → Myofibroblast\n(α-SMA+)" fillcolor="#3F51B5" fontcolor=white]
    Col1   [label="Collagen I/III\nDeposition (Fibrosis)" fillcolor="#9FA8DA"]
    ASM    [label="Airway Smooth Muscle\n(Hypertrophy / Hyperplasia)" fillcolor="#5C6BC0" fontcolor=white]
    EGFR   [label="EGFR → ERK\n(Mucin & remodeling)" fillcolor="#7986CB"]
    VEGF_aw [label="VEGF↑\n(Airway neoangiogenesis)" fillcolor="#7986CB"]
    AWthick [label="Airway Wall Thickening\n(Pi10↑, %WA↑ on HRCT)" fillcolor="#9FA8DA"]
    SAclosure [label="Small Airway Closure\n(FEV1/FVC↓)" fillcolor="#C5CAE9"]
    IL13   [label="IL-13 / IL-4\n(Th2 remodeling)" fillcolor="#9FA8DA"]
    Wnt    [label="WNT/β-catenin\n(Epithelial repair)" fillcolor="#C5CAE9"]
    FGF10  [label="FGF10 / KGF\n(Epithelial growth)" fillcolor="#C5CAE9"]
  }

  // ─────────────────────────────────────────────────────
  // CLUSTER 7: Pulmonary Vasculature & Systemic Effects
  // ─────────────────────────────────────────────────────
  subgraph cluster_vasculature {
    label="Pulmonary Vasculature, RV & Systemic Comorbidities"
    fontsize=13 fontname="Helvetica-Bold"
    style=filled fillcolor="#E0F2F1" color="#004D40" penwidth=2

    HPV  [label="Hypoxic Pulmonary\nVasoconstriction (HPV)" fillcolor="#00796B" fontcolor=white]
    ET1v [label="ET-1↑ / NO↓\n(eNOS uncoupling)" fillcolor="#00897B" fontcolor=white]
    PVrem [label="Pulmonary Vascular\nRemodeling (PASMC hypert.)" fillcolor="#009688" fontcolor=white]
    PH   [label="Pulmonary Hypertension\n(WHO Group 3 PH-COPD)" fillcolor="#00695C" fontcolor=white]
    RVH  [label="RV Hypertrophy\n→ Cor Pulmonale" fillcolor="#00796B" fontcolor=white]
    VQ   [label="V/Q Mismatch\n(Dead space + Shunt)" fillcolor="#4DB6AC"]
    Hypox [label="Hypoxemia\n(PaO2↓, SpO2↓)" fillcolor="#80CBC4"]
    HyperC [label="Hypercapnia\n(PaCO2↑, pH↓)" fillcolor="#80CBC4"]
    SysInflam [label="Systemic Inflammation\n(CRP↑, Fibrinogen↑, IL-6↑)" fillcolor="#B2DFDB"]
    Sarco [label="Sarcopenia / Cachexia\n(Myostatin↑, IGF-1↓)" fillcolor="#B2DFDB"]
    CVrisk [label="CV Comorbidities\n(CAD, HF, AF, PAD)" fillcolor="#4DB6AC"]
    BMD  [label="Osteoporosis\n(ICS use, systemic inflam.)" fillcolor="#80CBC4"]
    T2DM_c [label="T2DM / MetS\n(Metabolic comorbidity)" fillcolor="#B2DFDB"]
    Anemia [label="Anemia / Polycythemia\n(EPO response)" fillcolor="#A7FFEB"]
    DeprAnx [label="Depression / Anxiety\n(Neuroinflammation)" fillcolor="#B2DFDB"]
  }

  // ─────────────────────────────────────────────────────
  // CLUSTER 8: Clinical Endpoints & GOLD Classification
  // ─────────────────────────────────────────────────────
  subgraph cluster_clinical {
    label="Clinical Endpoints, Lung Function & GOLD Classification"
    fontsize=13 fontname="Helvetica-Bold"
    style=filled fillcolor="#FFFDE7" color="#F57F17" penwidth=2

    FEV1   [label="FEV1 (% predicted)\nGOLD 1: ≥80%\nGOLD 2: 50-79%\nGOLD 3: 30-49%\nGOLD 4: <30%" fillcolor="#F9A825" fontcolor=white]
    FVC    [label="FVC / FEV1/FVC\n(Post-BD <0.70 = obst.)" fillcolor="#FDD835"]
    RV_TLC [label="RV / TLC↑\nFRC↑\n(Static hyperinflation)" fillcolor="#FFEE58"]
    DLCO   [label="DLCO↓\n(Emphysema marker)" fillcolor="#FFF176"]
    HRCT   [label="HRCT\nLAA-950 (Emphysema%)\nAWI (Airway wall index)" fillcolor="#FFF9C4"]
    mMRC   [label="mMRC Dyspnea\n(0-4 scale)" fillcolor="#FFECB3"]
    CAT    [label="CAT Score\n(COPD Assessment Test\n0-40)" fillcolor="#FFECB3"]
    SGRQ   [label="SGRQ\n(St. George's\nRespiratory Q)" fillcolor="#FFF8E1"]
    BODE   [label="BODE Index\n(BMI/FEV1/Dyspnea/6MWT\n→ Mortality predictor)" fillcolor="#FFE082"]
    SixMWT [label="6-Minute Walk Distance\n(6MWT, m)" fillcolor="#FFE082"]
    AECOPD [label="Acute Exacerbation\n(AECOPD)\n[Moderate / Severe]" fillcolor="#FF8F00" fontcolor=white]
    AEbact  [label="Bacterial Exacerbation\nH.flu / S.pneumo\nM.catarrh / P.aerug" fillcolor="#FFB300"]
    AEviral [label="Viral Exacerbation\n(RV / Influenza / RSV)" fillcolor="#FFB300"]
    ICU    [label="Hospitalization / ICU\n(Mechanical Ventilation)" fillcolor="#E65100" fontcolor=white]
    Mort   [label="COPD Mortality\n(All-cause / Respiratory)" fillcolor="#BF360C" fontcolor=white]
    GOLD_ABE [label="GOLD ABCD/ABE Group\n(Symptom + Exacerbation)" fillcolor="#FFC107"]
  }

  // ─────────────────────────────────────────────────────
  // CLUSTER 9: Drug PK — LAMA, LABA, ICS, PDE4i
  // ─────────────────────────────────────────────────────
  subgraph cluster_pk {
    label="Drug Pharmacokinetics (LAMA · LABA · ICS · PDE4i · Others)"
    fontsize=13 fontname="Helvetica-Bold"
    style=filled fillcolor="#FCE4EC" color="#880E4F" penwidth=2

    LAMA_dose [label="LAMA (Inhaler)\nTiotropium HandiHaler 18µg\nUmeclidinium 62.5µg\nGlycopyrrolate 50µg\nAclidinium 400µg" fillcolor="#C2185B" fontcolor=white]
    LAMA_lung [label="LAMA Lung Depot\n(Inhalation efficiency ~20%)" fillcolor="#E91E63" fontcolor=white]
    LAMA_sys  [label="LAMA Systemic\n(F_sys <5%)\nCentral / Peripheral" fillcolor="#F48FB1"]
    LAMA_elim [label="LAMA Elimination\nRenal CL (Tio: CL 235 mL/min)\nt½: 5-6 days (Tio)" fillcolor="#F8BBD0"]

    LABA_dose [label="LABA (Inhaler)\nSalmeterol 50µg bid\nFormoterol 12µg bid\nIndacaterol 150µg qd\nOlodaterol 5µg qd" fillcolor="#AD1457" fontcolor=white]
    LABA_lung [label="LABA Lung Depot\n(Depot kinetics: Sal t½ ~1h)" fillcolor="#E91E63" fontcolor=white]
    LABA_sys  [label="LABA Systemic\nCentral / Peripheral\n(2-compartment)" fillcolor="#F48FB1"]
    LABA_elim [label="LABA Elimination\nCYP3A4 / CYP2D6\n(Inda CL ~23 L/h)" fillcolor="#F8BBD0"]

    ICS_dose  [label="ICS (Inhaler)\nBudesonide 400µg bid\nFluticasone Prop 500µg bid\nFluticasone Fur 100µg qd\nBeclomethasone 400µg" fillcolor="#880E4F" fontcolor=white]
    ICS_lung  [label="ICS Lung Depot\n(Dissolution / Absorption)" fillcolor="#C2185B" fontcolor=white]
    ICS_sys   [label="ICS Systemic\nProtein binding >99%\nCentral / Peripheral" fillcolor="#F48FB1"]
    ICS_GR    [label="GR (Glucocorticoid Rec.)\nNuclear Translocation\nGRE transactivation\nNF-κB / AP-1 transrepression" fillcolor="#EC407A"]
    ICS_elim  [label="ICS Elimination\nCYP3A4 (FP: CL 1.1 L/min)\nt½: BUD 2.8h / FP 7.8h" fillcolor="#F8BBD0"]

    PDE4i_dose [label="Roflumilast 500µg qd\n(Oral PDE4i)\nSevere COPD + Chronic bronchitis" fillcolor="#6A1B9A" fontcolor=white]
    PDE4i_abs  [label="Roflumilast PK\nF=80%, Cmax 7 ng/mL\nActive N-oxide metabolite\nt½: 17h / 30h (N-oxide)" fillcolor="#9C27B0" fontcolor=white]
    PDE4i_sys  [label="PDE4i Systemic\n(CYP3A4/1A2)\nProtein binding 99%" fillcolor="#CE93D8"]

    NAC_dose  [label="N-Acetylcysteine (NAC)\n600mg bid (HIACE trial)" fillcolor="#4527A0" fontcolor=white]
    Azithro   [label="Azithromycin\n250mg/day (Anti-inflam.\n+ Prophylaxis)" fillcolor="#5E35B1" fontcolor=white]

    Triple_comb [label="Triple Therapy\nFF/UMEC/VI (IMPACT)\nBUD/GLYCO/FORM (ETHOS)\nBEC/GLYCO/FORM (KRONOS)" fillcolor="#D81B60" fontcolor=white]
  }

  // ─────────────────────────────────────────────────────
  // CLUSTER 10: Drug PD Mechanisms
  // ─────────────────────────────────────────────────────
  subgraph cluster_pd {
    label="Drug Pharmacodynamics — Receptor Mechanisms & Endpoints"
    fontsize=13 fontname="Helvetica-Bold"
    style=filled fillcolor="#E8F5E9" color="#1B5E20" penwidth=2

    M3R   [label="M3 mAChR\n(ASM / Gland)" fillcolor="#388E3C" fontcolor=white]
    ACh   [label="Acetylcholine\n(Vagal tone)" fillcolor="#43A047" fontcolor=white]
    IP3_ach [label="IP3 / DAG\n(Ca2+ mobilization)" fillcolor="#66BB6A"]
    ROCK_ach [label="RhoA / ROCK\n(MLC phosphorylation)" fillcolor="#81C784"]
    Broncho [label="Bronchoconstriction\n(LAMA reversal)" fillcolor="#4CAF50" fontcolor=white]

    b2AR  [label="β2-Adrenoceptor\n(ASM)" fillcolor="#2E7D32" fontcolor=white]
    cAMP_b2 [label="cAMP↑\n(Gs/AC activation)" fillcolor="#4CAF50" fontcolor=white]
    PKA_b2 [label="PKA activation\n(MLCP activation\nBronchorelaxation)" fillcolor="#81C784"]
    LABA_FEV1 [label="LABA → FEV1↑\n(Bronchodilation\n~120-200 mL)" fillcolor="#A5D6A7"]

    PDE4  [label="PDE4 (Phosphodiesterase 4)\n(cAMP hydrolysis)" fillcolor="#558B2F" fontcolor=white]
    cAMP_PDE4 [label="cAMP↑ (PDE4 inhibited)\n→ PKA → NF-κB↓" fillcolor="#8BC34A"]
    AntiInflam_PDE4 [label="Anti-inflammatory Effect\nNeutrophil↓ IL-8↓\nMMP-9↓" fillcolor="#AED581"]

    ICS_NF [label="ICS → NF-κB↓\nAP-1↓ → IL-6↓ IL-8↓\nMMP↓ (Partial response)" fillcolor="#4CAF50" fontcolor=white]
    ICS_FEV1 [label="ICS → Eosinophil↓\n(If blood Eos ≥300)\nExacerbation↓" fillcolor="#66BB6A"]
    LAMA_FEV1 [label="LAMA → FEV1↑\n(100-150 mL)\nHyperinflation↓" fillcolor="#A5D6A7"]
    Exacerb_drug [label="Triple Therapy\nExacerbation Rate↓\n≥50% (IMPACT/ETHOS)" fillcolor="#388E3C" fontcolor=white]

    NAC_GSH [label="NAC → GSH↑\n(Antioxidant)\nExacerbation↓ 25%" fillcolor="#C8E6C9"]
    Azithro_NF [label="Azithromycin\nNF-κB↓ / Macrolide\nMucociliary↑\nExacerb↓ 17-27%" fillcolor="#C8E6C9"]
  }

  // ─────────────────────────────────────────────────────
  // CLUSTER 11: Exacerbation Pathophysiology
  // ─────────────────────────────────────────────────────
  subgraph cluster_exacerb {
    label="AECOPD Pathophysiology & Biomarkers"
    fontsize=13 fontname="Helvetica-Bold"
    style=filled fillcolor="#FFF8E1" color="#FF6F00" penwidth=2

    Trigger_inf [label="Infection Trigger\n(Virus: 40-50%\nBacteria: 30%\nBoth: 20%)" fillcolor="#F57C00" fontcolor=white]
    RV_inf  [label="Rhinovirus (RV)\nIL-8↑ ICAM-1↑" fillcolor="#FFA726"]
    Flu_inf [label="Influenza A/B\nCytokine storm" fillcolor="#FFA726"]
    RSV_inf [label="RSV / Parainfluenza\nMucus↑" fillcolor="#FFA726"]
    Haemo  [label="H. influenzae\nAdhesin/LPS → TLR4" fillcolor="#FFCA28"]
    Strepto [label="S. pneumoniae\nPneumolysin" fillcolor="#FFCA28"]
    Pseudo  [label="P. aeruginosa\n(Biofilm → Chronic)" fillcolor="#FFCA28"]
    CRP_AE [label="CRP↑↑\nFibrinogen↑" fillcolor="#FFE082"]
    PCT    [label="Procalcitonin (PCT)\n(Bacterial guide)" fillcolor="#FFE082"]
    EosAE  [label="Blood Eosinophils\n(≥300: ICS response\n<100: non-eosinophilic)" fillcolor="#FFE082"]
    SpO2dec [label="SpO2 Deterioration\nAcute Hypoxemia\n→ LTOT / NIV" fillcolor="#FF8F00" fontcolor=white]
    AE_treat [label="AECOPD Treatment\nSABA + SAMA (rescue)\nSystemic CS (5 days)\nAntibiotics (if bacterial)\nNIV / O2 therapy" fillcolor="#F57C00" fontcolor=white]
    PostAE  [label="Post-AECOPD\nIncreased Decline\nFEV1 loss 30mL/yr" fillcolor="#FF6F00" fontcolor=white]
  }

  // ─────────────────────────────────────────────────────
  // CLUSTER 12: Biomarkers
  // ─────────────────────────────────────────────────────
  subgraph cluster_biomarkers {
    label="Biomarkers (Blood · Sputum · Exhaled · Imaging)"
    fontsize=13 fontname="Helvetica-Bold"
    style=filled fillcolor="#E0F7FA" color="#006064" penwidth=2

    BioBlood [label="BLOOD BIOMARKERS\nCRP · Fibrinogen · IL-6 · IL-8\nTNF-α · MMP-9 · NE activity\nBlood Eos · Neutrophil count\nCCL-18 · Club cell protein 16 (CC16)\nSurfactant protein D (SP-D)" fillcolor="#00838F" fontcolor=white]
    BioSput [label="SPUTUM BIOMARKERS\nNeutrophil % · Eosinophil %\nIL-8 · IL-6 · NE · MMP-9\nMUC5AC · Mucin concentration" fillcolor="#00838F" fontcolor=white]
    BioExh  [label="EXHALED BIOMARKERS\neNO (ppb) · FeNO\nExhaled CO · H2O2\nBreath condensate: 8-isoprostane\npH · Leukotrienes" fillcolor="#26C6DA"]
    BioImag [label="IMAGING BIOMARKERS\nHRCT: LAA-950 (emphysema)\nHRCT: Pi10 / %WA (airway)\nMRI ventilation defects\nNuclear scintigraphy (V/Q)\nLung US (B-lines)" fillcolor="#26C6DA"]
    BioFunc [label="FUNCTIONAL BIOMARKERS\nOscillometry: R5-R20\nImpulse oscillometry\nBody plethysmography\nDiffusion (DLCO/VA)\nSwing test / FOT" fillcolor="#4DD0E1"]
  }

  // ─────────────────────────────────────────────────────
  // EDGES — Environmental → Epithelial/Oxidative
  // ─────────────────────────────────────────────────────
  CS -> ROS [label="→ Free radicals" color="#E65100"]
  CS -> Acr [color="#E65100"]
  CS -> PAH [color="#E65100"]
  AP -> ROS [color="#E65100"]
  Bio -> ROS [color="#E65100"]
  ROS -> OxStress [color="#FF5722" penwidth=2]
  RNS -> OxStress [color="#FF5722"]
  Acr -> OxStress [color="#FF5722"]
  OxStress -> SIRT1 [label="↓ HDAC2" color="#FF5722"]
  OxStress -> NRF2 [label="Keap1 oxidation" color="#FF5722"]
  NRF2 -> HO1 [color="#FFB300"]
  NRF2 -> GSH [color="#FFB300"]

