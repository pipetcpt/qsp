digraph KawasakiDisease_QSP {
    graph [
        label="Kawasaki Disease — Quantitative Systems Pharmacology Model\nInfectious Trigger → Innate/Adaptive Immunity → Cytokine Storm → Coronary Artery Lesions",
        labelloc=t,
        fontsize=20,
        fontname="Helvetica-Bold",
        rankdir=TB,
        splines=ortho,
        nodesep=0.4,
        ranksep=0.6,
        bgcolor="#F8F9FA",
        pad=0.5
    ]
    node [fontname="Helvetica", fontsize=10, style="filled,rounded", shape=box, margin="0.12,0.06"]
    edge [fontname="Helvetica", fontsize=9, arrowsize=0.8]

    // ============================================================
    // CLUSTER 1: Infectious/Environmental Trigger
    // ============================================================
    subgraph cluster_trigger {
        label="Infectious & Environmental Triggers"
        style=filled; fillcolor="#FFF3E0"; color="#E65100"; penwidth=2;
        fontname="Helvetica-Bold"; fontsize=13;

        infect_trigger [label="Infectious Trigger\n(Unknown Pathogen)", fillcolor="#FF8A65", fontcolor=white, shape=ellipse]
        rna_virus [label="RNA Virus\n(Coronavirus, RSV)", fillcolor="#FFAB91"]
        dna_virus [label="DNA Virus\n(EBV, Adenovirus)", fillcolor="#FFAB91"]
        bacteria [label="Bacterial Pathogens\n(Staph, Strep)", fillcolor="#FFAB91"]
        superantigen [label="Superantigens\n(TSST-1, SpeA)", fillcolor="#FF7043"]
        toxin [label="Bacterial Toxins\n(LPS, Peptidoglycan)", fillcolor="#FF7043"]
        environ_trigger [label="Environmental Factor\n(Windborne Antigen?)", fillcolor="#FFCC80"]
        genetic_suscept [label="Genetic Susceptibility\n(ITPKC, CASP3, HLA-B15)", fillcolor="#FFA726"]
        host_immune [label="Host Immune State\n(Age < 5yr peak)", fillcolor="#FFB74D"]

        rna_virus -> infect_trigger
        dna_virus -> infect_trigger
        bacteria -> infect_trigger
        environ_trigger -> infect_trigger
        genetic_suscept -> host_immune
        infect_trigger -> superantigen
        infect_trigger -> toxin
    }

    // ============================================================
    // CLUSTER 2: Innate Immune Response
    // ============================================================
    subgraph cluster_innate {
        label="Innate Immune Activation"
        style=filled; fillcolor="#E3F2FD"; color="#0D47A1"; penwidth=2;
        fontname="Helvetica-Bold"; fontsize=13;

        PRR_TLR [label="TLR2/TLR4\nPattern Recognition", fillcolor="#64B5F6"]
        PRR_NLR [label="NLR / NOD2\nCytosolic Sensors", fillcolor="#64B5F6"]
        macrophage [label="Macrophage/Monocyte\n(Tissue + Peripheral)", fillcolor="#1565C0", fontcolor=white]
        mac_activation [label="M1 Macrophage\nActivation", fillcolor="#1976D2", fontcolor=white]
        dendritic_cell [label="Plasmacytoid\nDendritic Cell", fillcolor="#42A5F5"]
        neutrophil [label="Neutrophil\n(PMN Activation)", fillcolor="#29B6F6"]
        NET_formation [label="NET Formation\n(NETosis)", fillcolor="#0288D1", fontcolor=white]
        mast_cell [label="Mast Cell\nDegranulation", fillcolor="#4FC3F7"]
        NK_cell [label="Natural Killer Cell\n(NK Activation)", fillcolor="#81D4FA"]
        complement [label="Complement\nActivation (C3, C5)", fillcolor="#B3E5FC"]
        MAC [label="Membrane Attack\nComplex (C5b-9)", fillcolor="#29B6F6"]
        M_CSF [label="M-CSF / GM-CSF\nMacrophage Growth", fillcolor="#90CAF9"]

        PRR_TLR -> macrophage
        PRR_NLR -> macrophage
        PRR_TLR -> neutrophil
        macrophage -> mac_activation
        mac_activation -> dendritic_cell
        neutrophil -> NET_formation
        complement -> MAC
        M_CSF -> macrophage
    }

    // ============================================================
    // CLUSTER 3: NLRP3 Inflammasome
    // ============================================================
    subgraph cluster_nlrp3 {
        label="NLRP3 Inflammasome Pathway"
        style=filled; fillcolor="#FCE4EC"; color="#880E4F"; penwidth=2;
        fontname="Helvetica-Bold"; fontsize=13;

        NLRP3 [label="NLRP3 Sensor\nActivation", fillcolor="#E91E63", fontcolor=white, shape=hexagon]
        ASC [label="ASC Adaptor\nProtein", fillcolor="#F06292"]
        caspase_1 [label="Pro-Caspase-1\n→ Active Caspase-1", fillcolor="#C2185B", fontcolor=white]
        pro_IL1b [label="Pro-IL-1β\n(Inactive)", fillcolor="#F8BBD9"]
        IL1b_mature [label="Mature IL-1β\n(Active, 17kDa)", fillcolor="#AD1457", fontcolor=white]
        pro_IL18 [label="Pro-IL-18\n→ IL-18", fillcolor="#FCE4EC"]
        pyroptosis [label="Pyroptosis\nCell Death", fillcolor="#880E4F", fontcolor=white]
        GSDMD [label="Gasdermin D\nPore Formation", fillcolor="#E91E63", fontcolor=white]

        NLRP3 -> ASC
        ASC -> caspase_1
        caspase_1 -> pro_IL1b [label="Cleavage"]
        pro_IL1b -> IL1b_mature
        caspase_1 -> pro_IL18
        caspase_1 -> GSDMD
        GSDMD -> pyroptosis
    }

    // ============================================================
    // CLUSTER 4: Cytokine Network
    // ============================================================
    subgraph cluster_cytokines {
        label="Cytokine Signaling Network"
        style=filled; fillcolor="#E8F5E9"; color="#1B5E20"; penwidth=2;
        fontname="Helvetica-Bold"; fontsize=13;

        IL1b_sig [label="IL-1β\nSignaling", fillcolor="#2E7D32", fontcolor=white]
        IL1R [label="IL-1 Receptor\n(IL-1R1/IL-1RAcP)", fillcolor="#66BB6A"]
        IL6 [label="IL-6\n(Central Mediator)", fillcolor="#1B5E20", fontcolor=white, shape=ellipse]
        IL6R [label="IL-6 Receptor\n(sIL-6R / mIL-6R)", fillcolor="#388E3C", fontcolor=white]
        gp130 [label="gp130 Signal\nTransducer", fillcolor="#43A047"]
        JAK_STAT3 [label="JAK1/2 → STAT3\nPhosphorylation", fillcolor="#4CAF50"]
        TNFa [label="TNF-α\n(Key Vasculitis Driver)", fillcolor="#B71C1C", fontcolor=white, shape=ellipse]
        TNFR1 [label="TNF Receptor 1\n(TNFR1/p55)", fillcolor="#E53935", fontcolor=white]
        IL8_CXCL8 [label="IL-8/CXCL8\nNeutrophil Chemotaxis", fillcolor="#81C784"]
        IL18 [label="IL-18\nIFN-γ Inducer", fillcolor="#A5D6A7"]
        IFNg [label="IFN-γ\nMacrophage Activator", fillcolor="#C8E6C9"]
        MCP1_CCL2 [label="MCP-1/CCL2\nMonocyte Chemotaxis", fillcolor="#A5D6A7"]
        IL10 [label="IL-10\nAnti-inflammatory", fillcolor="#DCEDC8"]
        IL12 [label="IL-12\nTh1 Polarization", fillcolor="#C5E1A5"]
        IL17 [label="IL-17\nNeutrophil Recruiter", fillcolor="#AED581"]
        VEGF [label="VEGF\nVascular Permeability", fillcolor="#8BC34A"]
        MMP9 [label="MMP-9\nECM Degradation", fillcolor="#558B2F", fontcolor=white]
        NF_kB [label="NF-κB\nTranscription Factor", fillcolor="#1B5E20", fontcolor=white, shape=diamond]

        IL1b_sig -> IL1R
        IL1R -> NF_kB
        NF_kB -> IL6
        NF_kB -> TNFa
        NF_kB -> IL8_CXCL8
        NF_kB -> MMP9
        IL6 -> IL6R
        IL6R -> gp130
        gp130 -> JAK_STAT3
        TNFa -> TNFR1
        TNFR1 -> NF_kB
        IL18 -> IFNg
        IL12 -> IFNg
    }

    // ============================================================
    // CLUSTER 5: Adaptive Immunity
    // ============================================================
    subgraph cluster_adaptive {
        label="Adaptive Immune Response"
        style=filled; fillcolor="#EDE7F6"; color="#4527A0"; penwidth=2;
        fontname="Helvetica-Bold"; fontsize=13;

        T_naive [label="Naïve T Cell\n(CD4+ / CD8+)", fillcolor="#9575CD"]
        Th1 [label="Th1 Cell\n(IFN-γ, IL-2)", fillcolor="#7E57C2", fontcolor=white]
        Th17 [label="Th17 Cell\n(IL-17, IL-22)", fillcolor="#673AB7", fontcolor=white]
        Treg [label="Regulatory T Cell\n(FoxP3+, IL-10)", fillcolor="#B39DDB"]
        CD8_T [label="Cytotoxic CD8+ T\n(Perforin, Granzyme)", fillcolor="#7986CB"]
        B_cell [label="B Cell\nActivation", fillcolor="#9C27B0", fontcolor=white]
        plasmablast [label="Plasmablast\n(Rapid Ab Producer)", fillcolor="#8E24AA", fontcolor=white]
        Ab_IgG [label="IgG Antibodies\n(Anti-endothelial)", fillcolor="#BA68C8"]
        Ab_IgA [label="IgA Antibodies\n(Mucosal)", fillcolor="#CE93D8"]
        FCR [label="Fc Receptor\n(FcγRIIa on Mac)", fillcolor="#AB47BC"]
        MHC_II [label="MHC Class II\nAntigen Presentation", fillcolor="#D1C4E9"]

        T_naive -> Th1
        T_naive -> Th17
        Th17 -> Treg [label="Suppress", style=dashed, color=gray]
        B_cell -> plasmablast
        plasmablast -> Ab_IgG
        plasmablast -> Ab_IgA
        Ab_IgG -> FCR
        dendritic_cell -> MHC_II [ltail=cluster_innate]
        MHC_II -> T_naive
    }

    // ============================================================
    // CLUSTER 6: Endothelial Activation
    // ============================================================
    subgraph cluster_endothelium {
        label="Endothelial Cell Activation & Dysfunction"
        style=filled; fillcolor="#FFFDE7"; color="#F57F17"; penwidth=2;
        fontname="Helvetica-Bold"; fontsize=13;

        EC_quiescent [label="Quiescent\nEndothelial Cell", fillcolor="#FFF176"]
        EC_activated [label="Activated\nEndothelial Cell", fillcolor="#FF8F00", fontcolor=white]
        VCAM1 [label="VCAM-1\nLeukocyte Adhesion", fillcolor="#FFA000", fontcolor=white]
        ICAM1 [label="ICAM-1\nLeukocyte Transmigration", fillcolor="#FFB300"]
        E_selectin [label="E-selectin\nLeukocyte Rolling", fillcolor="#FFC107"]
        tissue_factor [label="Tissue Factor\n(TF/F3)", fillcolor="#FF6F00", fontcolor=white]
        eNOS_NO [label="eNOS → Nitric Oxide\n(Vasodilation)", fillcolor="#FFEE58"]
        PGI2 [label="Prostacyclin (PGI2)\nAnti-platelet", fillcolor="#FFF59D"]
        ET1 [label="Endothelin-1\n(Vasoconstriction)", fillcolor="#FFE082"]
        EC_apoptosis [label="Endothelial\nApoptosis", fillcolor="#E65100", fontcolor=white]
        permeability [label="Vascular\nPermeability ↑", fillcolor="#FF8F00", fontcolor=white]
        SMC_media [label="Vascular SMC\n(Medial Layer)", fillcolor="#FFD54F"]
        EC_NLRP3 [label="NLRP3 in EC\n(Endothelial Inflammasome)", fillcolor="#FFA726"]
        leukocyte_infiltr [label="Leukocyte\nInfiltration", fillcolor="#FFB74D"]

        EC_quiescent -> EC_activated [label="Cytokine\nactivation"]
        EC_activated -> VCAM1
        EC_activated -> ICAM1
        EC_activated -> E_selectin
        EC_activated -> tissue_factor
        EC_activated -> EC_apoptosis
        EC_activated -> permeability
        EC_activated -> EC_NLRP3
        VCAM1 -> leukocyte_infiltr
        ICAM1 -> leukocyte_infiltr
        leukocyte_infiltr -> SMC_media [label="Medial\ndestruction"]
    }

    // ============================================================
    // CLUSTER 7: Coronary Artery Pathology
    // ============================================================
    subgraph cluster_coronary {
        label="Coronary Artery Pathology"
        style=filled; fillcolor="#FFEBEE"; color="#B71C1C"; penwidth=2.5;
        fontname="Helvetica-Bold"; fontsize=13;

        CA_inflammation [label="Coronary Artery\nInflammation", fillcolor="#EF9A9A"]
        medial_destruction [label="Medial Layer\nDestruction", fillcolor="#EF5350"]
        IEL_disruption [label="Internal Elastic Lamina\nDisruption", fillcolor="#E53935"]
        aneurysm_form [label="Coronary Artery\nAneurysm Formation", fillcolor="#C62828", fontcolor=white, shape=hexagon]
        CAL_small [label="Small CAA\n(z ≥ 2.5 to < 5)", fillcolor="#EF9A9A"]
        CAL_medium [label="Medium CAA\n(z = 5–10)", fillcolor="#EF5350", fontcolor=white]
        CAL_giant [label="Giant CAA\n(z ≥ 10)", fillcolor="#B71C1C", fontcolor=white, shape=hexagon]
        CA_thrombosis [label="Coronary\nThrombosis", fillcolor="#D32F2F", fontcolor=white]
        MI [label="Myocardial\nInfarction", fillcolor="#B71C1C", fontcolor=white, shape=doubleoctagon]
        CA_stenosis [label="Coronary\nStenosis", fillcolor="#C62828", fontcolor=white]
        CA_remodeling [label="Coronary\nRemodeling (Repair)", fillcolor="#FFCDD2"]
        pericarditis [label="Pericarditis\nMyocarditis", fillcolor="#FFCDD2"]
        aorta_root [label="Aortic Root\nDilation", fillcolor="#EF9A9A"]

        CA_inflammation -> medial_destruction
        medial_destruction -> IEL_disruption
        IEL_disruption -> aneurysm_form
        aneurysm_form -> CAL_small
        CAL_small -> CAL_medium
        CAL_medium -> CAL_giant
        aneurysm_form -> CA_thrombosis
        CA_thrombosis -> MI
        CA_remodeling -> CA_stenosis
        aneurysm_form -> CA_remodeling [label="Months–years", style=dashed]
        CA_inflammation -> pericarditis
        CA_inflammation -> aorta_root
    }

    // ============================================================
    // CLUSTER 8: Platelet Biology
    // ============================================================
    subgraph cluster_platelets {
        label="Platelet Activation & Thrombosis"
        style=filled; fillcolor="#F3E5F5"; color="#6A1B9A"; penwidth=2;
        fontname="Helvetica-Bold"; fontsize=13;

        PLT_resting [label="Resting\nPlatelet", fillcolor="#CE93D8"]
        PLT_activated [label="Activated\nPlatelet", fillcolor="#8E24AA", fontcolor=white]
        TXA2 [label="Thromboxane A2\n(TXA2)", fillcolor="#6A1B9A", fontcolor=white]
        COX1_PLT [label="COX-1\n(Platelet TXA2 synthesis)", fillcolor="#AB47BC"]
        ADP_receptor [label="ADP / P2Y12\nReceptor", fillcolor="#BA68C8"]
        GP_IIbIIIa [label="GPIIb/IIIa\nFibrinogen Receptor", fillcolor="#9C27B0", fontcolor=white]
        thrombus [label="Platelet\nThrombus", fillcolor="#6A1B9A", fontcolor=white, shape=hexagon]
        PLT_count [label="Thrombocytosis\n(PLT > 500k) Week 2–3", fillcolor="#D1C4E9"]
        vWF_high [label="von Willebrand Factor\n(vWF Elevated)", fillcolor="#E1BEE7"]
        PLT_aggreg [label="Platelet\nAggregation", fillcolor="#9575CD", fontcolor=white]

        PLT_resting -> PLT_activated [label="Activation"]
        PLT_activated -> COX1_PLT
        COX1_PLT -> TXA2
        TXA2 -> PLT_aggreg
        ADP_receptor -> PLT_aggreg
        PLT_aggreg -> GP_IIbIIIa
        GP_IIbIIIa -> thrombus
        vWF_high -> PLT_aggreg
        PLT_count -> PLT_aggreg [label="Week 2–3 peak"]
    }

    // ============================================================
    // CLUSTER 9: Fever & Acute Phase Response
    // ============================================================
    subgraph cluster_fever {
        label="Fever & Systemic Acute Phase Response"
        style=filled; fillcolor="#E0F7FA"; color="#006064"; penwidth=2;
        fontname="Helvetica-Bold"; fontsize=13;

        fever_center [label="Hypothalamic\nFever Center (POA)", fillcolor="#00BCD4", fontcolor=white]
        PGE2_brain [label="Prostaglandin E2\n(PGE2)", fillcolor="#4DD0E1"]
        COX2_brain [label="COX-2\n(Vascular Endothelium)", fillcolor="#26C6DA"]
        body_temp [label="Body Temperature\n(Fever ≥ 38.5°C × 5days)", fillcolor="#00838F", fontcolor=white, shape=ellipse]
        CRP [label="C-Reactive Protein\n(CRP > 30 mg/L)", fillcolor="#006064", fontcolor=white]
        ESR [label="Erythrocyte\nSedimentation Rate ↑", fillcolor="#0097A7", fontcolor=white]
        ferritin [label="Serum Ferritin\n(Inflammation Marker)", fillcolor="#00ACC1"]
        procalcitonin [label="Procalcitonin\n(PCT)", fillcolor="#4DB6AC"]
        albumin [label="Serum Albumin\n(Negative APP ↓)", fillcolor="#80CBC4"]
        ALP [label="Alkaline Phosphatase\n(ALP Elevated)", fillcolor="#B2EBF2"]
        acute_liver [label="Liver Acute Phase\nResponse", fillcolor="#00BCD4", fontcolor=white]
        WBC_count [label="WBC Count\n(Neutrophilia)", fillcolor="#80DEEA"]
        Na_hypo [label="Hyponatremia\n(Na < 135)", fillcolor="#B2EBF2"]
        lymphocyte [label="Lymphocyte\nCount (Relative Lymphopenia)", fillcolor="#AFEEEE"]

        IL6 -> acute_liver [ltail=cluster_cytokines]
        acute_liver -> CRP
        acute_liver -> ESR
        acute_liver -> ferritin
        acute_liver -> albumin [label="Negative APP", style=dashed]
        COX2_brain -> PGE2_brain
        PGE2_brain -> fever_center
        fever_center -> body_temp
    }

    // ============================================================
    // CLUSTER 10: IVIG PK
    // ============================================================
    subgraph cluster_pk_ivig {
        label="IVIG Pharmacokinetics"
        style=filled; fillcolor="#E8EAF6"; color="#283593"; penwidth=2;
        fontname="Helvetica-Bold"; fontsize=13;

        IVIG_dose [label="IVIG\n2 g/kg IV (10–12h)", fillcolor="#3F51B5", fontcolor=white, shape=parallelogram]
        IVIG_central [label="IVIG Central\nCompartment (Vc)", fillcolor="#5C6BC0", fontcolor=white]
        IVIG_periph [label="IVIG Peripheral\nCompartment (Vp)", fillcolor="#7986CB"]
        IVIG_FcRn [label="FcRn-mediated\nIgG Recycling", fillcolor="#9FA8DA"]
        IVIG_CL [label="IVIG Clearance\n(t½ = 21–28 days)", fillcolor="#C5CAE9"]
        IVIG_Cmax [label="IVIG Cmax\n~25 g/L (IgG)", fillcolor="#E8EAF6"]

        IVIG_dose -> IVIG_central
        IVIG_central -> IVIG_periph [label="kcp", dir=both]
        IVIG_central -> IVIG_FcRn
        IVIG_FcRn -> IVIG_central [label="Recycle"]
        IVIG_central -> IVIG_CL [label="Elimination"]
        IVIG_central -> IVIG_Cmax
    }

    // ============================================================
    // CLUSTER 11: Aspirin PK
    // ============================================================
    subgraph cluster_pk_aspirin {
        label="Aspirin Pharmacokinetics"
        style=filled; fillcolor="#FFF8E1"; color="#F57F17"; penwidth=2;
        fontname="Helvetica-Bold"; fontsize=13;

        ASA_hi_dose [label="High-dose Aspirin\n80–100 mg/kg/day (Anti-inflam)", fillcolor="#FFA000", fontcolor=white, shape=parallelogram]
        ASA_lo_dose [label="Low-dose Aspirin\n3–5 mg/kg/day (Anti-platelet)", fillcolor="#FFB300", shape=parallelogram]
        ASA_abs [label="Aspirin\nAbsorption (GI)", fillcolor="#FFC107"]
        ASA_plasma [label="Aspirin Plasma\nConcentration", fillcolor="#FFD54F"]
        SA_conc [label="Salicylate\nConcentration", fillcolor="#FFECB3"]
        ASA_deacetyl [label="ASA De-acetylation\n→ Salicylate", fillcolor="#FFE082"]
        ASA_CL [label="Aspirin/Salicylate\nClearance (Hepatic)", fillcolor="#FFF8E1"]

        ASA_hi_dose -> ASA_abs
        ASA_lo_dose -> ASA_abs
        ASA_abs -> ASA_plasma
        ASA_plasma -> ASA_deacetyl
        ASA_deacetyl -> SA_conc
        SA_conc -> ASA_CL
    }

    // ============================================================
    // CLUSTER 12: Corticosteroid PK
    // ============================================================
    subgraph cluster_pk_steroids {
        label="Corticosteroid Pharmacokinetics"
        style=filled; fillcolor="#E8F5E9"; color="#1B5E20"; penwidth=2;
        fontname="Helvetica-Bold"; fontsize=13;

        MP_IV_dose [label="IV Methylprednisolone\n2 mg/kg/day (KD adjunct)", fillcolor="#2E7D32", fontcolor=white, shape=parallelogram]
        PSL_oral_dose [label="Oral Prednisolone\n2 mg/kg/day", fillcolor="#388E3C", fontcolor=white, shape=parallelogram]
        MP_central [label="Methylprednisolone\nCentral (Vc)", fillcolor="#43A047", fontcolor=white]
        MP_periph [label="Methylprednisolone\nPeripheral (Vp)", fillcolor="#66BB6A"]
        MP_GR [label="Glucocorticoid\nReceptor (GR-α)", fillcolor="#81C784"]
        MP_transactivate [label="GRE Transactivation\n(Anti-inflam genes)", fillcolor="#A5D6A7"]
        MP_transrepress [label="NF-κB / AP-1\nRepression", fillcolor="#C8E6C9"]
        MP_CL [label="Methylprednisolone\nClearance (t½ ~2–3h)", fillcolor="#DCEDC8"]

        MP_IV_dose -> MP_central
        PSL_oral_dose -> MP_central [label="Oral bioavail."]
        MP_central -> MP_periph [dir=both]
        MP_central -> MP_GR
        MP_GR -> MP_transactivate
        MP_GR -> MP_transrepress
        MP_central -> MP_CL
    }

    // ============================================================
    // CLUSTER 13: Biologic Drug PK
    // ============================================================
    subgraph cluster_pk_biologics {
        label="Biologic Drug Pharmacokinetics"
        style=filled; fillcolor="#F3E5F5"; color="#4A148C"; penwidth=2;
        fontname="Helvetica-Bold"; fontsize=13;

        IFX_dose [label="Infliximab\n5 mg/kg IV (IVIG-resistant)", fillcolor="#6A1B9A", fontcolor=white, shape=parallelogram]
        IFX_central [label="Infliximab\nCentral (Vc)", fillcolor="#8E24AA", fontcolor=white]
        IFX_periph [label="Infliximab\nPeripheral (Vp)", fillcolor="#AB47BC"]
        IFX_TNF [label="Infliximab–TNF-α\nComplex", fillcolor="#CE93D8"]
        IFX_CL [label="Infliximab\nClearance (t½ ~8–10d)", fillcolor="#E1BEE7"]
        ANK_dose [label="Anakinra\n4 mg/kg/day SC (IL-1 blocker)", fillcolor="#4527A0", fontcolor=white, shape=parallelogram]
        ANK_central [label="Anakinra\nPlasma Conc", fillcolor="#5E35B1", fontcolor=white]
        ANK_IL1R [label="Anakinra–IL-1R\nBinding (Competitive)", fillcolor="#7B1FA2", fontcolor=white]
        ANK_CL [label="Anakinra\nClearance (t½ ~4–6h)", fillcolor="#9C27B0", fontcolor=white]
        CsA_dose [label="Cyclosporine A\n5 mg/kg/day (Refractory)", fillcolor="#7B1FA2", fontcolor=white, shape=parallelogram]
        CsA_central [label="Cyclosporine\nBlood Conc (Whole Blood)", fillcolor="#880E4F", fontcolor=white]
        CsA_calcineurin [label="Calcineurin\nInhibition → ↓IL-2", fillcolor="#AD1457", fontcolor=white]

        IFX_dose -> IFX_central
        IFX_central -> IFX_periph [dir=both]
        IFX_central -> IFX_TNF [label="TNF binding"]
        IFX_central -> IFX_CL
        ANK_dose -> ANK_central
        ANK_central -> ANK_IL1R
        ANK_central -> ANK_CL
        CsA_dose -> CsA_central
        CsA_central -> CsA_calcineurin
    }

    // ============================================================
    // CLUSTER 14: Clinical Endpoints
    // ============================================================
    subgraph cluster_clinical {
        label="Clinical Endpoints & Outcomes"
        style=filled; fillcolor="#FAFAFA"; color="#212121"; penwidth=2.5;
        fontname="Helvetica-Bold"; fontsize=13;

        fever_days [label="Fever Duration\n(Days of Fever)", fillcolor="#616161", fontcolor=white, shape=ellipse]
        Kobayashi_score [label="Kobayashi Risk Score\n(Predicts IVIG resistance)", fillcolor="#424242", fontcolor=white]
        Egami_score [label="Egami Score\n(Japanese prediction)", fillcolor="#757575", fontcolor=white]
        CAL_zscore [label="Coronary Artery\nZ-score (Echo, Day7–14)", fillcolor="#B71C1C", fontcolor=white, shape=ellipse]
        echo_assess [label="Echocardiographic\nAssessment (Serial)", fillcolor="#37474F", fontcolor=white]
        IVIG_resist [label="IVIG Resistance\n(~10–20% of cases)", fillcolor="#F44336", fontcolor=white, shape=diamond]
        KD_recurrence [label="KD Recurrence\n(~3% risk)", fillcolor="#9E9E9E"]
        MAS [label="Macrophage Activation\nSyndrome (Rare)", fillcolor="#D32F2F", fontcolor=white]
        acute_outcome [label="Acute Outcome\n(Fever resolution <48h)", fillcolor="#4CAF50", fontcolor=white, shape=ellipse]
        long_cv [label="Long-term CV Outcome\n(Ischemic heart disease risk)", fillcolor="#E91E63", fontcolor=white, shape=ellipse]
        aneurysm_regress [label="Aneurysm\nRegression (50% small/med)", fillcolor="#8BC34A"]
        HPS [label="Hemophagocytic\nSyndrome (HPS)", fillcolor="#FF5722", fontcolor=white]
        IVIG_infusion_rx [label="IVIG Infusion Reaction\n(< 5% cases)", fillcolor="#FF9800"]
        aspirin_tinnitus [label="Aspirin Toxicity\n(Tinnitus, Reye)", fillcolor="#FFC107"]

        body_temp -> fever_days [ltail=cluster_fever]
        Kobayashi_score -> IVIG_resist
        Egami_score -> IVIG_resist
        CAL_zscore -> echo_assess
        echo_assess -> CAL_zscore [dir=back, style=dashed, label="Monitoring"]
        IVIG_resist -> MAS [style=dashed, label="Rare complication"]
        aneurysm_form -> CAL_zscore [ltail=cluster_coronary]
        MI -> long_cv [ltail=cluster_coronary]
        CAL_giant -> long_cv [ltail=cluster_coronary]
        aneurysm_form -> aneurysm_regress [ltail=cluster_coronary, style=dashed]
        mac_activation -> MAS [ltail=cluster_innate, style=dashed]
        MAS -> HPS
    }

    // ============================================================
    // CROSS-CLUSTER EDGES — Drug Pharmacodynamic Effects
    // ============================================================

    // Trigger -> Innate
    superantigen -> PRR_TLR [lhead=cluster_innate]
    toxin -> PRR_TLR
    host_immune -> mac_activation [lhead=cluster_innate]

    // Innate -> NLRP3
    neutrophil -> NLRP3 [label="NET-triggered", lhead=cluster_nlrp3]
    mac_activation -> NLRP3 [label="Priming signal"]

    // NLRP3 -> Cytokines
    IL1b_mature -> IL1b_sig [lhead=cluster_cytokines]

    // Innate -> Cytokines
    mac_activation -> NF_kB [label="Pro-inflam\npathway"]
    mac_activation -> IL6 [lhead=cluster_cytokines]

    // Cytokines -> Endothelium
    TNFa -> EC_activated [lhead=cluster_endothelium, label="EC activation"]
    IL1b_sig -> EC_activated [lhead=cluster_endothelium]
    IL6 -> EC_activated

    // Cytokines -> Fever
    IL1b_sig -> COX2_brain [lhead=cluster_fever]
    TNFa -> COX2_brain
    IL6 -> acute_liver

    // Cytokines -> Coronary
    TNFa -> CA_inflammation [lhead=cluster_coronary, label="Key driver", style=bold, color="#B71C1C"]
    IL1b_sig -> CA_inflammation [lhead=cluster_coronary, color="#E91E63"]
    MMP9 -> medial_destruction [lhead=cluster_coronary]

    // Cytokines -> Platelets
    IL6 -> PLT_count [lhead=cluster_platelets, label="Thrombopoiesis"]
    TNFa -> PLT_activated [lhead=cluster_platelets]

    // Endothelium -> Coronary
    leukocyte_infiltr -> CA_inflammation [lhead=cluster_coronary]
    EC_apoptosis -> CA_inflammation [lhead=cluster_coronary]
    tissue_factor -> CA_thrombosis [lhead=cluster_coronary, label="Coagulation"]

    // Platelet -> Coronary
    thrombus -> CA_thrombosis [lhead=cluster_coronary]
    PGI2 -> PLT_resting [lhead=cluster_platelets, label="Inhibit\nactivation", style=dashed, color=green]

    // IVIG PD effects
    IVIG_central -> NF_kB [lhead=cluster_cytokines, label="↓ NF-κB\n(Fc block)", style=dashed, color="#1565C0"]
    IVIG_central -> FCR [lhead=cluster_adaptive, label="FcγR block", style=dashed, color="#1565C0"]
    IVIG_central -> MAC [lhead=cluster_innate, label="↓ Complement", style=dashed, color="#1565C0"]
    IVIG_central -> Treg [lhead=cluster_adaptive, label="Expand Treg", style=dashed, color="#1565C0"]
    IVIG_central -> acute_outcome [lhead=cluster_clinical, label="Fever\nresolution", style=bold, color="#1565C0"]

    // Aspirin PD effects (COX inhibition)
    ASA_plasma -> COX1_PLT [lhead=cluster_platelets, label="COX-1\nirreverisble\ninhibition", style=dashed, color="#FFA000"]
    ASA_plasma -> COX2_brain [lhead=cluster_fever, label="COX-2\ninhibition\n(anti-pyretic)", style=dashed, color="#FFA000"]
    SA_conc -> NF_kB [lhead=cluster_cytokines, label="↓ NF-κB\n(high dose)", style=dashed, color="#FFA000"]

    // Methylprednisolone PD effects
    MP_transrepress -> NF_kB [lhead=cluster_cytokines, label="Repression", style=dashed, color="#2E7D32"]
    MP_transrepress -> IL6 [lhead=cluster_cytokines, style=dashed, color="#2E7D32"]
    MP_transrepress -> IL1b_sig [lhead=cluster_cytokines, style=dashed, color="#2E7D32"]
    MP_transrepress -> CA_inflammation [lhead=cluster_coronary, style=dashed, color="#2E7D32"]

    // Infliximab PD effects
    IFX_TNF -> TNFa [lhead=cluster_cytokines, label="TNF-α\nneutralization", style=dashed, color="#8E24AA"]
    IFX_TNF -> TNFR1 [lhead=cluster_cytokines, label="TNFR block", style=dashed, color="#8E24AA"]

    // Anakinra PD effects
    ANK_IL1R -> IL1R [lhead=cluster_cytokines, label="IL-1R\ncompetitive block", style=dashed, color="#4527A0"]

    // Cyclosporine PD effects
    CsA_calcineurin -> Th17 [lhead=cluster_adaptive, label="↓ IL-2/IL-17", style=dashed, color="#880E4F"]
    CsA_calcineurin -> NF_kB [lhead=cluster_cytokines, label="↓ Cytokine\nproduction", style=dashed, color="#880E4F"]

    // Clinical score inputs
    ASA_plasma -> aspirin_tinnitus [lhead=cluster_clinical, style=dashed]
    IVIG_central -> IVIG_infusion_rx [lhead=cluster_clinical, style=dashed]

    // Legend (invisible node for spacing)
    legend [label="Legend:\n→  Activation\n--→  Inhibition (drug)\n═══  Key pathway\n⬡  Critical endpoint",
            shape=note, fillcolor="#F5F5F5", fontsize=10, pos="0,0!"]
}
