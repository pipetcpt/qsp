digraph APS_QSP_Model {
    graph [
        label="Antiphospholipid Syndrome (APS) — Comprehensive QSP Mechanistic Map\nAutoimmune Thrombosis · Obstetric Complications · Drug PK/PD",
        labelloc=t, fontsize=22, fontname="Helvetica-Bold",
        rankdir=TB, splines=polyline, nodesep=0.35, ranksep=0.55,
        bgcolor="#F8F9FA", pad=0.5
    ]
    node [shape=box, style="filled,rounded", fontname="Helvetica", fontsize=9, margin="0.08,0.04"]
    edge [fontname="Helvetica", fontsize=7.5, arrowsize=0.7]

    /* =====================================================================
       CLUSTER 1 — GENETIC RISK FACTORS
    ===================================================================== */
    subgraph cluster_genetics {
        label="Genetic Risk Factors"; style=filled; fillcolor="#FFF3E0";
        color="#E65100"; fontsize=11; fontname="Helvetica-Bold";

        HLA_DRw53   [label="HLA-DRw53\n(major susceptibility)", fillcolor="#FFCCBC"]
        HLA_DR4     [label="HLA-DR4", fillcolor="#FFCCBC"]
        IL10_poly   [label="IL-10 promoter\npolymorphism (−1082A/G)", fillcolor="#FFCCBC"]
        FVL         [label="Factor V Leiden\n(FVL; R506Q)", fillcolor="#FF8A65"]
        MTHFR       [label="MTHFR C677T\n(hyperhomocysteinemia)", fillcolor="#FFCCBC"]
        PTPN22      [label="PTPN22 R620W\n(lymphocyte phosphatase)", fillcolor="#FFCCBC"]
        STAT4       [label="STAT4 rs7574865\n(IFN signaling)", fillcolor="#FFCCBC"]
        C4_null     [label="C4A null allele\n(complement deficiency)", fillcolor="#FFCCBC"]
        FXII_def    [label="Factor XII deficiency\n(contact activation↓→LA)", fillcolor="#FF8A65"]
    }

    /* =====================================================================
       CLUSTER 2 — ENVIRONMENTAL TRIGGERS & ANTIGEN PRESENTATION
    ===================================================================== */
    subgraph cluster_triggers {
        label="Environmental Triggers & Antigen Presentation"; style=filled; fillcolor="#F3E5F5";
        color="#6A1B9A"; fontsize=11; fontname="Helvetica-Bold";

        Mol_mimicry      [label="Molecular Mimicry\n(CMV/EBV/syphilis)", fillcolor="#E1BEE7"]
        CMV_HSV          [label="CMV / HSV / HCV\ninfection trigger", fillcolor="#CE93D8"]
        OxPS             [label="Oxidized Phosphatidylserine\n(OxPS on apoptotic cells)", fillcolor="#CE93D8"]
        B2GPI_autoAg     [label="β2-Glycoprotein I\n(β2GPI autoantigen)", fillcolor="#AB47BC"]
        OCP_estrogen     [label="OCP / Estrogen\n(thrombosis risk ×3-9)", fillcolor="#E1BEE7"]
        Microbiome_dysb  [label="Gut Microbiome\nDysbiosis", fillcolor="#E1BEE7"]
        APC_activation   [label="APC / DC\nActivation", fillcolor="#CE93D8"]
        ANCA_cross       [label="Cross-reactive\nANCA Epitopes", fillcolor="#E1BEE7"]
        SLE_comorbid     [label="SLE Comorbidity\n(secondary APS)", fillcolor="#AB47BC"]
    }

    /* =====================================================================
       CLUSTER 3 — ADAPTIVE IMMUNE DYSREGULATION
    ===================================================================== */
    subgraph cluster_adaptive {
        label="Adaptive Immune Dysregulation"; style=filled; fillcolor="#E8F5E9";
        color="#1B5E20"; fontsize=11; fontname="Helvetica-Bold";

        Tfh_cells   [label="T Follicular Helper\n(Tfh; CXCR5+ PD-1hi)", fillcolor="#A5D6A7"]
        Th17_cells  [label="Th17 Cells\n(IL-17A/F, IL-22)", fillcolor="#A5D6A7"]
        Treg_cells  [label="Regulatory T cells\n(Treg; FoxP3+) ↓", fillcolor="#66BB6A"]
        CD4_T       [label="CD4+ T cells\n(anti-β2GPI reactive)", fillcolor="#A5D6A7"]
        CD8_T       [label="CD8+ Cytotoxic T\n(perforin/granzyme B)", fillcolor="#A5D6A7"]
        Naive_B     [label="Naïve B cells\n(autoreactive anti-β2GPI)", fillcolor="#81C784"]
        Memory_B    [label="Memory B cells\n(persistent aPL production)", fillcolor="#4CAF50"]
        PlasmaCells [label="Long-lived\nPlasma Cells", fillcolor="#388E3C", fontcolor=white]
        BAFF        [label="BAFF / BLyS\n(B cell survival factor)", fillcolor="#A5D6A7"]
        APRIL       [label="APRIL\n(PC survival signal)", fillcolor="#A5D6A7"]
        IL21        [label="IL-21\n(Tfh→B cell help)", fillcolor="#C8E6C9"]
        IL6_adapt   [label="IL-6\n(B cell differentiation)", fillcolor="#C8E6C9"]
        IL17        [label="IL-17A\n(neutrophil/NETosis)", fillcolor="#C8E6C9"]
        CTLA4_ICOS  [label="ICOS / CTLA-4\n(costimulation balance)", fillcolor="#C8E6C9"]
    }

    /* =====================================================================
       CLUSTER 4 — aPL ANTIBODY PRODUCTION
    ===================================================================== */
    subgraph cluster_apl {
        label="aPL Antibody Production"; style=filled; fillcolor="#FFF9C4";
        color="#F57F17"; fontsize=11; fontname="Helvetica-Bold";

        anti_B2GPI_IgG  [label="Anti-β2GPI IgG\n(high-risk; Domain I)", fillcolor="#FFF176"]
        anti_B2GPI_IgM  [label="Anti-β2GPI IgM", fillcolor="#FFF176"]
        aCL_IgG         [label="Anti-Cardiolipin IgG\n(aCL IgG)", fillcolor="#FFEE58"]
        aCL_IgM         [label="Anti-Cardiolipin IgM\n(aCL IgM)", fillcolor="#FFEE58"]
        LA_IgG          [label="Lupus Anticoagulant\n(LA; functional assay)", fillcolor="#FDD835"]
        anti_PSPT       [label="Anti-PS/PT IgG\n(anti-phosphoserine/\nprothrombin)", fillcolor="#FFF176"]
        anti_PT         [label="Anti-Prothrombin Ab\n(anti-PT)", fillcolor="#FFF176"]
        B2GPI_free      [label="β2GPI (free)\n(pentameric form)", fillcolor="#FFCA28"]
        B2GPI_bound     [label="β2GPI/aPL\nComplex (bound)", fillcolor="#FFB300"]
        B2GPI_domain1   [label="β2GPI Domain I\n(major epitope)", fillcolor="#FFCA28"]
        Triple_pos      [label="Triple Positivity\n(aCL+LA+aβ2GPI)\n→ highest risk", fillcolor="#FF8F00", fontcolor=white]
    }

    /* =====================================================================
       CLUSTER 5 — INNATE IMMUNE ACTIVATION
    ===================================================================== */
    subgraph cluster_innate {
        label="Innate Immune Activation"; style=filled; fillcolor="#E3F2FD";
        color="#0D47A1"; fontsize=11; fontname="Helvetica-Bold";

        TLR4_EC      [label="TLR4 (endothelium)\n→ NF-κB", fillcolor="#90CAF9"]
        TLR7_pDC     [label="TLR7 / TLR9\n(pDC activation)", fillcolor="#90CAF9"]
        MyD88_TRIF   [label="MyD88 / TRIF\nadaptor signaling", fillcolor="#90CAF9"]
        NFkB_innate  [label="NF-κB\n(innate)", fillcolor="#42A5F5"]
        IFN_alpha    [label="IFN-α\n(type I interferon)", fillcolor="#1E88E5", fontcolor=white]
        pDC          [label="Plasmacytoid DC\n(pDC)", fillcolor="#90CAF9"]
        NK_cells     [label="NK cells\n(ADCC)", fillcolor="#90CAF9"]
        Neutrophils  [label="Neutrophils\n(NET-prone)", fillcolor="#64B5F6"]
        NETs         [label="NETs\n(neutrophil extracellular\ntraps; citrullinated histones)", fillcolor="#1565C0", fontcolor=white]
        HMGB1        [label="HMGB1\n(alarmin; DAMPs)", fillcolor="#90CAF9"]
        S100A8A9     [label="S100A8/A9\n(myeloid-related proteins)", fillcolor="#90CAF9"]
        Monocytes    [label="Monocytes/\nMacrophages (M1)", fillcolor="#64B5F6"]
        PAMPs_DAMPs  [label="PAMPs / DAMPs\n(infection/sterile injury)", fillcolor="#BBDEFB"]
    }

    /* =====================================================================
       CLUSTER 6 — COMPLEMENT CASCADE
    ===================================================================== */
    subgraph cluster_complement {
        label="Complement Cascade"; style=filled; fillcolor="#FCE4EC";
        color="#880E4F"; fontsize=11; fontname="Helvetica-Bold";

        C1q       [label="C1q\n(classical pathway init.)", fillcolor="#F48FB1"]
        C1rs      [label="C1r / C1s\n(serine proteases)", fillcolor="#F48FB1"]
        C4c       [label="C4\n→C4b (opsonin)", fillcolor="#F48FB1"]
        C4b_node  [label="C4b\n+ C2a → C3 convertase", fillcolor="#F48FB1"]
        C2        [label="C2\n(classical/lectin)", fillcolor="#F48FB1"]
        C3c       [label="C3\n(central complement)", fillcolor="#EC407A"]
        C3a       [label="C3a\n(anaphylatoxin)", fillcolor="#F06292"]
        C3b_node  [label="C3b\n(opsonin; C5 convertase)", fillcolor="#E91E63", fontcolor=white]
        C5c       [label="C5\n(terminal pathway)", fillcolor="#C2185B", fontcolor=white]
        C5a       [label="C5a\n(potent anaphylatoxin;\nneutrophil recruiter)", fillcolor="#AD1457", fontcolor=white]
        C5b       [label="C5b\n→ MAC nucleation", fillcolor="#880E4F", fontcolor=white]
        C5b_9     [label="C5b-9 (MAC)\n(membrane attack complex;\ntrophoblast injury)", fillcolor="#560027", fontcolor=white]
        FacB      [label="Factor B\n(alternative pathway)", fillcolor="#F48FB1"]
        FacD      [label="Factor D\n(Ba+Bb→C3 convertase)", fillcolor="#F48FB1"]
        Properdin [label="Properdin\n(stabilizes C3bBb)", fillcolor="#F48FB1"]
        MBL       [label="MBL\n(lectin pathway)", fillcolor="#F48FB1"]
        MASP12    [label="MASP-1/2\n(lectin pathway init.)", fillcolor="#F48FB1"]
        CR3       [label="CR3 (CD11b/CD18)\n(neutrophil receptor)", fillcolor="#F48FB1"]
        C3aR      [label="C3aR\n(receptor on mast cells)", fillcolor="#F48FB1"]
        C5aR      [label="C5aR (CD88)\n(neutrophil/EC receptor)", fillcolor="#EC407A"]
    }

    /* =====================================================================
       CLUSTER 7 — ENDOTHELIAL CELL ACTIVATION
    ===================================================================== */
    subgraph cluster_ec {
        label="Endothelial Cell Activation"; style=filled; fillcolor="#E8EAF6";
        color="#1A237E"; fontsize=11; fontname="Helvetica-Bold";

        EC_activ    [label="Endothelial Cell\nActivation State", fillcolor="#9FA8DA"]
        NFkB_EC     [label="NF-κB (EC)\n(p65/p50 translocation)", fillcolor="#5C6BC0", fontcolor=white]
        TF_EC       [label="Tissue Factor (TF)\n(CD142; initiates clotting)", fillcolor="#3949AB", fontcolor=white]
        PAI1        [label="PAI-1\n(fibrinolysis inhibitor)", fillcolor="#7986CB"]
        ICAM1       [label="ICAM-1 (CD54)\n(leukocyte adhesion)", fillcolor="#9FA8DA"]
        VCAM1       [label="VCAM-1 (CD106)\n(leukocyte rolling)", fillcolor="#9FA8DA"]
        P_selectin  [label="P-selectin\n(platelet/leukocyte)", fillcolor="#7986CB"]
        E_selectin  [label="E-selectin\n(leukocyte rolling)", fillcolor="#9FA8DA"]
        mTOR_EC     [label="mTOR\n(vascular remodeling;\nEC proliferation)", fillcolor="#3F51B5", fontcolor=white]
        VEGF_EC     [label="VEGF\n(angiogenesis; vascular\npermeability)", fillcolor="#5C6BC0", fontcolor=white]
        ET1         [label="Endothelin-1 (ET-1)\n(vasoconstriction)", fillcolor="#9FA8DA"]
        PGI2_dec    [label="PGI₂ ↓\n(prostacyclin deficiency;\n→ thrombotic tendency)", fillcolor="#7986CB"]
        eNOS_dysf   [label="eNOS dysfunction\n(NO↓; BH4↓)", fillcolor="#9FA8DA"]
        ROS_EC      [label="ROS / Oxidative\nStress (EC)", fillcolor="#7986CB"]
        ApoER2_EC   [label="ApoER2'\n(β2GPI-EC receptor;\nY418 phosphorylation)", fillcolor="#5C6BC0", fontcolor=white]
        Annexin_A5  [label="Annexin A5\n(anticoagulant shield\ndisplacement)", fillcolor="#9FA8DA"]
    }

    /* =====================================================================
       CLUSTER 8 — PLATELET ACTIVATION
    ===================================================================== */
    subgraph cluster_platelet {
        label="Platelet Activation & Aggregation"; style=filled; fillcolor="#FBE9E7";
        color="#BF360C"; fontsize=11; fontname="Helvetica-Bold";

        ApoER2_plt  [label="ApoER2'\n(platelet β2GPI receptor)", fillcolor="#FFAB91"]
        GPIbalpha   [label="GPIb-α\n(vWF binding; aPL target)", fillcolor="#FF7043"]
        TLR4_plt    [label="TLR4 (platelet)\n→ activation", fillcolor="#FFAB91"]
        PI3K_plt    [label="PI3K / Akt\n(platelet signaling)", fillcolor="#FFAB91"]
        PKC_plt     [label="PKC\n(granule release)", fillcolor="#FFAB91"]
        TXA2        [label="TXA₂\n(thromboxane A2)", fillcolor="#FF5722", fontcolor=white]
        COX1        [label="COX-1\n(TXA2 synthesis)", fillcolor="#FF7043"]
        TP_recep    [label="TP receptor\n(TXA2 receptor)", fillcolor="#FFAB91"]
        P2Y12       [label="P2Y12\n(ADP receptor; Gi)", fillcolor="#FF5722", fontcolor=white]
        P2Y1        [label="P2Y1\n(ADP receptor; Gq)", fillcolor="#FFAB91"]
        PAR1_plt    [label="PAR-1\n(thrombin receptor)", fillcolor="#FF7043"]
        PAR4_plt    [label="PAR-4\n(thrombin receptor)", fillcolor="#FF7043"]
        GPIIbIIIa  [label="GPIIb/IIIa (αIIbβ3)\n(fibrinogen binding;\nfinal aggregation pathway)", fillcolor="#BF360C", fontcolor=white]
        Fibr_plt    [label="Fibrinogen\n(bridges platelets)", fillcolor="#FFCCBC"]
        vWF_GPIb    [label="vWF / GPIb-α\n(adhesion to subendothelium)", fillcolor="#FFAB91"]
    }

    /* =====================================================================
       CLUSTER 9 — COAGULATION CASCADE
    ===================================================================== */
    subgraph cluster_coagulation {
        label="Coagulation Cascade & Fibrinolysis"; style=filled; fillcolor="#E0F2F1";
        color="#004D40"; fontsize=11; fontname="Helvetica-Bold";

        TF_VIIa    [label="TF:FVIIa Complex\n(extrinsic Xase initiation)", fillcolor="#80CBC4"]
        FX         [label="Factor X\n(FX)", fillcolor="#80CBC4"]
        FXa        [label="Factor Xa\n(FXa; prothrombinase)", fillcolor="#26A69A"]
        FVa        [label="Factor Va\n(Fva; cofactor)", fillcolor="#26A69A"]
        Prothromb  [label="Prothrombinase Complex\n(FXa + FVa + Ca²⁺ + PL)", fillcolor="#00897B", fontcolor=white]
        FII        [label="Prothrombin (FII)\n(zymogen)", fillcolor="#80CBC4"]
        FIIa       [label="Thrombin (FIIa)\n(serine protease;\ncentral coagulation enzyme)", fillcolor="#00695C", fontcolor=white]
        Fibrinogen [label="Fibrinogen (I)\n(plasma protein)", fillcolor="#A7FFEB"]
        Fibrin     [label="Fibrin (Ia)\n(insoluble clot network)", fillcolor="#1DE9B6"]
        FXIII      [label="Factor XIII → XIIIa\n(crosslinks fibrin)", fillcolor="#26A69A"]
        XlinkedFib [label="Cross-linked Fibrin\n(stable thrombus)", fillcolor="#00695C", fontcolor=white]
        tPA        [label="tPA\n(tissue plasminogen activator)", fillcolor="#80CBC4"]
        Plasminogen[label="Plasminogen\n→ Plasmin", fillcolor="#80CBC4"]
        Plasmin    [label="Plasmin\n(fibrin degradation)", fillcolor="#26A69A"]
        Fibrinolys [label="Fibrinolysis\n(FDPs / D-dimer)", fillcolor="#A7FFEB"]
        Antithromb [label="Antithrombin III\n(ATIII; inhibits FXa/IIa)", fillcolor="#80CBC4"]
        TFPI       [label="TFPI\n(TF pathway inhibitor)", fillcolor="#80CBC4"]
        ProtC_S    [label="Protein C/S\n(anticoagulant pathway;\ninhibits FVa/VIIIa)", fillcolor="#26A69A"]
    }

    /* =====================================================================
       CLUSTER 10 — OBSTETRIC APS
    ===================================================================== */
    subgraph cluster_obstetric {
        label="Obstetric APS (OAPS)"; style=filled; fillcolor="#F1F8E9";
        color="#33691E"; fontsize=11; fontname="Helvetica-Bold";

        Trophoblast    [label="Trophoblast\n(invasive; decidualization)", fillcolor="#DCEDC8"]
        Syncytio       [label="Syncytiotrophoblast\n(nutrient exchange layer)", fillcolor="#C5E1A5"]
        Cytotrophob    [label="Cytotrophoblast\n(villous; proliferating)", fillcolor="#AED581"]
        EVT_invasion   [label="Extravillous Trophoblast\n(EVT; spiral artery invasion)", fillcolor="#8BC34A"]
        Spiral_artery  [label="Spiral Artery Remodeling\n(↓ in OAPS → high-resistance)", fillcolor="#558B2F", fontcolor=white]
        PlGF           [label="PlGF\n(placental growth factor;↓)", fillcolor="#C5E1A5"]
        sFlt1          [label="sFlt-1\n(VEGF inhibitor; ↑ in OAPS)", fillcolor="#8BC34A"]
        Angio_imbalance[label="Angiogenic Imbalance\nPlGF↓ / sFlt-1↑", fillcolor="#558B2F", fontcolor=white]
        C5b9_tropho    [label="C5b-9 (MAC)\non Trophoblast\n(apoptosis trigger)", fillcolor="#33691E", fontcolor=white]
        TNFa_placenta  [label="TNF-α / IL-1β\n(placental inflammation)", fillcolor="#AED581"]
        Placenta_throm [label="Placental\nThrombosis", fillcolor="#7CB342"]
        Placenta_infarc[label="Placental Infarction\n(decidual vasculopathy)", fillcolor="#558B2F", fontcolor=white]
        FGR            [label="FGR\n(fetal growth restriction)", fillcolor="#689F38"]
        Preeclampsia_ob[label="Preeclampsia\n(hypertension + proteinuria)", fillcolor="#33691E", fontcolor=white]
        RPL            [label="Recurrent Pregnancy\nLoss (RPL)", fillcolor="#8BC34A"]
    }

    /* =====================================================================
       CLUSTER 11 — DRUG PK / PD
    ===================================================================== */
    subgraph cluster_drugpk {
        label="Drug PK / PD"; style=filled; fillcolor="#EDE7F6";
        color="#4A148C"; fontsize=11; fontname="Helvetica-Bold";

        /* Warfarin */
        Warf_GUT    [label="Warfarin (GUT)\nka=1.1/h; F=0.99", fillcolor="#CE93D8"]
        Warf_PLASMA [label="Warfarin (PLASMA)\nCL=0.2 L/h; Vc=10 L", fillcolor="#BA68C8"]
        Warf_EFFECT [label="Warfarin Effect\nVKORC1 inhibition\n→ Factors II/VII/IX/X↓", fillcolor="#9C27B0", fontcolor=white]
        VKORC1      [label="VKORC1\n(vitamin K epoxide reductase;\nwarfarin target)", fillcolor="#7B1FA2", fontcolor=white]
        CYP2C9      [label="CYP2C9\n(warfarin metabolism;\n*2/*3 variants)", fillcolor="#CE93D8"]

        /* LMWH / Heparin */
        LMWH_C      [label="Enoxaparin (LMWH)\nSC; ka=0.2/h; t½~4.5h", fillcolor="#CE93D8"]

        /* Hydroxychloroquine */
        HCQ_GUT     [label="Hydroxychloroquine\n(GUT); ka=0.08/h", fillcolor="#CE93D8"]
        HCQ_PLASMA  [label="HCQ (PLASMA)\nCL=0.25 L/h; Vc=257 L\nt½~50 days (tissue dist.)", fillcolor="#BA68C8"]

        /* Rivaroxaban */
        Riva_GUT    [label="Rivaroxaban (GUT)\nka=1.5/h; F=0.66", fillcolor="#CE93D8"]
        Riva_PLASMA [label="Rivaroxaban (PLASMA)\nCL=4.8 L/h; Vc=47 L\nt½~9h", fillcolor="#BA68C8"]

        /* Aspirin */
        ASA_gut     [label="Aspirin (GUT)\nka=6/h; F=0.68", fillcolor="#CE93D8"]
        ASA_plasma  [label="Aspirin (PLASMA)\nt½~20 min (hydrolysis)", fillcolor="#CE93D8"]

        /* Rituximab */
        RTX_PLASMA  [label="Rituximab (IV)\n2-CMT; CL=0.38 L/d\nVc=3.5 L; t½~22 days", fillcolor="#AB47BC"]

        /* Eculizumab */
        Ecul_PLASMA [label="Eculizumab (IV)\nanti-C5 mAb\nCL=0.31 L/d; t½~11 days", fillcolor="#9C27B0", fontcolor=white]

        /* Belimumab */
        Beli_PLASMA [label="Belimumab (IV/SC)\nanti-BAFF mAb\nt½~19 days", fillcolor="#CE93D8"]
    }

    /* =====================================================================
       CLUSTER 12 — BIOMARKERS
    ===================================================================== */
    subgraph cluster_biomarkers {
        label="Laboratory Biomarkers"; style=filled; fillcolor="#FFFDE7";
        color="#827717"; fontsize=11; fontname="Helvetica-Bold";

        aCL_IgG_bm      [label="aCL IgG titer\n(>40 GPL-U = high-risk)", fillcolor="#FFF9C4"]
        aCL_IgM_bm      [label="aCL IgM titer\n(>40 MPL-U)", fillcolor="#FFF9C4"]
        aB2GPI_IgG_bm   [label="Anti-β2GPI IgG\n(>99th percentile)", fillcolor="#FFF176"]
        aB2GPI_IgM_bm   [label="Anti-β2GPI IgM\n(>99th percentile)", fillcolor="#FFF176"]
        LA_test         [label="Lupus Anticoagulant\n(dRVVT; confirm 12 wk)", fillcolor="#FFEE58"]
        INR_bm          [label="INR\n(warfarin PD; target 2.0-3.0)", fillcolor="#FDD835"]
        aPTT_bm         [label="aPTT\n(LA prolongs aPTT)", fillcolor="#FFF9C4"]
        AntiXa          [label="Anti-Xa Activity\n(LMWH/rivaroxaban monitoring)", fillcolor="#FFF176"]
        D_dimer         [label="D-dimer\n(fibrin degradation;\n>500 ng/mL = VTE risk)", fillcolor="#F9A825"]
        Comp_C3         [label="Complement C3\n(↓ in active SLE-APS)", fillcolor="#FFF9C4"]
        Comp_C4         [label="Complement C4\n(↓ in active disease)", fillcolor="#FFF9C4"]
        Fibrinogen_bm   [label="Fibrinogen\n(acute phase reactant)", fillcolor="#FFF9C4"]
        Platelet_ct     [label="Platelet Count\n(thrombocytopenia <100k)", fillcolor="#F9A825"]
        B2GPI_serum     [label="β2GPI serum level\n(free vs bound)", fillcolor="#FFF9C4"]
    }

    /* =====================================================================
       CLUSTER 13 — CLINICAL ENDPOINTS
    ===================================================================== */
    subgraph cluster_endpoints {
        label="Clinical Endpoints & Disease Outcomes"; style=filled; fillcolor="#FFEBEE";
        color="#B71C1C"; fontsize=11; fontname="Helvetica-Bold";

        DVT             [label="Deep Vein Thrombosis\n(DVT; annual rate 3-5%)", fillcolor="#EF9A9A"]
        PE              [label="Pulmonary Embolism\n(PE; life-threatening)", fillcolor="#E57373"]
        Arterial_throm  [label="Arterial Thrombosis\n(coronary, peripheral)", fillcolor="#E57373"]
        Stroke_TIA      [label="Stroke / TIA\n(annual rate 2-3%)", fillcolor="#EF5350"]
        Renal_nephro    [label="Renal Vascular\nNephropathy\n(APS nephropathy; mTOR)", fillcolor="#E57373"]
        CAPS            [label="Catastrophic APS (CAPS)\n(≥3 organs in <1 wk;\nmortality 37-50%)", fillcolor="#C62828", fontcolor=white]
        Maternal_mort   [label="Maternal Mortality\n(CAPS in pregnancy)", fillcolor="#B71C1C", fontcolor=white]
        RPL_1st         [label="Early Pregnancy Loss\n(<10 wks; RPL)", fillcolor="#EF9A9A"]
        RPL_late        [label="Late Fetal Loss\n(≥10 wks; stillbirth)", fillcolor="#E57373"]
        Preeclampsia_ep [label="Preeclampsia /<34 wk\n(early-onset)", fillcolor="#EF5350"]
        Placenta_insuff [label="Placental Insufficiency\n(↓ UPI Doppler)", fillcolor="#EF9A9A"]
        LiveBirth       [label="Live Birth Rate\n(treated: ~70% vs untreated: ~30%)", fillcolor="#E57373"]
        Recurrence_risk [label="Recurrence Risk\n(off anticoag.: 10-30%/yr)", fillcolor="#EF5350"]
        Thrombocytopenia[label="Thrombocytopenia\n(<150 × 10⁹/L; in 20–45%)", fillcolor="#EF9A9A"]
    }

    /* ===================================================================
       INTER-CLUSTER EDGES
    =================================================================== */

    /* Genetics → Triggers / Adaptive / Innate */
    HLA_DRw53 -> APC_activation [label="T cell peptide\npresentation"]
    HLA_DR4   -> CD4_T [label="anti-β2GPI\nT cell epitope"]
    IL10_poly -> Treg_cells [label="IL-10↓ →\nTreg impaired"]
    FVL       -> FVa [label="APC resistance\n→ FVa persistent"]
    C4_null   -> C3c [label="classical pathway\ndeficiency"]
    FXII_def  -> LA_IgG [label="contact activation ↓\n→ LA phenotype"]

    /* Triggers → Adaptive */
    Mol_mimicry   -> B2GPI_domain1 [label="epitope mimicry"]
    CMV_HSV       -> APC_activation [label="infection trigger\n→ DC activation"]
    OxPS          -> B2GPI_autoAg [label="OxPS binds β2GPI\n→ immunogenic complex"]
    OCP_estrogen  -> TF_EC [label="estrogen ↑ TF\nexpression"]
    SLE_comorbid  -> anti_B2GPI_IgG [label="SLE accelerates\naPL production"]

    /* Triggers → B/T cells */
    B2GPI_autoAg -> Naive_B [label="B cell\nautoreactivity"]
    APC_activation -> CD4_T [label="T cell\npriming"]
    APC_activation -> Tfh_cells [label="Tfh\ndifferentiation"]

    /* Adaptive → aPL */
    Tfh_cells   -> Memory_B [label="germinal center\nreaction"]
    Tfh_cells   -> PlasmaCells [label="PC\ndifferentiation"]
    CD4_T       -> Memory_B [label="T cell help\n→ class switch"]
    BAFF        -> Naive_B [label="survival\nsignal"]
    BAFF        -> Memory_B [label="class-switched\nB cell survival"]
    APRIL       -> PlasmaCells [label="LLPC\nsurvival"]
    IL21        -> Tfh_cells [label="Tfh\npolarization"]
    IL6_adapt   -> PlasmaCells [label="plasma cell\ndifferentiation"]
    Treg_cells  -> Tfh_cells [label="Tfr suppresses\nGC (when Treg↑)"]
    Memory_B    -> PlasmaCells [label="re-stimulation\n→ PC burst"]
    PlasmaCells -> anti_B2GPI_IgG [label="IgG secretion"]
    PlasmaCells -> aCL_IgG [label="IgG secretion"]
    PlasmaCells -> LA_IgG [label="IgG secretion"]
    PlasmaCells -> anti_B2GPI_IgM [label="IgM secretion"]
    PlasmaCells -> aCL_IgM [label="IgM secretion"]

    /* aPL → receptors / targets */
    anti_B2GPI_IgG -> B2GPI_bound [label="opsonization\nof β2GPI"]
    anti_B2GPI_IgG -> ApoER2_EC [label="β2GPI/Ab binds\nApoER2' on EC"]
    anti_B2GPI_IgG -> ApoER2_plt [label="β2GPI/Ab binds\nApoER2' on platelet"]
    anti_B2GPI_IgG -> GPIbalpha [label="β2GPI binds GPIb;\naPL co-activates"]
    B2GPI_bound -> C1q [label="immune complex\n→ classical complement"]
    LA_IgG -> Prothromb [label="LA interferes\nwith phospholipid\nsurface (paradox)"]
    anti_PSPT -> FII [label="binds prothrombin\n→ prothrombotic"]
    Triple_pos -> DVT [label="10× relative risk\nvs sero-negative"]

    /* aPL → innate immune */
    anti_B2GPI_IgG -> TLR4_EC [label="β2GPI/aPL complex\n→ TLR4 ligation"]
    anti_B2GPI_IgG -> TLR4_plt [label="TLR4 on\nplatelet surface"]
    B2GPI_bound -> Monocytes [label="FcγR ligation\n→ monocyte TF↑"]

    /* Innate immune */
    PAMPs_DAMPs  -> TLR4_EC [label="danger\nsignals"]
    PAMPs_DAMPs  -> TLR7_pDC [label="nucleic acid\nligands"]
    TLR4_EC      -> MyD88_TRIF [label="signaling\nadaptor"]
    TLR7_pDC     -> MyD88_TRIF
    MyD88_TRIF   -> NFkB_innate [label="IKK complex\nactivation"]
    MyD88_TRIF   -> IFN_alpha [label="IRF3/7 → IFN-α\n(type I IFN response)"]
    pDC          -> IFN_alpha [label="high IFN-α\nproducers"]
    TLR7_pDC     -> pDC
    NFkB_innate  -> Neutrophils [label="chemokine-driven\nneutrophil influx"]
    NFkB_innate  -> IL6_adapt
    Neutrophils  -> NETs [label="aPL-primed NET\nrelease (NADPH ox.)"]
    NETs         -> HMGB1 [label="nuclear HMGB1\nreleased in NETs"]
    NETs         -> TF_EC [label="NET-bound TF\n→ thrombin burst"]
    NETs         -> C1q [label="NET activate\nclassical complement"]
    HMGB1        -> TLR4_EC [label="HMGB1 → RAGE/TLR4\nEC activation"]
    S100A8A9     -> NFkB_innate [label="S100 alarmins\n→ NLRP3/NF-κB"]
    IFN_alpha    -> Naive_B [label="B cell\nhyperactivation"]
    IFN_alpha    -> Memory_B [label="memory B\nresponse boost"]
    Monocytes    -> NFkB_innate [label="FcγR → M1\nmacrophage activation"]

    /* Complement cascade */
    C1q    -> C1rs [label="activation"]
    C1rs   -> C4c  [label="C4 cleavage"]
    C4c    -> C4b_node [label="covalent binding\nto surface"]
    C2     -> C4b_node [label="C2 cleavage\nby C1s"]
    C4b_node -> C3c [label="C3 convertase\n(C4bC2a)"]
    MBL    -> MASP12 [label="lectin\npathway"]
    MASP12 -> C4c [label="C4/C2\ncleavage"]
    FacB   -> FacD [label="Factor B/D\ncomplex"]
    FacD   -> C3c [label="alternative C3\nconvertase (C3bBb)"]
    Properdin -> C3c [label="C3 convertase\nstabilization"]
    C3c    -> C3a [label="anaphylatoxin\ncleavage"]
    C3c    -> C3b_node [label="opsonin fragment"]
    C3b_node -> C5c [label="C5 convertase\n(C3bBbC3b)"]
    C5c    -> C5a [label="anaphylatoxin\ncleavage"]
    C5c    -> C5b [label="terminal\npathway"]
    C5b    -> C5b_9 [label="C6-C9 assembly\n→ MAC pore"]
    C5a    -> C5aR [label="C5aR\nbinding"]
    C5aR   -> Neutrophils [label="C5a-C5aR1 → NET\npriming of neutrophils"]
    C5aR   -> EC_activ [label="C5a ↑ TF\non EC"]
    C3aR   -> Monocytes [label="C3a-induced\nmacrophage activation"]
    C5b_9  -> Trophoblast [label="MAC-mediated\ntrophoblast apoptosis"]
    C3b_node -> CR3 [label="opsonization;\nneutrophil CR3 ligand"]
    CR3    -> Neutrophils [label="phagocytosis\nactivation"]

    /* Endothelial activation */
    ApoER2_EC  -> NFkB_EC   [label="β2GPI/aPL→ApoER2'\n→ Src/Akt→NF-κB"]
    NFkB_EC    -> TF_EC     [label="transcriptional ↑\nTF expression"]
    NFkB_EC    -> PAI1      [label="PAI-1 ↑\n(fibrinolysis ↓)"]
    NFkB_EC    -> ICAM1     [label="ICAM-1 ↑"]
    NFkB_EC    -> VCAM1     [label="VCAM-1 ↑"]
    NFkB_EC    -> E_selectin[label="E-selectin ↑"]
    NFkB_EC    -> VEGF_EC   [label="VEGF ↑\n(vascular remodeling)"]
    mTOR_EC    -> VEGF_EC   [label="mTOR → HIF-1α\n→ VEGF"]
    mTOR_EC    -> EC_activ  [label="mTOR: EC\nhyperproliferation"]
    ApoER2_EC  -> mTOR_EC   [label="β2GPI→ApoER2'→\nmTORC1 (chronic)"]
    ROS_EC     -> eNOS_dysf [label="ROS uncouples\neNOS → NO↓"]
    eNOS_dysf  -> PGI2_dec  [label="NO↓ → PGI₂↓\n(platelet activation ↑)"]
    ET1        -> EC_activ  [label="autocrine\nvasoconstriction"]
    Annexin_A5 -> Fibrinogen[label="aPL displaces\nAnnexin A5 → exposed\nphospholipid surface"]
    P_selectin -> Neutrophils[label="P-selectin ↑\nneutrophil tethering"]
    ICAM1      -> Monocytes [label="monocyte\nadhesion ↑"]

    /* Platelet activation */
    ApoER2_plt -> PI3K_plt  [label="ApoER2' signaling\n→ PI3K/Akt"]
    GPIbalpha  -> PI3K_plt  [label="GPIb-α\nsignaling"]
    TLR4_plt   -> PI3K_plt  [label="TLR4 → NF-κB\nin platelet"]
    PI3K_plt   -> PKC_plt   [label="DAG →\nPKC activation"]
    PKC_plt    -> TXA2      [label="arachidonic acid\nrelease → COX-1 → TXA2"]
    COX1       -> TXA2      [label="TXA2\nsynthesis"]
    TXA2       -> TP_recep  [label="TP receptor\nbinding"]
    TP_recep   -> GPIIbIIIa [label="inside-out\nactivation → GPIIb/IIIa"]
    P2Y12      -> GPIIbIIIa [label="Gi-mediated\ncAMP↓→GPIIb/IIIa"]
    PAR1_plt   -> GPIIbIIIa [label="thrombin-PAR1\n→ platelet activation"]
    GPIIbIIIa  -> Fibr_plt  [label="fibrinogen\nbridging"]
    Fibr_plt   -> Platelet_ct[label="platelet\nconsumption → ↓count"]
    vWF_GPIb   -> GPIbalpha [label="subendothelial\ncollagen-vWF adhesion"]
    PGI2_dec   -> TXA2      [label="PGI₂↓ removes\nbrake on TXA2"]

    /* Coagulation cascade */
    TF_EC      -> TF_VIIa   [label="TF + FVIIa\ncomplex formation"]
    TF_VIIa    -> FX        [label="extrinsic Xase\nactivates FX"]
    FX         -> FXa       [label="FXa\ngeneration"]
    FVa        -> Prothromb [label="cofactor\nassembly"]
    FXa        -> Prothromb [label="catalytic\nsubunit"]
    Prothromb  -> FII       [label="prothrombin\nsubstrate"]
    FII        -> FIIa      [label="thrombin\ngeneration"]
    FIIa       -> Fibrinogen[label="fibrinogen\ncleavage → fibrin"]
    Fibrinogen -> Fibrin     [label="fibrin\npolymerization"]
    FIIa       -> FXIII     [label="FXIII\nactivation"]
    FXIII      -> XlinkedFib[label="fibrin cross-\nlinking"]
    Fibrin     -> XlinkedFib[label="polymer +\ncrosslink → stable clot"]
    FIIa       -> PAR1_plt  [label="thrombin cleaves\nPAR-1 → platelet"]
    FIIa       -> PAR4_plt  [label="thrombin cleaves\nPAR-4"]
    tPA        -> Plasminogen[label="tPA activates\nplasminogen"]
    Plasminogen-> Plasmin   [label="plasmin\ngeneration"]
    Plasmin    -> Fibrinolys[label="fibrin\ndegradation → FDPs"]
    PAI1       -> tPA       [label="PAI-1 inhibits\ntPA → fibrinolysis↓"]
    Antithromb -> FXa       [label="ATIII inhibits\nFXa (heparin cofactor)"]
    Antithromb -> FIIa      [label="ATIII inhibits\nthrombin"]
    TFPI       -> TF_VIIa   [label="TFPI inhibits\nTF:VIIa"]
    ProtC_S    -> FVa       [label="APC inactivates\nFVa/FVIIIa"]

    /* Obstetric APS */
    anti_B2GPI_IgG -> Trophoblast   [label="aPL binds\ntrophoblast β2GPI"]
    aCL_IgG        -> Trophoblast   [label="aCL binds PS\non trophoblast"]
    C5b_9          -> C5b9_tropho   [label="MAC deposits\non trophoblast"]
    C5b9_tropho    -> Trophoblast   [label="trophoblast\napoptosis/dysfunction"]
    Trophoblast    -> EVT_invasion  [label="EVT\ndifferentiation"]
    EVT_invasion   -> Spiral_artery [label="EVT invasion\n→ artery remodeling"]
    Spiral_artery  -> Angio_imbalance[label="poor remodeling\n→ hypoxia"]
    anti_B2GPI_IgG -> Annexin_A5   [label="aPL displaces\nAnti-Annexin A5\n→ PS exposed"]
    Syncytio       -> PlGF          [label="syncytiotrophoblast\nsecretes PlGF"]
    sFlt1          -> Angio_imbalance[label="sFlt-1 ↑ sequesters\nVEGF/PlGF"]
    PlGF           -> Angio_imbalance[label="PlGF↓\n→ angiogenic imbalance"]
    Angio_imbalance-> Preeclampsia_ob[label="↑ BP / proteinuria\n→ preeclampsia"]
    Angio_imbalance-> FGR           [label="placental\nhypoperfusion → FGR"]
    Placenta_throm -> RPL            [label="thrombosis →\npregnancy loss"]
    Placenta_throm -> Placenta_infarc[label="infarction"]
    Placenta_infarc-> RPL_late       [label="late fetal loss\n(≥10 wks)"]
    TNFa_placenta  -> Placenta_throm [label="inflammation\n→ TF ↑ → thrombosis"]
    NETs           -> Placenta_throm [label="NET-fibrin\nthrombosis in placenta"]
    C5a            -> TNFa_placenta  [label="C5a → placental\nmacrophage activation"]

    /* Clinical endpoints from pathways */
    XlinkedFib     -> DVT           [label="venous\nthrombosis"]
    XlinkedFib     -> PE            [label="embolism\nfrom DVT"]
    Arterial_throm -> Stroke_TIA    [label="carotid/cerebral\nthromboembolism"]
    TF_EC          -> Arterial_throm[label="TF ↑ → arterial\nthrombosis"]
    GPIIbIIIa      -> Arterial_throm[label="platelet plug\n→ arterial occlusion"]
    mTOR_EC        -> Renal_nephro  [label="mTOR: renal\nvascular hyperplasia"]
    CAPS           -> Maternal_mort [label="multi-organ\nfailure"]
    DVT            -> CAPS          [label="extensive VTE\n→ CAPS trigger"]
    XlinkedFib     -> CAPS          [label="catastrophic\nthrombosis cascade"]
    RPL            -> RPL_1st       [label="<10 wks\nearly loss"]
    FGR            -> Placenta_insuff[label="placental\ninsufficiency"]
    Fibrinolys     -> D_dimer       [label="D-dimer\nelevated"]
    Platelet_ct    -> Thrombocytopenia[label="count <150k"]

    /* Drug PK → PD targets */
    Warf_GUT    -> Warf_PLASMA [label="absorption\nF=0.99"]
    Warf_PLASMA -> CYP2C9     [label="S-warfarin\nCYP2C9 metabolism"]
    CYP2C9      -> Warf_EFFECT [label="active S-warfarin\nclearance"]
    Warf_PLASMA -> VKORC1     [label="warfarin inhibits\nVKORC1"]
    VKORC1      -> FII        [label="VKORC1 inh.\n→ Factors II↓ → INR↑"]
    VKORC1      -> ProtC_S    [label="Protein C/S ↓\n(first ~48h of warfarin)"]
    Warf_EFFECT -> INR_bm     [label="INR ← warfarin\nPD effect"]

    LMWH_C     -> Antithromb  [label="LMWH potentiates\nATIII × 1000"]
    LMWH_C     -> AntiXa      [label="anti-Xa level\nmonitoring"]

    HCQ_GUT    -> HCQ_PLASMA  [label="oral absorption\nF=0.74"]
    HCQ_PLASMA -> anti_B2GPI_IgG[label="HCQ ↓ aPL\ntiters (indirect)"]
    HCQ_PLASMA -> TLR4_EC    [label="HCQ blocks TLR\nendosomal signaling"]
    HCQ_PLASMA -> GPIIbIIIa  [label="HCQ ↓ platelet\nactivation (PL membrane)"]

    Riva_GUT   -> Riva_PLASMA [label="absorption\nF=0.66"]
    Riva_PLASMA -> FXa        [label="rivaroxaban directly\ninhibits FXa (Ki=0.4 nM)"]
    Riva_PLASMA -> AntiXa     [label="anti-Xa level\ncorrelates with Riva conc."]

    ASA_gut    -> ASA_plasma  [label="rapid hydrolysis\nto salicylate"]
    ASA_plasma -> COX1        [label="irreversible COX-1\nserine acetylation"]

    RTX_PLASMA -> Memory_B    [label="RTX → anti-CD20\n→ B cell depletion"]
    RTX_PLASMA -> PlasmaCells [label="partial PC\ndepletion (CD20 low)"]
    RTX_PLASMA -> BAFF        [label="post-RTX BAFF ↑\n→ B cell rebound risk"]

    Ecul_PLASMA -> C5c        [label="eculizumab binds C5\n→ C5 cleavage ↓"]
    Ecul_PLASMA -> C5a        [label="C5a generation ↓\n→ complement ↓"]
    Ecul_PLASMA -> C5b_9      [label="MAC formation ↓\n(CAPS treatment)"]

    Beli_PLASMA -> BAFF       [label="belimumab\ninhibits BAFF"]
    Beli_PLASMA -> Memory_B   [label="BAFF↓ → Memory B\nsurvival ↓"]

    /* Biomarkers ← disease state */
    PlasmaCells     -> aCL_IgG_bm   [label="measured\nserum aCL IgG"]
    PlasmaCells     -> aB2GPI_IgG_bm[label="measured\nanti-β2GPI IgG"]
    LA_IgG          -> LA_test      [label="dRVVT\ncorrection test"]
    Warf_EFFECT     -> INR_bm       [label="INR\nmeasurement"]
    LMWH_C          -> AntiXa      [label="anti-Xa\nassay"]
    XlinkedFib      -> D_dimer      [label="FDP release\n→ D-dimer ↑"]
    Fibrin          -> Fibrinogen_bm[label="fibrinogen\nconsumption in CAPS"]
    Platelet_ct     -> Thrombocytopenia[label="count monitoring"]
    C3c             -> Comp_C3      [label="C3 level\nmeasured"]
    C4c             -> Comp_C4      [label="C4 level\nmeasured"]
}
