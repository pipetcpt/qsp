digraph ALS_QSP_Model {
  graph [
    label = "ALS (Amyotrophic Lateral Sclerosis) — QSP Mechanistic Map\nMotor Neuron Degeneration · Protein Aggregation · Excitotoxicity · Neuroinflammation · Drug PK/PD",
    labelloc  = "t",
    fontname  = "Arial",
    fontsize  = 22,
    rankdir   = "TB",
    splines   = "ortho",
    nodesep   = 0.35,
    ranksep   = 0.7,
    bgcolor   = "#F8F8F8",
    compound  = true
  ]
  node [fontname="Arial", fontsize=9, style="filled", shape="box",
        margin="0.08,0.05", height=0.3]
  edge [fontname="Arial", fontsize=8, arrowsize=0.7]

  /* ============================================================
     CLUSTER 1 : GENETIC & MOLECULAR DETERMINANTS
     ============================================================ */
  subgraph cluster_genetics {
    label     = "1. Genetic & Molecular Determinants"
    style     = "filled"
    fillcolor = "#FFEDED"
    fontname  = "Arial Bold"
    fontsize  = 12
    color     = "#CC0000"
    penwidth  = 2

    SOD1_wt       [label="SOD1 (WT)\nAntioxidant enzyme",     fillcolor="#FFB3B3"]
    SOD1_mut_A4V  [label="SOD1 A4V mutation\n(rapid progression)",fillcolor="#FF6666"]
    SOD1_mut_G93A [label="SOD1 G93A\n(model mutation)",        fillcolor="#FF6666"]
    SOD1_mut_G37R [label="SOD1 G37R\n(slow progression)",      fillcolor="#FF6666"]
    TARDBP        [label="TARDBP/TDP-43\n(RNA-binding protein)",fillcolor="#FFB3B3"]
    TDP43_mut     [label="TDP-43 mutations\n(A315T, M337V...)", fillcolor="#FF6666"]
    FUS_TLS       [label="FUS/TLS\n(RNA processing)",          fillcolor="#FFB3B3"]
    C9orf72       [label="C9orf72\n(G4C2)n repeat expansion",  fillcolor="#FF4444"]
    GGGGCC_repeat [label="GGGGCC hexanucleotide\nrepeat (>30 copies)",fillcolor="#FF4444"]
    DPR_proteins  [label="Dipeptide repeat proteins\nGA, GR, PR, PA, GP",fillcolor="#FF8888"]
    RNA_foci      [label="RNA foci\n(nuclear & cytoplasmic)",  fillcolor="#FF8888"]
    UBQLN2        [label="Ubiquilin-2 (UBQLN2)\nUPS shuttle protein",fillcolor="#FFB3B3"]
    VCP           [label="VCP/p97\nAAA-ATPase unfoldase",      fillcolor="#FFB3B3"]
    OPTN          [label="Optineurin (OPTN)\nautophagy receptor",fillcolor="#FFB3B3"]
    NEK1          [label="NEK1 kinase\nDNA damage response",   fillcolor="#FFD0D0"]
    ATXN2         [label="Ataxin-2 (ATXN2)\npolyQ expansion risk",fillcolor="#FFD0D0"]
    SETX          [label="Senataxin (SETX)\nRNA:DNA helicase", fillcolor="#FFD0D0"]
    MATR3         [label="Matrin-3 (MATR3)\nnuclear matrix protein",fillcolor="#FFD0D0"]
  }

  /* ============================================================
     CLUSTER 2 : PROTEIN QUALITY CONTROL (UPS / AUTOPHAGY / ER)
     ============================================================ */
  subgraph cluster_proteostasis {
    label     = "2. Protein Quality Control (UPS / Autophagy / ER Stress)"
    style     = "filled"
    fillcolor = "#FFF3E0"
    fontname  = "Arial Bold"
    fontsize  = 12
    color     = "#E65100"
    penwidth  = 2

    proteasome_26S  [label="26S Proteasome\nprotein degradation",   fillcolor="#FFD099"]
    poly_ubiquitin  [label="Poly-ubiquitin chains\n(K48: degradation, K63: autophagy)",fillcolor="#FFD099"]
    p62_SQSTM1      [label="p62 / SQSTM1\nautophagy receptor / hub",fillcolor="#FFD099"]
    autophagosome   [label="Autophagosome\n(LC3-II decorated)",      fillcolor="#FFD099"]
    beclin1         [label="Beclin-1 / PI3KC3\nautophagy initiation", fillcolor="#FFD099"]
    ULK1_ATG13      [label="ULK1 / ATG13\nautophagy induction complex",fillcolor="#FFD099"]
    LC3II           [label="LC3-II\nautophagosome marker",            fillcolor="#FFD099"]
    lysosome        [label="Lysosome\nautophagy termination",         fillcolor="#FFD099"]
    ER_lumen        [label="Endoplasmic Reticulum\nprotein folding",   fillcolor="#FFBF60"]
    PERK_kinase     [label="PERK kinase\nUPR sensor",                  fillcolor="#FFBF60"]
    eIF2a_P         [label="p-eIF2α\ntranslation attenuation",         fillcolor="#FFBF60"]
    ATF4            [label="ATF4\nUPR transcription factor",            fillcolor="#FFBF60"]
    CHOP_GADD153    [label="CHOP / GADD153\npro-apoptotic TF",          fillcolor="#FF9933"]
    GRP78_BiP       [label="GRP78 / BiP\nER chaperone",                 fillcolor="#FFBF60"]
    IRE1a           [label="IRE1α\nUPR endonuclease",                    fillcolor="#FFBF60"]
    XBP1s           [label="XBP1s\nUPR adaptive TF",                    fillcolor="#FFBF60"]
    ATF6            [label="ATF6\nUPR TF (ER to Golgi)",                 fillcolor="#FFBF60"]
    ubiq_aggregates [label="Ubiquitinated aggregates\nTDP-43 / SOD1 inclusions",fillcolor="#FF8800"]
  }

  /* ============================================================
     CLUSTER 3 : OXIDATIVE STRESS & MITOCHONDRIAL DYSFUNCTION
     ============================================================ */
  subgraph cluster_oxidative {
    label     = "3. Oxidative Stress & Mitochondrial Dysfunction"
    style     = "filled"
    fillcolor = "#E8F5E9"
    fontname  = "Arial Bold"
    fontsize  = 12
    color     = "#2E7D32"
    penwidth  = 2

    superoxide_O2   [label="Superoxide (O₂•⁻)\nprimary ROS",           fillcolor="#A5D6A7"]
    H2O2            [label="Hydrogen peroxide (H₂O₂)\nsecondary ROS",   fillcolor="#A5D6A7"]
    hydroxyl_rad    [label="Hydroxyl radical (•OH)\nFenton reaction",    fillcolor="#66BB6A"]
    GSH_pool        [label="Glutathione (GSH)\nantioxidant tripeptide",  fillcolor="#C8E6C9"]
    GSSG            [label="Oxidized glutathione (GSSG)\nredox burden",  fillcolor="#A5D6A7"]
    Nrf2            [label="Nrf2 (NFE2L2)\nredox master TF",             fillcolor="#81C784"]
    NRF2_ARE        [label="Nrf2-ARE binding\nantioxidant response",     fillcolor="#81C784"]
    HO1             [label="HO-1 (HMOX1)\nheme oxygenase-1",             fillcolor="#C8E6C9"]
    NQO1            [label="NQO1\nNAD(P)H quinone oxidoreductase",       fillcolor="#C8E6C9"]
    catalase        [label="Catalase\nH₂O₂ → H₂O + O₂",                 fillcolor="#C8E6C9"]
    GPx             [label="Glutathione peroxidase (GPx)\nGSH-dependent",fillcolor="#C8E6C9"]
    mito_membrane   [label="Mitochondrial ΔΨm\nmembrane potential",      fillcolor="#66BB6A"]
    ETC_complex_I   [label="Complex I (NADH dehydrogenase)\nelectron transport",fillcolor="#66BB6A"]
    ETC_complex_III [label="Complex III\n(ubiquinol:cytc reductase)",     fillcolor="#66BB6A"]
    cytochrome_c    [label="Cytochrome c release\napoptosis trigger",     fillcolor="#388E3C"]
    caspase9        [label="Caspase-9\napoptosome",                       fillcolor="#2E7D32"]
    caspase3        [label="Caspase-3\nexecutioner caspase",              fillcolor="#2E7D32"]
    Bcl2            [label="Bcl-2 / Bcl-XL\nanti-apoptotic",             fillcolor="#C8E6C9"]
    Bax_Bak         [label="Bax / Bak\npro-apoptotic pore",              fillcolor="#66BB6A"]
    PINK1_parkin    [label="PINK1 / Parkin\nmitophagy pathway",           fillcolor="#A5D6A7"]
  }

  /* ============================================================
     CLUSTER 4 : GLUTAMATE EXCITOTOXICITY
     ============================================================ */
  subgraph cluster_excitotox {
    label     = "4. Glutamate Excitotoxicity"
    style     = "filled"
    fillcolor = "#E3F2FD"
    fontname  = "Arial Bold"
    fontsize  = 12
    color     = "#1565C0"
    penwidth  = 2

    Glut_presynaptic [label="Glutamate\n(presynaptic neuron)",        fillcolor="#90CAF9"]
    VGLUT1           [label="VGLUT1 / VGLUT2\nvesicular glutamate transporter",fillcolor="#90CAF9"]
    syn_vesicle      [label="Synaptic vesicle fusion\nCa²⁺-dependent exocytosis",fillcolor="#90CAF9"]
    synaptic_cleft   [label="Synaptic cleft [Glu]\nexcess in ALS",    fillcolor="#42A5F5"]
    AMPA_receptor    [label="AMPA receptor\n(GluR2-lacking, Ca²⁺-permeable)",fillcolor="#1E88E5"]
    NMDA_receptor    [label="NMDA receptor\n(NR2B, Mg²⁺-block removed)",fillcolor="#1E88E5"]
    mGluR_group1     [label="mGluR1/5\n(group I metabotropic)",       fillcolor="#90CAF9"]
    Ca_entry         [label="Ca²⁺ entry\noverstimulation",             fillcolor="#42A5F5"]
    EAAT2_GLT1       [label="EAAT2 / GLT-1\nastrocyte Glu transporter ↓ALS",fillcolor="#E91E63"]
    EAAT1_GLAST      [label="EAAT1 / GLAST\nastrocyte transporter",    fillcolor="#F48FB1"]
    Glu_synthetase   [label="Glutamine synthetase\nGlu → Gln recycling",fillcolor="#90CAF9"]
    cPLA2            [label="cPLA2\nCa²⁺-activated lipase",            fillcolor="#42A5F5"]
    arachidonic_acid [label="Arachidonic acid\nneuroinflammatory lipid",fillcolor="#42A5F5"]
    calpain_mu       [label="μ-calpain\nCa²⁺-activated protease",      fillcolor="#1565C0"]
    calpain_m        [label="m-calpain\nhigh Ca²⁺ activated",          fillcolor="#1565C0"]
    nNOS             [label="nNOS\nNO synthase (Ca²⁺-activated)",      fillcolor="#1565C0"]
    peroxynitrite    [label="Peroxynitrite (ONOO⁻)\nhighly reactive nitrogen species",fillcolor="#0D47A1"]
    riluzole_target  [label="Na⁺ channel / Glu release\nRiluzole target",fillcolor="#B3E5FC"]
  }

  /* ============================================================
     CLUSTER 5 : MOTOR NEURON SURVIVAL SIGNALING
     ============================================================ */
  subgraph cluster_survival {
    label     = "5. Motor Neuron Survival Signaling"
    style     = "filled"
    fillcolor = "#F3E5F5"
    fontname  = "Arial Bold"
    fontsize  = 12
    color     = "#6A1B9A"
    penwidth  = 2

    BDNF          [label="BDNF\nbrain-derived neurotrophic factor",  fillcolor="#CE93D8"]
    TrkB          [label="TrkB receptor\nBDNF / NT-4 receptor",      fillcolor="#CE93D8"]
    NT3_NT4       [label="NT-3 / NT-4\nneurotrophins",               fillcolor="#CE93D8"]
    TrkC          [label="TrkC\nNT-3 receptor",                      fillcolor="#CE93D8"]
    CNTF          [label="CNTF\nciliary neurotrophic factor",        fillcolor="#BA68C8"]
    CNTFR_LIFRb   [label="CNTFR / LIFRβ / gp130\ncytokine receptor complex",fillcolor="#BA68C8"]
    GDNF          [label="GDNF\nglial cell-derived NTF",             fillcolor="#CE93D8"]
    GFRa1_RET     [label="GFRα1 / RET\nGDNF receptor complex",      fillcolor="#CE93D8"]
    VEGF_A        [label="VEGF-A\nvascular & neuroprotective",       fillcolor="#CE93D8"]
    VEGFR2        [label="VEGFR2\nKDR, endothelial survival",        fillcolor="#CE93D8"]
    IGF1          [label="IGF-1\ninsulin-like growth factor",        fillcolor="#CE93D8"]
    IGF1R         [label="IGF-1R\ntyrosine kinase receptor",         fillcolor="#CE93D8"]
    PI3K          [label="PI3K (p110/p85)\nphosphoinositide kinase", fillcolor="#AB47BC"]
    Akt_PKB       [label="Akt / PKB\nsurvival kinase",               fillcolor="#AB47BC"]
    mTORC1        [label="mTORC1\nrapamycin-sensitive complex",      fillcolor="#9C27B0"]
    p70S6K        [label="p70S6K\nprotein synthesis",                fillcolor="#9C27B0"]
    GSK3b         [label="GSK-3β\napoptosis regulator (↓ by Akt)",  fillcolor="#AB47BC"]
    FOXO3a        [label="FOXO3a\npro-apoptotic TF (inhibited by Akt)",fillcolor="#AB47BC"]
    NFkB_surv     [label="NF-κB (survival)\np65 / p50 anti-apoptotic",fillcolor="#AB47BC"]
    ERK12         [label="ERK1/2\nMAPK survival cascade",            fillcolor="#CE93D8"]
    STAT3_surv    [label="STAT3\ncytokine-mediated survival",        fillcolor="#CE93D8"]
    p38_MAPK      [label="p38 MAPK\nstress kinase (pro-apoptotic)",  fillcolor="#7B1FA2"]
    JNK           [label="JNK\nc-Jun N-terminal kinase apoptosis",  fillcolor="#7B1FA2"]
  }

  /* ============================================================
     CLUSTER 6 : NEUROINFLAMMATION
     ============================================================ */
  subgraph cluster_neuroInflam {
    label     = "6. Neuroinflammation"
    style     = "filled"
    fillcolor = "#FFF8E1"
    fontname  = "Arial Bold"
    fontsize  = 12
    color     = "#F57F17"
    penwidth  = 2

    microglia_rest  [label="Microglia (resting / M0)\nsurveillance state",         fillcolor="#FFE082"]
    microglia_M1    [label="Microglia M1\npro-inflammatory (ALS-dominant)",         fillcolor="#FFA000"]
    microglia_M2    [label="Microglia M2\nneuroprotective (depleted in ALS)",        fillcolor="#FFE082"]
    TNFa            [label="TNF-α\nmajor pro-inflammatory cytokine",                fillcolor="#FF8F00"]
    IL1b            [label="IL-1β\nNLRP3 inflammasome product",                     fillcolor="#FF8F00"]
    IL6             [label="IL-6\npleiotropic cytokine",                            fillcolor="#FF8F00"]
    IL18            [label="IL-18\npro-inflammatory, NMJ toxicity",                 fillcolor="#FF8F00"]
    NLRP3           [label="NLRP3 inflammasome\nactivated by misfolded proteins",   fillcolor="#F57F17"]
    caspase1        [label="Caspase-1\nmaturation of IL-1β / IL-18",               fillcolor="#F57F17"]
    COX2            [label="COX-2\nprostaglandin synthesis ↑",                      fillcolor="#FFB300"]
    PGE2            [label="PGE2\nneuroinflammatory prostanoid",                    fillcolor="#FFB300"]
    TLR4            [label="TLR4\nmutant protein PAMP sensor",                      fillcolor="#FFE082"]
    MyD88           [label="MyD88\nTLR adaptor protein",                            fillcolor="#FFE082"]
    NFkB_inflam     [label="NF-κB (inflammatory)\np65 nuclear translocation",      fillcolor="#F57F17"]
    astrocyte_A1    [label="Reactive astrocytes (A1)\nmotor neuron toxic secretome",fillcolor="#FFA000"]
    astrocyte_A2    [label="Neuroprotective astrocytes (A2)\ncompromised in ALS",   fillcolor="#FFE082"]
    GFAP            [label="GFAP\nastrocyte activation marker",                      fillcolor="#FFE082"]
    S100b           [label="S100β\nastrocyte damage marker",                         fillcolor="#FFE082"]
    complement_C3   [label="Complement C3\nA1 astrocyte product",                   fillcolor="#FFA000"]
    MHCII           [label="MHC II\nmicroglial antigen presentation",               fillcolor="#FFE082"]
    NOX2            [label="NADPH oxidase (NOX2)\nmicroglial ROS burst",            fillcolor="#FF8F00"]
    IL10_anti       [label="IL-10\nanti-inflammatory (depleted)",                   fillcolor="#FFE082"]
    TGFb            [label="TGF-β\nimmune tolerance factor",                        fillcolor="#FFE082"]
    Tregs           [label="Regulatory T cells (Tregs)\ndepleted in ALS patients",  fillcolor="#FFE082"]
    CD4_eff         [label="CD4+ effector T cells\nmicroglia activation aid",       fillcolor="#FFB300"]
  }

  /* ============================================================
     CLUSTER 7 : AXONAL TRANSPORT & CYTOSKELETAL DYNAMICS
     ============================================================ */
  subgraph cluster_axonal {
    label     = "7. Axonal Transport & Cytoskeletal Dynamics"
    style     = "filled"
    fillcolor = "#E8EAF6"
    fontname  = "Arial Bold"
    fontsize  = 12
    color     = "#283593"
    penwidth  = 2

    NfL           [label="NF-L (neurofilament light)\n68 kDa, CSF/plasma biomarker", fillcolor="#9FA8DA"]
    NfM           [label="NF-M (neurofilament medium)\n160 kDa triplet",             fillcolor="#9FA8DA"]
    NfH_phos      [label="pNF-H (phospho-heavy NF)\n200 kDa, hyperphos. in ALS",    fillcolor="#7986CB"]
    peripherin    [label="Peripherin (PRPH)\nintermediate filament",                 fillcolor="#9FA8DA"]
    kinesin1      [label="Kinesin-1 (KIF5A/B/C)\nanterograde transport",            fillcolor="#7986CB"]
    dynein        [label="Cytoplasmic dynein\nretrograde transport",                 fillcolor="#7986CB"]
    dynactin      [label="Dynactin (DCTN1 / p150glued)\ndynein processivity",       fillcolor="#7986CB"]
    alsin_ALS2    [label="Alsin (ALS2)\nRac1/Rab5 GEF, endosomal",                  fillcolor="#9FA8DA"]
    stathmin      [label="Stathmin\nmicrotubule destabilizer",                       fillcolor="#9FA8DA"]
    vimentin      [label="Vimentin\nintermediate filament scaffold",                 fillcolor="#9FA8DA"]
    actin_mf      [label="Actin microfilaments\ngrowth cone dynamics",               fillcolor="#9FA8DA"]
    tubulin_mt    [label="α/β-Tubulin / Microtubules\ntransport track",             fillcolor="#7986CB"]
    importin_b    [label="Importin-β\nnuclear import of repair factors",             fillcolor="#9FA8DA"]
    axonal_caliber[label="Axonal caliber\nNF stoichiometry dependent",               fillcolor="#7986CB"]
    node_ranvier  [label="Node of Ranvier\nsaltatory conduction",                    fillcolor="#9FA8DA"]
    myelination   [label="Myelination\nSchwann cells (PNS)",                         fillcolor="#9FA8DA"]
    transport_ves [label="Transport vesicles\nsynaptic cargo delivery",              fillcolor="#9FA8DA"]
    mito_transport[label="Mitochondrial transport\n(ATP supply to axon)",            fillcolor="#5C6BC0"]
  }

  /* ============================================================
     CLUSTER 8 : NEUROMUSCULAR JUNCTION & MOTOR UNIT
     ============================================================ */
  subgraph cluster_NMJ {
    label     = "8. Neuromuscular Junction & Motor Unit"
    style     = "filled"
    fillcolor = "#FCE4EC"
    fontname  = "Arial Bold"
    fontsize  = 12
    color     = "#880E4F"
    penwidth  = 2

    MN_axon_term  [label="Motor neuron axon terminal\npresynaptic bouton",      fillcolor="#F48FB1"]
    acetylcholine [label="Acetylcholine (ACh)\nneurotransmitter",               fillcolor="#F48FB1"]
    AChE          [label="Acetylcholinesterase (AChE)\nsynaptic cleft enzyme",  fillcolor="#F48FB1"]
    nAChR         [label="Nicotinic AChR\n(α1₂βδε pentamer)",                   fillcolor="#EC407A"]
    agrin         [label="Agrin\nneurally secreted organizer",                  fillcolor="#F48FB1"]
    MuSK          [label="MuSK\nmuscle-specific receptor kinase",               fillcolor="#F48FB1"]
    rapsyn        [label="Rapsyn\nAChR clustering protein",                     fillcolor="#F48FB1"]
    terminal_sch  [label="Terminal Schwann cells\nNMJ maintenance / repair",    fillcolor="#F48FB1"]
    muscle_type1  [label="Muscle Type I fibers\nslow-twitch, fatigue-resistant",fillcolor="#FCB0C7"]
    muscle_type2a [label="Muscle Type IIa fibers\nfast-twitch oxidative",       fillcolor="#FCB0C7"]
    muscle_type2b [label="Muscle Type IIx/IIb\nfast-twitch glycolytic",        fillcolor="#FCB0C7"]
    sarcomere     [label="Sarcomere\nactin/myosin cross-bridge",                fillcolor="#F48FB1"]
    denerv_atrophy[label="Denervation atrophy\nmuscle wasting",                 fillcolor="#C2185B"]
    EMG_amplitude [label="EMG amplitude\nmotor unit assessment",                fillcolor="#F48FB1"]
    MUNIX         [label="MUNIX\nmotor unit number index",                       fillcolor="#F48FB1"]
    motor_unit    [label="Motor unit\n(MN + muscle fibers)",                    fillcolor="#EC407A"]
    reinnervation [label="Compensatory reinnervation\ncollateral sprouting",    fillcolor="#F48FB1"]
    fasciculations[label="Fasciculations\nspontaneous motor unit discharge",    fillcolor="#C2185B"]
  }

  /* ============================================================
     CLUSTER 9 : DRUG PK / PD
     ============================================================ */
  subgraph cluster_drugs {
    label     = "9. Drug PK / PD Mechanisms"
    style     = "filled"
    fillcolor = "#E0F7FA"
    fontname  = "Arial Bold"
    fontsize  = 12
    color     = "#006064"
    penwidth  = 2

    riluzole_oral   [label="Riluzole 50 mg BID (oral)\nNa⁺ channel / pre-synaptic Glu blocker",fillcolor="#80DEEA"]
    riluzole_depot  [label="Riluzole GI absorption\nF=60%, Tmax≈1.5h",                         fillcolor="#80DEEA"]
    riluzole_plasma [label="Riluzole plasma Cp\n(2-compartment, CL=28 L/h, V=245 L)",           fillcolor="#4DD0E1"]
    riluzole_CYP1A2 [label="CYP1A2 metabolism\nN-OH-riluzole (active)\n+ glucuronide (inactive)",fillcolor="#80DEEA"]
    riluzole_effect [label="Riluzole PD effect\n↓ Glu release ~35%\n(Emax=60%, IC50=0.5 μg/mL)",fillcolor="#00ACC1"]

    edaravone_IV    [label="Edaravone 60 mg/day IV\ncycle: 14/14 days on/off → 10/14 oral",    fillcolor="#80DEEA"]
    edaravone_plasma[label="Edaravone plasma Cp\n(1-compartment, CL=18 L/h, V=120 L)",         fillcolor="#4DD0E1"]
    edaravone_glucur[label="Edaravone glucuronidation\nrapid hepatic metabolism",               fillcolor="#80DEEA"]
    edaravone_effect[label="Edaravone PD effect\nfree-radical scavenger\n↓ oxidative stress ~40%",fillcolor="#00ACC1"]

    tofersen_SC     [label="Tofersen 100 mg SC\nevery 4 weeks (loading × 3 then q4w)",         fillcolor="#80DEEA"]
    tofersen_plasma [label="Tofersen plasma\n(2-compartment, CL=0.5 L/h)",                      fillcolor="#4DD0E1"]
    tofersen_CSF    [label="Tofersen CSF distribution\nquarterly LP sampling",                  fillcolor="#4DD0E1"]
    tofersen_SOD1mRNA[label="SOD1 mRNA knockdown\ntofersen antisense target",                   fillcolor="#00ACC1"]
    SOD1_mRNA_KD    [label="↓ SOD1 protein in CSF\n≥50% reduction (ATLAS trial)",              fillcolor="#0097A7"]

    PB_oral         [label="Phenylbutyrate (AMX0035)\n3 g PO BID, histone deacetylase inhibitor",fillcolor="#80DEEA"]
    PB_plasma       [label="PB plasma Cp\n(F=85%, CL=12 L/h, V=50 L)",                         fillcolor="#4DD0E1"]
    TUDCA_oral      [label="TUDCA (AMX0035)\n1 g PO BID, bile acid ER protectant",              fillcolor="#80DEEA"]
    TUDCA_plasma    [label="TUDCA plasma\nenterohepatically recycled",                          fillcolor="#4DD0E1"]
    AMX0035_ER_eff  [label="AMX0035 PD\n↓ CHOP / ↓ ER stress / ↓ mito dysfunction",           fillcolor="#00ACC1"]

    masitinib_oral  [label="Masitinib 4.5 mg/kg/day (oral)\nc-Kit / PDGFR-β inhibitor",        fillcolor="#80DEEA"]
    masitinib_PK    [label="Masitinib plasma Cp\n(F=58%, CL=25 L/h, V1=190 L)",               fillcolor="#4DD0E1"]
    masitinib_eff   [label="Masitinib PD\n↓ mast cell / microglia activation",                 fillcolor="#00ACC1"]
  }

  /* ============================================================
     CLUSTER 10 : CLINICAL ENDPOINTS & BIOMARKERS
     ============================================================ */
  subgraph cluster_endpoints {
    label     = "10. Clinical Endpoints & Biomarkers"
    style     = "filled"
    fillcolor = "#FAFAFA"
    fontname  = "Arial Bold"
    fontsize  = 12
    color     = "#37474F"
    penwidth  = 2

    ALSFRS_total  [label="ALSFRS-R total (0–48)\nprimary clinical endpoint",     fillcolor="#B0BEC5"]
    ALSFRS_bulbar [label="ALSFRS-R bulbar subscore\nspeech / swallowing / saliva",fillcolor="#B0BEC5"]
    ALSFRS_limb   [label="ALSFRS-R limb subscore\nhandwriting / dressing / walking",fillcolor="#B0BEC5"]
    ALSFRS_resp   [label="ALSFRS-R respiratory subscore\ndyspnea / orthopnea / NIV",fillcolor="#B0BEC5"]
    FVC_pct       [label="FVC % predicted\nrespiratory primary measure",          fillcolor="#78909C"]
    SVC_pct       [label="SVC % predicted\nsupine VC assessment",                 fillcolor="#B0BEC5"]
    SNIP          [label="SNIP\nsniff nasal inspiratory pressure",                fillcolor="#B0BEC5"]
    CMAP          [label="CMAP amplitude\ncompound muscle action potential",       fillcolor="#B0BEC5"]
    MN_upper_count[label="Upper motor neurons\ncorticospinal tract (CST) count",  fillcolor="#78909C"]
    MN_lower_count[label="Lower motor neurons\nspinal / bulbar count",            fillcolor="#78909C"]
    NfL_CSF_bio   [label="CSF NfL (neurofilament light)\naxonal injury biomarker",fillcolor="#546E7A"]
    pNfH_plasma   [label="Plasma pNF-H\nphospho-heavy neurofilament",            fillcolor="#546E7A"]
    SOD1_CSF_bio  [label="CSF SOD1 protein\n(SOD1-ALS specific)",                 fillcolor="#546E7A"]
    time_decline  [label="Time to 6-pt ALSFRS-R decline\nkey trial endpoint",    fillcolor="#37474F"]
    time_resp_supp[label="Time to respiratory support\n(NPPV or tracheostomy)",  fillcolor="#37474F"]
    survival_TFS  [label="Tracheostomy-free survival\noverall survival endpoint", fillcolor="#263238"]
    diagnosis_delay[label="Diagnostic delay\n(symptom onset → diagnosis ≈13 mo)",fillcolor="#B0BEC5"]
  }

  /* ============================================================
     INTER-CLUSTER EDGES
     ============================================================ */

  /* Genetics → Protein aggregation */
  SOD1_mut_A4V  -> ubiq_aggregates   [label="rapid aggregation", color="#CC0000", style="bold"]
  SOD1_mut_G93A -> ubiq_aggregates   [label="model protein",     color="#CC0000"]
  TARDBP        -> TDP43_cyto_edge   [color="#880000", style="dashed"]
  TDP43_mut     -> ubiq_aggregates   [color="#CC0000"]
  C9orf72       -> DPR_proteins      [color="#CC0000"]
  DPR_proteins  -> RNA_foci          [color="#CC0000"]
  UBQLN2        -> proteasome_26S    [label="shuttle ub-proteins", color="#E65100", style="dashed"]
  VCP           -> ubiq_aggregates   [label="disaggregation↓ ALS", color="#E65100"]
  OPTN          -> autophagosome     [label="autophagy receptor", color="#E65100"]

  /* Aggregates → Proteostasis stress */
  ubiq_aggregates -> proteasome_26S  [label="overwhelm UPS", color="#E65100", style="bold"]
  ubiq_aggregates -> p62_SQSTM1      [label="sequestosome", color="#E65100"]
  ubiq_aggregates -> ER_lumen        [label="ER stress trigger", color="#E65100"]
  p62_SQSTM1    -> autophagosome     [label="cargo receptor", color="#E65100"]
  beclin1       -> autophagosome     [color="#E65100"]
  ULK1_ATG13    -> beclin1           [color="#E65100"]
  autophagosome -> LC3II             [color="#E65100"]
  LC3II         -> lysosome          [label="fusion", color="#E65100"]
  ER_lumen      -> PERK_kinase       [color="#E65100"]
  ER_lumen      -> IRE1a             [color="#E65100"]
  ER_lumen      -> ATF6              [color="#E65100"]
  ER_lumen      -> GRP78_BiP         [label="chaperone induction", color="#E65100"]
  PERK_kinase   -> eIF2a_P           [color="#E65100"]
  eIF2a_P       -> ATF4              [color="#E65100"]
  ATF4          -> CHOP_GADD153      [label="→ apoptosis", color="#CC0000"]
  IRE1a         -> XBP1s             [color="#E65100"]
  CHOP_GADD153  -> caspase9          [label="ER apoptosis", color="#CC0000"]

  /* Oxidative stress pathways */
  SOD1_wt       -> H2O2              [label="2O₂→H₂O₂ (normal)", color="#2E7D32"]
  SOD1_mut_G93A -> superoxide_O2     [label="gain-of-tox", color="#2E7D32", style="bold"]
  superoxide_O2 -> H2O2              [color="#2E7D32"]
  H2O2          -> hydroxyl_rad      [label="Fenton", color="#2E7D32"]
  GSH_pool      -> GPx               [label="substrate", color="#2E7D32"]
  GPx           -> H2O2              [label="scavenge", color="#2E7D32", dir="back"]
  Nrf2          -> NRF2_ARE          [color="#2E7D32"]
  NRF2_ARE      -> HO1               [color="#2E7D32"]
  NRF2_ARE      -> NQO1              [color="#2E7D32"]
  NRF2_ARE      -> GSH_pool          [label="γ-GCS induction", color="#2E7D32"]
  mito_membrane -> ETC_complex_I     [color="#2E7D32"]
  ETC_complex_I -> superoxide_O2     [label="electron leak", color="#2E7D32"]
  ETC_complex_III -> superoxide_O2   [label="electron leak", color="#2E7D32"]
  mito_membrane -> cytochrome_c      [label="ΔΨm collapse", color="#CC0000"]
  cytochrome_c  -> caspase9          [label="apoptosome", color="#CC0000"]
  caspase9      -> caspase3          [label="activation", color="#CC0000"]
  PINK1_parkin  -> mito_membrane     [label="mitophagy clearance", color="#2E7D32", style="dashed"]
  Bcl2          -> cytochrome_c      [label="block", color="#2E7D32", arrowhead="tee"]
  Bax_Bak       -> cytochrome_c      [label="pore formation", color="#CC0000"]

  /* Excitotoxicity cascade */
  Glut_presynaptic -> VGLUT1         [color="#1565C0"]
  VGLUT1           -> syn_vesicle    [color="#1565C0"]
  syn_vesicle      -> synaptic_cleft [label="exocytosis", color="#1565C0", style="bold"]
  synaptic_cleft   -> AMPA_receptor  [label="[Glu] excess", color="#1565C0"]
  synaptic_cleft   -> NMDA_receptor  [label="[Glu] excess", color="#1565C0"]
  AMPA_receptor    -> Ca_entry       [color="#1565C0"]
  NMDA_receptor    -> Ca_entry       [color="#1565C0"]
  mGluR_group1     -> Ca_entry       [label="IP3/DAG", color="#1565C0"]
  Ca_entry         -> cPLA2          [color="#1565C0"]
  Ca_entry         -> calpain_mu     [color="#1565C0"]
  Ca_entry         -> nNOS           [label="CaM binding", color="#1565C0"]
  nNOS             -> peroxynitrite  [label="NO+O₂→ONOO⁻", color="#CC0000"]
  peroxynitrite    -> superoxide_O2  [label="nitrosative",  color="#CC0000"]
  EAAT2_GLT1       -> synaptic_cleft [label="Glu clearance↓ALS", color="#E91E63", arrowhead="tee"]
  calpain_mu       -> NfL            [label="proteolysis→NfL release", color="#1565C0"]

  /* Survival signaling cascade */
  BDNF          -> TrkB              [color="#6A1B9A"]
  TrkB          -> PI3K              [color="#6A1B9A"]
  TrkB          -> ERK12             [color="#6A1B9A"]
  NT3_NT4       -> TrkC              [color="#6A1B9A"]
  GDNF          -> GFRa1_RET         [color="#6A1B9A"]
  GFRa1_RET     -> PI3K              [color="#6A1B9A"]
  IGF1          -> IGF1R             [color="#6A1B9A"]
  IGF1R         -> PI3K              [color="#6A1B9A"]
  VEGF_A        -> VEGFR2            [color="#6A1B9A"]
  VEGFR2        -> PI3K              [color="#6A1B9A"]
  PI3K          -> Akt_PKB           [color="#6A1B9A"]
  Akt_PKB       -> GSK3b             [label="phospho-inhib", color="#6A1B9A", arrowhead="tee"]
  Akt_PKB       -> FOXO3a            [label="phospho-inhib", color="#6A1B9A", arrowhead="tee"]
  Akt_PKB       -> mTORC1            [color="#6A1B9A"]
  Akt_PKB       -> NFkB_surv         [color="#6A1B9A"]
  mTORC1        -> p70S6K            [label="S6K phosph.", color="#6A1B9A"]
  TNFa          -> p38_MAPK          [label="stress", color="#F57F17"]
  TNFa          -> JNK               [label="stress", color="#F57F17"]
  p38_MAPK      -> caspase3          [label="→ apoptosis", color="#CC0000"]
  JNK           -> caspase3          [label="→ apoptosis", color="#CC0000"]

  /* Neuroinflammation circuit */
  microglia_rest  -> microglia_M1    [label="ALS signals → M1 bias", color="#F57F17", style="bold"]
  microglia_M1    -> TNFa            [label="secrete", color="#F57F17"]
  microglia_M1    -> IL1b            [label="secrete", color="#F57F17"]
  microglia_M1    -> IL6             [label="secrete", color="#F57F17"]
  microglia_M1    -> NOX2            [color="#F57F17"]
  NOX2            -> superoxide_O2   [label="burst", color="#F57F17"]
  NLRP3           -> caspase1        [color="#F57F17"]
  caspase1        -> IL1b            [label="mature IL-1β", color="#F57F17"]
  caspase1        -> IL18            [color="#F57F17"]
  microglia_M1    -> NLRP3           [color="#F57F17"]
  TLR4            -> MyD88           [color="#F57F17"]
  MyD88           -> NFkB_inflam     [color="#F57F17"]
  NFkB_inflam     -> TNFa            [color="#F57F17"]
  NFkB_inflam     -> COX2            [color="#F57F17"]
  COX2            -> PGE2            [color="#F57F17"]
  complement_C3   -> astrocyte_A1    [label="C3→A1 conversion", color="#F57F17"]
  astrocyte_A1    -> EAAT2_GLT1      [label="↓ EAAT2 expression", color="#CC0000", arrowhead="tee"]
  Tregs           -> microglia_M1    [label="suppress (lost in ALS)", color="#2E7D32", arrowhead="tee", style="dashed"]
  IL10_anti       -> NFkB_inflam     [label="anti-inflam", color="#2E7D32", arrowhead="tee"]
  TGFb            -> microglia_M2    [label="M2 polarization", color="#2E7D32"]

  /* Axonal transport connections */
  kinesin1      -> transport_ves     [label="anterograde delivery", color="#283593"]
  dynein        -> dynactin          [label="complex formation", color="#283593"]
  dynactin      -> dynein            [color="#283593"]
  NfL           -> axonal_caliber    [label="neurofilament scaffold", color="#283593"]
  NfM           -> axonal_caliber    [color="#283593"]
  NfH_phos      -> axonal_caliber    [color="#283593"]
  mito_transport -> mito_membrane    [label="ATP supply", color="#283593"]
  TNFa          -> dynein            [label="transport impair ↓", color="#CC0000", arrowhead="tee"]
  tubulin_mt    -> kinesin1          [label="track", color="#283593"]
  tubulin_mt    -> dynein            [label="track", color="#283593"]

  /* NMJ / Motor unit */
  MN_axon_term  -> acetylcholine     [label="synthesis", color="#880E4F"]
  acetylcholine -> syn_vesicle       [label="vesicle loading", color="#880E4F"]
  acetylcholine -> nAChR             [label="receptor binding", color="#880E4F"]
  nAChR         -> sarcomere         [label="endplate potential", color="#880E4F"]
  agrin         -> MuSK              [label="cluster AChR", color="#880E4F"]
  MuSK          -> rapsyn            [color="#880E4F"]
  rapsyn        -> nAChR             [label="anchoring", color="#880E4F"]
  AChE          -> acetylcholine     [label="hydrolysis", color="#880E4F", arrowhead="tee"]
  motor_unit    -> EMG_amplitude     [label="electrical signal", color="#880E4F"]
  motor_unit    -> MUNIX             [color="#880E4F"]
  denerv_atrophy -> ALSFRS_limb      [label="functional loss", color="#CC0000"]
  reinnervation -> motor_unit        [label="compensatory", color="#2E7D32"]
  caspase3      -> MN_lower_count    [label="motor neuron death", color="#CC0000", style="bold"]
  caspase3      -> MN_upper_count    [label="CST neuron death", color="#CC0000"]

  /* Drug effects */
  riluzole_oral   -> riluzole_depot  [label="oral administration", color="#006064"]
  riluzole_depot  -> riluzole_plasma [label="absorption (ka=0.8/h)", color="#006064"]
  riluzole_plasma -> riluzole_CYP1A2 [label="CYP1A2 first-pass", color="#006064"]
  riluzole_plasma -> riluzole_effect [color="#006064"]
  riluzole_effect -> synaptic_cleft  [label="↓ Glu release ~35%", color="#006064", arrowhead="tee", style="bold"]
  riluzole_effect -> ALSFRS_total    [label="survival +3 mo", color="#006064"]

  edaravone_IV    -> edaravone_plasma[label="IV infusion/oral", color="#006064"]
  edaravone_plasma -> edaravone_glucur [label="glucuronidation", color="#006064"]
  edaravone_plasma -> edaravone_effect [color="#006064"]
  edaravone_effect -> superoxide_O2  [label="scavenge", color="#006064", arrowhead="tee", style="bold"]
  edaravone_effect -> peroxynitrite  [label="scavenge", color="#006064", arrowhead="tee"]
  edaravone_effect -> ALSFRS_total   [label="slow decline", color="#006064"]

  tofersen_SC     -> tofersen_plasma [label="SC absorption", color="#006064"]
  tofersen_plasma -> tofersen_CSF    [label="CNS distribution", color="#006064"]
  tofersen_CSF    -> tofersen_SOD1mRNA [label="mRNA binding", color="#006064"]
  tofersen_SOD1mRNA -> SOD1_mRNA_KD  [label="RNase H degradation", color="#006064"]
  SOD1_mRNA_KD    -> SOD1_wt        [label="↓ SOD1 protein", color="#006064", arrowhead="tee"]
  SOD1_mRNA_KD    -> SOD1_mut_G93A  [label="↓ mutant SOD1", color="#006064", arrowhead="tee", style="bold"]
  SOD1_mRNA_KD    -> SOD1_CSF_bio   [label="↓ CSF SOD1", color="#006064"]

  PB_oral         -> PB_plasma       [label="oral (F=85%)", color="#006064"]
  TUDCA_oral      -> TUDCA_plasma    [label="enterohepatic", color="#006064"]
  PB_plasma       -> AMX0035_ER_eff  [color="#006064"]
  TUDCA_plasma    -> AMX0035_ER_eff  [color="#006064"]
  AMX0035_ER_eff  -> CHOP_GADD153   [label="↓ CHOP", color="#006064", arrowhead="tee"]
  AMX0035_ER_eff  -> mito_membrane  [label="↑ ΔΨm", color="#006064"]
  AMX0035_ER_eff  -> ALSFRS_total   [label="CENTAUR trial +3.4 pts/yr", color="#006064"]

  masitinib_oral  -> masitinib_PK    [label="oral (F=58%)", color="#006064"]
  masitinib_PK    -> masitinib_eff   [color="#006064"]
  masitinib_eff   -> microglia_M1    [label="↓ activation", color="#006064", arrowhead="tee"]
  masitinib_eff   -> IL1b            [label="↓ production", color="#006064", arrowhead="tee"]

  /* Biomarker connections */
  NfL           -> NfL_CSF_bio       [label="released on axon injury", color="#37474F"]
  NfH_phos      -> pNfH_plasma       [label="blood biomarker", color="#37474F"]
  MN_lower_count -> ALSFRS_total     [label="functional correlate", color="#37474F"]
  MN_lower_count -> FVC_pct          [label="respiratory drive", color="#37474F"]
  MN_upper_count -> ALSFRS_total     [color="#37474F"]
  ALSFRS_total  -> time_decline       [label="progression tracking", color="#37474F"]
  FVC_pct       -> time_resp_supp    [label="NIV threshold <50%", color="#37474F"]
  time_decline  -> survival_TFS      [color="#37474F"]
  time_resp_supp -> survival_TFS     [color="#37474F"]
  NfL_CSF_bio   -> diagnosis_delay   [label="early biomarker", color="#37474F"]
  ALSFRS_limb   -> ALSFRS_total      [color="#37474F"]
  ALSFRS_bulbar -> ALSFRS_total      [color="#37474F"]
  ALSFRS_resp   -> ALSFRS_total      [color="#37474F"]
  FVC_pct       -> ALSFRS_resp       [label="respiratory subscore", color="#37474F"]
  CMAP          -> MUNIX             [label="reference measure", color="#37474F"]
  MUNIX         -> MN_lower_count    [label="in vivo estimation", color="#37474F"]

  /* Hidden node to reference TDP43_cyto for edge routing */
  TDP43_cyto_edge [label="TDP-43\ncytoplasmic inclusions",
                    fillcolor="#FF6666", style="filled", fontname="Arial", fontsize=9, shape="box"]
  TDP43_cyto_edge -> ubiq_aggregates [label="stress granule seed", color="#CC0000"]
  TDP43_cyto_edge -> autophagosome   [label="autophagy substrate", color="#E65100"]
  ATXN2         -> TDP43_cyto_edge   [label="phase separation", color="#880000"]
}
