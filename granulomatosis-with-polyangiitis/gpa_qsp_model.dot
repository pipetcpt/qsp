digraph GPA_QSP_Model {
  graph [
    label="Granulomatosis with Polyangiitis (GPA) — Quantitative Systems Pharmacology Model\nANCA-Associated Vasculitis: PR3-ANCA, Neutrophil Activation, Granuloma Formation, Multi-Organ Injury"
    labelloc=t fontsize=22 fontname="Helvetica-Bold"
    rankdir=LR bgcolor="#FAFAFA"
    splines=true nodesep=0.4 ranksep=1.0
    compound=true
  ]
  node [shape=box style="filled,rounded" fontname="Helvetica" fontsize=10]
  edge [fontname="Helvetica" fontsize=9]

  // ─────────────────────────────────────────────────────────────────
  // CLUSTER 1: Genetic & Environmental Risk Factors
  // ─────────────────────────────────────────────────────────────────
  subgraph cluster_genetics {
    label="Genetic & Environmental Risk" style=filled color="#E8F4FD" penwidth=2
    fontname="Helvetica-Bold" fontsize=13

    HLA_DP [label="HLA-DPB1*04:01\n(strongest GPA locus)" fillcolor="#AED6F1" shape=diamond]
    PRTN3 [label="PRTN3 gene\n(PR3 expression level)" fillcolor="#AED6F1"]
    SERPINA1 [label="SERPINA1/α1-antitrypsin\n(PR3 inhibitor deficiency)" fillcolor="#AED6F1"]
    PTPN22 [label="PTPN22 polymorphism\n(lymphocyte signaling)" fillcolor="#AED6F1"]
    Env_trigger [label="Environmental Triggers\n(Staph aureus, silica, nasal carriage)" fillcolor="#D6EAF8" shape=ellipse]
    Nasal_colonization [label="S. aureus Nasal\nColonization (TMP-SMX target)" fillcolor="#D6EAF8"]
    Gut_microbiome [label="Gut Microbiome\nDysbiosis" fillcolor="#D6EAF8"]
  }

  // ─────────────────────────────────────────────────────────────────
  // CLUSTER 2: Innate Immune Activation
  // ─────────────────────────────────────────────────────────────────
  subgraph cluster_innate {
    label="Innate Immune Activation" style=filled color="#FEF9E7" penwidth=2
    fontname="Helvetica-Bold" fontsize=13

    DC_immature [label="Immature\nDendritic Cells" fillcolor="#F9E79F"]
    DC_mature [label="Mature\nDendritic Cells\n(CD80+/CD86+)" fillcolor="#F1C40F"]
    Macrophage_M1 [label="M1 Macrophage\n(pro-inflammatory)" fillcolor="#F39C12" fontcolor=white]
    Macrophage_M2 [label="M2 Macrophage\n(anti-inflammatory)" fillcolor="#F0B27A"]
    NK_cell [label="NK Cell" fillcolor="#FAD7A0"]
    TLR_activation [label="TLR2/TLR4/TLR9\nActivation" fillcolor="#FDEBD0"]
    NLRP3 [label="NLRP3 Inflammasome\nActivation" fillcolor="#FAD7A0"]
    IL1b_innate [label="IL-1β (Innate)" fillcolor="#E8DAEF" shape=ellipse]
    IL18 [label="IL-18" fillcolor="#E8DAEF" shape=ellipse]
    IL12_innate [label="IL-12" fillcolor="#D5DBDB" shape=ellipse]
    IL23 [label="IL-23" fillcolor="#D5DBDB" shape=ellipse]
    TNFa [label="TNF-α" fillcolor="#E74C3C" fontcolor=white shape=ellipse]
    IL6 [label="IL-6" fillcolor="#E74C3C" fontcolor=white shape=ellipse]
    IL8_CXCL8 [label="IL-8/CXCL8\n(Neutrophil Chemoattractant)" fillcolor="#FADBD8" shape=ellipse]
    MCP1_CCL2 [label="MCP-1/CCL2" fillcolor="#FADBD8" shape=ellipse]
  }

  // ─────────────────────────────────────────────────────────────────
  // CLUSTER 3: Adaptive Immunity — T Cells
  // ─────────────────────────────────────────────────────────────────
  subgraph cluster_tcell {
    label="Adaptive Immunity — T Cell Responses" style=filled color="#E8F8F5" penwidth=2
    fontname="Helvetica-Bold" fontsize=13

    Naive_Thelper [label="Naïve CD4+\nT Helper Cell" fillcolor="#A9DFBF"]
    Th1 [label="Th1 Cell\n(IFN-γ, TNF-α)" fillcolor="#27AE60" fontcolor=white]
    Th17 [label="Th17 Cell\n(IL-17A, IL-22)" fillcolor="#1E8449" fontcolor=white]
    Tfh [label="Tfh Cell\n(B cell helper)" fillcolor="#82E0AA"]
    Treg [label="Treg Cell\n(FoxP3+, IL-10)" fillcolor="#A9CCE3"]
    CD8_Teff [label="CD8+ Cytotoxic\nT Cell" fillcolor="#76D7C4"]
    IFNg [label="IFN-γ" fillcolor="#A9DFBF" shape=ellipse]
    IL17A [label="IL-17A" fillcolor="#A9DFBF" shape=ellipse]
    IL17F [label="IL-17F" fillcolor="#A9DFBF" shape=ellipse]
    IL22 [label="IL-22" fillcolor="#A9DFBF" shape=ellipse]
    IL21 [label="IL-21 (Tfh→B cell)" fillcolor="#A9DFBF" shape=ellipse]
    IL10 [label="IL-10 (Treg)" fillcolor="#AED6F1" shape=ellipse]
    TGFb [label="TGF-β" fillcolor="#AED6F1" shape=ellipse]
    CXCR3 [label="CXCR3 (Th1\ntrafficking)" fillcolor="#D5F5E3"]
    CCR6 [label="CCR6 (Th17\ntrafficking)" fillcolor="#D5F5E3"]
  }

  // ─────────────────────────────────────────────────────────────────
  // CLUSTER 4: B Cells and Anti-PR3 ANCA Production
  // ─────────────────────────────────────────────────────────────────
  subgraph cluster_bcell {
    label="B Cell Axis & Anti-PR3 ANCA Production" style=filled color="#F5EEF8" penwidth=2
    fontname="Helvetica-Bold" fontsize=13

    Naive_Bcell [label="Naïve B Cell\n(CD19+CD27-)" fillcolor="#D7BDE2"]
    GC_Bcell [label="Germinal Center\nB Cell" fillcolor="#C39BD3"]
    Memory_Bcell [label="Memory B Cell\n(CD19+CD27+)" fillcolor="#A569BD" fontcolor=white]
    Plasmablast [label="Plasmablast\n(CD38hi)" fillcolor="#884EA0" fontcolor=white]
    LongLived_PC [label="Long-lived Plasma\nCell (LLPC, bone marrow)" fillcolor="#6C3483" fontcolor=white]
    BAFF [label="BAFF/BLyS\n(B cell survival)" fillcolor="#D7BDE2" shape=ellipse]
    APRIL [label="APRIL\n(LLPC survival)" fillcolor="#D7BDE2" shape=ellipse]
    PR3_ANCA_IgG [label="Anti-PR3 ANCA\n(IgG, cANCA pattern)" fillcolor="#9B59B6" fontcolor=white shape=diamond]
    PR3_ANCA_IgA [label="Anti-PR3 ANCA\n(IgA, mucosal)" fillcolor="#C39BD3" shape=diamond]
    MPO_ANCA [label="Anti-MPO ANCA\n(pANCA, <10% in GPA)" fillcolor="#D7BDE2" shape=diamond]
    BCR_signaling [label="BCR Signaling\n(PI3K/BTK)" fillcolor="#E8DAEF"]
    CD20 [label="CD20\n(Rituximab target)" fillcolor="#A569BD" fontcolor=white]
    CD19_marker [label="CD19 (B cell\nmarker/monitoring)" fillcolor="#D7BDE2"]
    CXCL13 [label="CXCL13\n(GC formation)" fillcolor="#E8DAEF" shape=ellipse]
  }

  // ─────────────────────────────────────────────────────────────────
  // CLUSTER 5: Neutrophil Activation & NET Formation
  // ─────────────────────────────────────────────────────────────────
  subgraph cluster_neutrophil {
    label="Neutrophil Activation, Priming & NET Formation" style=filled color="#FDEDEC" penwidth=2
    fontname="Helvetica-Bold" fontsize=13

    Neutrophil_resting [label="Resting\nNeutrophil" fillcolor="#FADBD8"]
    Neutrophil_primed [label="Primed Neutrophil\n(TNF-α/IL-8/C5a)" fillcolor="#F1948A"]
    Neutrophil_activated [label="ANCA-Activated\nNeutrophil" fillcolor="#EC7063" fontcolor=white]
    PR3_surface [label="Membrane PR3\n(surface expression ↑)" fillcolor="#F1948A"]
    MPO_surface [label="Membrane MPO\n(degranulation)" fillcolor="#F1948A"]
    FcgRIIa [label="FcγRIIa\n(ANCA Fc receptor)" fillcolor="#FADBD8"]
    ROS_burst [label="Reactive Oxygen\nSpecies (ROS burst)" fillcolor="#E74C3C" fontcolor=white shape=ellipse]
    NET_formation [label="NETosis\n(NETs: DNA+PR3+MPO)" fillcolor="#C0392B" fontcolor=white]
    Degranulation [label="Granule\nDegranulation\n(protease release)" fillcolor="#E74C3C" fontcolor=white]
    PR3_released [label="Extracellular PR3\n(antigen presentation)" fillcolor="#F5CBA7"]
    MPO_released [label="Extracellular MPO\n(enzyme activity)" fillcolor="#F5CBA7"]
    Elastase [label="Neutrophil Elastase\n(tissue destruction)" fillcolor="#FADBD8"]
    MMP9 [label="MMP-9\n(matrix degradation)" fillcolor="#FADBD8"]
    PAD4 [label="PAD4\n(citrullination in NETs)" fillcolor="#FADBD8"]
    C5aR1 [label="C5aR1\n(Avacopan target)" fillcolor="#E8DAEF" shape=diamond]
    C5a_signal [label="C5a\n(complement fragment)" fillcolor="#D5D8DC" shape=ellipse]
  }

  // ─────────────────────────────────────────────────────────────────
  // CLUSTER 6: Complement System
  // ─────────────────────────────────────────────────────────────────
  subgraph cluster_complement {
    label="Complement System Activation" style=filled color="#EBF5FB" penwidth=2
    fontname="Helvetica-Bold" fontsize=13

    C1q [label="C1q (Classical\nPathway)" fillcolor="#AED6F1"]
    C3 [label="C3" fillcolor="#AED6F1"]
    C3b [label="C3b\n(opsonization)" fillcolor="#85C1E9"]
    C3a [label="C3a\n(anaphylatoxin)" fillcolor="#85C1E9" shape=ellipse]
    C5 [label="C5" fillcolor="#5DADE2"]
    C5a [label="C5a\n(major anaphylatoxin)" fillcolor="#2E86C1" fontcolor=white shape=ellipse]
    C5b [label="C5b" fillcolor="#5DADE2"]
    MAC [label="MAC (C5b-9)\n(cell lysis)" fillcolor="#1A5276" fontcolor=white]
    Properdin [label="Properdin\n(Alternative pathway)" fillcolor="#AED6F1"]
    MBL_pathway [label="MBL Pathway\n(mannose-binding lectin)" fillcolor="#AED6F1"]
    Factor_B [label="Factor B / Factor D\n(Alternative pathway)" fillcolor="#AED6F1"]
    C3_convertase [label="C3 Convertase\n(C3bBb)" fillcolor="#7FB3D3"]
    C5_convertase [label="C5 Convertase\n(C3bBbC3b)" fillcolor="#5DADE2"]
    CD46 [label="CD46 (Membrane\nComplement Regulator)" fillcolor="#D6EAF8"]
    FH [label="Factor H\n(Complement Inhibitor)" fillcolor="#D6EAF8"]
  }

  // ─────────────────────────────────────────────────────────────────
  // CLUSTER 7: Vascular Injury Mechanisms
  // ─────────────────────────────────────────────────────────────────
  subgraph cluster_vascular {
    label="Vascular Injury & Endothelial Dysfunction" style=filled color="#FDF2E9" penwidth=2
    fontname="Helvetica-Bold" fontsize=13

    Endothelial_normal [label="Normal\nEndothelium" fillcolor="#FAD7A0"]
    Endothelial_activated [label="Activated\nEndothelium\n(ICAM-1, VCAM-1↑)" fillcolor="#F0B27A"]
    Endothelial_injured [label="Injured/Necrotic\nEndothelium" fillcolor="#E59866"]
    ICAM1 [label="ICAM-1\n(leukocyte adhesion)" fillcolor="#FDEBD0" shape=ellipse]
    VCAM1 [label="VCAM-1\n(leukocyte adhesion)" fillcolor="#FDEBD0" shape=ellipse]
    vWF [label="vWF release\n(thrombosis risk)" fillcolor="#FDEBD0" shape=ellipse]
    Tissue_Factor [label="Tissue Factor\n(coagulation activation)" fillcolor="#FAD7A0" shape=ellipse]
    Fibrin [label="Fibrin\n(vessel occlusion)" fillcolor="#E59866"]
    Necrosis_fibrinoid [label="Fibrinoid Necrosis\n(vessel wall)" fillcolor="#C0392B" fontcolor=white]
    Thrombosis [label="Thrombosis /\nMicrovascular Occlusion" fillcolor="#C0392B" fontcolor=white]
    VEGF [label="VEGF\n(angiogenesis attempt)" fillcolor="#FDEBD0" shape=ellipse]
    PAI1 [label="PAI-1\n(fibrinolysis inhibitor)" fillcolor="#FAD7A0" shape=ellipse]
    ET1 [label="Endothelin-1\n(vasoconstriction)" fillcolor="#E59866" shape=ellipse]
  }

  // ─────────────────────────────────────────────────────────────────
  // CLUSTER 8: Granuloma Formation
  // ─────────────────────────────────────────────────────────────────
  subgraph cluster_granuloma {
    label="Granuloma Formation (Hallmark of GPA)" style=filled color="#F9F9F9" penwidth=2
    fontname="Helvetica-Bold" fontsize=13

    Granuloma_initiation [label="Granuloma Initiation\n(macrophage clustering)" fillcolor="#BDC3C7"]
    Epithelioid_cell [label="Epithelioid Cell\n(transformed macrophage)" fillcolor="#95A5A6"]
    Multinucleated_GC [label="Multinucleated\nGiant Cell" fillcolor="#717D7E" fontcolor=white]
    Granuloma_necrosis [label="Granuloma with\nNecrosis (necrobiotic)" fillcolor="#616A6B" fontcolor=white]
    Granuloma_microabcess [label="Microabscess\nFormation" fillcolor="#4D5656" fontcolor=white]
    Palisading_neutrophil [label="Palisading\nNeutrophils\n(around necrosis)" fillcolor="#A9CCE3"]
    CD68 [label="CD68+ Macrophage\n(granuloma core)" fillcolor="#95A5A6"]
    CD3_granuloma [label="CD3+ T cells\n(granuloma periphery)" fillcolor="#A9DFBF"]
    IFNg_granuloma [label="IFN-γ\n(granuloma maintenance)" fillcolor="#A9DFBF" shape=ellipse]
    TNFa_granuloma [label="TNF-α\n(granuloma integrity)" fillcolor="#E74C3C" fontcolor=white shape=ellipse]
    IL2 [label="IL-2\n(T cell proliferation)" fillcolor="#A9DFBF" shape=ellipse]
    CD25 [label="CD25 (IL-2Rα)\nTreg marker" fillcolor="#A9DFBF"]
  }

  // ─────────────────────────────────────────────────────────────────
  // CLUSTER 9: Organ-Specific Damage
  // ─────────────────────────────────────────────────────────────────
  subgraph cluster_organ {
    label="Organ-Specific Damage (ENT · Lung · Kidney)" style=filled color="#EAF2FF" penwidth=2
    fontname="Helvetica-Bold" fontsize=13

    // ENT
    ENT_mucosa [label="Upper Airway\nMucosa (ENT)" fillcolor="#AED6F1"]
    Nasal_granuloma [label="Nasal Granuloma\n(saddle-nose deformity)" fillcolor="#85C1E9"]
    Sinus_inflammation [label="Sinusitis /\nSinus Destruction" fillcolor="#7FB3D3"]
    Otitis [label="Otitis Media /\nConductive Hearing Loss" fillcolor="#7FB3D3"]
    Subglottic_stenosis [label="Subglottic Stenosis\n(life-threatening)" fillcolor="#2E86C1" fontcolor=white]

    // Lung
    Lung_parenchyma [label="Lung Parenchyma" fillcolor="#D6EAF8"]
    Pulmonary_nodule [label="Pulmonary Nodules\n(cavitating)" fillcolor="#AED6F1"]
    DAH [label="Diffuse Alveolar\nHemorrhage (DAH)" fillcolor="#2E86C1" fontcolor=white]
    Capillaritis [label="Pulmonary\nCapillaritis" fillcolor="#5DADE2" fontcolor=white]
    FVC_decline [label="FVC Decline\n(spirometry)" fillcolor="#85C1E9"]

    // Kidney
    Glomerulus [label="Glomerulus\n(target in GPA)" fillcolor="#D6EAF8"]
    Mesangium [label="Mesangial\nExpansion" fillcolor="#AED6F1"]
    Pauci_immune_GN [label="Pauci-immune\nCrescentic GN\n(ANCA-GN)" fillcolor="#2E86C1" fontcolor=white]
    Crescent_formation [label="Cellular Crescent\n(parietal cells)" fillcolor="#1A5276" fontcolor=white]
    Bowman_capsule [label="Bowman's Capsule\nRupture" fillcolor="#1A5276" fontcolor=white]
    GFR_decline [label="GFR Decline\n(AKI → CKD)" fillcolor="#1A5276" fontcolor=white]
    Proteinuria [label="Proteinuria\n(hematuria)" fillcolor="#85C1E9"]
    Kidney_fibrosis [label="Interstitial Fibrosis\n(chronic kidney damage)" fillcolor="#7FB3D3"]
  }

  // ─────────────────────────────────────────────────────────────────
  // CLUSTER 10: Drug PK/PD — Induction Therapy
  // ─────────────────────────────────────────────────────────────────
  subgraph cluster_pk_induction {
    label="Drug PK/PD — Induction Therapy" style=filled color="#FEF9E7" penwidth=2
    fontname="Helvetica-Bold" fontsize=13

    // Rituximab
    RTX_dose [label="Rituximab Dose\n(375 mg/m² ×4 wk or\n1000 mg ×2 doses)" fillcolor="#F9E79F" shape=parallelogram]
    RTX_plasma [label="RTX Plasma\n(Cp, mg/L)" fillcolor="#F1C40F"]
    RTX_Kabs [label="RTX Absorption\n(IV bolus / SC depot)" fillcolor="#F1C40F"]
    RTX_CL [label="RTX Clearance\n(CL ~ B cell burden)" fillcolor="#F9E79F"]
    RTX_CD20_bind [label="RTX:CD20\nBinding\n(kon/koff)" fillcolor="#E59866"]
    RTX_ADCC [label="ADCC\n(NK/macrophage\nmediated)" fillcolor="#E59866"]
    RTX_CDC [label="CDC\n(complement-dependent\ncytotoxicity)" fillcolor="#E59866"]
    Bcell_depletion [label="B Cell Depletion\n(CD19+→0, target)" fillcolor="#884EA0" fontcolor=white]

    // Cyclophosphamide
    CYC_dose [label="Cyclophosphamide Dose\n(15 mg/kg IV pulse or\n2 mg/kg/d PO)" fillcolor="#AED6F1" shape=parallelogram]
    CYC_plasma [label="CYC Plasma\n(prodrug)" fillcolor="#5DADE2" fontcolor=white]
    CYC_active [label="Active Metabolite\n(4-OH-CYC / Phosphoramide\nmustard)" fillcolor="#2E86C1" fontcolor=white]
    CYC_alkylation [label="DNA Alkylation\n(lymphocyte apoptosis)" fillcolor="#1A5276" fontcolor=white]
    CYC_gonadotoxicity [label="Gonadotoxicity\n(premature ovarian failure)" fillcolor="#F1948A"]
    CYC_bladder [label="Hemorrhagic Cystitis\n(Mesna prophylaxis)" fillcolor="#F1948A"]
  }

  // ─────────────────────────────────────────────────────────────────
  // CLUSTER 11: Drug PK/PD — Glucocorticoids & Avacopan
  // ─────────────────────────────────────────────────────────────────
  subgraph cluster_pk_gc {
    label="Drug PK/PD — GC Taper & Avacopan" style=filled color="#E8F8F5" penwidth=2
    fontname="Helvetica-Bold" fontsize=13

    // Glucocorticoids
    GC_dose [label="Glucocorticoid Dose\n(Pred 1 mg/kg/d → taper)" fillcolor="#A9DFBF" shape=parallelogram]
    GC_plasma [label="Prednisolone\nPlasma (Cp)" fillcolor="#52BE80" fontcolor=white]
    GR_complex [label="GC:GR Complex\n(nuclear translocate)" fillcolor="#1E8449" fontcolor=white]
    GC_transrepression [label="GC Transrepression\n(↓NF-κB, ↓AP-1)" fillcolor="#1E8449" fontcolor=white]
    GC_transactivation [label="GC Transactivation\n(anti-inflammatory genes)" fillcolor="#27AE60" fontcolor=white]
    GC_ADR [label="GC Adverse Effects:\nDM2, BMD↓, HPA\nsuppression, infection↑" fillcolor="#F1948A"]
    GC_ACTH_suppression [label="ACTH/Cortisol\nSuppression" fillcolor="#FAD7A0"]

    // Avacopan
    Avacopan_dose [label="Avacopan Dose\n(30 mg BID PO)" fillcolor="#E8DAEF" shape=parallelogram]
    Avacopan_plasma [label="Avacopan Plasma\n(Cp, CYP3A4 substrate)" fillcolor="#BB8FCE"]
    Avacopan_C5aR1_block [label="C5aR1 Blockade\n(competitive inhibitor)" fillcolor="#9B59B6" fontcolor=white]
    Avacopan_GC_spare [label="GC-Sparing Effect\n(primary endpoint:\nBVAS remission)" fillcolor="#6C3483" fontcolor=white]
    Avacopan_neutrophil_migr [label="↓Neutrophil\nMigration to Tissue" fillcolor="#D7BDE2"]
  }

  // ─────────────────────────────────────────────────────────────────
  // CLUSTER 12: Maintenance Therapy & Monitoring
  // ─────────────────────────────────────────────────────────────────
  subgraph cluster_maintenance {
    label="Maintenance Therapy & Disease Monitoring" style=filled color="#F4F6F7" penwidth=2
    fontname="Helvetica-Bold" fontsize=13

    // Maintenance
    RTX_maint [label="RTX Maintenance\n(500 mg q6mo ×2 yr)" fillcolor="#F9E79F" shape=parallelogram]
    AZA_dose [label="Azathioprine\n(2 mg/kg/d PO)" fillcolor="#85C1E9" shape=parallelogram]
    MTX_dose [label="Methotrexate\n(20-25 mg/wk)" fillcolor="#AED6F1" shape=parallelogram]
    TMP_SMX [label="TMP-SMX\nProphylaxis\n(anti-Pneumocystis,\nanti-Staph)" fillcolor="#A9DFBF" shape=parallelogram]
    TPMT_testing [label="TPMT/NUDT15\nPharmaacogenomics\n(AZA dose)" fillcolor="#D5DBDB"]

    // Biomarkers
    PR3_ANCA_titer [label="PR3-ANCA Titer\n(disease activity marker)" fillcolor="#9B59B6" fontcolor=white shape=diamond]
    CRP_ESR [label="CRP / ESR\n(acute inflammation)" fillcolor="#E74C3C" fontcolor=white shape=ellipse]
    Creatinine_GFR [label="Serum Creatinine /\neGFR (renal function)" fillcolor="#5DADE2" fontcolor=white]
    ANCA_rise [label="ANCA Rise →\nRelapse Prediction" fillcolor="#C0392B" fontcolor=white shape=diamond]
    Urinalysis [label="Urinalysis:\nhematuria, RBC casts" fillcolor="#7FB3D3"]
    Biopsy_score [label="Renal Biopsy\n(Berden Class)" fillcolor="#5DADE2" fontcolor=white]
    BVAS_score [label="BVAS Score\n(Birmingham Vasculitis\nActivity Score)" fillcolor="#E74C3C" fontcolor=white shape=diamond]
    VDI_score [label="VDI Score\n(Vasculitis Damage\nIndex)" fillcolor="#C0392B" fontcolor=white shape=diamond]
  }

  // ─────────────────────────────────────────────────────────────────
  // CLUSTER 13: Clinical Endpoints & Outcomes
  // ─────────────────────────────────────────────────────────────────
  subgraph cluster_endpoints {
    label="Clinical Endpoints & Outcomes" style=filled color="#F4ECF7" penwidth=2
    fontname="Helvetica-Bold" fontsize=13

    Remission [label="Complete Remission\n(BVAS=0, CRP normal)" fillcolor="#27AE60" fontcolor=white shape=diamond]
    Partial_remission [label="Partial Remission\n(BVAS ≥50% improvement)" fillcolor="#52BE80" fontcolor=white]
    Relapse [label="Disease Relapse\n(major/minor)" fillcolor="#E74C3C" fontcolor=white shape=diamond]
    ESRD [label="ESRD\n(dialysis/transplant)" fillcolor="#922B21" fontcolor=white]
    Mortality [label="All-Cause Mortality\n(infection, CV events)" fillcolor="#641E16" fontcolor=white]
    Infertility [label="Infertility\n(CYC-related)" fillcolor="#F1948A"]
    QoL [label="Quality of Life\n(SF-36, PROMIS)" fillcolor="#A9DFBF"]
    Infection_risk [label="Serious Infection Risk\n(immunosuppression)" fillcolor="#F1948A"]
    Malignancy_risk [label="Secondary Malignancy\n(lymphoma, bladder CA)" fillcolor="#E74C3C" fontcolor=white]
    Remission_rate_18m [label="Sustained Remission\n@18 months (RAVE/RITUXVAS)" fillcolor="#27AE60" fontcolor=white]
  }

  // =================================================================
  // EDGES
  // =================================================================

  // Genetics → Risk
  HLA_DP -> Naive_Thelper [label="HLA-DPB1*04:01\npresents PR3 peptides"]
  PRTN3 -> PR3_surface [label="↑PR3 expression"]
  SERPINA1 -> PR3_released [label="↓PR3 inhibition"]
  PTPN22 -> Naive_Thelper [label="altered TCR\nthreshold"]
  PTPN22 -> Naive_Bcell [label="altered BCR\nthreshold"]
  Env_trigger -> DC_immature [label="danger signals"]
  Nasal_colonization -> TLR_activation [label="S. aureus\nSEB/TLR2"]
  Gut_microbiome -> DC_immature [label="microbial\nmetabolites"]

  // Innate Immunity
  TLR_activation -> DC_mature [label="NF-κB activation"]
  TLR_activation -> NLRP3 [label="priming"]
  NLRP3 -> IL1b_innate [label="caspase-1\ncleavage"]
  NLRP3 -> IL18 [label="caspase-1\ncleavage"]
  DC_immature -> DC_mature [label="maturation"]
  DC_mature -> Naive_Thelper [label="antigen\npresentation\n(MHC-II)"]
  DC_mature -> IL12_innate [label="secretion"]
  DC_mature -> IL23 [label="secretion"]
  Macrophage_M1 -> TNFa [label="secretion"]
  Macrophage_M1 -> IL6 [label="secretion"]
  Macrophage_M1 -> IL8_CXCL8 [label="secretion"]
  Macrophage_M1 -> MCP1_CCL2 [label="secretion"]
  Macrophage_M1 -> IL12_innate [label="secretion"]
  IL1b_innate -> Neutrophil_primed [label="priming"]
  TNFa -> Neutrophil_primed [label="priming ↑"]
  IL8_CXCL8 -> Neutrophil_resting [label="chemotaxis"]
  MCP1_CCL2 -> Macrophage_M1 [label="recruitment"]

  // T Cell Differentiation
  Naive_Thelper -> Th1 [label="IL-12\npolarization"]
  Naive_Thelper -> Th17 [label="IL-6+TGF-β\npolarization"]
