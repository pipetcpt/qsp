digraph OCD_QSP_Model {
  graph [
    rankdir=LR,
    fontname="Helvetica",
    fontsize=11,
    bgcolor="#FAFAFA",
    label="Obsessive-Compulsive Disorder (OCD) — QSP Mechanistic Map\nClinical Pharmacology & Systems Pathophysiology",
    labelloc=t,
    labelfontsize=18,
    labelfontname="Helvetica-Bold",
    nodesep=0.4,
    ranksep=0.8,
    compound=true
  ];
  node [shape=box, style="rounded,filled", fontsize=9, fontname="Helvetica", margin="0.15,0.08"];
  edge [fontsize=8, fontname="Helvetica", arrowsize=0.8];

  // ============================================================
  // CLUSTER 1: SSRI PK
  // ============================================================
  subgraph cluster_ssri_pk {
    label="SSRI Pharmacokinetics";
    style=filled; fillcolor="#E8F4FD"; color="#2E86C1"; penwidth=2;
    fontcolor="#1A5276"; fontsize=11; fontname="Helvetica-Bold";

    SSRI_dose    [label="SSRI Dose\n(mg/day)", shape=diamond, fillcolor="#AED6F1", color="#2E86C1"];
    SSRI_gut     [label="GI Tract\n(Absorption)", fillcolor="#D6EAF8"];
    SSRI_plasma  [label="Plasma\nConcentration Cp\n(ng/mL)", fillcolor="#85C1E9"];
    SSRI_periph  [label="Peripheral\nTissue Cp2", fillcolor="#5DADE2"];
    SSRI_CNS     [label="CNS\nConcentration\nCcns", fillcolor="#2E86C1", fontcolor=white];
    SSRI_metab   [label="Inactive\nMetabolite", fillcolor="#AED6F1"];
    CYP2D6       [label="CYP2D6\n(Sertraline\nNorsertraline)", fillcolor="#D6EAF8"];
    CYP3A4       [label="CYP3A4\n(Fluoxetine\nFluvoxamine)", fillcolor="#D6EAF8"];
    SSRI_protein [label="Protein\nBinding\n(97–99%)", fillcolor="#EBF5FB"];
    F_oral       [label="Oral\nBioavailability\n(44–90%)", fillcolor="#D6EAF8"];
    BBB_transport[label="Blood-Brain\nBarrier\nTransport", fillcolor="#85C1E9"];
    Half_life    [label="t½\n(22–36 h)", fillcolor="#EBF5FB"];

    SSRI_dose -> F_oral -> SSRI_gut;
    SSRI_gut -> SSRI_plasma [label="ka"];
    SSRI_plasma -> SSRI_periph [label="Q"];
    SSRI_periph -> SSRI_plasma [label="Q"];
    SSRI_plasma -> SSRI_protein;
    SSRI_plasma -> BBB_transport -> SSRI_CNS;
    SSRI_plasma -> CYP2D6 -> SSRI_metab;
    SSRI_plasma -> CYP3A4 -> SSRI_metab;
    SSRI_plasma -> Half_life;
  }

  // ============================================================
  // CLUSTER 2: Clomipramine PK
  // ============================================================
  subgraph cluster_clomi_pk {
    label="Clomipramine PK";
    style=filled; fillcolor="#F5EEF8"; color="#7D3C98"; penwidth=2;
    fontcolor="#4A235A"; fontsize=11; fontname="Helvetica-Bold";

    CMI_dose     [label="Clomipramine\nDose (mg/day)", shape=diamond, fillcolor="#D7BDE2", color="#7D3C98"];
    CMI_gut      [label="GI Absorption", fillcolor="#E8DAEF"];
    CMI_first    [label="First-pass\nEffect (60%)", fillcolor="#C39BD3"];
    CMI_plasma   [label="CMI Plasma\nCp_CMI", fillcolor="#A569BD", fontcolor=white];
    CMI_active   [label="DCMI (Active\nMetabolite)\nDesmethylclomipramine", fillcolor="#7D3C98", fontcolor=white];
    CMI_CYP1A2   [label="CYP1A2\nN-demethylation", fillcolor="#E8DAEF"];
    CMI_protein  [label="Protein\nBinding\n(~97%)", fillcolor="#E8DAEF"];
    CMI_CNS      [label="CMI CNS\nConcentration", fillcolor="#A569BD", fontcolor=white];
    CMI_halflife [label="t½ CMI\n32 h / DCMI 69 h", fillcolor="#E8DAEF"];

    CMI_dose -> CMI_gut -> CMI_first -> CMI_plasma;
    CMI_plasma -> CMI_CYP1A2 -> CMI_active;
    CMI_plasma -> CMI_protein;
    CMI_plasma -> CMI_CNS;
    CMI_plasma -> CMI_halflife;
  }

  // ============================================================
  // CLUSTER 3: Augmentation Agents PK
  // ============================================================
  subgraph cluster_aug_pk {
    label="Augmentation Agent PK";
    style=filled; fillcolor="#FEF9E7"; color="#D35400"; penwidth=2;
    fontcolor="#784212"; fontsize=11; fontname="Helvetica-Bold";

    RISP_dose    [label="Risperidone\nDose (mg/day)", shape=diamond, fillcolor="#FAD7A0", color="#D35400"];
    RISP_plasma  [label="Risperidone\nPlasma Cp_RISP", fillcolor="#F8C471"];
    RISP_9OH     [label="9-OH-Risperidone\n(Active Metabolite)", fillcolor="#F39C12", fontcolor=white];
    ARIP_dose    [label="Aripiprazole\nDose (mg/day)", shape=diamond, fillcolor="#FAD7A0", color="#D35400"];
    ARIP_plasma  [label="Aripiprazole\nPlasma Cp_ARIP", fillcolor="#F8C471"];
    MEM_dose     [label="Memantine\nDose (mg/day)", shape=diamond, fillcolor="#FAD7A0", color="#D35400"];
    MEM_plasma   [label="Memantine\nPlasma Cp_MEM", fillcolor="#F8C471"];
    DCS_dose     [label="D-Cycloserine\nDose (mg, PRN)", shape=diamond, fillcolor="#FAD7A0", color="#D35400"];
    DCS_plasma   [label="DCS Plasma\nCp_DCS", fillcolor="#F8C471"];

    RISP_dose -> RISP_plasma -> RISP_9OH;
    ARIP_dose -> ARIP_plasma;
    MEM_dose -> MEM_plasma;
    DCS_dose -> DCS_plasma;
  }

  // ============================================================
  // CLUSTER 4: Serotonin System
  // ============================================================
  subgraph cluster_5ht {
    label="Serotonin (5-HT) System";
    style=filled; fillcolor="#FDEDEC"; color="#E74C3C"; penwidth=2;
    fontcolor="#922B21"; fontsize=11; fontname="Helvetica-Bold";

    Trp_diet     [label="Tryptophan\n(Dietary)", fillcolor="#FADBD8"];
    Trp_plasma   [label="Plasma\nTryptophan", fillcolor="#F5B7B1"];
    Trp_brain    [label="Brain\nTryptophan\nUptake (LAT1)", fillcolor="#EC7063"];
    TPH2         [label="TPH2\n(Tryptophan\nHydroxylase 2)", fillcolor="#E74C3C", fontcolor=white];
    X5HTP        [label="5-HTP\n(5-Hydroxytryptophan)", fillcolor="#CB4335", fontcolor=white];
    AADC_5ht     [label="AADC\n(Aromatic L-amino\nAcid Decarboxylase)", fillcolor="#E74C3C", fontcolor=white];
    HT5_synth    [label="5-HT Synthesis\n(Raphe Nuclei)", fillcolor="#922B21", fontcolor=white];
    VMAT2_5ht    [label="VMAT2\n(Vesicular 5-HT\nStorage)", fillcolor="#B03A2E", fontcolor=white];
    HT5_release  [label="Serotonin\nRelease\n(Action Potential)", fillcolor="#CB4335", fontcolor=white];
    HT5_syn      [label="Synaptic [5-HT]\n(NORMALIZED)", fillcolor="#E74C3C", fontcolor=white, penwidth=2];
    SERT_free    [label="Free SERT\n(Unbound Transporter)", fillcolor="#F1948A"];
    SERT_occ     [label="SERT\nOccupancy\n(≥80% needed)", fillcolor="#EC7063", penwidth=2];
    HT5_reuptake [label="5-HT\nReuptake\n(Blocked by SSRI)", fillcolor="#E74C3C", fontcolor=white];
    MAO_A        [label="MAO-A\nDegradation", fillcolor="#922B21", fontcolor=white];
    X5HIAA       [label="5-HIAA\n(CSF Marker)", fillcolor="#B03A2E", fontcolor=white];
    HT1A_pre     [label="5-HT1A\nSomatodendritic\nAutoreceptor", fillcolor="#F1948A"];
    HT1A_des     [label="5-HT1A\nDesensitization\n(2–4 weeks)", fillcolor="#EC7063"];
    HT1D_term    [label="5-HT1D\nTerminal\nAutoreceptor", fillcolor="#F5B7B1"];
    HT2A_post    [label="5-HT2A\nPostsynaptic\nReceptor", fillcolor="#F1948A"];
    HT2C_post    [label="5-HT2C\nPostsynaptic\nReceptor", fillcolor="#F1948A"];
    HT3_ion      [label="5-HT3\nIonotropic\nReceptor", fillcolor="#FADBD8"];
    HT4_post     [label="5-HT4\nReceptor\n(GI motility)", fillcolor="#FADBD8"];

    Trp_diet -> Trp_plasma -> Trp_brain;
    Trp_brain -> TPH2 -> X5HTP -> AADC_5ht -> HT5_synth;
    HT5_synth -> VMAT2_5ht -> HT5_release -> HT5_syn;
    HT5_syn -> HT5_reuptake -> VMAT2_5ht [label="Recycled"];
    SERT_free -> HT5_reuptake [label="Transporter"];
    HT5_syn -> MAO_A -> X5HIAA;
    HT5_syn -> HT1A_pre [label="↓ Release"];
    HT1A_pre -> HT1A_des [label="Chronic SSRI"];
    HT5_syn -> HT1D_term [label="↓ Release"];
    HT5_syn -> HT2A_post [label="Postsynaptic"];
    HT5_syn -> HT2C_post;
    HT5_syn -> HT3_ion;
    HT5_syn -> HT4_post;
  }

  // ============================================================
  // CLUSTER 5: Dopamine System
  // ============================================================
  subgraph cluster_da {
    label="Dopamine System";
    style=filled; fillcolor="#EAFAF1"; color="#1E8449"; penwidth=2;
    fontcolor="#145A32"; fontsize=11; fontname="Helvetica-Bold";

    Tyr_diet     [label="Tyrosine\n(Dietary)", fillcolor="#D5F5E3"];
    TH_enz       [label="TH\n(Tyrosine\nHydroxylase)", fillcolor="#A9DFBF"];
    LDOPA        [label="L-DOPA", fillcolor="#82E0AA"];
    AADC_da      [label="AADC", fillcolor="#58D68D", fontcolor=white];
    DA_synth_vta [label="DA Synthesis\n(VTA / SNc)", fillcolor="#2ECC71", fontcolor=white];
    VMAT2_da     [label="VMAT2\n(Vesicular DA)", fillcolor="#27AE60", fontcolor=white];
    DA_release   [label="DA Release\n(Mesolimbic /\nMesocortical)", fillcolor="#1E8449", fontcolor=white];
    DA_striatum  [label="Striatal\n[Dopamine]", fillcolor="#2ECC71", fontcolor=white, penwidth=2];
    DA_OFC       [label="OFC/PFC\n[Dopamine]", fillcolor="#58D68D", fontcolor=white];
    DAT_trans    [label="DAT\n(Dopamine\nTransporter)", fillcolor="#A9DFBF"];
    DA_reuptake  [label="DA Reuptake", fillcolor="#82E0AA"];
    COMT_enz     [label="COMT\n(Catechol-O-\nMethyltransferase)", fillcolor="#27AE60", fontcolor=white];
    MAOB_enz     [label="MAO-B\nDegradation", fillcolor="#1E8449", fontcolor=white];
    HVA_mark     [label="HVA (Homovanillic\nAcid, Biomarker)", fillcolor="#A9DFBF"];
    D1R_str      [label="D1 Receptor\n(Direct/Go\nPathway)", fillcolor="#ABEBC6", penwidth=2];
    D2R_str      [label="D2 Receptor\n(Indirect/No-Go\nPathway)", fillcolor="#ABEBC6", penwidth=2];
    D1R_OFC      [label="D1R (OFC/PFC)\nWorking Memory", fillcolor="#D5F5E3"];
    D2R_occ      [label="D2R\nOccupancy\n(Antipsychotic)", fillcolor="#82E0AA", penwidth=2];

    Tyr_diet -> TH_enz -> LDOPA -> AADC_da -> DA_synth_vta;
    DA_synth_vta -> VMAT2_da -> DA_release;
    DA_release -> DA_striatum;
    DA_release -> DA_OFC;
    DA_striatum -> DAT_trans -> DA_reuptake -> VMAT2_da;
    DA_striatum -> COMT_enz;
    DA_striatum -> MAOB_enz;
    COMT_enz -> HVA_mark;
    MAOB_enz -> HVA_mark;
    DA_striatum -> D1R_str [label="Activates"];
    DA_striatum -> D2R_str [label="Activates"];
    DA_OFC -> D1R_OFC;
  }

  // ============================================================
  // CLUSTER 6: Glutamate/GABA System
  // ============================================================
  subgraph cluster_glu_gaba {
    label="Glutamate / GABA System";
    style=filled; fillcolor="#F4ECF7"; color="#6C3483"; penwidth=2;
    fontcolor="#4A235A"; fontsize=11; fontname="Helvetica-Bold";

    Gln_astro    [label="Glutamine\n(Astrocyte)", fillcolor="#D7BDE2"];
    Glu_pool     [label="Presynaptic\nGlutamate Pool", fillcolor="#C39BD3"];
    Glu_OFC      [label="OFC\nGlutamate\n(HYPERACTIVE)", fillcolor="#8E44AD", fontcolor=white, penwidth=2];
    Glu_str_syn  [label="Corticostriatal\nGlutamate\nSynapse", fillcolor="#A569BD", fontcolor=white];
    NMDA_R       [label="NMDA\nReceptor\n(GluN2B)", fillcolor="#7D3C98", fontcolor=white];
    AMPA_R       [label="AMPA\nReceptor", fillcolor="#8E44AD", fontcolor=white];
    mGluR2_3     [label="mGluR2/3\n(Presynaptic)", fillcolor="#A569BD", fontcolor=white];
    mGluR5       [label="mGluR5\n(Postsynaptic)", fillcolor="#A569BD", fontcolor=white];
    EAAT_glu     [label="EAAT\n(Glutamate\nReuptake)", fillcolor="#C39BD3"];
    Gln_cycle    [label="Glutamine-\nGlutamate\nCycle", fillcolor="#D7BDE2"];
    GAD67        [label="GAD67\n(GABA Synthesis)", fillcolor="#E8DAEF"];
    GABA_pool    [label="GABAergic\nInterneuron", fillcolor="#D7BDE2"];
    GABA_A_R     [label="GABA-A\nReceptor\n(Ionotropic)", fillcolor="#E8DAEF"];
    GABA_B_R     [label="GABA-B\nReceptor\n(Metabotropic)", fillcolor="#E8DAEF"];
    Gly_coag     [label="Glycine\nCo-agonist\n(NMDA)", fillcolor="#E8DAEF"];
    DCS_target   [label="DCS Binding\nSite (NMDA\nGly site)", fillcolor="#F4ECF7"];

    Gln_astro -> Glu_pool -> Glu_OFC -> Glu_str_syn;
    Glu_str_syn -> NMDA_R;
    Glu_str_syn -> AMPA_R;
    Glu_str_syn -> mGluR2_3;
    Glu_str_syn -> mGluR5;
    NMDA_R -> EAAT_glu -> Gln_cycle -> Gln_astro;
    GAD67 -> GABA_pool;
    GABA_pool -> GABA_A_R;
    GABA_pool -> GABA_B_R;
    Gly_coag -> NMDA_R [label="Co-agonist"];
    Gly_coag -> DCS_target;
  }

  // ============================================================
  // CLUSTER 7: CSTC Circuit
  // ============================================================
  subgraph cluster_cstc {
    label="CSTC Circuit (Cortico-Striato-Thalamo-Cortical)";
    style=filled; fillcolor="#EBF5FB"; color="#1F618D"; penwidth=2;
    fontcolor="#154360"; fontsize=11; fontname="Helvetica-Bold";

    OFC_node     [label="Orbitofrontal\nCortex (OFC)\n★ HYPERACTIVE ★", fillcolor="#2E86C1", fontcolor=white, penwidth=3, shape=ellipse];
    ACC_node     [label="Anterior\nCingulate\nCortex (ACC)", fillcolor="#85C1E9"];
    DLPFC_node   [label="Dorsolateral\nPFC (DLPFC)", fillcolor="#AED6F1"];
    Caudate_node [label="Caudate\nNucleus\n(↑ Hypermetabolism)", fillcolor="#5DADE2", fontcolor=white, penwidth=2];
    Putamen_node [label="Putamen\n(Sensorimotor)", fillcolor="#5DADE2", fontcolor=white];
    Striatum_all [label="Striatum\n(Input Nucleus)", fillcolor="#3498DB", fontcolor=white];
    Direct_path  [label="Direct (Go)\nPathway D1\n↑↑ OCD", fillcolor="#1A5276", fontcolor=white, penwidth=2];
    Indirect_path[label="Indirect (No-Go)\nPathway D2\n↓↓ OCD", fillcolor="#1F618D", fontcolor=white, penwidth=2];
    GPi_SNr      [label="GPi / SNr\n(Output)", fillcolor="#1A5276", fontcolor=white];
    GPe_node     [label="GPe\n(Indirect relay)", fillcolor="#2E86C1", fontcolor=white];
    STN_node     [label="Subthalamic\nNucleus (STN)\n(Hyperdirect)", fillcolor="#2E86C1", fontcolor=white];
    MD_thalamus  [label="MD Thalamus\n(Mediodorsal\nNucleus)", fillcolor="#154360", fontcolor=white, penwidth=2];
    Amygdala_node[label="Amygdala\n(Fear/Threat\nProcessing)", fillcolor="#85C1E9", penwidth=2];
    Hippo_node   [label="Hippocampus\n(Episodic\nMemory)", fillcolor="#AED6F1"];
    Insula_node  [label="Insula\n(Interoception\nDiscomfort)", fillcolor="#85C1E9"];
    SMA_node     [label="Supplementary\nMotor Area\n(Action Initiation)", fillcolor="#AED6F1"];
    DBS_target   [label="DBS Target:\nVC/VS or STN", shape=diamond, fillcolor="#5DADE2", fontcolor=white];

    OFC_node -> Caudate_node [label="Glu (++)\nHyper", color="#E74C3C", penwidth=2];
    OFC_node -> ACC_node;
    ACC_node -> Striatum_all;
    DLPFC_node -> Striatum_all;
    DLPFC_node -> OFC_node [label="Top-down\nControl", color="#1E8449"];
    Caudate_node -> Direct_path;
    Caudate_node -> Indirect_path;
    Striatum_all -> Direct_path;
    Striatum_all -> Indirect_path;
    Direct_path -> GPi_SNr [label="Inhibit\n(GABAergic)", color="#2980B9"];
    Indirect_path -> GPe_node [label="Inhibit"];
    GPe_node -> STN_node [label="Inhibit"];
    STN_node -> GPi_SNr [label="Excite\n(Glutamate)"];
    GPi_SNr -> MD_thalamus [label="Tonic\nInhibit", color="#2980B9"];
    MD_thalamus -> OFC_node [label="Excite\n(Loop ↻)", color="#E74C3C", penwidth=2];
    MD_thalamus -> DLPFC_node [label="Excite"];
    Amygdala_node -> OFC_node [label="Threat\nSignal", color="#E74C3C"];
    Hippo_node -> OFC_node [label="Contextual\nMemory"];
    Insula_node -> ACC_node;
    SMA_node -> Putamen_node;
    OFC_node -> Insula_node [label="Distress\nAmplify"];
    STN_node -> DBS_target;
  }

  // ============================================================
  // CLUSTER 8: HPA Axis & Stress
  // ============================================================
  subgraph cluster_hpa {
    label="HPA Axis & Stress Response";
    style=filled; fillcolor="#FEF5E7"; color="#E67E22"; penwidth=2;
    fontcolor="#784212"; fontsize=11; fontname="Helvetica-Bold";

    Stress_trigger [label="Psychological\nStress / Trigger", shape=diamond, fillcolor="#FAD7A0", color="#E67E22"];
    CRH_hypo      [label="CRH\n(Hypothalamus)", fillcolor="#F8C471"];
    ACTH_pit      [label="ACTH\n(Anterior\nPituitary)", fillcolor="#F39C12", fontcolor=white];
    Cortisol_adre [label="Cortisol\n(Adrenal Gland)", fillcolor="#D35400", fontcolor=white];
    GR_brain      [label="Glucocorticoid\nReceptor (GR)\nin Brain", fillcolor="#FAD7A0"];
    BDNF_reduce   [label="BDNF ↓\n(Cortisol-induced)", fillcolor="#F8C471"];
    Hippo_atrophy [label="Hippocampal\nAtrophy", fillcolor="#F39C12", fontcolor=white];
    Anxiety_loop  [label="Anxiety/\nWorry State", fillcolor="#FDEBD0", penwidth=2];
    OCD_trigger   [label="OCD Symptom\nTrigger/Worsening", fillcolor="#E59866"];
    Immune_act    [label="Immune\nActivation\n(Cortisol +\nInflammation)", fillcolor="#FAD7A0"];

    Stress_trigger -> CRH_hypo -> ACTH_pit -> Cortisol_adre;
    Cortisol_adre -> GR_brain;
    Cortisol_adre -> BDNF_reduce;
    Cortisol_adre -> Hippo_atrophy;
    GR_brain -> Anxiety_loop;
    Anxiety_loop -> OCD_trigger;
    Stress_trigger -> Anxiety_loop;
    Cortisol_adre -> Immune_act;
  }

  // ============================================================
  // CLUSTER 9: Neuroinflammation
  // ============================================================
  subgraph cluster_neuroinflamm {
    label="Neuroinflammation";
    style=filled; fillcolor="#FDEDEC"; color="#C0392B"; penwidth=2;
    fontcolor="#7B241C"; fontsize=11; fontname="Helvetica-Bold";

    Microglia_act  [label="Microglia\nActivation\n(M1 phenotype)", fillcolor="#F1948A"];
    Astrocyte_dys  [label="Astrocyte\nDysfunction", fillcolor="#F1948A"];
    TNFa_brain     [label="TNF-α\n(Brain)", fillcolor="#E74C3C", fontcolor=white];
    IL6_brain      [label="IL-6\n(Brain)", fillcolor="#E74C3C", fontcolor=white];
    IL1b_brain     [label="IL-1β\n(Brain)", fillcolor="#E74C3C", fontcolor=white];
    IL12_brain     [label="IL-12\n(Brain)", fillcolor="#EC7063"];
    CRP_sys        [label="CRP\n(Systemic\nElevated)", fillcolor="#F5B7B1"];
    IDO_pathway    [label="IDO\nActivation\n(Tryptophan\nDepletion)", fillcolor="#CB4335", fontcolor=white];
    Kynurenine_p   [label="Kynurenine\nPathway", fillcolor="#B03A2E", fontcolor=white];
    QUIN_acid      [label="Quinolinic\nAcid\n(NMDA Agonist)", fillcolor="#922B21", fontcolor=white];
    KYNA_acid      [label="Kynurenic Acid\n(NMDA/nAChR\nAntagonist)", fillcolor="#B03A2E", fontcolor=white];
    BBB_perm       [label="BBB\nPermeability ↑", fillcolor="#F1948A"];
    PANDAS_strep   [label="PANDAS\n(Post-Streptococcal\nAutoimmune)", fillcolor="#FADBD8"];
    Anti_BG_ab     [label="Anti-Basal\nGanglia\nAntibodies", fillcolor="#F5B7B1"];
    Oxidative_st   [label="Oxidative\nStress\nROS ↑", fillcolor="#F1948A"];

    Microglia_act -> TNFa_brain;
    Microglia_act -> IL6_brain;
    Microglia_act -> IL1b_brain;
    Microglia_act -> IL12_brain;
    Astrocyte_dys -> BBB_perm;
    TNFa_brain -> IDO_pathway;
    IL6_brain -> CRP_sys;
    IL1b_brain -> IDO_pathway;
    IDO_pathway -> Kynurenine_p;
    Kynurenine_p -> QUIN_acid;
    Kynurenine_p -> KYNA_acid;
    BBB_perm -> Microglia_act [label="Feedback"];
    PANDAS_strep -> Anti_BG_ab;
    Anti_BG_ab -> Caudate_node [label="Molecular\nMimicry", color="#C0392B"];
    Oxidative_st -> Microglia_act;
    Oxidative_st -> TNFa_brain;
  }

  // ============================================================
  // CLUSTER 10: Neuroplasticity
  // ============================================================
  subgraph cluster_neuroplas {
    label="Neuroplasticity & Molecular Signaling";
    style=filled; fillcolor="#EAECEE"; color="#566573"; penwidth=2;
    fontcolor="#2C3E50"; fontsize=11; fontname="Helvetica-Bold";

    BDNF_node    [label="BDNF\n(Brain-Derived\nNeurotrophic Factor)", fillcolor="#BFC9CA", penwidth=2];
    TrkB_R       [label="TrkB\nReceptor\nSignaling", fillcolor="#ABB2B9"];
    CREB_tf      [label="CREB\nTranscription\nFactor", fillcolor="#979A9A"];
    ERK_path     [label="ERK/MAPK\nPathway", fillcolor="#ABB2B9"];
    PI3K_AKT     [label="PI3K/AKT/\nmTOR Pathway", fillcolor="#979A9A"];
    Dendritic_sp [label="Dendritic Spine\nRemodeling\nSynaptic Density", fillcolor="#7F8C8D", fontcolor=white];
    LTP_syn      [label="LTP\n(Long-Term\nPotentiation)", fillcolor="#ABB2B9"];
    LTD_syn      [label="LTD\n(Long-Term\nDepression)", fillcolor="#ABB2B9"];
    Neurogenesis_h[label="Hippocampal\nNeurogenesis ↑\n(Chronic SSRI)", fillcolor="#CCD1D1"];
    SRC_kin      [label="Src Kinase\n(NMDA\nPhosphorylation)", fillcolor="#BFC9CA"];
    ARC_gene     [label="Arc/Arg3.1\n(Synaptic\nPlasticity Gene)", fillcolor="#CCD1D1"];
    White_matter [label="White Matter\nMyelination\n(OFC-Caudate)", fillcolor="#D5D8DC"];

    BDNF_node -> TrkB_R -> ERK_path;
    TrkB_R -> PI3K_AKT;
    ERK_path -> CREB_tf;
    PI3K_AKT -> CREB_tf;
    CREB_tf -> Neurogenesis_h;
    CREB_tf -> ARC_gene;
    PI3K_AKT -> Dendritic_sp;
    Dendritic_sp -> LTP_syn;
    Dendritic_sp -> LTD_syn;
    SRC_kin -> NMDA_R [label="Modulates"];
    LTP_syn -> White_matter;
    ARC_gene -> Dendritic_sp;
  }

  // ============================================================
  // CLUSTER 11: CBT / ERP Therapeutic Mechanisms
  // ============================================================
  subgraph cluster_cbt {
    label="CBT / ERP Therapeutic Mechanisms";
    style=filled; fillcolor="#EAFAF1"; color="#1A5276"; penwidth=2;
    fontcolor="#145A32"; fontsize=11; fontname="Helvetica-Bold";

    ERP_session  [label="ERP Session\n(Exposure &\nResponse Prevention)", shape=diamond, fillcolor="#A9DFBF", color="#1E8449"];
    Inhib_learn  [label="Inhibitory\nLearning\n(New Safe Memory)", fillcolor="#82E0AA"];
    Fear_extinct [label="Fear\nExtinction\n(vmPFC-Amygdala)", fillcolor="#58D68D", fontcolor=white];
    Habit_break  [label="Habit Breaking\n(Compulsion\nReduction)", fillcolor="#2ECC71", fontcolor=white];
    Cog_reappr   [label="Cognitive\nReappraisal\n(DLPFC ↑)", fillcolor="#27AE60", fontcolor=white];
    Meta_cog     [label="Metacognition\n(Belief about\nObsessions)", fillcolor="#A9DFBF"];
    IL_2Proc     [label="IL 2-Process\nModel\n(Inhibitory)", fillcolor="#82E0AA"];
    OFC_downreg  [label="OFC Activity\nNormalization", fillcolor="#1E8449", fontcolor=white];
    Caud_downreg [label="Caudate\nMetabolism ↓\n(Post-CBT)", fillcolor="#27AE60", fontcolor=white];
    DCS_enhance  [label="D-Cycloserine\nERP Augmentation\n(5× dose PRN)", fillcolor="#ABEBC6"];
    Acceptance   [label="Acceptance &\nCommitment\n(ACT)", fillcolor="#D5F5E3"];
    Response_prev[label="Response\nPrevention\n(No compulsion)", fillcolor="#58D68D", fontcolor=white];

    ERP_session -> Inhib_learn;
    ERP_session -> Response_prev;
    Inhib_learn -> Fear_extinct;
    Inhib_learn -> Habit_break;
    Response_prev -> Habit_break;
    ERP_session -> Cog_reappr;
    Cog_reappr -> Meta_cog;
    Meta_cog -> IL_2Proc;
    IL_2Proc -> Inhib_learn;
    Cog_reappr -> OFC_downreg;
    Habit_break -> Caud_downreg;
    DCS_enhance -> Fear_extinct [label="Enhances\nConsolidation"];
    DCS_plasma -> DCS_target [label="Partial\nAgonist"];
    DCS_target -> Fear_extinct;
    Acceptance -> Meta_cog;
  }

  // ============================================================
  // CLUSTER 12: Clinical Endpoints & Assessment
  // ============================================================
  subgraph cluster_clinical {
    label="Clinical Endpoints & Assessment";
    style=filled; fillcolor="#F8F9FA"; color="#2C3E50"; penwidth=2;
    fontcolor="#1A252F"; fontsize=11; fontname="Helvetica-Bold";

    YBOCS_total  [label="Y-BOCS\nTotal Score\n(0–40)", shape=ellipse, fillcolor="#AED6F1", penwidth=3];
    YBOCS_obs    [label="Y-BOCS\nObsession\nSubscale (0–20)", fillcolor="#D6EAF8"];
    YBOCS_comp   [label="Y-BOCS\nCompulsion\nSubscale (0–20)", fillcolor="#D6EAF8"];
    CGI_S        [label="CGI-S\n(Severity)", fillcolor="#85C1E9"];
    CGI_I        [label="CGI-I\n(Improvement)", fillcolor="#85C1E9"];
    OCI_R        [label="OCI-R\n(Self-report)", fillcolor="#AED6F1"];
    MADRS_score  [label="MADRS\n(Depression\nComorbidity)", fillcolor="#D6EAF8"];
    Response_crit[label="Response\n(≥35%\nY-BOCS ↓)", shape=ellipse, fillcolor="#82E0AA", penwidth=2];
    Remission    [label="Remission\n(Y-BOCS ≤12)", shape=ellipse, fillcolor="#2ECC71", fontcolor=white, penwidth=2];
    Partial_resp [label="Partial\nResponse\n(25–35% ↓)", fillcolor="#A9DFBF"];
    Nonresponse  [label="Non-Response\n(<25% ↓)", fillcolor="#F1948A"];
    QoL_score    [label="QoL (SF-36\nQ-LES-Q)", fillcolor="#AED6F1"];
    GAF_score    [label="GAF\n(Global\nFunctioning)", fillcolor="#D6EAF8"];
    Relapse_rate [label="Relapse Rate\n(Discontinuation)", fillcolor="#E74C3C", fontcolor=white];
    Functional_imp[label="Functional\nImpairment\n(Work/Social)", fillcolor="#F5B7B1"];

    YBOCS_obs -> YBOCS_total;
    YBOCS_comp -> YBOCS_total;
    YBOCS_total -> CGI_S;
    YBOCS_total -> CGI_I;
    YBOCS_total -> OCI_R;
    YBOCS_total -> Response_crit;
    YBOCS_total -> Remission;
    YBOCS_total -> Partial_resp;
    YBOCS_total -> Nonresponse;
    Remission -> QoL_score [label="Improves"];
    Response_crit -> GAF_score;
    Remission -> Relapse_rate [label="Risk ↓"];
    YBOCS_total -> Functional_imp;
    Functional_imp -> QoL_score;
  }

  // ============================================================
  // CLUSTER 13: Genetic & Biomarker Factors
  // ============================================================
  subgraph cluster_genetic {
    label="Genetic & Biomarker Factors";
    style=filled; fillcolor="#F2F3F4"; color="#7F8C8D"; penwidth=2;
    fontcolor="#2C3E50"; fontsize=11; fontname="Helvetica-Bold";

    SLC6A4_var   [label="SLC6A4\n(SERT gene)\n5-HTTLPR", fillcolor="#E5E8E8"];
    HTR2A_var    [label="HTR2A\n(5-HT2A gene)\n102T/C", fillcolor="#E5E8E8"];
    COMT_var     [label="COMT\nVal158Met\nPolymorphism", fillcolor="#D7DBDD"];
    BDNF_var     [label="BDNF\nVal66Met\nVariant", fillcolor="#D7DBDD"];
    SLC1A1_var   [label="SLC1A1\n(EAAT3 gene)\nGlu Transporter", fillcolor="#CCD1D1"];
    SAPAP3_var   [label="SAPAP3\n(DLGAP3)\nSynapse Scaffolding", fillcolor="#BFC9CA"];
    SLITRK5_var  [label="SLITRK5\nOCD Mouse Model\nGene", fillcolor="#BFC9CA"];
    OFC_GMV      [label="OFC Gray\nMatter Volume\n(↑ in OCD)", fillcolor="#CCD1D1"];
    Caudate_GMV  [label="Caudate\nVolume (↑)", fillcolor="#CCD1D1"];
    Cingulate_GMV[label="ACC Volume\n(↑)", fillcolor="#D7DBDD"];
    fMRI_resting [label="fMRI Resting\nState Connectivity\n(↑ CSTC)", fillcolor="#BFC9CA"];
    PET_SERT     [label="PET SERT\nBinding\n(↓ OCD)", fillcolor="#ABB2B9"];
    PET_Glu      [label="MRS Glutamate\n(↑ Caudate,\n↓ ACC)", fillcolor="#ABB2B9"];

    SLC6A4_var -> SERT_free [label="Modulates\nExpression", style=dashed];
    HTR2A_var -> HT2A_post [style=dashed];
    COMT_var -> COMT_enz [style=dashed];
    BDNF_var -> BDNF_node [style=dashed];
    SLC1A1_var -> EAAT_glu [style=dashed];
    SAPAP3_var -> NMDA_R [style=dashed];
    OFC_GMV -> OFC_node [label="Structural\nCorrelate", style=dashed];
    Caudate_GMV -> Caudate_node [style=dashed];
    Cingulate_GMV -> ACC_node [style=dashed];
  }

  // ============================================================
  // CROSS-CLUSTER PHARMACODYNAMIC CONNECTIONS
  // ============================================================

  // SSRI → Serotonin system
  SSRI_CNS -> SERT_occ [label="Blocks SERT\n(IC50~1 ng/mL)", color="#2E86C1", penwidth=2];
  SERT_occ -> HT5_reuptake [label="Inhibits ↓", color="#2E86C1", penwidth=2];
  SERT_occ -> HT5_syn [label="↑ Synaptic 5-HT", color="#2E86C1"];
  HT5_syn -> HT1A_des [label="Chronic: desensitize\nAutoreceptor (2–4 wks)"];
  HT1A_des -> HT5_syn [label="↑ Release\n(Delayed Response)", color="#1E8449"];

  // Clomipramine → Serotonin + extra
  CMI_CNS -> SERT_free [label="SERT Block\n(Most Potent)", color="#7D3C98", penwidth=2];
  CMI_active -> SERT_free [label="DCMI also\nblocks SERT", color="#7D3C98"];

  // Antipsychotic → Dopamine D2R
  RISP_plasma -> D2R_occ [label="D2 Block\n(60–80%)", color="#D35400", penwidth=2];
  ARIP_plasma -> D2R_occ [label="D2 Partial\nAgonist", color="#D35400"];
  D2R_occ -> Indirect_path [label="Restores\nGo/No-Go\nBalance", color="#1E8449"];

  // Memantine → NMDA
  MEM_plasma -> NMDA_R [label="NMDA\nAntagonist\n(Uncompetitive)", color="#D35400"];

  // 5-HT → CSTC Circuit
  HT5_syn -> OFC_node [label="5-HT\nModulates\nHyperactivity ↓", color="#E74C3C"];
  HT5_syn -> Caudate_node [label="5-HT\nModulates", color="#E74C3C"];
  HT5_syn -> MD_thalamus [label="5-HT\nModulates", color="#E74C3C"];
  HT2A_post -> OFC_node [label="5-HT2A\nExcitatory", color="#E74C3C"];
  HT2C_post -> Caudate_node [label="5-HT2C\nInhibitory", color="#1E8449"];

  // Dopamine → CSTC
  D1R_str -> Direct_path [label="Activates Go ↑"];
  D2R_str -> Indirect_path [label="Activates No-Go ↑"];
  D1R_OFC -> OFC_node [label="Working\nMemory"];

  // Glutamate → CSTC
  Glu_OFC -> OFC_node [label="Drives\nHyperactivity", color="#8E44AD"];
  Glu_str_syn -> Caudate_node [label="Corticostriatal\nDrive", color="#8E44AD"];
  QUIN_acid -> NMDA_R [label="Overactivates\n(Excitotoxic)", color="#C0392B"];

  // NMDA → Neuroplasticity
  NMDA_R -> LTP_syn [label="Ca2+ influx"];
  NMDA_R -> LTD_syn;

  // 5-HT → BDNF (chronic SSRI)
  HT5_syn -> BDNF_node [label="Chronic ↑5-HT\n→ BDNF ↑", color="#1E8449"];
  HT2A_post -> BDNF_node [label="2A → BDNF", color="#E74C3C"];
  BDNF_node -> OFC_node [label="Trophic\nSupport"];
  BDNF_node -> Neurogenesis_h;

  // Neuroinflammation → 5-HT
  TNFa_brain -> TPH2 [label="Inhibits\nSynthesis", color="#C0392B"];
  IDO_pathway -> Trp_brain [label="Competes for\nTryptophan", color="#C0392B"];

  // HPA → Neuroplasticity
  Cortisol_adre -> BDNF_node [label="Reduces ↓", color="#E67E22"];
  Cortisol_adre -> Hippo_node [label="Atrophy", color="#E67E22"];
  Immune_act -> Microglia_act [label="Stimulates"];

  // CBT → CSTC
  OFC_downreg -> OFC_node [label="Normalizes ↓", color="#1E8449", penwidth=2];
  Caud_downreg -> Caudate_node [label="Normalizes ↓", color="#1E8449", penwidth=2];
  Fear_extinct -> Amygdala_node [label="Reduces\nActivity ↓", color="#1E8449"];
  Habit_break -> Striatum_all [label="Normalizes\nHabit Circuits ↓", color="#1E8449"];
  Cog_reappr -> DLPFC_node [label="Strengthens\nPFC Control ↑", color="#1E8449"];

  // Anxiety → OCD loop
  Anxiety_loop -> OFC_node [label="Drives\nRumination", color="#E67E22"];
  OCD_trigger -> Anxiety_loop [label="Feedback\nLoop", color="#E67E22"];
  Amygdala_node -> Anxiety_loop [label="Fear\nResponse"];

  // CSTC → Clinical
  OFC_node -> YBOCS_obs [label="Obsessive\nThoughts ↑", color="#C0392B", penwidth=2];
  Caudate_node -> YBOCS_comp [label="Compulsive\nBehaviors ↑", color="#C0392B", penwidth=2];
  Insula_node -> YBOCS_obs [label="Disgust/\nUrge", color="#E67E22"];

  // SERT occupancy → Clinical response
  SERT_occ -> YBOCS_total [label="≥80% SERT\nOccupancy Required", color="#2E86C1", style=dashed, penwidth=2];

  // 5HT1A desensitization → delayed response
  HT1A_des -> YBOCS_total [label="Delayed Onset\n6–12 weeks", style=dashed, color="#1E8449"];

  // DBS
  DBS_target -> MD_thalamus [label="Disrupts\nLoop", color="#5DADE2", style=dashed];
  DBS_target -> GPi_SNr [label="Modulates\nOutput", color="#5DADE2", style=dashed];

  // Genetic → SERT
  PET_SERT -> SERT_free [label="Imaging\nCorrelate", style=dashed, color="#7F8C8D"];
  PET_Glu -> Glu_OFC [label="MRS\nCorrelate", style=dashed, color="#7F8C8D"];
  fMRI_resting -> OFC_node [label="Imaging\nCorrelate", style=dashed, color="#7F8C8D"];
}
