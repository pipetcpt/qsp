digraph DR_QSP {
    rankdir=TB;
    graph [
        label="Diabetic Retinopathy (DR) QSP Mechanistic Map\nHyperglycemia → Oxidative Stress / AGE / PKC → VEGF / Inflammation → Retinal Vascular & Neural Pathology → Clinical Outcomes",
        labelloc=t, fontsize=20, fontname="Helvetica-Bold",
        bgcolor="#F8F9FA", splines=ortho, nodesep=0.45, ranksep=0.75, pad=0.6
    ];
    node [fontname="Helvetica", fontsize=10, style="filled,rounded", penwidth=1.4];
    edge [fontsize=8, fontname="Helvetica", penwidth=1.1, arrowsize=0.7];

    /* ======================================================
       CLUSTER 1 : Systemic Risk Factors & Metabolic Control
       ====================================================== */
    subgraph cluster_systemic {
        label="① Systemic Risk Factors & Metabolic Control";
        style=filled; color="#E3F2FD"; fontsize=13; fontcolor="#1565C0";
        node [fillcolor="#BBDEFB", color="#1565C0"];
        BG        [label="Blood Glucose\n(mmol/L)"];
        HbA1c     [label="HbA1c (%)"];
        Insulin   [label="Insulin\nDeficiency/Resistance"];
        BP        [label="Blood Pressure\n(mmHg)"];
        LDL_sys   [label="LDL Cholesterol"];
        TG_sys    [label="Triglycerides"];
        FFA_sys   [label="Free Fatty Acids"];
        DM_Dur    [label="DM Duration\n(years)"];
        T1DM      [label="Type 1 DM",   shape=diamond];
        T2DM      [label="Type 2 DM",   shape=diamond];
        Genetics  [label="Genetic Factors\n(VEGF polymorphisms)", shape=box];
        Smoking   [label="Smoking\n(risk factor)",               shape=box];
        Pregnancy [label="Pregnancy\n(worsening risk)",          shape=box];
        RAAS_sys  [label="Systemic RAAS\nActivation"];
        AngII_sys [label="Angiotensin II\n(systemic)"];
        Aldost    [label="Aldosterone"];
        SNS_act   [label="Sympathetic\nNervous System"];
        Nephrop   [label="Diabetic Nephropathy\n(comorbidity)",  shape=box];
        Neuropat  [label="Diabetic Neuropathy\n(comorbidity)",   shape=box];
        Anemia_DM [label="Anemia\n(worsens hypoxia)",            shape=box];
    }

    /* ======================================================
       CLUSTER 2 : Hyperglycemia-Induced Biochemical Pathways
       ====================================================== */
    subgraph cluster_biochem {
        label="② Hyperglycemia-Induced Biochemical Pathways";
        style=filled; color="#FFF3E0"; fontsize=13; fontcolor="#E65100";
        node [fillcolor="#FFE0B2", color="#E65100"];
        Gluc_ret  [label="Intracellular Glucose\n(retinal cells)"];
        /* --- Polyol Pathway --- */
        AR        [label="Aldose Reductase\n(AR)"];
        Sorbitol  [label="Sorbitol ↑"];
        SDH       [label="Sorbitol\nDehydrogenase"];
        Fructose  [label="Fructose ↑"];
        NADPH_dep [label="NADPH Depletion\n(↓ GSH synthesis)"];
        NADH_exc  [label="NADH/NAD⁺ ↑\n(pseudohypoxia)"];
        /* --- Hexosamine Pathway --- */
        GFAT      [label="GFAT Enzyme"];
        OGlcNAc   [label="O-GlcNAc\nModification ↑"];
        Sp1_hex   [label="Sp1 O-GlcNAcylation"];
        TGFb_hex  [label="TGF-β ↑\n(via hexosamine)"];
        PAI1_hex  [label="PAI-1 ↑\n(via hexosamine)"];
        /* --- PKC Pathway --- */
        DAG_acc   [label="DAG Accumulation"];
        PKCb1     [label="PKCβ1"];
        PKCb2     [label="PKCβ2 ↑"];
        PKCd      [label="PKCδ ↑"];
        PKCz      [label="PKCζ"];
        eNOS_PKC  [label="eNOS ↓\n(PKC-mediated)"];
        ET1_PKC   [label="Endothelin-1 ↑"];
        /* --- AGE Pathway --- */
        Methylgly [label="Methylglyoxal"];
        Glyoxal   [label="Glyoxal"];
        AGE_mol   [label="AGE Molecules\n(CML, CEL, AGES)"];
        RAGE_rec  [label="RAGE Receptor\nActivation"];
        CrossLink [label="Protein\nCross-Linking"];
        BM_thick  [label="Basement Membrane\nThickening", shape=box];
        VEGF_AGE  [label="VEGF ↑\n(via AGE-RAGE)"];
        NFkB_AGE  [label="NF-κB ↑\n(via AGE-RAGE)"];
    }

    /* ======================================================
       CLUSTER 3 : Oxidative & Nitrosative Stress
       ====================================================== */
    subgraph cluster_oxidative {
        label="③ Oxidative & Nitrosative Stress";
        style=filled; color="#FCE4EC"; fontsize=13; fontcolor="#880E4F";
        node [fillcolor="#F8BBD0", color="#880E4F"];
        mito_ETC  [label="Mitochondrial ETC\n(Complex I–III) ↑"];
        O2m_mito  [label="Superoxide O₂•⁻\n[mitochondrial]"];
        NADPH_ox  [label="NADPH Oxidase\n(NOX1/2/4)"];
        O2m_NOX   [label="Superoxide O₂•⁻\n[cytosolic]"];
        H2O2_ret  [label="Hydrogen Peroxide\nH₂O₂"];
        OH_rad    [label="•OH Radical\n(Fenton)"];
        ONOO_ret  [label="Peroxynitrite\nONOO⁻"];
        NO_ret    [label="Nitric Oxide\n(NO)"];
        iNOS_ret  [label="iNOS ↑"];
        eNOS_unc  [label="eNOS Uncoupling"];
        BH4_dep   [label="BH4 Depletion"];
        MDA_ret   [label="MDA ↑\n(lipid peroxidation)"];
        OxLDL_ret [label="Oxidized LDL"];
        PARP_act  [label="PARP Activation"];
        GAPDH_inh [label="GAPDH Inhibition\n→ upstream overflow"];
        mtDNA_dmg [label="Mitochondrial\nDNA Damage"];
        CytC_rel  [label="Cytochrome c\nRelease"];
        Apop_ox   [label="Apoptosis\n(endothelial/pericyte)", shape=box];
        SOD_ret   [label="SOD ↓"];
        CAT_ret   [label="Catalase ↓"];
        GPx_ret   [label="GPx ↓"];
        GSH_ret   [label="GSH ↓"];
        Nrf2      [label="Nrf2/ARE\n(antioxidant response)"];
        HO1       [label="HO-1 ↑\n(cytoprotective)"];
    }

    /* ======================================================
       CLUSTER 4 : VEGF / Angiogenesis Signaling
       ====================================================== */
    subgraph cluster_vegf {
        label="④ VEGF / Angiogenesis & Growth Factor Signaling";
        style=filled; color="#E8F5E9"; fontsize=13; fontcolor="#1B5E20";
        node [fillcolor="#C8E6C9", color="#1B5E20"];
        Hypoxia   [label="Retinal\nHypoxia/Ischemia",          shape=box, fillcolor="#A5D6A7"];
        PHD_enz   [label="PHD Enzymes\n(O₂-dependent)"];
        VHL_prot  [label="VHL Protein"];
        HIF1a     [label="HIF-1α\n(hypoxia inducible factor)"];
        HIF2a     [label="HIF-2α"];
        VEGFA165  [label="VEGF-A165\n(dominant isoform)",       fillcolor="#66BB6A"];
        VEGFA121  [label="VEGF-A121"];
        VEGFA189  [label="VEGF-A189"];
        VEGFB     [label="VEGF-B"];
        VEGFC     [label="VEGF-C"];
        PlGF      [label="PlGF\n(Placental GF)"];
        VEGFR1    [label="VEGFR1/Flt-1\n(decoy)"];
        sVEGFR1   [label="sVEGFR1\n(soluble, inhibitory)"];
        VEGFR2    [label="VEGFR2/KDR\n(signaling)",              fillcolor="#66BB6A"];
        NRP1      [label="Neuropilin-1\n(co-receptor)"];
        VEGFR2sig [label="VEGFR2\nSignaling Cascade",            fillcolor="#A5D6A7"];
        PI3K_V    [label="PI3K/AKT\n(survival/permeability)"];
        ERK_V     [label="ERK1/2\n(proliferation)"];
        PLC_V     [label="PLCγ/PKC\n(permeability)"];
        Rac1_V    [label="Rac1/Cdc42\n(migration)"];
        FAK_V     [label="FAK\n(adhesion)"];
        Ang1      [label="Angiopoietin-1\n(vascular stabilizer)"];
        Ang2      [label="Angiopoietin-2\n(destabilizer ↑)"];
        Tie2      [label="Tie-2 Receptor"];
        PDGFB     [label="PDGF-B"];
        PDGFRb    [label="PDGFRβ\n(pericyte survival)"];
        FGF2      [label="FGF-2 / bFGF"];
        IGF1      [label="IGF-1"];
        IGF1R     [label="IGF-1R"];
        EPO_V     [label="EPO\n(angiogenic)"];
        SDF1      [label="SDF-1/CXCL12"];
        CXCR4     [label="CXCR4"];
        Dll4_Notch[label="Dll4/Notch\n(tip vs stalk cell)"];
        ROBO4     [label="ROBO4\n(vascular stability)"];
    }

    /* ======================================================
       CLUSTER 5 : Neuroinflammation & Immunological Pathways
       ====================================================== */
    subgraph cluster_inflam {
        label="⑤ Neuroinflammation & Immunological Pathways";
        style=filled; color="#FFF8E1"; fontsize=13; fontcolor="#F57F17";
        node [fillcolor="#FFF9C4", color="#F57F17"];
        NFkB      [label="NF-κB Activation",  fillcolor="#FFD54F"];
        NLRP3     [label="NLRP3 Inflammasome"];
        Casp1     [label="Caspase-1"];
        IL1b      [label="IL-1β ↑"];
        IL6       [label="IL-6 ↑"];
        IL8       [label="IL-8/CXCL8 ↑"];
        IL10      [label="IL-10\n(anti-inflammatory)"];
        IL17      [label="IL-17 ↑"];
        IL18      [label="IL-18 ↑"];
        TNFa      [label="TNF-α ↑",           fillcolor="#FFD54F"];
        MCP1      [label="MCP-1/CCL2 ↑"];
        IP10      [label="IP-10/CXCL10 ↑"];
        ICAM1     [label="ICAM-1 ↑"];
        VCAM1     [label="VCAM-1 ↑"];
        Selectin  [label="P/E-Selectin ↑"];
        Leukost   [label="Leukostasis\n(leukocyte adhesion)", shape=box, fillcolor="#FFD54F"];
        Neut_inf  [label="Neutrophil\nInfiltration"];
        Mac_inf   [label="Macrophage\nInfiltration"];
        Microglia [label="Microglial\nActivation"];
        Muller    [label="Müller Cell\nReactive Gliosis"];
        GFAP_ret  [label="GFAP ↑\n(gliosis marker)"];
        COX2_ret  [label="COX-2 ↑"];
        PGE2_ret  [label="PGE-2 ↑"];
        LTB4_ret  [label="LTB4 ↑"];
        C3_comp   [label="Complement C3"];
        C5a_comp  [label="C5a"];
        MAC_comp  [label="MAC (C5b-9)"];
        TGFb1     [label="TGF-β1\n(fibrosis)"];
        TGFb2     [label="TGF-β2\n(fibrosis)"];
        CTGF      [label="CTGF/CCN2"];
        MMP2_ret  [label="MMP-2 / MMP-9"];
        Thromb1   [label="Thrombospondin-1\n(anti-angiogenic)"];
        PEDF      [label="PEDF\n(pigment epithelium\nderived factor)"];
    }

    /* ======================================================
       CLUSTER 6 : Retinal Vascular & Structural Pathology
       ====================================================== */
    subgraph cluster_vascular {
        label="⑥ Retinal Vascular & Structural Pathology";
        style=filled; color="#F3E5F5"; fontsize=13; fontcolor="#4A148C";
        node [fillcolor="#E1BEE7", color="#4A148C"];
        Pericyte  [label="Pericyte Loss\n(hallmark lesion)", shape=box, fillcolor="#CE93D8"];
        EC_apop   [label="Endothelial Cell\nApoptosis"];
        BRB_brk   [label="Blood-Retinal Barrier\nBreakdown (iBRB/oBRB)", shape=box, fillcolor="#CE93D8"];
        TJ_loss   [label="Tight Junction\nDisassembly"];
        ZO1_loss  [label="ZO-1 ↓"];
        Occ_loss  [label="Occludin ↓"];
        Clau_loss [label="Claudin-5 ↓"];
        VEcad     [label="VE-Cadherin ↓"];
        Microan   [label="Microaneurysms\n(earliest lesion)", shape=box, fillcolor="#CE93D8"];
        HardExud  [label="Hard Exudates\n(lipid leakage)",   shape=box];
        FlameHem  [label="Flame Hemorrhages", shape=box];
        DotHem    [label="Dot-and-Blot\nHemorrhages",        shape=box];
        CWS       [label="Cotton-Wool Spots\n(nerve fiber ischemia)", shape=box];
        IRMA      [label="IRMA\n(intraretinal microvascular\nabnormalities)", shape=box];
        VenBead   [label="Venous Beading",  shape=box];
        CapClos   [label="Capillary\nNon-Perfusion/Closure", shape=box, fillcolor="#CE93D8"];
        RetIsch   [label="Retinal Ischemia"];
        NV_ret    [label="Retinal\nNeovascularization (NVE)", shape=box, fillcolor="#9C27B0"];
        NVD       [label="NVD\n(disc neovasc.)",             shape=box, fillcolor="#9C27B0"];
        NVI       [label="NVI\n(iris neovasc.)",             shape=box];
        VitHem    [label="Vitreous Hemorrhage",              shape=box, fillcolor="#9C27B0"];
        FibroV    [label="Fibrovascular\nProliferation",     shape=box];
        TRD       [label="Tractional Retinal\nDetachment",   shape=box, fillcolor="#9C27B0"];
        Rubeosis  [label="Rubeosis Iridis / NVG",           shape=box];
        VascPerm  [label="Vascular\nPermeability ↑"];
        FluidLeak [label="Fluid Leakage\ninto Retina"];
        SRF       [label="Subretinal Fluid"];
        IRF       [label="Intraretinal Fluid"];
        DME       [label="Diabetic Macular\nEdema (DME)",    shape=box, fillcolor="#7B1FA2"];
        CI_DME    [label="Center-Involving\nDME (CI-DME)",   shape=box, fillcolor="#7B1FA2"];
    }

    /* ======================================================
       CLUSTER 7 : Retinal Neurodegeneration
       ====================================================== */
    subgraph cluster_neuro {
        label="⑦ Retinal Neurodegeneration (Early & Concurrent)";
        style=filled; color="#E8EAF6"; fontsize=13; fontcolor="#1A237E";
        node [fillcolor="#C5CAE9", color="#1A237E"];
        RGC_loss  [label="Retinal Ganglion Cell\n(RGC) Loss"];
        RNFL_thin [label="RNFL Thinning\n(OCT-measured)"];
        Photorec  [label="Photoreceptor\nDamage"];
        RPE_dysf  [label="RPE Dysfunction"];
        Amacrine  [label="Amacrine Cell Loss"];
        Bipolar   [label="Bipolar Cell Loss"];
        GluImb    [label="Glutamate/GABA\nImbalance"];
        Excitotox [label="Glutamate\nExcitotoxicity"];
        NMDAR     [label="NMDA Receptor\nOveractivation"];
        Ca_influx [label="Ca²⁺ Influx\n(neurotoxic)"];
        Casp3     [label="Caspase-3\nActivation"];
        BDNF_ret  [label="BDNF ↓\n(neuroprotective)"];
        TrkB      [label="TrkB Receptor"];
        ERG_abn   [label="ERG Abnormalities\n(b-wave ↓, implicit time ↑)"];
        OCT_str   [label="OCT Structural\nChanges (early)"];
        GFAP_ast  [label="GFAP+ Astrocyte\nReactivation"];
        SynLoss   [label="Synaptic Density ↓"];
        SubP      [label="Substance P ↑"];
        CGRP_ret  [label="CGRP"];
        VEGF_neur [label="VEGF as\nNeuroprotectant\n(double-edged)"];
    }

    /* ======================================================
       CLUSTER 8 : Drug PK/PD
       ====================================================== */
    subgraph cluster_drugs {
        label="⑧ Drug PK/PD — Anti-VEGF, Corticosteroids & Other Treatments";
        style=filled; color="#E0F7FA"; fontsize=13; fontcolor="#006064";
        node [fillcolor="#B2EBF2", color="#006064"];
        /* Aflibercept */
        Afl_dose  [label="Aflibercept Dose\n(IVT 2 mg q4-8w)",  shape=box, fillcolor="#00ACC1"];
        Afl_vit   [label="Aflibercept\nVitreous Conc."];
        Afl_plas  [label="Aflibercept\nPlasma Conc."];
        /* Ranibizumab */
        Ran_dose  [label="Ranibizumab Dose\n(IVT 0.5 mg q4w)", shape=box, fillcolor="#00ACC1"];
        Ran_vit   [label="Ranibizumab\nVitreous Conc."];
        /* Bevacizumab */
        Bev_dose  [label="Bevacizumab Dose\n(IVT 1.25 mg)",    shape=box, fillcolor="#00ACC1"];
        Bev_vit   [label="Bevacizumab\nVitreous Conc."];
        /* Faricimab */
        Far_dose  [label="Faricimab Dose\n(IVT 6 mg q4-16w)",  shape=box, fillcolor="#26C6DA"];
        Far_vit   [label="Faricimab\nVitreous Conc."];
        /* Brolucizumab */
        Bro_dose  [label="Brolucizumab Dose\n(IVT 6 mg q8-12w)", shape=box, fillcolor="#00ACC1"];
        Bro_vit   [label="Brolucizumab\nVitreous Conc."];
        /* PD nodes */
        VEGF_free  [label="Free VEGF\n(retina)"];
        VEGF_bound [label="VEGF-Drug\nComplex (bound)"];
        Ang2_bound [label="Ang2-Drug Complex\n(faricimab-specific)"];
        VEGFR2_inh [label="VEGFR2 Activation ↓\n(pharmacodynamic)"];
        /* Corticosteroids */
        Dexa_imp  [label="Dexamethasone\nImplant 0.7mg (Ozurdex)", shape=box];
        Triam_ivt [label="Triamcinolone\nAcetonide (IVTA)",         shape=box];
        Cort_vit  [label="Corticosteroid\nVitreous Conc."];
        Cort_PD   [label="NF-κB ↓ / VEGF ↓\n(GR-mediated)"];
        /* Laser & Surgery */
        Laser_PRP [label="Pan-Retinal\nPhotocoagulation (PRP)", shape=box, fillcolor="#4DD0E1"];
        Laser_FG  [label="Focal/Grid Laser\n(DME treatment)",   shape=box];
        Vitrect   [label="Vitrectomy (PPV)\n(VH / TRD)",        shape=box];
        /* Systemic */
        Insulin_tx[label="Insulin Therapy\n(tight glycemic Ctrl)", shape=box];
        Metf_tx   [label="Metformin\n(AMPK activation)",           shape=box];
        GLP1RA_tx [label="GLP-1 RA\n(semaglutide, liraglutide)",   shape=box];
        SGLT2i_tx [label="SGLT2 Inhibitor\n(renoprotective)",       shape=box];
        RAAS_tx   [label="ACEi / ARB\n(RAAS blockade)",             shape=box];
        Statin_tx [label="Statin\n(lipid control)",                 shape=box];
        Fenofib   [label="Fenofibrate\n(ACCORD-Eye benefit)",       shape=box, fillcolor="#00ACC1"];
    }

    /* ======================================================
       CLUSTER 9 : Clinical Endpoints & Biomarkers
       ====================================================== */
    subgraph cluster_endpoints {
        label="⑨ Clinical Endpoints & Outcome Measures";
        style=filled; color="#FAFAFA"; fontsize=13; fontcolor="#212121";
        node [fillcolor="#F5F5F5", color="#424242"];
        BCVA      [label="BCVA\n(ETDRS letters)",          shape=box, fillcolor="#BDBDBD"];
        CRT       [label="Central Retinal Thickness\n(CRT, µm — OCT)", shape=box, fillcolor="#BDBDBD"];
        DR_grade  [label="DR Severity Grade\n(ETDRS scale)", shape=box];
        NPDR_m    [label="Mild NPDR\n(Level 20)"];
        NPDR_mo   [label="Moderate NPDR\n(Level 35–43)"];
        NPDR_sv   [label="Severe NPDR\n(Level 47–53)\n4-2-1 rule"];
        PDR       [label="PDR\n(Level 61–71)",             fillcolor="#BDBDBD"];
        PDR_HR    [label="High-Risk PDR\n(Level 71A)"];
        OCT_param [label="OCT Parameters", shape=box];
        IRF_end   [label="Intraretinal Fluid\n(IRF)"];
        SRF_end   [label="Subretinal Fluid\n(SRF)"];
        PED_end   [label="PED\n(pigment epithelial detachment)"];
        DRIL_end  [label="DRIL\n(disorganization inner layers)"];
        ELM_end   [label="ELM Integrity\n(external limiting membrane)"];
        COST_end  [label="COST Line\n(outer segment tips)"];
        GCL_vol   [label="GCL+ Volume\n(neurodegeneration proxy)"];
        FA_leak   [label="FA Leakage\n(fluorescein angiography)"];
        OCTA_NV   [label="OCTA: Neovascular\nArea (mm²)"];
        OCTA_FAZ  [label="OCTA: FAZ Area\n(foveal avascular zone)"];
        OCTA_VD   [label="OCTA: Vessel\nDensity (%)"];
        TwoStep   [label="2-Step DR Worsening\n(regulatory endpoint)", shape=box];
        ThreeStep [label="3-Step DR Worsening", shape=box];
        SevVL     [label="Severe Visual Loss\n(≥30 letters ↓)",       shape=box];
        LegalBlind[label="Legal Blindness\n(<3/60 VA)",               shape=box];
        VFI_end   [label="Visual Field Index (%)"];
        CS_end    [label="Contrast Sensitivity"];
        ReadSpeed [label="Reading Speed\n(words/min)"];
        PRO_end   [label="PRO: VFQ-25 / NEI-VFQ"];
        VitVEGF   [label="Vitreous VEGF\n(pg/mL)"];
        SerVEGF   [label="Serum VEGF"];
        HbA1c_mon [label="HbA1c Monitoring"];
        VitCyto   [label="Vitreous Cytokines\n(IL-6, IL-8, TNFα)"];
        AngVitF   [label="Angiopoietin-2\nVitreous Level"];
    }

    /* ======================================================
       EDGES — Inter-cluster connections
       ====================================================== */

    /* --- Systemic → Biochemical --- */
    BG        -> Gluc_ret  [label="glucose\nuptake"];
    HbA1c     -> BG        [label="reflects avg", dir=both, style=dashed];
    T1DM      -> Insulin   [label="absolute\ndeficiency"];
    T2DM      -> Insulin   [label="relative\ndeficiency"];
    Insulin   -> BG        [label="control ↓", dir=back, color="#1B5E20"];
    BG        -> AR        [label="polyol pathway"];
    BG        -> GFAT      [label="hexosamine\npathway"];
    BG        -> DAG_acc   [label="DAG ↑"];
    BG        -> Methylgly [label="AGE precursor"];
    BG        -> Glyoxal;
    BP        -> RAAS_sys  [label="triggers"];
    RAAS_sys  -> AngII_sys;
    AngII_sys -> VEGFA165  [label="upregulates"];
    AngII_sys -> NFkB      [label="→ NF-κB"];
    Aldost    -> BP        [label="salt-water\nretention", dir=back];
    DM_Dur    -> BG        [label="cumulative\nexposure", style=dashed];
    Smoking   -> NADPH_ox  [label="↑ oxidative\nstress"];
    Anemia_DM -> Hypoxia   [label="↓ O₂\ndelivery"];

    /* --- Polyol Pathway --- */
    AR        -> Sorbitol  [label="glucose→sorbitol"];
    Sorbitol  -> SDH;
    SDH       -> Fructose;
    Sorbitol  -> NADPH_dep [label="NADPH consumed"];
    NADPH_dep -> GSH_ret   [label="↓ GSH\nsynthesis", color="#880E4F"];
    AR        -> NADH_exc  [label="NADH generated"];
    NADH_exc  -> mito_ETC  [label="↑ electron\nflux"];

    /* --- Hexosamine Pathway --- */
    GFAT      -> OGlcNAc;
    OGlcNAc   -> Sp1_hex;
    Sp1_hex   -> TGFb_hex  [label="↑ TGF-β\ntranscription"];
    Sp1_hex   -> PAI1_hex  [label="↑ PAI-1"];
    TGFb_hex  -> VEGFA165  [label="upregulates"];
    TGFb_hex  -> TGFb1;

    /* --- PKC Pathway --- */
    DAG_acc   -> PKCb1;
    DAG_acc   -> PKCb2;
    DAG_acc   -> PKCd;
    PKCb2     -> VEGF_AGE  [label="↑ VEGF"];
    PKCb2     -> NFkB_AGE  [label="↑ NF-κB"];
    PKCb2     -> ET1_PKC;
    PKCb2     -> eNOS_PKC  [label="↓ eNOS\nactivity"];
    PKCb2     -> NADPH_ox  [label="activates"];
    PKCd      -> Apop_ox   [label="pro-apoptotic"];

    /* --- AGE Pathway --- */
    Methylgly -> AGE_mol;
    Glyoxal   -> AGE_mol;
    AGE_mol   -> RAGE_rec  [label="ligand-receptor"];
    AGE_mol   -> CrossLink;
    CrossLink -> BM_thick;
    BM_thick  -> Pericyte  [label="entraps\npericytes"];
    RAGE_rec  -> NFkB_AGE;
    RAGE_rec  -> VEGF_AGE;
    RAGE_rec  -> NADPH_ox  [label="→ ROS"];
    NFkB_AGE  -> NFkB;
    VEGF_AGE  -> VEGFA165;

    /* --- Oxidative Stress --- */
    mito_ETC  -> O2m_mito  [label="electron leak"];
    NADPH_ox  -> O2m_NOX   [label="generates"];
    O2m_mito  -> H2O2_ret  [label="SOD"];
    O2m_NOX   -> H2O2_ret;
    H2O2_ret  -> OH_rad    [label="Fenton\n(Fe²⁺)"];
    O2m_mito  -> ONOO_ret  [label="+ NO"];
    O2m_NOX   -> ONOO_ret;
    NO_ret    -> ONOO_ret;
    iNOS_ret  -> NO_ret    [label="overproduction"];
    eNOS_unc  -> NO_ret    [label="uncoupled"];
    BH4_dep   -> eNOS_unc  [label="BH4 ↓ causes"];
    OH_rad    -> MDA_ret;
    OH_rad    -> Apop_ox;
    ONOO_ret  -> Apop_ox;
    ONOO_ret  -> PARP_act;
    PARP_act  -> GAPDH_inh [label="poly-ADP\nribosylation"];
    GAPDH_inh -> AR        [label="↑ flux via\nhexose overflow", style=dashed];
    GAPDH_inh -> GFAT      [style=dashed];
    GAPDH_inh -> DAG_acc   [style=dashed];
    GAPDH_inh -> Methylgly [style=dashed, label="AGE ↑"];
    SOD_ret   -> O2m_mito  [label="scavenge", dir=back];
    SOD_ret   -> O2m_NOX   [dir=back];
    GPx_ret   -> H2O2_ret  [label="scavenge", dir=back];
    GSH_ret   -> GPx_ret   [label="substrate"];
    Nrf2      -> SOD_ret   [label="↑ transcription", color="#1B5E20"];
    Nrf2      -> GPx_ret   [color="#1B5E20"];
    Nrf2      -> HO1       [color="#1B5E20"];
    mito_ETC  -> mtDNA_dmg;
    mtDNA_dmg -> CytC_rel;
    CytC_rel  -> Apop_ox;

    /* --- VEGF Signaling --- */
    RetIsch   -> Hypoxia   [label="chronic"];
    CapClos   -> RetIsch;
    Hypoxia   -> HIF1a     [label="PHD inhibited\n→ stabilizes"];
    Hypoxia   -> HIF2a;
    PHD_enz   -> HIF1a     [label="hydroxylates\n(normoxia)", dir=back];
    VHL_prot  -> HIF1a     [label="targets for\nproteasomal\ndeg.", dir=back];
    HIF1a     -> VEGFA165  [label="transcription ↑"];
    HIF2a     -> VEGFA165;
    HIF1a     -> EPO_V     [label="↑ EPO"];
    HIF1a     -> SDF1;
    NFkB      -> VEGFA165  [label="transcription ↑"];
    TGFb1     -> VEGFA165  [label="upregulates"];
    VEGFA165  -> VEGFR1    [label="binds (decoy)"];
    VEGFA165  -> VEGFR2    [label="high-affinity\nsignaling"];
    VEGFB     -> VEGFR1;
    PlGF      -> VEGFR1    [label="PlGF preferential"];
    VEGFA165  -> NRP1      [label="co-receptor\nenhancement"];
    NRP1      -> VEGFR2    [label="enhances\nsignaling"];
    VEGFR2    -> VEGFR2sig [label="autophosphorylation"];
    VEGFR2sig -> PI3K_V;
    VEGFR2sig -> ERK_V;
    VEGFR2sig -> PLC_V;
    VEGFR2sig -> Rac1_V;
    VEGFR2sig -> FAK_V;
    PI3K_V    -> VascPerm  [label="↑ permeability"];
    ERK_V     -> NV_ret    [label="EC proliferation"];
    PLC_V     -> VascPerm;
    Ang2      -> Tie2      [label="antagonist\n(disease)"];
    Ang1      -> Tie2      [label="agonist\n(stable)", color="#1B5E20"];
    Tie2      -> Pericyte  [label="Ang2 destabilizes", style=dashed, color=red];
    PDGFB     -> PDGFRb    [label="pericyte\nsurvival", color="#1B5E20"];
    PDGFRb    -> Pericyte  [label="survival signal", dir=back, color="#1B5E20"];
    FGF2      -> NV_ret    [label="angiogenic"];
    IGF1      -> IGF1R;
    IGF1R     -> VEGFA165  [label="↑ expression"];
    EPO_V     -> NV_ret    [label="angiogenic"];
    SDF1      -> CXCR4;
    CXCR4     -> NV_ret    [label="EPC recruitment"];
    Ang2      -> VEGFA165  [label="synergizes\nangiogenesis"];
    Dll4_Notch-> VEGFR2    [label="modulates tip/\nstalk fate"];
    Thromb1   -> VEGFR2    [label="inhibits", color=red];
    PEDF      -> NV_ret    [label="inhibits", color=red];
    ROBO4     -> VascPerm  [label="stabilizes\n(inhibits ↑)", color="#1B5E20", dir=back];

    /* --- Inflammation --- */
    RAGE_rec  -> NFkB;
    NFkB_AGE  -> NFkB;
    O2m_mito  -> NFkB      [label="ROS → IKK"];
    TNFa      -> NFkB      [label="autocrine loop"];
    NFkB      -> IL1b;
    NFkB      -> IL6;
    NFkB      -> IL8;
    NFkB      -> TNFa;
    NFkB      -> MCP1;
    NFkB      -> ICAM1;
    NFkB      -> VCAM1;
    NFkB      -> COX2_ret;
    NFkB      -> MMP2_ret;
    NFkB      -> Ang2      [label="↑ Ang2\ntranscription"];
    NLRP3     -> Casp1;
    Casp1     -> IL1b      [label="cleavage"];
    Casp1     -> IL18;
    IL6       -> NFkB      [label="STAT3 feedback", style=dashed];
    TNFa      -> ICAM1;
    TNFa      -> Apop_ox;
    TNFa      -> VEGFA165  [label="upregulates"];
    IL1b      -> VEGFA165  [label="upregulates"];
    COX2_ret  -> PGE2_ret;
    PGE2_ret  -> VascPerm  [label="↑ permeability"];
    ICAM1     -> Leukost;
    VCAM1     -> Leukost;
    Selectin  -> Leukost;
    MCP1      -> Mac_inf;
    IL8       -> Neut_inf;
    Leukost   -> EC_apop   [label="mechanical/\nchemical injury"];
    Leukost   -> CapClos   [label="vessel occlusion"];
    Microglia -> IL1b      [label="secretes"];
    Microglia -> TNFa;
    Muller    -> VEGFA165  [label="major source"];
    Muller    -> IL6;
    Muller    -> MCP1;
    GFAP_ret  -> Muller    [label="marker of"];
    TGFb1     -> CTGF;
    TGFb2     -> CTGF;
    CTGF      -> FibroV    [label="fibrosis"];
    C3_comp   -> C5a_comp;
    C5a_comp  -> MAC_comp;
    C5a_comp  -> Microglia [label="activates"];
    MAC_comp  -> Pericyte  [label="cytotoxic"];
    MMP2_ret  -> BRB_brk   [label="matrix\ndegradation"];

    /* --- Vascular Pathology --- */
    Apop_ox   -> Pericyte;
    Apop_ox   -> EC_apop;
    EC_apop   -> BRB_brk;
    Pericyte  -> BRB_brk   [label="loss of EC\nsupport"];
    Pericyte  -> Microan   [label="outpouching"];
    VascPerm  -> BRB_brk;
    VascPerm  -> FluidLeak;
    BRB_brk   -> TJ_loss;
    TJ_loss   -> ZO1_loss;
    TJ_loss   -> Occ_loss;
    TJ_loss   -> Clau_loss;
    TJ_loss   -> VEcad;
    FluidLeak -> SRF;
    FluidLeak -> IRF;
    SRF       -> DME;
    IRF       -> DME;
    DME       -> CI_DME;
    Microan   -> HardExud;
    Microan   -> FlameHem;
    Microan   -> DotHem;
    CapClos   -> CWS;
    CapClos   -> IRMA;
    IRMA      -> VenBead;
    RetIsch   -> Hypoxia;
    Hypoxia   -> NV_ret    [label="HIF-VEGF axis"];
    NV_ret    -> NVD;
    NV_ret    -> VitHem    [label="fragile vessels\nbleed"];
    NV_ret    -> FibroV;
    FibroV    -> TRD;
    NVI       -> Rubeosis;

    /* --- Neurodegeneration --- */
    Excitotox -> NMDAR;
    NMDAR     -> Ca_influx;
    Ca_influx -> Casp3;
    Casp3     -> RGC_loss;
    RGC_loss  -> RNFL_thin;
    Microglia -> Excitotox [label="glutamate\nrelease"];
    Muller    -> GluImb;
    GluImb    -> Excitotox;
    BDNF_ret  -> TrkB      [label="neuroprotection\n(reduced)", color="#1B5E20"];
    TrkB      -> RGC_loss  [label="survival\nsignal", dir=back, color="#1B5E20"];
    Apop_ox   -> Photorec;
    Photorec  -> ERG_abn;
    TNFa      -> RGC_loss  [label="apoptosis"];
    IL1b      -> RPE_dysf;
    RPE_dysf  -> Photorec  [label="support failure"];
    VEGF_neur -> RGC_loss  [label="neuroprotective\nrole", dir=back, color="#1B5E20"];
    VEGFA165  -> VEGF_neur;

    /* --- Drug PK/PD --- */
    Afl_dose  -> Afl_vit   [label="IVT bolus\nVd_vit~4mL"];
    Afl_vit   -> Afl_plas  [label="systemic\nabsorption\nt½_vit~9d"];
    Afl_vit   -> VEGF_bound[label="VEGF binding\nKd~0.5pM"];
    Ran_dose  -> Ran_vit   [label="IVT bolus"];
    Ran_vit   -> VEGF_bound[label="VEGF binding"];
    Bev_dose  -> Bev_vit   [label="IVT bolus"];
    Bev_vit   -> VEGF_bound[label="VEGF binding"];
    Far_dose  -> Far_vit   [label="IVT bolus"];
    Far_vit   -> VEGF_bound[label="VEGF binding"];
    Far_vit   -> Ang2_bound[label="Ang2 binding\n(dual action)"];
    Bro_dose  -> Bro_vit   [label="IVT bolus"];
    Bro_vit   -> VEGF_bound[label="VEGF binding"];
    VEGF_bound-> VEGF_free [label="reduces free\nVEGF", dir=back];
    VEGF_free -> VEGFR2    [label="activates\n(free VEGF)", color="#4A148C"];
    VEGFR2    -> VEGFR2_inh[label="anti-VEGF\neffect", dir=back];
    VEGFR2_inh-> VascPerm  [label="↓ permeability", color="#006064", dir=back];
    VEGFR2_inh-> NV_ret    [label="↓ NV", color="#006064", dir=back];
    Ang2_bound-> Tie2      [label="blocks Ang2\nantagonism", color="#006064"];
    Dexa_imp  -> Cort_vit;
    Triam_ivt -> Cort_vit;
    Cort_vit  -> Cort_PD   [label="GR activation"];
    Cort_PD   -> NFkB      [label="↓ NF-κB", dir=back, color="#006064"];
    Cort_PD   -> VEGFA165  [label="↓ VEGF",  dir=back, color="#006064"];
    Cort_PD   -> VascPerm  [label="↓ permeability", dir=back, color="#006064"];
    Laser_PRP -> Hypoxia   [label="ablation ↓\nischemic load", dir=back, color="#006064"];
    Laser_PRP -> NV_ret    [label="regression", dir=back, color="#006064"];
    Laser_FG  -> FluidLeak [label="seals\nmicroaneurysms", dir=back, color="#006064"];
    Insulin_tx-> BG        [label="↓ BG",    dir=back, color="#1B5E20"];
    Metf_tx   -> BG        [label="↓ BG\nAMPK", dir=back, color="#1B5E20"];
    GLP1RA_tx -> BG        [label="↓ BG",    dir=back, color="#1B5E20"];
    SGLT2i_tx -> BG        [label="↓ BG",    dir=back, color="#1B5E20"];
    RAAS_tx   -> AngII_sys [label="↓ AngII", dir=back, color="#1B5E20"];
    Statin_tx -> LDL_sys   [label="↓ LDL",  dir=back, color="#1B5E20"];
    Fenofib   -> TG_sys    [label="↓ TG",    dir=back, color="#1B5E20"];
    Fenofib   -> VEGFA165  [label="PPARα ↓\nVEGF expr", dir=back, color="#1B5E20"];

    /* --- Clinical Endpoints --- */
    DME       -> CRT       [label="↑ CRT"];
    CI_DME    -> BCVA      [label="↓ BCVA"];
    RGC_loss  -> BCVA      [label="↓ VA"];
    Photorec  -> BCVA      [label="↓ VA"];
    VitHem    -> BCVA      [label="acute ↓ VA"];
    TRD       -> BCVA      [label="severe ↓ VA"];
    CRT       -> OCT_param;
    OCT_param -> IRF_end;
    OCT_param -> SRF_end;
    OCT_param -> PED_end;
    OCT_param -> DRIL_end;
    OCT_param -> ELM_end;
    OCT_param -> COST_end;
    OCT_param -> GCL_vol;
    NV_ret    -> OCTA_NV;
    NV_ret    -> FA_leak;
    CapClos   -> OCTA_FAZ  [label="↑ FAZ"];
    CapClos   -> OCTA_VD   [label="↓ VD"];
    NPDR_m    -> NPDR_mo   [label="progression\n~8%/yr"];
    NPDR_mo   -> NPDR_sv   [label="4-2-1 rule"];
    NPDR_sv   -> PDR       [label="~50%/yr"];
    PDR       -> PDR_HR;
    NPDR_m    -> DR_grade;
    NPDR_mo   -> DR_grade;
    NPDR_sv   -> DR_grade;
    PDR       -> DR_grade;
    PDR       -> TwoStep;
    PDR       -> ThreeStep;
    BCVA      -> SevVL     [label="≥30 letter\nloss"];
    SevVL     -> LegalBlind;
    BCVA      -> PRO_end;
    BCVA      -> ReadSpeed;
    BCVA      -> CS_end;
    BCVA      -> VFI_end;
    VEGFA165  -> VitVEGF   [label="main source\nin vitreous"];
    PlGF      -> VitVEGF;
    IL1b      -> VitCyto;
    IL6       -> VitCyto;
    TNFa      -> VitCyto;
    Ang2      -> AngVitF   [label="vitreous\nconc."];

    /* --- Legend --- */
    subgraph cluster_legend {
        label="Legend"; style=filled; color="#FFFDE7"; fontsize=11;
        node [shape=ellipse, fontsize=9, width=2.2];
        L1 [label="↑ Activation / Upregulation",       fillcolor="#FFCDD2", color=red];
        L2 [label="↓ Inhibition / Downregulation",     fillcolor="#BBDEFB", color=blue];
        L3 [label="Key Therapeutic Target (green)",     fillcolor="#C8E6C9", color="#1B5E20"];
        L4 [label="Disease Milestone / Lesion (purple)",fillcolor="#CE93D8", color="#4A148C"];
        L5 [label="Drug / Intervention (teal)",         fillcolor="#B2EBF2", color="#006064"];
    }
}
