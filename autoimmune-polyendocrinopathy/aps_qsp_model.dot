digraph APS_QSP {
  graph [
    label="Autoimmune Polyendocrinopathy Syndrome (APS/APECED)\nQuantitative Systems Pharmacology Model"
    labelloc=t
    fontsize=22
    fontname="Helvetica-Bold"
    rankdir=TB
    splines=ortho
    nodesep=0.4
    ranksep=0.6
    bgcolor="#FAFAFA"
    pad=0.5
  ]
  node [fontname="Helvetica" fontsize=10 style="filled,rounded" shape=box]
  edge [fontname="Helvetica" fontsize=8 arrowsize=0.7]

  /* ============================================================
     CLUSTER 1: AIRE Gene & Thymic Central Tolerance
  ============================================================ */
  subgraph cluster_aire {
    label="AIRE Gene & Thymic Central Tolerance"
    style=filled fillcolor="#EEF4FF" color="#4A6FA5" penwidth=2.5 fontsize=14 fontcolor="#1A3A6B"

    AIRE_gene  [label="AIRE Gene\n(Chr 21q22.3)" fillcolor="#B8D0FF" shape=oval]
    AIRE_prot  [label="AIRE Protein\n(Nuclear/Cytoplasmic)" fillcolor="#B8D0FF"]
    AIRE_mut   [label="AIRE Mutation\n(>300 known)\n[APS1 defining]" fillcolor="#FF9999" shape=diamond]
    AIRE_func  [label="AIRE Function\n(0→1 scale)" fillcolor="#7FB3F5"]

    mTEC_immat [label="Immature mTEC\n(medullary thymic\nepithelial cells)" fillcolor="#C5E8FF"]
    mTEC_mat   [label="Mature mTEC\n(AIRE+)" fillcolor="#90C8FF"]
    TSA_expr   [label="Tissue-Specific\nAntigen (TSA)\nExpression\n(Promiscuous gene\nexpression)" fillcolor="#80C9F0"]
    neg_sel    [label="Negative Selection\n(Autoreactive T cell\nelimination)" fillcolor="#82D9A5"]
    pos_sel    [label="Positive Selection\n(MHC restriction)" fillcolor="#95DDB5"]
    Treg_thy   [label="Thymic Treg\nGeneration\n(FoxP3+ CD4+)" fillcolor="#A8E6C4"]
    cTEC       [label="Cortical TEC\n(cTEC)" fillcolor="#C5E8FF"]
    DN_T       [label="Double-Negative\nThymocyte (DN)" fillcolor="#D0EAF8"]
    DP_T       [label="Double-Positive\nThymocyte (DP)" fillcolor="#C0E0F5"]
    SP4_T      [label="Single-Positive\nCD4+ Thymocyte" fillcolor="#B0D8F0"]
    SP8_T      [label="Single-Positive\nCD8+ Thymocyte" fillcolor="#A0D0EC"]
    clonal_del [label="Clonal Deletion\n(Apoptosis)" fillcolor="#FFB3B3"]
    clonal_ign [label="Clonal Ignorance" fillcolor="#FFCCCC"]
    HLA_II     [label="HLA Class II\n(DR, DQ, DP)\nPresentation" fillcolor="#C8D8FF"]
    HLA_I      [label="HLA Class I\n(A, B, C)\nPresentation" fillcolor="#C8D8FF"]
  }

  /* ============================================================
     CLUSTER 2: Peripheral Tolerance & Immune Regulation
  ============================================================ */
  subgraph cluster_periph {
    label="Peripheral Tolerance & Immune Regulation"
    style=filled fillcolor="#F0FFF0" color="#3A7D44" penwidth=2.5 fontsize=14 fontcolor="#1A5C25"

    Treg_periph [label="Peripheral Treg\n(FoxP3+ CD4+ CD25+)" fillcolor="#82D9A5"]
    Treg_func   [label="Treg Function\n(Suppression)" fillcolor="#68C490"]
    CTLA4       [label="CTLA-4\n(B7 blocking)" fillcolor="#50B07B"]
    PD1         [label="PD-1 / PD-L1\nCheckpoint" fillcolor="#60BF8A"]
    IL10_Treg   [label="IL-10\n(Treg-derived)" fillcolor="#A8E6C4"]
    TGFb_Treg   [label="TGF-β\n(Treg-derived)" fillcolor="#A8E6C4"]
    anergy      [label="T Cell Anergy\n(CD28 co-stim\nfailure)" fillcolor="#C5F0D0"]
    Breg        [label="Regulatory B Cells\n(Breg, IL-10+)" fillcolor="#90D8A8"]
    FOXP3_mut   [label="FOXP3 Dysfunction\nin APS1" fillcolor="#FF9999" shape=diamond]
    APC_periph  [label="Peripheral APC\n(DC, Macrophage)" fillcolor="#B8ECC5"]
    memory_T    [label="Memory\nAutoreactive T" fillcolor="#FFBBBB"]
    effector_T  [label="Effector\nAutoreactive T" fillcolor="#FF9999"]
  }

  /* ============================================================
     CLUSTER 3: Autoantibody Production & B Cell Activation
  ============================================================ */
  subgraph cluster_autoAb {
    label="Autoantibody Production & B Cell Activation"
    style=filled fillcolor="#FFF8E8" color="#C07820" penwidth=2.5 fontsize=14 fontcolor="#7A4A00"

    B_naive    [label="Naive B Cell" fillcolor="#FFE4B5"]
    B_activated[label="Activated B Cell\n(GC Reaction)" fillcolor="#FFD080"]
    B_plasma   [label="Plasma Cell\n(Ab secreting)" fillcolor="#FFC040"]
    B_memory   [label="Memory B Cell" fillcolor="#FFD8A0"]
    GC_rxn     [label="Germinal Center\nReaction\n(Somatic\nHypermutation)" fillcolor="#FFE0A0"]
    Tfh        [label="T follicular helper\n(Tfh CD4+ CXCR5+)" fillcolor="#FFA080"]
    AID        [label="Activation-Induced\nCytidine Deaminase\n(AID/AICDA)" fillcolor="#FFD080"]
    complement [label="Complement\nActivation\n(C1q, C3, C5)" fillcolor="#FFB860"]
    ADCC       [label="ADCC\n(NK cell-mediated)" fillcolor="#FFB060"]
    Ab_class_sw[label="Class Switching\n(IgM→IgG/IgA)" fillcolor="#FFD090"]

    /* Major autoantibodies */
    Ab_21OH    [label="Anti-21-Hydroxylase\nIgG\n(Adrenal autoAb)" fillcolor="#FF9040" shape=oval]
    Ab_NALP5   [label="Anti-NALP5/CASR\nIgG\n(Parathyroid autoAb)" fillcolor="#FF9040" shape=oval]
    Ab_GAD65   [label="Anti-GAD65/IA-2\nIgG\n(Beta-cell autoAb)" fillcolor="#FF9040" shape=oval]
    Ab_TPO     [label="Anti-TPO/TG\nIgG\n(Thyroid autoAb)" fillcolor="#FF9040" shape=oval]
    Ab_IFNA    [label="Anti-IFN-α\nAutoantibodies\n[Pathognomonic\nin APS1]" fillcolor="#FF6020" shape=oval]
    Ab_IFNW    [label="Anti-IFN-ω\nAutoantibodies" fillcolor="#FF7030" shape=oval]
    Ab_17OH    [label="Anti-17-Hydroxylase\n(Gonadal autoAb)" fillcolor="#FF9040" shape=oval]
    Ab_AIF     [label="Anti-Parietal Cell /\nAnti-Intrinsic Factor\n(Gastric autoAb)" fillcolor="#FF9040" shape=oval]
    Ab_ANA     [label="Anti-Nuclear Ab\n(ANA)" fillcolor="#FFB060" shape=oval]
    FcR_bind   [label="FcγR Binding\n(Macrophage/NK)" fillcolor="#FFC070"]
  }

  /* ============================================================
     CLUSTER 4: Cytokine & Inflammatory Network
  ============================================================ */
  subgraph cluster_cytokine {
    label="Cytokine & Inflammatory Network"
    style=filled fillcolor="#FFF0F8" color="#A03070" penwidth=2.5 fontsize=14 fontcolor="#600040"

    IFNg       [label="IFN-γ\n(Th1 key cytokine)" fillcolor="#F0A0C0"]
    IL12       [label="IL-12\n(DC/Macrophage)" fillcolor="#F0A0C0"]
    IL23       [label="IL-23\n(Th17 amplifier)" fillcolor="#F5A8CC"]
    IL17       [label="IL-17A/F\n(Th17 effector)" fillcolor="#F0A0C0"]
    IL6        [label="IL-6\n(Pleiotropic)" fillcolor="#E890B8"]
    IL1b       [label="IL-1β\n(Inflammasome)" fillcolor="#E890B8"]
    TNFa       [label="TNF-α\n(Systemic inflam)" fillcolor="#E080B0"]
    IL21       [label="IL-21\n(Tfh/B cell help)" fillcolor="#F0A8C8"]
    IL4        [label="IL-4\n(Th2 / B-cell isotype)" fillcolor="#E8B0D0"]
    IL10_eff   [label="IL-10\n(Anti-inflammatory)" fillcolor="#C8F0D8"]
    TGFb_eff   [label="TGF-β\n(Fibrosis/Treg)" fillcolor="#C8F0D8"]
    BAFF       [label="BAFF/BLyS\n(B cell survival)" fillcolor="#F0B8D0"]
    APRIL      [label="APRIL\n(Plasma cell\nsurvival)" fillcolor="#F0B8D0"]
    JAK_STAT   [label="JAK-STAT Signaling\n(JAK1/2, STAT1/3/4/6)" fillcolor="#F5C0D8"]
    NF_kB      [label="NF-κB Pathway\n(Inflammatory\ngene induction)" fillcolor="#F5C0D8"]
    NLRP3      [label="NLRP3\nInflammasome" fillcolor="#F5C0D8"]
    Th1_cell   [label="Th1 CD4+ T\n(IFN-γ producer)" fillcolor="#F8D0E4"]
    Th17_cell  [label="Th17 CD4+ T\n(IL-17 producer)" fillcolor="#F8D0E4"]
    Th2_cell   [label="Th2 CD4+ T\n(IL-4/IL-13)" fillcolor="#F8D0E4"]
    CD8_Teff   [label="CD8+ Cytotoxic T\n(CTL, Tissue damage)" fillcolor="#FF9999"]
  }

  /* ============================================================
     CLUSTER 5: Adrenal Gland Pathology (Addison's Disease)
  ============================================================ */
  subgraph cluster_adrenal {
    label="Adrenal Gland Pathology — Addison's Disease"
    style=filled fillcolor="#FFF0E8" color="#B05020" penwidth=2.5 fontsize=14 fontcolor="#703010"

    adrenal_mass   [label="Adrenocortical\nMass/Function\n(%, 0-100)" fillcolor="#FFCCA0"]
    adrenal_inflam [label="Adrenal\nInflammation\n(CD8+ infiltrate)" fillcolor="#FFB080"]
    adrenal_fibros [label="Adrenal Fibrosis\n& Atrophy" fillcolor="#E8A080"]
    cortisol_prod  [label="Cortisol\nProduction Rate\n(μg/day)" fillcolor="#FFA060"]
    cortisol_plasma[label="Plasma Cortisol\n[C_plasma]\n(μg/dL)" fillcolor="#FF8040" shape=oval]
    ACTH_pit       [label="ACTH\n(Pituitary)\n(pg/mL)" fillcolor="#D08050" shape=oval]
    CRH_hyp        [label="CRH\n(Hypothalamus)" fillcolor="#C07040"]
    HPA_axis       [label="HPA Axis\nFeedback Loop\n(−FB cortisol)" fillcolor="#FFD0B0"]
    aldo_prod      [label="Aldosterone\nProduction\n(Zona glomerulosa)" fillcolor="#FFC090"]
    aldo_plasma    [label="Plasma Aldosterone\n(pg/mL)" fillcolor="#FFB070" shape=oval]
    RAAS           [label="RAAS\n(Renin-Angiotensin-\nAldosterone)" fillcolor="#D09060"]
    Na_K_balance   [label="Na+/K+ Balance\n(Serum Na+/K+)" fillcolor="#FFD0A0"]
    gluconeo       [label="Gluconeogenesis\n(Liver, suppressed)" fillcolor="#FFCCB0"]
    cortisol_immun [label="Cortisol\nImmunomodulation\n(anti-inflam)" fillcolor="#FFD8C0"]
    ADR_medulla    [label="Adrenal Medulla\n(Catecholamines)" fillcolor="#E8BDA0"]
    Epi_release    [label="Epinephrine\nRelease\n(Stress response)" fillcolor="#F0C8B0"]
  }

  /* ============================================================
     CLUSTER 6: Parathyroid Pathology (Hypoparathyroidism)
  ============================================================ */
  subgraph cluster_parathyroid {
    label="Parathyroid Pathology — Hypoparathyroidism"
    style=filled fillcolor="#F0F8FF" color="#2060A0" penwidth=2.5 fontsize=14 fontcolor="#103060"

    PTG_mass    [label="Parathyroid\nGland Mass/\nFunction (%)" fillcolor="#A0D0FF"]
    PTG_inflam  [label="Parathyroid\nInflammation\n(Lymphocyte infiltrate)" fillcolor="#80B8F0"]
    PTH_prod    [label="PTH Production\nRate" fillcolor="#60A0E0"]
    PTH_plasma  [label="Plasma PTH\n[PTH_plasma]\n(pg/mL)" fillcolor="#4090D0" shape=oval]
    Ca_serum    [label="Serum Calcium\n[Ca_serum]\n(mg/dL)" fillcolor="#C8E8FF" shape=oval]
    Phos_serum  [label="Serum Phosphate\n[P_serum]\n(mg/dL)" fillcolor="#C8E8FF" shape=oval]
    VitD_active [label="1,25(OH)₂D\nCalcitriol\n(ng/mL)" fillcolor="#90C8F0" shape=oval]
    VitD_25OH   [label="25(OH)D\n(Substrate)" fillcolor="#B0D8FF"]
    Ca_GI_abs   [label="GI Calcium\nAbsorption\n(PTH/VitD dependent)" fillcolor="#D0EAFF"]
    Ca_renal_ret[label="Renal Ca²⁺\nReabsorption\n(DCT, TRPV5)" fillcolor="#C0E0FF"]
    bone_Ca_mob [label="Bone Calcium\nMobilization\n(Osteoclast)" fillcolor="#B0D8FF"]
    CASR        [label="Calcium-Sensing\nReceptor (CASR)\n(CaSR/CASR1)" fillcolor="#80B8F8"]
    neuromuscul [label="Neuromuscular\nExcitability\n(Tetany, Seizure)" fillcolor="#FF9999"]
    chvostek    [label="Chvostek/\nTrousseau Sign" fillcolor="#FFB0B0"]
    QTc_prolong [label="QTc Prolongation\n(Cardiac)" fillcolor="#FFB0B0"]
  }

  /* ============================================================
     CLUSTER 7: Pancreatic Beta Cell Pathology (T1DM in APS1)
  ============================================================ */
  subgraph cluster_pancreas {
    label="Pancreatic Beta Cell Pathology — T1DM Component"
    style=filled fillcolor="#F5FFF0" color="#306030" penwidth=2.5 fontsize=14 fontcolor="#103010"

    beta_mass   [label="Beta Cell\nMass/Function\n(% of normal)" fillcolor="#B0E0A0"]
    beta_inflam [label="Insulitis\n(CD4+/CD8+ infiltrate)" fillcolor="#90CC80"]
    beta_apop   [label="Beta Cell\nApoptosis\n(FasL, Perforin)" fillcolor="#FF9999"]
    insulin_sec [label="Insulin Secretion\nRate (pmol/min)" fillcolor="#70BA60"]
    insulin_plas[label="Plasma Insulin\n[Ins_plasma]\n(pmol/L)" fillcolor="#50A840" shape=oval]
    glucose_plas[label="Plasma Glucose\n[G_plasma]\n(mg/dL)" fillcolor="#90D080" shape=oval]
    glucagon    [label="Glucagon\n(Alpha cell)" fillcolor="#B0E0A0"]
    GLP1        [label="GLP-1\n(Incretin)" fillcolor="#C0EAB0"]
    insulin_sens[label="Insulin\nSensitivity\n(SI)" fillcolor="#A8E098"]
    hepatic_glu [label="Hepatic Glucose\nOutput (HGO)" fillcolor="#C8F0B8"]
    HbA1c       [label="HbA1c\n(%)\n[Clinical endpoint]" fillcolor="#50A840" shape=octagon]
    FPG         [label="Fasting Plasma\nGlucose (mg/dL)" fillcolor="#70C060" shape=octagon]
    C_peptide   [label="C-Peptide\n(Beta cell residual)" fillcolor="#A0D890" shape=oval]
    ZnT8        [label="ZnT8 Autoantigen\n(Zinc transporter)" fillcolor="#C0E8B0"]
  }

  /* ============================================================
     CLUSTER 8: Thyroid Pathology (in APS with Hashimoto's)
  ============================================================ */
  subgraph cluster_thyroid {
    label="Thyroid Pathology — Hashimoto's Component"
    style=filled fillcolor="#FFFAE8" color="#9A8020" penwidth=2.5 fontsize=14 fontcolor="#5A4800"

    thyroid_mass  [label="Thyroid Gland\nMass/Function (%)" fillcolor="#FFE8A0"]
    thyroid_inflam[label="Thyroid\nInflammation\n(Lymphocyte infiltrate)" fillcolor="#FFD880"]
    thyroid_fibros[label="Thyroid Fibrosis\n& Goiter" fillcolor="#EEC860"]
    TSH_plasma    [label="Serum TSH\n[TSH_plasma]\n(mIU/L)" fillcolor="#FFD060" shape=oval]
    FT4_plasma    [label="Serum Free T4\n[FT4_plasma]\n(ng/dL)" fillcolor="#FFD060" shape=oval]
    FT3_plasma    [label="Serum Free T3\n[FT3_plasma]\n(pg/mL)" fillcolor="#FFD060" shape=oval]
    T4_prod       [label="T4 Production\n(Thyroglobulin\ncleaved)" fillcolor="#EEC060"]
    T3_periph     [label="T4→T3\nConversion\n(5'-Deiodinase)" fillcolor="#E0B050"]
    TRH_hyp       [label="TRH\n(Hypothalamus)" fillcolor="#D0A040"]
    HPT_axis      [label="HPT Axis\nFeedback Loop" fillcolor="#FFE8C0"]
    TPO_enzyme    [label="Thyroid\nPeroxidase (TPO)\nIodination of Tg" fillcolor="#F0C860"]
    NIS           [label="Na⁺/I⁻ Symporter\n(NIS)" fillcolor="#E0B860"]
    thyroid_meta  [label="Thyroid Hormone\nMetabolic Effects\n(BMR, HR, Temp)" fillcolor="#FFF0C8"]
    BMR           [label="Basal Metabolic\nRate (BMR)" fillcolor="#FFE8B0" shape=octagon]
  }

  /* ============================================================
     CLUSTER 9: Drug PK — Hormone Replacement Therapies
  ============================================================ */
  subgraph cluster_HRT {
    label="Drug PK — Hormone Replacement Therapies"
    style=filled fillcolor="#F8F0FF" color="#6030A0" penwidth=2.5 fontsize=14 fontcolor="#3A1060"

    /* Glucocorticoid Replacement */
    HC_dose    [label="Hydrocortisone\nDose (mg/day)\n[Oral]" fillcolor="#D0A8FF" shape=parallelogram]
    HC_gut     [label="HC GI Absorption\n(F=0.96)" fillcolor="#C090F0"]
    HC_plasma  [label="HC Plasma Conc\n[HC_central]\n(μg/dL)" fillcolor="#B070E0" shape=oval]
    HC_tissue  [label="HC Tissue Conc\n[HC_tissue]" fillcolor="#A060D0"]
    HC_metab   [label="HC Metabolism\n(CYP3A4/CYP11B1)\nt½=1.5-2h" fillcolor="#9050C0"]
    CBG        [label="Cortisol-Binding\nGlobulin (CBG)" fillcolor="#C0A0F0"]
    cortisol_free[label="Free Cortisol\n(Active fraction,\n5-10%)" fillcolor="#B080E0" shape=oval]
    GCR        [label="Glucocorticoid\nReceptor (GR/NR3C1)" fillcolor="#A070D0"]

    /* Mineralocorticoid */
    FC_dose    [label="Fludrocortisone\nDose (μg/day)" fillcolor="#D0A8FF" shape=parallelogram]
    FC_plasma  [label="Fludrocortisone\nPlasma Conc\n(ng/mL)" fillcolor="#B070E0" shape=oval]
    MCR        [label="Mineralocorticoid\nReceptor (MR)" fillcolor="#A060D0"]

    /* Calcium/VitD Replacement */
    CaSup_dose [label="Calcium Supplement\nDose (mg/day)" fillcolor="#80C8FF" shape=parallelogram]
    CalcD_dose [label="Calcitriol Dose\n(μg/day)" fillcolor="#80C8FF" shape=parallelogram]
    calcitriol_plas[label="Calcitriol Plasma\n(1,25(OH)₂D)\n(pg/mL)" fillcolor="#60B0F0" shape=oval]
    VitD_rec   [label="VDR\n(Vitamin D Receptor)" fillcolor="#50A0E0"]

    /* Thyroid Hormone Replacement */
    LT4_dose   [label="Levothyroxine\nDose (μg/day)" fillcolor="#FFE080" shape=parallelogram]
    LT4_gut    [label="LT4 GI Absorption\n(F=0.75-0.80)" fillcolor="#FFCC60"]
    LT4_plasma [label="Levothyroxine\nPlasma Conc\n[LT4_plasma]" fillcolor="#FFB840" shape=oval]
    LT4_tissue [label="T3 in Tissues\n(Active)" fillcolor="#FFA020"]
  }

  /* ============================================================
     CLUSTER 10: Drug PK — Immunosuppressants & Novel Therapies
  ============================================================ */
  subgraph cluster_immuno {
    label="Drug PK — Immunosuppressants & Novel Therapies"
    style=filled fillcolor="#F0FFF8" color="#20906050" penwidth=2.5 fontsize=14 fontcolor="#105030"

    /* Cyclosporine A */
    CsA_dose   [label="Cyclosporine A\nDose (mg/kg/day)" fillcolor="#80E8A8" shape=parallelogram]
    CsA_plasma [label="CsA Plasma Conc\n[CsA_plasma]\n(ng/mL)" fillcolor="#50D080" shape=oval]
    CsA_mech   [label="CsA Mechanism\n(Calcineurin inhibition\n→ NFAT block)" fillcolor="#40C070"]
    CsA_IL2    [label="IL-2 Suppression\nby CsA" fillcolor="#30B060"]

    /* Abatacept / CTLA4-Ig */
    Aba_dose   [label="Abatacept\n(CTLA4-Ig)\n125mg SC/wk" fillcolor="#80E8A8" shape=parallelogram]
    Aba_plasma [label="Abatacept\nPlasma Conc\n(μg/mL)" fillcolor="#50D080" shape=oval]
    Aba_mech   [label="Abatacept Mechanism\n(CD28/B7 blockade\n→ co-stim block)" fillcolor="#40C070"]

    /* Rituximab */
    RTX_dose   [label="Rituximab\n(Anti-CD20)\n375mg/m²" fillcolor="#80E8A8" shape=parallelogram]
    RTX_plasma [label="Rituximab\nPlasma Conc\n(μg/mL)" fillcolor="#50D080" shape=oval]
    RTX_mech   [label="Rituximab Mechanism\n(CD20+ B cell depletion\nADCC + CDC)" fillcolor="#40C070"]
    B_depletion[label="B Cell\nDepletion\n(>99%)" fillcolor="#FF9999"]

    /* Tofacitinib / JAK inhibition */
    JAKi_dose  [label="JAK Inhibitor\n(Tofacitinib 5mg BID)" fillcolor="#80E8A8" shape=parallelogram]
    JAKi_plasma[label="JAKi Plasma Conc\n(ng/mL)" fillcolor="#50D080" shape=oval]
    JAKi_mech  [label="JAKi Mechanism\n(JAK1/JAK3 block\n→ STAT1/3/5 block)" fillcolor="#40C070"]

    /* IVIG */
    IVIG_dose  [label="IVIG\n(1-2g/kg monthly)" fillcolor="#80E8A8" shape=parallelogram]
    IVIG_mech  [label="IVIG Mechanism\n(FcR saturation,\nAb neutralization)" fillcolor="#40C070"]
  }

  /* ============================================================
     CLUSTER 11: Clinical Endpoints & Monitoring
  ============================================================ */
  subgraph cluster_endpoints {
    label="Clinical Endpoints & Monitoring"
    style=filled fillcolor="#FFFFF0" color="#808020" penwidth=2.5 fontsize=14 fontcolor="#484800"

    /* Disease Activity */
    disease_comp  [label="Number of Disease\nComponents\n(0→7+)" fillcolor="#FFFF90" shape=octagon]
    endocrine_fail[label="Endocrine\nFunction Score\n(0→100%)" fillcolor="#FFFF90" shape=octagon]
    APS_score     [label="APS Composite\nDisease Score" fillcolor="#FFEE60" shape=octagon]

    /* Adrenal endpoints */
    morning_cort  [label="AM Cortisol\n(8am serum, μg/dL)\n[< 3 = adrenal fail]" fillcolor="#FFC080" shape=octagon]
    stim_test     [label="ACTH Stimulation\nTest\n(Peak cortisol)" fillcolor="#FFB060" shape=octagon]

    /* Parathyroid endpoints */
    Ca_corrected  [label="Corrected Serum\nCa²⁺ (mg/dL)\n[Endpoint]" fillcolor="#A0D8FF" shape=octagon]
    tetany_risk   [label="Tetany Risk\nScore (0→5)" fillcolor="#FFB0B0" shape=octagon]

    /* Pancreas endpoints */
    HbA1c_end     [label="HbA1c (%)\n[<7.0 target]" fillcolor="#90D070" shape=octagon]
    TDD_insulin   [label="Total Daily Insulin\nDose (units/day)" fillcolor="#70C050" shape=octagon]
    CGM_TIR       [label="CGM Time-in-Range\n(70-180 mg/dL, %)" fillcolor="#80D060" shape=octagon]

    /* Thyroid endpoints */
    TSH_normal    [label="TSH Normalization\n(0.4-4.0 mIU/L)" fillcolor="#FFEE80" shape=octagon]
    FT4_normal    [label="FT4 Normalization\n(0.8-1.8 ng/dL)" fillcolor="#FFEE80" shape=octagon]

    /* Autoantibody monitoring */
    Ab_21OH_titer [label="Anti-21OH Ab\nTiter (U/mL)\n[>1: adrenal risk]" fillcolor="#FFA040" shape=octagon]
    Ab_screen     [label="Annual AutoAb\nScreening Panel" fillcolor="#FFB060" shape=octagon]

    /* Quality of Life */
    QoL           [label="Quality of Life\n(SF-36)\n[Patient-reported]" fillcolor="#FFFF90" shape=octagon]
    ADL           [label="Activities of\nDaily Living\n(ADL score)" fillcolor="#FFFF90" shape=octagon]
    fatigue       [label="Chronic Fatigue\nScore (VAS)" fillcolor="#FFDD80" shape=octagon]

    /* Infection risk */
    infect_risk   [label="Infection Risk\n(Candida, CMV,\nPneumonia)" fillcolor="#FF9090" shape=octagon]
    candida_oral  [label="Chronic Mucocutaneous\nCandidiasis (CMC)\n[1st APS1 criterion]" fillcolor="#FF8080" shape=octagon]
    candida_anti  [label="Anti-Candida\nImmune Response" fillcolor="#FFA090"]
  }

  /* ============================================================
     EDGE DEFINITIONS — MAIN PATHWAYS
  ============================================================ */

  /* AIRE gene → protein → function */
  AIRE_gene -> AIRE_prot [label="Transcription\nTranslation" color="#4A6FA5"]
  AIRE_mut -> AIRE_func [label="Reduces 0-100%\nloss-of-function" color="red" style=dashed]
  AIRE_prot -> AIRE_func [label="Protein activity" color="#4A6FA5"]
  AIRE_func -> TSA_expr [label="Enables promiscuous\ngene expression" color="#4A6FA5"]
  AIRE_func -> mTEC_mat [label="AIRE expression in\nmature mTEC" color="#4A6FA5"]

  /* Thymic education */
