digraph SCD_QSP {
    graph [
        label="Sickle Cell Disease (SCD): Quantitative Systems Pharmacology Model\nHbS Polymerization · RBC Sickling · Hemolysis · Vaso-occlusion · Drug PK/PD",
        labelloc=t,
        fontsize=22,
        fontname="Helvetica-Bold",
        rankdir=LR,
        splines=ortho,
        nodesep=0.45,
        ranksep=1.2,
        bgcolor="#F7F9FC",
        pad=0.6
    ];
    node [shape=box, style="filled,rounded", fontname="Helvetica", fontsize=11, margin="0.2,0.1"];
    edge [fontname="Helvetica", fontsize=9, arrowsize=0.7];

    /* ─────────────────────────────────────────────────────────
       CLUSTER 1 — HbS Genetics & Molecular Pathophysiology
    ───────────────────────────────────────────────────────── */
    subgraph cluster_genetics {
        label="HbS Genetics & Molecular Pathophysiology";
        style="filled"; color="#3A5F8A"; fillcolor="#EBF1FB"; fontcolor="#3A5F8A";
        fontsize=14; fontname="Helvetica-Bold";

        HBB_gene      [label="HBB Gene\n(β-globin locus 11p15.4)", fillcolor="#AED6F1"];
        Glu6Val       [label="E6V Mutation\n(Glu→Val, codon 6)", fillcolor="#AED6F1"];
        alpha_globin  [label="α-Globin Chain\n(HBA1/HBA2)", fillcolor="#D6EAF8"];
        beta_S        [label="βS-Globin Chain\n(Mutant)", fillcolor="#AED6F1"];
        beta_A        [label="βA-Globin Chain\n(Normal)", fillcolor="#D6EAF8"];
        gamma_globin  [label="γ-Globin Chain\n(HBG1/HBG2)", fillcolor="#D6EAF8"];
        HbS_tetramer  [label="HbS Tetramer\n(α₂βS₂)", fillcolor="#85C1E9"];
        HbA_tetramer  [label="HbA Tetramer\n(α₂βA₂, Normal)", fillcolor="#D6EAF8"];
        HbF_tetramer  [label="HbF Tetramer\n(α₂γ₂, Fetal Hb)", fillcolor="#A9DFBF"];
        HbA2_tetramer [label="HbA2 Tetramer\n(α₂δ₂)", fillcolor="#D6EAF8"];
        BCL11A        [label="BCL11A\n(γ-globin repressor)", fillcolor="#F9E79F"];
        KLF1          [label="KLF1\n(Erythroid TF)", fillcolor="#F9E79F"];
        deoxy_HbS     [label="Deoxy-HbS\n(Deoxygenated form)", fillcolor="#85C1E9"];
        HbS_polymer   [label="HbS Polymer\n(14-strand fibers)", fillcolor="#5DADE2"];
        MCHC          [label="MCHC\n(Intracellular HbS conc.)", fillcolor="#D6EAF8"];
        P50_value     [label="P₅₀ (mmHg)\nO₂ Dissociation Curve", fillcolor="#D6EAF8"];
        nucleation    [label="Nucleation Phase\n(Delay period)", fillcolor="#5DADE2"];
        polymer_growth[label="Polymer Growth\n(Exponential kinetics)", fillcolor="#5DADE2"];
        polymerization_Kd [label="Polymerization Kd\n(Conc. threshold)", fillcolor="#85C1E9"];
    }

    /* ─────────────────────────────────────────────────────────
       CLUSTER 2 — Erythropoiesis & RBC Biology
    ───────────────────────────────────────────────────────── */
    subgraph cluster_erythropoiesis {
        label="Erythropoiesis & RBC Biology";
        style="filled"; color="#6B4226"; fillcolor="#FDEBD0"; fontcolor="#6B4226";
        fontsize=14; fontname="Helvetica-Bold";

        EPO           [label="Erythropoietin (EPO)\n(Kidney→Bone marrow)", fillcolor="#FDEBD0"];
        EPOR          [label="EPO Receptor\n(EPOR/JAK2/STAT5)", fillcolor="#FDEBD0"];
        BFU_E         [label="BFU-E\n(Burst Forming Unit–E)", fillcolor="#E59866"];
        CFU_E         [label="CFU-E\n(Colony Forming Unit–E)", fillcolor="#E59866"];
        proerythro    [label="Proerythroblast\n(Nucleated)", fillcolor="#DC7633"];
        basophilic_E  [label="Basophilic\nErythroblast", fillcolor="#DC7633"];
        polychromatic [label="Polychromatophilic\nErythroblast", fillcolor="#DC7633"];
        orthochromatic[label="Orthochromatic\nErythroblast", fillcolor="#DC7633"];
        reticulocyte  [label="Reticulocyte\n(Immature RBC)", fillcolor="#A04000"];
        young_RBC     [label="Young RBC\n(Days 0–30)", fillcolor="#A04000"];
        dense_RBC     [label="Dense RBC\n(Dehydrated, high MCHC)", fillcolor="#7B241C"];
        sickle_RBC    [label="Sickle RBC\n(Distorted morphology)", fillcolor="#7B241C"];
        normal_Hb_RBC [label="HbA/HbF RBC\n(Non-sickling)", fillcolor="#E59866"];
        RBC_lifespan  [label="RBC Lifespan\n(10–20 d vs 120 d normal)", fillcolor="#A04000"];
        KCC_channel   [label="KCC Transporter\n(K-Cl cotransport)", fillcolor="#FDEBD0"];
        gardos_channel[label="Gardos Channel\n(KCNN4/IK1)", fillcolor="#FDEBD0"];
        PS_exposure   [label="Phosphatidylserine\nExposure (Apoptosis signal)", fillcolor="#A04000"];
        RBC_dehydration[label="RBC Dehydration\n(Cell shrinkage)", fillcolor="#7B241C"];
    }

    /* ─────────────────────────────────────────────────────────
       CLUSTER 3 — Hemolysis & Anemia
    ───────────────────────────────────────────────────────── */
    subgraph cluster_hemolysis {
        label="Hemolysis & Anemia";
        style="filled"; color="#922B21"; fillcolor="#FDEDEC"; fontcolor="#922B21";
        fontsize=14; fontname="Helvetica-Bold";

        intravascular_lysis [label="Intravascular\nHemolysis", fillcolor="#F1948A"];
        extravascular_lysis [label="Extravascular Hemolysis\n(Spleen/Liver)", fillcolor="#F1948A"];
        cell_free_Hb   [label="Cell-Free Hb\n(Plasma, μM)", fillcolor="#EC7063"];
        haptoglobin    [label="Haptoglobin\n(Hp, scavenger protein)", fillcolor="#F9EBEA"];
        Hb_Hp_complex  [label="Hb-Hp Complex\n(CD163-mediated uptake)", fillcolor="#EC7063"];
        hemopexin      [label="Hemopexin\n(Heme scavenger)", fillcolor="#F9EBEA"];
        free_heme      [label="Free Heme\n(Pro-inflammatory/toxic)", fillcolor="#C0392B"];
        HO1            [label="Heme Oxygenase-1\n(HO-1, cytoprotective)", fillcolor="#F9EBEA"];
        bilirubin      [label="Unconjugated Bilirubin\n(μmol/L)", fillcolor="#F9E79F"];
        LDH            [label="LDH\n(Hemolysis marker, U/L)", fillcolor="#EC7063"];
        AST_plasma     [label="AST (Plasma)\n(Hemolysis marker)", fillcolor="#EC7063"];
        iron_overload  [label="Iron Overload\n(Ferritin, μg/L)", fillcolor="#C0392B"];
        transferrin    [label="Transferrin\n(Iron transport)", fillcolor="#F9EBEA"];
        ferritin       [label="Ferritin\n(Iron storage)", fillcolor="#F9EBEA"];
        Hgb_total      [label="Total Hemoglobin\n(g/dL, target >9)", fillcolor="#C0392B"];
        reticulocyte_pct[label="Reticulocyte %\n(5–20% in SCD)", fillcolor="#F1948A"];
        HbF_pct        [label="HbF %\n(Protective, target >20%)", fillcolor="#A9DFBF"];
        anemia_severity[label="Anemia Severity\n(Hgb 6–9 g/dL)", fillcolor="#C0392B"];
    }

    /* ─────────────────────────────────────────────────────────
       CLUSTER 4 — Vaso-occlusion & Adhesion Cascade
    ───────────────────────────────────────────────────────── */
    subgraph cluster_vaso {
        label="Vaso-occlusion & Adhesion Cascade";
        style="filled"; color="#1A5276"; fillcolor="#EBF5FB"; fontcolor="#1A5276";
        fontsize=14; fontname="Helvetica-Bold";

        P_selectin    [label="P-Selectin\n(CD62P, endothelium)", fillcolor="#AED6F1"];
        E_selectin    [label="E-Selectin\n(CD62E, induced by TNF-α)", fillcolor="#AED6F1"];
        VCAM1         [label="VCAM-1\n(CD106, adhesion molecule)", fillcolor="#AED6F1"];
        ICAM1         [label="ICAM-1\n(CD54, adhesion molecule)", fillcolor="#AED6F1"];
        VWF_multimers [label="vWF Multimers\n(Ultra-large, ULVWF)", fillcolor="#85C1E9"];
        PSGL1         [label="PSGL-1\n(CD162, on WBC/RBC)", fillcolor="#5DADE2"];
        alpha4beta1   [label="α4β1 Integrin\n(VLA-4, sickle RBC)", fillcolor="#5DADE2"];
        Lu_BCAM       [label="Lu/BCAM\n(Laminin receptor, RBC)", fillcolor="#5DADE2"];
        TSP1          [label="Thrombospondin-1\n(TSP-1, bridging)", fillcolor="#5DADE2"];
        CD47          [label="CD47\n('Don't eat me' signal)", fillcolor="#AED6F1"];
        neutrophil_act [label="Neutrophil\nActivation/Adhesion", fillcolor="#85C1E9"];
        WBC_RBC_bridge [label="WBC-RBC-Endothelium\nBridging Complex", fillcolor="#2E86C1"];
        microvascular_stasis [label="Microvascular\nStasis", fillcolor="#1A5276", fontcolor="white"];
        VOC_rate      [label="VOC Annual Rate\n(Crises/year)", fillcolor="#1A5276", fontcolor="white"];
        ischemia_reperfusion [label="Ischemia-\nReperfusion Injury", fillcolor="#1A5276", fontcolor="white"];
        platelet_adhesion [label="Platelet Adhesion\n(Microthrombus formation)", fillcolor="#5DADE2"];
    }

    /* ─────────────────────────────────────────────────────────
       CLUSTER 5 — Inflammation & Oxidative Stress
    ───────────────────────────────────────────────────────── */
    subgraph cluster_inflammation {
        label="Inflammation & Oxidative Stress";
        style="filled"; color="#6C3483"; fillcolor="#F4ECF7"; fontcolor="#6C3483";
        fontsize=14; fontname="Helvetica-Bold";

        TLR4          [label="TLR4\n(Heme/DAMP receptor)", fillcolor="#D7BDE2"];
        NLRP3         [label="NLRP3 Inflammasome\n(IL-1β processing)", fillcolor="#BB8FCE"];
        NFkB          [label="NF-κB\n(Master inflammatory TF)", fillcolor="#9B59B6"];
        TNF_alpha     [label="TNF-α\n(Pro-inflammatory)", fillcolor="#BB8FCE"];
        IL1_beta      [label="IL-1β\n(Endothelial activation)", fillcolor="#BB8FCE"];
        IL6           [label="IL-6\n(Acute phase response)", fillcolor="#BB8FCE"];
        IL8_CXCL8     [label="IL-8 (CXCL8)\n(Neutrophil chemoattractant)", fillcolor="#BB8FCE"];
        IL18          [label="IL-18\n(Inflammasome product)", fillcolor="#BB8FCE"];
        CRP           [label="CRP\n(Acute phase protein)", fillcolor="#D7BDE2"];
        NADPH_oxidase [label="NADPH Oxidase\n(NOX2/gp91phox)", fillcolor="#8E44AD"];
        superoxide    [label="Superoxide (O₂·⁻)\n(ROS)", fillcolor="#8E44AD"];
        H2O2          [label="H₂O₂\n(Secondary ROS)", fillcolor="#8E44AD"];
        xanthine_ox   [label="Xanthine Oxidase\n(Ischemia-reperfusion ROS)", fillcolor="#8E44AD"];
        peroxynitrite [label="Peroxynitrite (ONOO⁻)\n(NO + O₂·⁻)", fillcolor="#8E44AD"];
        glutathione   [label="Glutathione (GSH)\n(Antioxidant)", fillcolor="#A9DFBF"];
        catalase      [label="Catalase\n(H₂O₂ decomposition)", fillcolor="#A9DFBF"];
        SOD           [label="Superoxide Dismutase\n(SOD1/2)", fillcolor="#A9DFBF"];
        oxidized_Hb   [label="Met-Hb / Hemichrome\n(Oxidized Hb forms)", fillcolor="#BB8FCE"];
        NADH_redox    [label="NADH/NAD⁺ Ratio\n(Redox state)", fillcolor="#D7BDE2"];
        complement_act[label="Complement\nActivation (C3, C5)", fillcolor="#BB8FCE"];
    }

    /* ─────────────────────────────────────────────────────────
       CLUSTER 6 — Nitric Oxide Biology & Vasomotor Tone
    ───────────────────────────────────────────────────────── */
    subgraph cluster_NO {
        label="Nitric Oxide (NO) Biology & Vasomotor Tone";
        style="filled"; color="#1E8449"; fillcolor="#E9F7EF"; fontcolor="#1E8449";
        fontsize=14; fontname="Helvetica-Bold";

        eNOS          [label="eNOS\n(Endothelial NOS, NOS3)", fillcolor="#A9DFBF"];
        iNOS          [label="iNOS\n(Inducible NOS, NOS2)", fillcolor="#A9DFBF"];
        L_arginine    [label="L-Arginine\n(eNOS substrate, μM)", fillcolor="#ABEBC6"];
        NO_synthesis  [label="NO Synthesis\n(eNOS → NO)", fillcolor="#52BE80"];
        NO_bioavail   [label="NO Bioavailability\n(Endothelial function)", fillcolor="#27AE60"];
        NO_scavenging [label="NO Scavenging\n(by cell-free Hb)", fillcolor="#C0392B"];
        nitrite_pool  [label="Nitrite (NO₂⁻)\n(NO reservoir, μM)", fillcolor="#ABEBC6"];
        sGC           [label="Soluble Guanylate Cyclase\n(NO receptor, α1β1)", fillcolor="#A9DFBF"];
        cGMP          [label="cGMP\n(2nd messenger, vasodilation)", fillcolor="#52BE80"];
        PDE5          [label="PDE5\n(cGMP hydrolysis)", fillcolor="#ABEBC6"];
        arginase      [label="Arginase I/II\n(L-arg competitor)", fillcolor="#E74C3C"];
        ADMA          [label="ADMA\n(eNOS inhibitor)", fillcolor="#E74C3C"];
        endothelin1   [label="Endothelin-1 (ET-1)\n(Vasoconstrictor)", fillcolor="#E74C3C"];
        prostacyclin  [label="Prostacyclin (PGI₂)\n(Vasodilator/Antiplatelet)", fillcolor="#52BE80"];
        thromboxane_A2[label="Thromboxane A₂ (TXA₂)\n(Vasoconstrictor)", fillcolor="#E74C3C"];
        vasodilation  [label="Vasodilation\n(Smooth muscle relaxation)", fillcolor="#27AE60"];
        vasoconstriction[label="Vasoconstriction\n(Vascular resistance ↑)", fillcolor="#C0392B"];
    }

    /* ─────────────────────────────────────────────────────────
       CLUSTER 7 — Coagulation & Thrombosis
    ───────────────────────────────────────────────────────── */
    subgraph cluster_coagulation {
        label="Coagulation & Thrombosis";
        style="filled"; color="#784212"; fillcolor="#FEF9E7"; fontcolor="#784212";
        fontsize=14; fontname="Helvetica-Bold";

        tissue_factor [label="Tissue Factor (TF)\n(Exposed by injured endothelium)", fillcolor="#F9E79F"];
        factor_VIIa   [label="Factor VIIa\n(Initiates extrinsic pathway)", fillcolor="#F0B27A"];
        factor_Xa     [label="Factor Xa\n(Prothrombinase complex)", fillcolor="#F0B27A"];
        thrombin      [label="Thrombin (IIa)\n(Serine protease)", fillcolor="#E59866"];
        fibrinogen    [label="Fibrinogen\n(Acute phase protein)", fillcolor="#F9E79F"];
        fibrin        [label="Fibrin\n(Clot matrix)", fillcolor="#DC7633"];
        microthrombi  [label="Microthrombi\n(Vascular occlusion)", fillcolor="#DC7633"];
        procoag_RBC   [label="Procoagulant RBC\n(PS+ sickle cells)", fillcolor="#E59866"];
        MP_generation [label="Microparticle\nGeneration (PS+)", fillcolor="#E59866"];
        PAI1          [label="PAI-1\n(Fibrinolysis inhibitor)", fillcolor="#F0B27A"];
        tPA_fibrinolysis[label="tPA\n(Fibrinolysis activator)", fillcolor="#ABEBC6"];
        D_dimer       [label="D-Dimer\n(Fibrinolysis marker, μg/L)", fillcolor="#F9E79F"];
        TFPI          [label="TFPI\n(TF Pathway Inhibitor)", fillcolor="#ABEBC6"];
        protein_C     [label="Protein C\n(Anticoagulant)", fillcolor="#ABEBC6"];
    }

    /* ─────────────────────────────────────────────────────────
       CLUSTER 8 — End-Organ Damage
    ───────────────────────────────────────────────────────── */
    subgraph cluster_organ {
        label="End-Organ Damage & Clinical Complications";
        style="filled"; color="#7B241C"; fillcolor="#FDEDEC"; fontcolor="#7B241C";
        fontsize=14; fontname="Helvetica-Bold";

        ACS           [label="Acute Chest Syndrome\n(ACS, lung VOC)", fillcolor="#F1948A"];
        splenic_seq   [label="Splenic Sequestration\n(Acute crisis)", fillcolor="#F1948A"];
        autosplenectomy[label="Autosplenectomy\n(Functional, adults)", fillcolor="#EC7063"];
        stroke_risk   [label="Stroke Risk\n(TCD velocity >200 cm/s)", fillcolor="#C0392B", fontcolor="white"];
        silent_infarct[label="Silent Cerebral\nInfarction (SCI)", fillcolor="#EC7063"];
        priapism      [label="Priapism\n(Ischemic, painful)", fillcolor="#F1948A"];
        AVN           [label="Avascular Necrosis\n(AVN, hip/shoulder)", fillcolor="#F1948A"];
        sickle_nephro [label="Sickle Nephropathy\n(Glomerular hyperfiltration)", fillcolor="#EC7063"];
        GFR_decline   [label="GFR Decline\n(mL/min/1.73m²)", fillcolor="#EC7063"];
        retinopathy   [label="Sickle Retinopathy\n(Proliferative)", fillcolor="#F1948A"];
        cardiomegaly  [label="Cardiomegaly\n(Compensatory, high output)", fillcolor="#F1948A"];
        pulm_HTN_comp [label="Pulmonary HTN\n(TRV >2.5 m/s)", fillcolor="#C0392B", fontcolor="white"];
        leg_ulcers    [label="Leg Ulcers\n(Chronic, NO deficiency)", fillcolor="#F1948A"];
        pain_crisis   [label="Pain Crisis\n(VOC, hospitalizations)", fillcolor="#C0392B", fontcolor="white"];
        pain_NRS      [label="Pain Score NRS\n(0–10 scale)", fillcolor="#EC7063"];
        opioid_burden [label="Opioid Burden\n(mg/d morphine equiv.)", fillcolor="#EC7063"];
        neurocognitive[label="Neurocognitive\nDeficits (IQ, attention)", fillcolor="#EC7063"];
        QoL_SCD       [label="Quality of Life\n(ASCQ-Me / SF-36)", fillcolor="#EC7063"];
    }

    /* ─────────────────────────────────────────────────────────
       CLUSTER 9 — Drug PK: Hydroxyurea
    ───────────────────────────────────────────────────────── */
    subgraph cluster_HU_PK {
        label="Drug PK: Hydroxyurea (HU)";
        style="filled"; color="#117A65"; fillcolor="#E8F8F5"; fontcolor="#117A65";
        fontsize=14; fontname="Helvetica-Bold";

        HU_dose       [label="HU Dose\n(15–35 mg/kg/day, oral)", fillcolor="#A2D9CE", shape=diamond];
        HU_gut        [label="HU Gut Compartment\n(ka=2.0 h⁻¹)", fillcolor="#76D7C4"];
        HU_plasma     [label="HU Plasma\n(Cmax 25–100 μM, t½=2–4 h)", fillcolor="#45B39D"];
        HU_tissue     [label="HU Tissue\n(Vd=0.5 L/kg)", fillcolor="#76D7C4"];
        HU_RNR_inhib  [label="RNR Inhibition\n(Ribonucleotide reductase)", fillcolor="#45B39D"];
        HU_renal_excr [label="HU Renal Excretion\n(80% unchanged)", fillcolor="#A2D9CE"];
        HU_bioavail   [label="HU Bioavailability\n(F=80–100%)", fillcolor="#76D7C4"];
    }

    /* ─────────────────────────────────────────────────────────
       CLUSTER 10 — Drug PK: Voxelotor
    ───────────────────────────────────────────────────────── */
    subgraph cluster_VOX_PK {
        label="Drug PK: Voxelotor (GBT440)";
        style="filled"; color="#1A5276"; fillcolor="#EAF2FF"; fontcolor="#1A5276";
        fontsize=14; fontname="Helvetica-Bold";

        VOX_dose      [label="VOX Dose\n(1500 mg/day, oral)", fillcolor="#AED6F1", shape=diamond];
        VOX_gut       [label="VOX Gut Compartment\n(ka=0.5 h⁻¹, food↑)", fillcolor="#85C1E9"];
        VOX_plasma    [label="VOX Plasma\n(Cmax ~2 μM, t½~16–25 h)", fillcolor="#5DADE2"];
        VOX_RBC       [label="VOX-RBC Binding\n(High affinity, α-chain T-state)", fillcolor="#2E86C1"];
        VOX_metabol   [label="VOX Metabolism\n(CYP3A4, hepatic)", fillcolor="#85C1E9"];
        VOX_excretion [label="VOX Biliary/Renal\nExcretion", fillcolor="#AED6F1"];
        VOX_protein_binding [label="VOX Plasma\nProtein Binding (>99%)", fillcolor="#85C1E9"];
    }

    /* ─────────────────────────────────────────────────────────
       CLUSTER 11 — Drug PK: Crizanlizumab & L-Glutamine
    ───────────────────────────────────────────────────────── */
    subgraph cluster_CRIZ_PK {
        label="Drug PK: Crizanlizumab (SEG101) & L-Glutamine";
        style="filled"; color="#784212"; fillcolor="#FEF5E7"; fontcolor="#784212";
        fontsize=14; fontname="Helvetica-Bold";

        CRIZ_dose     [label="CRIZ Dose\n(5 mg/kg IV q4w → 7.5 mg/kg)", fillcolor="#FAD7A0", shape=diamond];
        CRIZ_central  [label="CRIZ Central\n(Plasma, 2-cmpt PK)", fillcolor="#F0B27A"];
        CRIZ_peripheral[label="CRIZ Peripheral\n(Tissue distribution)", fillcolor="#F0B27A"];
        CRIZ_clearance[label="CRIZ Clearance\n(IgG catabolism, t½~10 d)", fillcolor="#E59866"];
        CRIZ_Psel_occ [label="P-Selectin Target\nOccupancy (>80%)", fillcolor="#DC7633"];
        LG_dose       [label="L-Glutamine\n(5 g BID, oral)", fillcolor="#FAD7A0", shape=diamond];
        LG_plasma     [label="L-Glu Plasma\n(Amino acid pool)", fillcolor="#F0B27A"];
        LG_RBC_uptake [label="L-Glu → RBC\nNAD⁺ redox support", fillcolor="#F0B27A"];
        HU_MCV        [label="HU Effect: MCV↑\n(Macrocytosis marker)", fillcolor="#A2D9CE"];
        HU_WBC        [label="HU Effect: WBC↓\n(Myelosuppression)", fillcolor="#A2D9CE"];
    }

    /* ─────────────────────────────────────────────────────────
       CLUSTER 12 — Drug PD & Clinical Endpoints
    ───────────────────────────────────────────────────────── */
    subgraph cluster_PD {
        label="Drug Pharmacodynamics & Clinical Endpoints";
        style="filled"; color="#1C2833"; fillcolor="#F2F3F4"; fontcolor="#1C2833";
        fontsize=14; fontname="Helvetica-Bold";

        HU_HbF_induct [label="HU → HbF↑\n(HbF induction: ΔHbF ~15–20%)", fillcolor="#A9DFBF"];
        VOX_O2_affinity[label="VOX → O₂ Affinity↑\n(ΔP₅₀: −10 mmHg)", fillcolor="#AED6F1"];
        VOX_Hgb_incr  [label="VOX → Hgb↑\n(+1.0–1.5 g/dL, HOPE trial)", fillcolor="#AED6F1"];
        CRIZ_VOC_reduce[label="CRIZ → VOC↓\n(−45%, SUSTAIN trial)", fillcolor="#FAD7A0"];
        CRIZ_ACS_reduce[label="CRIZ → ACS↓\n(Secondary endpoint)", fillcolor="#FAD7A0"];
        LG_crisis_reduce[label="L-Glu → Crises↓\n(−25%, Phase III)", fillcolor="#F9E79F"];
        combo_synergy [label="HU+VOX Synergy\n(Additive Hgb response)", fillcolor="#D5F5E3"];
        annual_VOC    [label="Annual VOC Rate\n(Baseline ~3–4/year)", fillcolor="#1C2833", fontcolor="white"];
        hospitalization_rate[label="Hospitalization Rate\n(Crises requiring IV)", fillcolor="#1C2833", fontcolor="white"];
        Hgb_response  [label="Hemoglobin Response\n(Target: ≥11 g/dL)", fillcolor="#1C2833", fontcolor="white"];
        TRV_endpoint  [label="TRV Velocity\n(Echo, m/s)", fillcolor="#F2F3F4"];
        renal_function[label="eGFR Trend\n(CKD progression)", fillcolor="#F2F3F4"];
        QoL_endpoint  [label="QoL Score\n(ASCQ-Me domains)", fillcolor="#F2F3F4"];
        pain_endpoint [label="Pain Endpoint\n(Days in pain/year)", fillcolor="#F2F3F4"];
    }

    /* ═════════════════════════════════════════════════════════
       EDGES — Cluster 1 (Genetics) Internal
    ═════════════════════════════════════════════════════════ */
    HBB_gene -> Glu6Val [label="Point mutation", color="#3A5F8A"];
    Glu6Val -> beta_S [color="#3A5F8A"];
    alpha_globin -> HbS_tetramer [color="#3A5F8A"];
    beta_S -> HbS_tetramer [color="#3A5F8A"];
    alpha_globin -> HbA_tetramer [color="#6C3483", style=dashed];
    beta_A -> HbA_tetramer [color="#6C3483", style=dashed];
    alpha_globin -> HbF_tetramer [color="#1E8449", style=dashed];
    gamma_globin -> HbF_tetramer [color="#1E8449"];
    BCL11A -> gamma_globin [label="Represses", color="#C0392B", arrowhead=tee];
    KLF1 -> BCL11A [label="Activates", color="#F39C12"];
    HbS_tetramer -> deoxy_HbS [label="Deoxygenation\n(pO₂<5 kPa)", color="#5DADE2"];
    deoxy_HbS -> nucleation [label="Supersaturation\n(MCHC>25 g/dL)", color="#5DADE2"];
    nucleation -> polymer_growth [color="#3A5F8A"];
    polymer_growth -> HbS_polymer [color="#3A5F8A"];
    MCHC -> polymerization_Kd [color="#3A5F8A"];
    P50_value -> deoxy_HbS [label="Low O₂ affinity", color="#5DADE2"];
    HbF_tetramer -> nucleation [label="Inhibits HbS\npolymerization", color="#27AE60", arrowhead=tee];

    /* ═════════════════════════════════════════════════════════
       EDGES — Cluster 2 (Erythropoiesis) Internal
    ═════════════════════════════════════════════════════════ */
