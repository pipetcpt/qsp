digraph AL_Amyloidosis_QSP {
  graph [
    rankdir=LR
    label="AL (Immunoglobulin Light Chain) Amyloidosis — QSP Mechanistic Map\nDaratumumab · Bortezomib · Cyclophosphamide · Dexamethasone · Melphalan"
    labelloc=t
    fontname="Helvetica-Bold"
    fontsize=18
    fontcolor="#1a1a2e"
    bgcolor="#f8f9fa"
    splines=polyline
    nodesep=0.45
    ranksep=1.0
    pad=0.6
    compound=true
  ]
  node [shape=box style="filled,rounded" fontname="Helvetica" fontsize=10 margin="0.12,0.08"]
  edge [fontname="Helvetica" fontsize=9 penwidth=1.3]

  //=============================================================
  // CLUSTER 1: Plasma Cell Biology & Clonal Evolution
  //=============================================================
  subgraph cluster_plasma_cell {
    label="① Plasma Cell Biology & Clonal Evolution"
    style="filled,rounded" fillcolor="#e8eaf6" color="#3949ab" penwidth=2.5 fontsize=13 fontcolor="#3949ab"

    HSC [label="HSC\n(Hematopoietic\nStem Cell)" fillcolor="#c5cae9" shape=ellipse]
    MGUS [label="MGUS\n(Monoclonal Gammopathy\nof Undetermined Significance)" fillcolor="#9fa8da"]
    SMM [label="SMM\n(Smoldering\nMultiple Myeloma)" fillcolor="#7986cb"]
    ClonalPC [label="Clonal Plasma\nCell Expansion\n(Bone Marrow)" fillcolor="#5c6bc0"]
    MalignantPC [label="Malignant\nPlasma Cells\n(AL-secreting)" fillcolor="#3949ab" fontcolor=white]
    PC_Prolif [label="PC Proliferation\nRate (k_prolif)" fillcolor="#7986cb"]
    PC_Death [label="PC Apoptosis\nRate (k_death)" fillcolor="#9fa8da"]
    ClonoEvol [label="Clonal Evolution\n(Mutation → Progression)" fillcolor="#c5cae9"]
    BMPlasmaCells [label="Bone Marrow\nPlasma Cell %\n(BMPC%)" fillcolor="#7986cb"]
    CD38_Expr [label="CD38\nExpression\n(Target Antigen)" fillcolor="#5c6bc0" fontcolor=white]
    CD38_Density [label="CD38 Receptor\nDensity / Cell" fillcolor="#7986cb"]

    HSC -> MGUS -> SMM -> ClonalPC -> MalignantPC
    MalignantPC -> PC_Prolif [dir=both]
    MalignantPC -> PC_Death
    ClonoEvol -> MalignantPC
    MalignantPC -> BMPlasmaCells
    MalignantPC -> CD38_Expr -> CD38_Density
  }

  //=============================================================
  // CLUSTER 2: Light Chain Production & Proteostasis
  //=============================================================
  subgraph cluster_light_chain {
    label="② Light Chain Production & Proteostasis"
    style="filled,rounded" fillcolor="#fce4ec" color="#c62828" penwidth=2.5 fontsize=13 fontcolor="#c62828"

    LC_Prod [label="Monoclonal Free\nLight Chain (FLC)\nProduction Rate" fillcolor="#ef9a9a"]
    LambdaFLC [label="Lambda FLC\n(λ-FLC)" fillcolor="#e57373"]
    KappaFLC [label="Kappa FLC\n(κ-FLC)" fillcolor="#e57373"]
    dFLC [label="Difference FLC\n(dFLC = involved −\nuninvolved FLC)" fillcolor="#ef5350" fontcolor=white]
    FLC_Serum [label="Serum FLC\nConcentration\n(mg/L)" fillcolor="#e57373"]
    FLC_Ratio [label="FLC Ratio\n(κ/λ)" fillcolor="#ef9a9a"]
    Misfolding [label="Amyloidogenic\nLC Misfolding\n(β-sheet propensity)" fillcolor="#c62828" fontcolor=white]
    Oligomers [label="Soluble LC\nOligomers\n(Cardiotoxic)" fillcolor="#e53935" fontcolor=white]
    ProteaBurden [label="Proteasome\nBurden / Stress\n(UPR)" fillcolor="#ef9a9a"]
    UPR [label="Unfolded Protein\nResponse (UPR)\nActivation" fillcolor="#e57373"]
    BiP_GRP78 [label="BiP/GRP78\nChaperone\nUpregulation" fillcolor="#ffcdd2"]
    CHOP [label="CHOP\n(Pro-apoptotic\nTranscription Factor)" fillcolor="#ef9a9a"]

    LC_Prod -> LambdaFLC
    LC_Prod -> KappaFLC
    LambdaFLC -> dFLC
    KappaFLC -> dFLC
    LambdaFLC -> FLC_Serum
    KappaFLC -> FLC_Serum
    FLC_Serum -> FLC_Ratio
    LambdaFLC -> Misfolding
    Misfolding -> Oligomers
    Misfolding -> ProteaBurden -> UPR
    UPR -> BiP_GRP78
    UPR -> CHOP
    CHOP -> PC_Death [label="ER stress\napoptosis" style=dashed]
  }

  //=============================================================
  // CLUSTER 3: Amyloid Fibril Formation & Deposition
  //=============================================================
  subgraph cluster_fibril {
    label="③ Amyloid Fibril Formation & Deposition"
    style="filled,rounded" fillcolor="#fff3e0" color="#e65100" penwidth=2.5 fontsize=13 fontcolor="#e65100"

    Nucleation [label="Fibril Nucleation\n(Rate: k_nuc)" fillcolor="#ffe0b2"]
    Elongation [label="Fibril Elongation\n(Rate: k_elong)" fillcolor="#ffcc80"]
    Seeding [label="Seeding Effect\n(Autocatalytic)" fillcolor="#ffb74d"]
    AmyloidFibril [label="Amyloid Fibrils\n(β-sheet Polymer)" fillcolor="#e65100" fontcolor=white]
    SAP_Binding [label="Serum Amyloid P\n(SAP) Binding\n(Fibril Stabilization)" fillcolor="#ffe0b2"]
    GAG_Binding [label="Glycosaminoglycan\n(GAG) Binding\n(Heparan Sulfate)" fillcolor="#ffcc80"]
    OrgDeposition [label="Organ-Specific\nDeposition Rate\n(Heart/Kidney/Liver)" fillcolor="#ff8f00" fontcolor=white]
    FibrilBurden [label="Total Amyloid\nFibril Burden\n(Histology)" fillcolor="#e65100" fontcolor=white]
    Congo_Red [label="Congo Red\nPositivity\n(Apple-Green Birefringence)" fillcolor="#ffe0b2"]

    Oligomers -> Nucleation
    Nucleation -> Elongation -> AmyloidFibril
    AmyloidFibril -> Seeding -> Elongation [label="autocatalytic" style=dashed]
    SAP_Binding -> AmyloidFibril [label="stabilize" dir=both]
    GAG_Binding -> AmyloidFibril [label="scaffold" dir=both]
    AmyloidFibril -> OrgDeposition -> FibrilBurden
    FibrilBurden -> Congo_Red
  }

  //=============================================================
  // CLUSTER 4: Cardiac Amyloidosis
  //=============================================================
  subgraph cluster_cardiac {
    label="④ Cardiac Amyloidosis (CA-AL)"
    style="filled,rounded" fillcolor="#fbe9e7" color="#bf360c" penwidth=2.5 fontsize=13 fontcolor="#bf360c"

    CardiacDepos [label="Cardiac\nAmyloid\nDeposition" fillcolor="#ff8a65"]
    LVWallThick [label="LV Wall\nThickening\n(mm)" fillcolor="#ff7043"]
    Diastolic_Dysfn [label="Diastolic\nDysfunction\n(Grade I-III)" fillcolor="#ff5722" fontcolor=white]
    LVEF [label="LVEF\n(%)" fillcolor="#ff8a65"]
    LV_Strain [label="LV Global\nLongitudinal\nStrain (GLS, %)" fillcolor="#ff7043"]
    Troponin_T [label="High-Sensitivity\nTroponin T\n(hs-TnT, ng/L)" fillcolor="#e64a19" fontcolor=white]
    NTproBNP [label="NT-proBNP\n(pg/mL)" fillcolor="#e64a19" fontcolor=white]
    CardiacStage [label="Mayo 2012\nCardiac Stage\n(I–IV)" fillcolor="#bf360c" fontcolor=white]
    Arrhythmia [label="Atrial Fibrillation\n/ Arrhythmia Risk" fillcolor="#ff8a65"]
    SynchroDysfn [label="Cardiac\nConduction\nAbnormalities" fillcolor="#ffab91"]
    CardiacOutput [label="Cardiac Output\n(L/min)" fillcolor="#ff7043"]
    HeartFailure [label="Heart Failure\n(NYHA Class)" fillcolor="#bf360c" fontcolor=white]
    Oligomers_cardio [label="Oligomer-Mediated\nCardiotoxicity\n(Direct)" fillcolor="#ff8a65"]

    CardiacDepos -> LVWallThick -> Diastolic_Dysfn
    Diastolic_Dysfn -> LVEF
    Diastolic_Dysfn -> HeartFailure
    LV_Strain -> Diastolic_Dysfn
    CardiacDepos -> Troponin_T
    CardiacDepos -> NTproBNP
    Troponin_T -> CardiacStage
    NTproBNP -> CardiacStage
    CardiacDepos -> Arrhythmia
    CardiacDepos -> SynchroDysfn
    Diastolic_Dysfn -> CardiacOutput
    CardiacOutput -> HeartFailure
    Oligomers_cardio -> Troponin_T [label="direct\ncardiotoxicity" style=dashed color=red]
    Oligomers_cardio -> Diastolic_Dysfn [style=dashed color=red]
  }

  //=============================================================
  // CLUSTER 5: Renal Amyloidosis
  //=============================================================
  subgraph cluster_renal {
    label="⑤ Renal Amyloidosis"
    style="filled,rounded" fillcolor="#e8f5e9" color="#1b5e20" penwidth=2.5 fontsize=13 fontcolor="#1b5e20"

    RenalDepos [label="Renal\nAmyloid\nDeposition" fillcolor="#a5d6a7"]
    GlomAmyloid [label="Glomerular\nAmyloid\n(Mesangium)" fillcolor="#81c784"]
    Proteinuria [label="24h Proteinuria\n(g/day)" fillcolor="#4caf50" fontcolor=white]
    Nephrotic [label="Nephrotic\nSyndrome\n(≥3.5 g/day)" fillcolor="#2e7d32" fontcolor=white]
    GFR [label="eGFR\n(mL/min/1.73m²)" fillcolor="#43a047" fontcolor=white]
    CKD_Stage [label="CKD Stage\n(I–V)" fillcolor="#1b5e20" fontcolor=white]
    RenalFail [label="ESKD /\nDialysis Need" fillcolor="#2e7d32" fontcolor=white]
    FLC_Renal [label="Renal FLC\nClearance\n(Filtered FLC)" fillcolor="#a5d6a7"]
    TubularInj [label="Tubular\nInjury\n(Cast Nephropathy)" fillcolor="#81c784"]
    Albuminuria [label="Albuminuria\n(g/g creatinine)" fillcolor="#66bb6a"]

    RenalDepos -> GlomAmyloid -> Proteinuria -> Nephrotic
    GlomAmyloid -> GFR
    GFR -> CKD_Stage -> RenalFail
    FLC_Renal -> TubularInj -> GFR
    GlomAmyloid -> Albuminuria
    RenalDepos -> FLC_Renal [label="filtered FLC\nreabsorption" style=dashed]
  }

  //=============================================================
  // CLUSTER 6: Hepatic & Neuropathic Amyloidosis
  //=============================================================
  subgraph cluster_other_organs {
    label="⑥ Hepatic & Peripheral Neuropathy"
    style="filled,rounded" fillcolor="#f3e5f5" color="#6a1b9a" penwidth=2.5 fontsize=13 fontcolor="#6a1b9a"

    LiverDepos [label="Hepatic\nAmyloid\nDeposition" fillcolor="#ce93d8"]
    Hepatomegaly [label="Hepatomegaly\n(cm below\ncostal margin)" fillcolor="#ba68c8"]
    AlkPhos [label="Alkaline\nPhosphatase\n(ALP, IU/L)" fillcolor="#9c27b0" fontcolor=white]
    LiverFail [label="Hepatic\nFailure\n(Rare)" fillcolor="#6a1b9a" fontcolor=white]
    AutoNeuropathy [label="Autonomic\nNeuropathy\n(Orthostasis)" fillcolor="#ce93d8"]
    PNeuropathy [label="Peripheral\nNeuropathy\n(Paresthesia, PN)" fillcolor="#ba68c8"]
    GI_Dysmotility [label="GI Dysmotility\n(Malabsorption)" fillcolor="#e1bee7"]
    MacroGloss [label="Macroglossia\n(Soft Tissue)" fillcolor="#ce93d8"]
    SoftTissue [label="Soft Tissue\nInfiltration\n(Periorbital Purpura)" fillcolor="#e1bee7"]
    Factor_X [label="Factor X\nDeficiency\n(Coagulopathy)" fillcolor="#ba68c8"]

    LiverDepos -> Hepatomegaly -> AlkPhos
    LiverDepos -> LiverFail
    AutoNeuropathy -> GI_Dysmotility
    PNeuropathy -> AutoNeuropathy
    LiverDepos -> Factor_X [label="adsorption" style=dashed]
    SoftTissue -> MacroGloss
  }

  //=============================================================
  // CLUSTER 7: Bone Marrow Microenvironment & Signaling
  //=============================================================
  subgraph cluster_bm_micro {
    label="⑦ Bone Marrow Microenvironment"
    style="filled,rounded" fillcolor="#e0f2f1" color="#004d40" penwidth=2.5 fontsize=13 fontcolor="#004d40"

    Stromal [label="Bone Marrow\nStromal Cells\n(BMSC)" fillcolor="#80cbc4"]
    VCAM1 [label="VCAM-1\n(Cell Adhesion)" fillcolor="#4db6ac"]
    IL6_BM [label="IL-6\n(Survival Signal)" fillcolor="#26a69a" fontcolor=white]
    APRIL_BM [label="APRIL / BAFF\n(PC Survival)" fillcolor="#00897b" fontcolor=white]
    NF_kB [label="NF-κB\nSignaling\n(PC Survival)" fillcolor="#00695c" fontcolor=white]
    IRF4 [label="IRF4\n(PC Differentiation\nMaster TF)" fillcolor="#004d40" fontcolor=white]
    Blimp1 [label="BLIMP-1\n(PC Differentiation)" fillcolor="#26a69a" fontcolor=white]
    Pax5 [label="PAX5\n(B-cell Identity\nSuppressed)" fillcolor="#80cbc4"]
    Mcl1 [label="MCL-1\n(Anti-apoptotic)" fillcolor="#4db6ac"]
    VEGF_BM [label="VEGF\n(Angiogenesis\nin BM)" fillcolor="#80cbc4"]
    RANKL [label="RANKL\n(Osteoclast\nActivation)" fillcolor="#4db6ac"]
    DKK1 [label="DKK1\n(Wnt Inhibition\n→ Bone Loss)" fillcolor="#80cbc4"]

    Stromal -> VCAM1 -> MalignantPC [label="adhesion\nmediated\nsurvival" style=dashed]
    Stromal -> IL6_BM -> MalignantPC [label="JAK/STAT3" style=dashed]
    APRIL_BM -> NF_kB -> Mcl1
    NF_kB -> MalignantPC
    IRF4 -> Blimp1 -> LC_Prod [label="LC gene\ntranscription" style=dashed]
    Blimp1 -> Pax5 [label="suppress" style=dashed arrowhead=tee]
    Stromal -> VEGF_BM
    MalignantPC -> RANKL
    MalignantPC -> DKK1
  }

  //=============================================================
  // CLUSTER 8: Drug PK — Daratumumab (Anti-CD38 mAb)
  //=============================================================
  subgraph cluster_dara_pk {
    label="⑧ Drug PK — Daratumumab (Anti-CD38 mAb)"
    style="filled,rounded" fillcolor="#e3f2fd" color="#0d47a1" penwidth=2.5 fontsize=13 fontcolor="#0d47a1"

    DARA_Dose [label="Daratumumab\nDose\n(16 mg/kg IV)" fillcolor="#90caf9" shape=hexagon]
    DARA_Inf [label="IV Infusion\nRate" fillcolor="#64b5f6"]
    DARA_C1 [label="Daratumumab\nCentral\nCompartment (C1)" fillcolor="#42a5f5"]
    DARA_C2 [label="Daratumumab\nPeripheral\nCompartment (C2)" fillcolor="#1e88e5" fontcolor=white]
    DARA_TMDD [label="TMDD Binding\nto CD38\n(Target-Mediated\nDrug Disposition)" fillcolor="#0d47a1" fontcolor=white]
    DARA_Free [label="Free\nDaratumumab\n(Cp, µg/mL)" fillcolor="#42a5f5"]
    DARA_Bound [label="Daratumumab-\nCD38 Complex\n(Rc)" fillcolor="#1565c0" fontcolor=white]
    DARA_CL [label="Daratumumab\nLinear CL\n(mL/day/kg)" fillcolor="#64b5f6"]
    DARA_Half [label="Daratumumab\nt½ ~18-23 days\n(TMDD dependent)" fillcolor="#90caf9"]
    DARA_Vd [label="Vd Central\n~56 mL/kg" fillcolor="#90caf9"]
    DARA_RSS [label="DARA\nDosing\nSchedule\n(Wk1-8: QW\nWk9-24: Q2W\n>Wk24: Q4W)" fillcolor="#e3f2fd" shape=note]

    DARA_Dose -> DARA_Inf -> DARA_C1
    DARA_C1 -> DARA_C2 [dir=both label="Q12"]
    DARA_C1 -> DARA_Free
    DARA_Free -> DARA_TMDD
    DARA_TMDD -> DARA_Bound [label="kon"]
    DARA_Bound -> DARA_Free [label="koff" style=dashed]
    DARA_C1 -> DARA_CL [label="linear\nelimination"]
    DARA_Half -> DARA_CL [style=invis]
    DARA_Vd -> DARA_C1 [style=invis]
    DARA_RSS -> DARA_Dose [style=dashed]
  }

  //=============================================================
  // CLUSTER 9: Drug PK — Bortezomib & CyBorD
  //=============================================================
  subgraph cluster_cyborg_pk {
    label="⑨ Drug PK — Bortezomib, Cyclophosphamide & Dexamethasone"
    style="filled,rounded" fillcolor="#e8eaf6" color="#283593" penwidth=2.5 fontsize=13 fontcolor="#283593"

    BTZ_Dose [label="Bortezomib\nDose\n(1.3 mg/m² SC\nD1,8,15,22)" fillcolor="#9fa8da" shape=hexagon]
    BTZ_C1 [label="Bortezomib\nCentral CMT\n(Cp, nM)" fillcolor="#7986cb"]
    BTZ_20S [label="Bortezomib-20S\nProteasome\nComplex (Bound)" fillcolor="#3949ab" fontcolor=white]
    BTZ_Effi [label="20S Proteasome\nInhibition\n(Chymotryptic, %)" fillcolor="#5c6bc0" fontcolor=white]
    BTZ_Half [label="Bortezomib\nt½ ~9-15h\n(Plasma)" fillcolor="#9fa8da"]

    CY_Dose [label="Cyclophosphamide\nDose\n(300 mg/m² PO\nD1,8,15,22)" fillcolor="#b0bec5" shape=hexagon]
    CY_C1 [label="Cyclophosphamide\nActive Metabolite\n(4-OH-CY, µM)" fillcolor="#90a4ae"]
    CY_Effi [label="CY DNA\nAlkylation\nEffect" fillcolor="#607d8b" fontcolor=white]

    DEX_Dose [label="Dexamethasone\nDose\n(20-40 mg PO\nD1,8,15,22)" fillcolor="#bcaaa4" shape=hexagon]
    DEX_C1 [label="Dexamethasone\nConcentration\n(nM)" fillcolor="#a1887f"]
    GR_Occ [label="Glucocorticoid\nReceptor\nOccupancy (%)" fillcolor="#795548" fontcolor=white]
    GR_Effect [label="GR-Mediated\nApoptosis\n& Anti-inflammatory" fillcolor="#6d4c41" fontcolor=white]

    BTZ_Dose -> BTZ_C1 -> BTZ_20S [label="rapid binding"]
    BTZ_20S -> BTZ_Effi [label="% inhibition"]
    BTZ_Half -> BTZ_C1 [style=invis]
    CY_Dose -> CY_C1 -> CY_Effi [label="CYP2B6\nactivation" style=dashed]
    DEX_Dose -> DEX_C1 -> GR_Occ -> GR_Effect
  }

  //=============================================================
  // CLUSTER 10: Pharmacodynamics & Hematologic Response
  //=============================================================
  subgraph cluster_pd_heme {
    label="⑩ Pharmacodynamics — Hematologic & Organ Response"
    style="filled,rounded" fillcolor="#fff8e1" color="#f57f17" penwidth=2.5 fontsize=13 fontcolor="#f57f17"

    PC_Kill_Dara [label="Dara-Mediated\nPC Killing\n(ADCC/CDC/ADCP)" fillcolor="#ffe082"]
    CDC [label="Complement-\nDependent\nCytotoxicity (CDC)" fillcolor="#ffd54f"]
    ADCC [label="Antibody-Dependent\nCellular Cytotoxicity\n(ADCC via NK cells)" fillcolor="#ffca28"]
    ADCP [label="Antibody-Dependent\nCellular Phagocytosis\n(ADCP via macrophage)" fillcolor="#ffc107" fontcolor=white]
    PC_Kill_BTZ [label="Bortezomib-Mediated\nPC Apoptosis\n(Proteasome Inhibition)" fillcolor="#ffb300" fontcolor=white]
    PC_Kill_CY [label="CY-Mediated\nPC DNA Damage" fillcolor="#ff8f00" fontcolor=white]
    PC_Kill_DEX [label="DEX-Mediated\nPC Apoptosis\n(GR-induced)" fillcolor="#ff6f00" fontcolor=white]

    HemResp [label="Hematologic\nResponse\n(CR/VGPR/PR/NR)" fillcolor="#f57f17" fontcolor=white]
    CR_Heme [label="Complete Hematologic\nResponse (CR)\ndFLC <40 mg/L" fillcolor="#e65100" fontcolor=white]
    sCR_Heme [label="Stringent CR\n(sCR)" fillcolor="#bf360c" fontcolor=white]
    OrgResp_Card [label="Cardiac Organ\nResponse\n(NT-proBNP ↓≥30%)" fillcolor="#ffe082"]
    OrgResp_Renal [label="Renal Organ\nResponse\n(Proteinuria ↓≥30%)" fillcolor="#ffd54f"]

    NK_Cells [label="NK Cell\nActivation\n(CD16+CD56+)" fillcolor="#ffe082"]
    Complement [label="Complement\nSystem\n(C1q Activation)" fillcolor="#ffd54f"]
    Macrophage [label="Macrophage\nPhagocytosis" fillcolor="#ffca28"]

    PC_Kill_Dara -> CDC
    PC_Kill_Dara -> ADCC
    PC_Kill_Dara -> ADCP
    CDC -> Complement
    ADCC -> NK_Cells
    ADCP -> Macrophage
    PC_Kill_BTZ -> BTZ_Effi [style=dashed dir=back label="drives"]
    PC_Kill_CY -> CY_Effi [style=dashed dir=back label="drives"]
    PC_Kill_DEX -> GR_Effect [style=dashed dir=back label="drives"]
    PC_Kill_Dara -> HemResp
    PC_Kill_BTZ -> HemResp
    PC_Kill_CY -> HemResp
    PC_Kill_DEX -> HemResp
    HemResp -> CR_Heme -> sCR_Heme
    HemResp -> OrgResp_Card
    HemResp -> OrgResp_Renal
  }

  //=============================================================
  // CLUSTER 11: Clinical Staging & Prognostic Biomarkers
  //=============================================================
  subgraph cluster_staging {
    label="⑪ Clinical Staging & Biomarkers (Mayo 2012)"
    style="filled,rounded" fillcolor="#fafafa" color="#424242" penwidth=2.5 fontsize=13 fontcolor="#424242"

    Mayo2012 [label="Mayo 2012\nStaging System\n(4-stage)" fillcolor="#e0e0e0"]
    S1_criteria [label="Stage I\n(0 risk factors)\nMedian OS: >~10y" fillcolor="#a5d6a7"]
    S2_criteria [label="Stage II\n(1 risk factor)\nMedian OS: ~6y" fillcolor="#fff9c4"]
    S3_criteria [label="Stage III\n(2 risk factors)\nMedian OS: ~4y" fillcolor="#ffcc80"]
    S4_criteria [label="Stage IV\n(3-4 risk factors)\nMedian OS: ~1y" fillcolor="#ef9a9a"]
    RF_TnT [label="Risk Factor 1:\nTnT ≥0.025 ng/mL" fillcolor="#bdbdbd"]
    RF_NTpBNP [label="Risk Factor 2:\nNT-proBNP ≥1800 pg/mL" fillcolor="#bdbdbd"]
    RF_dFLC [label="Risk Factor 3:\ndFLC ≥18 mg/dL" fillcolor="#bdbdbd"]
    RF_eGFR [label="Risk Factor 4:\neGFR <50 mL/min" fillcolor="#bdbdbd"]
    ECOG_PS [label="ECOG\nPerformance\nStatus" fillcolor="#e0e0e0"]
    Karnofsky [label="Karnofsky\nScore" fillcolor="#e0e0e0"]
    6MWT [label="6-Minute\nWalk Test\n(meters)" fillcolor="#e0e0e0"]

    Troponin_T -> RF_TnT -> Mayo2012
    NTproBNP -> RF_NTpBNP -> Mayo2012
    dFLC -> RF_dFLC -> Mayo2012
    GFR -> RF_eGFR -> Mayo2012
    Mayo2012 -> S1_criteria
    Mayo2012 -> S2_criteria
    Mayo2012 -> S3_criteria
    Mayo2012 -> S4_criteria
    ECOG_PS -> ECOG_PS [style=invis]
    HeartFailure -> ECOG_PS
    HeartFailure -> 6MWT
  }

  //=============================================================
  // CLUSTER 12: Immune Effector Mechanisms
  //=============================================================
  subgraph cluster_immune {
    label="⑫ Immune Effector & Regulatory Mechanisms"
    style="filled,rounded" fillcolor="#e8f5e9" color="#2e7d32" penwidth=2.5 fontsize=13 fontcolor="#2e7d32"

    Treg [label="Regulatory T Cells\n(CD4+CD25+FoxP3+)" fillcolor="#a5d6a7"]
    Th17 [label="Th17\n(IL-17 production)" fillcolor="#81c784"]
    CD8_T [label="Cytotoxic\nT Cells\n(CD8+)" fillcolor="#66bb6a"]
    NK_Activity [label="NK Cell\nCytolytic\nActivity" fillcolor="#4caf50" fontcolor=white]
    PD1_L1 [label="PD-1/PD-L1\nCheckpoint\n(Immune Evasion)" fillcolor="#2e7d32" fontcolor=white]
    CD38_NK [label="CD38 on\nNK Cells\n(Fratricide Risk)" fillcolor="#388e3c" fontcolor=white]
    Daratumumab_NK [label="Dara Effect on\nNK Cells\n(Initial Depletion)" fillcolor="#81c784"]
    DARA_Synergy [label="Dara-Mediated\nNK Recovery\n(Daratumumab\nDuration Effect)" fillcolor="#a5d6a7"]

    MalignantPC -> PD1_L1 [label="immune\nevasion" style=dashed]
    PD1_L1 -> CD8_T [label="suppress" arrowhead=tee]
    NK_Cells -> NK_Activity
    CD38_NK -> NK_Activity [label="fratricide\n(transient)" arrowhead=tee style=dashed]
    DARA_Bound -> Daratumumab_NK
    Daratumumab_NK -> NK_Activity [label="initial\ndepletion" arrowhead=tee style=dashed]
    Daratumumab_NK -> DARA_Synergy [label="chronic\nrecovery" style=dashed]
    DARA_Synergy -> NK_Activity [style=dashed]
    Treg -> CD8_T [label="suppress" arrowhead=tee]
    Th17 -> IL6_BM [style=dashed]
  }

  //=============================================================
  // CLUSTER 13: Clinical Endpoints & Survival
  //=============================================================
  subgraph cluster_endpoints {
    label="⑬ Clinical Endpoints & Survival Outcomes"
    style="filled,rounded" fillcolor="#f3e5f5" color="#4a148c" penwidth=2.5 fontsize=13 fontcolor="#4a148c"

    OS [label="Overall\nSurvival (OS)" fillcolor="#ce93d8"]
    EFS [label="Event-Free\nSurvival (EFS)" fillcolor="#ba68c8"]
    PFS [label="Progression-Free\nSurvival (PFS)" fillcolor="#ab47bc"]
    TTR [label="Time to\nHematologic\nResponse" fillcolor="#9c27b0" fontcolor=white]
    CardiacDeath [label="Cardiac\nDeath\n(#1 Cause)" fillcolor="#7b1fa2" fontcolor=white]
    SuddenDeath [label="Sudden\nCardiac\nDeath" fillcolor="#6a1b9a" fontcolor=white]
    QoL [label="Quality of\nLife (QoL)\n(SF-36/KCCQ)" fillcolor="#ce93d8"]
    Hospitaliz [label="Heart Failure\nHospitalization" fillcolor="#e1bee7"]
    ANDROMEDA [label="ANDROMEDA Trial\n(NEJM 2021)\nDara+CyBorD vs CyBorD\n53% vs 18% CR\n(p<0.001)" fillcolor="#7b1fa2" fontcolor=white shape=note]

    CardiacStage -> OS
    CR_Heme -> OS [label="~60% ↓ mortality\nwith CR" style=dashed color="#4a148c"]
    OrgResp_Card -> OS [style=dashed]
    CardiacDeath -> OS [arrowhead=inv]
    SuddenDeath -> CardiacDeath
    HeartFailure -> CardiacDeath
    HeartFailure -> Hospitaliz
    HemResp -> TTR
    OrgResp_Card -> EFS
    OrgResp_Renal -> EFS
    EFS -> PFS -> OS
    QoL -> ECOG_PS [style=dashed]
    ANDROMEDA -> CR_Heme [style=dashed label="calibration\ndata"]
  }

  //=============================================================
  // CLUSTER 14: Adverse Effects & Safety Monitoring
  //=============================================================
  subgraph cluster_safety {
    label="⑭ Adverse Effects & Safety Monitoring"
    style="filled,rounded" fillcolor="#ffebee" color="#b71c1c" penwidth=2.5 fontsize=13 fontcolor="#b71c1c"

    IRR [label="Infusion-Related\nReaction (IRR)\n(DARA: ~48% G1-2)" fillcolor="#ffcdd2"]
    Cytopenias [label="Cytopenias\n(Neutropenia,\nThrombocytopenia)" fillcolor="#ef9a9a"]
    Infections [label="Infections\n(Pneumonia,\nHerpes Zoster)" fillcolor="#e57373"]
    Neuropathy_BTZ [label="Peripheral\nNeuropathy\n(Bortezomib-induced)" fillcolor="#ef9a9a"]
    DVT_PE [label="DVT/PE\nRisk\n(Thromboembolic)" fillcolor="#e57373"]
    GI_toxicity [label="GI Toxicity\n(Nausea/Diarrhea,\nCY/DEX)" fillcolor="#ef9a9a"]
    Steroid_AE [label="Steroid AEs\n(Hyperglycemia,\nOsteoporosis)" fillcolor="#ffcdd2"]
    Immuno_Paresis [label="Immunoparesis\n(Reduced Polyclonal\nIg)" fillcolor="#e57373"]
    REMS_Monitor [label="REMS / Safety\nMonitoring\n(CBC, LFT, CMP)" fillcolor="#b71c1c" fontcolor=white shape=parallelogram]

    DARA_Bound -> IRR [label="cytokine\nrelease" style=dashed]
    BTZ_Effi -> Neuropathy_BTZ [style=dashed]
    CY_Effi -> Cytopenias [style=dashed]
    CY_Effi -> DVT_PE [style=dashed]
    DEX_C1 -> Steroid_AE [style=dashed]
    DEX_C1 -> GI_toxicity [style=dashed]
    Cytopenias -> Infections
    Immuno_Paresis -> Infections
    REMS_Monitor -> DARA_C1 [style=dashed]
  }

  //=============================================================
  // INTER-CLUSTER CONNECTIONS
  //=============================================================

  // Light chain → fibril deposition
  FLC_Serum -> Nucleation [label="misfolded\nLC seeds" color="#c62828" penwidth=2]
  Oligomers -> Oligomers_cardio [color=red penwidth=2]

  // Fibril → organ deposition
  AmyloidFibril -> CardiacDepos [color="#e65100" penwidth=2 label="cardiac\ndeposition"]
  AmyloidFibril -> RenalDepos [color="#1b5e20" penwidth=2 label="renal\ndeposition"]
  AmyloidFibril -> LiverDepos [color="#6a1b9a" penwidth=2]

  // Plasma cell → LC production
  MalignantPC -> LC_Prod [color="#c62828" penwidth=2.5 label="monoclonal\nLC secretion"]

  // DARA PD → PC killing
  DARA_Bound -> PC_Kill_Dara [color="#0d47a1" penwidth=2.5 label="CD38 opsonization\n→ ADCC/CDC/ADCP"]

  // BTZ PD → PC killing
  BTZ_Effi -> PC_Kill_BTZ [color="#283593" penwidth=2]

  // CY PD → PC killing
  CY_Effi -> PC_Kill_CY [color="#455a64" penwidth=2]

  // DEX PD → PC killing
  GR_Effect -> PC_Kill_DEX [color="#795548" penwidth=2]

  // PC killing → PC reduction
  PC_Kill_Dara -> MalignantPC [arrowhead=tee color="#0d47a1" penwidth=2 label="↓ PC"]
  PC_Kill_BTZ -> MalignantPC [arrowhead=tee color="#283593" penwidth=2]
  PC_Kill_CY -> MalignantPC [arrowhead=tee color="#455a64" penwidth=2]
  PC_Kill_DEX -> MalignantPC [arrowhead=tee color="#795548" penwidth=2]

  // PC reduction → LC reduction → FLC reduction
  MalignantPC -> dFLC [label="FLC\nproduction" style=dashed color="#c62828"]

  // Staging connections
  CardiacStage -> Mayo2012 [style=dashed label="Mayo cardiac\nstage → OS risk"]

  // Organ response after hematologic response
  dFLC -> OrgResp_Card [label="dFLC↓ →\ncardiac\nrecovery" style=dashed color="#f57f17"]
  dFLC -> OrgResp_Renal [label="dFLC↓ →\nrenal\nrecovery" style=dashed color="#1b5e20"]
  NTproBNP -> OrgResp_Card [label="NT-proBNP\n≥30% reduction" style=dashed color="#bf360c"]
  Proteinuria -> OrgResp_Renal [label="proteinuria\n≥30% reduction" style=dashed color="#1b5e20"]

  // BM microenvironment signals → PC
  IL6_BM -> MalignantPC [label="survival\nsignals" style=dashed color="#004d40"]
  Mcl1 -> PC_Death [arrowhead=tee label="anti-apoptotic\nshield" style=dashed]
  BTZ_Effi -> ProteaBurden [label="UPS stress" style=dashed]

  // NK cell effects
  ADCC -> NK_Activity [style=dashed]
  NK_Activity -> MalignantPC [arrowhead=tee style=dashed color="#2e7d32" label="ADCC killing"]

  // Complement effects
  CDC -> MalignantPC [arrowhead=tee style=dashed color="#0d47a1"]

  // Renal clearance of FLC
  GFR -> FLC_Renal [label="filtered\nFLC" style=dashed]

  // Safety monitoring
  MalignantPC -> BMPlasmaCells -> REMS_Monitor [style=dashed]
  Troponin_T -> REMS_Monitor [style=dashed]
  NTproBNP -> REMS_Monitor [style=dashed]
  dFLC -> REMS_Monitor [style=dashed]

  // PD interactions (DDI)
  CY_Effi -> NK_Cells [label="lymphopenia\n(transient)" arrowhead=tee style=dashed]

  //=============================================================
  // LEGEND
  //=============================================================
  subgraph cluster_legend {
    label="Legend"
    style="filled,rounded" fillcolor="#ffffff" color="#9e9e9e" penwidth=1.5 fontsize=11

    L1 [label="Pathophysiology" fillcolor="#ef9a9a" style="filled,rounded" fontsize=9]
    L2 [label="Drug PK/PD" fillcolor="#90caf9" style="filled,rounded" fontsize=9]
    L3 [label="Biomarker" fillcolor="#ffe082" style="filled,rounded" fontsize=9]
    L4 [label="Clinical Outcome" fillcolor="#ce93d8" style="filled,rounded" fontsize=9]
    L5 [label="Inhibition" fillcolor="#ffffff" style="filled,rounded" fontsize=9 shape=plaintext]
    L5b [label="" shape=point]
    L6 [label="Activation" fillcolor="#ffffff" style="filled,rounded" fontsize=9 shape=plaintext]
    L6b [label="" shape=point]

    L5 -> L5b [arrowhead=tee color=red label=""]
    L6b -> L6 [color="#0d47a1" label=""]
  }
}
