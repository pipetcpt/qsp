digraph BreastCancerQSP {
    rankdir=TB
    splines=ortho
    fontname="Helvetica"
    fontsize=11
    compound=true
    nodesep=0.4
    ranksep=0.6
    graph [bgcolor="#FAFAFA"]

    // ─────────────────────────────────────────────
    // CLUSTER 1: TUMOR CELLS
    // ─────────────────────────────────────────────
    subgraph cluster_tumor_cells {
        label="Tumor Cell Compartment"
        style=filled
        bgcolor="#FFE4E1"
        fontsize=13
        fontcolor="#7B0000"
        pencolor="#C62828"

        node [shape=box, style=filled, color="#B71C1C", fillcolor="#FFCDD2", fontsize=10]

        CSC          [label="Cancer Stem Cells\n(CSC)"]
        ERpos_cell   [label="ER+ Tumor Cells"]
        HER2pos_cell [label="HER2+ Tumor Cells"]
        TNBC_cell    [label="TNBC Cells"]
        LumA_cell    [label="Luminal A Cells"]
        LumB_cell    [label="Luminal B Cells"]
        Basal_cell   [label="Basal-like Cells"]
        G0_phase     [label="Cell Cycle: G0"]
        G1_phase     [label="Cell Cycle: G1"]
        S_phase      [label="Cell Cycle: S"]
        G2_phase     [label="Cell Cycle: G2"]
        M_phase      [label="Cell Cycle: M"]
        Apoptotic    [label="Apoptotic Cells"]
        Necrotic     [label="Necrotic Cells"]
        Senescent    [label="Senescent Cells"]
        CTCs_primary [label="Circulating Tumor\nCells (CTCs)"]
    }

    // ─────────────────────────────────────────────
    // CLUSTER 2: SIGNALING PATHWAYS
    // ─────────────────────────────────────────────
    subgraph cluster_signaling {
        label="Intracellular Signaling Networks"
        style=filled
        bgcolor="#E1F0FF"
        fontsize=13
        fontcolor="#003087"
        pencolor="#1565C0"

        node [shape=ellipse, style=filled, color="#1B5E20", fillcolor="#C8E6C9", fontsize=10]

        ERalpha_sig  [label="ERα (ESR1)"]
        ERE_act      [label="ERE Activation"]
        CycD1_sig    [label="Cyclin D1\n(signaling)"]
        HER2_sig     [label="HER2 (ERBB2)"]
        ERBB3        [label="ERBB3"]
        EGFR         [label="EGFR (ERBB1)"]
        HER4         [label="HER4 (ERBB4)"]
        PI3K         [label="PI3K (p110α)"]
        AKT          [label="AKT (pAKT)"]
        mTORC1       [label="mTORC1"]
        mTORC2       [label="mTORC2"]
        S6K1         [label="S6K1"]
        bpEBP1       [label="4EBP1"]
        MAPK_node    [label="MAPK Cascade"]
        MEK          [label="MEK1/2"]
        ERK          [label="ERK1/2"]
        RSK          [label="RSK"]
        JAK1         [label="JAK1"]
        JAK2         [label="JAK2"]
        STAT3        [label="STAT3"]
        Wnt_lig      [label="Wnt Ligand"]
        bCatenin     [label="β-catenin"]
        Frizzled     [label="Frizzled Receptor"]
        Notch1       [label="Notch1"]
        Dll4         [label="Dll4"]
        p53          [label="p53 (TP53)"]
        MDM2         [label="MDM2"]
        BRCA1        [label="BRCA1"]
        BRCA2        [label="BRCA2"]
        RB1_sig      [label="RB1 (signaling)"]
    }

    // ─────────────────────────────────────────────
    // CLUSTER 3: CDK4/6 AXIS
    // ─────────────────────────────────────────────
    subgraph cluster_cdk46_axis {
        label="CDK4/6 – Cell Cycle Axis"
        style=filled
        bgcolor="#E1FFE4"
        fontsize=13
        fontcolor="#003300"
        pencolor="#2E7D32"

        node [shape=ellipse, style=filled, color="#1B5E20", fillcolor="#A5D6A7", fontsize=10]

        CDK4         [label="CDK4"]
        CDK6         [label="CDK6"]
        CycD1_cdk    [label="Cyclin D1\n(CDK axis)"]
        CycE1        [label="Cyclin E1"]
        CycE2        [label="Cyclin E2"]
        RB1_active   [label="RB1 (active,\nhypophospho)"]
        pRB          [label="pRB\n(phosphorylated)"]
        E2F1         [label="E2F1"]
        E2F2         [label="E2F2"]
        E2F3         [label="E2F3"]
        p21_CDKN1A   [label="p21 (CDKN1A)"]
        p27_CDKN1B   [label="p27 (CDKN1B)"]
        p16_CDKN2A   [label="p16 (CDKN2A)"]
        CDC25A       [label="CDC25A"]

        node [shape=diamond, style=filled, color="#006064", fillcolor="#B2EBF2", fontsize=10]
        G1S_transit  [label="G1→S Transition"]
        G2M_transit  [label="G2→M Transition"]
    }

    // ─────────────────────────────────────────────
    // CLUSTER 4: TUMOR MICROENVIRONMENT
    // ─────────────────────────────────────────────
    subgraph cluster_tme {
        label="Tumor Microenvironment (TME)"
        style=filled
        bgcolor="#FFF0E1"
        fontsize=13
        fontcolor="#4E2000"
        pencolor="#E65100"

        node [shape=box, style=filled, color="#B71C1C", fillcolor="#FFCCBC", fontsize=10]

        CD8T         [label="CD8+ T Cells\n(Cytotoxic)"]
        CD4T         [label="CD4+ T Cells\n(Helper)"]
        Tregs        [label="Tregs (FoxP3+)"]
        NK_cells     [label="NK Cells"]
        DCs          [label="Dendritic Cells (DCs)"]
        TAM_M1       [label="TAM M1\n(pro-inflammatory)"]
        TAM_M2       [label="TAM M2\n(immunosuppressive)"]
        MDSCs        [label="MDSCs"]
        TIL_score    [label="TIL Score"]

        node [shape=ellipse, style=filled, color="#1B5E20", fillcolor="#C8E6C9", fontsize=10]

        PD1          [label="PD-1 (PDCD1)"]
        PDL1         [label="PD-L1 (CD274)"]
        CTLA4        [label="CTLA-4"]
        LAG3         [label="LAG-3"]
        TIM3         [label="TIM-3"]
        IDO1         [label="IDO1"]
        IFNg         [label="IFN-γ"]
        TNFa         [label="TNF-α"]
        IL10         [label="IL-10"]
        IL6          [label="IL-6"]
        TGFb         [label="TGF-β"]
        CCL2         [label="CCL2 (MCP-1)"]
        CXCL9        [label="CXCL9"]
        CXCL10       [label="CXCL10"]
        CXCR3        [label="CXCR3"]
    }

    // ─────────────────────────────────────────────
    // CLUSTER 5: ANGIOGENESIS & METASTASIS
    // ─────────────────────────────────────────────
    subgraph cluster_angiogenesis_metastasis {
        label="Angiogenesis and Metastasis"
        style=filled
        bgcolor="#F0E1FF"
        fontsize=13
        fontcolor="#2E0050"
        pencolor="#6A1B9A"

        node [shape=ellipse, style=filled, color="#1B5E20", fillcolor="#E1BEE7", fontsize=10]

        VEGFa        [label="VEGF-A"]
        VEGFc        [label="VEGF-C"]
        VEGFR1       [label="VEGFR1"]
        VEGFR2       [label="VEGFR2"]
        VEGFR3       [label="VEGFR3"]
        Angpt1       [label="Angiopoietin-1"]
        Angpt2       [label="Angiopoietin-2"]
        Tie2         [label="Tie2"]
        HIF1a        [label="HIF-1α"]
        MMP2         [label="MMP-2"]
        MMP9         [label="MMP-9"]
        Ecadherin    [label="E-cadherin"]
        Ncadherin    [label="N-cadherin"]
        Vimentin     [label="Vimentin"]
        Twist1       [label="Twist1"]
        Snail1       [label="Snail1"]
        ZEB1         [label="ZEB1"]
        Fibronectin  [label="Fibronectin"]

        node [shape=diamond, style=filled, color="#006064", fillcolor="#B2EBF2", fontsize=10]

        Lymphangio   [label="Lymphangiogenesis"]
        EMT_process  [label="EMT Process"]

        node [shape=box, style=filled, color="#B71C1C", fillcolor="#CE93D8", fontsize=10]

        CTCs_meta    [label="CTCs (metastatic)"]
        BM_niche     [label="Bone Marrow Niche"]
        Brain_meta   [label="Brain Metastasis"]
        Liver_meta   [label="Liver Metastasis"]
    }

    // ─────────────────────────────────────────────
    // CLUSTER 6: HORMONE METABOLISM
    // ─────────────────────────────────────────────
    subgraph cluster_hormone_metabolism {
        label="Estrogen Synthesis and Metabolism"
        style=filled
        bgcolor="#FFFFE1"
        fontsize=13
        fontcolor="#3E2000"
        pencolor="#F57F17"

        node [shape=ellipse, style=filled, color="#1B5E20", fillcolor="#FFF9C4", fontsize=10]

        E2           [label="Estradiol (E2)"]
        E1           [label="Estrone (E1)"]
        E3           [label="Estriol (E3)"]
        Aromatase    [label="Aromatase\n(CYP19A1)"]
        SHBG         [label="SHBG"]
        ERalpha_hm   [label="ERα (hormone)"]
        ERbeta       [label="ERβ"]
        Genomic_ER   [label="Genomic ER Signaling"]
        NonGenomic_ER [label="Non-genomic\nER Signaling"]
        Ovarian_E2   [label="Ovarian Estrogen"]
        Adrenal_DHEA [label="Adrenal DHEA"]
        Testosterone [label="Testosterone"]
        Androstene   [label="Androstenedione"]
        PR_receptor  [label="Progesterone\nReceptor (PR)"]
        SRC1         [label="SRC-1 (Coactivator)"]
        SRC3_AIB1    [label="SRC-3 / AIB1"]
    }

    // ─────────────────────────────────────────────
    // CLUSTER 7: DRUG PK/PD
    // ─────────────────────────────────────────────
    subgraph cluster_drug_pkpd {
        label="Pharmacological Interventions (PK/PD)"
        style=filled
        bgcolor="#E1FFFF"
        fontsize=13
        fontcolor="#003333"
        pencolor="#00838F"

        node [shape=hexagon, style=filled, color="#1565C0", fillcolor="#E3F2FD", fontsize=10]

        Tamoxifen    [label="Tamoxifen"]
        Endoxifen    [label="Endoxifen\n(active metabolite)"]
        CYP2D6_enz   [label="CYP2D6"]
        Letrozole    [label="Letrozole"]
        Anastrozole  [label="Anastrozole"]
        Exemestane   [label="Exemestane"]
        Palbociclib  [label="Palbociclib"]
        Ribociclib   [label="Ribociclib"]
        Abemaciclib  [label="Abemaciclib"]
        Trastuzumab  [label="Trastuzumab"]
        Pertuzumab   [label="Pertuzumab"]
        TDM1         [label="T-DM1\n(ado-trastuzumab)"]
        TDXd         [label="T-DXd\n(trastuzumab deruxtecan)"]
        Pembro       [label="Pembrolizumab"]
        Atezo        [label="Atezolizumab"]
        Olaparib     [label="Olaparib"]
        Talazoparib  [label="Talazoparib"]
        Niraparib    [label="Niraparib"]
        Alpelisib    [label="Alpelisib\n(PIK3CA inhibitor)"]
        Everolimus   [label="Everolimus\n(mTOR inhibitor)"]
        Capecitabine [label="Capecitabine"]
        FiveFlU      [label="5-Fluorouracil (5-FU)"]
        Paclitaxel   [label="Paclitaxel"]
        Docetaxel    [label="Docetaxel"]
        SacGovitecan [label="Sacituzumab\nGovitecan"]
        Elacestrant  [label="Elacestrant\n(SERD)"]
    }

    // ─────────────────────────────────────────────
    // CLUSTER 8: RESISTANCE MECHANISMS
    // ─────────────────────────────────────────────
    subgraph cluster_resistance {
        label="Resistance Mechanisms"
        style=filled
        bgcolor="#FFE8F0"
        fontsize=13
        fontcolor="#5D0033"
        pencolor="#AD1457"

        node [shape=ellipse, style=filled, color="#E65100", fillcolor="#FFE0B2", fontsize=10]

        ESR1_Y537S    [label="ESR1 Y537S Mutation"]
        ESR1_D538G    [label="ESR1 D538G Mutation"]
        PIK3CA_H1047R [label="PIK3CA H1047R"]
        PIK3CA_E545K  [label="PIK3CA E545K"]
        ERBB2_amp     [label="ERBB2 Amplification"]
        PTEN_loss     [label="PTEN Loss"]
        CycE_amp      [label="Cyclin E Amplification"]
        CDK2_bypass   [label="CDK2 Bypass"]
        EMT_resist    [label="EMT-driven Resistance"]
        CSC_enrich    [label="CSC Enrichment"]
        ABCB1         [label="ABCB1 Efflux Pump"]
        MDR1          [label="MDR1 (P-gp)"]
        HER2_L755S    [label="HER2 L755S Mutation"]
        CCND1_amp     [label="CCND1 Amplification"]
        FGFR1_amp     [label="FGFR1 Amplification"]
        AURKA_amp     [label="AURKA Amplification"]
        Lapatinib_r   [label="Lapatinib\nResistance\nTarget", shape=ellipse,
                        color="#E65100", fillcolor="#FFE0B2"]
    }

    // ─────────────────────────────────────────────
    // CLUSTER 9: CLINICAL ENDPOINTS
    // ─────────────────────────────────────────────
    subgraph cluster_clinical_endpoints {
        label="Clinical Endpoints and Biomarkers"
        style=filled
        bgcolor="#F5F5E1"
        fontsize=13
        fontcolor="#1A1A00"
        pencolor="#827717"

        node [shape=ellipse, style=filled, color="#4A148C", fillcolor="#E1BEE7", fontsize=10]

        OS     [label="Overall Survival (OS)"]
        PFS    [label="Progression-free\nSurvival (PFS)"]
        ORR    [label="Objective Response\nRate (ORR)"]
        pCR    [label="Pathological Complete\nResponse (pCR)"]
        Ki67   [label="Ki-67 Index"]
        CA153  [label="CA15-3 Marker"]
        CEA_ep [label="CEA"]
        ctDNA  [label="ctDNA"]
        CTCs_ep [label="CTCs (endpoint)"]
        LVEF   [label="LVEF\n(cardiac safety)"]
        ANC    [label="ANC\n(neutrophil count)"]
        ALTAST [label="ALT/AST\n(hepatotoxicity)"]
        BMD    [label="Bone Mineral\nDensity (BMD)"]
        TumorVol [label="Tumor Volume (TV)"]
        TTR    [label="Time to Response (TTR)"]
    }

    // ─────────────────────────────────────────────
    // EDGES — CLUSTER 1: TUMOR CELL BIOLOGY
    // Cell cycle is directed (acyclic in DOT terms via constraint)
    // ─────────────────────────────────────────────

    CSC -> ERpos_cell    [arrowhead=normal, color="#C62828"]
    CSC -> HER2pos_cell  [arrowhead=normal, color="#C62828"]
    CSC -> TNBC_cell     [arrowhead=normal, color="#C62828"]
    CSC -> LumA_cell     [arrowhead=normal, color="#C62828"]
    CSC -> LumB_cell     [arrowhead=normal, color="#C62828"]
    CSC -> Basal_cell    [arrowhead=normal, color="#C62828"]

    G0_phase -> G1_phase [arrowhead=normal, color="#8B0000"]
    G1_phase -> S_phase  [arrowhead=normal, color="#8B0000"]
    S_phase -> G2_phase  [arrowhead=normal, color="#8B0000"]
    G2_phase -> M_phase  [arrowhead=normal, color="#8B0000"]
    M_phase -> Apoptotic [arrowhead=normal, color="#555555", style=dashed]
    G1_phase -> Senescent [arrowhead=normal, color="#555555", style=dashed]
    ERpos_cell -> CTCs_primary [arrowhead=normal, color="#C62828"]
    HER2pos_cell -> CTCs_primary [arrowhead=normal, color="#C62828"]
    TNBC_cell -> CTCs_primary [arrowhead=normal, color="#C62828"]
    ERpos_cell -> Necrotic [arrowhead=normal, color="#888888", style=dashed]

    // ─────────────────────────────────────────────
    // EDGES — CLUSTER 2: SIGNALING
    // ─────────────────────────────────────────────

    ERalpha_sig -> ERE_act   [arrowhead=normal, color="#1B5E20"]
    ERE_act -> CycD1_sig     [arrowhead=normal, color="#1B5E20"]
    HER2_sig -> ERBB3        [arrowhead=normal, color="#1B5E20"]
    HER2_sig -> EGFR         [arrowhead=normal, color="#1B5E20"]
    EGFR -> PI3K             [arrowhead=normal, color="#1B5E20"]
    ERBB3 -> PI3K            [arrowhead=normal, color="#1B5E20"]
    HER4 -> PI3K             [arrowhead=normal, color="#1B5E20"]
    PI3K -> AKT              [arrowhead=normal, color="#1B5E20"]
    AKT -> mTORC1            [arrowhead=normal, color="#1B5E20"]
    AKT -> mTORC2            [arrowhead=normal, color="#1B5E20"]
    mTORC1 -> S6K1           [arrowhead=normal, color="#1B5E20"]
    mTORC1 -> bpEBP1         [arrowhead=tee,    color="#C62828"]
    mTORC2 -> AKT            [arrowhead=normal, color="#1B5E20", constraint=false]
    EGFR -> MAPK_node        [arrowhead=normal, color="#1B5E20"]
    HER2_sig -> MAPK_node    [arrowhead=normal, color="#1B5E20"]
    MAPK_node -> MEK         [arrowhead=normal, color="#1B5E20"]
    MEK -> ERK               [arrowhead=normal, color="#1B5E20"]
    ERK -> RSK               [arrowhead=normal, color="#1B5E20"]
    ERK -> CycD1_sig         [arrowhead=normal, color="#1B5E20"]
    JAK1 -> JAK2             [arrowhead=normal, color="#1B5E20"]
    JAK2 -> STAT3            [arrowhead=normal, color="#1B5E20"]
    STAT3 -> CycD1_sig       [arrowhead=normal, color="#1B5E20"]
    Wnt_lig -> Frizzled      [arrowhead=normal, color="#1B5E20"]
    Frizzled -> bCatenin     [arrowhead=normal, color="#1B5E20"]
    bCatenin -> CycD1_sig    [arrowhead=normal, color="#1B5E20"]
    Dll4 -> Notch1           [arrowhead=normal, color="#1B5E20"]
    Notch1 -> CSC            [arrowhead=normal, color="#1B5E20", style=dashed, constraint=false]
    p53 -> MDM2              [arrowhead=normal, color="#1B5E20"]
    MDM2 -> p53              [arrowhead=tee,    color="#C62828", constraint=false]
    p53 -> Apoptotic         [arrowhead=normal, color="#1B5E20", style=dashed]
    BRCA1 -> p53             [arrowhead=normal, color="#1B5E20"]
    BRCA2 -> p53             [arrowhead=normal, color="#1B5E20"]
    CycD1_sig -> RB1_sig     [arrowhead=normal, color="#1B5E20"]

    // ─────────────────────────────────────────────
    // EDGES — CLUSTER 3: CDK4/6 AXIS
    // ─────────────────────────────────────────────

    CycD1_cdk -> CDK4        [arrowhead=normal, color="#2E7D32"]
    CycD1_cdk -> CDK6        [arrowhead=normal, color="#2E7D32"]
    CDK4 -> pRB              [arrowhead=normal, color="#2E7D32"]
    CDK6 -> pRB              [arrowhead=normal, color="#2E7D32"]
    RB1_active -> E2F1       [arrowhead=tee,    color="#C62828"]
    RB1_active -> E2F2       [arrowhead=tee,    color="#C62828"]
    RB1_active -> E2F3       [arrowhead=tee,    color="#C62828"]
    pRB -> E2F1              [arrowhead=normal, color="#2E7D32"]
    E2F1 -> G1S_transit      [arrowhead=normal, color="#2E7D32"]
    E2F2 -> G1S_transit      [arrowhead=normal, color="#2E7D32"]
    E2F3 -> G1S_transit      [arrowhead=normal, color="#2E7D32"]
    G1S_transit -> CycE1     [arrowhead=normal, color="#2E7D32"]
    CycE2 -> G1S_transit     [arrowhead=normal, color="#2E7D32"]
    p21_CDKN1A -> CDK4       [arrowhead=tee,    color="#C62828"]
    p27_CDKN1B -> CDK6       [arrowhead=tee,    color="#C62828"]
    p16_CDKN2A -> CDK4       [arrowhead=tee,    color="#C62828"]
    p16_CDKN2A -> CDK6       [arrowhead=tee,    color="#C62828"]
    CDC25A -> CycE1           [arrowhead=normal, color="#2E7D32"]
    G2_phase -> G2M_transit   [arrowhead=normal, color="#2E7D32"]
    G2M_transit -> M_phase    [arrowhead=normal, color="#2E7D32"]
    p53 -> p21_CDKN1A         [arrowhead=normal, color="#1B5E20"]
    CycD1_sig -> CycD1_cdk    [arrowhead=normal, color="#006064", style=dashed]
    AKT -> p27_CDKN1B         [arrowhead=tee,    color="#C62828"]
    ERK -> CDC25A             [arrowhead=normal, color="#1B5E20"]
    G1S_transit -> S_phase    [arrowhead=normal, color="#2E7D32"]
    E2F1 -> S_phase           [arrowhead=normal, color="#2E7D32"]

    // ─────────────────────────────────────────────
    // EDGES — CLUSTER 4: TME
    // ─────────────────────────────────────────────

    CD8T -> ERpos_cell       [arrowhead=normal, color="#E65100"]
    CD8T -> HER2pos_cell     [arrowhead=normal, color="#E65100"]
    CD8T -> TNBC_cell        [arrowhead=normal, color="#E65100"]
    NK_cells -> Apoptotic    [arrowhead=normal, color="#E65100"]
    IFNg -> PDL1             [arrowhead=normal, color="#E65100"]
    TNFa -> Apoptotic        [arrowhead=normal, color="#E65100"]
    Tregs -> CD8T            [arrowhead=tee,    color="#C62828"]
    TAM_M2 -> CD8T           [arrowhead=tee,    color="#C62828"]
    MDSCs -> CD8T            [arrowhead=tee,    color="#C62828"]
    MDSCs -> NK_cells        [arrowhead=tee,    color="#C62828"]
    IL10 -> CD8T             [arrowhead=tee,    color="#C62828"]
    TGFb -> CD8T             [arrowhead=tee,    color="#C62828"]
    TGFb -> Tregs            [arrowhead=normal, color="#C62828"]
    IL6 -> STAT3             [arrowhead=normal, color="#E65100"]
    IDO1 -> CD8T             [arrowhead=tee,    color="#C62828"]
    PD1 -> CD8T              [arrowhead=tee,    color="#C62828"]
    PDL1 -> PD1              [arrowhead=tee,    color="#C62828"]
    CTLA4 -> CD4T            [arrowhead=tee,    color="#C62828"]
    LAG3 -> CD8T             [arrowhead=tee,    color="#C62828"]
    TIM3 -> CD8T             [arrowhead=tee,    color="#C62828"]
    CCL2 -> TAM_M2           [arrowhead=normal, color="#E65100"]
    CCL2 -> MDSCs            [arrowhead=normal, color="#E65100"]
    CXCL9 -> CD8T            [arrowhead=normal, color="#E65100"]
    CXCL10 -> CD8T           [arrowhead=normal, color="#E65100"]
    CXCR3 -> CD8T            [arrowhead=normal, color="#E65100", constraint=false]
    DCs -> CD8T              [arrowhead=normal, color="#E65100"]
    DCs -> CD4T              [arrowhead=normal, color="#E65100"]
    TIL_score -> OS          [arrowhead=normal, color="#827717", style=dashed]
    ERpos_cell -> IL6        [arrowhead=normal, color="#C62828", style=dashed]
    ERpos_cell -> TGFb       [arrowhead=normal, color="#C62828", style=dashed]
    TNBC_cell -> CCL2        [arrowhead=normal, color="#C62828", style=dashed]
    TAM_M1 -> IFNg           [arrowhead=normal, color="#E65100"]
    TAM_M1 -> TNFa           [arrowhead=normal, color="#E65100"]
    TAM_M2 -> IL10           [arrowhead=normal, color="#C62828"]
    TAM_M2 -> TGFb           [arrowhead=normal, color="#C62828"]

    // ─────────────────────────────────────────────
    // EDGES — CLUSTER 5: ANGIOGENESIS & METASTASIS
    // ─────────────────────────────────────────────

    HIF1a -> VEGFa           [arrowhead=normal, color="#6A1B9A"]
    HIF1a -> VEGFc           [arrowhead=normal, color="#6A1B9A"]
    HIF1a -> MMP2            [arrowhead=normal, color="#6A1B9A"]
    HIF1a -> MMP9            [arrowhead=normal, color="#6A1B9A"]
    VEGFa -> VEGFR2          [arrowhead=normal, color="#6A1B9A"]
    VEGFc -> VEGFR3          [arrowhead=normal, color="#6A1B9A"]
    VEGFa -> VEGFR1          [arrowhead=normal, color="#6A1B9A"]
    VEGFR2 -> Lymphangio     [arrowhead=normal, color="#6A1B9A"]
    VEGFR3 -> Lymphangio     [arrowhead=normal, color="#6A1B9A"]
    Angpt1 -> Tie2           [arrowhead=normal, color="#6A1B9A"]
    Angpt2 -> Tie2           [arrowhead=tee,    color="#C62828"]
    MMP2 -> Ecadherin        [arrowhead=tee,    color="#C62828"]
    MMP9 -> Fibronectin      [arrowhead=normal, color="#6A1B9A"]
    Ecadherin -> EMT_process [arrowhead=tee,    color="#C62828"]
    Twist1 -> Ecadherin      [arrowhead=tee,    color="#C62828"]
    Snail1 -> Ecadherin      [arrowhead=tee,    color="#C62828"]
    ZEB1 -> Ecadherin        [arrowhead=tee,    color="#C62828"]
    Twist1 -> Ncadherin      [arrowhead=normal, color="#6A1B9A"]
    Snail1 -> Vimentin       [arrowhead=normal, color="#6A1B9A"]
