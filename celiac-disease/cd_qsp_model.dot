digraph CeliacDisease_QSP {
    graph [splines=curved, nodesep=0.55, ranksep=0.9,
           bgcolor="#FAFAFA", fontname="Helvetica",
           label="Celiac Disease QSP Mechanistic Map\nQuantitative Systems Pharmacology Model",
           labelloc=t, fontsize=18, fontcolor="#0D47A1"]
    node [fontname="Helvetica", fontsize=9, style="filled,rounded", penwidth=1.5]
    edge [fontname="Helvetica", fontsize=7.5, penwidth=1.2]

    // ============================================================
    // CLUSTER 1: Genetic & Environmental Predisposition
    // ============================================================
    subgraph cluster_genetics {
        label="① Genetic & Environmental Predisposition"
        style=filled; fillcolor="#E8F5E9"; color="#2E7D32"
        fontcolor="#1B5E20"; fontsize=13; fontname="Helvetica-Bold"

        HLA_DQ2   [label="HLA-DQ2.5\n(DQA1*05:DQB1*02)", shape=box, fillcolor="#4CAF50", fontcolor=white]
        HLA_DQ8   [label="HLA-DQ8\n(DQA1*03:DQB1*03:02)", shape=box, fillcolor="#4CAF50", fontcolor=white]
        IL2gene   [label="IL-2/IL-21\ngene variants", shape=box, fillcolor="#81C784"]
        CTLA4gene [label="CTLA4\ngene variant", shape=box, fillcolor="#81C784"]
        PTPN22g   [label="PTPN22\nvariant", shape=box, fillcolor="#A5D6A7"]
        RGS1g     [label="RGS1 / CCR3\nvariants", shape=box, fillcolor="#A5D6A7"]
        SH2B3g    [label="SH2B3 / TAGAP\nvariants", shape=box, fillcolor="#A5D6A7"]
        Gluten_in [label="Gluten\nIngestion\n(10–15 g/day)", shape=ellipse, fillcolor="#FFF9C4"]
        Rotavirus [label="Rotavirus\nInfection", shape=ellipse, fillcolor="#FFF9C4"]
        Microbiome[label="Gut Microbiome\nDysbiosis", shape=ellipse, fillcolor="#FFF9C4"]
        EarlyExp  [label="Early Gluten\nExposure Timing", shape=ellipse, fillcolor="#FFF9C4"]
        BreastFeed[label="Breastfeeding\n(protective?)", shape=ellipse, fillcolor="#C8E6C9"]
    }

    // ============================================================
    // CLUSTER 2: Gluten Peptide Processing & Deamidation
    // ============================================================
    subgraph cluster_gluten {
        label="② Gluten Peptide Processing & tTG2 Deamidation"
        style=filled; fillcolor="#FFF3E0"; color="#E65100"
        fontcolor="#BF360C"; fontsize=13; fontname="Helvetica-Bold"

        W_gliadin  [label="Wheat α-Gliadin\np31–43 / p57–68 / 33-mer", shape=box, fillcolor="#FF9800", fontcolor=white]
        W_glutenin [label="Wheat\nGlutenin Peptides", shape=box, fillcolor="#FFB74D"]
        B_hordein  [label="Barley\nHordein", shape=box, fillcolor="#FFB74D"]
        R_secalin  [label="Rye\nSecalin", shape=box, fillcolor="#FFB74D"]
        PartDig    [label="Partial Luminal\nDigestion", shape=diamond, fillcolor="#FFF9C4"]
        Gliadin_P  [label="Immunogenic\nGliadin Peptides\n(33-mer, 26-mer)", shape=box, fillcolor="#FF6F00", fontcolor=white]
        tTG2       [label="Tissue\nTransglutaminase 2\n(TG2 / tTG)", shape=box, fillcolor="#F4511E", fontcolor=white]
        Deamid     [label="Deamidation\n(Gln→Glu)", shape=diamond, fillcolor="#FFCCBC"]
        DGP        [label="Deamidated\nGliadin Peptides (DGP)\n↑Negative charge", shape=box, fillcolor="#BF360C", fontcolor=white]
        TGFb_tTG   [label="TGF-β\n→ tTG2 activation", shape=box, fillcolor="#FF8A65"]
        IFNg_tTG   [label="IFN-γ\n→ tTG2 upregulation", shape=box, fillcolor="#FF8A65"]
    }

    // ============================================================
    // CLUSTER 3: Intestinal Barrier & Epithelium
    // ============================================================
    subgraph cluster_barrier {
        label="③ Intestinal Barrier Dysfunction"
        style=filled; fillcolor="#E3F2FD"; color="#0D47A1"
        fontcolor="#01579B"; fontsize=13; fontname="Helvetica-Bold"

        TJ_claudin [label="Tight Junctions\n(Claudin-3/4, Occludin,\nZO-1, JAM-A)", shape=box, fillcolor="#1976D2", fontcolor=white]
        Zonulin    [label="Zonulin\n(Haptoglobin-2)", shape=box, fillcolor="#42A5F5"]
        IP_index   [label="↑ Intestinal\nPermeability", shape=box, fillcolor="#90CAF9"]
        Para_trans [label="Paracellular\nTransport", shape=diamond, fillcolor="#E3F2FD"]
        Retro_tc   [label="Retrotranscytosis\n(pIgR pathway)", shape=diamond, fillcolor="#E3F2FD"]
        SIgA       [label="Secretory IgA\n(SIgA barrier)", shape=box, fillcolor="#1565C0", fontcolor=white]
        Entero_str [label="Enterocyte\nStress Response", shape=box, fillcolor="#64B5F6"]
        MICA_MICB  [label="MICA / MICB\n(NKG2D ligands)", shape=box, fillcolor="#64B5F6"]
        Ep_apopt   [label="Epithelial Cell\nApoptosis (Fas/FasL)", shape=box, fillcolor="#1E88E5", fontcolor=white]
        MLCK_path  [label="MLCK Activation\n(myosin phosphorylation)", shape=box, fillcolor="#90CAF9"]
    }

    // ============================================================
    // CLUSTER 4: Innate Immune Activation
    // ============================================================
    subgraph cluster_innate {
        label="④ Innate Immune Activation"
        style=filled; fillcolor="#FCE4EC"; color="#880E4F"
        fontcolor="#880E4F"; fontsize=13; fontname="Helvetica-Bold"

        IL15_epi   [label="IL-15\n(Enterocyte-derived)", shape=box, fillcolor="#E91E63", fontcolor=white]
        NK_cells   [label="NK Cells", shape=ellipse, fillcolor="#F06292"]
        NKG2D_R    [label="NKG2D Receptor\n(activating)", shape=box, fillcolor="#F48FB1"]
        IEL_CD8    [label="Intraepithelial\nLymphocytes (IEL)\nCD8+ / γδ T cells", shape=ellipse, fillcolor="#C2185B", fontcolor=white]
        IEL_act    [label="IEL Cytotoxic\nActivation\n(NKG2C+ IEL)", shape=box, fillcolor="#AD1457", fontcolor=white]
        DC_CD103   [label="CD103+ DCs\n(lamina propria)", shape=ellipse, fillcolor="#F48FB1"]
        Macro_M1   [label="M1 Macrophages\n(lamina propria)", shape=ellipse, fillcolor="#F48FB1"]
        TNFa_inn   [label="TNF-α\n(innate)", shape=box, fillcolor="#EC407A"]
        IL1b_inn   [label="IL-1β", shape=box, fillcolor="#EC407A"]
        IL6_inn    [label="IL-6\n(innate)", shape=box, fillcolor="#EC407A"]
        MMP_mat    [label="MMP-1/3/9\nMatrix metalloproteinases", shape=box, fillcolor="#F06292"]
        Complement [label="Complement\nActivation (C1q/C3/C4)", shape=box, fillcolor="#F48FB1"]
        NLRP3      [label="NLRP3\nInflammasome", shape=box, fillcolor="#E91E63", fontcolor=white]
    }

    // ============================================================
    // CLUSTER 5: Adaptive Immunity — T Cells
    // ============================================================
    subgraph cluster_tcell {
        label="⑤ Adaptive Immunity — T Cell Responses"
        style=filled; fillcolor="#F3E5F5"; color="#4A148C"
        fontcolor="#4A148C"; fontsize=13; fontname="Helvetica-Bold"

        CD4T      [label="CD4+ T Helper Cells\n(Lamina Propria)", shape=ellipse, fillcolor="#9C27B0", fontcolor=white]
        TCR_MHC   [label="TCR–MHC-II\nInteraction", shape=diamond, fillcolor="#E1BEE7"]
        Th1_cell  [label="Th1 Cells", shape=ellipse, fillcolor="#6A1B9A", fontcolor=white]
        Th2_cell  [label="Th2 Cells", shape=ellipse, fillcolor="#8E24AA", fontcolor=white]
        Th17_cell [label="Th17 Cells", shape=ellipse, fillcolor="#AB47BC"]
        Treg_cell [label="Regulatory T Cells\n(Treg, FoxP3+)", shape=ellipse, fillcolor="#CE93D8"]
        IFNg_T    [label="IFN-γ\n(Th1 signature)", shape=box, fillcolor="#4A148C", fontcolor=white]
        TNFa_T    [label="TNF-α\n(adaptive)", shape=box, fillcolor="#6A1B9A", fontcolor=white]
        IL4_T     [label="IL-4\n(Th2)", shape=box, fillcolor="#9C27B0", fontcolor=white]
        IL5_T     [label="IL-5\n(Th2)", shape=box, fillcolor="#AB47BC"]
        IL13_T    [label="IL-13\n(Th2)", shape=box, fillcolor="#AB47BC"]
        IL17A_T   [label="IL-17A\n(Th17)", shape=box, fillcolor="#8E24AA", fontcolor=white]
        IL21_T    [label="IL-21\n(Th17/Tfh)", shape=box, fillcolor="#9C27B0", fontcolor=white]
        IL22_T    [label="IL-22\n(Th17→epithelium)", shape=box, fillcolor="#AB47BC"]
        IL10_Tr   [label="IL-10\n(Treg, anti-inflam)", shape=box, fillcolor="#CE93D8"]
        TGFb_Tr   [label="TGF-β\n(Treg, suppression)", shape=box, fillcolor="#CE93D8"]
        CTLA4_Tr  [label="CTLA4\n(Treg, co-inhibitory)", shape=box, fillcolor="#CE93D8"]
        PD1_path  [label="PD-1/PD-L1\nPathway (exhaustion?)", shape=box, fillcolor="#E1BEE7"]
    }

    // ============================================================
    // CLUSTER 6: B Cells & Autoantibodies
    // ============================================================
    subgraph cluster_bcell {
        label="⑥ B Cell Response & Autoantibodies"
        style=filled; fillcolor="#E8F5E9"; color="#1B5E20"
        fontcolor="#1B5E20"; fontsize=13; fontname="Helvetica-Bold"

        Bcell_LP   [label="B Cells\n(Lamina Propria)", shape=ellipse, fillcolor="#388E3C", fontcolor=white]
        Plasma_LP  [label="IgA-secreting\nPlasma Cells", shape=ellipse, fillcolor="#2E7D32", fontcolor=white]
        AntiTTG_A  [label="Anti-tTG IgA\n(Diagnostic gold std)", shape=box, fillcolor="#1B5E20", fontcolor=white]
        AntiDGP_G  [label="Anti-DGP IgG\n(Deamidated gliadin)", shape=box, fillcolor="#43A047"]
        AGA_ab     [label="Anti-Gliadin\nAntibodies (AGA)", shape=box, fillcolor="#66BB6A"]
        EMA_ab     [label="Endomysial\nAntibodies (EMA)", shape=box, fillcolor="#81C784"]
        IgA_def    [label="Selective IgA\nDeficiency (2–3%)", shape=box, fillcolor="#A5D6A7"]
        IC_depos   [label="Immune Complex\nDeposition", shape=box, fillcolor="#4CAF50"]
        GC_react   [label="Germinal Center\nReaction", shape=diamond, fillcolor="#C8E6C9"]
        Tfh_help   [label="T Follicular Helper\n(Tfh) Cell Support", shape=box, fillcolor="#81C784"]
    }

    // ============================================================
    // CLUSTER 7: Intestinal Histopathology (Marsh)
    // ============================================================
    subgraph cluster_marsh {
        label="⑦ Intestinal Histopathology — Marsh Classification"
        style=filled; fillcolor="#FFF8E1"; color="#F57F17"
        fontcolor="#E65100"; fontsize=13; fontname="Helvetica-Bold"

        Marsh0    [label="Marsh 0\n(Normal mucosa)", shape=box, fillcolor="#FFECB3"]
        Marsh1    [label="Marsh 1\n(↑IEL >25/100 enterocytes)", shape=box, fillcolor="#FFE082"]
        Marsh2    [label="Marsh 2\n(+ Crypt hyperplasia)", shape=box, fillcolor="#FFD54F"]
        Marsh3a   [label="Marsh 3a\n(Partial villous atrophy)", shape=box, fillcolor="#FFCA28"]
        Marsh3b   [label="Marsh 3b\n(Subtotal villous atrophy)", shape=box, fillcolor="#FFC107"]
        Marsh3c   [label="Marsh 3c\n(Total villous atrophy)", shape=box, fillcolor="#FF8F00", fontcolor=white]
        VillAtrop [label="↓ Villous Height\n(V:C ratio < 1)", shape=box, fillcolor="#E65100", fontcolor=white]
        CryptHyp  [label="↑ Crypt Depth\n(Hyperplasia)", shape=box, fillcolor="#E65100", fontcolor=white]
        IEL_count [label="↑ IEL Count\n(Lymphocytosis)", shape=box, fillcolor="#BF360C", fontcolor=white]
        AbsArea   [label="↓ Absorption\nSurface Area", shape=box, fillcolor="#BF360C", fontcolor=white]
        EnterLoss [label="Enterocyte\nLoss / Apoptosis", shape=box, fillcolor="#FF6F00", fontcolor=white]
    }

    // ============================================================
    // CLUSTER 8: Malabsorption & Nutritional Deficiencies
    // ============================================================
    subgraph cluster_malabs {
        label="⑧ Malabsorption & Nutritional Deficiencies"
        style=filled; fillcolor="#EFEBE9"; color="#3E2723"
        fontcolor="#3E2723"; fontsize=13; fontname="Helvetica-Bold"

        Iron_mal  [label="Iron\nMalabsorption\n(Duodenum)", shape=box, fillcolor="#6D4C41", fontcolor=white]
        Ca_mal    [label="Calcium / Vit D\nMalabsorption", shape=box, fillcolor="#6D4C41", fontcolor=white]
        Fol_mal   [label="Folate / B12\nMalabsorption", shape=box, fillcolor="#6D4C41", fontcolor=white]
        FatVit    [label="Fat-Soluble Vit\n(A,D,E,K) Deficiency", shape=box, fillcolor="#795548", fontcolor=white]
        Prot_mal  [label="Protein\nMalabsorption", shape=box, fillcolor="#795548", fontcolor=white]
        IDA       [label="Iron Deficiency\nAnemia (↓Hgb, ↓Ferritin)", shape=box, fillcolor="#4E342E", fontcolor=white]
        Megalo    [label="Megaloblastic\nAnemia (↑MCV)", shape=box, fillcolor="#4E342E", fontcolor=white]
        Osteo_cd  [label="Osteopenia /\nOsteoporosis (↓BMD)", shape=box, fillcolor="#4E342E", fontcolor=white]
        Hypoalb   [label="Hypoalbuminemia\n(Edema, Ascites)", shape=box, fillcolor="#5D4037", fontcolor=white]
        Steat     [label="Steatorrhea\n(Fat malabsorption)", shape=box, fillcolor="#795548", fontcolor=white]
        Diarrhea  [label="Chronic\nDiarrhea", shape=box, fillcolor="#6D4C41", fontcolor=white]
        Bloating  [label="Bloating &\nAbdominal Pain", shape=box, fillcolor="#795548", fontcolor=white]
        Wasting   [label="Weight Loss /\nFailure to Thrive", shape=box, fillcolor="#4E342E", fontcolor=white]
    }

    // ============================================================
    // CLUSTER 9: Systemic Complications & Associated Conditions
    // ============================================================
    subgraph cluster_complications {
        label="⑨ Systemic Complications & Associated Conditions"
        style=filled; fillcolor="#E1F5FE"; color="#01579B"
        fontcolor="#01579B"; fontsize=13; fontname="Helvetica-Bold"

        DerHerp   [label="Dermatitis Herpetiformis\n(IgA skin deposits)", shape=box, fillcolor="#0277BD", fontcolor=white]
        GluNeur   [label="Gluten Neuropathy\n& Cerebellar Ataxia", shape=box, fillcolor="#0288D1", fontcolor=white]
        Infert    [label="Infertility\n(Male & Female)", shape=box, fillcolor="#039BE5"]
        EATL      [label="Enteropathy-Associated\nT-cell Lymphoma (EATL)", shape=box, fillcolor="#01579B", fontcolor=white]
        RCD_I     [label="Refractory Celiac\nDisease Type I (RCD-I)", shape=box, fillcolor="#0277BD", fontcolor=white]
        RCD_II    [label="Refractory Celiac\nDisease Type II (RCD-II)", shape=box, fillcolor="#01579B", fontcolor=white]
        T1DM_as   [label="Type 1 Diabetes\n(Shared HLA-DQ2/DQ8)", shape=box, fillcolor="#29B6F6"]
        AITD_as   [label="Autoimmune Thyroid\nDisease (Hashimoto/Graves)", shape=box, fillcolor="#29B6F6"]
        Down_s    [label="Down Syndrome\n(↑Risk 5–10%)", shape=box, fillcolor="#4FC3F7"]
        Turner_s  [label="Turner Syndrome\n(↑Risk ~6%)", shape=box, fillcolor="#4FC3F7"]
        GrowFail  [label="Growth Failure\n(Children)", shape=box, fillcolor="#0288D1", fontcolor=white]
        DepAnx    [label="Depression &\nAnxiety", shape=box, fillcolor="#4FC3F7"]
        HepaSteat [label="Hepatic Steatosis\n(elevated LFTs)", shape=box, fillcolor="#29B6F6"]
    }

    // ============================================================
    // CLUSTER 10: Drug Treatments & PK/PD
    // ============================================================
    subgraph cluster_drugs {
        label="⑩ Drug Treatments & Pharmacological Interventions"
        style=filled; fillcolor="#F9FBE7"; color="#33691E"
        fontcolor="#33691E"; fontsize=13; fontname="Helvetica-Bold"

        GFD       [label="Gluten-Free Diet\n(GFD — Standard Care)", shape=box, fillcolor="#8BC34A", fontcolor=white]
        Larazotide[label="Larazotide Acetate\n(AT-1001) — Zonulin inhib\nPhase III", shape=box, fillcolor="#689F38", fontcolor=white]
        ALV003    [label="Latiglutenase\n(ALV003 / IMGX003)\nGluten-digesting enzyme", shape=box, fillcolor="#558B2F", fontcolor=white]
        TIMPGLIA  [label="TIMP-GLIA\n(Nanoparticle tolerogen)\nAntigen-specific tolerance", shape=box, fillcolor="#33691E", fontcolor=white]
        Nexvax2   [label="Nexvax2\n(Tolerogenic peptide vaccine)\nPhase II", shape=box, fillcolor="#689F38", fontcolor=white]
        AMG714    [label="AMG 714\n(Anti-IL-15 mAb)\nRCD treatment", shape=box, fillcolor="#33691E", fontcolor=white]
        ZED1227   [label="ZED1227\n(TG2 inhibitor)\nPhase II", shape=box, fillcolor="#558B2F", fontcolor=white]
        TAK101    [label="TAK-101\n(Gluten nanoparticles)\nTolerogenic", shape=box, fillcolor="#689F38", fontcolor=white]
        Budesonide[label="Budesonide\n(Refractory CD)", shape=box, fillcolor="#7CB342"]
        Azathio   [label="Azathioprine\n(Refractory CD)", shape=box, fillcolor="#9CCC65"]
        Prednisol [label="Prednisolone\n(Refractory / RCD-I)", shape=box, fillcolor="#9CCC65"]
        Bortezomib[label="Bortezomib\n(RCD-II / EATL)", shape=box, fillcolor="#AFB42B"]
        Cladribine[label="Cladribine\n(RCD-II)", shape=box, fillcolor="#C0CA33"]

        // PK compartments
        DrugGut   [label="Drug: GI Compartment\n(Cmax_gut)", shape=box, fillcolor="#F0F4C3"]
        DrugPlasma[label="Drug: Plasma\nConcentration Cp", shape=box, fillcolor="#DCE775"]
        DrugDist  [label="Drug: Tissue\nDistribution (Vd)", shape=diamond, fillcolor="#F9FBE7"]
        DrugCL    [label="Drug: Hepatic\nMetabolism (CLH)", shape=diamond, fillcolor="#F9FBE7"]
        DrugRen   [label="Drug: Renal\nElimination (CLR)", shape=diamond, fillcolor="#F9FBE7"]
        PD_effect [label="PD Effect\n(EC50 model)", shape=diamond, fillcolor="#F9FBE7"]
    }

    // ============================================================
    // EDGES — Genetic/Environmental
    // ============================================================
    Gluten_in -> W_gliadin
    Gluten_in -> W_glutenin
    Gluten_in -> B_hordein
    Gluten_in -> R_secalin
    W_gliadin -> PartDig
    W_glutenin -> PartDig
    B_hordein -> PartDig
    R_secalin -> PartDig
    PartDig -> Gliadin_P
    EarlyExp -> Microbiome [label="timing effect"]
    BreastFeed -> SIgA [label="promotes", color="#4CAF50"]
    Rotavirus -> Microbiome [label="dysbiosis", color="#F44336"]
    Rotavirus -> IEL_CD8 [label="molecular mimicry"]

    // ============================================================
    // EDGES — Gluten Processing
    // ============================================================
    Gliadin_P -> IP_index [label="p31-43 direct\nstress", color="#FF6F00"]
    Gliadin_P -> tTG2 [label="substrate"]
    Gliadin_P -> IL15_epi [label="p31-43 induces"]
    TGFb_Tr -> tTG2 [label="activates (Ca2+\ndependent)", color="#FF9800"]
    IFNg_tTG -> tTG2 [label="upregulates\nexpression"]
    tTG2 -> Deamid [label="catalyzes"]
    Deamid -> DGP
    DGP -> HLA_DQ2 [label="high-affinity\nbinding", color="#4CAF50"]
    DGP -> HLA_DQ8 [label="high-affinity\nbinding", color="#4CAF50"]
    AntiTTG_A -> tTG2 [label="inhibits\n(feedback)", color="#F44336", style=dashed]

    // ============================================================
    // EDGES — Barrier Dysfunction
    // ============================================================
    IL15_epi -> Zonulin [label="induces"]
    Gliadin_P -> Zonulin [label="p31-43\nstimulates"]
    Zonulin -> TJ_claudin [label="disrupts", color="#F44336"]
    TJ_claudin -> IP_index [label="determines"]
    MLCK_path -> TJ_claudin [label="phosphorylates\n(disrupts)", color="#F44336"]
    IFNg_T -> MLCK_path [label="activates"]
    IP_index -> Para_trans
    IP_index -> Retro_tc
    Para_trans -> DGP [label="LP access"]
    Retro_tc -> Gliadin_P [label="SIgA-bound\npeptides"]
    SIgA -> Gliadin_P [label="traps, limits", color="#4CAF50"]
    Gliadin_P -> Entero_str [label="oxidative stress"]
    Entero_str -> MICA_MICB [label="upregulates"]
    MICA_MICB -> NKG2D_R [label="ligand for"]
    IFNg_T -> Ep_apopt [label="induces"]
    TNFa_T -> Ep_apopt [label="induces"]

    // ============================================================
    // EDGES — Innate Immunity
    // ============================================================
    IL15_epi -> NK_cells [label="activates"]
    IL15_epi -> IEL_CD8 [label="survival /\nexpansion"]
    IL15_epi -> DC_CD103 [label="maturation"]
    IL15_epi -> NLRP3 [label="primes"]
    NKG2D_R -> IEL_act [label="activates via"]
    NK_cells -> NKG2D_R [label="express"]
    IEL_CD8 -> NKG2D_R [label="express"]
    IEL_act -> Ep_apopt [label="cytotoxic\nkilling"]
    IEL_act -> EnterLoss [label="causes"]
    DC_CD103 -> CD4T [label="antigen\npresentation"]
    Macro_M1 -> TNFa_inn
    Macro_M1 -> IL1b_inn
    Macro_M1 -> IL6_inn
    TNFa_inn -> MMP_mat [label="upregulates"]
    IL1b_inn -> NLRP3 [label="amplifies"]
    NLRP3 -> IL1b_inn [label="processes"]
    IL6_inn -> Th17_cell [label="promotes\ndifferentiation"]
    MMP_mat -> VillAtrop [label="matrix\ndegradation"]
    MMP_mat -> TJ_claudin [label="degrades\nclaudin", color="#F44336"]
    IC_depos -> Complement [label="activates"]

    // ============================================================
    // EDGES — Adaptive T Cell
    // ============================================================
    HLA_DQ2 -> TCR_MHC [label="presents DGP"]
    HLA_DQ8 -> TCR_MHC [label="presents DGP"]
    IL2gene -> CD4T [label="enhanced\nproliferation"]
    TCR_MHC -> CD4T [label="activates"]
    CD4T -> Th1_cell [label="Th1 skew\n(IL-12/IL-18)"]
    CD4T -> Th2_cell [label="Th2 skew\n(IL-4)"]
    CD4T -> Th17_cell [label="Th17 skew\n(TGF-β+IL-6)"]
    CD4T -> Treg_cell [label="Treg induction\n(TGF-β + CTLA4)"]
    CTLA4gene -> Treg_cell [label="enhances\nsuppression"]
    Th1_cell -> IFNg_T
    Th1_cell -> TNFa_T
    Th2_cell -> IL4_T
    Th2_cell -> IL5_T
    Th2_cell -> IL13_T
    Th17_cell -> IL17A_T
    Th17_cell -> IL21_T
    Th17_cell -> IL22_T
    Treg_cell -> IL10_Tr
    Treg_cell -> TGFb_Tr
    Treg_cell -> CTLA4_Tr
    IL10_Tr -> Th1_cell [label="inhibits", color="#F44336", style=dashed]
    IL10_Tr -> Macro_M1 [label="inhibits", color="#F44336", style=dashed]
    TGFb_Tr -> Th17_cell [label="promotes in\nIL-6 context", color="#FF9800"]
    TGFb_Tr -> tTG2 [label="activates", color="#FF9800"]
    IL21_T -> Bcell_LP [label="B cell help"]
    IL21_T -> IL15_epi [label="amplifies loop", color="#FF9800"]
    IFNg_T -> IFNg_tTG
    IFNg_T -> VillAtrop [label="promotes"]
    IFNg_T -> CryptHyp [label="induces"]
    TNFa_T -> VillAtrop [label="promotes"]
    IL22_T -> CryptHyp [label="crypt cell\nproliferation"]
    IL13_T -> TJ_claudin [label="disrupts\nclaudin-2", color="#F44336"]
    PD1_path -> CD4T [label="T cell\nexhaustion?", style=dashed]

    // ============================================================
    // EDGES — B Cells & Serology
    // ============================================================
    DGP -> Bcell_LP [label="B cell antigen"]
    CD4T -> Bcell_LP [label="T cell help\n(cognate)"]
    IL21_T -> GC_react [label="drives"]
    Tfh_help -> GC_react [label="provides help"]
    Tfh_help -> Bcell_LP
    GC_react -> Plasma_LP [label="affinity\nmaturation"]
    Bcell_LP -> Plasma_LP [label="differentiates"]
    Plasma_LP -> AntiTTG_A
    Plasma_LP -> AntiDGP_G
    Plasma_LP -> AGA_ab
    Plasma_LP -> EMA_ab
    AntiTTG_A -> IC_depos [label="forms"]
    IC_depos -> Complement
    IgA_def -> AntiTTG_A [label="↓ serology\n(false neg)", color="#F44336", style=dashed]

    // ============================================================
    // EDGES — Histopathology
    // ============================================================
    IEL_CD8 -> IEL_count
    IEL_count -> Marsh1
    Marsh1 -> Marsh2 [label="progression"]
    Marsh2 -> Marsh3a [label="progression"]
    Marsh3a -> Marsh3b [label="progression"]
    Marsh3b -> Marsh3c [label="progression"]
    Marsh3a -> VillAtrop
    Marsh3b -> VillAtrop
    Marsh3c -> VillAtrop
    CryptHyp -> Marsh2
    IL15_epi -> CryptHyp [label="stem cell\nproliferation"]
    VillAtrop -> AbsArea [label="reduces"]
    CryptHyp -> IEL_count [label="dilution\neffect"]
    Ep_apopt -> EnterLoss
    EnterLoss -> VillAtrop

    // ============================================================
    // EDGES — Malabsorption
    // ============================================================
    AbsArea -> Iron_mal [label="duodenum\ncritical"]
    AbsArea -> Ca_mal
    AbsArea -> Fol_mal
    AbsArea -> FatVit
    AbsArea -> Prot_mal
    AbsArea -> Diarrhea [label="osmotic"]
    AbsArea -> Bloating
    AbsArea -> Steat
    Iron_mal -> IDA
    Fol_mal -> Megalo
    Ca_mal -> Osteo_cd
    Prot_mal -> Hypoalb
    IDA -> Wasting
    Hypoalb -> Wasting
    IDA -> GrowFail [label="children"]
    Ca_mal -> GrowFail [label="children"]
    Osteo_cd -> Infert [label="indirect"]

    // ============================================================
    // EDGES — Complications
    // ============================================================
    AntiTTG_A -> DerHerp [label="IgA deposits\nin dermis"]
    IFNg_T -> GluNeur [label="anti-ganglioside\nAbs?"]
    GluNeur -> Infert [label="autonomic\nneuropathy"]
    Marsh3c -> RCD_I [label="GFD\nnon-responsive"]
    RCD_I -> RCD_II [label="clonal IEL\nexpansion"]
    RCD_II -> EATL [label="malignant\ntransformation"]
    HLA_DQ2 -> T1DM_as [label="shared HLA\nrisk"]
    HLA_DQ2 -> AITD_as [label="autoimmune\noverlap"]
    AbsArea -> HepaSteat [label="portal\nendotoxemia"]
    Microbiome -> HepaSteat [label="dysbiosis"]
    IL15_epi -> DepAnx [label="neuroinflam\n(indirect)"]
    Diarrhea -> DepAnx [label="QoL impact"]

    // ============================================================
    // EDGES — Drug Mechanisms (PK/PD)
    // ============================================================
    GFD -> Gliadin_P [label="removes source", color="#1565C0", style=bold, penwidth=2.5]
    GFD -> W_gliadin [label="eliminates", color="#1565C0", style=bold, penwidth=2.5]

    Larazotide -> Zonulin [label="antagonizes\n(tight junction)", color="#0D47A1", style=bold, penwidth=2]
    Larazotide -> IP_index [label="↓ permeability\n(EC50 ~50 nM)", color="#0D47A1", style=bold, penwidth=2]

    ALV003 -> Gliadin_P [label="degrades\n(EP-B2 + SC-PEP)", color="#0D47A1", style=bold, penwidth=2]

    ZED1227 -> tTG2 [label="covalent inhibitor\n(EC50 ~5 μM)", color="#0D47A1", style=bold, penwidth=2]
    ZED1227 -> Deamid [label="reduces", color="#0D47A1", style=bold, penwidth=2]

    AMG714 -> IL15_epi [label="neutralizes\n(anti-IL-15 mAb)", color="#0D47A1", style=bold, penwidth=2]
    AMG714 -> IEL_CD8 [label="reduces\nsignaling", color="#0D47A1", style=bold, penwidth=2]

    TIMPGLIA -> CD4T [label="anergy\n(nanoparticle)", color="#0D47A1", style=bold, penwidth=2]
    TAK101 -> CD4T [label="tolerogenic\n(nanoparticle)", color="#0D47A1", style=bold, penwidth=2]
    Nexvax2 -> CD4T [label="immune\ntolerance", color="#0D47A1", style=bold, penwidth=2]

    Budesonide -> IFNg_T [label="suppresses", color="#0D47A1", style=bold, penwidth=2]
    Budesonide -> TNFa_T [label="suppresses", color="#0D47A1", style=bold, penwidth=2]
    Prednisol -> Th1_cell [label="suppresses", color="#0D47A1", style=bold, penwidth=2]
    Prednisol -> Macro_M1 [label="suppresses", color="#0D47A1", style=bold, penwidth=2]
    Azathio -> Bcell_LP [label="anti-metabolite", color="#0D47A1", style=bold, penwidth=2]
    Azathio -> CD4T [label="anti-metabolite", color="#0D47A1", style=bold, penwidth=2]
    Bortezomib -> Plasma_LP [label="plasma cell\napoptosis", color="#0D47A1", style=bold, penwidth=2]
    Cladribine -> IEL_CD8 [label="clonal IEL\ndepletion", color="#0D47A1", style=bold, penwidth=2]
    Cladribine -> RCD_II [label="treats", color="#0D47A1", style=bold, penwidth=2]

    // PK flow
    Larazotide -> DrugGut [label="oral 0.5–4 mg"]
    ZED1227 -> DrugGut [label="oral ~300 mg"]
    AMG714 -> DrugPlasma [label="sc/iv injection"]
    DrugGut -> DrugPlasma [label="ka (absorption)"]
    DrugPlasma -> DrugDist [label="Vd"]
    DrugDist -> DrugCL [label="hepatic"]
    DrugDist -> DrugRen [label="renal"]
    DrugPlasma -> PD_effect [label="Emax model\n(EC50-driven)"]
    PD_effect -> IP_index [label="Larazotide PD"]
    PD_effect -> tTG2 [label="ZED1227 PD"]
    PD_effect -> IL15_epi [label="AMG714 PD"]

    // ============================================================
    // Cross-cluster feedback loops (key)
    // ============================================================
    IL15_epi -> IL21_T [label="synergy\n(amplification loop)", color="#FF6F00", style=dashed]
    IL21_T -> IL15_epi [label="feedback\namplification", color="#FF6F00", style=dashed]
    Microbiome -> IL15_epi [label="dysbiosis\ndrives", color="#FF6F00"]
    SIgA -> Microbiome [label="regulates\ndiversity", color="#4CAF50"]
    PTPN22g -> CD4T [label="T cell\nhyperactivation"]
    RGS1g -> Bcell_LP [label="B cell\nmigration"]
    SH2B3g -> IEL_CD8 [label="IEL\nexpansion"]
}
