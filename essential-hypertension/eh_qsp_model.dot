digraph EssentialHypertension_QSP {
    graph [
        label="Essential Hypertension — Comprehensive QSP Model\nPathophysiology · Drug PK/PD · Clinical Endpoints",
        labelloc=t, fontsize=22, fontname="Helvetica-Bold",
        compound=true, rankdir=LR,
        splines=ortho, nodesep=0.35, ranksep=0.7,
        bgcolor="white", pad=0.5
    ];
    node [fontname="Helvetica", fontsize=9, style="filled,rounded", shape=box];
    edge [fontname="Helvetica", fontsize=8, arrowsize=0.7];

    /* =====================================================================
       CLUSTER 1 — Risk Factors & Epidemiology
    ===================================================================== */
    subgraph cluster_risk {
        label="Risk Factors"; style=filled; color="#FFF9C4";
        node [fillcolor="#FFF9C4"];
        RF_age      [label="Aging\n(vascular stiffening)"];
        RF_obesity  [label="Obesity\n(BMI ↑, adipose RAAS)"];
        RF_genetics [label="Genetic\nPolymorphisms\n(ACE I/D, AGT M235T)"];
        RF_salt     [label="High Salt\nIntake (Na+ excess)"];
        RF_sedent   [label="Sedentary\nLifestyle"];
        RF_stress   [label="Psychosocial\nStress"];
        RF_smoke    [label="Smoking\n(ROS↑, NO↓)"];
        RF_alcohol  [label="Alcohol\n(catecholamines↑)"];
        RF_apnea    [label="Sleep Apnea\n(intermittent hypoxia)"];
        RF_DM       [label="Diabetes\n(insulin resistance)"];
    }

    /* =====================================================================
       CLUSTER 2 — Renin-Angiotensin-Aldosterone System (RAAS)
    ===================================================================== */
    subgraph cluster_raas {
        label="RAAS (Renin-Angiotensin-Aldosterone System)"; style=filled; color="#BBDEFB";
        node [fillcolor="#BBDEFB"];
        AOGEN      [label="Angiotensinogen\n(liver synthesis)"];
        RENIN      [label="Renin\n(kidney JGA)"];
        ANG_I      [label="Angiotensin I\n(AngI, inactive)"];
        ACE_enz    [label="ACE\n(Angiotensin-\nConverting Enzyme)"];
        ANG_II     [label="Angiotensin II\n(AngII, vasoactive)"];
        AT1R       [label="AT1 Receptor\n(AngII-AT1R complex)"];
        AT2R       [label="AT2 Receptor\n(counter-regulatory)"];
        ANG_III    [label="Angiotensin III\n(AngIII)"];
        ANG_17     [label="Ang-(1-7)\n(vasodilatory)"];
        ACE2_enz   [label="ACE2\n(angiotensin\nconvertase)"];
        MAS_R      [label="Mas Receptor\n(Ang1-7 signaling)"];
        ALDO       [label="Aldosterone\n(adrenal cortex)"];
        MR         [label="Mineralocorticoid\nReceptor (MR)"];
        CHYMASE    [label="Chymase\n(ACE-independent\nAngII synthesis)"];
        NEPRILYSIN [label="Neprilysin (NEP)\n(angiotensin\ndegradation)"];
        PRORENIN   [label="Prorenin/\nProrenin Receptor\n(PRR)"];
        AGT_adipose [label="Adipose\nAngiotensinogen\n(obesity RAAS)"];
    }

    /* =====================================================================
       CLUSTER 3 — Sympathetic Nervous System
    ===================================================================== */
    subgraph cluster_sns {
        label="Sympathetic Nervous System (SNS)"; style=filled; color="#FFCDD2";
        node [fillcolor="#FFCDD2"];
        CNS_symp   [label="CNS Sympathetic\nCenter\n(RVLM, NTS)"];
        NE_release [label="Norepinephrine\nRelease (NE)"];
        EPI_adrenal [label="Epinephrine\n(adrenal medulla)"];
        ALPHA1R    [label="α1-Adrenoceptor\n(vascular SM)"];
        ALPHA2R    [label="α2-Adrenoceptor\n(presynaptic\nfeedback)"];
        BETA1R     [label="β1-Adrenoceptor\n(cardiac, JGA)"];
        BETA2R     [label="β2-Adrenoceptor\n(vasodilation,\nbronchodilation)"];
        BARO_rcpt  [label="Baroreceptors\n(aortic arch,\ncarotid sinus)"];
        RENAL_nerv [label="Renal Sympathetic\nNerves"];
        TH_enzyme  [label="Tyrosine\nHydroxylase (TH)\n(NE synthesis)"];
        COMT_MAO   [label="COMT/MAO\n(NE degradation)"];
        NPY        [label="Neuropeptide Y\n(NPY, co-released)"];
        BAROREFLEX [label="Baroreflex\nGain\n(sensitivity)"];
    }

    /* =====================================================================
       CLUSTER 4 — Endothelial Function & Vascular Biology
    ===================================================================== */
    subgraph cluster_endo {
        label="Endothelial Function & Vascular Biology"; style=filled; color="#C8E6C9";
        node [fillcolor="#C8E6C9"];
        eNOS       [label="eNOS\n(endothelial NOS)"];
        NO_mol     [label="Nitric Oxide\n(NO, vasodilator)"];
        sGC_enz    [label="sGC\n(soluble guanylyl\ncyclase)"];
        cGMP_mol   [label="cGMP\n(2nd messenger)"];
        PDE5_enz   [label="PDE5\n(cGMP\nphosphodiesterase)"];
        ET1        [label="Endothelin-1\n(ET-1, vasoconstrictor)"];
        ETA_R      [label="ETA Receptor\n(vasoconstriction)"];
        ETB_R      [label="ETB Receptor\n(NO release,\nclearance)"];
        PGI2       [label="Prostacyclin\n(PGI2, vasodilator)"];
        TXA2       [label="Thromboxane A2\n(TXA2,\nvasoconstrictor)"];
        COX1_enz   [label="COX-1\n(constitutive)"];
        COX2_enz   [label="COX-2\n(inducible,\ninflammation)"];
        BRAD_kinin [label="Bradykinin\n(vasodilator)"];
        BK_B2R     [label="Bradykinin B2\nReceptor"];
        iNOS_enz   [label="iNOS\n(inflammatory\nNO, high flux)"];
        ROS_mol    [label="Reactive Oxygen\nSpecies (ROS)"];
        OxStress   [label="Oxidative\nStress"];
        NADPH_ox   [label="NADPH Oxidase\n(Nox1/Nox2)"];
        ONOO       [label="Peroxynitrite\n(ONOO−, cytotoxic)"];
        TETRABIOP  [label="BH4\n(eNOS cofactor,\noxidized→BH2)"];
    }

    /* =====================================================================
       CLUSTER 5 — Renal Mechanisms
    ===================================================================== */
    subgraph cluster_kidney {
        label="Renal Mechanisms & Tubular Transport"; style=filled; color="#B2EBF2";
        node [fillcolor="#B2EBF2"];
        GFR        [label="GFR\n(glomerular\nfiltration rate)"];
        PCT_seg    [label="Proximal Convoluted\nTubule (PCT)\n60–70% Na reabs."];
        LOH_seg    [label="Loop of\nHenle (LOH)\n25% Na reabs."];
        DCT_seg    [label="Distal Convoluted\nTubule (DCT)\n5–8% Na reabs."];
        CD_seg     [label="Collecting\nDuct (CD)\n2–3% Na reabs."];
        ENaC_ch    [label="ENaC\n(Epithelial Na+\nChannel, CD)"];
        NHE3_tr    [label="NHE3\n(Na+-H+ Exchanger,\nPCT)"];
        NKCC2_tr   [label="NKCC2\n(Na-K-2Cl,\nLOH, TAL)"];
        NCC_tr     [label="NCC\n(Na-Cl Cotransporter,\nDCT, thiazide target)"];
        AQP2_ch    [label="Aquaporin-2\n(AQP2, water\nchannel, CD)"];
        ADH_vp     [label="ADH/Vasopressin\n(V2 receptor,\nAQP2↑)"];
        JGA_app    [label="Juxtaglomerular\nApparatus (JGA)"];
        MACULA_D   [label="Macula Densa\n(NaCl sensing,\nrenin release)"];
        PLASMA_V   [label="Plasma Volume\n(effective circulating\nvolume)"];
        NA_balance [label="Na+ Balance\n(intake − excretion)"];
        SGLT2_tr   [label="SGLT2\n(glucose-Na\ncotransporter)"];
        ANP_kidney [label="ANP Effect\non Kidney\n(natriuresis↑)"];
    }

    /* =====================================================================
       CLUSTER 6 — Cardiac Function
    ===================================================================== */
    subgraph cluster_cardiac {
        label="Cardiac Function & Remodeling"; style=filled; color="#F8BBD9";
        node [fillcolor="#F8BBD9"];
        HR_bpm     [label="Heart Rate\n(HR, bpm)"];
        SV_ml      [label="Stroke Volume\n(SV, mL)"];
        CO_lmin    [label="Cardiac Output\n(CO = HR × SV,\nL/min)"];
        PRELOAD    [label="Preload\n(EDV, venous return)"];
        AFTERLOAD  [label="Afterload\n(TPR, aortic\npressure)"];
        CONTRACT   [label="Contractility\n(Frank-Starling,\ninotropy)"];
        LVEDP      [label="LVEDP\n(LV end-diastolic\npressure)"];
        LV_MASS    [label="LV Mass\n(hypertrophy index)"];
        ANP_mol    [label="ANP\n(Atrial Natriuretic\nPeptide)"];
        BNP_mol    [label="BNP/NT-proBNP\n(cardiac stress\nbiomarker)"];
        NPRA_r     [label="NPR-A Receptor\n(cGMP→\nnatriuresis)"];
        L_VGCC     [label="L-type VGCC\n(Ca2+ channel,\nheart & vessels)"];
        CA_cyto    [label="Intracellular\nCa2+ ([Ca2+]i)"];
        MYOSIN     [label="Myosin ATPase\n(cross-bridge\ncycling)"];
        CAMP_cAR   [label="cAMP / PKA\n(β1-AR→AC→cAMP)"];
        FIBROSIS_C [label="Cardiac\nFibrosis\n(collagen↑)"];
    }

    /* =====================================================================
       CLUSTER 7 — Vascular Remodeling & Hemodynamics
    ===================================================================== */
    subgraph cluster_vascular {
        label="Vascular Remodeling & Hemodynamics"; style=filled; color="#FFF3E0";
        node [fillcolor="#FFF3E0"];
        TPR_val    [label="Total Peripheral\nResistance (TPR)"];
        VSM_TONE   [label="Vascular Smooth\nMuscle Tone\n(acute regulation)"];
        VSM_PROLIF [label="VSM Cell\nProliferation\n(structural)"];
        ECM_rmdl   [label="ECM Remodeling\n(structural changes)"];
        COLLAGEN   [label="Collagen\nDeposition\n(fibrosis)"];
        IMT        [label="Intima-Media\nThickness (IMT)"];
        ART_STIFF  [label="Arterial\nStiffness\n(wall elastic modulus)"];
        PWV        [label="Pulse Wave\nVelocity (PWV)\n(aortic stiffness)"];
        TGF_B      [label="TGF-β1\n(fibrotic, pro-\nremodeling)"];
        MMP_enz    [label="MMPs\n(matrix\nmetalloproteinases)"];
        PDGF_gf    [label="PDGF\n(platelet-derived\ngrowth factor)"];
        FGF_gf     [label="FGF\n(fibroblast\ngrowth factor)"];
        MAPK_path  [label="MAPK/ERK1-2\n(proliferation\nsignaling)"];
        PKC_enz    [label="PKC\n(protein kinase C)"];
        ROCK_enz   [label="ROCK\n(Rho kinase,\nCa2+ sensitization)"];
        IP3_DAG    [label="IP3/DAG\n(Gq signaling)"];
        IL6_vasc   [label="IL-6\n(vascular\ninflammation)"];
        CRP_prot   [label="hsCRP\n(systemic\ninflammation)"];
    }

    /* =====================================================================
       CLUSTER 8 — Inflammation & Immune Activation
    ===================================================================== */
    subgraph cluster_inflam {
        label="Inflammation & Immune Activation"; style=filled; color="#EDE7F6";
        node [fillcolor="#EDE7F6"];
        NLRP3      [label="NLRP3\nInflammasome"];
        IL1B       [label="IL-1β\n(pro-inflammatory)"];
        TNF_a      [label="TNF-α\n(endothelial\nactivation)"];
        IL6        [label="IL-6\n(systemic\ninflammation)"];
        ICAM1      [label="ICAM-1\n(monocyte\nadhesion)"];
        VCAM1      [label="VCAM-1\n(leukocyte\nadhesion)"];
        MAC_infilt [label="Macrophage\nInfiltration\n(vascular wall)"];
        OXLDL      [label="Oxidized LDL\n(foam cell\nformation)"];
        NFKB_path  [label="NF-κB\nPathway\n(inflammatory gene↑)"];
        FOAM_cell  [label="Foam Cells\n(early\natherosclerosis)"];
    }

    /* =====================================================================
       CLUSTER 9 — Drug PK/PD (5 drug classes)
    ===================================================================== */
    subgraph cluster_drugs {
        label="Drug PK/PD — 5 Antihypertensive Classes"; style=filled; color="#E8EAF6";
        node [fillcolor="#E8EAF6"];

        /* ACE Inhibitor — Ramipril */
        RAMP_gut   [label="Ramipril\n(oral dose, GI)"];
        RAMP_C     [label="Ramiprilat\n(active, central Vc)"];
        RAMP_P     [label="Ramiprilat\n(peripheral Vp)"];
        RAMP_ACE   [label="ACE-Ramiprilat\nComplex\n(% inhibition)"];

        /* ARB — Losartan/EXP3174 */
        LOS_gut    [label="Losartan\n(oral dose, GI)"];
        LOS_C      [label="EXP3174\n(active metabolite,\ncentral Vc)"];
        LOS_P      [label="EXP3174\n(peripheral Vp)"];
        AT1R_occ   [label="AT1R Occupancy\nby EXP3174\n(% blocked)"];

        /* CCB — Amlodipine */
        AML_gut    [label="Amlodipine\n(oral dose, GI)"];
        AML_C      [label="Amlodipine\n(central Vc)"];
        AML_P      [label="Amlodipine\n(peripheral Vp)"];
        VGCC_blk   [label="L-VGCC\nBlockade\n(fractional block)"];

        /* Beta-blocker — Bisoprolol */
        BIS_gut    [label="Bisoprolol\n(oral dose, GI)"];
        BIS_C      [label="Bisoprolol\n(central Vc)"];
        BIS_P      [label="Bisoprolol\n(peripheral Vp)"];
        BETA1_blk  [label="β1-AR\nBlockade\n(fractional block)"];

        /* Thiazide Diuretic — Hydrochlorothiazide (HCTZ) */
        HCTZ_gut   [label="HCTZ\n(oral dose, GI)"];
        HCTZ_C     [label="HCTZ\n(central Vc)"];
        NCC_inhib  [label="NCC Inhibition\n(DCT Na-Cl\ntransport block)"];
    }

    /* =====================================================================
       CLUSTER 10 — Clinical Endpoints & Biomarkers
    ===================================================================== */
    subgraph cluster_endpoints {
        label="Clinical Endpoints & Biomarkers"; style=filled; color="#FAFAFA";
        node [fillcolor="#FFF176", shape=hexagon];
        SBP_ep   [label="Systolic BP\n(SBP, mmHg)"];
        DBP_ep   [label="Diastolic BP\n(DBP, mmHg)"];
        MAP_ep   [label="Mean Arterial\nPressure (MAP)"];
        PP_ep    [label="Pulse Pressure\n(PP = SBP−DBP)"];

        node [fillcolor="#FFAB91", shape=hexagon];
        LVH_ep   [label="LV Hypertrophy\n(Echo LV mass index)"];
        CKD_ep   [label="CKD Progression\n(proteinuria, eGFR↓)"];
        STROKE_r [label="Stroke Risk\n(cerebrovascular)"];
        MI_r     [label="MI Risk\n(coronary events)"];
        HF_r     [label="Heart Failure\nRisk"];
        RETINO   [label="Hypertensive\nRetinopathy"];

        node [fillcolor="#B0BEC5", shape=diamond];
        PRA_bm   [label="Plasma Renin\nActivity (PRA)"];
        SALDO_bm [label="Serum\nAldosterone"];
        BNP_bm   [label="Plasma BNP\n(pg/mL)"];
        UACR_bm  [label="UACR\n(albumin-creatinine\nratio)"];
        SCr_bm   [label="Serum\nCreatinine"];
        UNa_bm   [label="Urinary Na+\nExcretion\n(mmol/24h)"];
        SCORE_bm [label="ESH/ESC\nSCORE Risk"];
        FRMHM_bm [label="Framingham\nRisk Score"];
    }

    /* ===================================================================
       EDGES — Risk Factors → Pathways
    =================================================================== */
    RF_salt    -> NA_balance  [label="↑Na+ intake"];
    RF_obesity -> AGT_adipose [label="adipokines↑\nangiotensinogen"];
    RF_obesity -> NE_release  [label="↑SNS\nactivation"];
    RF_obesity -> IL6         [label="adipose\ninflammation"];
    RF_stress  -> CNS_symp    [label="cortical\nactivation"];
    RF_genetics-> RENIN       [label="ACE I/D,\nAGT M235T"];
    RF_apnea   -> CNS_symp    [label="hypoxia→\nSNS↑"];
    RF_alcohol -> NE_release  [label="catecholamines↑"];
    RF_smoke   -> ROS_mol     [label="oxidative\nstress↑"];
    RF_smoke   -> NFKB_path   [label="inflammatory\nactivation"];
    RF_age     -> ART_STIFF   [label="elastin\nfragmentation"];
    RF_age     -> RENIN       [label="nephron loss\n→ renin↑"];
    RF_DM      -> NADPH_ox    [label="hyperglycemia\nROS↑"];
    RF_DM      -> ANG_II      [label="insulin\nresistance↑RAAS"];

    /* ===================================================================
       EDGES — RAAS Cascade
    =================================================================== */
    AOGEN      -> ANG_I    [label="cleaved by renin"];
    RENIN      -> ANG_I    [label="catalysis\n(rate-limiting)"];
    PRORENIN   -> RENIN    [label="activation"];
    AGT_adipose-> ANG_II   [label="local RAAS\n(adipose tissue)"];
    ANG_I      -> ANG_II   [label="ACE\nconversion"];
    ANG_I      -> ANG_17   [label="ACE2 / NEP\nconversion"];
    CHYMASE    -> ANG_II   [label="ACE-bypass\n(heart, vessel)"];
    ACE_enz    -> ANG_II   [label="catalyzes"];
    ACE2_enz   -> ANG_17   [label="AngII → Ang(1-7)"];
    NEPRILYSIN -> ANG_I    [label="degradation"];
    ANG_II     -> AT1R     [label="binding\n(high affinity)"];
    ANG_II     -> AT2R     [label="binding\n(counter-reg)"];
    ANG_II     -> ANG_III  [label="aminopeptidase A"];
    ANG_II     -> ANG_17   [label="ACE2"];
    ANG_17     -> MAS_R    [label="binding\n→vasodilation"];
    AT1R       -> ALDO     [label="adrenal\nstimulation"];
    AT1R       -> NE_release[label="facilitates\nsynaptic NE"];
    AT1R       -> NA_balance[label="↑proximal\nNa reabs."];
    AT1R       -> VSM_TONE [label="Gq→IP3→Ca2+\nvasoconstriction"];
    AT1R       -> ROS_mol  [label="↑NADPH\noxidase"];
    AT1R       -> TGF_B    [label="fibrotic\ncytokine"];
    AT1R       -> MAPK_path[label="ERK1/2\nproliferation"];
    AT1R       -> NLRP3    [label="inflammasome\nactivation"];
    AT2R       -> NO_mol   [label="counter-reg\n↑NO"];
    MAS_R      -> NO_mol   [label="eNOS\nactivation"];
    ALDO       -> MR       [label="binding"];
    MR         -> ENaC_ch  [label="↑ENaC\nexpression"];
    MR         -> NCC_tr   [label="↑NCC\nactivity"];
    MR         -> COLLAGEN [label="cardiac/renal\nfibrosis"];
    MR         -> FIBROSIS_C[label="cardiac\nfibrosis"];
    JGA_app    -> RENIN    [label="release\n(low BP→↑renin)"];
    MACULA_D   -> JGA_app  [label="TGF mechanism\n(low Na→↑renin)"];
    RENAL_nerv -> RENIN    [label="β1→↑renin\nsecretion"];
    RENAL_nerv -> NA_balance[label="↑tubular\nreabsorption"];

    /* ===================================================================
       EDGES — SNS Cascade
    =================================================================== */
    CNS_symp   -> NE_release  [label="preganglionic\nnerve firing"];
    CNS_symp   -> EPI_adrenal [label="adrenal medulla\nstimulation"];
    NE_release -> ALPHA1R     [label="binding\n(Gq)"];
    NE_release -> ALPHA2R     [label="presynaptic\nautoreceptor"];
    NE_release -> BETA1R      [label="cardiac/JGA\n(Gs)"];
    NE_release -> RENAL_nerv  [label="renal\nsympathetic"];
    EPI_adrenal-> BETA2R      [label="vasodilatory\n(muscle)"];
    ALPHA1R    -> IP3_DAG     [label="Gq → PLC\nactivation"];
    ALPHA1R    -> VSM_TONE    [label="vasoconstriction\n(IP3→Ca2+)"];
    ALPHA2R    -> NE_release  [label="negative\nfeedback ⊣", style=dashed, color=red];
    BETA1R     -> HR_bpm      [label="chronotropy↑\n(SA node)"];
    BETA1R     -> CONTRACT    [label="inotropy↑\n(PKA)"];
    BETA1R     -> RENIN       [label="β1-Gs→\nrenin↑"];
    BETA1R     -> CAMP_cAR    [label="Gs→AC→cAMP\n(PKA activation)"];
    BARO_rcpt  -> BAROREFLEX  [label="arterial wall\nstretch"];
    BAROREFLEX -> CNS_symp    [label="inhibitory\nreflex ⊣", style=dashed, color=red];
    MAP_ep     -> BARO_rcpt   [label="pressure\nsensing"];
    TH_enzyme  -> NE_release  [label="tyrosine→\nDOPA→NE"];
    COMT_MAO   -> NE_release  [label="degradation ⊣", style=dashed, color=red];
    NPY        -> VSM_TONE    [label="Y1 receptor\nvasoconstriction"];

    /* ===================================================================
       EDGES — Endothelial / Vascular Biology
    =================================================================== */
    eNOS       -> NO_mol   [label="L-Arg + O2\n→ NO + citrulline"];
    TETRABIOP  -> eNOS     [label="BH4 cofactor\n(uncoupling→ROS\nif BH4→BH2)"];
    OxStress   -> TETRABIOP[label="BH4\noxidation→BH2"];
    BRAD_kinin -> BK_B2R   [label="binding"];
    BK_B2R     -> eNOS     [label="↑Ca2+→eNOS\nactivation"];
    ACE_enz    -> BRAD_kinin[label="kininase II\n(inactivation)", style=dashed, color=red];
    NO_mol     -> sGC_enz  [label="activates\nheme Fe2+"];
    sGC_enz    -> cGMP_mol [label="GTP→cGMP"];
    cGMP_mol   -> VSM_TONE [label="PKG→\nMLC phosphatase"];
    PDE5_enz   -> cGMP_mol [label="hydrolyzes ⊣", style=dashed, color=red];
    ET1        -> ETA_R    [label="vasoconstriction"];
    ET1        -> ETB_R    [label="NO release,\nET clearance"];
    ETA_R      -> VSM_TONE [label="Gq→IP3→Ca2+"];
    ETB_R      -> eNOS     [label="↑NO\n(counter-reg)"];
    COX1_enz   -> PGI2     [label="AA→PGI2"];
    COX1_enz   -> TXA2     [label="AA→TXA2"];
    PGI2       -> VSM_TONE [label="IP receptor\nvasodilation ⊣", style=dashed, color=red];
    TXA2       -> VSM_TONE [label="TP receptor\nvasoconstriction"];
    NADPH_ox   -> ROS_mol  [label="superoxide (O2•−)\nproduction"];
    ROS_mol    -> NO_mol   [label="quenching\n(→ONOO−) ⊣", style=dashed, color=red];
    ROS_mol    -> ONOO     [label="+ NO\n→peroxynitrite"];
    ROS_mol    -> OxStress [label="cumulative\neffect"];
    ROS_mol    -> NFKB_path[label="oxidative\nactivation"];
    AT1R       -> NADPH_ox [label="Nox1/Nox2\nactivation"];
    NFKB_path  -> ET1      [label="↑ET-1\ngene expression"];
    NFKB_path  -> ICAM1    [label="↑ICAM-1"];
    NFKB_path  -> VCAM1    [label="↑VCAM-1"];
    iNOS_enz   -> NO_mol   [label="large flux\n(inflammatory NO)"];

    /* ===================================================================
       EDGES — Kidney/Tubular Transport
    =================================================================== */
    GFR        -> PCT_seg  [label="filtered Na+ load"];
    PCT_seg    -> NHE3_tr  [label="NHE3-mediated\nreabsorption"];
    NHE3_tr    -> NA_balance[label="60-70% reabs"];
    LOH_seg    -> NKCC2_tr [label="NKCC2-mediated\nreabsorption"];
    NKCC2_tr   -> NA_balance[label="25% reabs"];
    DCT_seg    -> NCC_tr   [label="NCC-mediated\nreabsorption"];
    NCC_tr     -> NA_balance[label="5-8% reabs"];
    CD_seg     -> ENaC_ch  [label="ENaC-mediated\nfine-tuning"];
    ENaC_ch    -> NA_balance[label="2-3% reabs"];
    NA_balance -> PLASMA_V [label="osmotic volume\nregulation"];
    PLASMA_V   -> PRELOAD  [label="venous return\n(Frank-Starling)"];
    ADH_vp     -> AQP2_ch  [label="V2 receptor→\ncAMP→AQP2 exo"];
    AQP2_ch    -> PLASMA_V [label="water\nreabsorption↑"];
    AT1R       -> ADH_vp   [label="posterior\npituitary stim."];
    NPRA_r     -> NA_balance[label="cGMP→\nnatriuresis↑"];
    ANP_mol    -> NPRA_r   [label="binding"];
    BNP_mol    -> NPRA_r   [label="binding"];
    ANP_kidney -> NA_balance[label="natriuresis↑"];
    GFR        -> CKD_ep   [label="decline →\nCKD progression"];
    SGLT2_tr   -> NA_balance[label="glucose-Na\ncotransport"];

    /* ===================================================================
       EDGES — Cardiac Function
    =================================================================== */
    HR_bpm     -> CO_lmin  [label="CO = HR × SV"];
    SV_ml      -> CO_lmin  [label="CO = HR × SV"];
    PRELOAD    -> SV_ml    [label="Frank-Starling\nlaw"];
    AFTERLOAD  -> SV_ml   [label="↑TPR → ↓SV"];
    CONTRACT   -> SV_ml    [label="↑inotropy\n→ ↑SV"];
    L_VGCC     -> CA_cyto  [label="Ca2+ influx\n(depolarization)"];
    CA_cyto    -> CONTRACT [label="Ca2+-calmodulin\n→ myosin activation"];
    CA_cyto    -> HR_bpm   [label="SA node\nCa2+ clock"];
    MYOSIN     -> CONTRACT [label="cross-bridge\ncycling"];
    CAMP_cAR   -> CA_cyto  [label="PKA→\nL-VGCC phospho"];
    CAMP_cAR   -> CONTRACT [label="PKA→\ntroponin I phospho"];
    PRELOAD    -> LVEDP    [label="↑filling\npressure"];
    LVEDP      -> BNP_mol  [label="wall stress→\nBNP synthesis↑"];
    LV_MASS    -> LVH_ep   [label="LV mass index\n>115 g/m²"];
    AT1R       -> LV_MASS  [label="hypertrophic\nsignaling"];
    TGF_B      -> LV_MASS  [label="cardiac\nfibrosis"];
    ALDO       -> LV_MASS  [label="MR-mediated\nfibrosis"];
    FIBROSIS_C -> LV_MASS  [label="collagen↑\n→stiffness"];

    /* ===================================================================
       EDGES — Vascular Remodeling
    =================================================================== */
    VSM_TONE   -> TPR_val  [label="functional\ncomponent"];
    VSM_PROLIF -> IMT      [label="↑wall thickness"];
    IMT        -> TPR_val  [label="structural\ncomponent"];
    COLLAGEN   -> ART_STIFF[label="↑wall\nstiffness"];
    ART_STIFF  -> PWV      [label="direct measure"];
    PWV        -> PP_ep    [label="↑pulse\npressure"];
    TGF_B      -> COLLAGEN [label="↑collagen I/III\nsynthesis"];
    TGF_B      -> ECM_rmdl [label="fibrotic\nremodeling"];
    MMP_enz    -> ECM_rmdl [label="matrix\ndegradation"];
    PDGF_gf    -> VSM_PROLIF[label="mitogen"];
    FGF_gf     -> VSM_PROLIF[label="angiogenesis"];
    MAPK_path  -> VSM_PROLIF[label="ERK1/2\ncell cycle"];
    PKC_enz    -> MAPK_path [label="activation"];
    ROCK_enz   -> VSM_TONE  [label="Ca2+\nsensitization\n(MLC phospho↑)"];
    IP3_DAG    -> CA_cyto   [label="IP3-gated\nER Ca2+ release"];
    IL6_vasc   -> MAPK_path [label="JAK-STAT\nproliferation"];
    CRP_prot   -> NFKB_path [label="systemic\ninflammation"];

    /* ===================================================================
       EDGES — Inflammation
    =================================================================== */
    NLRP3      -> IL1B     [label="caspase-1\ncleavage"];
    IL1B       -> NFKB_path[label="→inflammatory\ngene cascade"];
    TNF_a      -> NFKB_path[label="TNFR→NF-κB"];
    IL6        -> CRP_prot  [label="hepatic CRP\nsynthesis"];
    ICAM1      -> MAC_infilt[label="leukocyte\nrolling/adhesion"];
    VCAM1      -> MAC_infilt[label="monocyte\nrecruitment"];
    MAC_infilt -> OXLDL    [label="scavenger\nreceptor"];
    OXLDL      -> FOAM_cell [label="lipid\naccumulation"];
    FOAM_cell  -> NFKB_path [label="further\nactivation"];
    ROS_mol    -> OXLDL     [label="LDL oxidation"];

    /* ===================================================================
       EDGES — Drug PK (absorption → central → peripheral)
    =================================================================== */
    /* ACE Inhibitor */
    RAMP_gut -> RAMP_C   [label="ka_ACEI, F=0.28\nhydrolysis→ramiprilat"];
    RAMP_C   -> RAMP_P   [label="Q_ACEI\ndistribution"];
    RAMP_C   -> RAMP_ACE [label="competitive\nbinding to ACE"];

    /* ARB */
    LOS_gut  -> LOS_C    [label="ka_ARB, F=0.33\nCYP2C9→EXP3174"];
    LOS_C    -> LOS_P    [label="Q_ARB\ndistribution"];
    LOS_C    -> AT1R_occ [label="EXP3174\nAT1R blockade"];

    /* CCB */
    AML_gut  -> AML_C    [label="ka_CCB, F=0.64\nCYP3A4"];
    AML_C    -> AML_P    [label="Q_CCB\ndistribution"];
    AML_C    -> VGCC_blk [label="L-VGCC\nchannel binding"];

    /* Beta-blocker */
    BIS_gut  -> BIS_C    [label="ka_BB, F=0.80"];
    BIS_C    -> BIS_P    [label="Q_BB\ndistribution"];
    BIS_C    -> BETA1_blk[label="competitive\nβ1-AR blockade"];

    /* HCTZ */
    HCTZ_gut -> HCTZ_C   [label="ka_HCTZ, F=0.70"];
    HCTZ_C   -> NCC_inhib[label="NCC inhibition\n(DCT)"];

    /* ===================================================================
       EDGES — Drug PD Effects (pharmacological actions)
    =================================================================== */
    RAMP_ACE -> ACE_enz   [label="inhibits ⊣\n(IC50 = 0.002 nM)", style=dashed, color=blue, arrowhead=tee];
    AT1R_occ -> AT1R      [label="blocks ⊣\n(Ki = 18 nM)", style=dashed, color=blue, arrowhead=tee];
    VGCC_blk -> L_VGCC    [label="blocks ⊣\n(IC50 ~ 2.4 nM)", style=dashed, color=blue, arrowhead=tee];
    BETA1_blk-> BETA1R    [label="blocks ⊣\n(Ki = 9 nM)", style=dashed, color=blue, arrowhead=tee];
    NCC_inhib-> NCC_tr    [label="inhibits ⊣\n(IC50 ~ 25 μM)", style=dashed, color=blue, arrowhead=tee];

    /* ACE inhibition → bradykinin accumulation */
    RAMP_ACE -> BRAD_kinin [label="↑bradykinin\n(kininase II blocked)", style=dotted, color=blue];

    /* ===================================================================
       EDGES — Hemodynamics Integration
    =================================================================== */
    CO_lmin    -> MAP_ep   [label="MAP = CO × TPR\n+ (venous offset)"];
    TPR_val    -> MAP_ep   [label="MAP = CO × TPR"];
    MAP_ep     -> SBP_ep   [label="SBP ≈ MAP\n+ PP×2/3"];
    MAP_ep     -> DBP_ep   [label="DBP ≈ MAP\n− PP/3"];
    AFTERLOAD  -> TPR_val  [label="TPR drives\nafterload"];
    CO_lmin    -> AFTERLOAD[label="feedback"];

    /* ===================================================================
       EDGES → Clinical Endpoints & Biomarkers
    =================================================================== */
    MAP_ep     -> CKD_ep   [label="glomerular\nhypertension"];
    MAP_ep     -> RETINO   [label="arteriolar\nwall damage"];
    MAP_ep     -> STROKE_r [label="cerebrovascular\nwall stress"];
    MAP_ep     -> MI_r     [label="↑coronary\nworkload"];
    ART_STIFF  -> MI_r     [label="↑afterload"];
    LVH_ep     -> HF_r     [label="diastolic\ndysfunction"];
    SBP_ep     -> SCORE_bm [label="ESH/ESC\nrisk model"];
    SBP_ep     -> FRMHM_bm [label="Framingham\nequation"];

    /* Biomarkers */
    PLASMA_V   -> PRA_bm   [label="low vol→↑PRA"];
    ALDO       -> SALDO_bm [label="circulating\naldosterone"];
    BNP_mol    -> BNP_bm   [label="plasma\nBNP level"];
    GFR        -> SCr_bm   [label="↓GFR→↑Cr"];
    GFR        -> UACR_bm  [label="glomerular\nproteinuria"];
    NA_balance -> UNa_bm   [label="urinary\nexcretion"];
}
