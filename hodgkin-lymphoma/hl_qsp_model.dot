digraph HodgkinLymphoma_QSP {
  // ============================================================
  // Hodgkin Lymphoma (HL) — Quantitative Systems Pharmacology Map
  // Classical HL (cHL: NS, MC, LR, LD) + NLPHL biology
  // HRS cells · EBV · NF-kB · JAK/STAT · 9p24.1/PD-L1
  // ABVD · escBEACOPP · BV-AVD · Nivolumab · Pembrolizumab
  // ============================================================

  graph [rankdir=LR, splines=polyline, overlap=false, nodesep=0.35, ranksep=0.55, fontname="Helvetica", fontsize=11, label="Hodgkin Lymphoma QSP Map\n(HRS / TME / Checkpoint / ADC / Chemo / Endpoints / Late effects)", labelloc="t"];
  node  [shape=box, style="filled,rounded", fontname="Helvetica", fontsize=10, color="#444444", penwidth=1.2];
  edge  [fontname="Helvetica", fontsize=9, color="#666666", arrowsize=0.7];

  // ---------- Cluster: Etiology & Predisposition ----------
  subgraph cluster_etiology {
    label="① Etiology / Predisposition";
    style="rounded,filled"; color="#1f77b4"; fillcolor="#e9f1fb";
    EBV         [label="EBV (LMP1, LMP2A)",       fillcolor="#cfe2f3"];
    HLA_class2  [label="HLA class II alleles\n(DRB1*15, DPB1)", fillcolor="#cfe2f3"];
    Age_bimodal [label="Bimodal age peaks\n(15–35y, >55y)",      fillcolor="#cfe2f3"];
    FamilyHx    [label="Familial risk\n(KLHDC8B, others)",        fillcolor="#cfe2f3"];
    Immunosup   [label="HIV / Immunosuppression",                 fillcolor="#cfe2f3"];
    Smoking     [label="Tobacco / Lifestyle",                     fillcolor="#cfe2f3"];
  }

  // ---------- Cluster: Cell of Origin & HRS Differentiation ----------
  subgraph cluster_origin {
    label="② Cell of Origin → HRS";
    style="rounded,filled"; color="#ff7f0e"; fillcolor="#fdebd0";
    GC_Bcell    [label="Germinal-center B cell\n(crippled BCR)", fillcolor="#ffe0b3"];
    Apoptosis_escape [label="Escape from apoptosis\n(BCL2, c-FLIP↑)", fillcolor="#ffe0b3"];
    BCR_loss    [label="BCR / Ig loss\n(somatic mutations)",    fillcolor="#ffe0b3"];
    Bcell_program_loss [label="B-cell program loss\n(PAX5 dim, OCT2↓, BOB1↓)", fillcolor="#ffe0b3"];
    HRS_cell    [label="Hodgkin/Reed-Sternberg cell\n(CD30+ CD15+ CD20−/dim)", fillcolor="#ffcc80", shape=octagon];
    Mummified   [label="Mummified HRS\n(apoptotic)", fillcolor="#ffe0b3"];
    Popcorn     [label="LP / popcorn cell\n(NLPHL: CD20+ CD30−)", fillcolor="#ffe0b3"];
  }

  // ---------- Cluster: Oncogenic Signaling ----------
  subgraph cluster_signaling {
    label="③ Oncogenic Signaling in HRS";
    style="rounded,filled"; color="#2ca02c"; fillcolor="#e2f0d9";
    NFkB_canon  [label="NF-kB canonical\n(REL gains, IKK)", fillcolor="#cfe2cf"];
    NFkB_noncan [label="NF-kB non-canonical\n(TNFAIP3 / A20 loss)", fillcolor="#cfe2cf"];
    JAK2_amp    [label="JAK2 amplification\n(9p24.1)", fillcolor="#cfe2cf"];
    STAT3_6     [label="STAT3 / STAT5 / STAT6 activation", fillcolor="#cfe2cf"];
    PI3K_AKT    [label="PI3K / AKT / mTOR", fillcolor="#cfe2cf"];
    NOTCH1      [label="NOTCH1 signaling", fillcolor="#cfe2cf"];
    AP1_JUNB    [label="AP-1 / JUNB", fillcolor="#cfe2cf"];
    SOCS1_loss  [label="SOCS1 loss-of-function", fillcolor="#cfe2cf"];
    PTPN1_loss  [label="PTPN1 loss-of-function", fillcolor="#cfe2cf"];
    CIITA_rear  [label="CIITA rearrangements\n(MHC II loss)", fillcolor="#cfe2cf"];
  }

  // ---------- Cluster: 9p24.1 Locus & Checkpoint Biology ----------
  subgraph cluster_checkpoint {
    label="④ 9p24.1 locus / Immune checkpoint";
    style="rounded,filled"; color="#d62728"; fillcolor="#fce4e4";
    Amp_9p241   [label="9p24.1 amplification\n(PDCD1LG1/2, JAK2)", fillcolor="#f9c7c7"];
    PDL1_HRS    [label="PD-L1 on HRS", fillcolor="#f9c7c7"];
    PDL2_HRS    [label="PD-L2 on HRS", fillcolor="#f9c7c7"];
    PD1_Texh    [label="PD-1 on exhausted T cells", fillcolor="#f9c7c7"];
    TIM3        [label="TIM-3 / LAG-3 (Texh)", fillcolor="#f9c7c7"];
    MHCI_loss   [label="MHC I / B2M loss", fillcolor="#f9c7c7"];
    MHCII_HRS   [label="MHC II on HRS\n(antigen presentation)", fillcolor="#f9c7c7"];
    Treg_pool   [label="Treg pool (FOXP3+)", fillcolor="#f9c7c7"];
  }

  // ---------- Cluster: Tumor Microenvironment ----------
  subgraph cluster_tme {
    label="⑤ Tumor Microenvironment";
    style="rounded,filled"; color="#9467bd"; fillcolor="#ede5f4";
    Th2_cells   [label="Th2 cells\n(IL-4, IL-5, IL-13)", fillcolor="#d9c9e8"];
    Th17_cells  [label="Th17 cells (IL-17)", fillcolor="#d9c9e8"];
    Tfh_cells   [label="TFH cells (PD-1+, NLPHL)", fillcolor="#d9c9e8"];
    Eos_TME     [label="Eosinophils", fillcolor="#d9c9e8"];
    PlasmaCells_TME [label="Plasma cells",  fillcolor="#d9c9e8"];
    MastCells   [label="Mast cells (CD30L+)", fillcolor="#d9c9e8"];
    Macroph_TAM [label="TAM (CD68+ / CD163+)", fillcolor="#d9c9e8"];
    Fibroblasts [label="Fibroblasts / nodular sclerosis", fillcolor="#d9c9e8"];
    Neutrophils_TME [label="Neutrophils (NLR↑)", fillcolor="#d9c9e8"];
    NK_cells    [label="NK cells", fillcolor="#d9c9e8"];
    Effector_T  [label="Effector CD8+ T cells", fillcolor="#d9c9e8"];
  }

  // ---------- Cluster: Cytokines & Chemokines ----------
  subgraph cluster_cytokines {
    label="⑥ Cytokine / Chemokine network";
    style="rounded,filled"; color="#8c564b"; fillcolor="#efe4e2";
    IL6         [label="IL-6", fillcolor="#e0cdc8"];
    IL10        [label="IL-10", fillcolor="#e0cdc8"];
    IL13        [label="IL-13 (autocrine)", fillcolor="#e0cdc8"];
    TGFb        [label="TGF-β", fillcolor="#e0cdc8"];
    TNFa_HL     [label="TNF-α", fillcolor="#e0cdc8"];
    IFNg        [label="IFN-γ", fillcolor="#e0cdc8"];
    CCL17_TARC  [label="CCL17 (TARC)", fillcolor="#e0cdc8"];
    CCL22_MDC   [label="CCL22 (MDC)", fillcolor="#e0cdc8"];
    CCL5_RANTES [label="CCL5 (RANTES)", fillcolor="#e0cdc8"];
    CXCL10      [label="CXCL10 (IP-10)", fillcolor="#e0cdc8"];
    Galectin1   [label="Galectin-1", fillcolor="#e0cdc8"];
    sIL2R       [label="soluble IL-2R (sCD25)", fillcolor="#e0cdc8"];
    sCD30       [label="soluble CD30", fillcolor="#e0cdc8"];
    Ferritin    [label="Ferritin", fillcolor="#e0cdc8"];
  }

  // ---------- Cluster: Clinical Phenotype / Staging ----------
  subgraph cluster_clinical {
    label="⑦ Clinical phenotype / Staging";
    style="rounded,filled"; color="#17becf"; fillcolor="#dff3f6";
    LN_cervical [label="Cervical / SCV LN", fillcolor="#bfe7ed"];
    LN_mediast  [label="Mediastinal mass / bulky", fillcolor="#bfe7ed"];
    LN_axillary [label="Axillary / abdominal LN", fillcolor="#bfe7ed"];
    BoneMarrow_inv [label="Bone marrow involvement", fillcolor="#bfe7ed"];
    Spleen_inv  [label="Splenic involvement", fillcolor="#bfe7ed"];
    Bsymptoms   [label="B-symptoms\n(fever, sweats, weight loss)", fillcolor="#bfe7ed"];
    Pruritus    [label="Pruritus / alcohol pain", fillcolor="#bfe7ed"];
    Ann_Arbor   [label="Lugano stage I–IV", fillcolor="#bfe7ed", shape=parallelogram];
    IPS_score   [label="IPS score (advanced)", fillcolor="#bfe7ed", shape=parallelogram];
    GHSG_risk   [label="GHSG risk groups\n(early-fav / unfav / advanced)", fillcolor="#bfe7ed", shape=parallelogram];
    Histology   [label="Histology\n(NS / MC / LR / LD / NLPHL)", fillcolor="#bfe7ed", shape=parallelogram];
  }

  // ---------- Cluster: Imaging & Biomarkers ----------
  subgraph cluster_biomarkers {
    label="⑧ Imaging / Biomarkers";
    style="rounded,filled"; color="#bcbd22"; fillcolor="#f3f5cf";
    PET_SUVmax  [label="FDG-PET SUVmax", fillcolor="#e6ebb0"];
    Deauville   [label="Deauville score (1–5)", fillcolor="#e6ebb0"];
    iPET2       [label="iPET2 (interim)", fillcolor="#e6ebb0"];
    MTV_TLG     [label="MTV / TLG", fillcolor="#e6ebb0"];
    ctDNA       [label="ctDNA / mutational burden", fillcolor="#e6ebb0"];
    TARC_serum  [label="Serum TARC", fillcolor="#e6ebb0"];
    ESR_CRP     [label="ESR / CRP", fillcolor="#e6ebb0"];
    Albumin     [label="Serum albumin", fillcolor="#e6ebb0"];
    Hb_lab      [label="Hemoglobin", fillcolor="#e6ebb0"];
    LDH_lab     [label="LDH", fillcolor="#e6ebb0"];
    WBC_lymph   [label="WBC / lymphopenia", fillcolor="#e6ebb0"];
  }

  // ---------- Cluster: Drug PK Compartments ----------
  subgraph cluster_pk {
    label="⑨ Drug PK / PD";
    style="rounded,filled"; color="#7f7f7f"; fillcolor="#ececec";
    Dox_PK      [label="Doxorubicin PK\n(2-cpt, t½ 20–48h)", fillcolor="#d9d9d9"];
    Bleo_PK     [label="Bleomycin PK\n(renal CL)",            fillcolor="#d9d9d9"];
    Vin_PK      [label="Vinblastine PK\n(3-cpt)",              fillcolor="#d9d9d9"];
    Dac_PK      [label="Dacarbazine PK",                       fillcolor="#d9d9d9"];
    Etop_PK     [label="Etoposide PK (BEACOPP)",               fillcolor="#d9d9d9"];
    Cyc_PK      [label="Cyclophosphamide PK",                  fillcolor="#d9d9d9"];
    Vinc_PK     [label="Vincristine PK",                       fillcolor="#d9d9d9"];
    Pred_PK     [label="Prednisone / Pred",                    fillcolor="#d9d9d9"];
    Procarb_PK  [label="Procarbazine PK",                      fillcolor="#d9d9d9"];
    BV_PK       [label="Brentuximab vedotin PK\n(ADC, t½ ~4–6d)", fillcolor="#d9d9d9"];
    MMAE_PK     [label="MMAE released payload", fillcolor="#d9d9d9"];
    Nivo_PK     [label="Nivolumab PK\n(t½ ~25d)", fillcolor="#d9d9d9"];
    Pembro_PK   [label="Pembrolizumab PK\n(t½ ~22d)", fillcolor="#d9d9d9"];
    Bend_PK     [label="Bendamustine PK",  fillcolor="#d9d9d9"];
    Gem_PK      [label="Gemcitabine PK",   fillcolor="#d9d9d9"];
    GCSF        [label="G-CSF support",    fillcolor="#d9d9d9"];
  }

  // ---------- Cluster: Toxicity ----------
  subgraph cluster_tox {
    label="⑩ Acute / Late Toxicity";
    style="rounded,filled"; color="#e377c2"; fillcolor="#fbe4f1";
    NeutropFever [label="Febrile neutropenia",    fillcolor="#f7c4df"];
    Mucositis   [label="Mucositis",               fillcolor="#f7c4df"];
    NV_emesis   [label="Nausea / Emesis",         fillcolor="#f7c4df"];
    Alopecia    [label="Alopecia",                fillcolor="#f7c4df"];
    PeriphNeuro [label="Peripheral neuropathy\n(MMAE/VBL/VCR)", fillcolor="#f7c4df"];
    Cardiotox   [label="Anthracycline cardiotox\n(LV dysfunction)", fillcolor="#f7c4df"];
    PulmTox_BLM [label="Bleomycin pulmonary tox", fillcolor="#f7c4df"];
    Fertility   [label="Gonadotoxicity / infertility", fillcolor="#f7c4df"];
    SecMalig    [label="Secondary malignancies\n(AML, NHL, solid)", fillcolor="#f7c4df"];
    irAE        [label="Immune-related AEs\n(thyroid, pneumonitis, colitis)", fillcolor="#f7c4df"];
    RT_lateTox  [label="Radiation late effects\n(CVD, breast cancer, hypothyroid)", fillcolor="#f7c4df"];
    Infections  [label="Infections (CMV, PJP, HZV)", fillcolor="#f7c4df"];
  }

  // ---------- Cluster: Endpoints & Outcomes ----------
  subgraph cluster_endpoints {
    label="⑪ Endpoints / Outcomes";
    style="rounded,filled"; color="#393b79"; fillcolor="#dadbf0";
    PETCR       [label="End-of-treatment PET-CR", fillcolor="#bcbee3", shape=parallelogram];
    iPET_neg    [label="iPET2 negativity",        fillcolor="#bcbee3", shape=parallelogram];
    PFS         [label="PFS",                     fillcolor="#bcbee3", shape=parallelogram];
    OS          [label="Overall survival",        fillcolor="#bcbee3", shape=parallelogram];
    FFTF        [label="Freedom from treatment failure", fillcolor="#bcbee3", shape=parallelogram];
    DOR         [label="Duration of response",    fillcolor="#bcbee3", shape=parallelogram];
    ORR         [label="ORR (relapsed/refractory)", fillcolor="#bcbee3", shape=parallelogram];
    QoL         [label="QoL / Fatigue / FACT-Lym", fillcolor="#bcbee3"];
    HSCT_eligibility [label="HSCT eligibility / consolidation", fillcolor="#bcbee3"];
  }

  // ---------- Cluster: Therapy Regimens ----------
  subgraph cluster_regimens {
    label="⑫ Therapy regimens & response";
    style="rounded,filled"; color="#2f4f4f"; fillcolor="#d6e3e3";
    ABVD        [label="ABVD\n(2–6 cycles)",         fillcolor="#a7c4c4"];
    AVD         [label="AVD (drop BLM)",             fillcolor="#a7c4c4"];
    escBEACOPP  [label="escBEACOPP",                 fillcolor="#a7c4c4"];
    BV_AVD      [label="A+AVD (BV+AVD)\n(ECHELON-1)", fillcolor="#a7c4c4"];
    Nivo_AVD    [label="N-AVD (SWOG S1826)",         fillcolor="#a7c4c4"];
    Pembro_AVD  [label="K-AVD (KEYNOTE-867)",        fillcolor="#a7c4c4"];
    ISRT_RT     [label="Involved-site RT (ISRT)",    fillcolor="#a7c4c4"];
    HDT_ASCT    [label="HDT + ASCT",                 fillcolor="#a7c4c4"];
    BV_mono     [label="BV monotherapy (R/R)",       fillcolor="#a7c4c4"];
    Nivo_mono   [label="Nivolumab (R/R)",            fillcolor="#a7c4c4"];
    Pembro_mono [label="Pembrolizumab (R/R)",        fillcolor="#a7c4c4"];
    BV_nivo     [label="BV + Nivolumab (R/R)",       fillcolor="#a7c4c4"];
    AlloSCT     [label="Allogeneic HSCT (advanced R/R)", fillcolor="#a7c4c4"];
  }

  // ============================================================
  // EDGES — pathogenic & therapeutic interactions
  // ============================================================

  // Etiology drives HRS
  EBV         -> GC_Bcell        [label="LMP1=CD40-like"];
  EBV         -> NFkB_canon      [label="LMP1→TRAF→IKK"];
  EBV         -> Apoptosis_escape;
  HLA_class2  -> EBV             [label="susceptibility"];
  Age_bimodal -> GC_Bcell;
  FamilyHx    -> GC_Bcell;
  Immunosup   -> EBV             [label="reactivation"];
  Smoking     -> HRS_cell;

  // Cell of origin → HRS
  GC_Bcell    -> BCR_loss;
  BCR_loss    -> Apoptosis_escape;
  Apoptosis_escape -> Bcell_program_loss;
  Bcell_program_loss -> HRS_cell;
  HRS_cell    -> Mummified       [style=dashed];
  GC_Bcell    -> Popcorn         [label="NLPHL"];

  // Oncogenic signaling
  HRS_cell    -> NFkB_canon;
  HRS_cell    -> NFkB_noncan;
  HRS_cell    -> JAK2_amp;
  HRS_cell    -> PI3K_AKT;
  HRS_cell    -> NOTCH1;
  HRS_cell    -> AP1_JUNB;
  TNFAIP3_node [label="TNFAIP3/A20 loss", style="filled,rounded", fillcolor="#cfe2cf"];
  TNFAIP3_node -> NFkB_canon     [label="dis-inhibition"];
  SOCS1_loss  -> JAK2_amp        [label="dis-inhibition"];
  PTPN1_loss  -> STAT3_6;
  JAK2_amp    -> STAT3_6;
  STAT3_6     -> HRS_cell        [label="proliferation/survival"];
  NFkB_canon  -> HRS_cell;
  NFkB_noncan -> HRS_cell;
  PI3K_AKT    -> HRS_cell;
  CIITA_rear  -> MHCII_HRS       [label="↓"];

  // 9p24.1 → checkpoint
  Amp_9p241   -> PDL1_HRS;
  Amp_9p241   -> PDL2_HRS;
  Amp_9p241   -> JAK2_amp;
  JAK2_amp    -> PDL1_HRS        [label="STAT1→PD-L1"];
  PDL1_HRS    -> PD1_Texh        [label="ligation"];
  PDL2_HRS    -> PD1_Texh;
  PD1_Texh    -> Effector_T      [label="exhaustion", style=dotted, color="#cc0000"];
  Effector_T  -> HRS_cell        [label="lysis", color="#2ca02c"];
  TIM3        -> Effector_T      [style=dotted, color="#cc0000"];
  MHCI_loss   -> Effector_T      [label="evasion"];
  MHCII_HRS   -> CD4_helper      [label="presents Ag"];
  CD4_helper  [label="CD4+ T helper",  style="filled,rounded", fillcolor="#d9c9e8"];
  Treg_pool   -> Effector_T      [style=dotted, color="#cc0000"];

  // TME crosstalk
  HRS_cell    -> CCL17_TARC      [label="secretes"];
  HRS_cell    -> CCL22_MDC;
  HRS_cell    -> Galectin1;
  HRS_cell    -> IL13            [label="autocrine"];
  HRS_cell    -> IL6;
  HRS_cell    -> TGFb;
  HRS_cell    -> IL10;
  CCL17_TARC  -> Th2_cells;
  CCL17_TARC  -> Treg_pool;
  CCL22_MDC   -> Th2_cells;
  CCL22_MDC   -> Treg_pool;
  Galectin1   -> Th2_cells       [label="skew"];
  TGFb        -> Treg_pool;
  TGFb        -> Fibroblasts     [label="nodular sclerosis"];
  IL10        -> Effector_T      [style=dotted, color="#cc0000"];
  IL13        -> Eos_TME;
  IL13        -> HRS_cell        [label="STAT6"];
  IL6         -> HRS_cell        [label="STAT3"];
  TNFa_HL     -> NFkB_canon;
  IFNg        -> PDL1_HRS        [label="↑ via STAT1"];
  CXCL10      -> Effector_T;
  CCL5_RANTES -> Macroph_TAM;
  MastCells   -> HRS_cell        [label="CD30L"];
  Eos_TME     -> Fibroblasts;
  PlasmaCells_TME -> IL6;
  Macroph_TAM -> HRS_cell        [label="support"];
  Neutrophils_TME -> HRS_cell    [label="elastase/NETs"];
  Fibroblasts -> LN_mediast      [label="NS bands"];
  NK_cells    -> HRS_cell        [color="#2ca02c"];
  HRS_cell    -> sCD30           [label="shed"];
  HRS_cell    -> sIL2R           [label="shed"];

  // Clinical phenotype
  HRS_cell    -> LN_cervical;
  HRS_cell    -> LN_mediast;
  HRS_cell    -> LN_axillary;
  HRS_cell    -> BoneMarrow_inv;
  HRS_cell    -> Spleen_inv;
  IL6         -> Bsymptoms;
  TNFa_HL     -> Bsymptoms;
  IL13        -> Pruritus;
  HRS_cell    -> Histology;
  Histology   -> Ann_Arbor;
  Ann_Arbor   -> IPS_score;
  Ann_Arbor   -> GHSG_risk;

  // Imaging / biomarkers
  HRS_cell    -> PET_SUVmax      [label="FDG uptake"];
  PET_SUVmax  -> Deauville;
  Deauville   -> iPET2;
  PET_SUVmax  -> MTV_TLG;
  CCL17_TARC  -> TARC_serum;
  IL6         -> ESR_CRP;
  Bsymptoms   -> Albumin         [label="↓"];
  HRS_cell    -> LDH_lab;
  HRS_cell    -> WBC_lymph       [label="lymphopenia"];
  HRS_cell    -> Hb_lab          [label="anemia"];
  HRS_cell    -> ctDNA;
  HRS_cell    -> Ferritin;

  // PK → PD on HRS
  ABVD        -> Dox_PK;
  ABVD        -> Bleo_PK;
  ABVD        -> Vin_PK;
  ABVD        -> Dac_PK;
  AVD         -> Dox_PK;
  AVD         -> Vin_PK;
  AVD         -> Dac_PK;
  escBEACOPP  -> Bleo_PK;
  escBEACOPP  -> Etop_PK;
  escBEACOPP  -> Dox_PK;
  escBEACOPP  -> Cyc_PK;
  escBEACOPP  -> Vinc_PK;
  escBEACOPP  -> Procarb_PK;
  escBEACOPP  -> Pred_PK;
  BV_AVD      -> BV_PK;
  BV_AVD      -> Dox_PK;
  BV_AVD      -> Vin_PK;
  BV_AVD      -> Dac_PK;
  Nivo_AVD    -> Nivo_PK;
  Nivo_AVD    -> Dox_PK;
  Nivo_AVD    -> Vin_PK;
  Nivo_AVD    -> Dac_PK;
  Pembro_AVD  -> Pembro_PK;
  ISRT_RT     -> HRS_cell        [label="DNA DSB", color="#cc0000"];
  HDT_ASCT    -> HRS_cell        [label="myeloablation", color="#cc0000"];
  BV_mono     -> BV_PK;
  Nivo_mono   -> Nivo_PK;
  Pembro_mono -> Pembro_PK;
  BV_nivo     -> BV_PK;
  BV_nivo     -> Nivo_PK;
  AlloSCT     -> Effector_T      [label="GVL", color="#2ca02c"];

  Dox_PK      -> HRS_cell        [label="topo-II / ROS", color="#cc0000"];
  Bleo_PK     -> HRS_cell        [label="DNA strand breaks", color="#cc0000"];
  Vin_PK      -> HRS_cell        [label="microtubule", color="#cc0000"];
  Dac_PK      -> HRS_cell        [label="alkylation", color="#cc0000"];
  Etop_PK     -> HRS_cell        [label="topo-II", color="#cc0000"];
  Cyc_PK      -> HRS_cell        [label="alkylation", color="#cc0000"];
  Vinc_PK     -> HRS_cell        [label="microtubule", color="#cc0000"];
  Pred_PK     -> HRS_cell        [label="apoptosis", color="#cc0000"];
  Procarb_PK  -> HRS_cell        [label="alkylation", color="#cc0000"];
  BV_PK       -> HRS_cell        [label="anti-CD30 internalize"];
  BV_PK       -> MMAE_PK         [label="protease release"];
  MMAE_PK     -> HRS_cell        [label="microtubule kill", color="#cc0000"];
  Nivo_PK     -> PD1_Texh        [label="block PD-1", color="#2ca02c"];
  Pembro_PK   -> PD1_Texh        [label="block PD-1", color="#2ca02c"];
  PD1_Texh    -> Effector_T      [label="reinvigorate (post-IO)", color="#2ca02c", style=dashed];
  Bend_PK     -> HRS_cell        [label="alkyl+nucleoside", color="#cc0000"];
  Gem_PK      -> HRS_cell        [label="dCTP analog", color="#cc0000"];
  GCSF        -> Neutrophils_TME [label="rescue ANC"];

  // Toxicity links
  Dox_PK      -> Cardiotox       [label="cumulative dose"];
  Bleo_PK     -> PulmTox_BLM     [label="alveolar damage"];
  Vin_PK      -> PeriphNeuro;
  Vinc_PK     -> PeriphNeuro;
  MMAE_PK     -> PeriphNeuro     [label="microtubule axonal"];
  Cyc_PK      -> Fertility;
  Procarb_PK  -> Fertility;
  ISRT_RT     -> SecMalig        [label="breast/lung/thyroid"];
  ISRT_RT     -> Cardiotox;
  ISRT_RT     -> RT_lateTox;
  Etop_PK     -> SecMalig        [label="t-AML"];
  Cyc_PK      -> SecMalig;
  Nivo_PK     -> irAE;
  Pembro_PK   -> irAE;
  BV_PK       -> PeriphNeuro;
  Dox_PK      -> Mucositis;
  Dox_PK      -> Alopecia;
  Cyc_PK      -> NeutropFever;
  Etop_PK     -> NeutropFever;
  GCSF        -> NeutropFever    [label="↓ risk"];
  NeutropFever -> Infections;
  Pred_PK     -> Infections      [label="PJP/HSV"];

  // Endpoints
  HRS_cell    -> PETCR           [label="kill→CR"];
  PETCR       -> PFS;
  iPET2       -> iPET_neg;
  iPET_neg    -> ESC_de_escalate  [label="RAPID/H10"];
  ESC_de_escalate [label="iPET-adapted de-escalation", style="filled,rounded", fillcolor="#bcbee3"];
  ESC_de_escalate -> AVD         [label="drop BLM"];
  ESC_de_escalate -> ISRT_RT     [label="omit RT"];
  PFS         -> OS;
  PETCR       -> FFTF;
  HRS_cell    -> ORR             [label="R/R"];
  ORR         -> DOR;
  PFS         -> QoL;
  Cardiotox   -> OS              [label="late", color="#cc0000"];
  SecMalig    -> OS              [color="#cc0000"];
  PulmTox_BLM -> OS              [color="#cc0000"];
  RT_lateTox  -> OS              [color="#cc0000"];
  HDT_ASCT    -> HSCT_eligibility;
  HSCT_eligibility -> PFS;

  // Risk stratification
  IPS_score   -> escBEACOPP      [label="advanced"];
  GHSG_risk   -> ABVD            [label="early-favorable"];
  GHSG_risk   -> BV_AVD          [label="advanced"];
  GHSG_risk   -> Nivo_AVD;
  GHSG_risk   -> Pembro_AVD;

  // ============================================================
  // LEGEND
  // ============================================================
  subgraph cluster_legend {
    label="Legend";
    style="rounded,filled"; color="#000000"; fillcolor="#ffffff";
    L_drive [label="↗ drives/activates", fillcolor="#ffffff", color="#2ca02c", fontcolor="#2ca02c"];
    L_inhib [label="⊣ inhibits/exhausts", fillcolor="#ffffff", color="#cc0000", fontcolor="#cc0000"];
    L_node  [label="Mechanism node", fillcolor="#ececec"];
    L_endpt [label="Clinical endpoint", fillcolor="#bcbee3", shape=parallelogram];
    L_hrs   [label="HRS cell", fillcolor="#ffcc80", shape=octagon];
  }
}
