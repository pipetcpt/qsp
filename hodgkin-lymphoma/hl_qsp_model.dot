/* ============================================================
   Hodgkin Lymphoma QSP Mechanistic Map
   Quantitative Systems Pharmacology Model
   Nodes: 120+ | Clusters: 12
   Generated: 2026-06-28
   ============================================================ */

digraph HL_QSP {

    /* Global graph attributes */
    rankdir=LR;
    compound=true;
    splines=ortho;
    nodesep=0.4;
    ranksep=0.7;
    fontname="Helvetica";
    fontsize=11;
    graph [bgcolor="#F8F8F8", pad=0.5];

    /* Default node style */
    node [fontname="Helvetica", fontsize=9, style="filled,rounded", margin=0.08];
    edge [fontname="Helvetica", fontsize=8, arrowsize=0.7];

    /* ============================================================
       CLUSTER 1: Reed-Sternberg Cell Biology
       ============================================================ */
    subgraph cluster_rs_cell {
        label="Reed-Sternberg Cell Biology";
        style="filled,rounded";
        fillcolor="#FFF3E0";
        color="#E65100";
        fontsize=12;
        fontcolor="#E65100";
        fontname="Helvetica-Bold";

        /* Surface markers */
        RS_CD30   [label="CD30\n(TNFRSF8)", shape=box, fillcolor="#FF8F00", fontcolor=white];
        RS_CD15   [label="CD15\n(Lewis-X)", shape=box, fillcolor="#FF8F00", fontcolor=white];
        RS_CD20p  [label="CD20\n(partial/weak)", shape=box, fillcolor="#FFB300", fontcolor="#333333"];
        RS_CD25   [label="CD25 (IL-2Rα)\noverexpressed", shape=box, fillcolor="#FF8F00", fontcolor=white];
        RS_MHC1   [label="MHC class I\n(downregulated)", shape=box, fillcolor="#EF9A9A"];
        RS_MHC2   [label="MHC class II\n(variable)", shape=box, fillcolor="#FFB300"];

        /* Transcription factors */
        RS_PAX5   [label="PAX5\n(weak/+)", shape=ellipse, fillcolor="#FFA726", fontcolor=white];
        RS_MUM1   [label="MUM1/IRF4\n(strong+)", shape=ellipse, fillcolor="#EF6C00", fontcolor=white];
        RS_OCT2   [label="OCT2\n(variable)", shape=ellipse, fillcolor="#FFA726"];
        RS_BSAP   [label="BSAP/PAX5\nloss of B-cell program", shape=ellipse, fillcolor="#E65100", fontcolor=white];
        RS_NOTCH1 [label="NOTCH1\nsignaling", shape=ellipse, fillcolor="#FF8F00", fontcolor=white];

        /* Genetic alterations */
        RS_9p24   [label="9p24.1\namplification", shape=diamond, fillcolor="#FFE0B2"];
        RS_2p16   [label="2p16.1\nREL amplification", shape=diamond, fillcolor="#FFE0B2"];
        RS_TNFAIP3[label="TNFAIP3 (A20)\nmutation/deletion", shape=diamond, fillcolor="#FFCCBC"];
        RS_CARD11 [label="CARD11\nactivating mutation", shape=diamond, fillcolor="#FFCCBC"];
        RS_B2M    [label="B2M\nmutation", shape=diamond, fillcolor="#FFCCBC"];

        /* Cytokine secretion */
        RS_IL13   [label="IL-13\nsecretion", shape=ellipse, fillcolor="#FFFDE7", color="#E65100"];
        RS_IL10   [label="IL-10\nsecretion", shape=ellipse, fillcolor="#FFFDE7", color="#E65100"];
        RS_TGFB   [label="TGF-β\nsecretion", shape=ellipse, fillcolor="#FFFDE7", color="#E65100"];
        RS_CCL17  [label="CCL17/TARC\nsecretion", shape=ellipse, fillcolor="#FFFDE7", color="#E65100"];
        RS_CCL22  [label="CCL22\nsecretion", shape=ellipse, fillcolor="#FFFDE7", color="#E65100"];
        RS_IL6    [label="IL-6\nsecretion", shape=ellipse, fillcolor="#FFFDE7", color="#E65100"];
        RS_CXCL13 [label="CXCL13\nsecretion", shape=ellipse, fillcolor="#FFFDE7", color="#E65100"];

        /* Cell fate */
        RS_prolif  [label="RS Cell\nProliferation", shape=box, fillcolor="#BF360C", fontcolor=white];
        RS_survival[label="RS Cell\nSurvival/Apoptosis\nResistance", shape=box, fillcolor="#BF360C", fontcolor=white];

        /* Internal connectivity */
        RS_PAX5   -> RS_BSAP      [label="drives", style=dashed];
        RS_MUM1   -> RS_prolif    [label="promotes"];
        RS_NOTCH1 -> RS_survival  [label="anti-apoptotic"];
        RS_9p24   -> RS_CD30      [label="amplifies\nexpression", color="#E65100"];
        RS_2p16   -> RS_survival  [label="REL→NF-κB"];
        RS_TNFAIP3-> RS_survival  [label="A20 loss→\nconstitutive NF-κB", color=red];
        RS_CARD11 -> RS_survival  [label="→NF-κB\nactivation"];
        RS_B2M    -> RS_MHC1      [label="disrupts", style=dashed, color=red];
        RS_IL13   -> RS_prolif    [label="autocrine", style=dotted];
        RS_CCL17  -> RS_prolif    [label="paracrine\nloop", style=dotted];
    }

    /* ============================================================
       CLUSTER 2: NF-κB Signaling Pathway
       ============================================================ */
    subgraph cluster_nfkb {
        label="NF-κB Signaling Pathway";
        style="filled,rounded";
        fillcolor="#E8EAF6";
        color="#283593";
        fontsize=12;
        fontcolor="#283593";
        fontname="Helvetica-Bold";

        /* Canonical pathway */
        NF_IKKgamma [label="IKKγ (NEMO)\nregulatory subunit", shape=box, fillcolor="#5C6BC0", fontcolor=white];
        NF_IKKalpha [label="IKKα\ncatalytic", shape=box, fillcolor="#5C6BC0", fontcolor=white];
        NF_IKKbeta  [label="IKKβ\ncatalytic", shape=box, fillcolor="#5C6BC0", fontcolor=white];
        NF_IKBa     [label="IκBα\ninhibitor\n(phosphorylated/degraded)", shape=box, fillcolor="#EF9A9A"];
        NF_p65      [label="p65 (RelA)\nNF-κB subunit", shape=ellipse, fillcolor="#3949AB", fontcolor=white];
        NF_p50      [label="p50\nNF-κB subunit", shape=ellipse, fillcolor="#3949AB", fontcolor=white];
        NF_p65p50   [label="p65:p50\nheterodimer\n(active)", shape=ellipse, fillcolor="#283593", fontcolor=white];

        /* Non-canonical pathway */
        NF_NIK      [label="NIK (MAP3K14)\nnon-canonical", shape=box, fillcolor="#7986CB", fontcolor=white];
        NF_IKKa2    [label="IKKα homodimer\nnon-canonical", shape=box, fillcolor="#7986CB", fontcolor=white];
        NF_RELB     [label="RelB\nnon-canonical", shape=ellipse, fillcolor="#3949AB", fontcolor=white];
        NF_p52      [label="p52 (from p100)\nnon-canonical", shape=ellipse, fillcolor="#3949AB", fontcolor=white];

        /* Target genes */
        NF_BCL2     [label="Bcl-2\nanti-apoptotic", shape=box, fillcolor="#C5CAE9"];
        NF_BCLxL    [label="Bcl-xL\nanti-apoptotic", shape=box, fillcolor="#C5CAE9"];
        NF_survivin [label="Survivin\n(BIRC5)\nIAP family", shape=box, fillcolor="#C5CAE9"];
        NF_XIAP     [label="XIAP\nIAP family", shape=box, fillcolor="#C5CAE9"];
        NF_cycD1    [label="Cyclin D1\ncell cycle", shape=box, fillcolor="#C5CAE9"];
        NF_MYC      [label="c-MYC\nproliferation", shape=box, fillcolor="#9FA8DA"];
        NF_IL6gene  [label="IL-6 gene\ntranscription", shape=box, fillcolor="#C5CAE9"];
        NF_CD30gene [label="CD30 gene\ntranscription", shape=box, fillcolor="#C5CAE9"];

        /* Pathway connections */
        NF_IKKgamma -> NF_IKKbeta  [label="recruits"];
        NF_IKKbeta  -> NF_IKBa     [label="phosphorylates\nSer32/Ser36", color="#283593"];
        NF_IKBa     -> NF_p65      [label="releases", style=dashed];
        NF_p65      -> NF_p65p50   [label="dimerizes"];
        NF_p50      -> NF_p65p50   [label="dimerizes"];
        NF_p65p50   -> NF_BCL2     [label="transcribes", color="#283593"];
        NF_p65p50   -> NF_BCLxL    [label="transcribes", color="#283593"];
        NF_p65p50   -> NF_survivin [label="transcribes", color="#283593"];
        NF_p65p50   -> NF_XIAP     [label="transcribes", color="#283593"];
        NF_p65p50   -> NF_cycD1    [label="transcribes", color="#283593"];
        NF_p65p50   -> NF_MYC      [label="transcribes", color="#283593"];
        NF_p65p50   -> NF_IL6gene  [label="transcribes", color="#283593"];
        NF_p65p50   -> NF_CD30gene [label="transcribes", color="#283593"];
        NF_NIK      -> NF_IKKa2    [label="activates"];
        NF_IKKa2    -> NF_p52      [label="p100→p52\nprocessing"];
        NF_RELB     -> NF_p52      [label="dimerizes"];
    }

    /* ============================================================
       CLUSTER 3: JAK/STAT Pathway
       ============================================================ */
    subgraph cluster_jak_stat {
        label="JAK/STAT Pathway";
        style="filled,rounded";
        fillcolor="#E0F2F1";
        color="#00695C";
        fontsize=12;
        fontcolor="#00695C";
        fontname="Helvetica-Bold";

        /* Receptors */
        JS_IL13Ra1  [label="IL-13Rα1\nchain", shape=box, fillcolor="#26A69A", fontcolor=white];
        JS_IL13Ra2  [label="IL-13Rα2\ndecoy receptor", shape=box, fillcolor="#80CBC4"];
        JS_IL4Ra    [label="IL-4Rα\nchain", shape=box, fillcolor="#26A69A", fontcolor=white];
        JS_gp130    [label="gp130 (IL6ST)\nIL-6 receptor", shape=box, fillcolor="#26A69A", fontcolor=white];
        JS_IL6Ra    [label="IL-6Rα\n(sIL-6R trans)", shape=box, fillcolor="#26A69A", fontcolor=white];

        /* JAKs */
        JS_JAK1     [label="JAK1\nkinase", shape=ellipse, fillcolor="#00796B", fontcolor=white];
        JS_JAK2     [label="JAK2\nkinase\n(9p24.1 amplified)", shape=ellipse, fillcolor="#00695C", fontcolor=white];
        JS_TYK2     [label="TYK2\nkinase", shape=ellipse, fillcolor="#00796B", fontcolor=white];

        /* STATs */
        JS_STAT3    [label="STAT3\n(phospho-Tyr705)", shape=ellipse, fillcolor="#004D40", fontcolor=white];
        JS_STAT5    [label="STAT5\nactivation", shape=ellipse, fillcolor="#004D40", fontcolor=white];
        JS_STAT6    [label="STAT6\n(IL-13/IL-4 driven)", shape=ellipse, fillcolor="#004D40", fontcolor=white];
        JS_pSTAT3   [label="pSTAT3 dimer\nnuclear", shape=ellipse, fillcolor="#1B5E20", fontcolor=white];
        JS_pSTAT6   [label="pSTAT6 dimer\nnuclear", shape=ellipse, fillcolor="#1B5E20", fontcolor=white];

        /* STAT target genes */
        JS_PDL1gene [label="PD-L1/PD-L2\ngene expression", shape=box, fillcolor="#B2DFDB"];
        JS_BCL2stat [label="Bcl-2\n(STAT3 target)", shape=box, fillcolor="#B2DFDB"];
        JS_MYCstat  [label="c-MYC\n(STAT3 target)", shape=box, fillcolor="#B2DFDB"];
        JS_SOCS1    [label="SOCS1\nnegative feedback", shape=box, fillcolor="#FFCCBC", color="#E65100"];
        JS_CCL17stat[label="CCL17/TARC\ngene expression", shape=box, fillcolor="#B2DFDB"];
        JS_GATA3    [label="GATA3\nTh2 transcription factor", shape=box, fillcolor="#B2DFDB"];

        /* Amplification */
        JS_9p24amp  [label="9p24.1 locus\nJAK2 + PDL1/PDL2\namplification", shape=diamond, fillcolor="#80CBC4"];

        /* Pathway flow */
        JS_IL13Ra1  -> JS_JAK1   [label="activates"];
        JS_IL4Ra    -> JS_JAK1   [label="activates"];
        JS_gp130    -> JS_JAK2   [label="activates"];
        JS_IL6Ra    -> JS_gp130  [label="complex"];
        JS_JAK1     -> JS_STAT3  [label="phosphorylates\nTyr705"];
        JS_JAK1     -> JS_STAT6  [label="phosphorylates"];
        JS_JAK2     -> JS_STAT3  [label="phosphorylates"];
        JS_JAK2     -> JS_STAT5  [label="phosphorylates"];
        JS_TYK2     -> JS_STAT3  [label="phosphorylates"];
        JS_STAT3    -> JS_pSTAT3 [label="dimerization\nnuclear transloc."];
        JS_STAT6    -> JS_pSTAT6 [label="dimerization\nnuclear transloc."];
        JS_pSTAT3   -> JS_PDL1gene  [label="transcribes"];
        JS_pSTAT3   -> JS_BCL2stat  [label="transcribes"];
        JS_pSTAT3   -> JS_MYCstat   [label="transcribes"];
        JS_pSTAT3   -> JS_SOCS1     [label="induces\n(feedback)", color="red"];
        JS_pSTAT6   -> JS_CCL17stat [label="transcribes"];
        JS_pSTAT6   -> JS_GATA3     [label="transcribes"];
        JS_SOCS1    -> JS_JAK2      [label="inhibits", color=red, style=dashed];
        JS_9p24amp  -> JS_JAK2      [label="amplified", color="#00695C", style=bold];
        JS_9p24amp  -> JS_PDL1gene  [label="copy number\ngain", color="#00695C", style=bold];
    }

    /* ============================================================
       CLUSTER 4: CD30/TNFRSF8 Signaling
       ============================================================ */
    subgraph cluster_cd30 {
        label="CD30 / TNFRSF8 Signaling";
        style="filled,rounded";
        fillcolor="#FCE4EC";
        color="#880E4F";
        fontsize=12;
        fontcolor="#880E4F";
        fontname="Helvetica-Bold";

        /* Ligand-receptor */
        CD30_L      [label="CD30L (CD153)\nexpressed on\nT cells, eosinophils", shape=box, fillcolor="#F48FB1"];
        CD30_R      [label="CD30 (TNFRSF8)\nRS cell surface\nhigh expression", shape=box, fillcolor="#AD1457", fontcolor=white];
        CD30_sCD30  [label="sCD30\n(shed ectodomain)\nserum biomarker", shape=ellipse, fillcolor="#F8BBD0", color="#880E4F"];

        /* Signal transducers */
        CD30_TRAF2  [label="TRAF2\nadaptor protein", shape=ellipse, fillcolor="#C2185B", fontcolor=white];
        CD30_TRAF3  [label="TRAF3\nadaptor protein", shape=ellipse, fillcolor="#C2185B", fontcolor=white];
        CD30_TRAF5  [label="TRAF5\nadaptor protein", shape=ellipse, fillcolor="#C2185B", fontcolor=white];
        CD30_RIP1   [label="RIP1 (RIPK1)\nnecrosome/NF-κB", shape=ellipse, fillcolor="#AD1457", fontcolor=white];

        /* Downstream effectors */
        CD30_AP1    [label="AP-1 (c-Jun/c-Fos)\ntranscription factor", shape=ellipse, fillcolor="#880E4F", fontcolor=white];
        CD30_ERK    [label="ERK1/2\nMAPK pathway", shape=ellipse, fillcolor="#880E4F", fontcolor=white];
        CD30_JNK    [label="JNK\nstress kinase", shape=ellipse, fillcolor="#880E4F", fontcolor=white];
        CD30_p38    [label="p38 MAPK\nstress response", shape=ellipse, fillcolor="#880E4F", fontcolor=white];

        /* Outcomes */
        CD30_prolif [label="Proliferation\nsurvival signals", shape=box, fillcolor="#F8BBD0"];
        CD30_cytok  [label="Cytokine\nproduction\nIL-13, CCL17", shape=box, fillcolor="#F8BBD0"];
        CD30_NF     [label="→ NF-κB\nactivation", shape=box, fillcolor="#FCE4EC", color="#283593"];

        /* Pathway */
        CD30_L   -> CD30_R     [label="binds", arrowhead=normal];
        CD30_R   -> CD30_sCD30 [label="metalloprotease\nshedding (ADAM10)", style=dashed];
        CD30_R   -> CD30_TRAF2 [label="recruits"];
        CD30_R   -> CD30_TRAF3 [label="recruits"];
        CD30_R   -> CD30_TRAF5 [label="recruits"];
        CD30_TRAF2 -> CD30_RIP1  [label="recruits"];
        CD30_TRAF2 -> CD30_AP1   [label="→ JNK→AP-1"];
        CD30_TRAF2 -> CD30_NF    [label="activates"];
        CD30_TRAF5 -> CD30_NF    [label="activates"];
        CD30_RIP1  -> CD30_ERK   [label="activates"];
        CD30_RIP1  -> CD30_JNK   [label="activates"];
        CD30_AP1   -> CD30_prolif [label="drives"];
        CD30_ERK   -> CD30_prolif [label="drives"];
        CD30_AP1   -> CD30_cytok  [label="induces"];
        CD30_p38   -> CD30_cytok  [label="induces"];
    }

    /* ============================================================
       CLUSTER 5: PD-1/PD-L1 Checkpoint
       ============================================================ */
    subgraph cluster_pdl1 {
        label="PD-1/PD-L1 Immune Checkpoint";
        style="filled,rounded";
        fillcolor="#EDE7F6";
        color="#4527A0";
        fontsize=12;
        fontcolor="#4527A0";
        fontname="Helvetica-Bold";

        /* T cell side */
        PD_TCR      [label="TCR\nT cell receptor complex", shape=box, fillcolor="#7E57C2", fontcolor=white];
        PD_CD28     [label="CD28\nco-stimulatory", shape=box, fillcolor="#7E57C2", fontcolor=white];
        PD_PD1      [label="PD-1 (CD279)\nT cell checkpoint receptor", shape=box, fillcolor="#4527A0", fontcolor=white];
        PD_SHP2     [label="SHP-2\nphosphatase\n(PD-1 recruited)", shape=ellipse, fillcolor="#673AB7", fontcolor=white];
        PD_CTLA4    [label="CTLA-4\nalternate checkpoint", shape=box, fillcolor="#5E35B1", fontcolor=white];

        /* T cell states */
        PD_Teff     [label="Effector T cell\n(CD8+ cytotoxic)", shape=box, fillcolor="#9575CD"];
        PD_Texh     [label="Exhausted T cell\nTOX+, LAG3+, TIM3+", shape=box, fillcolor="#B39DDB", color="#4527A0", style="filled,dashed"];
        PD_Tmem     [label="Memory T cell\n(CD8+/CD4+)", shape=box, fillcolor="#9575CD"];

        /* RS cell side */
        PD_PDL1_RS  [label="PD-L1 (CD274)\nRS cell\n(9p24.1 amplified)", shape=box, fillcolor="#4527A0", fontcolor=white];
        PD_PDL2_RS  [label="PD-L2 (CD273)\nRS cell", shape=box, fillcolor="#4527A0", fontcolor=white];

        /* Signaling consequences */
        PD_ZAP70    [label="ZAP70\nTCR signaling\n(blocked by SHP-2)", shape=ellipse, fillcolor="#EDE7F6", color="#4527A0"];
        PD_PI3K_inh [label="PI3K/Akt\n(inhibited)", shape=ellipse, fillcolor="#EDE7F6", color=red];
        PD_IFNg_inh [label="IFN-γ production\n(reduced)", shape=ellipse, fillcolor="#EDE7F6", color=red];
        PD_GrzmB    [label="Granzyme B\nperforin\n(reduced)", shape=ellipse, fillcolor="#EDE7F6", color=red];

        /* Checkpoint markers on exhausted T */
        PD_LAG3     [label="LAG-3\nexhaustion marker", shape=box, fillcolor="#D1C4E9"];
        PD_TIM3     [label="TIM-3\nexhaustion marker", shape=box, fillcolor="#D1C4E9"];
        PD_TOX      [label="TOX\nexhaustion TF", shape=ellipse, fillcolor="#D1C4E9"];

        /* Connections */
        PD_TCR    -> PD_ZAP70    [label="activates\n(normally)"];
        PD_PDL1_RS -> PD_PD1     [label="ligates", arrowhead=normal];
        PD_PDL2_RS -> PD_PD1     [label="ligates", arrowhead=normal];
        PD_PD1    -> PD_SHP2     [label="recruits", color="#4527A0"];
        PD_SHP2   -> PD_ZAP70    [label="dephosphorylates\n(inhibits)", color=red, arrowhead=tee];
        PD_SHP2   -> PD_PI3K_inh [label="inactivates", color=red, arrowhead=tee];
        PD_ZAP70  -> PD_IFNg_inh [label="→ reduced", style=dashed];
        PD_ZAP70  -> PD_GrzmB    [label="→ reduced", style=dashed];
        PD_Teff   -> PD_Texh     [label="chronic antigen\nexposure → exhaustion", style=dashed];
        PD_Texh   -> PD_LAG3     [label="expresses"];
        PD_Texh   -> PD_TIM3     [label="expresses"];
        PD_Texh   -> PD_TOX      [label="upregulates"];
        PD_CD28   -> PD_CTLA4    [label="feedback\ninduction", style=dashed];
    }

    /* ============================================================
       CLUSTER 6: EBV Pathogenesis
       ============================================================ */
    subgraph cluster_ebv {
        label="EBV Pathogenesis (EBV+ HL ~40%)";
        style="filled,rounded";
        fillcolor="#F3E5F5";
        color="#6A1B9A";
        fontsize=12;
        fontcolor="#6A1B9A";
        fontname="Helvetica-Bold";

        /* EBV latency proteins */
        EBV_LMP1    [label="LMP1\n(latent membrane protein 1)\nCD40 mimic", shape=box, fillcolor="#8E24AA", fontcolor=white];
        EBV_LMP2A   [label="LMP2A\nBCR mimic\nsurvival signal", shape=box, fillcolor="#8E24AA", fontcolor=white];
        EBV_EBNA1   [label="EBNA-1\nepigenetic\nimmune evasion", shape=box, fillcolor="#8E24AA", fontcolor=white];
        EBV_EBER    [label="EBERs\nnon-coding RNAs\ninnate immune evasion", shape=ellipse, fillcolor="#AB47BC", fontcolor=white];

        /* EBV miRNAs */
        EBV_miR_BHRF1 [label="BHRF1 miRNAs\napoptosis inhibition", shape=ellipse, fillcolor="#CE93D8"];
        EBV_miR_BART  [label="BART miRNAs\nimmune modulation", shape=ellipse, fillcolor="#CE93D8"];

        /* LMP1 signaling hubs */
        EBV_CTAR1   [label="CTAR1 domain\nTRAF2/3 binding", shape=ellipse, fillcolor="#7B1FA2", fontcolor=white];
        EBV_CTAR2   [label="CTAR2 domain\nTRAF6/TRADD\nbinding", shape=ellipse, fillcolor="#7B1FA2", fontcolor=white];

        /* LMP1 downstream */
        EBV_NF_act  [label="NF-κB\nconstit. activation\nvia LMP1", shape=box, fillcolor="#E1BEE7", color="#283593"];
        EBV_AP1_act [label="AP-1\nactivation\nvia LMP1", shape=box, fillcolor="#E1BEE7", color="#880E4F"];
        EBV_STAT_act[label="JAK/STAT\nactivation\nvia LMP1", shape=box, fillcolor="#E1BEE7", color="#00695C"];
        EBV_PI3K    [label="PI3K/Akt\nsurvival\nvia LMP2A", shape=box, fillcolor="#E1BEE7"];

        /* Viral immune evasion */
        EBV_BCRF1   [label="BCRF1 (vIL-10)\nimmune evasion", shape=box, fillcolor="#F3E5F5", color="#6A1B9A"];
        EBV_BNLF2a  [label="BNLF2a\nTAP inhibition\nMHC-I evasion", shape=box, fillcolor="#F3E5F5", color="#6A1B9A"];

        /* Connections */
        EBV_LMP1  -> EBV_CTAR1   [label="via N-terminus"];
        EBV_LMP1  -> EBV_CTAR2   [label="via C-terminus"];
        EBV_CTAR1 -> EBV_NF_act  [label="TRAF2→NF-κB"];
        EBV_CTAR2 -> EBV_NF_act  [label="TRADD→RIP→NF-κB"];
        EBV_CTAR1 -> EBV_AP1_act [label="→ JNK→AP-1"];
        EBV_LMP1  -> EBV_STAT_act [label="JAK3 activation"];
        EBV_LMP2A -> EBV_PI3K    [label="BCR mimic\n→ PI3K/Akt"];
        EBV_EBNA1 -> EBV_NF_act  [label="epigenetic\nactivation", style=dashed];
        EBV_miR_BHRF1 -> EBV_PI3K [label="→ apoptosis\nresistance", style=dashed];
        EBV_BCRF1 -> EBV_NF_act  [label="immune\nevasion", style=dashed];
        EBV_BNLF2a -> EBV_NF_act [label="MHC-I\ndown", style=dashed];
        EBV_EBER  -> EBV_NF_act  [label="TLR3 activation\n→ NF-κB", style=dashed];
    }

    /* ============================================================
       CLUSTER 7: Tumor Microenvironment
       ============================================================ */
    subgraph cluster_tme {
        label="Tumor Microenvironment (TME)";
        style="filled,rounded";
        fillcolor="#E8F5E9";
        color="#1B5E20";
        fontsize=12;
        fontcolor="#1B5E20";
        fontname="Helvetica-Bold";

        /* Immune cell populations */
        TME_CD4     [label="CD4+ T helper\ncells (abundant)", shape=box, fillcolor="#66BB6A", fontcolor=white];
        TME_CD8     [label="CD8+ Cytotoxic\nT lymphocytes\n(suppressed)", shape=box, fillcolor="#43A047", fontcolor=white];
        TME_Treg    [label="Tregs (FoxP3+)\nimmune suppression", shape=box, fillcolor="#2E7D32", fontcolor=white];
        TME_Th2     [label="Th2 cells\nIL-4/IL-13\nproducers", shape=box, fillcolor="#66BB6A", fontcolor=white];
        TME_M2mac   [label="M2 Macrophages\n(CD163+, CD206+)\nimmune suppressive", shape=box, fillcolor="#388E3C", fontcolor=white];
        TME_Eosin   [label="Eosinophils\n(abundant in HL)\nCCL11/eotaxin recruited", shape=box, fillcolor="#81C784"];
        TME_Mast    [label="Mast cells\nhistamine,\npro-tumor", shape=box, fillcolor="#81C784"];
        TME_Neutro  [label="Neutrophils\nTAN phenotype", shape=box, fillcolor="#A5D6A7"];
        TME_NK      [label="NK cells\n(CD56+, suppressed)", shape=box, fillcolor="#43A047", fontcolor=white];
        TME_Plasma  [label="Plasma cells\nIgG4+ subset", shape=box, fillcolor="#81C784"];
        TME_Fibro   [label="Cancer-Associated\nFibroblasts (CAF)\nstromal remodeling", shape=box, fillcolor="#4CAF50", fontcolor=white];
        TME_EC      [label="Endothelial cells\nangiogenesis", shape=box, fillcolor="#81C784"];

        /* Key cytokines in TME */
        TME_CXCL13  [label="CXCL13\n(B-cell chemokine)\nEosinophil recruit", shape=ellipse, fillcolor="#C8E6C9"];
        TME_CCL17   [label="CCL17/TARC\nTh2 recruitment\nserum biomarker", shape=ellipse, fillcolor="#C8E6C9"];
        TME_CCL22   [label="CCL22\nTreg recruitment", shape=ellipse, fillcolor="#C8E6C9"];
        TME_CCL11   [label="CCL11 (Eotaxin)\neosinophil chemo.", shape=ellipse, fillcolor="#C8E6C9"];
        TME_VEGF    [label="VEGF\nangiogenesis", shape=ellipse, fillcolor="#C8E6C9"];
        TME_TGFbTME [label="TGF-β\nTreg induction\nfibrosis", shape=ellipse, fillcolor="#C8E6C9"];
        TME_IL10TME [label="IL-10\nimmuno-\nsuppression", shape=ellipse, fillcolor="#C8E6C9"];
        TME_CSF1    [label="CSF1 (M-CSF)\nmacrophage\nrecruitment", shape=ellipse, fillcolor="#C8E6C9"];

        /* TME connectivity */
        TME_CCL17  -> TME_Th2    [label="recruits"];
        TME_CCL22  -> TME_Treg   [label="recruits"];
        TME_CCL11  -> TME_Eosin  [label="recruits"];
        TME_CXCL13 -> TME_Eosin  [label="recruits"];
        TME_CSF1   -> TME_M2mac  [label="differentiates"];
        TME_TGFbTME -> TME_Treg  [label="induces\nFoxP3+"];
        TME_TGFbTME -> TME_Fibro [label="activates CAF"];
        TME_VEGF   -> TME_EC     [label="angiogenic\nsignal"];
        TME_IL10TME -> TME_CD8   [label="suppresses", arrowhead=tee, color=red];
        TME_Treg   -> TME_CD8    [label="suppresses", arrowhead=tee, color=red];
        TME_M2mac  -> TME_CD8    [label="inhibits via\nArg1/IDO", arrowhead=tee, color=red];
        TME_M2mac  -> TME_IL10TME [label="secretes"];
        TME_M2mac  -> TME_TGFbTME [label="secretes"];
        TME_Fibro  -> TME_VEGF   [label="secretes"];
        TME_Mast   -> TME_TGFbTME [label="secretes"];
        TME_Th2    -> TME_IL10TME [label="secretes"];
        TME_CD4    -> TME_CD30_L [label="CD30L\nexpression"];
        TME_Eosin  -> TME_CD30_L [label="CD30L\nexpression"];
        TME_CD30_L [label="CD30L\nin TME cells", shape=ellipse, fillcolor="#C8E6C9"];
    }

    /* ============================================================
       CLUSTER 8: ABVD Drug Pharmacokinetics
       ============================================================ */
    subgraph cluster_abvd {
        label="ABVD Chemotherapy PK/PD";
        style="filled,rounded";
        fillcolor="#FFF8E1";
        color="#F57F17";
        fontsize=12;
        fontcolor="#F57F17";
        fontname="Helvetica-Bold";

        /* Doxorubicin (A) */
        ABVD_DOX_iv   [label="Doxorubicin\nIV bolus\n25 mg/m²", shape=box, fillcolor="#F57F17", fontcolor=white];
        ABVD_DOX_C1   [label="Dox Central\nCompartment\n(V1=21.8 L)", shape=ellipse, fillcolor="#FF8F00", fontcolor=white];
        ABVD_DOX_C2   [label="Dox Peripheral\nCompartment\n(V2=573 L)", shape=ellipse, fillcolor="#FFA000", fontcolor=white];
        ABVD_DOX_meta [label="Doxorubicinol\nactive metabolite\n(13-OH-Dox)", shape=box, fillcolor="#FFB300"];
        ABVD_DOX_topo [label="Topo-II\ninhibition\nDNA intercalation", shape=box, fillcolor="#FFCA28"];
        ABVD_DOX_ROS  [label="ROS generation\nfree radicals\ncardiotoxicity", shape=box, fillcolor="#FFCA28"];

        /* Bleomycin (B) */
        ABVD_BLM_iv   [label="Bleomycin\nIV infusion\n10 units/m²", shape=box, fillcolor="#F57F17", fontcolor=white];
        ABVD_BLM_C1   [label="Bleomycin\nCentral (V=7L)\n(t1/2 β ~2h)", shape=ellipse, fillcolor="#FFA000"];
        ABVD_BLM_DNA  [label="DNA single/\ndouble strand\nbreaks", shape=box, fillcolor="#FFCA28"];
        ABVD_BLM_lung [label="Pulmonary\ntoxicity\n(Bleomycin hydrolase↓)", shape=box, fillcolor="#FFECB3", color="red"];

        /* Vinblastine (V) */
        ABVD_VBL_iv   [label="Vinblastine\nIV bolus\n6 mg/m²", shape=box, fillcolor="#F57F17", fontcolor=white];
        ABVD_VBL_C1   [label="Vinblastine\n3-compartment\nCL=35 L/h", shape=ellipse, fillcolor="#FFA000"];
        ABVD_VBL_tub  [label="β-tubulin\nbinding\nmitotic arrest", shape=box, fillcolor="#FFCA28"];
        ABVD_VBL_GI   [label="GI toxicity\nneuropathy", shape=box, fillcolor="#FFECB3", color="orange"];

        /* Dacarbazine (D) */
        ABVD_DTIC_iv  [label="Dacarbazine\nIV infusion\n375 mg/m²", shape=box, fillcolor="#F57F17", fontcolor=white];
        ABVD_DTIC_C1  [label="Dacarbazine\n(prodrug)\nCL=300 mL/min", shape=ellipse, fillcolor="#FFA000"];
        ABVD_MTIC     [label="MTIC\n(5-(3-methyltriazen-1-yl)-\nimidazole-4-carboxamide)\nactive metabolite", shape=box, fillcolor="#FFB300"];
        ABVD_AIC      [label="AIC metabolite\nDNA methylation\nalkylation", shape=box, fillcolor="#FFCA28"];

        /* PK flows */
        ABVD_DOX_iv   -> ABVD_DOX_C1  [label="IV bolus\nCL=43 L/h"];
        ABVD_DOX_C1   -> ABVD_DOX_C2  [label="Q=10 L/h", style=dashed];
        ABVD_DOX_C2   -> ABVD_DOX_C1  [label="Q=10 L/h", style=dashed];
        ABVD_DOX_C1   -> ABVD_DOX_meta [label="CYP3A4/\nAKR1C3"];
        ABVD_DOX_C1   -> ABVD_DOX_topo [label="distributes\nto tumor"];
        ABVD_DOX_C1   -> ABVD_DOX_ROS  [label="redox\ncycling"];

        ABVD_BLM_iv   -> ABVD_BLM_C1  [label="IV infusion\nrenal elim."];
        ABVD_BLM_C1   -> ABVD_BLM_DNA [label="Fe²⁺-mediated\nO₂ radicals"];
        ABVD_BLM_C1   -> ABVD_BLM_lung [label="accumulates\nin lung"];

        ABVD_VBL_iv   -> ABVD_VBL_C1  [label="IV bolus\nCYP3A4"];
        ABVD_VBL_C1   -> ABVD_VBL_tub [label="vinca alkaloid\nbinding"];
        ABVD_VBL_C1   -> ABVD_VBL_GI  [label="toxicity"];

        ABVD_DTIC_iv  -> ABVD_DTIC_C1 [label="prodrug\nactivation"];
        ABVD_DTIC_C1  -> ABVD_MTIC    [label="hepatic\nmetabolism"];
        ABVD_MTIC     -> ABVD_AIC     [label="spontaneous\ndegradation"];
    }

    /* ============================================================
       CLUSTER 9: Brentuximab Vedotin PK/PD
       ============================================================ */
    subgraph cluster_bv {
        label="Brentuximab Vedotin (ADC) PK/PD";
        style="filled,rounded";
        fillcolor="#E1F5FE";
        color="#01579B";
        fontsize=12;
        fontcolor="#01579B";
        fontname="Helvetica-Bold";

        /* BV dosing */
        BV_dose     [label="Brentuximab Vedotin\n1.8 mg/kg IV q3w", shape=box, fillcolor="#0277BD", fontcolor=white];
        BV_ADC_C1   [label="ADC Central\nCompartment\nV1=3.05 L", shape=ellipse, fillcolor="#0288D1", fontcolor=white];
        BV_ADC_C2   [label="ADC Peripheral\nV2=8.64 L", shape=ellipse, fillcolor="#039BE5", fontcolor=white];
        BV_MMAE_C1  [label="Free MMAE\nCentral\nCL=19.9 L/h", shape=ellipse, fillcolor="#0277BD", fontcolor=white];
        BV_MMAE_C2  [label="Free MMAE\nPeripheral\nV2=672 L", shape=ellipse, fillcolor="#039BE5", fontcolor=white];

        /* ADC mechanism */
        BV_bind_CD30 [label="ADC binds CD30\non RS cell surface", shape=box, fillcolor="#B3E5FC"];
        BV_intern    [label="CD30-ADC complex\ninternalization\n(clathrin-mediated)", shape=box, fillcolor="#B3E5FC"];
        BV_lyso      [label="Lysosomal\ndegradation of\nantibody linker", shape=box, fillcolor="#B3E5FC"];
        BV_MMAE_rel  [label="MMAE release\nintracellular\n(vcMMAE linker)", shape=box, fillcolor="#81D4FA"];
        BV_bystander [label="Bystander killing\nMMAE diffusion\nto adjacent cells", shape=box, fillcolor="#81D4FA"];

        /* MMAE mechanism */
        BV_tubulin   [label="β-tubulin binding\nby MMAE", shape=box, fillcolor="#29B6F6"];
        BV_Gstop     [label="G2/M arrest\nmitotic catastrophe", shape=box, fillcolor="#03A9F4", fontcolor=white];
        BV_apoptosis [label="Apoptosis\ncaspase activation", shape=box, fillcolor="#0288D1", fontcolor=white];

        /* DAR and pharmacology */
        BV_DAR      [label="Drug:Antibody Ratio\nDAR=8 (avg)\nvcMMAE linker", shape=diamond, fillcolor="#E1F5FE", color="#01579B"];
        BV_pgp      [label="P-gp efflux\nMMAE resistance\n(MDR1/ABCB1)", shape=box, fillcolor="#E1F5FE", color="red"];

        /* PK flows */
        BV_dose     -> BV_ADC_C1   [label="IV infusion\n30 min", arrowhead=normal];
        BV_ADC_C1   -> BV_ADC_C2   [label="Q=1.25 L/h"];
        BV_ADC_C2   -> BV_ADC_C1   [label="Q=1.25 L/h"];
        BV_ADC_C1   -> BV_MMAE_C1  [label="deconjugation\nCL=0.84 L/h"];
        BV_MMAE_C1  -> BV_MMAE_C2  [label="Q=19 L/h"];
        BV_MMAE_C2  -> BV_MMAE_C1  [label="Q=19 L/h"];
        BV_ADC_C1   -> BV_bind_CD30 [label="target-mediated\nuptake"];
        BV_bind_CD30 -> BV_intern   [label="endocytosis"];
        BV_intern   -> BV_lyso      [label="trafficking"];
        BV_lyso     -> BV_MMAE_rel  [label="cathepsin B\ncleavage"];
        BV_MMAE_rel -> BV_tubulin   [label="intracellular\neffect"];
        BV_MMAE_rel -> BV_bystander [label="membrane\ndiffusion"];
        BV_tubulin  -> BV_Gstop     [label="→ mitotic\narrest"];
        BV_Gstop    -> BV_apoptosis [label="caspase\ncascade"];
        BV_DAR      -> BV_ADC_C1    [label="defines\npayload loading", style=dashed];
        BV_pgp      -> BV_MMAE_rel  [label="effluxes MMAE\n(resistance)", style=dashed, color=red];
    }

    /* ============================================================
       CLUSTER 10: Anti-PD-1 Therapy (Pembrolizumab)
       ============================================================ */
    subgraph cluster_pembrolizumab {
        label="Pembrolizumab (Anti-PD-1) PK/PD";
        style="filled,rounded";
        fillcolor="#F1F8E9";
        color="#33691E";
        fontsize=12;
        fontcolor="#33691E";
        fontname="Helvetica-Bold";

        /* Dosing */
        PEM_dose    [label="Pembrolizumab\n200 mg IV q3w\n(or 2 mg/kg)", shape=box, fillcolor="#558B2F", fontcolor=white];
        PEM_C1      [label="Pembrolizumab\nCentral (V1=3.7 L)\ntarget: PD-1", shape=ellipse, fillcolor="#689F38", fontcolor=white];
        PEM_C2      [label="Pembrolizumab\nPeripheral\nV2=3.9 L", shape=ellipse, fillcolor="#7CB342", fontcolor=white];

        /* PD-1 binding and occupancy */
        PEM_bind    [label="PD-1 binding\n(KD ~0.2 nM)\n>90% receptor\noccupancy", shape=box, fillcolor="#DCEDC8"];
        PEM_RO      [label="PD-1 Receptor\nOccupancy (%)\nPK/PD model", shape=diamond, fillcolor="#C5E1A5", color="#33691E"];

        /* Immune reactivation */
        PEM_Treact  [label="T cell\nreactivation\nIFN-γ production", shape=box, fillcolor="#AED581"];
        PEM_IL2     [label="IL-2\nproliferation\nsignal restored", shape=ellipse, fillcolor="#C5E1A5"];
        PEM_IFNg    [label="IFN-γ\ntumor cell killing\nMHC-I upregulation", shape=ellipse, fillcolor="#C5E1A5"];
        PEM_CD8_act [label="CD8+ T cell\nactivation\nGranzyme B+", shape=box, fillcolor="#8BC34A", fontcolor=white];

        /* Efficacy */
        PEM_ORR     [label="ORR ~87%\nrelapsed/refractory\nHL (KEYNOTE-087)", shape=box, fillcolor="#DCEDC8"];
        PEM_CR      [label="CR rate ~17%\nPartial response\n~70%", shape=box, fillcolor="#DCEDC8"];

        /* irAEs */
        PEM_irae    [label="Immune-related\nAdverse Events (irAE)\npneumonitis, colitis", shape=box, fillcolor="#FFCCBC", color="red"];
        PEM_thyroid [label="Thyroid\ndysfunction\n(common irAE)", shape=box, fillcolor="#FFCCBC", color="orange"];

        /* Flows */
        PEM_dose  -> PEM_C1     [label="IV 30-min\ninfusion"];
        PEM_C1    -> PEM_C2     [label="Q=0.65 L/day"];
        PEM_C2    -> PEM_C1     [label="Q=0.65 L/day"];
        PEM_C1    -> PEM_bind   [label="binds PD-1\non T cells"];
        PEM_bind  -> PEM_RO     [label="Emax model\nEC50=~0.1 μg/mL"];
        PEM_RO    -> PEM_Treact [label="blockade\nreactivates"];
        PEM_Treact -> PEM_IL2   [label="secretes"];
        PEM_Treact -> PEM_IFNg  [label="secretes"];
        PEM_Treact -> PEM_CD8_act [label="expands"];
        PEM_CD8_act -> PEM_ORR  [label="tumor killing\n→ response"];
        PEM_ORR   -> PEM_CR     [label="subset achieve\nCR"];
        PEM_Treact -> PEM_irae  [label="off-tumor\nimmune\nactivation", color=red];
        PEM_irae  -> PEM_thyroid [label="includes", style=dashed];
    }

    /* ============================================================
       CLUSTER 11: Bone Marrow Toxicity
       ============================================================ */
    subgraph cluster_bm_toxicity {
        label="Bone Marrow Toxicity & Myelosuppression";
        style="filled,rounded";
        fillcolor="#FFEBEE";
        color="#B71C1C";
        fontsize=12;
        fontcolor="#B71C1C";
        fontname="Helvetica-Bold";

        /* Cell hierarchy */
        BM_HSC      [label="Hematopoietic\nStem Cells (HSC)\nquiescent pool", shape=box, fillcolor="#EF9A9A", color="#B71C1C"];
        BM_CMP      [label="Common Myeloid\nProgenitor (CMP)", shape=box, fillcolor="#EF9A9A"];
        BM_GMP      [label="Granulocyte-Monocyte\nProgenitor (GMP)", shape=box, fillcolor="#EF9A9A"];
        BM_MEP      [label="Megakaryocyte-\nErythroid Progenitor", shape=box, fillcolor="#EF9A9A"];

        /* Mature cells */
        BM_ANC      [label="ANC\n(Absolute Neutrophil\nCount) /μL", shape=diamond, fillcolor="#C62828", fontcolor=white];
        BM_PLT      [label="Platelet count\n(/μL)", shape=diamond, fillcolor="#C62828", fontcolor=white];
        BM_Hgb      [label="Hemoglobin\n(g/dL)", shape=diamond, fillcolor="#C62828", fontcolor=white];

        /* Toxicity grades */
        BM_nadir    [label="ANC Nadir\nDay 10-14 post-chemo\nNadir model (Friberg)", shape=box, fillcolor="#D32F2F", fontcolor=white];
        BM_G3G4     [label="Grade 3/4\nNeutropenia\nANC <1000/μL", shape=box, fillcolor="#B71C1C", fontcolor=white];
        BM_febrile  [label="Febrile\nNeutropenia\nrisk assessment", shape=box, fillcolor="#B71C1C", fontcolor=white];

        /* Growth factors */
        BM_GCSF     [label="G-CSF (Filgrastim/\nPegfilgrastim)\n6 mg SC day 3-4", shape=box, fillcolor="#FFCDD2"];
        BM_GCSF_R   [label="G-CSF Receptor\n(CSF3R)\ngranulopoiesis", shape=ellipse, fillcolor="#FFCDD2"];
        BM_EPO      [label="Erythropoietin\n(EPO)\nerythropoiesis", shape=box, fillcolor="#FFCDD2"];
        BM_TPO      [label="Thrombopoietin\n(TPO)\nplatelet production", shape=box, fillcolor="#FFCDD2"];

        /* Friberg model parameters */
        BM_transit  [label="Transit compartments\nmaturation delay\n(MTT ~5 days)", shape=box, fillcolor="#FFEBEE", color="#B71C1C"];
        BM_ktr      [label="ktr = 4/MTT\ntransit rate constant", shape=ellipse, fillcolor="#FFEBEE", color="#B71C1C"];
        BM_slope    [label="Drug effect\nSlope=0.18 L/μg\n(doxorubicin)", shape=ellipse, fillcolor="#FFEBEE", color="#B71C1C"];

        /* Connections */
        BM_HSC    -> BM_CMP     [label="differentiation\nself-renewal"];
        BM_CMP    -> BM_GMP     [label="→ granulocytes"];
        BM_CMP    -> BM_MEP     [label="→ RBC/platelets"];
        BM_GMP    -> BM_ANC     [label="→ neutrophils\n(14-day maturation)"];
        BM_MEP    -> BM_PLT     [label="→ megakaryocytes\n→ platelets"];
        BM_MEP    -> BM_Hgb     [label="→ erythrocytes"];
        BM_ANC    -> BM_nadir   [label="tracked by\nFriberg model"];
        BM_nadir  -> BM_G3G4    [label="if ANC<1000/μL"];
        BM_G3G4   -> BM_febrile [label="fever +\nneutropenia"];
        BM_GCSF   -> BM_GCSF_R [label="activates"];
        BM_GCSF_R -> BM_GMP    [label="accelerates\nmaturation"];
        BM_GCSF   -> BM_ANC    [label="increases\nANC", color="green"];
        BM_EPO    -> BM_MEP    [label="erythroid\nstimulation"];
        BM_TPO    -> BM_MEP    [label="thrombopoietic\nstimulation"];
        BM_transit -> BM_nadir [label="determines\ntiming"];
        BM_ktr    -> BM_transit [label="parameterizes"];
        BM_slope  -> BM_nadir  [label="E-Friberg\ndrug effect"];
    }

    /* ============================================================
       CLUSTER 12: Clinical Endpoints & Disease Assessment
       ============================================================ */
    subgraph cluster_endpoints {
        label="Clinical Endpoints & Disease Assessment";
        style="filled,rounded";
        fillcolor="#E3F2FD";
        color="#0D47A1";
        fontsize=12;
        fontcolor="#0D47A1";
        fontname="Helvetica-Bold";

        /* Staging */
        EP_AnnArbor [label="Ann Arbor\nStage I-IV\nwith B symptoms", shape=box, fillcolor="#1565C0", fontcolor=white];
        EP_IPS      [label="International\nPrognostic Score (IPS)\n0-7 factors", shape=box, fillcolor="#1565C0", fontcolor=white];
        EP_GHSG     [label="GHSG Risk\nEarly/Intermediate/\nAdvanced", shape=box, fillcolor="#1565C0", fontcolor=white];

        /* PET imaging */
        EP_PET_CT   [label="PET-CT\n(FDG-PET)", shape=box, fillcolor="#1976D2", fontcolor=white];
        EP_SUVmax   [label="SUVmax\n(standardized uptake\nvalue maximum)", shape=diamond, fillcolor="#1565C0", fontcolor=white];
        EP_Deauville[label="Deauville Score\n1-5 scale\n(D1=no uptake;\nD5>liver)", shape=diamond, fillcolor="#0D47A1", fontcolor=white];
        EP_interim  [label="Interim PET\n(iPET2/iPET4)\nresponse-adapted\ntherapy", shape=box, fillcolor="#42A5F5"];
        EP_ePET     [label="End-of-treatment\nPET\n(ePET)", shape=box, fillcolor="#42A5F5"];

        /* Lab biomarkers */
        EP_LDH      [label="LDH\n(lactate dehydrogenase)\ntumor burden marker", shape=diamond, fillcolor="#1976D2", fontcolor=white];
        EP_albumin  [label="Serum Albumin\n<4 g/dL → IPS factor", shape=diamond, fillcolor="#64B5F6"];
        EP_Hgb_EP   [label="Hemoglobin\n<10.5 g/dL (F)\n<12 g/dL (M)", shape=diamond, fillcolor="#64B5F6"];
        EP_WBC      [label="WBC\n>15×10⁹/L → IPS", shape=diamond, fillcolor="#64B5F6"];
        EP_lymph    [label="Lymphocyte %\n<8% or <0.6×10⁹/L\n→ IPS factor", shape=diamond, fillcolor="#64B5F6"];
        EP_TARC     [label="TARC/CCL17\nserum biomarker\nprognostic", shape=diamond, fillcolor="#64B5F6"];
        EP_beta2m   [label="β2-microglobulin\nserum biomarker", shape=diamond, fillcolor="#64B5F6"];

        /* Tumor volume */
        EP_bulk     [label="Bulky disease\n>10 cm or\n>1/3 thoracic width", shape=box, fillcolor="#42A5F5"];
        EP_MTV      [label="Metabolic\nTumor Volume (MTV)\nfrom PET-CT", shape=diamond, fillcolor="#64B5F6"];
        EP_TLG      [label="Total Lesion\nGlycolysis (TLG)\nSUVmean×MTV", shape=diamond, fillcolor="#64B5F6"];

        /* B symptoms */
        EP_Bsymp    [label="B Symptoms\nFever >38°C\nNight sweats\nWeight loss >10%", shape=box, fillcolor="#1976D2", fontcolor=white];
        EP_pruritis [label="Pruritus\n(Pel-Ebstein fever)", shape=box, fillcolor="#64B5F6"];

        /* Response criteria */
        EP_CR_resp  [label="Complete Response\n(CR)\nDeauville 1-3", shape=box, fillcolor="#0D47A1", fontcolor=white];
        EP_PR_resp  [label="Partial Response\n(PR)\nDeauville 4 + ≥50%\nSPD reduction", shape=box, fillcolor="#1565C0", fontcolor=white];
        EP_PD_resp  [label="Progressive Disease\n(PD)\nDeauville 5 + new\nlesions", shape=box, fillcolor="#B71C1C", fontcolor=white];

        /* Survival endpoints */
        EP_PFS      [label="PFS\n(Progression-Free\nSurvival)", shape=box, fillcolor="#0D47A1", fontcolor=white];
        EP_OS       [label="OS\n(Overall Survival)\n5-yr ~85% Stage I-II", shape=box, fillcolor="#0D47A1", fontcolor=white];
        EP_EFS      [label="Event-Free Survival\n(EFS)\nincl. treatment\nfailures", shape=box, fillcolor="#1565C0", fontcolor=white];

        /* Connections */
        EP_AnnArbor -> EP_IPS     [label="staging\ncomponent"];
        EP_IPS      -> EP_GHSG    [label="risk\nstratification"];
        EP_PET_CT   -> EP_SUVmax  [label="measures"];
        EP_PET_CT   -> EP_MTV     [label="quantifies"];
        EP_PET_CT   -> EP_TLG     [label="quantifies"];
        EP_SUVmax   -> EP_Deauville [label="compared to\nliver/mediastinum"];
        EP_MTV      -> EP_TLG     [label="component"];
        EP_Deauville -> EP_interim [label="assessed at\ncycle 2/4"];
        EP_Deauville -> EP_ePET   [label="assessed\npost-treatment"];
        EP_interim  -> EP_CR_resp  [label="D1-3 → CR"];
        EP_interim  -> EP_PR_resp  [label="D4 + SPD↓"];
        EP_interim  -> EP_PD_resp  [label="D5 + new\nlesions"];
        EP_LDH      -> EP_IPS     [label="IPS factor"];
        EP_albumin  -> EP_IPS     [label="IPS factor"];
        EP_Hgb_EP   -> EP_IPS     [label="IPS factor"];
        EP_WBC      -> EP_IPS     [label="IPS factor"];
        EP_lymph    -> EP_IPS     [label="IPS factor"];
        EP_TARC     -> EP_CR_resp  [label="normalization\n→ CR marker", style=dashed];
        EP_CR_resp  -> EP_PFS     [label="impacts\npositively"];
        EP_PR_resp  -> EP_PFS     [label="partial\nimpact"];
        EP_PD_resp  -> EP_PFS     [label="determines\nfailure", color=red];
        EP_PFS      -> EP_OS      [label="surrogate\nendpoint"];
        EP_EFS      -> EP_OS      [label="treatment\nfailures", style=dashed];
        EP_Bsymp    -> EP_AnnArbor [label="suffix B\ndesignation"];
        EP_pruritis -> EP_Bsymp   [label="associated"];
        EP_bulk     -> EP_GHSG    [label="adverse\nfactor"];
    }

    /* ============================================================
       INTER-CLUSTER CONNECTIONS
       ============================================================ */

    /* RS Cell -> NF-κB */
    RS_TNFAIP3 -> NF_IKBa    [label="A20 loss →\nIκBα degradation\n(constitutive NF-κB)", lhead=cluster_nfkb, color="#283593", style=bold, ltail=cluster_rs_cell];
    RS_CARD11  -> NF_IKKgamma [label="→ IKK complex\nactivation", color="#283593", ltail=cluster_rs_cell, lhead=cluster_nfkb];

    /* NF-κB -> RS Cell survival */
    NF_BCL2    -> RS_survival  [label="anti-apoptotic\noutcome", lhead=cluster_rs_cell, ltail=cluster_nfkb, color="#E65100"];
    NF_survivin -> RS_survival [label="IAP\nprotection", lhead=cluster_rs_cell, ltail=cluster_nfkb, color="#E65100"];
    NF_cycD1   -> RS_prolif    [label="cell cycle\npromotion", lhead=cluster_rs_cell, ltail=cluster_nfkb, color="#E65100"];

    /* RS Cell cytokines -> JAK/STAT */
    RS_IL13 -> JS_IL13Ra1 [label="autocrine/paracrine\nIL-13 → JAK/STAT6", color="#00695C", ltail=cluster_rs_cell, lhead=cluster_jak_stat];
    RS_IL6  -> JS_gp130   [label="IL-6 → gp130 →\nJAK2/STAT3", color="#00695C", ltail=cluster_rs_cell, lhead=cluster_jak_stat];

    /* JAK/STAT -> NF-κB crosstalk */
    JS_pSTAT3 -> NF_p65p50  [label="STAT3-NF-κB\ncrosstalk", style=dashed, color="#283593", ltail=cluster_jak_stat, lhead=cluster_nfkb];

    /* JAK/STAT -> PD-L1 on RS */
    JS_PDL1gene -> PD_PDL1_RS [label="PD-L1 protein\nexpression", color="#4527A0", ltail=cluster_jak_stat, lhead=cluster_pdl1];
    RS_9p24    -> PD_PDL1_RS  [label="9p24.1 amp. →\nPD-L1 overexpr.", color="#4527A0", ltail=cluster_rs_cell, lhead=cluster_pdl1];

    /* EBV -> NF-κB / JAK-STAT */
    EBV_NF_act  -> NF_p65p50  [label="constitutive\nNF-κB via LMP1", color="#283593", ltail=cluster_ebv, lhead=cluster_nfkb];
    EBV_STAT_act -> JS_STAT3  [label="LMP1 →\nJAK3→STAT3", color="#00695C", ltail=cluster_ebv, lhead=cluster_jak_stat];

    /* CD30 -> NF-κB */
    CD30_NF -> NF_IKKgamma [label="TRAF2→IKK\nactivation", color="#283593", ltail=cluster_cd30, lhead=cluster_nfkb];

    /* RS cell -> TME cytokines */
    RS_CCL17 -> TME_CCL17  [label="secreted into\nTME", ltail=cluster_rs_cell, lhead=cluster_tme, color="#1B5E20"];
    RS_CCL22 -> TME_CCL22  [label="secreted into\nTME", ltail=cluster_rs_cell, lhead=cluster_tme, color="#1B5E20"];
    RS_IL10  -> TME_IL10TME [label="immunosuppressive\ncytokine", ltail=cluster_rs_cell, lhead=cluster_tme, color="#1B5E20"];
    RS_TGFB  -> TME_TGFbTME [label="fibrosis / Treg\ninduction", ltail=cluster_rs_cell, lhead=cluster_tme, color="#1B5E20"];
    RS_CXCL13 -> TME_CXCL13 [label="chemokine\nTME", ltail=cluster_rs_cell, lhead=cluster_tme, color="#1B5E20"];

    /* TME -> CD30 (CD30L from TME cells) */
    TME_CD30_L -> CD30_L   [label="activates CD30\non RS cells", ltail=cluster_tme, lhead=cluster_cd30, color="#880E4F"];

    /* PD-1/PD-L1 -> TME */
    PD_Texh -> TME_CD8     [label="exhausted CTL\nin TME", ltail=cluster_pdl1, lhead=cluster_tme, color="#1B5E20"];
    TME_Treg -> PD_CTLA4   [label="Treg → CTLA4\nupregulated", ltail=cluster_tme, lhead=cluster_pdl1, color="#4527A0"];

    /* ABVD -> BM Toxicity */
    ABVD_DOX_C1 -> BM_HSC  [label="cytotoxicity\nproliferating cells", color="#B71C1C", ltail=cluster_abvd, lhead=cluster_bm_toxicity];
    ABVD_VBL_tub -> BM_GMP [label="mitotic arrest\nmyelosuppression", color="#B71C1C", ltail=cluster_abvd, lhead=cluster_bm_toxicity];
    ABVD_DOX_C1 -> BM_slope [label="drug conc.\ndrives E-Friberg", color="#B71C1C", ltail=cluster_abvd, lhead=cluster_bm_toxicity];

    /* ABVD -> Tumor kill */
    ABVD_DOX_topo -> RS_survival [label="inhibits Topo-II\n→ DNA damage\n→ apoptosis", color=red, arrowhead=tee, ltail=cluster_abvd, lhead=cluster_rs_cell];
    ABVD_BLM_DNA  -> RS_survival [label="DSBs →\napoptosis", color=red, arrowhead=tee, ltail=cluster_abvd, lhead=cluster_rs_cell];
    ABVD_VBL_tub  -> RS_prolif   [label="mitotic arrest\nRS cells", color=red, arrowhead=tee, ltail=cluster_abvd, lhead=cluster_rs_cell];
    ABVD_AIC      -> RS_survival [label="DNA methylation\nalkylation", color=red, arrowhead=tee, ltail=cluster_abvd, lhead=cluster_rs_cell];

    /* Brentuximab -> CD30 on RS */
    BV_bind_CD30 -> RS_CD30 [label="ADC targets\nCD30 on RS cells", color="#01579B", ltail=cluster_bv, lhead=cluster_rs_cell];
    BV_apoptosis -> RS_survival [label="MMAE-induced\napoptosis", color=red, arrowhead=tee, ltail=cluster_bv, lhead=cluster_rs_cell];

    /* Pembrolizumab -> PD-1 on T cells */
    PEM_bind -> PD_PD1    [label="blocks PD-1\nreceptor", color="#33691E", ltail=cluster_pembrolizumab, lhead=cluster_pdl1];
    PEM_CD8_act -> TME_CD8 [label="reactivated\nCTL in TME", color="#1B5E20", ltail=cluster_pembrolizumab, lhead=cluster_tme];

    /* Clinical endpoints <- Tumor biology */
    RS_prolif   -> EP_LDH    [label="cell turnover\n→ LDH release", color="#0D47A1", ltail=cluster_rs_cell, lhead=cluster_endpoints];
    RS_survival -> EP_SUVmax [label="metabolic\nactivity → FDG", color="#0D47A1", ltail=cluster_rs_cell, lhead=cluster_endpoints];
    RS_IL6      -> EP_LDH    [label="IL-6 drives\nLDH", color="#0D47A1", ltail=cluster_rs_cell, lhead=cluster_endpoints];
    RS_CCL17    -> EP_TARC   [label="TARC serum\nlevel", color="#0D47A1", ltail=cluster_rs_cell, lhead=cluster_endpoints];
    BM_ANC      -> EP_Hgb_EP [label="cytopenias\nassessed", color="#0D47A1", ltail=cluster_bm_toxicity, lhead=cluster_endpoints];

    /* Drug effects -> Endpoints */
    ABVD_DOX_topo -> EP_CR_resp [label="cytotoxic\neffect → CR", style=dashed, color="#0D47A1", ltail=cluster_abvd, lhead=cluster_endpoints];
    BV_apoptosis   -> EP_CR_resp [label="BV → CR\nin R/R HL", style=dashed, color="#0D47A1", ltail=cluster_bv, lhead=cluster_endpoints];
    PEM_ORR        -> EP_PFS     [label="response →\nPFS benefit", style=dashed, color="#0D47A1", ltail=cluster_pembrolizumab, lhead=cluster_endpoints];

    /* B symptoms */
    RS_IL6 -> EP_Bsymp  [label="IL-6 → fever,\nconstitutional sx", color="#0D47A1", ltail=cluster_rs_cell, lhead=cluster_endpoints];
    RS_IL10 -> EP_Bsymp [label="systemic\ncytokines", color="#0D47A1", ltail=cluster_rs_cell, lhead=cluster_endpoints];

    /* EBV -> Endpoints */
    EBV_LMP1 -> EP_IPS  [label="EBV+ → modified\nrisk stratification", style=dashed, color="#0D47A1", ltail=cluster_ebv, lhead=cluster_endpoints];

} /* end digraph */
