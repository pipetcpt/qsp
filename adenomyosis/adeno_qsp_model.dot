digraph Adenomyosis_QSP {
  graph [rankdir=LR, fontname="Helvetica", fontsize=11, labelloc=t,
         label="Adenomyosis (자궁선근증) — Integrated QSP Mechanistic Map\nJunctional-Zone Hyperperistalsis · Estrogen Excess / Progesterone Resistance · Neuroangiogenesis · Fibrosis · HMB & Dysmenorrhea\nGnRH antagonists (relugolix CT / elagolix add-back) · GnRH agonists (leuprolide) · Dienogest · LNG-IUS · Aromatase Inhibitors · NSAIDs · Tranexamic acid · Mifepristone · Ulipristal · Surgery",
         splines=spline, overlap=false, nodesep=0.30, ranksep=0.55,
         bgcolor="#fbfbfd"];
  node  [shape=box, style="rounded,filled", fontname="Helvetica", fontsize=10,
         fillcolor="#ffffff", color="#7d8590"];
  edge  [fontname="Helvetica", fontsize=9, color="#6e7681", arrowsize=0.7];

  /* ───────────────────────── 1. Etiology / Histogenesis ───────────────────── */
  subgraph cluster_etiol {
    label="1. Etiogenesis (TIAR · Invagination · Stem Cell · Müllerian Remnant)";
    style="filled,rounded"; color="#5c6370"; fillcolor="#f3f0ff"; fontsize=12;
    TIAR        [label="TIAR\nTissue Injury & Repair\n(Leyendecker 2002,2009)"];
    Microtrauma [label="Repeated\nJZ microtrauma\n(parity·D&C·Cesarean)"];
    Invag       [label="Endometrial\nbasalis invagination\n(direct downgrowth)"];
    StemCell    [label="Endometrial / bone-marrow\nstem-cell metaplasia\n(SSEA-1+, SUSD2+)"];
    Mullerian   [label="Müllerian remnant\nde-novo metaplasia"];
    EMT         [label="EMT\n(E-cad↓ → N-cad/Vim/Snail↑)\n(Khan 2015·Garcia-Solares 2018)"];
    SubEndomet  [label="Sub-endometrial\nmyometrium (archi-myometrium)"];
    PhenoFocal  [label="Focal adenomyoma /\nCystic / Polypoid variants\n(MUSA·Bazot)"];
    PhenoDiff   [label="Diffuse adenomyosis\n(JZ>12 mm, globular uterus)"];
    Microtrauma -> TIAR;
    TIAR -> Invag -> SubEndomet;
    StemCell -> SubEndomet;
    Mullerian -> SubEndomet;
    EMT -> SubEndomet;
    SubEndomet -> PhenoDiff;
    SubEndomet -> PhenoFocal;
  }

  /* ───────────────────────── 2. Junctional Zone Dysfunction ─────────────── */
  subgraph cluster_jz {
    label="2. Junctional Zone (JZ) — Archi-myometrial dysfunction";
    style="filled,rounded"; color="#5c6370"; fillcolor="#fff4e6"; fontsize=12;
    JZ_Hyperp   [label="JZ hyper-peristalsis\n(perimenstrual >4 waves/min)\n(Kunz 1996·Leyendecker 2009)"];
    JZ_Thick    [label="JZ thickening\n(>8 mm sub-clinical, >12 mm dx)\n(Bazot 2018·Van den Bosch MUSA)"];
    JZ_disrupt  [label="JZ disruption / interruption\n(MRI features 2/3 trans. zone)"];
    Cervix      [label="Cervix→fundus\nperistaltic gradient\nfor sperm transport"];
    Retrograde  [label="Retrograde menstruation\n(↑ desquamated fragments)"];
    JZ_Hyperp -> JZ_disrupt;
    JZ_disrupt -> JZ_Thick;
    JZ_Hyperp -> Retrograde;
    Cervix -> JZ_Hyperp [style=dashed, label="dyscoord."];
  }

  /* ───────────────────────── 3. Estrogen Excess (Local) ─────────────────── */
  subgraph cluster_estro {
    label="3. Local Estrogen Excess (Aromatase·StAR·Sulfatase·17βHSD)";
    style="filled,rounded"; color="#5c6370"; fillcolor="#ffe6ec"; fontsize=12;
    StAR        [label="StAR\nCholesterol→Mitochondria"];
    P450scc     [label="CYP11A1 (P450scc)\nCHOL → Pregnenolone"];
    ArommRNA    [label="CYP19A1 mRNA\n(aromatase gene)"];
    AROM        [label="Aromatase (CYP19A1)\nAndrostenedione/T → E1/E2\n(Bulun 1994·Yamamoto 1993)"];
    SULF        [label="Steroid sulfatase (STS)\nE1-S → E1"];
    HSD17B1     [label="17β-HSD type 1\nE1 → E2 (activate)"];
    HSD17B2     [label="17β-HSD type 2\nE2 → E1 (deactivate)\n↓in adenomyosis"];
    ERa         [label="ESR1 (ERα)\n↑ in lesion"];
    ERb         [label="ESR2 (ERβ)\n↑↑ in lesion (>140-fold)\n(Bulun·Vannuccini 2017)"];
    E1S         [label="Plasma E1-S\n(sulfated pool)"];
    Local_E2    [label="Intra-lesional E2\nLOCAL HIGH"];
    Systemic_E2 [label="Systemic estradiol\n(ovarian)"];
    Ovary       [label="Ovary\n(theca + granulosa)"];
    Ovary -> Systemic_E2;
    StAR -> P450scc -> AROM;
    ArommRNA -> AROM;
    AROM -> Local_E2;
    SULF -> HSD17B1 -> Local_E2;
    E1S -> SULF;
    HSD17B2 -> Local_E2 [style=dashed, label="↓ E2 clearance"];
    Local_E2 -> ERa; Local_E2 -> ERb;
    Systemic_E2 -> ERa;
  }

  /* ───────────────────────── 4. Progesterone Resistance ─────────────────── */
  subgraph cluster_prog {
    label="4. Progesterone Resistance (PR-A↓ / PR-B imbalance · NF-κB co-repression)";
    style="filled,rounded"; color="#5c6370"; fillcolor="#e6f6ff"; fontsize=12;
    P4          [label="Progesterone (P4)\nluteal phase"];
    PRA         [label="PR-A (PGR-A)\n↓ in adenomyosis"];
    PRB         [label="PR-B (PGR-B)\nratio shifted"];
    NFkB_PR     [label="NF-κB hyper-activation\n(local)\n→ PR co-repression"];
    HOXA10      [label="HOXA10 / 11\n↓ implantation gene"];
    GnRH_local  [label="Decidualization\nfailure"];
    P4 -> PRA;  P4 -> PRB;
    PRA -> HOXA10;
    NFkB_PR -> PRA [style=dashed, arrowhead=tee, label="repress"];
    PRA -> GnRH_local [style=dashed, label="decidualize"];
  }

  /* ───────────────────────── 5. Inflammation / Prostaglandins ───────────── */
  subgraph cluster_inflam {
    label="5. Inflammation · Macrophages · Prostaglandin-E2 / F2α loop";
    style="filled,rounded"; color="#5c6370"; fillcolor="#fff9e6"; fontsize=12;
    MAC         [label="CD68+ Macrophages\n(M2 polarised)\n+ NK / T cells"];
    IL1b        [label="IL-1β"];
    IL6         [label="IL-6"];
    IL8         [label="IL-8 / CXCL8"];
    TNFa        [label="TNF-α"];
    NFkB        [label="NF-κB"];
    COX2        [label="PTGS2 / COX-2\n↑↑ in lesion"];
    PGE2        [label="PGE2\n(EP2/EP4)"];
    PGF2a       [label="PGF2α\n(FP) → myometrial contraction"];
    NSAID_arrow [shape=none, label="", width=0, height=0];
    MAC -> IL1b; MAC -> IL6; MAC -> TNFa; MAC -> IL8;
    IL1b -> NFkB; TNFa -> NFkB;
    NFkB -> COX2 -> PGE2;
    COX2 -> PGF2a;
    PGE2 -> ArommRNA [color="#d63384", label="+EP2/4→cAMP→aromatase"];
  }

  /* ───────────────────────── 6. Oxidative Stress (Free Iron) ────────────── */
  subgraph cluster_ros {
    label="6. Oxidative Stress · Iron · Heme (perimenstrual)";
    style="filled,rounded"; color="#5c6370"; fillcolor="#f3e7ff"; fontsize=12;
    Heme        [label="Heme / Free Fe²⁺\n(retrograde + local bleed)"];
    Fenton      [label="Fenton reaction\n→ ROS / OH•"];
    LPO         [label="Lipid peroxidation\n(MDA, 4-HNE)"];
    NRF2        [label="NRF2 / KEAP1\nantioxidant ARE"];
    Heme -> Fenton -> LPO;
    Fenton -> NFkB;
    NRF2 -> LPO [style=dashed, arrowhead=tee];
  }

  /* ───────────────────────── 7. Fibrosis & EMT ─────────────────────────── */
  subgraph cluster_fibrosis {
    label="7. Fibrosis · TGF-β / SMAD · Collagen deposition";
    style="filled,rounded"; color="#5c6370"; fillcolor="#fde0e0"; fontsize=12;
    TGFb        [label="TGF-β1"];
    SMAD23      [label="SMAD2/3 / SMAD4"];
    CTGF        [label="CCN2 / CTGF"];
    Col1        [label="Collagen I/III\n↑↑ around glands"];
    MMP         [label="MMP-2 / 9"];
    TIMP        [label="TIMP-1/2"];
    Myofib      [label="Myofibroblast\n(α-SMA+, FAP+)"];
    Fibrosis    [label="Periglandular\nfibrosis"];
    TGFb -> SMAD23 -> CTGF -> Col1;
    SMAD23 -> Myofib -> Fibrosis;
    MMP -> Fibrosis [style=dashed, arrowhead=tee];
    TIMP -> MMP [arrowhead=tee];
  }

  /* ───────────────────────── 8. Neuroangiogenesis & Pain ───────────────── */
  subgraph cluster_neuro {
    label="8. Neuroangiogenesis · VEGF / NGF / BDNF · Sensitization";
    style="filled,rounded"; color="#5c6370"; fillcolor="#e6ffe6"; fontsize=12;
    HIF1a       [label="HIF-1α\n(local hypoxia)"];
    VEGF        [label="VEGF-A"];
    Angio       [label="Aberrant\nmicrovessels"];
    NGF         [label="NGF (β-NGF)"];
    BDNF        [label="BDNF"];
    TrkA        [label="TrkA / p75NTR\n(sensory nociceptor)"];
    PIEZO       [label="PIEZO2 / TRPV1\nmechano-nociceptor"];
    DRG         [label="DRG hypersensitization\n(T10–L1, S2–S4)"];
    SC          [label="Spinal cord\ndorsal horn (Lamina I/II)"];
    CNS         [label="Central sensitization\n(thalamus, insula, ACC)"];
    DYSM        [label="Dysmenorrhea\nVAS / NRS"];
    PEL_PAIN    [label="Chronic pelvic pain\n& dyspareunia"];
    HIF1a -> VEGF -> Angio;
    Angio -> NGF; Angio -> BDNF;
    NGF -> TrkA -> DRG;
    BDNF -> SC;
    PIEZO -> DRG;
    DRG -> SC -> CNS;
    CNS -> DYSM; CNS -> PEL_PAIN;
    PGF2a -> DYSM [color="#d63384", label="cramping"];
  }

  /* ───────────────────────── 9. Endometrial Dysfunction / HMB ───────────── */
  subgraph cluster_hmb {
    label="9. Heavy Menstrual Bleeding (HMB) · PBAC score · Iron-deficiency anemia";
    style="filled,rounded"; color="#5c6370"; fillcolor="#ffe6f7"; fontsize=12;
    BigEndo     [label="Enlarged endometrial\nsurface area\n(globular cavity)"];
    Aberrant    [label="Aberrant spiral arterioles\n+ neoangiogenesis"];
    PA          [label="Plasminogen activators\ntPA / uPA ↑\n→ Plasmin"];
    PAI         [label="PAI-1 (↓ relative)"];
    Hemostasis  [label="Defective\nlocal hemostasis"];
    HMB         [label="Heavy Menstrual Bleeding\nPBAC > 100"];
    IDA         [label="Iron-deficiency anemia\nHb ↓ / ferritin ↓"];
    QoL         [label="Quality of life ↓\n(SF-36, EHP-30)"];
    BigEndo -> HMB; Aberrant -> HMB;
    PA -> Plasmin [label=""];
    Plasmin     [label="Plasmin"];
    PA -> Plasmin -> Hemostasis [arrowhead=tee];
    PAI -> Plasmin [arrowhead=tee];
    Hemostasis -> HMB [arrowhead=tee];
    HMB -> IDA -> QoL;
  }

  /* ───────────────────────── 10. Smooth Muscle Hyperplasia ──────────────── */
  subgraph cluster_smc {
    label="10. Myometrial Smooth-Muscle Hyperplasia / Hypertrophy";
    style="filled,rounded"; color="#5c6370"; fillcolor="#f0f4f8"; fontsize=12;
    OXT_R       [label="OXTR\nOxytocin receptor"];
    Calcium     [label="[Ca²⁺]i\nspike"];
    MLCK        [label="MLCK → MLC-P\n(contraction)"];
    Hyperplasia [label="Myometrial cell\nhyperplasia / hypertrophy"];
    UterusEnl   [label="Uterine enlargement\n(>120 mL, globular)"];
    OXT_R -> Calcium -> MLCK -> JZ_Hyperp;
    PGF2a -> Calcium [color="#d63384"];
    Hyperplasia -> UterusEnl;
    Local_E2 -> Hyperplasia;
  }

  /* ───────────────────────── 11. Fertility & Implantation ──────────────── */
  subgraph cluster_fert {
    label="11. Subfertility · Implantation failure · Obstetric outcome";
    style="filled,rounded"; color="#5c6370"; fillcolor="#fff0f5"; fontsize=12;
    Implant     [label="Implantation\nwindow defect"];
    HOXA10_eff  [label="HOXA10/11 ↓\nLIF ↓"];
    AbortRisk   [label="Miscarriage ↑\n(OR ~2.1)"];
    Preterm     [label="Preterm birth↑\nPPROM↑ Placenta↑"];
    HOXA10_eff -> Implant;
    Implant -> AbortRisk;
    Implant -> Preterm;
    PRA -> HOXA10_eff;
  }

  /* ───────────────────────── 12. HPO Axis (Endocrine) ───────────────────── */
  subgraph cluster_hpo {
    label="12. HPO Axis · GnRH · Pituitary · Ovarian feedback";
    style="filled,rounded"; color="#5c6370"; fillcolor="#e0f7fa"; fontsize=12;
    HYPO        [label="Hypothalamus\n(arcuate, preoptic)"];
    GnRH        [label="GnRH pulse\nKisspeptin"];
    GnRHR       [label="GnRHR (pituitary\ngonadotrope)"];
    FSH         [label="FSH"];
    LH          [label="LH"];
    HYPO -> GnRH -> GnRHR;
    GnRHR -> FSH; GnRHR -> LH;
    FSH -> Ovary; LH -> Ovary;
    Systemic_E2 -> HYPO [arrowhead=tee, label="−feedback"];
  }

  /* ───────────────────────── 13. Drug Pharmacology ──────────────────────── */
  subgraph cluster_drugs {
    label="13. Pharmacology · Hormonal · Non-hormonal · Surgical";
    style="filled,rounded"; color="#5c6370"; fillcolor="#fff8dc"; fontsize=12;
    /* GnRH antagonists */
    REL         [label="Relugolix 40 mg PO\n(GnRH antagonist)\n+ E2 1 mg / NETA 0.5 mg\n[SPIRIT-1/2 endo, MR LIBERTY UF]"];
    ELA         [label="Elagolix 150/200 mg PO\n(GnRH antagonist)\n± E2/NETA add-back\n[ELARIS EM-I/II endo]"];
    LIN         [label="Linzagolix 100/200 mg PO\n(GnRH antagonist)\n[PRIMROSE UF]"];
    /* GnRH agonists */
    LEU         [label="Leuprolide depot 3.75 mg IM q4w\n(GnRH agonist, flare → desensitization)"];
    TRI         [label="Triptorelin 3.75 mg IM q4w"];
    GOSE        [label="Goserelin 3.6 mg SC q4w"];
    /* Progestins */
    DNG         [label="Dienogest 2 mg PO QD\n(selective progestin)\n[Osuga 2017,2018 KIM ADENO]"];
    LNG_IUS     [label="LNG-IUS 52 mg\n(20 µg/day intrauterine release)\n[Maia 2003·Sheng 2009·Yoo 2018]"];
    NETA        [label="Norethindrone acetate 5 mg PO\n(add-back / monotherapy)"];
    MPA         [label="Medroxyprogesterone\nacetate 10 mg PO\n(depot 150 mg IM q3m)"];
    /* SPRMs / antagonists */
    MIFE        [label="Mifepristone 25–50 mg PO\n(SPRM/PR antagonist)\n[Che 2020]"];
    ULIP        [label="Ulipristal acetate 5 mg\n(SPRM, PEARL)\n*EMA hepatic risk warning*"];
    /* AIs */
    LET         [label="Letrozole 2.5 mg PO QD\n(non-steroidal AI)\n[Badawy 2012·Kim 2013]"];
    ANA         [label="Anastrozole 1 mg PO QD\n(non-steroidal AI)"];
    /* COC */
    COC         [label="Combined OC (continuous)\nEE 30 + LNG/DSG\n[Vannuccini 2018]"];
    /* Non-hormonal */
    NSAID       [label="NSAIDs\nIbuprofen 400-800 mg q6h\nMefenamic 500 mg q8h\n(COX-1/2)"];
    TXA         [label="Tranexamic acid\n1 g PO q6h × 5d\n(anti-fibrinolytic)\n[NICE NG88]"];
    /* Surgical */
    HYS         [label="Hysterectomy\n(definitive)"];
    UAE         [label="Uterine artery embolization\n(UAE/UFE)"];
    HIFU        [label="HIFU / MR-HIFU\n(focused ultrasound)"];
    ABLAT       [label="Endometrial ablation\nresectoscope/balloon"];
    /* Edges from drugs to mechanisms */
    REL  -> GnRHR  [color="#1f77b4", arrowhead=tee, label="competitive antag"];
    ELA  -> GnRHR  [color="#1f77b4", arrowhead=tee];
    LIN  -> GnRHR  [color="#1f77b4", arrowhead=tee];
    LEU  -> GnRHR  [color="#1f77b4", label="agonist → flare\n→ desensitize"];
    TRI  -> GnRHR  [color="#1f77b4", label="agonist"];
    GOSE -> GnRHR  [color="#1f77b4", label="agonist"];
    DNG  -> PRB    [color="#2ca02c", label="selective PR-B"];
    DNG  -> Ovary  [color="#2ca02c", arrowhead=tee, label="ovulation↓"];
    DNG  -> COX2   [color="#2ca02c", arrowhead=tee];
    DNG  -> AROM   [color="#2ca02c", arrowhead=tee];
    LNG_IUS -> PRB [color="#2ca02c", label="local PR agonist"];
    LNG_IUS -> BigEndo [color="#2ca02c", arrowhead=tee, label="endo atrophy"];
    NETA -> PRB    [color="#2ca02c"];
    MPA  -> PRB    [color="#2ca02c"];
    MIFE -> PRA    [color="#9467bd", arrowhead=tee, label="antagonist"];
    ULIP -> PRA    [color="#9467bd", arrowhead=tee, label="SPRM"];
    LET  -> AROM   [color="#ff7f0e", arrowhead=tee];
    ANA  -> AROM   [color="#ff7f0e", arrowhead=tee];
    COC  -> Ovary  [color="#17becf", arrowhead=tee, label="suppress"];
    COC  -> HYPO   [color="#17becf", arrowhead=tee];
    NSAID -> COX2  [color="#8c564b", arrowhead=tee];
    NSAID -> PGE2  [color="#8c564b", arrowhead=tee];
    NSAID -> PGF2a [color="#8c564b", arrowhead=tee, label="↓ cramps"];
    TXA  -> Plasmin [color="#bcbd22", arrowhead=tee, label="anti-fibrinolytic"];
    HYS  -> UterusEnl [color="#e377c2", label="excision"];
    UAE  -> Angio  [color="#e377c2", arrowhead=tee];
    HIFU -> Hyperplasia [color="#e377c2", arrowhead=tee, label="thermal ablation"];
    ABLAT -> BigEndo [color="#e377c2", arrowhead=tee];
  }

  /* ───────────────────────── 14. Add-back / Safety ─────────────────────── */
  subgraph cluster_safety {
    label="14. Hypoestrogenic Safety · BMD · Hot Flushes · Lipid · LFTs";
    style="filled,rounded"; color="#5c6370"; fillcolor="#fbecd9"; fontsize=12;
    BMD         [label="Bone mineral density ↓\n(DXA −1 to −3% / 6 mo,\n>1% sustained → ATR)"];
    HF          [label="Hot flushes\n(VMS, daily count)"];
    LIPID       [label="LDL / HDL / TG\nlipid panel"];
    LFT         [label="LFT (AST/ALT)\nelagolix label"];
    ADDBACK     [label="Add-back therapy\nE2 1 mg + NETA 0.5 mg\n(Pierce 1999·Surrey)"];
    Hypoestro   [label="Hypoestrogenic state\n(menopausal-like)"];
    Systemic_E2 -> Hypoestro [arrowhead=tee];
    Hypoestro -> BMD [arrowhead=tee];
    Hypoestro -> HF;
    Hypoestro -> LIPID;
    ADDBACK -> BMD [color="#1f77b4"];
    ADDBACK -> HF [color="#1f77b4", arrowhead=tee];
    ELA -> LFT  [color="#1f77b4", label="elagolix Tx-AE"];
    REL -> Hypoestro [arrowhead=tee];
    ELA -> Hypoestro [arrowhead=tee];
    LEU -> Hypoestro [arrowhead=tee];
  }

  /* ───────────────────────── 15. Clinical Endpoints / Biomarkers ───────── */
  subgraph cluster_endpts {
    label="15. Clinical Endpoints · Biomarkers · Imaging";
    style="filled,rounded"; color="#5c6370"; fillcolor="#eef9ff"; fontsize=12;
    PBAC        [label="PBAC (pictorial blood-loss\nassessment chart)\n≥100 → HMB"];
    VAS_D       [label="Dysmenorrhea VAS / NRS\n0–10"];
    NPRS_NMPP   [label="Non-menstrual\npelvic pain NRS"];
    DEEP_DYS    [label="Deep dyspareunia\n(DPP-Q)"];
    PGIC        [label="PGIC / PGIS\n(patient global)"];
    EHP30       [label="EHP-30 QoL"];
    JZ_MRI      [label="JZ thickness MRI\n(T2-W)"];
    CA125       [label="Serum CA-125"];
    Ferritin    [label="Serum ferritin"];
    Hb          [label="Hemoglobin (Hb)"];
    UV_Vol      [label="Uterine volume (TVUS/MRI)"];
    HMB -> PBAC;
    HMB -> Hb [arrowhead=tee];
    IDA -> Ferritin [arrowhead=tee];
    JZ_Thick -> JZ_MRI;
    UterusEnl -> UV_Vol;
    DYSM -> VAS_D;
    PEL_PAIN -> NPRS_NMPP;
    PEL_PAIN -> DEEP_DYS;
    QoL -> EHP30;
    Hyperplasia -> CA125 [label="↑"];
  }

  /* ───────────────────────── Cross-cluster wiring ──────────────────────── */
  Local_E2 -> Hyperplasia;
  Local_E2 -> COX2;
  ERa -> Hyperplasia;
  ERb -> ArommRNA [color="#d63384", label="self-amplify"];
  PGE2 -> StAR    [color="#d63384", label="EP2/4→cAMP→SF1→StAR/CYP19A1"];
  COX2 -> NGF;
  COX2 -> VEGF;
  TGFb -> EMT;
  TGFb -> JZ_Thick;
  NFkB_PR -> PRA;
  IL1b -> NFkB_PR;
  TNFa -> NFkB_PR;
  ROS_node [shape=ellipse, label="ROS", fillcolor="#f3e7ff"];
  Fenton -> ROS_node;
  ROS_node -> NFkB;
  ROS_node -> TGFb;
  NGF -> DYSM;
  VEGF -> Angio;
  Aberrant -> NGF;
  Retrograde -> Heme;
  TGFb -> Fibrosis;
  Fibrosis -> JZ_Thick;
  IL6 -> ArommRNA [color="#d63384", label="STAT3"];
  PRA -> NFkB [arrowhead=tee, label="suppress (when ↓ → uncage NF-κB)"];
  ADDBACK -> Local_E2 [style=dashed];

  /* Patient / population layer */
  subgraph cluster_pat {
    label="Patient & Population Modifiers";
    style="filled,rounded"; color="#5c6370"; fillcolor="#f5f5f5"; fontsize=12;
    AGE     [label="Age 30–55\n(reproductive→peri)"];
    PARITY  [label="Parity / prior\nuterine surgery"];
    BMI     [label="BMI"];
    GENET   [label="Genetic loci\n(WNT4, GREB1, SYNE1\n CDC42 — GWAS)"];
    AGE -> Microtrauma;
    PARITY -> Microtrauma;
    BMI -> AROM [label="↑ adipose"];
    GENET -> StemCell;
  }
}
