digraph ChronicHepC_QSP {

    graph [
        rankdir=LR,
        fontname="Helvetica",
        fontsize=11,
        compound=true,
        label="Chronic Hepatitis C — QSP Mechanistic Map\nVersion 1.0  |  2026-06-23",
        labelloc=t,
        labelfontsize=18,
        bgcolor="#F8F9FA",
        splines=ortho,
        nodesep=0.4,
        ranksep=0.65,
        pad=0.5
    ];

    node [fontname="Helvetica", fontsize=9, style=filled, margin="0.10,0.05"];
    edge [fontname="Helvetica", fontsize=8, arrowsize=0.7];

    /* =========================================================
       CLUSTER 1 – HCV Virion & Viral Entry
       ========================================================= */
    subgraph cluster_virus {
        label="① HCV Virion & Cell Entry";
        style=filled; bgcolor="#FFF3E0"; color="#E65100"; penwidth=2;

        HCV_E1E2    [label="HCV Envelope\nE1/E2 Glycoproteins",     shape=ellipse, fillcolor="#FFAB40"];
        CD81        [label="CD81 Receptor\n(Tetraspanin)",          shape=box,     fillcolor="#FFD54F"];
        SR_B1       [label="SR-B1\n(Scavenger receptor B1)",        shape=box,     fillcolor="#FFD54F"];
        CLDN1       [label="Claudin-1\n(Tight junction)",           shape=box,     fillcolor="#FFD54F"];
        OCLN        [label="Occludin\n(Tight junction)",            shape=box,     fillcolor="#FFD54F"];
        EGFR_NPC1L1 [label="EGFR / NPC1L1\nCo-receptors",          shape=box,     fillcolor="#FFD54F"];
        clathrin    [label="Clathrin-mediated\nEndocytosis",        shape=diamond, fillcolor="#FF8F00"];
        viral_fusion[label="Viral-Endosomal\nMembrane Fusion",     shape=diamond, fillcolor="#FF8F00"];
        uncoating   [label="Nucleocapsid\nUncoating",               shape=diamond, fillcolor="#FF8F00"];
        HCV_RNA_in  [label="HCV + ssRNA\n(Incoming genome 9.6 kb)", shape=ellipse, fillcolor="#FF5722", fontcolor=white];
        lipoprotein [label="LDL/VLDL\nAssociation\n(LVP complex)", shape=ellipse, fillcolor="#FFCC80"];
    }

    /* =========================================================
       CLUSTER 2 – HCV Replication Cycle
       ========================================================= */
    subgraph cluster_replication {
        label="② Intracellular Replication Cycle";
        style=filled; bgcolor="#FCE4EC"; color="#880E4F"; penwidth=2;

        IRES_trans  [label="IRES-mediated\nTranslation\n(5'-UTR)",     shape=diamond, fillcolor="#F48FB1"];
        polyprotein [label="HCV Polyprotein\n(~3011 aa)",              shape=box,     fillcolor="#F06292"];
        NS3_4A      [label="NS3/4A\nSerine Protease\n(viral processing)", shape=box,  fillcolor="#E91E63", fontcolor=white];
        NS5A        [label="NS5A\n(Replication complex,\nmembrane web)", shape=box,   fillcolor="#AD1457", fontcolor=white];
        NS5B        [label="NS5B\nRNA-dep. RNA\nPolymerase (RdRp)",     shape=box,    fillcolor="#880E4F", fontcolor=white];
        NS4B        [label="NS4B\nMembranous Web\nInducer",             shape=box,    fillcolor="#C2185B", fontcolor=white];
        NS2         [label="NS2\nAutoprotease",                         shape=ellipse, fillcolor="#F06292"];
        core        [label="Core Protein\n(Nucleocapsid)",              shape=ellipse, fillcolor="#E91E63", fontcolor=white];
        E1_E2_struct[label="E1/E2 Structural\nProteins (ER)",           shape=ellipse, fillcolor="#F48FB1"];
        minus_RNA   [label="(−) Strand\nRNA Template",                  shape=ellipse, fillcolor="#FCE4EC", style="filled,dashed"];
        plus_RNA    [label="(+) Strand\nRNA (progeny)",                 shape=ellipse, fillcolor="#F48FB1"];
        RC          [label="Replication\nComplex (RC)\nMembranous web", shape=box,    fillcolor="#C2185B", fontcolor=white, penwidth=3];
        lipid_drop  [label="Lipid Droplets\n(Core-LD association)",     shape=ellipse, fillcolor="#FFCDD2"];
        LD_NS5A     [label="NS5A-LD\nInteraction\n(Assembly hub)",      shape=diamond, fillcolor="#E91E63", fontcolor=white];
    }

    /* =========================================================
       CLUSTER 3 – HCV Assembly & Secretion
       ========================================================= */
    subgraph cluster_assembly {
        label="③ Virion Assembly & Secretion";
        style=filled; bgcolor="#E8EAF6"; color="#283593"; penwidth=2;

        capsid_assem  [label="Nucleocapsid\nAssembly (ER/LD)",     shape=diamond, fillcolor="#7986CB"];
        envelope_acq  [label="Envelope\nAcquisition (ER budding)", shape=diamond, fillcolor="#5C6BC0"];
        golgi_transit [label="Golgi\nTrafficking",                  shape=box,     fillcolor="#3F51B5", fontcolor=white];
        VLDL_pathway  [label="VLDL Secretory\nPathway (ApoE, ApoB)", shape=box,   fillcolor="#283593", fontcolor=white];
        HCV_virion_out[label="Mature HCV\nVirion (released)",       shape=ellipse, fillcolor="#1A237E", fontcolor=white, penwidth=3];
        viral_prod    [label="Viral Production\nRate P (RNA/mL/d)", shape=box,    fillcolor="#3949AB", fontcolor=white];
    }

    /* =========================================================
       CLUSTER 4 – Host Innate Immunity
       ========================================================= */
    subgraph cluster_innate {
        label="④ Host Innate Immune Response";
        style=filled; bgcolor="#E8F5E9"; color="#1B5E20"; penwidth=2;

        RIG_I       [label="RIG-I / MDA5\n(Pattern Recognition\nRNA sensor)",   shape=box,     fillcolor="#66BB6A"];
        MAVS        [label="MAVS\n(IPS-1/VISA)\nMitochondrial adapter",         shape=box,     fillcolor="#4CAF50"];
        IRF3        [label="IRF3/IRF7\nActivation",                              shape=diamond, fillcolor="#388E3C", fontcolor=white];
        IFN_beta    [label="IFN-β\n(Type I IFN)\nProduction",                   shape=ellipse, fillcolor="#1B5E20", fontcolor=white];
        IFN_alpha   [label="IFN-α\n(Type I IFN)",                               shape=ellipse, fillcolor="#2E7D32", fontcolor=white];
        IFNAR       [label="IFNAR1/2\nType I IFN Receptor",                     shape=box,     fillcolor="#43A047"];
        JAK_TYK2    [label="JAK1/TYK2\nPhosphorylation",                        shape=diamond, fillcolor="#388E3C", fontcolor=white];
        STAT1_2     [label="STAT1/STAT2\npSTAT (ISGF3)",                        shape=diamond, fillcolor="#2E7D32", fontcolor=white];
        ISRE        [label="IFN-Stimulated\nResponse Elements",                 shape=box,     fillcolor="#1B5E20", fontcolor=white];
        ISGs        [label="ISGs\n(OAS1, MxA, PKR,\nISG15, IFIT1/3)",          shape=box,     fillcolor="#43A047"];
        PKR         [label="PKR\n(eIF2α kinase,\nantiviral)",                   shape=ellipse, fillcolor="#66BB6A"];
        OAS_RNaseL  [label="OAS1-RNaseL\nRNA Degradation",                     shape=ellipse, fillcolor="#66BB6A"];
        NS3_4A_cut  [label="NS3/4A Cleavage\nof MAVS & TRIF\n(Immune Evasion)", shape=box,   fillcolor="#C62828", fontcolor=white, penwidth=3];
        NK_act      [label="NK Cell\nActivation",                               shape=box,     fillcolor="#A5D6A7"];
        CXCL10      [label="CXCL10 / IP-10\n(T cell recruitment)",             shape=ellipse, fillcolor="#A5D6A7"];
        IL28B       [label="IL-28B (IFN-λ3)\nGenotype (CC favorable)", shape=ellipse, fillcolor="#81C784"];
        IFN_lambda  [label="IFN-λ1/2/3\n(Type III IFN)\nHepatic",             shape=ellipse, fillcolor="#43A047"];
    }

    /* =========================================================
       CLUSTER 5 – Adaptive Immunity
       ========================================================= */
    subgraph cluster_adaptive {
        label="⑤ Adaptive Immune Response";
        style=filled; bgcolor="#E3F2FD"; color="#0D47A1"; penwidth=2;

        MHC_I       [label="MHC I\nAntigen Presentation\n(CTL priming)",        shape=box,     fillcolor="#90CAF9"];
        MHC_II      [label="MHC II\nAntigen Presentation\n(CD4 priming)",       shape=box,     fillcolor="#90CAF9"];
        CD4_Th1     [label="CD4+ Th1 Cells\n(IFN-γ, IL-2 helpers)",            shape=box,     fillcolor="#1E88E5", fontcolor=white];
        CD8_CTL     [label="CD8+ CTL\n(Cytotoxic T cells)",                     shape=box,     fillcolor="#1565C0", fontcolor=white];
        CTL_exhaust [label="CTL Exhaustion\n(PD-1↑, Tim-3↑, CTLA-4↑)",        shape=box,     fillcolor="#0D47A1", fontcolor=white, penwidth=3];
        B_cell      [label="B Cells\n→ Anti-HCV Antibodies",                    shape=box,     fillcolor="#42A5F5"];
        anti_E2_Ab  [label="Anti-E2\nNeutralising Ab\n(nAb, limited efficacy)", shape=ellipse, fillcolor="#64B5F6"];
        Treg_HCV    [label="Treg\n(Foxp3+, IL-10, TGF-β)\nImmune suppression", shape=box,     fillcolor="#29B6F6"];
        NK_KIR      [label="NK/KIR2DL3\nGenotype\n(spontaneous clearance)",    shape=ellipse, fillcolor="#81D4FA"];
        IFN_gamma_T [label="IFN-γ\n(T-cell derived)",                          shape=ellipse, fillcolor="#1E88E5", fontcolor=white];
        T_memory    [label="HCV-specific\nMemory T Cells",                      shape=ellipse, fillcolor="#90CAF9"];
    }

    /* =========================================================
       CLUSTER 6 – Liver Pathology
       ========================================================= */
    subgraph cluster_liver {
        label="⑥ Hepatic Pathology & Fibrosis";
        style=filled; bgcolor="#FFF8E1"; color="#F57F17"; penwidth=2;

        hepatocyte  [label="Hepatocyte\n(Target cell)",              shape=box,     fillcolor="#FFF176"];
        hepatocyte_death [label="Hepatocyte\nApoptosis/Necrosis",   shape=box,     fillcolor="#FFCA28"];
        ALT_level   [label="ALT / AST\nLiver Enzymes (IU/L)",       shape=ellipse, fillcolor="#FFD54F"];
        liver_inflam[label="Liver\nInflammation\n(HAI/Knodell score)", shape=box,  fillcolor="#FFB300"];
        HSC         [label="Hepatic Stellate\nCells (HSC)",          shape=box,     fillcolor="#FFA726"];
        HSC_act     [label="Activated HSC\n(Myofibroblast)",         shape=box,     fillcolor="#EF6C00", fontcolor=white];
        TGF_b_liver [label="TGF-β1\n(Pro-fibrotic)",                shape=ellipse, fillcolor="#E65100", fontcolor=white];
        collagen    [label="Collagen\nDeposition (I, III)",          shape=box,     fillcolor="#BF360C", fontcolor=white];
        fibrosis    [label="Liver Fibrosis\n(Metavir F0–F4)",        shape=box,     fillcolor="#8D1A0A", fontcolor=white, penwidth=3, style="filled,bold"];
        cirrhosis   [label="Liver Cirrhosis\n(F4, HVPG >10 mmHg)",  shape=box,     fillcolor="#4E0A06", fontcolor=white];
        HCC_risk    [label="HCC Risk\n(Hepatocellular Carcinoma)",   shape=box,     fillcolor="#B71C1C", fontcolor=white, penwidth=3];
        MMP_liver   [label="MMP-1/2/9\n(Matrix Degradation)",       shape=ellipse, fillcolor="#FFCC80"];
        TIMP_liver  [label="TIMP-1\n(Fibrosis stabiliser)",         shape=ellipse, fillcolor="#A5D6A7"];
        steatosis   [label="Steatosis\n(Lipid accumulation,\ngenotype 3)", shape=box, fillcolor="#FFF9C4"];
    }

    /* =========================================================
       CLUSTER 7 – Direct-Acting Antivirals (DAA) PK
       ========================================================= */
    subgraph cluster_DAA_PK {
        label="⑦ Direct-Acting Antiviral (DAA) Drug PK";
        style=filled; bgcolor="#EDE7F6"; color="#4527A0"; penwidth=2;

        SOF_dose    [label="Sofosbuvir (SOF)\n400 mg QD oral\n(NS5B NNI pro-drug)", shape=hexagon, fillcolor="#B39DDB"];
        LED_dose    [label="Ledipasvir (LED)\n90 mg QD oral\n(NS5A inhibitor)",     shape=hexagon, fillcolor="#B39DDB"];
        VEL_dose    [label="Velpatasvir (VEL)\n100 mg QD oral\n(pangenotypic NS5A)", shape=hexagon, fillcolor="#9575CD"];
        GLE_dose    [label="Glecaprevir (GLE)\n300 mg QD oral\n(NS3/4A PI)",        shape=hexagon, fillcolor="#7E57C2"];
        PIB_dose    [label="Pibrentasvir (PIB)\n120 mg QD oral\n(NS5A inhibitor)",  shape=hexagon, fillcolor="#7E57C2"];
        RBV_dose    [label="Ribavirin (RBV)\nWeight-based BID\n(NS5B NI, antiviral)", shape=hexagon, fillcolor="#CE93D8"];

        SOF_GS331   [label="GS-331007\n(SOF Active Nucleotide\nTp metabolite)",     shape=box,     fillcolor="#D1C4E9"];
        LED_plasma  [label="Ledipasvir\nPlasma Cp (ng/mL)",                        shape=box,     fillcolor="#D1C4E9"];
        VEL_plasma  [label="Velpatasvir\nPlasma Cp (ng/mL)",                       shape=box,     fillcolor="#CE93D8"];
        GLE_plasma  [label="Glecaprevir\nPlasma Cp (ng/mL)",                       shape=box,     fillcolor="#B39DDB"];
        PIB_plasma  [label="Pibrentasvir\nPlasma Cp (ng/mL)",                      shape=box,     fillcolor="#B39DDB"];
        RBV_plasma  [label="Ribavirin\nPlasma Cp (μg/mL)",                         shape=box,     fillcolor="#CE93D8"];
        RBV_RBC     [label="Ribavirin\nRBC phosphates (intracell.)",               shape=box,     fillcolor="#CE93D8"];

        SOF_intrahep[label="SOF Intrahepatic\nConcentration (Ct)",                 shape=box,     fillcolor="#D1C4E9"];
        food_effect [label="Food/Acid-suppression\nInteraction (ledipasvir)",      shape=diamond, fillcolor="#EDE7F6"];
    }

    /* =========================================================
       CLUSTER 8 – Drug PD / Target Engagement
       ========================================================= */
    subgraph cluster_PD {
        label="⑧ Drug PD — Target Engagement & Viral Kinetics";
        style=filled; bgcolor="#E8F5E9"; color="#1B5E20"; penwidth=2;

        E_SOF       [label="SOF\nNS5B Inhibition\nIC50 = 0.4 μM",   shape=ellipse, fillcolor="#A5D6A7"];
        E_LED       [label="LED/VEL\nNS5A Inhibition\n(picomolar)",  shape=ellipse, fillcolor="#A5D6A7"];
        E_GLE       [label="GLE\nNS3/4A Inhibition\n(low pM)",       shape=ellipse, fillcolor="#A5D6A7"];
        E_PIB       [label="PIB\nNS5A Inhibition\n(pan-genotypic)",  shape=ellipse, fillcolor="#A5D6A7"];
        E_RBV       [label="RBV\nInosine 5-Monophosphate DH\nInhibition (antiviral + IFN-like)", shape=ellipse, fillcolor="#C5E1A5"];

        viral_prod_rate [label="Viral Production\nRate P(t)\n(virions/mL/d)",    shape=diamond, fillcolor="#388E3C", fontcolor=white];
        viral_clear_rate[label="Viral Clearance\nRate c\n(/day)",                shape=diamond, fillcolor="#388E3C", fontcolor=white];
        infected_death  [label="Infected Cell\nDeath Rate δ\n(/day)",            shape=diamond, fillcolor="#2E7D32", fontcolor=white];
        epsilon_prod    [label="Drug Efficacy ε\non Production",                 shape=diamond, fillcolor="#43A047"];
        epsilon_infect  [label="Drug Efficacy η\non Infectivity",                shape=diamond, fillcolor="#43A047"];
        barrier_resist  [label="Genetic Barrier\nto Resistance\n(NS5A > NS3/4A)", shape=box,   fillcolor="#81C784"];
        RAS             [label="Resistance-Associated\nSubstitutions (RASs)\nY93H (NS5A)",  shape=box, fillcolor="#EF9A9A"];
    }

    /* =========================================================
       CLUSTER 9 – Viral Kinetics Model (Neumann / Perelson)
       ========================================================= */
    subgraph cluster_vk {
        label="⑨ Viral Kinetics Model (Perelson Framework)";
        style=filled; bgcolor="#F3E5F5"; color="#6A1B9A"; penwidth=2;

        T_cells     [label="Target Hepatocytes (T)\n(uninfected cells)",        shape=box,     fillcolor="#E1BEE7"];
        I_cells     [label="Infected Hepatocytes (I)\n(productively infected)", shape=box,     fillcolor="#CE93D8"];
        V_free      [label="Free Virus (V)\nHCV-RNA (IU/mL log10)",            shape=box,     fillcolor="#AB47BC", fontcolor=white, penwidth=3, style="filled,bold"];
        V_defective [label="Defective Particles\n(non-infectious)",             shape=ellipse, fillcolor="#E1BEE7"];
        phase1      [label="Phase 1 Decline\n(rapid, 24–48h)\nClearance of\nfree virus",  shape=box, fillcolor="#9C27B0", fontcolor=white];
        phase2      [label="Phase 2 Decline\n(slow, weeks)\nLoss of infected\ncells",     shape=box, fillcolor="#7B1FA2", fontcolor=white];
        SVR12       [label="SVR12\n(HCV RNA < 15 IU/mL\nat 12 wk post-Rx)",             shape=box, fillcolor="#4A148C", fontcolor=white, penwidth=3, style="filled,bold"];
        TND         [label="Target-Not-Detected\n(HCV RNA < LLOQ)",                       shape=ellipse, fillcolor="#CE93D8"];
        relapse     [label="Virological Relapse\n(post-treatment)",                        shape=box, fillcolor="#E91E63", fontcolor=white];
    }

    /* =========================================================
       CLUSTER 10 – Clinical Outcomes
       ========================================================= */
    subgraph cluster_outcomes {
        label="⑩ Clinical Outcomes";
        style=filled; bgcolor="#FAFAFA"; color="#37474F"; penwidth=2;

        SVR_fibrosis[label="SVR → Fibrosis\nRegression\n(F4→F3, F3→F2…)",    shape=box,     fillcolor="#80CBC4"];
        HCC_prevent [label="HCC Risk\nReduction\n(~75% with SVR)",            shape=box,     fillcolor="#80CBC4"];
        all_cause_mort [label="All-cause\nMortality\nReduction",              shape=box,     fillcolor="#80CBC4"];
        extrahep    [label="Extra-hepatic\nManifestations\n(cryo-vasculitis,\nB-cell lymphoma)", shape=box, fillcolor="#B2DFDB"];
        HRQoL       [label="Health-Related\nQuality of Life\n(EQ-5D, SF-36)", shape=box,     fillcolor="#B2DFDB"];
        reinfection [label="Re-infection\nRisk (PWID)",                       shape=ellipse, fillcolor="#FFCDD2"];
        LT_waitlist [label="Liver Transplant\nWaitlist Removal",              shape=box,     fillcolor="#80CBC4"];
        MELD_score  [label="MELD Score\n(Decompensation risk)",              shape=ellipse, fillcolor="#B0BEC5"];
        spontaneous_clear [label="Spontaneous\nClearance\n(~20–25%,\nacute infection)", shape=ellipse, fillcolor="#C8E6C9"];
    }

    /* =========================================================
       CLUSTER 11 – Viral Dynamics Parameters
       ========================================================= */
    subgraph cluster_params {
        label="⑪ Viral Dynamics Parameters & Genotype";
        style=filled; bgcolor="#ECEFF1"; color="#455A64"; penwidth=2;

        GT1         [label="Genotype 1\n(Most prevalent\nNA/Europe)",          shape=ellipse, fillcolor="#CFD8DC"];
        GT2         [label="Genotype 2\n(SOF-sensitive)",                      shape=ellipse, fillcolor="#CFD8DC"];
        GT3         [label="Genotype 3\n(Steatosis, harder\nto treat NS5A)",   shape=ellipse, fillcolor="#CFD8DC"];
        GT4         [label="Genotype 4\n(MENA region)",                        shape=ellipse, fillcolor="#CFD8DC"];
        c_clearance [label="Viral Clearance\nRate c = 22 /day",                shape=ellipse, fillcolor="#B0BEC5"];
        delta_inf   [label="Infected Cell Loss\nδ = 1.0 /day",                 shape=ellipse, fillcolor="#B0BEC5"];
        R0_HCV      [label="Basic Reproduction\nNumber R₀ >> 1\n(chronic infection)", shape=diamond, fillcolor="#78909C", fontcolor=white];
        viral_load  [label="Baseline Viral Load\n(106–10⁸ IU/mL)",           shape=ellipse, fillcolor="#90A4AE"];
        rapid_VR    [label="Rapid Virological\nResponse (RVR)\n(wk4 TND)",    shape=ellipse, fillcolor="#CFD8DC"];
        EOT_resp    [label="End-of-Treatment\nResponse (EOTR)",                shape=ellipse, fillcolor="#CFD8DC"];
    }

    /* =========================================================
       CLUSTER 12 – Treatment Combinations
       ========================================================= */
    subgraph cluster_regimens {
        label="⑫ Approved DAA Regimen Combinations";
        style=filled; bgcolor="#FFF3E0"; color="#BF360C"; penwidth=2;

        SOF_LED     [label="SOF/LED\nHarvoni® (GT1/4/5/6)\n12 wk",            shape=box, fillcolor="#FFCC80"];
        SOF_VEL     [label="SOF/VEL\nEpclusa® (pangenotypic)\n12 wk",         shape=box, fillcolor="#FFB74D"];
        GLE_PIB     [label="GLE/PIB\nMavyret® (pangenotypic)\n8 wk naive",    shape=box, fillcolor="#FFA726"];
        SOF_VEL_VOX [label="SOF/VEL/VOX\nVosevi® (GT3 Y93H,\nprevious NS5A fail)", shape=box, fillcolor="#FF7043"];
        PEG_RBV     [label="PEG-IFN + RBV\n(Historical; PR therapy,\n48 wk)",  shape=box, fillcolor="#BCAAA4"];
        elbasvir_graz[label="Elbasvir/Grazoprevir\nZepatier® (GT1/4)\n12 wk", shape=box, fillcolor="#FFAB40"];
        ombitasvir  [label="Ombitasvir/Paritaprevir/\nRitonavir ± Dasabuvir\n(Viekira Pak®)", shape=box, fillcolor="#FFCC80"];
    }

    /* =========================================================
       EDGES — Viral Entry
       ========================================================= */
    HCV_E1E2    -> CD81         [color="#E65100"];
    HCV_E1E2    -> SR_B1        [color="#E65100"];
    CD81        -> CLDN1        [color="#E65100", label="co-receptor"];
    CD81        -> OCLN         [color="#E65100"];
    SR_B1       -> EGFR_NPC1L1  [color="#E65100"];
    lipoprotein -> HCV_E1E2     [color="#E65100", label="LVP association"];
    HCV_E1E2    -> clathrin     [color="#E65100"];
    clathrin    -> viral_fusion [color="#E65100"];
    viral_fusion -> uncoating   [color="#E65100"];
    uncoating   -> HCV_RNA_in   [color="#E65100"];

    /* Replication */
    HCV_RNA_in  -> IRES_trans   [color="#880E4F"];
    IRES_trans  -> polyprotein  [color="#880E4F"];
    polyprotein -> NS3_4A       [color="#880E4F", label="cleavage"];
    polyprotein -> NS5A         [color="#880E4F", label="cleavage"];
    polyprotein -> NS5B         [color="#880E4F", label="cleavage"];
    polyprotein -> NS4B         [color="#880E4F"];
    polyprotein -> NS2          [color="#880E4F"];
    polyprotein -> core         [color="#880E4F"];
    polyprotein -> E1_E2_struct [color="#880E4F"];
    NS5A        -> RC           [color="#880E4F"];
    NS4B        -> RC           [color="#880E4F"];
    NS5B        -> RC           [color="#880E4F"];
    RC          -> minus_RNA    [color="#880E4F", label="(−) template synthesis"];
    minus_RNA   -> plus_RNA     [color="#880E4F", label="(+) strand synthesis"];
    plus_RNA    -> HCV_RNA_in   [color="#880E4F", style=dashed, label="amplification"];
    core        -> lipid_drop   [color="#880E4F"];
    NS5A        -> LD_NS5A      [color="#880E4F"];
    lipid_drop  -> LD_NS5A      [color="#880E4F"];

    /* Assembly */
    LD_NS5A     -> capsid_assem [color="#283593"];
    core        -> capsid_assem [color="#283593"];
    plus_RNA    -> capsid_assem [color="#283593"];
    E1_E2_struct -> envelope_acq [color="#283593"];
    capsid_assem -> envelope_acq [color="#283593"];
    envelope_acq -> golgi_transit [color="#283593"];
    VLDL_pathway -> golgi_transit [color="#283593"];
    golgi_transit -> HCV_virion_out [color="#283593"];
    HCV_virion_out -> viral_prod  [color="#283593"];

    /* Innate Immune */
    HCV_RNA_in  -> RIG_I        [color="#2E7D32", label="dsRNA detection"];
    RIG_I       -> MAVS         [color="#2E7D32"];
    MAVS        -> IRF3         [color="#2E7D32"];
    IRF3        -> IFN_beta     [color="#2E7D32"];
    IRF3        -> IFN_alpha    [color="#2E7D32"];
    IFN_beta    -> IFNAR        [color="#1B5E20"];
    IFN_alpha   -> IFNAR        [color="#1B5E20"];
    IFN_lambda  -> IFNAR        [color="#1B5E20", style=dashed];
    IFNAR       -> JAK_TYK2    [color="#1B5E20"];
    JAK_TYK2    -> STAT1_2      [color="#1B5E20"];
    STAT1_2     -> ISRE         [color="#1B5E20"];
    ISRE        -> ISGs         [color="#1B5E20"];
    ISGs        -> PKR          [color="#1B5E20"];
    ISGs        -> OAS_RNaseL   [color="#1B5E20"];
    PKR         -> plus_RNA     [color="#27AE60", label="PKR→eIF2α\n→↓translation"];
    OAS_RNaseL  -> plus_RNA     [color="#27AE60", label="RNA cleavage"];
    NS3_4A      -> MAVS         [color="#C0392B", label="protease cleavage\n(immune evasion)"];
    NS3_4A_cut  -> MAVS         [color="#C0392B", label="evasion"];
    NS3_4A      -> NS3_4A_cut   [color="#C0392B"];
    CXCL10      -> CD8_CTL      [color="#1E88E5", label="recruit"];
    IL28B       -> IFN_lambda   [color="#1B5E20"];
    ISGs        -> CXCL10       [color="#1B5E20"];

    /* Adaptive Immune */
    HCV_virion_out -> B_cell    [color="#1565C0"];
    MHC_I       -> CD8_CTL      [color="#1565C0"];
    MHC_II      -> CD4_Th1      [color="#1565C0"];
    CD4_Th1     -> CD8_CTL      [color="#1565C0", label="help"];
    CD4_Th1     -> B_cell       [color="#1565C0"];
    CD8_CTL     -> I_cells      [color="#C0392B", label="kill"];
    CD8_CTL     -> IFN_gamma_T  [color="#C0392B"];
    IFN_gamma_T -> Macrophage_HCV [style=dashed, color="#999999"];
    CTL_exhaust -> CD8_CTL      [color="#C0392B", dir=back, label="exhaustion"];
    Treg_HCV    -> CD8_CTL      [color="#27AE60", label="suppress"];
    Treg_HCV    -> CD4_Th1      [color="#27AE60", label="suppress"];
    B_cell      -> anti_E2_Ab   [color="#1565C0"];
    NK_act      -> I_cells      [color="#C0392B", label="cytolysis"];
    NK_KIR      -> spontaneous_clear [style=dashed, color="#999999"];

    /* Liver Pathology */
    HCV_virion_out -> hepatocyte [color="#E65100", label="infection"];
    CD8_CTL     -> hepatocyte_death [color="#C0392B"];
    I_cells     -> hepatocyte_death [color="#C0392B", label="virus-induced"];
    hepatocyte_death -> ALT_level [color="#E67E22"];
    ALT_level   -> liver_inflam  [color="#E67E22"];
    liver_inflam -> TGF_b_liver  [color="#E67E22"];
    TGF_b_liver -> HSC_act       [color="#BF360C"];
    HSC         -> HSC_act       [color="#BF360C"];
    HSC_act     -> collagen      [color="#BF360C"];
    collagen    -> fibrosis      [color="#BF360C"];
    fibrosis    -> cirrhosis     [color="#8D1A0A", label="F4"];
    cirrhosis   -> HCC_risk      [color="#8D1A0A"];
    MMP_liver   -> collagen      [color="#27AE60", label="degrade"];
    TIMP_liver  -> MMP_liver     [color="#C0392B", label="inhibit"];
    TGF_b_liver -> TIMP_liver    [color="#E67E22"];
    steatosis   -> liver_inflam  [color="#E67E22"];
    HCV_RNA_in  -> steatosis     [color="#E67E22", style=dashed, label="GT3 direct"];

    /* DAA PK */
    SOF_dose    -> SOF_intrahep [color="#7E57C2", label="intrahepatic activation"];
    SOF_dose    -> SOF_GS331    [color="#7E57C2", label="plasma metabolite"];
    LED_dose    -> LED_plasma   [color="#7E57C2"];
    VEL_dose    -> VEL_plasma   [color="#7E57C2"];
    GLE_dose    -> GLE_plasma   [color="#7E57C2"];
    PIB_dose    -> PIB_plasma   [color="#7E57C2"];
    RBV_dose    -> RBV_plasma   [color="#CE93D8"];
    RBV_plasma  -> RBV_RBC      [color="#CE93D8", label="phosphorylation\nin RBCs"];
    food_effect -> LED_plasma   [color="#999999", style=dashed, label="↑Cp"];

    /* Drug PD */
    SOF_intrahep -> E_SOF       [color="#388E3C"];
    LED_plasma  -> E_LED        [color="#388E3C"];
    VEL_plasma  -> E_LED        [color="#388E3C"];
    GLE_plasma  -> E_GLE        [color="#388E3C"];
    PIB_plasma  -> E_LED        [color="#388E3C"];
    RBV_RBC     -> E_RBV        [color="#388E3C"];
    E_SOF       -> NS5B         [color="#27AE60", label="inhibit RdRp"];
    E_LED       -> NS5A         [color="#27AE60", label="inhibit NS5A"];
    E_GLE       -> NS3_4A       [color="#27AE60", label="inhibit protease"];
    E_SOF       -> epsilon_prod [color="#27AE60"];
    E_LED       -> epsilon_prod [color="#27AE60"];
    E_GLE       -> epsilon_prod [color="#27AE60"];
    E_RBV       -> epsilon_infect [color="#27AE60"];
    E_SOF       -> epsilon_infect [color="#27AE60", style=dashed];
    epsilon_prod    -> viral_prod_rate [color="#27AE60", label="↓production"];
    epsilon_infect  -> T_cells        [color="#27AE60", label="↓new infections"];
    barrier_resist  -> RAS            [dir=back, color="#E74C3C", label="selects"];

    /* Viral Kinetics */
    T_cells     -> I_cells      [color="#880E4F", label="β·V·T (infection)"];
    I_cells     -> V_free       [color="#880E4F", label="p (production)"];
    V_free      -> V_defective  [style=dashed, color="#999999"];
    V_free      -> T_cells      [color="#880E4F", label="infection\n(−δI)"];
    viral_prod_rate -> V_free   [color="#880E4F"];
    viral_clear_rate -> V_free  [color="#27AE60", label="clearance c·V"];
    infected_death -> I_cells   [color="#C0392B", dir=back, label="δ·I"];
    phase1      -> V_free       [color="#6A1B9A", dir=back, label="rapid"];
    phase2      -> I_cells      [color="#6A1B9A", dir=back, label="slow"];
    V_free      -> SVR12        [color="#6A1B9A", style=dashed, label="→ TND → SVR"];
    TND         -> SVR12        [color="#27AE60"];
    SVR12       -> relapse      [dir=back, color="#27AE60"];
    rapid_VR    -> SVR12        [color="#27AE60", style=dashed, label="predictor"];
    EOT_resp    -> SVR12        [color="#27AE60", style=dashed];

    /* Genotype effects */
    GT1         -> viral_load   [style=dashed, color="#999999"];
    GT3         -> steatosis    [color="#E67E22"];
    GT3         -> barrier_resist [color="#E74C3C", style=dashed];
    R0_HCV      -> V_free       [color="#999999", style=dashed];
    c_clearance -> viral_clear_rate [color="#999999"];
    delta_inf   -> infected_death [color="#999999"];

    /* Treatment regimens */
    SOF_LED     -> SOF_dose     [color="#BF360C", style=dashed];
    SOF_LED     -> LED_dose     [color="#BF360C", style=dashed];
    SOF_VEL     -> SOF_dose     [color="#BF360C", style=dashed];
    SOF_VEL     -> VEL_dose     [color="#BF360C", style=dashed];
    GLE_PIB     -> GLE_dose     [color="#BF360C", style=dashed];
    GLE_PIB     -> PIB_dose     [color="#BF360C", style=dashed];
    PEG_RBV     -> RBV_dose     [color="#BF360C", style=dashed];

    /* Clinical outcomes */
    SVR12       -> SVR_fibrosis [color="#27AE60"];
    SVR12       -> HCC_prevent  [color="#27AE60"];
    SVR12       -> all_cause_mort [color="#27AE60"];
    SVR12       -> HRQoL        [color="#27AE60"];
    SVR12       -> extrahep     [color="#27AE60"];
    cirrhosis   -> MELD_score   [color="#C0392B"];
    MELD_score  -> LT_waitlist  [color="#C0392B"];
    SVR12       -> LT_waitlist  [color="#27AE60", label="removal\nfrom list"];
    fibrosis    -> HCC_risk     [style=dashed, color="#999999"];

    /* Hidden node for layout */
    Macrophage_HCV [label="Kupffer Cell\n(Hepatic Macrophage)", shape=ellipse, fillcolor="#A5D6A7", style=filled];
    Macrophage_HCV -> liver_inflam [color="#E67E22"];
    Macrophage_HCV -> TGF_b_liver  [color="#E67E22"];
}
