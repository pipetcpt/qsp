digraph ChrGastritis_QSP {

  graph [
    label = "Chronic Gastritis QSP Model\nH. pylori Colonization → Virulence → Inflammation → Correa Cascade → Eradication Therapy",
    labelloc = t, fontsize = 20, fontname = "Helvetica-Bold",
    splines = ortho, rankdir = LR, nodesep = 0.38, ranksep = 0.80,
    bgcolor = "#FAFAFA", compound = true
  ]
  node [fontname = "Helvetica", fontsize = 9, style = "filled,rounded", shape = box]
  edge [fontname = "Helvetica", fontsize = 7, arrowsize = 0.7]

  /* ============================================================
     CLUSTER 0 – H. pylori Colonization
     ============================================================ */
  subgraph cluster_Hp {
    label = "H. pylori Colonization"
    style = filled; color = "#388E3C"; bgcolor = "#E8F5E9"

    Hp_luminal     [label = "H. pylori\n(Luminal)", fillcolor = "#A5D6A7"]
    Hp_mucosal     [label = "H. pylori\n(Mucosal)",  fillcolor = "#66BB6A"]
    Hp_adhesion    [label = "Mucosal\nAdhesion",     fillcolor = "#81C784"]
    Hp_motility    [label = "Flagellar\nMotility",   fillcolor = "#A5D6A7"]
    Hp_urease      [label = "Urease\nActivity",      fillcolor = "#C8E6C9"]
    NH3_local      [label = "NH₃ (Local)",           fillcolor = "#DCEDC8"]
    Hp_growth_rate [label = "Hp Net\nGrowth Rate",   fillcolor = "#81C784"]
    gastric_pH     [label = "Luminal pH",            fillcolor = "#AED581"]
    mucus_pen      [label = "Mucus Layer\nPenetration", fillcolor = "#C5E1A5"]
    Hp_density     [label = "Hp Density\n(CFU/biopsy)",fillcolor = "#66BB6A"]
  }

  /* ============================================================
     CLUSTER 1 – Virulence Factors
     ============================================================ */
  subgraph cluster_VF {
    label = "Virulence Factors (CagA / VacA / OipA / HopQ)"
    style = filled; color = "#1565C0"; bgcolor = "#E3F2FD"

    cagPAI       [label = "cag Pathogenicity\nIsland (cagPAI)",   fillcolor = "#90CAF9"]
    CagA_T4SS    [label = "CagA Injection\nvia T4SS",             fillcolor = "#90CAF9"]
    CagA_cell    [label = "Intracellular CagA\n(Western strains)", fillcolor = "#42A5F5"]
    EPIYA        [label = "EPIYA Motif\nPhosphorylation",          fillcolor = "#42A5F5"]
    CagA_SHP2    [label = "CagA–SHP2\nComplex",                   fillcolor = "#1E88E5"]
    VacA_s1m1    [label = "VacA (s1/m1)\nHigh-toxicity strain",   fillcolor = "#90CAF9"]
    VacA_vacuole [label = "VacA-induced\nVacuolation",            fillcolor = "#64B5F6"]
    VacA_mito    [label = "VacA →\nMitochondria",                 fillcolor = "#64B5F6"]
    VacA_pore    [label = "VacA Pore\nFormation",                  fillcolor = "#90CAF9"]
    OipA         [label = "OipA Outer\nMembrane Protein",         fillcolor = "#BBDEFB"]
    HopQ         [label = "HopQ Adhesin\n(CEA binding)",           fillcolor = "#BBDEFB"]
    babA         [label = "BabA Adhesin\n(Lewis b binding)",       fillcolor = "#BBDEFB"]
    sabA         [label = "SabA Adhesin\n(sialyl-Lex binding)",   fillcolor = "#C3E5FD"]
    LPS_Hp       [label = "H. pylori LPS\n(TLR4 agonist)",        fillcolor = "#BBDEFB"]
    flagellin_Hp [label = "H. pylori\nFlagellin (TLR5)",          fillcolor = "#BBDEFB"]
    PG_fragment  [label = "Peptidoglycan\nFragment (NOD1)",        fillcolor = "#BBDEFB"]
    CagA_EGFR    [label = "CagA →\nEGFR Activation",              fillcolor = "#90CAF9"]
  }

  /* ============================================================
     CLUSTER 2 – Innate Immune Response
     ============================================================ */
  subgraph cluster_innate {
    label = "Innate Immune Response"
    style = filled; color = "#880E4F"; bgcolor = "#FCE4EC"

    TLR4_ep       [label = "TLR4 (Epithelial)",      fillcolor = "#F48FB1"]
    TLR5_ep       [label = "TLR5 (Epithelial)",      fillcolor = "#F48FB1"]
    TLR9_ep       [label = "TLR9 (Epithelial)",      fillcolor = "#F48FB1"]
    NOD1          [label = "NOD1 Receptor\n(RIPK2)", fillcolor = "#F06292"]
    NLRP3         [label = "NLRP3\nInflammasome",    fillcolor = "#EC407A"]
    NFkB          [label = "NF-κB\nActivation",      fillcolor = "#E91E63"]
    AP1           [label = "AP-1\nActivation",       fillcolor = "#EC407A"]
    MAPK_ERK      [label = "MAPK/ERK\nPathway",      fillcolor = "#F48FB1"]
    IL8_ep        [label = "IL-8\n(Epithelial pg/mL)",fillcolor = "#F8BBD0"]
    IL1b_pro      [label = "Pro-IL-1β",              fillcolor = "#F8BBD0"]
    IL1b          [label = "IL-1β\n(Mature pg/mL)",  fillcolor = "#F06292"]
    TNFa          [label = "TNF-α\n(pg/mL)",         fillcolor = "#F06292"]
    IL6           [label = "IL-6\n(pg/mL)",          fillcolor = "#F48FB1"]
    IL18          [label = "IL-18\n(pg/mL)",         fillcolor = "#F48FB1"]
    Caspase1      [label = "Caspase-1\n(Activated)", fillcolor = "#F8BBD0"]
    ROS_ep        [label = "ROS\n(Epithelial)",       fillcolor = "#FF80AB"]
    iNOS          [label = "iNOS → NO\n(RNS)",       fillcolor = "#F8BBD0"]
    Neutrophil    [label = "Neutrophils\n(Gastric)",  fillcolor = "#F06292"]
    NET_form      [label = "NET\nFormation",          fillcolor = "#F8BBD0"]
    elastase      [label = "Neutrophil\nElastase",   fillcolor = "#F8BBD0"]
    MPO           [label = "Myeloperoxidase\n(HOCl)",fillcolor = "#F8BBD0"]
    Macrophage_M1 [label = "M1 Macrophage\n(Pro-inflam)",  fillcolor = "#E91E63"]
    Macrophage_M2 [label = "M2 Macrophage\n(Anti-inflam)", fillcolor = "#F48FB1"]
    DC            [label = "Dendritic Cell\n(Gastric)",     fillcolor = "#F8BBD0"]
    COX2_ep       [label = "COX-2\n(Epithelial)",   fillcolor = "#F48FB1"]
    PGE2_inflam   [label = "PGE2 (Pro-\ninflammatory)",    fillcolor = "#F8BBD0"]
  }

  /* ============================================================
     CLUSTER 3 – Adaptive Immune Response
     ============================================================ */
  subgraph cluster_adaptive {
    label = "Adaptive Immune Response"
    style = filled; color = "#4527A0"; bgcolor = "#EDE7F6"

    IL12_23   [label = "IL-12 / IL-23",          fillcolor = "#B39DDB"]
    IL10      [label = "IL-10\n(Anti-inflam)",    fillcolor = "#CE93D8"]
    TGFb      [label = "TGF-β",                  fillcolor = "#B39DDB"]
    Th1       [label = "Th1 Cells\n(IFN-γ, TNF-α)",fillcolor = "#7E57C2"]
    Th2       [label = "Th2 Cells\n(IL-4, IL-13)",fillcolor = "#9575CD"]
    Th17      [label = "Th17 Cells\n(IL-17A/F)",  fillcolor = "#7C4DFF"]
    Treg      [label = "T-reg Cells\n(FoxP3+)",   fillcolor = "#B39DDB"]
    CD8_T     [label = "CD8+ CTL",               fillcolor = "#9575CD"]
    IFNg      [label = "IFN-γ",                  fillcolor = "#673AB7"]
    IL17A     [label = "IL-17A / IL-17F",         fillcolor = "#7C4DFF"]
    IL4_IL13  [label = "IL-4 / IL-13",           fillcolor = "#CE93D8"]
    B_cell    [label = "B Cells\n(Germinal Center)",fillcolor = "#CE93D8"]
    IgA_HP    [label = "Anti-Hp IgA\n(Mucosal)",  fillcolor = "#B39DDB"]
    IgG_HP    [label = "Anti-Hp IgG\n(Systemic)", fillcolor = "#B39DDB"]
    MALT_lymph[label = "MALT Lymphoid\nTissue",   fillcolor = "#CE93D8"]
  }

  /* ============================================================
     CLUSTER 4 – Gastric Physiology
     ============================================================ */
  subgraph cluster_gastric {
    label = "Gastric Physiology"
    style = filled; color = "#F57F17"; bgcolor = "#FFFDE7"

    PariCell     [label = "Parietal Cells\n(Corpus)",        fillcolor = "#FFF176"]
    HKATPase     [label = "H⁺/K⁺-ATPase\n(Proton Pump)",    fillcolor = "#FDD835"]
    HCl_output   [label = "Gastric HCl\n(mmol/h)",           fillcolor = "#FFEE58"]
    H2R          [label = "H₂ Receptor",                     fillcolor = "#FFF176"]
    M3R          [label = "M3 Receptor\n(ACh)",              fillcolor = "#FFF176"]
    CCK2R        [label = "CCK-2R\n(Gastrin receptor)",      fillcolor = "#FFF176"]
    Gastrin      [label = "Gastrin G17\n(pg/mL, G-cell)",   fillcolor = "#FDD835"]
    Gcell        [label = "G Cells\n(Antrum)",               fillcolor = "#FFF176"]
    Dcell        [label = "D Cells\n(Somatostatin)",         fillcolor = "#FFF176"]
    Somatostatin [label = "Somatostatin\n(SST)",             fillcolor = "#FFF9C4"]
    ECL_cell     [label = "ECL Cells\n(Enterochromaffin-like)",fillcolor = "#FFF176"]
    Histamine_E  [label = "Histamine\n(ECL release)",         fillcolor = "#FFF176"]
    mucus_layer  [label = "Mucus Layer\n(μm thickness)",     fillcolor = "#FFF9C4"]
    MUC5AC       [label = "MUC5AC\n(Surface mucin)",         fillcolor = "#FFF176"]
    MUC6         [label = "MUC6\n(Gland mucin)",             fillcolor = "#FFF9C4"]
    PGE2_mucosal [label = "PGE2 (Mucosal\nProtection)",      fillcolor = "#FFF9C4"]
    HCO3_sec     [label = "HCO₃⁻ Secretion\n(Buffer)",      fillcolor = "#FFF9C4"]
    EGF_mucosa   [label = "EGF Receptor\n(Repair)",          fillcolor = "#FFF176"]
    Pepsinogen   [label = "Pepsinogen I/II\n(Chief cells)",  fillcolor = "#FFF176"]
    Pepsin       [label = "Pepsin\n(Active enzyme)",         fillcolor = "#FFEE58"]
  }

  /* ============================================================
     CLUSTER 5 – Correa Cascade (Disease Progression)
     ============================================================ */
  subgraph cluster_correa {
    label = "Correa Cascade (Gastric Disease Progression)"
    style = filled; color = "#BF360C"; bgcolor = "#FBE9E7"

    Normal_mucosa    [label = "Normal Gastric\nMucosa",             fillcolor = "#FFCCBC"]
    Superficial_G    [label = "Superficial / Non-atrophic\nGastritis (NAG)", fillcolor = "#FFAB91"]
    Atrophic_G       [label = "Atrophic Gastritis\n(CAG) – OLGA I-II",      fillcolor = "#FF8A65"]
    IM_complete      [label = "Complete Intestinal\nMetaplasia (Type I)",    fillcolor = "#FF7043"]
    IM_incomplete    [label = "Incomplete IM\n(Type II/III – High risk)",    fillcolor = "#F4511E"]
    LGD              [label = "Low-grade\nDysplasia (LGD)",                  fillcolor = "#E64A19"]
    HGD              [label = "High-grade\nDysplasia (HGD)",                 fillcolor = "#D84315"]
    EGC              [label = "Early Gastric\nCancer (EGC)",                 fillcolor = "#BF360C"]
    MMP_ecm          [label = "MMPs (1/3/7/9)\nECM Degradation",            fillcolor = "#FF8A65"]
    CDH1_loss        [label = "E-cadherin Loss\n(CDH1 silencing)",           fillcolor = "#FF7043"]
    p53_mut          [label = "TP53 Mutation\n(DNA damage)",                 fillcolor = "#E64A19"]
    RUNX3_loss       [label = "RUNX3 Loss\n(tumor suppressor)",              fillcolor = "#F4511E"]
    COX2_up          [label = "COX-2 Upregulation\n(carcinogenesis)",        fillcolor = "#FF8A65"]
    PCNA_prolif      [label = "PCNA / Ki-67\nProliferation Index",           fillcolor = "#FFAB91"]
    Wnt_path         [label = "Wnt/β-catenin\nActivation",                  fillcolor = "#FF8A65"]
    EGFR_amp         [label = "EGFR Amplification\n(cancer driver)",         fillcolor = "#BF360C"]
    PG_I_level       [label = "Pepsinogen I\n(Corpus function)",             fillcolor = "#FFCCBC"]
    PG_II_level      [label = "Pepsinogen II\n(Inflam marker)",              fillcolor = "#FFCCBC"]
    PG_ratio_val     [label = "PGI/PGII Ratio\n(<3 → severe atrophy)",      fillcolor = "#FFAB91"]
    OLGA_stage       [label = "OLGA Stage\n(0 → IV)",                       fillcolor = "#FF8A65"]
  }

  /* ============================================================
     CLUSTER 6 – Drug PK
     ============================================================ */
  subgraph cluster_PK {
    label = "Drug Pharmacokinetics (PK)"
    style = filled; color = "#37474F"; bgcolor = "#ECEFF1"

    PPI_oral    [label = "PPI Oral Dose\n(omeprazole 20mg)", fillcolor = "#B0BEC5"]
    PPI_gut     [label = "PPI (GI Lumen)",                   fillcolor = "#90A4AE"]
    PPI_plasma  [label = "PPI Plasma\n(Cp, mg/L)",           fillcolor = "#78909C"]
    PPI_acid    [label = "PPI Active Sulfenamide\n(Canalicular)", fillcolor = "#546E7A"]
    AMX_oral    [label = "Amoxicillin Oral\n(1000 mg BID)",  fillcolor = "#B0BEC5"]
    AMX_plasma  [label = "AMX Plasma\n(mg/L)",               fillcolor = "#90A4AE"]
    AMX_gastric [label = "AMX Gastric\nMucosa (mg/L)",       fillcolor = "#78909C"]
    CLR_oral    [label = "Clarithromycin Oral\n(500 mg BID)",fillcolor = "#B0BEC5"]
    CLR_plasma  [label = "CLR Plasma\n(mg/L)",               fillcolor = "#90A4AE"]
    CLR_gastric [label = "CLR Gastric\nMucosa (mg/L)",       fillcolor = "#78909C"]
    MTZ_oral    [label = "Metronidazole Oral\n(500 mg TID)", fillcolor = "#B0BEC5"]
    MTZ_plasma  [label = "MTZ Plasma\n(mg/L)",               fillcolor = "#90A4AE"]
    BSS_oral    [label = "Bismuth Subsalicylate\n(525 mg QID)",fillcolor = "#B0BEC5"]
    BSS_mucosa  [label = "Bismuth Gastric\nMucosa",          fillcolor = "#90A4AE"]
    VPZ_oral    [label = "Vonoprazan Oral\n(20 mg QD)",      fillcolor = "#B0BEC5"]
    VPZ_plasma  [label = "VPZ Plasma\n(mg/L)",               fillcolor = "#90A4AE"]
    TET_oral    [label = "Tetracycline Oral\n(500 mg QID)",  fillcolor = "#B0BEC5"]
    TET_gastric [label = "TET Gastric\nMucosa (mg/L)",       fillcolor = "#78909C"]
  }

  /* ============================================================
     CLUSTER 7 – Drug PD
     ============================================================ */
  subgraph cluster_PD {
    label = "Drug Pharmacodynamics (PD)"
    style = filled; color = "#0277BD"; bgcolor = "#E1F5FE"

    PPI_effect    [label = "PPI → Irreversible\nH+/K+-ATPase Inhibition",  fillcolor = "#81D4FA"]
    VPZ_effect    [label = "VPZ → K+-competitive\nAcid Blocker (fast)",     fillcolor = "#4FC3F7"]
    AMX_PD        [label = "AMX → β-lactam\nPBP Binding (Hp)",              fillcolor = "#81D4FA"]
    CLR_PD        [label = "CLR → 23S rRNA\nBinding (50S inhibition)",      fillcolor = "#81D4FA"]
    MTZ_PD        [label = "MTZ → rdxA nitroreduction\n→ DNA strand break", fillcolor = "#81D4FA"]
    BSS_PD        [label = "Bismuth → Hp Adhesion\n+ Membrane Block",       fillcolor = "#81D4FA"]
    TET_PD        [label = "TET → 30S ribosome\nInhibition (Hp)",           fillcolor = "#81D4FA"]
    CLR_resist    [label = "CLR Resistance\n(23S rRNA A2142/A2143G)",       fillcolor = "#4FC3F7"]
    MTZ_resist    [label = "MTZ Resistance\n(rdxA, frxA mutation)",         fillcolor = "#4FC3F7"]
    AMX_resist    [label = "AMX Resistance\n(PBP1 mutation; rare <1%)",     fillcolor = "#4FC3F7"]
    dual_resist   [label = "Dual Resistance\n(CLR+MTZ; >15% failure risk)", fillcolor = "#0288D1"]
    pH_ABX_stab   [label = "pH ↑ → AMX/CLR\nStability ↑ (MIC effective↓)", fillcolor = "#81D4FA"]
    kill_rate_Hp  [label = "Hp Kill Rate\n(bacteria/day)",                  fillcolor = "#29B6F6"]
    eradication   [label = "Hp Eradication\n(ITT ≥90%)",                   fillcolor = "#0288D1"]
    reinfection   [label = "Reinfection Rate\n(<1%/year in adults)",        fillcolor = "#81D4FA"]
  }

  /* ============================================================
     CLUSTER 8 – Clinical Endpoints & Biomarkers
     ============================================================ */
  subgraph cluster_endpoints {
    label = "Clinical Endpoints & Biomarkers"
    style = filled; color = "#2E7D32"; bgcolor = "#F1F8E9"

    symptom_score  [label = "Global Symptom Score\n(GIS 0-16)",        fillcolor = "#A5D6A7"]
    epigastric_pain[label = "Epigastric Pain\n(NRS 0-10)",             fillcolor = "#81C784"]
    nausea_bloat   [label = "Nausea / Bloating\n(NRS 0-10)",           fillcolor = "#A5D6A7"]
    early_satiety  [label = "Early Satiety /\nBelching",               fillcolor = "#A5D6A7"]
    UBT_result     [label = "¹³C-UBT\n(Eradication test)",             fillcolor = "#66BB6A"]
    HpSA_stool     [label = "Stool Antigen\n(HpSA, eradication)",      fillcolor = "#81C784"]
    Hp_serology    [label = "H. pylori IgG\n(Serology)",               fillcolor = "#A5D6A7"]
    CagA_sero      [label = "CagA IgG\n(Serology)",                    fillcolor = "#A5D6A7"]
    PGI_serum      [label = "Pepsinogen I\n(Serum, μg/L)",             fillcolor = "#A5D6A7"]
    PGII_serum     [label = "Pepsinogen II\n(Serum, μg/L)",            fillcolor = "#A5D6A7"]
    PGratio_serum  [label = "PGI/PGII Ratio\n(<3: atrophy screen)",    fillcolor = "#66BB6A"]
    G17_serum      [label = "Gastrin-17\n(Serum, pmol/L)",             fillcolor = "#A5D6A7"]
    GastroPanel    [label = "GastroPanel®\n(PGI+PGII+G17+IgG)",       fillcolor = "#81C784"]
    endoscopy_score[label = "Endoscopy Score\n(OLGA + modified Sydney)",fillcolor = "#66BB6A"]
    histology_upd  [label = "Histology\n(Updated Sydney System)",       fillcolor = "#81C784"]
    functional_dysp[label = "Functional Dyspepsia\n(Rome IV)",         fillcolor = "#A5D6A7"]
  }

  /* ============================================================
     CLUSTER 9 – Systemic & Extra-gastric Effects
     ============================================================ */
  subgraph cluster_systemic {
    label = "Systemic / Extra-gastric Effects"
    style = filled; color = "#E65100"; bgcolor = "#FFF3E0"

    iron_def     [label = "Iron Deficiency\n(IDA – achlorhydria)",    fillcolor = "#FFCC80"]
    vitB12_def   [label = "Vitamin B12\nDeficiency (IF loss)",        fillcolor = "#FFCC80"]
    ITP_Hp       [label = "H. pylori-associated\nITP",                fillcolor = "#FFA726"]
    IHD_Hp       [label = "Cardiovascular Risk\n(Hp-IgG cross-react)",fillcolor = "#FFA726"]
    MALT_lymph2  [label = "Gastric MALT\nLymphoma",                   fillcolor = "#FF7043"]
    GC_lifetime  [label = "Gastric Cancer\nLifetime Risk ↑",          fillcolor = "#E64A19"]
    NSAID_risk   [label = "NSAID → COX-1 block\n→ PGE2 ↓",          fillcolor = "#FFCC80"]
    stress_muc   [label = "Stress-related\nMucosal Disease",          fillcolor = "#FFA726"]
    portal_hyp   [label = "Portal Gastropathy\n(Cirrhosis)",          fillcolor = "#FFCC80"]
    bile_reflux  [label = "Bile Reflux\n(DGER)",                      fillcolor = "#FFCC80"]
    proton_alkal [label = "Alkaline Tide\n(Post-prandial)",           fillcolor = "#FFF3E0"]
  }

  /* ============================================================
     EDGES – Colonization
     ============================================================ */
  Hp_luminal  -> Hp_adhesion    [label = "BabA/HopQ"]
  Hp_motility -> mucus_pen      [label = "enables"]
  mucus_pen   -> Hp_adhesion    [label = "penetrates"]
  Hp_adhesion -> Hp_mucosal     [label = "establishes"]
  Hp_urease   -> NH3_local      [label = "generates"]
  NH3_local   -> gastric_pH     [label = "alkalinizes"]
  gastric_pH  -> Hp_growth_rate [label = "pH 6-7 optimal"]
  Hp_growth_rate -> Hp_mucosal  [label = "proliferates"]
  Hp_mucosal  -> Hp_density     [label = "quantified as"]
  babA        -> Hp_adhesion    [label = "Lewis b bond"]
  sabA        -> Hp_adhesion    [label = "sialyl-Lex bond"]

  /* ============================================================
     EDGES – Virulence Factors
     ============================================================ */
  Hp_mucosal -> cagPAI         [label = "expresses"]
  cagPAI     -> CagA_T4SS      [label = "encodes T4SS"]
  CagA_T4SS  -> CagA_cell      [label = "injects CagA"]
  CagA_cell  -> EPIYA          [label = "phosphorylates"]
  EPIYA      -> CagA_SHP2      [label = "binds SHP2"]
  CagA_SHP2  -> MAPK_ERK       [label = "activates"]
  CagA_cell  -> CagA_EGFR      [label = "transactivates"]
  CagA_EGFR  -> MAPK_ERK       [label = "activates"]
  Hp_mucosal -> VacA_s1m1      [label = "secretes"]
  VacA_s1m1  -> VacA_vacuole   [label = "vacuolation"]
  VacA_s1m1  -> VacA_pore      [label = "pore formation"]
  VacA_vacuole -> VacA_mito    [label = "targets mitochond"]
  VacA_mito  -> ROS_ep         [label = "generates ROS"]
  VacA_pore  -> NLRP3          [label = "activates"]
  Hp_mucosal -> OipA           [label = "expresses"]
  OipA       -> NFkB           [label = "direct activation"]
  Hp_mucosal -> HopQ           [label = "expresses"]
  HopQ       -> Hp_adhesion    [label = "CEA mediated"]
  Hp_mucosal -> LPS_Hp         [label = "releases"]
  LPS_Hp     -> TLR4_ep        [label = "agonist"]
  Hp_mucosal -> flagellin_Hp   [label = "releases"]
  flagellin_Hp -> TLR5_ep      [label = "agonist"]
  Hp_mucosal -> PG_fragment    [label = "releases"]
  PG_fragment -> NOD1          [label = "activates"]

  /* ============================================================
     EDGES – Innate Immunity
     ============================================================ */
  TLR4_ep  -> NFkB        [label = "MyD88"]
  TLR5_ep  -> NFkB        [label = "TRIF"]
  TLR9_ep  -> NFkB        [label = "CpG DNA"]
  NOD1     -> NFkB        [label = "RIPK2"]
  MAPK_ERK -> AP1         [label = "activates"]
  NFkB     -> IL8_ep      [label = "transcribes"]
  NFkB     -> TNFa        [label = "transcribes"]
  NFkB     -> IL6         [label = "transcribes"]
  NFkB     -> IL1b_pro    [label = "transcribes"]
  NFkB     -> iNOS        [label = "transcribes"]
  NFkB     -> COX2_ep     [label = "transcribes"]
  AP1      -> IL8_ep      [label = "co-transcribes"]
  AP1      -> COX2_ep     [label = "co-transcribes"]
  COX2_ep  -> PGE2_inflam [label = "produces"]
  NLRP3    -> Caspase1    [label = "activates"]
  Caspase1 -> IL1b        [label = "cleaves pro-IL1β"]
  Caspase1 -> IL18        [label = "cleaves pro-IL18"]
  IL1b_pro -> IL1b        [label = "via Caspase-1"]
  IL8_ep   -> Neutrophil  [label = "chemotaxis"]
  Neutrophil -> ROS_ep    [label = "NADPH oxidase"]
  Neutrophil -> NET_form  [label = "NETosis"]
  Neutrophil -> elastase  [label = "releases"]
  Neutrophil -> MPO       [label = "releases"]
  MPO      -> ROS_ep      [label = "HOCl generation"]
  ROS_ep   -> NFkB        [label = "amplifies (loop)"]
  iNOS     -> ROS_ep      [label = "NO + RNS"]
  TNFa     -> Macrophage_M1 [label = "activates"]
  IL6      -> DC          [label = "matures"]
  DC       -> Th1         [label = "IL-12-dependent"]
  DC       -> Th17        [label = "IL-23-dependent"]
  Macrophage_M1 -> IL12_23  [label = "secretes"]
  Macrophage_M1 -> TNFa     [label = "amplifies"]
  Macrophage_M2 -> IL10     [label = "secretes"]
  Macrophage_M2 -> TGFb     [label = "secretes"]

  /* ============================================================
     EDGES – Adaptive Immunity
     ============================================================ */
  IL12_23 -> Th1         [label = "IL-12 polarizes"]
  Th1     -> IFNg        [label = "secretes"]
  IFNg    -> Macrophage_M1 [label = "activates M1"]
  IFNg    -> CD8_T       [label = "activates CTL"]
  CD8_T   -> MALT_lymph  [label = "populates"]
  Th2     -> IL4_IL13    [label = "secretes"]
  IL4_IL13 -> B_cell     [label = "class switch IgA"]
  B_cell  -> IgA_HP      [label = "secretory IgA"]
  B_cell  -> IgG_HP      [label = "systemic IgG"]
  B_cell  -> MALT_lymph  [label = "forms follicles"]
  IgA_HP  -> Hp_mucosal  [label = "opsonizes"]
  Th17    -> IL17A       [label = "secretes"]
  IL17A   -> NFkB        [label = "amplifies"]
  TGFb    -> Treg        [label = "induces FoxP3"]
  Treg    -> Th1         [label = "suppresses (IL-10)"]
  Treg    -> Th17        [label = "suppresses"]
  IL10    -> NFkB        [label = "inhibits"]
  IL12_23 -> Th17        [label = "IL-23 stabilizes"]

  /* ============================================================
     EDGES – Gastric Physiology
     ============================================================ */
  Hp_mucosal  -> Gcell        [label = "antral HP → G-cell↑"]
  Gcell       -> Gastrin       [label = "secretes G17"]
  Gastrin     -> CCK2R         [label = "binds CCK-2R"]
  CCK2R       -> PariCell      [label = "stimulates"]
  CCK2R       -> ECL_cell      [label = "stimulates"]
  ECL_cell    -> Histamine_E   [label = "releases"]
  Histamine_E -> H2R           [label = "binds H2R"]
  H2R         -> PariCell      [label = "stimulates"]
  PariCell    -> HKATPase      [label = "expresses"]
  HKATPase    -> HCl_output    [label = "pumps H⁺"]
  HCl_output  -> gastric_pH    [label = "acidifies lumen"]
  Dcell       -> Somatostatin  [label = "secretes SST"]
  Somatostatin -> Gcell        [label = "inhibits"]
  Somatostatin -> ECL_cell     [label = "inhibits"]
  Hp_mucosal  -> Somatostatin  [label = "inhibits D-cell"]
  mucus_layer -> MUC5AC        [label = "key component"]
  mucus_layer -> MUC6          [label = "deep layer"]
  PGE2_mucosal -> mucus_layer  [label = "stimulates"]
  PGE2_mucosal -> HCO3_sec     [label = "stimulates"]
  EGF_mucosa  -> mucus_layer   [label = "repairs"]
  Pepsinogen  -> Pepsin        [label = "HCl activation"]
  HCl_output  -> Pepsin        [label = "activates"]
  IL1b        -> PariCell      [label = "inhibits (potent)"]
  TNFa        -> PariCell      [label = "inhibits"]
  IFNg        -> PariCell      [label = "inhibits"]
  ROS_ep      -> mucus_layer   [label = "degrades"]
  elastase    -> mucus_layer   [label = "degrades"]

  /* ============================================================
     EDGES – Correa Cascade
     ============================================================ */
  Normal_mucosa -> Superficial_G [label = "Hp + inflammation"]
  Superficial_G -> Atrophic_G   [label = "chronic inflam\n(years–decades)"]
  Atrophic_G    -> IM_complete  [label = "intestinal\nmetaplasia"]
  IM_complete   -> IM_incomplete [label = "type switch\n(incomplete IM)"]
  IM_incomplete -> LGD           [label = "dysplasia"]
  LGD           -> HGD           [label = "progression"]
  HGD           -> EGC           [label = "carcinoma"]
  IL1b          -> Atrophic_G    [label = "drives atrophy"]
  TNFa          -> Atrophic_G    [label = "drives"]
  IFNg          -> Atrophic_G    [label = "drives"]
  ROS_ep        -> p53_mut       [label = "DNA damage"]
  ROS_ep        -> CDH1_loss     [label = "oxidative silencing"]
  MMP_ecm       -> Atrophic_G    [label = "ECM destruction"]
  CDH1_loss     -> LGD           [label = "loss of polarity"]
  RUNX3_loss    -> IM_incomplete [label = "epigenetic silencing"]
  p53_mut       -> HGD           [label = "clonal expansion"]
  COX2_up       -> EGC           [label = "promotes survival"]
  Wnt_path      -> LGD           [label = "Wnt activation"]
  EGFR_amp      -> EGC           [label = "growth signal"]
  PCNA_prolif   -> LGD           [label = "proliferation"]
  NFkB          -> COX2_up       [label = "transcribes"]
  Atrophic_G    -> PG_I_level    [label = "corpus damage\n→ PGI↓"]
  IL8_ep        -> PG_II_level   [label = "inflammation\n→ PGII↑"]
  PG_I_level    -> PG_ratio_val  [label = "numerator"]
  PG_II_level   -> PG_ratio_val  [label = "denominator"]
  PG_ratio_val  -> OLGA_stage    [label = "correlates (<3)"]
  MALT_lymph    -> MALT_lymph2   [label = "rare progression"]
  EGC           -> GC_lifetime   [label = "represents"]

  /* ============================================================
     EDGES – Drug PK
     ============================================================ */
  PPI_oral   -> PPI_gut     [label = "dissolution\nF=0.65"]
  PPI_gut    -> PPI_plasma  [label = "absorption\nKa=0.50/h"]
  PPI_plasma -> PPI_acid    [label = "canalicular uptake\nthen activated"]
  AMX_oral   -> AMX_plasma  [label = "F=0.90 Ka=1.0/h"]
  AMX_plasma -> AMX_gastric [label = "Kd distribution"]
  CLR_oral   -> CLR_plasma  [label = "F=0.55 Ka=0.6/h"]
  CLR_plasma -> CLR_gastric [label = "8-12× tissue conc"]
  MTZ_oral   -> MTZ_plasma  [label = "F=0.99 Ka=0.8/h"]
  BSS_oral   -> BSS_mucosa  [label = "local action"]
  VPZ_oral   -> VPZ_plasma  [label = "F=0.80 Ka=1.2/h"]
  TET_oral   -> TET_gastric [label = "F=0.75 Ka=0.7/h"]

  /* ============================================================
     EDGES – Drug PD
     ============================================================ */
  PPI_acid    -> PPI_effect  [label = "irreversible bind"]
  PPI_effect  -> HKATPase    [label = "covalent inhibit"]
  VPZ_plasma  -> VPZ_effect  [label = "K+-competitive"]
  VPZ_effect  -> HKATPase    [label = "fast reversible block"]
  HKATPase    -> HCl_output  [label = "inhibited → pH↑"]
  HCl_output  -> pH_ABX_stab [label = "pH 5-6 → stable AMX"]
  PPI_effect  -> pH_ABX_stab [label = "raises pH"]
  AMX_gastric -> AMX_PD      [label = "MIC > 0.016-0.5 mg/L"]
  CLR_gastric -> CLR_PD      [label = "MIC > 0.016-64 mg/L"]
  MTZ_plasma  -> MTZ_PD      [label = "MIC > 0.25-32 mg/L"]
  BSS_mucosa  -> BSS_PD      [label = "local barrier"]
  TET_gastric -> TET_PD      [label = "ribosome block"]
  CLR_resist  -> CLR_PD      [label = "reduces efficacy"]
  MTZ_resist  -> MTZ_PD      [label = "reduces efficacy"]
  CLR_resist  -> dual_resist [label = "component"]
  MTZ_resist  -> dual_resist [label = "component"]
  AMX_PD      -> kill_rate_Hp [label = "contributes"]
  CLR_PD      -> kill_rate_Hp [label = "contributes (major)"]
  MTZ_PD      -> kill_rate_Hp [label = "contributes"]
  BSS_PD      -> kill_rate_Hp [label = "reduces adhesion"]
  TET_PD      -> kill_rate_Hp [label = "contributes"]
  pH_ABX_stab -> AMX_PD      [label = "enhances efficacy"]
  kill_rate_Hp -> eradication [label = "outcome (14 days)"]
  eradication -> Hp_mucosal   [label = "clears bacteria"]
  Hp_mucosal  -> reinfection  [label = "rare adult re-infect"]

  /* ============================================================
     EDGES – Clinical Endpoints
     ============================================================ */
  Hp_mucosal  -> UBT_result    [label = "detected 13C-CO2"]
  Hp_mucosal  -> HpSA_stool    [label = "antigen shed"]
  IgG_HP      -> Hp_serology   [label = "detected"]
  IgG_HP      -> CagA_sero     [label = "CagA+ subgroup"]
  Gastrin     -> G17_serum     [label = "measured"]
  PG_I_level  -> PGI_serum     [label = "measured"]
  PG_II_level -> PGII_serum    [label = "measured"]
  PG_ratio_val -> PGratio_serum [label = "calculated"]
  PGI_serum   -> GastroPanel   [label = "component"]
  PGII_serum  -> GastroPanel   [label = "component"]
  G17_serum   -> GastroPanel   [label = "component"]
  Hp_serology -> GastroPanel   [label = "component"]
  OLGA_stage  -> endoscopy_score [label = "defines"]
  IM_complete -> histology_upd   [label = "scored"]
  IM_incomplete -> histology_upd [label = "scored"]
  NFkB        -> symptom_score   [label = "via inflammation"]
  TNFa        -> epigastric_pain [label = "sensitizes nociceptors"]
  IL1b        -> nausea_bloat    [label = "CNS / motility"]
  HCl_output  -> epigastric_pain [label = "mucosal irritation"]
  Superficial_G -> functional_dysp [label = "overlaps Rome IV"]
  epigastric_pain -> symptom_score [label = "component"]
  nausea_bloat    -> symptom_score [label = "component"]
  early_satiety   -> symptom_score [label = "component"]

  /* ============================================================
     EDGES – Systemic / Extra-gastric
     ============================================================ */
  Atrophic_G   -> iron_def    [label = "achlorhydria → Fe2+↓"]
  Atrophic_G   -> vitB12_def  [label = "IF loss → B12↓"]
  Hp_mucosal   -> ITP_Hp      [label = "molecular mimicry\n→ anti-GPIIb/IIIa"]
  IgG_HP       -> IHD_Hp      [label = "cross-reactive\n→ endothelial damage"]
  MALT_lymph2  -> GC_lifetime [label = "lymphoma risk"]
  NSAID_risk   -> PGE2_mucosal [label = "COX-1 block → PGE2↓"]
  PGE2_mucosal -> mucus_layer  [label = "protects mucosa"]
  NSAID_risk   -> stress_muc   [label = "NSAID gastropathy"]
  portal_hyp   -> mucus_layer  [label = "congestion → fragile"]
  bile_reflux  -> mucus_layer  [label = "detergent effect"]
  bile_reflux  -> Atrophic_G   [label = "contributes"]
  HCl_output   -> proton_alkal [label = "blood pH response"]
}
