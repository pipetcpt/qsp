digraph HepaticEncephalopathy_QSP {
  // =====================================================================
  // Hepatic Encephalopathy (HE) — Comprehensive QSP Mechanistic Map
  //   Gut-Liver-Muscle-Brain axis · NH3-Glutamine-Glutamate cycle ·
  //   Astrocyte swelling · Neuroinflammation · Lactulose / Rifaximin /
  //   LOLA / BCAA / Na-Benzoate / Glycerol Phenylbutyrate / Polyethylene
  //   Glycol / Albumin / Zinc / Flumazenil / TIPS / Transplant
  //   >150 nodes · 12 subgraph clusters
  // =====================================================================
  rankdir=LR;
  compound=true;
  newrank=true;
  graph [fontname="Helvetica", fontsize=12, splines=spline, overlap=false, nodesep=0.28, ranksep=0.55];
  node  [fontname="Helvetica", fontsize=10, style="filled,rounded", shape=box, color="#37474f"];
  edge  [fontname="Helvetica", fontsize=8, color="#546e7a", arrowsize=0.6];

  // ===================== CLUSTER 1 : ETIOLOGY / LIVER ====================
  subgraph cluster_liver {
    label="Cluster 1 — Liver Failure / Etiology / Urea Cycle";
    style="rounded,filled"; fillcolor="#e8f5e9"; color="#43a047";
    CIRRHOSIS    [label="Liver Cirrhosis\n(MELD↑, Child-Pugh B/C)", fillcolor="#a5d6a7"];
    ALF          [label="Acute Liver Failure\n(ALF; King's College)", fillcolor="#a5d6a7"];
    TIPS         [label="TIPS / Portosystemic\nShunt", fillcolor="#a5d6a7"];
    PORTAL_HTN   [label="Portal Hypertension\n(HVPG>10 mmHg)", fillcolor="#a5d6a7"];
    HEPATOCYTE   [label="Hepatocyte Mass\n(functional)", fillcolor="#c8e6c9"];
    UREA_CYCLE   [label="Urea Cycle\n(periportal)", fillcolor="#c8e6c9"];
    CPS1         [label="CPS1\n(N-acetyl-glutamate)", fillcolor="#c8e6c9"];
    OTC          [label="OTC", fillcolor="#c8e6c9"];
    ASS1         [label="ASS1", fillcolor="#c8e6c9"];
    ASL          [label="ASL", fillcolor="#c8e6c9"];
    ARG1         [label="Arginase-1", fillcolor="#c8e6c9"];
    UREA_OUT     [label="Urea Excretion\n(renal)", fillcolor="#c8e6c9"];
    GS_PERIVENOUS [label="Glutamine Synthetase\n(perivenous, NH3 scavenger)", fillcolor="#c8e6c9"];
    PRECIPITANT_GIB [label="GI Bleed\n(protein load)", fillcolor="#fff9c4"];
    PRECIPITANT_INF [label="Infection / SBP\n(LPS)", fillcolor="#fff9c4"];
    PRECIPITANT_DIUR [label="Diuretic / Hypokalemia /\nAlkalosis", fillcolor="#fff9c4"];
    PRECIPITANT_CONST [label="Constipation\n(NH3 reabsorption)", fillcolor="#fff9c4"];
    PRECIPITANT_BZD [label="Benzodiazepine /\nOpioid", fillcolor="#fff9c4"];
    PRECIPITANT_DEHY [label="Dehydration /\nAKI", fillcolor="#fff9c4"];

    CIRRHOSIS -> PORTAL_HTN -> TIPS;
    CIRRHOSIS -> HEPATOCYTE [arrowhead=tee,color="#c62828"];
    ALF -> HEPATOCYTE [arrowhead=tee,color="#c62828"];
    HEPATOCYTE -> UREA_CYCLE [color="#2e7d32"];
    UREA_CYCLE -> CPS1 -> OTC -> ASS1 -> ASL -> ARG1 -> UREA_OUT;
    UREA_CYCLE -> GS_PERIVENOUS;
    PORTAL_HTN -> PRECIPITANT_GIB;
    PRECIPITANT_GIB -> PRECIPITANT_INF;
  }

  // ===================== CLUSTER 2 : GUT / MICROBIOME ====================
  subgraph cluster_gut {
    label="Cluster 2 — Gut Microbiome / NH3 Generation";
    style="rounded,filled"; fillcolor="#fff3e0"; color="#fb8c00";
    DIET_PROTEIN  [label="Dietary Protein\n(1.0–1.5 g/kg/d)", fillcolor="#ffe0b2"];
    COLON_PROT    [label="Colonic Protein\nFermentation", fillcolor="#ffe0b2"];
    ENTEROBACT    [label="Enterobacteriaceae /\nProteobacteria ↑", fillcolor="#ffcc80"];
    STREPT_SAL    [label="Streptococcus salivarius\nKlebsiella (urease+) ↑", fillcolor="#ffcc80"];
    BACTEROIDETES [label="Bacteroidetes /\nFirmicutes ↓", fillcolor="#ffcc80"];
    UREASE        [label="Bacterial Urease\nNH3 production", fillcolor="#ffb74d"];
    GLUTAMINASE_G [label="Intestinal Glutaminase\n(enterocytes)", fillcolor="#ffb74d"];
    GUT_NH3       [label="Gut NH3 Pool", fillcolor="#ff8a65"];
    GUT_NH4       [label="Gut NH4+\n(pH-dependent)", fillcolor="#ff8a65"];
    SCFA          [label="SCFA / Butyrate\n(barrier)", fillcolor="#ffe0b2"];
    BILE_ACIDS    [label="Bile Acid Pool\n(2° BA↑, FXR↓)", fillcolor="#ffe0b2"];
    GUT_BARRIER   [label="Gut Barrier\nIntegrity (TJ, ZO-1)", fillcolor="#ffe0b2"];
    LPS_TRANSL    [label="LPS Translocation\nEndotoxemia", fillcolor="#ff7043"];
    CONSTIP_NODE  [label="Constipation\n(transit time↑)", fillcolor="#ffe0b2"];
    pH_LUMEN      [label="Luminal pH\n(5.5 with lactulose)", fillcolor="#ffe0b2"];

    DIET_PROTEIN -> COLON_PROT -> UREASE;
    ENTEROBACT -> UREASE;
    STREPT_SAL -> UREASE;
    UREASE -> GUT_NH3;
    GLUTAMINASE_G -> GUT_NH3;
    GUT_NH3 -> GUT_NH4 [color="#1976d2",label="pKa 9.25"];
    GUT_NH4 -> GUT_NH3 [color="#1976d2"];
    GUT_BARRIER -> LPS_TRANSL [arrowhead=tee];
    BACTEROIDETES -> SCFA -> GUT_BARRIER;
    BILE_ACIDS -> GUT_BARRIER;
    CONSTIP_NODE -> GUT_NH3;
    pH_LUMEN -> GUT_NH3 [arrowhead=tee];
  }

  // ===================== CLUSTER 3 : SYSTEMIC NH3 ========================
  subgraph cluster_systemic {
    label="Cluster 3 — Systemic Ammonia Kinetics";
    style="rounded,filled"; fillcolor="#e3f2fd"; color="#1976d2";
    PORTAL_NH3    [label="Portal Vein NH3\n(~300–400 µM)", fillcolor="#bbdefb"];
    SYS_NH3       [label="Systemic Plasma NH3\n(>50 µmol/L = ↑)", fillcolor="#90caf9"];
    NH4_BLOOD     [label="Blood NH4+\n(99% at pH 7.4)", fillcolor="#90caf9"];
    SHUNT_FRAC    [label="Portosystemic\nShunt Fraction (fps)", fillcolor="#bbdefb"];
    MUSCLE_GS     [label="Skeletal Muscle GS\n(NH3 detox, 50%)", fillcolor="#90caf9"];
    RENAL_GLNase  [label="Renal Glutaminase\n(NH4+ excretion)", fillcolor="#90caf9"];
    SARCOPENIA    [label="Sarcopenia\n(L3-SMI↓)", fillcolor="#90caf9"];
    GLUTAMINE_POOL[label="Plasma Glutamine\n(NH3 carrier)", fillcolor="#bbdefb"];
    ALPHA_KG      [label="α-Ketoglutarate\n(TCA anaplerosis)", fillcolor="#bbdefb"];
    BCAA_POOL     [label="Plasma BCAA\n(Leu, Ile, Val)", fillcolor="#bbdefb"];
    AAA_POOL      [label="Plasma AAA\n(Phe, Tyr, Trp)", fillcolor="#bbdefb"];
    FISCHER_RATIO [label="Fischer Ratio\n(BCAA/AAA)", fillcolor="#64b5f6"];
    HEPATIC_NH3   [label="Hepatic NH3 Clearance\n(periportal CPS1)", fillcolor="#bbdefb"];

    PORTAL_NH3 -> SHUNT_FRAC -> SYS_NH3;
    PORTAL_NH3 -> HEPATIC_NH3;
    HEPATIC_NH3 -> UREA_OUT [ltail=cluster_systemic,lhead=cluster_liver];
    SYS_NH3 -> NH4_BLOOD [color="#1976d2"];
    SYS_NH3 -> MUSCLE_GS [color="#2e7d32"];
    SYS_NH3 -> RENAL_GLNase [color="#2e7d32"];
    SARCOPENIA -> MUSCLE_GS [arrowhead=tee];
    GLUTAMINE_POOL -> RENAL_GLNase;
    BCAA_POOL -> MUSCLE_GS [label="N-donor"];
    BCAA_POOL -> FISCHER_RATIO;
    AAA_POOL -> FISCHER_RATIO [arrowhead=tee];
  }

  // ===================== CLUSTER 4 : BBB / NEURO-AMMONIA =================
  subgraph cluster_bbb {
    label="Cluster 4 — Blood-Brain Barrier / Brain NH3 Uptake";
    style="rounded,filled"; fillcolor="#f3e5f5"; color="#8e24aa";
    BBB           [label="Blood-Brain Barrier\n(integrity)", fillcolor="#ce93d8"];
    BBB_PERMEAB   [label="BBB Permeability\n(claudin-5↓, ZO-1↓)", fillcolor="#ce93d8"];
    NH3_DIFF      [label="NH3 Diffusion\n(non-ionic)", fillcolor="#e1bee7"];
    RhBG_RhCG     [label="Rh-glycoproteins\n(Astrocyte)", fillcolor="#e1bee7"];
    AAA_TRANSPORT [label="LAT-1 Transporter\n(AAA → brain)", fillcolor="#e1bee7"];
    BRAIN_NH3     [label="Brain NH3", fillcolor="#ba68c8"];
    BRAIN_AAA     [label="Brain AAA / Tyr / Trp /\nPhe", fillcolor="#ba68c8"];
    FALSE_NTM     [label="False Neurotransmitters\n(octopamine·β-Phenyl-EA)", fillcolor="#ce93d8"];
    MN_DEPOSIT    [label="Manganese Deposit\n(globus pallidus T1↑)", fillcolor="#e1bee7"];
    PB_MN         [label="Plasma Mn\n(↑ in cirrhosis)", fillcolor="#e1bee7"];

    SYS_NH3 -> NH3_DIFF -> BRAIN_NH3 [color="#6a1b9a"];
    BBB -> NH3_DIFF [arrowhead=tee];
    BBB_PERMEAB -> BBB [arrowhead=tee];
    AAA_POOL -> AAA_TRANSPORT -> BRAIN_AAA -> FALSE_NTM;
    PB_MN -> MN_DEPOSIT;
    RhBG_RhCG -> BRAIN_NH3 [label="uptake"];
  }

  // ===================== CLUSTER 5 : ASTROCYTE / GLUTAMINE TRAP =========
  subgraph cluster_astro {
    label="Cluster 5 — Astrocyte Swelling / Glutamine Trap (Norenberg)";
    style="rounded,filled"; fillcolor="#fce4ec"; color="#d81b60";
    ASTROCYTE     [label="Astrocyte\n(perivascular)", fillcolor="#f8bbd0"];
    GS_BRAIN      [label="Glutamine Synthetase\n(astrocyte)", fillcolor="#f48fb1"];
    BRAIN_GLN     [label="Astrocyte Glutamine\n(osmolyte)", fillcolor="#f06292"];
    GLUTAMATE_BR  [label="Glutamate Pool\n(neuron→astrocyte)", fillcolor="#f8bbd0"];
    MIT_PT        [label="Mitochondrial\nPermeability Transition", fillcolor="#f8bbd0"];
    ROS_BRAIN     [label="Brain ROS\n(NOX2, mit)", fillcolor="#f8bbd0"];
    OXIDATIVE_STR [label="RNS / Tyr-Nitration", fillcolor="#f8bbd0"];
    ATP_DEPLETION [label="Astrocyte ATP↓\n(α-KG depletion)", fillcolor="#f8bbd0"];
    OSMOTIC_SWELL [label="Astrocyte Osmotic\nSwelling (low-grade edema)", fillcolor="#ec407a"];
    AQP4          [label="Aquaporin-4\n(water flux)", fillcolor="#f8bbd0"];
    MYO_INOSITOL  [label="Myo-inositol↓\n(osmoregulation)", fillcolor="#f8bbd0"];
    TAURINE_BR    [label="Brain Taurine↓\n(osmoregulation)", fillcolor="#f8bbd0"];

    BRAIN_NH3 -> GS_BRAIN [label="Km≈0.2mM"];
    GS_BRAIN -> BRAIN_GLN;
    GLUTAMATE_BR -> GS_BRAIN [label="substrate"];
    BRAIN_GLN -> OSMOTIC_SWELL [color="#c2185b"];
    BRAIN_GLN -> MIT_PT [color="#c2185b"];
    MIT_PT -> ROS_BRAIN -> OXIDATIVE_STR;
    MIT_PT -> ATP_DEPLETION;
    AQP4 -> OSMOTIC_SWELL;
    MYO_INOSITOL -> OSMOTIC_SWELL [arrowhead=tee];
    TAURINE_BR -> OSMOTIC_SWELL [arrowhead=tee];
  }

  // ===================== CLUSTER 6 : NEUROTRANSMISSION ==================
  subgraph cluster_nt {
    label="Cluster 6 — Neurotransmission (GABA / Glu / DA / 5-HT)";
    style="rounded,filled"; fillcolor="#fff8e1"; color="#fbc02d";
    GABA_TONE     [label="GABAergic Tone↑", fillcolor="#fff59d"];
    GABA_A_R      [label="GABA-A Receptor\n(α1/γ2)", fillcolor="#fff59d"];
    NEUROSTEROID  [label="Neurosteroids\n(ALLO, THDOC)", fillcolor="#fff176"];
    TSPO          [label="TSPO / PBR\n(18kDa)", fillcolor="#fff176"];
    ENDO_BZD      [label="Endogenous BZD-like\nligands (Mullen)", fillcolor="#fff176"];
    NMDA          [label="NMDA Receptor\n(GluN2B)", fillcolor="#fff59d"];
    EAAT2         [label="EAAT2 / GLT-1\n(glutamate uptake↓)", fillcolor="#fff59d"];
    SYN_GLU       [label="Synaptic Glutamate↑\n(extracellular)", fillcolor="#fff59d"];
    DOPAMINE_BG   [label="Dopaminergic BG\n(parkinsonism)", fillcolor="#fff59d"];
    SEROTONIN_BR  [label="5-HT Turnover↑\n(sleep, mood)", fillcolor="#fff59d"];
    LACTATE_BR    [label="Brain Lactate↑\n(Warburg-like)", fillcolor="#fff59d"];

    NEUROSTEROID -> GABA_A_R [label="PAM"];
    TSPO -> NEUROSTEROID;
    ENDO_BZD -> GABA_A_R [label="PAM"];
    GABA_A_R -> GABA_TONE;
    EAAT2 -> SYN_GLU [arrowhead=tee];
    BRAIN_NH3 -> EAAT2 [arrowhead=tee];
    SYN_GLU -> NMDA;
    NMDA -> ROS_BRAIN;
    MN_DEPOSIT -> DOPAMINE_BG [arrowhead=tee];
    BRAIN_AAA -> SEROTONIN_BR;
    ATP_DEPLETION -> LACTATE_BR;
  }

  // ===================== CLUSTER 7 : NEUROINFLAMMATION ==================
  subgraph cluster_neuroinflam {
    label="Cluster 7 — Neuroinflammation / Microglia / Cytokines";
    style="rounded,filled"; fillcolor="#ffebee"; color="#e53935";
    MICROGLIA     [label="Microglia (M1 polar.)", fillcolor="#ffcdd2"];
    TNFa          [label="TNF-α", fillcolor="#ef9a9a"];
    IL6           [label="IL-6", fillcolor="#ef9a9a"];
    IL1B          [label="IL-1β", fillcolor="#ef9a9a"];
    NLRP3         [label="NLRP3 Inflammasome", fillcolor="#ef9a9a"];
    NFKB          [label="NF-κB", fillcolor="#ef9a9a"];
    SYS_INFL      [label="Systemic Inflammation\n(SBP, SIRS)", fillcolor="#ef5350"];
    HMGB1         [label="HMGB1 / DAMPs", fillcolor="#ef9a9a"];
    BBB_DISRUPT   [label="BBB Disruption\n(MMP-9)", fillcolor="#ef9a9a"];
    HEPATIC_KC    [label="Kupffer Cell\nActivation", fillcolor="#ffcdd2"];
    INFL_AMMONIA_SYN [label="NH3-Inflammation\nSynergy (Shawcross 2004)", fillcolor="#ef5350"];

    LPS_TRANSL -> HEPATIC_KC -> TNFa;
    HEPATIC_KC -> IL6;
    HEPATIC_KC -> SYS_INFL;
    SYS_INFL -> BBB_DISRUPT;
    TNFa -> MICROGLIA;
    IL6 -> MICROGLIA;
    MICROGLIA -> NLRP3 -> IL1B;
    NLRP3 -> NFKB;
    HMGB1 -> NLRP3;
    SYS_INFL -> INFL_AMMONIA_SYN;
    BRAIN_NH3 -> INFL_AMMONIA_SYN;
    INFL_AMMONIA_SYN -> OSMOTIC_SWELL [color="#c62828"];
    BBB_DISRUPT -> BBB [arrowhead=tee];
  }

  // ===================== CLUSTER 8 : CLINICAL / WEST HAVEN ==============
  subgraph cluster_clinical {
    label="Cluster 8 — Clinical Manifestations / Endpoints";
    style="rounded,filled"; fillcolor="#e0f7fa"; color="#0097a7";
    WH_GRADE      [label="West Haven Grade\n(0–IV)", fillcolor="#80deea"];
    MHE           [label="Minimal HE\n(PHES<-4)", fillcolor="#80deea"];
    OHE           [label="Overt HE\n(Grade II–IV)", fillcolor="#80deea"];
    PHES          [label="PHES Test\n(NCT-A/B, DST, SDT)", fillcolor="#b2ebf2"];
    CFF           [label="Critical Flicker\nFrequency (Hz)", fillcolor="#b2ebf2"];
    ICT           [label="Inhibitory Control\nTest", fillcolor="#b2ebf2"];
    ASTERIXIS     [label="Asterixis / Flapping\nTremor", fillcolor="#b2ebf2"];
    GCS           [label="Glasgow Coma Scale", fillcolor="#b2ebf2"];
    ICP_EDEMA     [label="ICP↑ / Cerebral\nEdema (ALF)", fillcolor="#26c6da"];
    SLEEP_INV     [label="Sleep Reversal", fillcolor="#b2ebf2"];
    QOL_HE        [label="HRQoL / CLDQ", fillcolor="#b2ebf2"];
    HOSPITAL_RATE [label="HE Hospitalization\nRate", fillcolor="#b2ebf2"];
    MORTALITY     [label="30/90-d Mortality", fillcolor="#0097a7", fontcolor="white"];
    DRIVING_RISK  [label="Driving Risk /\nFalls / Accidents", fillcolor="#b2ebf2"];

    OSMOTIC_SWELL -> WH_GRADE;
    GABA_TONE -> WH_GRADE;
    INFL_AMMONIA_SYN -> WH_GRADE;
    WH_GRADE -> OHE;
    PHES -> MHE;
    CFF -> MHE;
    ICT -> MHE;
    OHE -> ASTERIXIS;
    OHE -> SLEEP_INV;
    OHE -> GCS [arrowhead=tee];
    ALF -> ICP_EDEMA [label="ammonia >150"];
    WH_GRADE -> HOSPITAL_RATE;
    WH_GRADE -> QOL_HE [arrowhead=tee];
    MHE -> DRIVING_RISK;
    OHE -> MORTALITY [label="HR≈2–4"];
    ICP_EDEMA -> MORTALITY;
  }

  // ===================== CLUSTER 9 : DRUG PK ============================
  subgraph cluster_pk {
    label="Cluster 9 — Drug Pharmacokinetics";
    style="rounded,filled"; fillcolor="#ede7f6"; color="#5e35b1";
    LACTULOSE_PK  [label="Lactulose PK\n(non-absorbable\n F≈0%, gut)", fillcolor="#d1c4e9"];
    RIFAXIMIN_PK  [label="Rifaximin PK\n(F<0.4% gut, 550 mg BID)", fillcolor="#d1c4e9"];
    LOLA_PK       [label="LOLA PK\n(L-Orn L-Asp,\nIV 20 g/d)", fillcolor="#d1c4e9"];
    BCAA_PK       [label="BCAA Granules\n(12 g TID PO)", fillcolor="#d1c4e9"];
    BENZOATE_PK   [label="Na-Benzoate\n(5–10 g PO)", fillcolor="#d1c4e9"];
    GPB_PK        [label="Glycerol Phenyl-\nbutyrate (HPN-100)", fillcolor="#d1c4e9"];
    PEG_PK        [label="PEG 3350\n(4 L gut prep)", fillcolor="#d1c4e9"];
    ALB_PK        [label="20% Albumin\n(IV)", fillcolor="#d1c4e9"];
    ZN_PK         [label="Zinc Acetate\n(220 mg BID)", fillcolor="#d1c4e9"];
    FLUMAZ_PK     [label="Flumazenil\n(IV 0.5–1 mg)", fillcolor="#d1c4e9"];
    PROBIOTIC_PK  [label="Probiotics / VSL#3\n450B CFU/d", fillcolor="#d1c4e9"];
    FMT_PK        [label="Fecal Microbiota\nTransplant", fillcolor="#d1c4e9"];

    LACTULOSE_PK -> pH_LUMEN [arrowhead=tee,label="↓ pH"];
    LACTULOSE_PK -> GUT_NH4 [label="trap"];
    LACTULOSE_PK -> CONSTIP_NODE [arrowhead=tee];
    RIFAXIMIN_PK -> ENTEROBACT [arrowhead=tee,color="#1976d2"];
    RIFAXIMIN_PK -> UREASE [arrowhead=tee];
    LOLA_PK -> CPS1 [label="↑"];
    LOLA_PK -> MUSCLE_GS [label="↑"];
    BCAA_PK -> BCAA_POOL;
    BCAA_PK -> MUSCLE_GS;
    BENZOATE_PK -> HEPATIC_NH3 [label="hippurate path"];
    GPB_PK -> HEPATIC_NH3 [label="PAGN"];
    PEG_PK -> CONSTIP_NODE [arrowhead=tee];
    ALB_PK -> SYS_INFL [arrowhead=tee];
    ZN_PK -> OTC [label="cofactor"];
    FLUMAZ_PK -> GABA_A_R [arrowhead=tee,label="comp. antag."];
    PROBIOTIC_PK -> BACTEROIDETES [label="↑"];
    FMT_PK -> BACTEROIDETES [label="↑"];
  }

  // ===================== CLUSTER 10 : DRUG PD / EFFECTS =================
  subgraph cluster_pd {
    label="Cluster 10 — Drug PD / Mechanism Synthesis";
    style="rounded,filled"; fillcolor="#e8eaf6"; color="#3949ab";
    EFF_PH        [label="↓ Gut pH (5.5)\n(NH3→NH4+ trap)", fillcolor="#c5cae9"];
    EFF_BACTKILL  [label="↓ Urease+ bact.\n(rifaximin AUC)", fillcolor="#c5cae9"];
    EFF_UREAGEN   [label="↑ Ureagenesis\n(LOLA cycle)", fillcolor="#c5cae9"];
    EFF_GS_MUSC   [label="↑ Muscle GS\n(LOLA + BCAA)", fillcolor="#c5cae9"];
    EFF_HIPPURATE [label="↑ Hippurate /\nPAGN excretion", fillcolor="#c5cae9"];
    EFF_LAXATIVE  [label="↑ Transit\n(↓NH3 reabs.)", fillcolor="#c5cae9"];
    EFF_GABA_ANT  [label="↓ GABA-A PAM\n(flumazenil)", fillcolor="#c5cae9"];
    EFF_DYSBIO    [label="↓ Dysbiosis\n(probiotic, FMT)", fillcolor="#c5cae9"];

    LACTULOSE_PK -> EFF_PH;
    LACTULOSE_PK -> EFF_LAXATIVE;
    RIFAXIMIN_PK -> EFF_BACTKILL;
    LOLA_PK -> EFF_UREAGEN;
    LOLA_PK -> EFF_GS_MUSC;
    BCAA_PK -> EFF_GS_MUSC;
    BENZOATE_PK -> EFF_HIPPURATE;
    GPB_PK -> EFF_HIPPURATE;
    PEG_PK -> EFF_LAXATIVE;
    PROBIOTIC_PK -> EFF_DYSBIO;
    FMT_PK -> EFF_DYSBIO;
    FLUMAZ_PK -> EFF_GABA_ANT;

    EFF_PH -> GUT_NH3 [arrowhead=tee,color="#3949ab"];
    EFF_BACTKILL -> GUT_NH3 [arrowhead=tee,color="#3949ab"];
    EFF_UREAGEN -> SYS_NH3 [arrowhead=tee,color="#3949ab"];
    EFF_GS_MUSC -> SYS_NH3 [arrowhead=tee,color="#3949ab"];
    EFF_HIPPURATE -> SYS_NH3 [arrowhead=tee,color="#3949ab"];
    EFF_LAXATIVE -> GUT_NH3 [arrowhead=tee,color="#3949ab"];
    EFF_DYSBIO -> GUT_NH3 [arrowhead=tee,color="#3949ab"];
    EFF_GABA_ANT -> GABA_TONE [arrowhead=tee,color="#3949ab"];
  }

  // ===================== CLUSTER 11 : TRIALS / EVIDENCE =================
  subgraph cluster_trials {
    label="Cluster 11 — Key Clinical Trials";
    style="rounded,filled"; fillcolor="#f1f8e9"; color="#558b2f";
    BASS2010      [label="Bass NEJM 2010\nRifaximin RFHE3001\n(↓ breakthrough HE 22%)", fillcolor="#dcedc8"];
    SHARMA2013    [label="Sharma 2013 Gastro\nRifaximin+Lactulose\n(↓ mortality 24%)", fillcolor="#dcedc8"];
    AGRAWAL2012   [label="Agrawal 2012 AJG\nLactulose 2° prevention", fillcolor="#dcedc8"];
    LES2011       [label="Les 2011 BCAA\nMHE improvement", fillcolor="#dcedc8"];
    KIRCHEIS1997  [label="Kircheis 1997 Hep\nLOLA pivotal RCT", fillcolor="#dcedc8"];
    RAHIMI2014    [label="Rahimi 2014 JAMA IM\nPEG vs Lactulose (HELP)", fillcolor="#dcedc8"];
    BAJAJ2019     [label="Bajaj 2019 Hep\nFMT (PROFIT trial)", fillcolor="#dcedc8"];
    SHAW2004      [label="Shawcross 2004\nNH3-inflammation synergy", fillcolor="#dcedc8"];
    FISCHER1976   [label="Fischer 1976 BCAA\nratio hypothesis", fillcolor="#dcedc8"];
    HASSANEIN2007 [label="Hassanein 2007 MARS\nartificial liver", fillcolor="#dcedc8"];

    BASS2010 -> RIFAXIMIN_PK [style=dashed];
    SHARMA2013 -> RIFAXIMIN_PK [style=dashed];
    AGRAWAL2012 -> LACTULOSE_PK [style=dashed];
    LES2011 -> BCAA_PK [style=dashed];
    KIRCHEIS1997 -> LOLA_PK [style=dashed];
    RAHIMI2014 -> PEG_PK [style=dashed];
    BAJAJ2019 -> FMT_PK [style=dashed];
    SHAW2004 -> INFL_AMMONIA_SYN [style=dashed];
    FISCHER1976 -> FISCHER_RATIO [style=dashed];
  }

  // ===================== CLUSTER 12 : SCENARIOS / GUIDELINES ============
  subgraph cluster_scn {
    label="Cluster 12 — Scenarios / Guidelines (AASLD/EASL 2014, ISHEN)";
    style="rounded,filled"; fillcolor="#fbe9e7"; color="#bf360c";
    SC0           [label="Scenario 0\nUntreated (baseline)", fillcolor="#ffccbc"];
    SC1           [label="Scenario 1\nLactulose only", fillcolor="#ffccbc"];
    SC2           [label="Scenario 2\nRifaximin only", fillcolor="#ffccbc"];
    SC3           [label="Scenario 3\nLactulose + Rifaximin", fillcolor="#ffccbc"];
    SC4           [label="Scenario 4\n+ LOLA", fillcolor="#ffccbc"];
    SC5           [label="Scenario 5\n+ BCAA", fillcolor="#ffccbc"];
    SC6           [label="Scenario 6\n+ Na-Benzoate/GPB", fillcolor="#ffccbc"];
    SC7           [label="Scenario 7\n+ Probiotic / FMT", fillcolor="#ffccbc"];
    SC8           [label="Scenario 8\nALF protocol (ICP)", fillcolor="#ffccbc"];

    SC1 -> LACTULOSE_PK [style=dotted];
    SC2 -> RIFAXIMIN_PK [style=dotted];
    SC3 -> LACTULOSE_PK [style=dotted];
    SC3 -> RIFAXIMIN_PK [style=dotted];
    SC4 -> LOLA_PK [style=dotted];
    SC5 -> BCAA_PK [style=dotted];
    SC6 -> BENZOATE_PK [style=dotted];
    SC6 -> GPB_PK [style=dotted];
    SC7 -> PROBIOTIC_PK [style=dotted];
    SC7 -> FMT_PK [style=dotted];
    SC8 -> ALB_PK [style=dotted];
    SC8 -> FLUMAZ_PK [style=dotted];
  }

  // ===================== CROSS-CLUSTER EDGES ============================
  CIRRHOSIS -> SARCOPENIA [color="#558b2f"];
  PORTAL_HTN -> SHUNT_FRAC [color="#558b2f"];
  HEPATOCYTE -> HEPATIC_NH3;
  GUT_NH3 -> PORTAL_NH3;
  LPS_TRANSL -> SYS_INFL [color="#c62828"];
  PRECIPITANT_INF -> SYS_INFL;
  PRECIPITANT_GIB -> COLON_PROT [label="hemoglobin"];
  PRECIPITANT_DIUR -> SYS_NH3 [color="#7b1fa2",label="alkalosis"];
  PRECIPITANT_CONST -> CONSTIP_NODE;
  PRECIPITANT_BZD -> GABA_A_R;
  PRECIPITANT_DEHY -> SYS_NH3;
  WH_GRADE -> SC0 [style=invis];
}
