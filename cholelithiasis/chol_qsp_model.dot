digraph CholelithiasisQSP {
    graph [label="Cholelithiasis (Gallstone Disease) QSP Mechanistic Map\nBile Acid Metabolism · Biliary Transport · Gallbladder Physiology · Drug PK/PD",
           labelloc=t, fontsize=22, fontname="Helvetica-Bold",
           bgcolor="#FAFAFA", rankdir=LR, splines=ortho,
           nodesep=0.4, ranksep=0.8, pad=0.5,
           tooltip="QSP Model: Cholelithiasis"];
    node [fontname="Helvetica", fontsize=10, style=filled, shape=box, margin="0.15,0.06"];
    edge [fontname="Helvetica", fontsize=8, arrowsize=0.7];

    /* ===== CLUSTER 1: Hepatic Cholesterol Metabolism ===== */
    subgraph cluster_hepatic {
        label="Hepatic Cholesterol Metabolism";
        style=filled; fillcolor="#FFF3E0"; color="#E65100"; fontsize=14;

        Acetyl_CoA [label="Acetyl-CoA", fillcolor="#FFE0B2", shape=ellipse];
        HMG_CoA [label="HMG-CoA", fillcolor="#FFE0B2", shape=ellipse];
        HMGCR [label="HMG-CoA Reductase\n(HMGCR)", fillcolor="#FF8F00", fontcolor=white, shape=diamond];
        Mevalonate [label="Mevalonate", fillcolor="#FFE0B2", shape=ellipse];
        Squalene [label="Squalene", fillcolor="#FFE0B2", shape=ellipse];
        Lanosterol [label="Lanosterol", fillcolor="#FFE0B2", shape=ellipse];
        CHOL_free [label="Free Cholesterol\n(Hepatic)", fillcolor="#FB8C00", fontcolor=white];
        CHOL_ester [label="Cholesterol Ester\n(Hepatic)", fillcolor="#FFB74D"];
        ACAT2 [label="ACAT2", fillcolor="#E65100", fontcolor=white, shape=diamond];
        LDLR [label="LDL Receptor\n(LDLR)", fillcolor="#EF6C00", fontcolor=white];
        LDL_plasma [label="Plasma LDL-C", fillcolor="#FFB74D"];
        PCSK9 [label="PCSK9", fillcolor="#BF360C", fontcolor=white, shape=diamond];
        SREBP2 [label="SREBP2", fillcolor="#E65100", fontcolor=white, shape=diamond];
        LXR [label="LXR\n(Liver X Receptor)", fillcolor="#F57C00", fontcolor=white, shape=diamond];
        HDL_hepatic [label="Hepatic HDL\n(Reverse Transport)", fillcolor="#FFB74D"];
        ABCA1 [label="ABCA1", fillcolor="#E65100", fontcolor=white];
        ApoB100 [label="ApoB100", fillcolor="#FFB74D"];
        VLDL [label="VLDL Secretion", fillcolor="#FFB74D"];
    }

    /* ===== CLUSTER 2: Bile Acid Synthesis ===== */
    subgraph cluster_ba_synth {
        label="Bile Acid Synthesis & Regulation";
        style=filled; fillcolor="#E8F5E9"; color="#1B5E20"; fontsize=14;

        CYP7A1 [label="CYP7A1\n(Rate-limiting)", fillcolor="#2E7D32", fontcolor=white, shape=diamond];
        CYP8B1 [label="CYP8B1\n(12α-hydroxylase)", fillcolor="#388E3C", fontcolor=white, shape=diamond];
        CYP27A1 [label="CYP27A1\n(Mitochondrial)", fillcolor="#43A047", fontcolor=white, shape=diamond];
        CYP7B1 [label="CYP7B1\n(Alternative path)", fillcolor="#4CAF50", fontcolor=white, shape=diamond];
        CA [label="Cholic Acid (CA)", fillcolor="#A5D6A7"];
        CDCA [label="Chenodeoxycholic Acid\n(CDCA)", fillcolor="#A5D6A7"];
        GCA [label="Glycocholic Acid\n(GCA)", fillcolor="#C8E6C9"];
        TCA [label="Taurocholic Acid\n(TCA)", fillcolor="#C8E6C9"];
        GCDCA [label="Glyco-CDCA\n(GCDCA)", fillcolor="#C8E6C9"];
        TCDCA [label="Tauro-CDCA\n(TCDCA)", fillcolor="#C8E6C9"];
        UDCA_synth [label="UDCA\n(7β-epimer of CDCA)", fillcolor="#81C784"];
        FXR [label="FXR\n(Farnesoid X Receptor)", fillcolor="#1B5E20", fontcolor=white, shape=diamond];
        SHP [label="SHP\n(Small Heterodimer\nPartner)", fillcolor="#2E7D32", fontcolor=white];
        HNF4a [label="HNF4α", fillcolor="#388E3C", fontcolor=white];
        FGF19 [label="FGF19\n(Ileal hormone)", fillcolor="#43A047", fontcolor=white];
        FGFR4 [label="FGFR4\n(Hepatic receptor)", fillcolor="#388E3C", fontcolor=white];
        KLOTHO [label="β-Klotho\n(co-receptor)", fillcolor="#4CAF50", fontcolor=white];
        BA_pool_total [label="Total Bile Acid Pool\n(~3-5 g)", fillcolor="#66BB6A"];
        BA_primary [label="Primary BA Pool", fillcolor="#81C784"];
        BA_secondary [label="Secondary BA Pool\n(DCA, LCA)", fillcolor="#A5D6A7"];
    }

    /* ===== CLUSTER 3: Biliary Transport ===== */
    subgraph cluster_transport {
        label="Hepatobiliary Transport";
        style=filled; fillcolor="#E3F2FD"; color="#0D47A1"; fontsize=14;

        BSEP [label="BSEP\n(ABCB11)\nBile Salt Export Pump", fillcolor="#1565C0", fontcolor=white, shape=diamond];
        MDR3 [label="MDR3\n(ABCB4)\nPhospholipid Flippase", fillcolor="#1976D2", fontcolor=white, shape=diamond];
        ABCG5_hep [label="ABCG5/ABCG8\n(Hepatic Cholesterol\nTransport)", fillcolor="#1E88E5", fontcolor=white, shape=diamond];
        NTCP [label="NTCP\n(SLC10A1)\nNa-BA Cotransporter", fillcolor="#2196F3", fontcolor=white, shape=diamond];
        OATP1B1 [label="OATP1B1\n(SLCO1B1)", fillcolor="#42A5F5", fontcolor=white, shape=diamond];
        OATP1B3 [label="OATP1B3\n(SLCO1B3)", fillcolor="#42A5F5", fontcolor=white, shape=diamond];
        MRP2 [label="MRP2\n(ABCC2)", fillcolor="#1976D2", fontcolor=white, shape=diamond];
        MDR1 [label="MDR1\n(ABCB1)\nP-glycoprotein", fillcolor="#1565C0", fontcolor=white, shape=diamond];
        OST_ab [label="OSTα/β\n(Basolateral)", fillcolor="#2196F3", fontcolor=white, shape=diamond];
        Canalicular_bile [label="Bile Canaliculus", fillcolor="#90CAF9"];
        Cholangiocyte [label="Cholangiocyte\n(Bile Duct Cell)", fillcolor="#BBDEFB"];
        Bile_duct [label="Intrahepatic Bile Duct", fillcolor="#BBDEFB"];
        CBD [label="Common Bile Duct", fillcolor="#90CAF9"];
        Bile_BA [label="Biliary Bile Acids\n(mM)", fillcolor="#64B5F6"];
        Bile_CHOL [label="Biliary Cholesterol\n(mmol/L)", fillcolor="#42A5F5", fontcolor=white];
        Bile_PL [label="Biliary Phospholipids\n(PC dominant)", fillcolor="#64B5F6"];
        Bile_water [label="Bile Water Content", fillcolor="#BBDEFB"];
    }

    /* ===== CLUSTER 4: Gallbladder Physiology ===== */
    subgraph cluster_gb {
        label="Gallbladder Physiology";
        style=filled; fillcolor="#FCE4EC"; color="#880E4F"; fontsize=14;

        GB_lumen [label="Gallbladder Lumen", fillcolor="#F8BBD9"];
        GB_wall [label="Gallbladder Wall", fillcolor="#F48FB1"];
        GB_epithelium [label="Gallbladder Epithelium\n(Absorptive / Secretory)", fillcolor="#F06292"];
        GB_smooth_muscle [label="Gallbladder Smooth Muscle", fillcolor="#EC407A"];
        CCK [label="Cholecystokinin (CCK)\n(Duodenal secretion)", fillcolor="#880E4F", fontcolor=white];
        CCK_R [label="CCK-A Receptor\n(CCKAR)", fillcolor="#AD1457", fontcolor=white, shape=diamond];
        VIP [label="VIP\n(Inhibitory)", fillcolor="#C2185B", fontcolor=white];
        Somatostatin [label="Somatostatin\n(Inhibitory)", fillcolor="#C2185B", fontcolor=white];
        GB_contraction [label="GB Contraction\n(Ejection Fraction)", fillcolor="#E91E63", fontcolor=white];
        GB_emptying [label="GB Emptying\n(Volume → Duodenum)", fillcolor="#EC407A"];
        GB_filling [label="GB Filling\n(Hepatic bile)", fillcolor="#F48FB1"];
        GB_stasis [label="Gallbladder Stasis\n(Risk factor)", fillcolor="#C2185B", fontcolor=white];
        Mucin_secret [label="Mucin Secretion\n(MUC5B, MUC5AC)", fillcolor="#E91E63", fontcolor=white];
        Mucin_gel [label="Mucin Gel Layer\n(Nucleation scaffold)", fillcolor="#F48FB1"];
        Water_absorb [label="Water Absorption\n(Bile concentration ↑)", fillcolor="#F8BBD9"];
        GB_vol [label="Gallbladder Volume\n(mL)", fillcolor="#E91E63", fontcolor=white];
        GB_bile_conc [label="Concentrated\nGallbladder Bile", fillcolor="#F48FB1"];
        Inflammation_GB [label="GB Wall Inflammation\n(Cholecystitis)", fillcolor="#AD1457", fontcolor=white];
        Prostaglandins_GB [label="Prostaglandins\n(GB inflammation)", fillcolor="#C2185B", fontcolor=white];
    }

    /* ===== CLUSTER 5: Nucleation & Crystallization ===== */
    subgraph cluster_nucleation {
        label="Nucleation, Crystallization & Stone Growth";
        style=filled; fillcolor="#F3E5F5"; color="#4A148C"; fontsize=14;

        CSI [label="Cholesterol Saturation\nIndex (CSI)\n[>1 = Lithogenic]", fillcolor="#7B1FA2", fontcolor=white, shape=ellipse];
        Bile_triangle [label="Bile Triangular Phase\nDiagram (Admirand-Small)", fillcolor="#9C27B0", fontcolor=white];
        Micelles [label="Mixed Micelles\n(BA+PC+CHOL)", fillcolor="#CE93D8"];
        Vesicles [label="Cholesterol-Rich\nVesicles (Unilamellar)", fillcolor="#CE93D8"];
        Liquid_crystals [label="Liquid Crystals\n(Transition phase)", fillcolor="#BA68C8"];
        Nucleation_time [label="Nucleation Time\n(hours)", fillcolor="#8E24AA", fontcolor=white];
        Nucleation_promo [label="Nucleation-Promoting\nFactors\n(Mucin, IgG, fetuin)", fillcolor="#AB47BC"];
        Nucleation_inhib [label="Nucleation-Inhibiting\nFactors\n(ApoAI, ApoAII)", fillcolor="#CE93D8"];
        Mono_crystal [label="Cholesterol\nMonohydrate Crystal", fillcolor="#7B1FA2", fontcolor=white];
        Crystal_growth_rate [label="Crystal Growth Rate", fillcolor="#9C27B0", fontcolor=white];
        Crystal_aggregation [label="Crystal Aggregation\n(gel-mucin scaffold)", fillcolor="#AB47BC"];
        Stone [label="Gallstone\n(Cholesterol >70%)", fillcolor="#4A148C", fontcolor=white, shape=ellipse];
        Stone_vol [label="Stone Volume\n(mL)", fillcolor="#6A1B9A", fontcolor=white];
        Stone_dissolution [label="Stone Dissolution\n(UDCA-mediated)", fillcolor="#7E57C2", fontcolor=white];
        Pigment_stone [label="Pigment Stone\n(Bilirubin type)", fillcolor="#CE93D8"];
        Black_pigment [label="Black Pigment Stone\n(Hemolysis, cirrhosis)", fillcolor="#BA68C8"];
        Brown_pigment [label="Brown Pigment Stone\n(Infection, stasis)", fillcolor="#BA68C8"];
    }

    /* ===== CLUSTER 6: Enterohepatic Circulation ===== */
    subgraph cluster_entero {
        label="Enterohepatic Circulation";
        style=filled; fillcolor="#E0F2F1"; color="#004D40"; fontsize=14;

        Duodenum [label="Duodenum\n(Bile acid delivery)", fillcolor="#80CBC4"];
        Jejunum [label="Jejunum\n(Passive BA absorption)", fillcolor="#80CBC4"];
        Ileum [label="Ileum (Terminal)\n(Active BA reabsorption)", fillcolor="#4DB6AC"];
        ASBT [label="ASBT\n(SLC10A2)\nApical Na-BA Transporter", fillcolor="#00897B", fontcolor=white, shape=diamond];
        IBABP [label="IBABP (FABP6)\nIleal BA Binding Protein", fillcolor="#26A69A", fontcolor=white];
        OSTab_int [label="OSTα/β\n(Basolateral intestinal)", fillcolor="#009688", fontcolor=white, shape=diamond];
        Portal_BA [label="Portal Bile Acids\n(Hepatic reuptake)", fillcolor="#4DB6AC"];
        Colon [label="Colon\n(Bacterial deconjugation)", fillcolor="#80CBC4"];
        Gut_bacteria [label="Gut Microbiota\n(BSH enzymes)", fillcolor="#26A69A", fontcolor=white];
        DCA [label="Deoxycholic Acid (DCA)\n(7α-dehydroxylation of CA)", fillcolor="#80CBC4"];
        LCA [label="Lithocholic Acid (LCA)\n(7α-dehydroxylation of CDCA)", fillcolor="#80CBC4"];
        Fecal_BA [label="Fecal BA Excretion\n(~0.5 g/day)", fillcolor="#A7FFEB"];
        Intestinal_CHOL [label="Intestinal Cholesterol\nAbsorption", fillcolor="#4DB6AC"];
        NPC1L1 [label="NPC1L1\n(Apical cholesterol\ntransporter)", fillcolor="#00897B", fontcolor=white, shape=diamond];
        ABCG5G8_int [label="ABCG5/ABCG8\n(Intestinal cholesterol\nefflux back to lumen)", fillcolor="#00796B", fontcolor=white, shape=diamond];
        UDCA_entero [label="UDCA\nEnterohepatic Cycling", fillcolor="#4DB6AC"];
        EHC_count [label="EHC Cycling\n(6-10× per day)", fillcolor="#80CBC4"];
    }

    /* ===== CLUSTER 7: Risk Factors ===== */
    subgraph cluster_risk {
        label="Risk Factors & Genetic Modulators";
        style=filled; fillcolor="#FFF9C4"; color="#F57F17"; fontsize=14;

        Obesity_RF [label="Obesity\n(BMI >30)", fillcolor="#F9A825", fontcolor=white];
        Insulin_resist [label="Insulin Resistance", fillcolor="#F57F17", fontcolor=white];
        T2DM_RF [label="Type 2 Diabetes", fillcolor="#FF8F00", fontcolor=white];
        Female_sex [label="Female Sex\n(2-3× higher risk)", fillcolor="#FBC02D"];
        Estrogen_RF [label="Estrogen\n↑CHOL biliary secretion\n↓BA synthesis", fillcolor="#F9A825"];
        Progesterone_RF [label="Progesterone\n↓GB motility", fillcolor="#F9A825"];
        Pregnancy [label="Pregnancy\n(↑estrogen/progesterone)", fillcolor="#FBC02D"];
        OCP [label="Oral Contraceptives", fillcolor="#FDD835"];
        Age_RF [label="Age (>40)\n(↑risk per decade)", fillcolor="#F9A825"];
        Rapid_WL [label="Rapid Weight Loss\n(>1.5 kg/week)", fillcolor="#F57F17", fontcolor=white];
        TPN [label="Total Parenteral Nutrition\n(GB stasis)", fillcolor="#FF8F00", fontcolor=white];
        Hemolysis [label="Hemolysis\n(Bilirubin ↑)\nSickle cell, hereditary", fillcolor="#FBC02D"];
        Crohn_RF [label="Crohn's Disease\n(↓ileal BA reabsorption)", fillcolor="#F9A825"];
        Cirrhosis_RF [label="Cirrhosis\n(↓BA synthesis)", fillcolor="#FF8F00", fontcolor=white];
        Gene_ABCG5 [label="ABCG5/ABCG8\nPolymorphisms\n(rs11887534 D19H)", fillcolor="#F57F17", fontcolor=white];
        Gene_CYP7A1 [label="CYP7A1 Polymorphisms\n(rs3808607)", fillcolor="#FF8F00", fontcolor=white];
        Gene_ABCB4 [label="ABCB4 Mutations\n(MDR3 deficiency)", fillcolor="#F57F17", fontcolor=white];
        Gene_ABCB11 [label="ABCB11 Polymorphisms\n(PFIC-2 spectrum)", fillcolor="#FF8F00", fontcolor=white];
        Western_diet [label="Western Diet\n(High fat, low fiber)", fillcolor="#FDD835"];
        Fibrates_RF [label="Fibrate Therapy\n(↑cholesterol secretion)", fillcolor="#FBC02D"];
        Ceftriaxone [label="Ceftriaxone\n(Biliary precipitation)", fillcolor="#FDD835"];
        Octreotide [label="Octreotide/Somatostatin\nAnalogues (↓CCK, ↓GB\nmotility)", fillcolor="#FDD835"];
    }

    /* ===== CLUSTER 8: Drug PK/PD ===== */
    subgraph cluster_drug {
        label="Drug PK/PD";
        style=filled; fillcolor="#E8EAF6"; color="#1A237E"; fontsize=14;

        UDCA_oral [label="UDCA Oral Dose\n(250 mg TID or\n10 mg/kg/day)", fillcolor="#3949AB", fontcolor=white, shape=ellipse];
        UDCA_abs [label="UDCA Absorption\n(Gut → Portal)", fillcolor="#5C6BC0", fontcolor=white];
        UDCA_portal [label="UDCA Portal Vein\n(First-pass uptake)", fillcolor="#7986CB"];
        UDCA_liver_pk [label="UDCA Hepatic\nConcentration", fillcolor="#3F51B5", fontcolor=white];
        UDCA_biliary [label="UDCA Biliary\nConcentration\n(30-40% of BA pool)", fillcolor="#3949AB", fontcolor=white];
        UDCA_plasma [label="UDCA Plasma\nConcentration (Css)", fillcolor="#7986CB"];
        UDCA_EHC [label="UDCA Enterohepatic\nRecycling", fillcolor="#5C6BC0", fontcolor=white];
        UDCA_fecal [label="UDCA Fecal\nElimination", fillcolor="#7986CB"];

        Statin_oral [label="Statin Oral Dose\n(Simvastatin 40 mg\nor Atorvastatin 20 mg)", fillcolor="#283593", fontcolor=white, shape=ellipse];
        Statin_abs [label="Statin Absorption", fillcolor="#3949AB", fontcolor=white];
        Statin_plasma_pk [label="Statin Plasma\nConcentration", fillcolor="#7986CB"];
        Statin_liver_pk [label="Statin Hepatic\nConcentration", fillcolor="#3F51B5", fontcolor=white];
        Statin_HMGCR_inh [label="HMGCR Inhibition\n(IC50 ~ 0.1 nM)", fillcolor="#1A237E", fontcolor=white, shape=diamond];

        Ezet_oral [label="Ezetimibe\n10 mg/day", fillcolor="#283593", fontcolor=white, shape=ellipse];
        Ezet_NPC1L1 [label="Ezetimibe-NPC1L1\nInhibition\n(IC50 ~ 10 nM)", fillcolor="#1A237E", fontcolor=white, shape=diamond];
        Ezet_gluc [label="Ezetimibe Glucuronide\n(Active metabolite)", fillcolor="#5C6BC0", fontcolor=white];

        UDCA_effect_CSI [label="UDCA Effect on CSI\n(↓biliary CHOL secretion\n↑hydrophilicity)", fillcolor="#1A237E", fontcolor=white];
        UDCA_effect_stone [label="Stone Dissolution\nRate (UDCA)\n(mm/month)", fillcolor="#283593", fontcolor=white];
        Statin_effect_CHOL [label="Statin Effect on\nBiliary Cholesterol\n(↓~25%)", fillcolor="#3F51B5", fontcolor=white];
        UDCA_effect_FXR [label="UDCA-FXR\nSignaling\n(Partial agonist)", fillcolor="#5C6BC0", fontcolor=white];
        UDCA_effect_TGR5 [label="UDCA-TGR5\nSignaling\n(Intestinal + GB)", fillcolor="#5C6BC0", fontcolor=white];
    }

    /* ===== CLUSTER 9: Inflammatory Cascade ===== */
    subgraph cluster_inflam {
        label="Inflammatory Cascade (Acute Cholecystitis)";
        style=filled; fillcolor="#FFEBEE"; color="#B71C1C"; fontsize=14;

        Stone_obstruct [label="Stone Obstruction\n(Cystic duct)", fillcolor="#C62828", fontcolor=white];
        GB_distension [label="GB Distension\n(↑intraluminal pressure)", fillcolor="#D32F2F", fontcolor=white];
        PG_synthase [label="PGE2, PGI2\n(Prostaglandin synthesis)", fillcolor="#EF5350"];
        COX1_COX2 [label="COX-1/COX-2\nActivation", fillcolor="#C62828", fontcolor=white, shape=diamond];
        IL1b_inflam [label="IL-1β\n(Macrophage)", fillcolor="#EF9A9A"];
        IL6_inflam [label="IL-6\n(Systemic)", fillcolor="#EF9A9A"];
        TNFa_inflam [label="TNF-α", fillcolor="#EF9A9A"];
        Neutrophil_infilt [label="Neutrophil\nInfiltration", fillcolor="#EF5350"];
        NF_kB [label="NF-κB\nActivation", fillcolor="#B71C1C", fontcolor=white, shape=diamond];
        Lyso_PL [label="Lysophospholipids\n(Mucosal injury)", fillcolor="#FFCDD2"];
        Bacterial_infect [label="Bacterial Infection\n(E.coli, Klebsiella,\nEnterococcus)", fillcolor="#C62828", fontcolor=white];
        CRP_inflam [label="CRP ↑\n(Acute phase)", fillcolor="#EF9A9A"];
        WBC_inflam [label="WBC ↑\n(Leukocytosis)", fillcolor="#FFCDD2"];
    }

    /* ===== CLUSTER 10: Clinical Outcomes ===== */
    subgraph cluster_clinical {
        label="Clinical Manifestations & Endpoints";
        style=filled; fillcolor="#E0F7FA"; color="#006064"; fontsize=14;

        Biliary_colic [label="Biliary Colic\n(Episodic RUQ pain)", fillcolor="#00838F", fontcolor=white, shape=ellipse];
        Acute_cholecyst [label="Acute Cholecystitis\n(Persistent inflammation)", fillcolor="#00695C", fontcolor=white, shape=ellipse];
        Choledocholithiasis [label="Choledocholithiasis\n(Common duct stone)", fillcolor="#004D40", fontcolor=white, shape=ellipse];
        Cholangitis [label="Cholangitis\n(Bile duct infection)", fillcolor="#00695C", fontcolor=white, shape=ellipse];
        GB_pancreatitis [label="Gallstone Pancreatitis\n(Ampullary obstruction)", fillcolor="#004D40", fontcolor=white, shape=ellipse];
        Asymptomatic [label="Asymptomatic\nGallstones (70-80%)", fillcolor="#26C6DA"];
        Mirizzi [label="Mirizzi Syndrome\n(Extrinsic CBD\ncompression)", fillcolor="#00838F", fontcolor=white];
        GB_cancer [label="Gallbladder Cancer\n(Rare, chronic inflam.)", fillcolor="#004D40", fontcolor=white];
        Stone_recurrence [label="Stone Recurrence\n(after UDCA Rx)", fillcolor="#00838F", fontcolor=white];
        UDCA_dissolution [label="UDCA Stone Dissolution\n(Radiolucent <5mm:\n~50% at 6 months)", fillcolor="#00897B", fontcolor=white];
        Pain_score [label="Pain VAS Score", fillcolor="#26C6DA"];
        ERCP_interv [label="ERCP Intervention\n(Stone extraction)", fillcolor="#00838F", fontcolor=white];
        Cholecystectomy [label="Cholecystectomy\n(Laparoscopic)", fillcolor="#004D40", fontcolor=white];
        LFT_abnorm [label="LFT Abnormalities\n(ALT, AST, ALP, GGT)", fillcolor="#80DEEA"];
        Bilirubin_elev [label="Serum Bilirubin ↑\n(Obstruction)", fillcolor="#80DEEA"];
    }

    /* ===== EDGES: Hepatic Cholesterol Metabolism ===== */
    Acetyl_CoA -> HMG_CoA [label="HMGS"];
    HMG_CoA -> HMGCR [style=bold];
    HMGCR -> Mevalonate [label="Rate-limiting step"];
    Mevalonate -> Squalene [label="MVK,PMK"];
    Squalene -> Lanosterol [label="Squalene synthase"];
    Lanosterol -> CHOL_free [label="CYP51,DHCR7"];
    CHOL_free -> CHOL_ester [label="ACAT2"];
    ACAT2 -> CHOL_ester [style=dashed, color=gray];
    LDL_plasma -> LDLR [label="Endocytosis"];
    LDLR -> CHOL_free;
    PCSK9 -> LDLR [label="Degradation", color=red, arrowhead=tee];
    SREBP2 -> HMGCR [label="Transcription ↑", color=green];
    SREBP2 -> LDLR [label="Transcription ↑", color=green];
    LXR -> ABCA1 [label="Transcription ↑", color=green];
    CHOL_free -> ApoB100 [label="VLDL assembly"];
    ApoB100 -> VLDL;
    CHOL_free -> HDL_hepatic [via=ABCA1];
    ABCA1 -> HDL_hepatic;

    /* ===== EDGES: Bile Acid Synthesis ===== */
    CHOL_free -> CYP7A1 [label="Substrate\n(Classic path)", style=bold];
    CYP7A1 -> CYP8B1 [label="7α-hydroxy\ncholesterol"];
    CYP8B1 -> CA [label="CA synthesis"];
    CYP7A1 -> CYP27A1 [label="Alternative"];
    CYP27A1 -> CDCA [label="CDCA synthesis"];
    CYP7B1 -> CDCA [label="Alternative path"];
    CA -> GCA [label="Glycine conjugation"];
    CA -> TCA [label="Taurine conjugation"];
    CDCA -> GCDCA;
    CDCA -> TCDCA;
    BA_primary -> BA_pool_total;
    BA_secondary -> BA_pool_total;
    GCA -> BA_primary;
    TCA -> BA_primary;
    GCDCA -> BA_primary;
    TCDCA -> BA_primary;
    BA_pool_total -> FXR [label="FXR ligands", style=bold];
    FXR -> SHP [label="Induces", color=green];
    SHP -> CYP7A1 [label="Represses", color=red, arrowhead=tee];
    SHP -> HNF4a [label="Represses", color=red, arrowhead=tee];
    HNF4a -> CYP7A1 [label="Activates", color=green];
    FXR -> FGF19 [label="Induces (ileal)", color=green];
    FGF19 -> FGFR4 [label="Binds"];
    FGFR4 -> KLOTHO [label="Complex"];
    KLOTHO -> CYP7A1 [label="Represses", color=red, arrowhead=tee];
    UDCA_synth -> FXR [label="Partial agonist", style=dashed];

    /* ===== EDGES: Biliary Transport ===== */
    BA_primary -> BSEP [label="BSEP substrate"];
    BSEP -> Bile_BA [label="Canalicular secretion"];
    CHOL_free -> ABCG5_hep;
    ABCG5_hep -> Bile_CHOL [label="Cholesterol secretion"];
    MDR3 -> Bile_PL [label="PC flipping"];
    MRP2 -> Canalicular_bile [label="Bilirubin-glucuronide"];
    Bile_BA -> Canalicular_bile;
    Bile_CHOL -> Canalicular_bile;
    Bile_PL -> Canalicular_bile;
    Canalicular_bile -> Bile_duct;
    Bile_duct -> CBD;
    CBD -> GB_lumen [label="Hepatocystic\nduct → GB"];
    CBD -> Duodenum [label="Sphincter of Oddi\n(CCK-mediated)"];
    Portal_BA -> NTCP [label="Na-dependent"];
    Portal_BA -> OATP1B1 [label="Na-independent"];
    Portal_BA -> OATP1B3;
    NTCP -> BA_primary [label="Hepatic reuptake"];
    OATP1B1 -> BA_primary;
