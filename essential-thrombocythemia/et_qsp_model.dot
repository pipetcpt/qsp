digraph ET_QSP {
    graph [rankdir=TB, fontname="Helvetica", fontsize=12,
           bgcolor="#fafafa", splines=ortho, nodesep=0.35, ranksep=0.65,
           label="Essential Thrombocythemia (ET) — QSP Mechanistic Map\nJAK2/CALR/MPL Mutations · Megakaryopoiesis · Thrombosis · Drug PK/PD",
           labelloc=t, labeljust=c, fontsize=15];
    node [shape=box, style="filled,rounded", fontname="Helvetica", fontsize=9, margin="0.12,0.05"];
    edge [fontname="Helvetica", fontsize=8, arrowsize=0.65];

    /* ============================================================
       Cluster 1: Driver Mutations & Clonal Architecture
       ============================================================ */
    subgraph cluster_genetics {
        label="① Driver Mutations & Clonal Evolution";
        style=filled; fillcolor="#fff3e0";
        color="#e65100"; fontcolor="#bf360c"; penwidth=2.5;

        node [fillcolor="#ffcc80", color="#e65100"];
        JAK2_V617F   [label="JAK2 V617F\n(~55–65% ET)", shape=doubleoctagon, fillcolor="#ff8f00", fontcolor="white"];
        JAK2_exon12  [label="JAK2 Exon12\n(~3% ET)"];
        CALR_type1   [label="CALR Type 1\nDel52bp (~15%)"];
        CALR_type2   [label="CALR Type 2\nIns5bp (~10%)"];
        MPL_W515L    [label="MPL W515L/K\n(~3–5%)"];
        Triple_neg   [label="Triple Negative\n(~10%)"];

        node [fillcolor="#ffe0b2"];
        TET2_mut     [label="TET2\n(co-mutation)"];
        ASXL1_mut    [label="ASXL1\n(↑MF risk)"];
        DNMT3A_mut   [label="DNMT3A"];
        SF3B1_mut    [label="SF3B1"];
        TP53_mut     [label="TP53\n(blast risk)"];
        IDH1_2_mut   [label="IDH1/IDH2\n(AML risk)"];
        EZH2_mut     [label="EZH2\n(↑MF risk)"];
        SRSF2_mut    [label="SRSF2"];
        CBL_mut      [label="CBL"];
        LNK_mut      [label="LNK/SH2B3\n(↑JAK2 signal)"];
    }

    /* ============================================================
       Cluster 2: TPO/JAK-STAT & Downstream Signaling
       ============================================================ */
    subgraph cluster_signaling {
        label="② TPO·JAK-STAT · PI3K·AKT · MAPK Signaling";
        style=filled; fillcolor="#e8f5e9";
        color="#2e7d32"; fontcolor="#1b5e20"; penwidth=2.5;

        node [fillcolor="#a5d6a7", color="#2e7d32"];
        TPO_liver    [label="TPO Production\n(Liver/Kidney)"];
        TPO_serum    [label="Circulating TPO\n(ng/mL)", shape=ellipse];
        MPL_receptor [label="MPL/TPOR\nReceptor", shape=cylinder];
        JAK2_wt      [label="JAK2 WT\n(inactive)"];
        JAK2_act     [label="JAK2\nActivated (pY1007)", fillcolor="#43a047", fontcolor="white"];

        node [fillcolor="#c8e6c9"];
        STAT5_p      [label="pSTAT5\n(nuclear)"];
        STAT3_p      [label="pSTAT3"];
        PI3K_act     [label="PI3K p110α"];
        AKT_act      [label="AKT\n(phospho-S473)"];
        mTORC1       [label="mTORC1"];
        mTORC2       [label="mTORC2"];
        MAPK_act     [label="MAPK p38"];
        ERK_act      [label="ERK1/2\n(phospho)"];
        NFkB_act     [label="NF-κB"];
        SOCS1_3      [label="SOCS1/3\n(negative feedback)"];

        node [fillcolor="#dcedc8", color="#558b2f"];
        BCL2         [label="BCL-2\n(anti-apoptosis)"];
        BCL_XL       [label="BCL-XL"];
        MCL1         [label="MCL-1"];
        PIM1         [label="PIM1 Kinase"];
        CyclinD1     [label="Cyclin D1\n↑Proliferation"];
        CDK4_6       [label="CDK4/6\nComplex"];
        p21_p27      [label="p21/p27\nCDK Inhibitors"];
        c_MYC        [label="c-MYC\nTranscription"];
    }

    /* ============================================================
       Cluster 3: Megakaryopoiesis Hierarchy
       ============================================================ */
    subgraph cluster_hematopoiesis {
        label="③ Megakaryopoiesis Hierarchy & Platelet Biogenesis";
        style=filled; fillcolor="#e3f2fd";
        color="#1565c0"; fontcolor="#0d47a1"; penwidth=2.5;

        node [fillcolor="#90caf9", color="#1565c0"];
        LT_HSC       [label="LT-HSC\n(Long-term\nStem Cell)", shape=hexagon];
        ST_HSC       [label="ST-HSC"];
        MPP          [label="MPP\n(Multipotent\nProgenitor)"];
        CMP          [label="CMP\n(Common\nMyeloid Prog)"];
        MEP          [label="MEP\n(MK-Erythroid\nProgenitor)"];
        MKP          [label="MKP\n(MK Progenitor)"];
        BFU_MK       [label="BFU-MK\n(Burst Forming)"];
        CFU_MK       [label="CFU-MK\n(Colony Forming)"];

        node [fillcolor="#42a5f5", color="#1565c0"];
        IMK          [label="Immature\nMegakaryocyte\n(2N→8N)"];
        PMK          [label="Promegakaryocyte\n(8N→16N)"];
        Mature_MK    [label="Mature\nMegakaryocyte\n(16–64N ploidy)", shape=doubleoctagon, fillcolor="#1e88e5", fontcolor="white"];

        node [fillcolor="#bbdefb"];
        Proplatelet  [label="Proplatelet\nExtension"];
        PLT_release  [label="Platelet\nShedding\n(~2000/MK)"];
        Endomitosis  [label="Endomitosis\n(DNA amplification\nwithout cytokinesis)"];
        DMS          [label="Demarcation\nMembrane System\n(DMS)"];
        CytExpan     [label="Cytoplasmic\nExpansion"];
        GranSynth    [label="α/Dense Granule\nSynthesis"];
        vWF_MK       [label="vWF Synthesis\n(in MK)"];
        GP1b_ex      [label="GPIbα\nExpression"];
        GPIIbIIIa_ex [label="GPIIb/IIIa (αIIbβ3)\nExpression"];
        PF4_syn      [label="PF4/CXCL4\nSynthesis"];
        TXB2_synth   [label="TXA2/TXB2\nSynthesis (MK)"];
    }

    /* ============================================================
       Cluster 4: Cytokine & Growth Factor Environment
       ============================================================ */
    subgraph cluster_cytokines {
        label="④ Cytokine & Growth Factor Milieu";
        style=filled; fillcolor="#f3e5f5";
        color="#6a1b9a"; fontcolor="#4a148c"; penwidth=2.5;

        node [fillcolor="#ce93d8", color="#6a1b9a"];
        IL1beta      [label="IL-1β\n(inflammation)"];
        IL3          [label="IL-3\n(MK proliferation)"];
        IL6          [label="IL-6\n(TPO↑, acute phase)"];
        IL11         [label="IL-11\n(MK maturation)"];
        SCF          [label="SCF / c-Kit\nLigand"];
        EPO          [label="EPO\n(erythropoiesis)"];
        G_CSF        [label="G-CSF\n(neutrophil↑)"];
        GM_CSF       [label="GM-CSF"];
        CXCL12       [label="CXCL12/SDF-1\n(BM niche retention)"];
        TGF_b1       [label="TGF-β1\n(fibrosis driver)"];
        IFNa_endo    [label="Endogenous\nIFN-α"];
        IFNg         [label="IFN-γ"];
        PDGF_AB      [label="PDGF-AB\n(released by MK)"];
        bFGF         [label="bFGF\n(BM angiogenesis)"];
        VEGF         [label="VEGF\n(neovascularization)"];
        HGF          [label="HGF\n(hepatocyte GF)"];
    }

    /* ============================================================
       Cluster 5: Platelet Biology & Activation
       ============================================================ */
    subgraph cluster_platelets {
        label="⑤ Platelet Biology, Activation & Dysfunction";
        style=filled; fillcolor="#fff8e1";
        color="#f57f17"; fontcolor="#e65100"; penwidth=2.5;

        node [fillcolor="#ffe082", color="#f57f17"];
        Plt_circ     [label="Circulating\nPlatelets\n(N: 150–400×10⁹/L)", shape=ellipse, fillcolor="#ffd54f"];
        Plt_activ    [label="Platelet\nActivation"];
        ADP_rel      [label="ADP Release\n(Dense Granules)"];
        TXA2_prod    [label="TXA2 Production\n(COX-1 pathway)"];
        P2Y12        [label="P2Y12\nReceptor"];
        COX1_enz     [label="COX-1 Enzyme\n(PTGS1)"];
        GP1b_vWF     [label="GPIb-V-IX ↔ vWF\n(Adhesion)"];
        GPIIbIIIa_f  [label="GPIIb/IIIa ↔ Fibrinogen\n(Aggregation)"];
        Plt_aggr     [label="Platelet\nAggregation"];
        Plt_adh      [label="Platelet\nAdhesion to\nEndothelium"];
        Micropart    [label="Platelet\nMicroparticles\n(procoagulant)"];
        Plt_life     [label="Platelet Lifespan\n(~8–10 days)"];
        Plt_spleen   [label="Splenic\nClearance"];
        ET_dysfun    [label="ET-specific PLT\nDysfunction\n(acquired vWD)"];
        Fibrinogen   [label="Fibrinogen\nBinding"];
    }

    /* ============================================================
       Cluster 6: Thrombotic & Hemorrhagic Complications
       ============================================================ */
    subgraph cluster_thrombosis {
        label="⑥ Thrombotic & Hemorrhagic Complications";
        style=filled; fillcolor="#ffebee";
        color="#b71c1c"; fontcolor="#7f0000"; penwidth=2.5;

        node [fillcolor="#ef9a9a", color="#c62828"];
        Art_thromb   [label="Arterial\nThrombosis", shape=octagon, fillcolor="#e53935", fontcolor="white"];
        Ven_thromb   [label="Venous\nThrombosis", shape=octagon, fillcolor="#e53935", fontcolor="white"];
        Stroke       [label="Stroke / TIA", fillcolor="#ef5350", fontcolor="white"];
        MI_ACS       [label="MI / ACS", fillcolor="#ef5350", fontcolor="white"];
        DVT          [label="Deep Vein\nThrombosis (DVT)"];
        PE           [label="Pulmonary\nEmbolism (PE)"];
        Budd_Chiari  [label="Budd-Chiari\nSyndrome"];
        Port_thromb  [label="Portal/Hepatic\nVein Thrombosis"];
        Micro_thromb [label="Microvascular\nThrombosis"];
        Erythromel   [label="Erythromelalgia\n(digital ischemia)"];
        Headache_vis [label="Headache /\nVisual Disturbance"];

        node [fillcolor="#ffcdd2"];
        Coag_casc    [label="Coagulation\nCascade\n(TF pathway)"];
        Thrombin_g   [label="Thrombin\nGeneration"];
        Fibrin_clot  [label="Fibrin Clot"];
        Endoth_dyf   [label="Endothelial\nDysfunction\n(↓NO, ↑TXA2)"];
        vWF_ultra    [label="Ultra-large vWF\nMultimers"];
        ADAMTS13     [label="ADAMTS13\n(cleaves vWF)"];
        Hemorrhage   [label="Major\nHemorrhage\n(PLT>1500)", shape=octagon, fillcolor="#ff8a80"];
    }

    /* ============================================================
       Cluster 7: Drug PK/PD
       ============================================================ */
    subgraph cluster_drugs {
        label="⑦ Drug PK/PD: Hydroxyurea · Anagrelide · Ruxolitinib · Peg-IFN-α · Aspirin";
        style=filled; fillcolor="#e8eaf6";
        color="#283593"; fontcolor="#1a237e"; penwidth=2.5;

        /* Hydroxyurea */
        node [fillcolor="#9fa8da", color="#283593"];
        HU_dose      [label="Hydroxyurea\nDose PO\n(500–2000 mg/d)", shape=Msquare, fillcolor="#5c6bc0", fontcolor="white"];
        HU_C         [label="HU Central\nCompartment\n(Cp, µM)"];
        HU_P         [label="HU Peripheral\nCompartment"];
        HU_RRM2      [label="RRM2 Inhibition\n(ribonucleotide\nreductase)"];
        HU_Sphase    [label="S-phase Block\n→ DNA strand breaks"];
        HU_apop      [label="Apoptosis\n(MKP + MK)"];

        /* Anagrelide */
        node [fillcolor="#b39ddb", color="#4527a0"];
        ANA_dose     [label="Anagrelide\nDose PO\n(0.5–3 mg/d)", shape=Msquare, fillcolor="#7e57c2", fontcolor="white"];
        ANA_C        [label="ANA Central\n(Cp, nM)"];
        ANA_P        [label="ANA Peripheral"];
        ANA_PDE3     [label="PDE3A\nInhibition\n(MK-selective)"];
        ANA_cAMP     [label="↑cAMP in MK\n→ Anti-maturation"];
        ANA_3OH      [label="3-OH-ANA\n(active metabolite)"];

        /* Ruxolitinib */
        node [fillcolor="#80cbc4", color="#00695c"];
        RUX_dose     [label="Ruxolitinib\nDose PO\n(10–20 mg BID)", shape=Msquare, fillcolor="#00897b", fontcolor="white"];
        RUX_C        [label="RUX Central\n(Cp, nM)"];
        RUX_P        [label="RUX Peripheral"];
        RUX_JAK12    [label="JAK1/2\nInhibition\n(Ki~3nM JAK2)"];
        RUX_pSTAT5   [label="↓pSTAT5\n→ ↓Proliferation"];
        RUX_cytok    [label="↓Inflammatory\nCytokines"];

        /* Pegylated IFN-α */
        node [fillcolor="#f48fb1", color="#880e4f"];
        pIFN_dose    [label="Peg-IFN-α2a\nDose SC\n(90–180 µg/wk)", shape=Msquare, fillcolor="#e91e63", fontcolor="white"];
        pIFN_C       [label="pIFN Central\n(SC depot)"];
        pIFN_P       [label="pIFN Peripheral"];
        pIFN_immune  [label="IFN-α\nImmune Modulation\n(ISG induction)"];
        pIFN_clone   [label="JAK2+ Clone\nSuppression\n(preferential HSC)"];
        pIFN_MR      [label="Molecular\nRemission\n(JAK2 AB↓)"];

        /* Aspirin */
        node [fillcolor="#ffe0b2", color="#e65100"];
        ASA_dose     [label="Aspirin\nLow-dose PO\n(81–100 mg/d)", shape=Msquare];
        ASA_COX1     [label="COX-1\nIrreversible\nAcetylation"];
        ASA_TXA2i    [label="↓TXA2\n→ ↓Aggregation"];

        /* Busulfan */
        node [fillcolor="#d7ccc8", color="#3e2723"];
        BUS_dose     [label="Busulfan PO\n(elderly pts)", shape=Msquare];
        BUS_alkyl    [label="DNA\nAlkylation\n(CML-type)"];
    }

    /* ============================================================
       Cluster 8: Clinical Endpoints & Response Criteria
       ============================================================ */
    subgraph cluster_endpoints {
        label="⑧ Clinical Endpoints & Response Criteria (ELN 2009 / WHO 2016)";
        style=filled; fillcolor="#e0f7fa";
        color="#006064"; fontcolor="#004d40"; penwidth=2.5;

        node [fillcolor="#80deea", color="#006064"];
        PLT_count    [label="Platelet Count\n(×10⁹/L)", shape=ellipse, fillcolor="#26c6da"];
        WBC_count    [label="WBC Count\n(×10⁹/L)"];
        Hgb_level    [label="Hemoglobin\n(g/dL)"];
        LDH_level    [label="LDH (U/L)\n(BM turnover)"];
        Spleen_cm    [label="Spleen Size\n(cm below costal)"];
        JAK2_AB      [label="JAK2 Allele\nBurden (%)"];
        BM_histo     [label="BM Histology\n(MF grade 0–3)"];
        Sym_burden   [label="Symptom Burden\n(MPN-SAF TSS)"];
        QoL_score    [label="QoL Score\n(EORTC QLQ-C30)"];

        node [fillcolor="#b2ebf2"];
        CHR          [label="Complete Hematologic\nResponse (CHR)\nPLT≤400 + WBC≤10\n+ normal spleen", shape=octagon, fillcolor="#00b0ff", fontcolor="white"];
        PHR          [label="Partial Hematologic\nResponse (PHR)\nPLT≤600 or\n≥50% reduction"];
        CR_ELN       [label="Complete\nRemission (CR)\nCHR + normal BM", shape=octagon];
        CMR          [label="Complete\nMolecular Response\nJAK2 AB<1%"];
        PMR          [label="Partial\nMolecular Response\n≥50% AB reduction"];
        NR           [label="No Response\n/ Resistance"];
        IPSS_ET      [label="IPSS-ET Risk\n(Low/Int/High)"];
        MIPSS_ET     [label="MIPSS-ET\n(Molecular IPS)"];
        WHO2016      [label="WHO 2016\nDiagnosis Criteria"];
        ELN_resp     [label="ELN Response\nCriteria 2009"];
        Thrombo_free [label="Thrombosis-free\nSurvival (TFS)"];
        OS_endpoint  [label="Overall\nSurvival (OS)"];
    }

    /* ============================================================
       Cluster 9: BM Pathology & Disease Transformation
       ============================================================ */
    subgraph cluster_progression {
        label="⑨ BM Pathology & Disease Transformation";
        style=filled; fillcolor="#fce4ec";
        color="#880e4f"; fontcolor="#560027"; penwidth=2.5;

        node [fillcolor="#f48fb1", color="#880e4f"];
        BM_hyper     [label="BM\nHypercellularity\n(MK clusters)"];
        Reticulin    [label="Reticulin Fibrosis\n(MF-0 → MF-3)"];
        Collagen_fib [label="Collagen\nFibrosis (MF-3)"];
        BM_angio     [label="BM\nNeovascularization"];
        Osteoscl     [label="Osteosclerosis"];
        EMH_spleen   [label="Extramedullary\nHematopoiesis\n(Spleen/Liver)"];

        node [fillcolor="#e91e63", fontcolor="white"];
        Post_ET_MF   [label="Post-ET\nMyelofibrosis\n(10–20% / 10yr)"];
        Blast_phase  [label="Blast Phase\n(Accelerated MDS)"];
        AML_transf   [label="AML\nTransformation\n(~1–3% / 10yr)"];

        node [fillcolor="#f8bbd0", color="#880e4f"];
        Cytogen_abn  [label="Cytogenetic\nAbnormalities\n(del20q, +8)"];
        Genomic_inst [label="Genomic\nInstability"];
        Clonal_evol  [label="Clonal\nEvolution"];
        Add_mutation [label="Additional Driver\nMutations\n(ASXL1, IDH1/2)"];
        JAK2_expand  [label="JAK2+ Clone\nExpansion"];
        Fibroblast_a [label="Fibroblast\nActivation\n(TGF-β)"];
    }

    /* ============================================================
       EDGES — Genetic Mutations
       ============================================================ */
    JAK2_V617F   -> JAK2_act    [label="constitutive\nactivation", color="#e65100", penwidth=2.5];
    JAK2_exon12  -> JAK2_act    [color="#e65100"];
    CALR_type1   -> MPL_receptor [label="aberrant\nactivation", color="#e65100", penwidth=2];
    CALR_type2   -> MPL_receptor [color="#e65100"];
    MPL_W515L    -> JAK2_act    [color="#e65100", penwidth=2];
    Triple_neg   -> JAK2_act    [label="unknown\nmechanism", style=dashed];
    LNK_mut      -> JAK2_act    [label="enhances\nsignaling"];
    TPO_serum    -> MPL_receptor [label="normal\nligand"];
    MPL_receptor -> JAK2_act    [label="JAK2\nrecruitment"];
    JAK2_wt      -> JAK2_act    [label="TPO-induced"];

    /* JAK-STAT signaling */
    JAK2_act -> STAT5_p     [label="Y694\nphospho", penwidth=2.5, color="#2e7d32"];
    JAK2_act -> STAT3_p;
    JAK2_act -> PI3K_act;
    JAK2_act -> MAPK_act;
    STAT5_p  -> SOCS1_3     [label="negative\nfeedback", arrowhead=tee, style=dashed];
    SOCS1_3  -> JAK2_act    [arrowhead=tee, label="suppression"];
    PI3K_act -> AKT_act;
    AKT_act  -> mTORC1;
    AKT_act  -> mTORC2;
    MAPK_act -> ERK_act;
    ERK_act  -> c_MYC       [label="transcription"];
    STAT5_p  -> BCL_XL      [label="gene\ntargets"];
    STAT5_p  -> MCL1;
    STAT5_p  -> PIM1;
    STAT5_p  -> CyclinD1;
    STAT5_p  -> c_MYC;
    NFkB_act -> BCL2;
    mTORC1   -> CyclinD1;
    CyclinD1 -> CDK4_6      [label="complex"];
    CDK4_6   -> p21_p27     [arrowhead=tee, label="inactivates"];

    /* TPO feedback */
    Plt_circ  -> TPO_liver  [label="PLT absorbs\nTPO (↓serum)", arrowhead=tee, color="#f57f17", style=dashed];
    TPO_liver -> TPO_serum;
    IL6       -> TPO_liver  [label="↑TPO\nproduction"];
    IL3       -> MKP        [label="↑proliferation"];
    SCF       -> MKP;
    IL11      -> Mature_MK  [label="maturation"];

    /* Megakaryopoiesis hierarchy */
    LT_HSC   -> ST_HSC   -> MPP -> CMP -> MEP -> MKP -> BFU_MK -> CFU_MK -> IMK -> PMK;
    PMK      -> Mature_MK  [label="endomitosis\n×8 cycles", penwidth=2];
    Mature_MK -> Endomitosis [dir=both];
    Mature_MK -> DMS        [label="DMS\nformation"];
    DMS      -> Proplatelet [label="extension\ninto sinusoid"];
    Proplatelet -> PLT_release;
    PLT_release -> Plt_circ [penwidth=2.5, color="#1565c0"];

    /* MK maturation steps */
    IMK -> CytExpan -> GranSynth -> vWF_MK;
    IMK -> GP1b_ex;
    IMK -> GPIIbIIIa_ex;
    IMK -> PF4_syn;
    IMK -> TXB2_synth;

    /* JAK2 → hematopoiesis */
    JAK2_act -> MKP       [label="↑proliferation", penwidth=2.5, color="#1565c0"];
    JAK2_act -> BFU_MK    [label="↑self-renewal"];
    STAT5_p  -> Mature_MK [label="survival signal", color="#1565c0"];
    BCL_XL   -> Mature_MK [label="anti-apoptosis"];
    CyclinD1 -> MKP       [label="cell cycle\nprogression"];

    /* Cytokines → BM */
    TGF_b1    -> Reticulin   [label="fibrosis", color="#880e4f", penwidth=2];
    TGF_b1    -> Fibroblast_a [color="#880e4f"];
    Fibroblast_a -> Reticulin;
    Fibroblast_a -> Collagen_fib;
    PDGF_AB   -> BM_angio;
    bFGF      -> BM_angio;
    VEGF      -> BM_angio;
    IFNa_endo -> JAK2_V617F  [label="↓clone\n(partial)", arrowhead=tee];
    Mature_MK -> TGF_b1      [label="secretion"];
    Mature_MK -> PDGF_AB     [label="secretion"];
    Mature_MK -> VEGF        [label="secretion"];
    Mature_MK -> bFGF;

    /* Platelet biology */
    Plt_circ  -> Plt_activ  [label="shear/ADP/\ncollagen/thrombin"];
    Plt_activ -> ADP_rel;
    Plt_activ -> TXA2_prod;
    COX1_enz  -> TXA2_prod  [label="catalysis"];
    TXA2_prod -> Plt_aggr   [penwidth=2];
    ADP_rel   -> P2Y12      -> Plt_aggr;
    GP1b_vWF  -> Plt_adh;
    GPIIbIIIa_f -> Plt_aggr [label="fibrinogen\nbinding"];
    Fibrinogen -> GPIIbIIIa_f;
    Plt_activ -> Micropart;
    Plt_circ  -> Plt_life   -> Plt_spleen;
    Plt_circ  -> ET_dysfun  [label="high PLT\n→ shear↑"];
    ET_dysfun -> vWF_ultra  [label="ADAMTS13-\nresistant"];
    vWF_ultra -> ADAMTS13   [label="substrate"];
    vWF_MK    -> vWF_ultra  [label="↑secretion"];

    /* Thrombosis cascade */
    Plt_aggr  -> Art_thromb  [penwidth=2.5, color="#c62828"];
    Plt_aggr  -> Ven_thromb  [color="#c62828"];
    Art_thromb -> Stroke;
    Art_thromb -> MI_ACS;
    Ven_thromb -> DVT;
    Ven_thromb -> PE;
    Ven_thromb -> Budd_Chiari;
    Ven_thromb -> Port_thromb;
    Micro_thromb -> Erythromel;
    Micro_thromb -> Headache_vis;
    Plt_adh   -> Micro_thromb;
    Coag_casc -> Thrombin_g  -> Fibrin_clot;
    Micropart -> Coag_casc   [label="PS exposure\n+ TF"];
    Endoth_dyf -> Art_thromb [label="↓NO\n↑TXA2"];
    vWF_ultra -> Plt_adh     [label="↑adhesion\nat high shear"];
    Plt_circ  -> Hemorrhage  [label="PLT>1500\nacquired vWD", color="#c62828"];
    ET_dysfun -> Hemorrhage;

    /* Drug PK: Hydroxyurea */
    HU_dose  -> HU_C         [label="F=0.80\nka=1.4/h", color="#283593"];
    HU_C     -> HU_P         [label="distribution"];
    HU_C     -> HU_RRM2      [label="IC50=80µM", color="#283593", penwidth=2];
    HU_RRM2  -> HU_Sphase    [label="↓dNTP pool"];
    HU_Sphase -> HU_apop;
    HU_apop  -> MKP          [arrowhead=tee, label="↓proliferation", color="#283593", penwidth=2];
    HU_apop  -> Mature_MK    [arrowhead=tee, color="#283593"];
    HU_apop  -> LT_HSC       [arrowhead=tee, label="mild BM\nsuppression", style=dashed];

    /* Drug PK: Anagrelide */
    ANA_dose -> ANA_C        [label="F=0.70\nka=4.6/h", color="#4527a0"];
    ANA_C    -> ANA_P        [label="distribution"];
    ANA_C    -> ANA_PDE3     [label="Ki=36nM\nMK-selective", color="#4527a0", penwidth=2];
    ANA_C    -> ANA_3OH      [label="CYP1A2"];
    ANA_PDE3 -> ANA_cAMP     [label="↑cAMP"];
    ANA_cAMP -> IMK          [arrowhead=tee, label="↓maturation", color="#4527a0", penwidth=2];
    ANA_cAMP -> Proplatelet  [arrowhead=tee, label="↓proplatelet", color="#4527a0"];

    /* Drug PK: Ruxolitinib */
    RUX_dose -> RUX_C        [label="F=0.95\nka=2.3/h", color="#00695c"];
    RUX_C    -> RUX_P        [label="distribution"];
    RUX_C    -> RUX_JAK12    [label="Ki=3.3nM\nJAK2", color="#00695c", penwidth=2];
    RUX_JAK12 -> RUX_pSTAT5 [label="↓pSTAT5"];
    RUX_JAK12 -> RUX_cytok  [label="↓IL-6,TNF"];
    RUX_pSTAT5 -> JAK2_act  [arrowhead=tee, label="pathway\nblock", color="#00695c", penwidth=2.5];
    RUX_pSTAT5 -> MKP       [arrowhead=tee, color="#00695c"];
    RUX_cytok  -> IL6        [arrowhead=tee];
    RUX_cytok  -> IL1beta    [arrowhead=tee];
    RUX_cytok  -> Sym_burden [arrowhead=tee, label="↓symptoms"];

    /* Drug PK: Peg-IFN-α */
    pIFN_dose -> pIFN_C      [label="SC depot\nka=0.02/h", color="#880e4f"];
    pIFN_C    -> pIFN_P      [label="distribution"];
    pIFN_C    -> pIFN_immune [color="#880e4f", penwidth=2];
    pIFN_immune -> pIFN_clone [label="ISG induction\nprefer JAK2+ HSC"];
    pIFN_clone -> JAK2_V617F [arrowhead=tee, label="↓allele burden", color="#880e4f", penwidth=2.5];
    pIFN_clone -> JAK2_expand [arrowhead=tee];
    pIFN_clone -> pIFN_MR;

    /* Drug: Aspirin */
    ASA_dose  -> ASA_COX1    [label="covalent\nacetylation", color="#e65100", penwidth=2];
    ASA_COX1  -> COX1_enz    [arrowhead=tee, label="irreversible"];
    ASA_COX1  -> ASA_TXA2i;
    ASA_TXA2i -> TXA2_prod   [arrowhead=tee, color="#e65100", penwidth=2];
    ASA_TXA2i -> Plt_aggr    [arrowhead=tee, label="↓aggregation"];

    /* Drug: Busulfan */
    BUS_dose  -> BUS_alkyl   [color="#3e2723"];
    BUS_alkyl -> MKP         [arrowhead=tee, label="cytotoxic", color="#3e2723"];
    BUS_alkyl -> LT_HSC      [arrowhead=tee, label="HSC\nreduction", style=dashed];

    /* Clinical endpoints */
    Plt_circ   -> PLT_count;
    Spleen_cm  -> EMH_spleen;
    JAK2_V617F -> JAK2_AB;
    JAK2_AB    -> MIPSS_ET;
    PLT_count  -> CHR        [label="≤400×10⁹/L\n+ WBC≤10"];
    PLT_count  -> PHR        [label="≤600 or\n≥50%↓"];
    PLT_count  -> NR         [label="no criteria"];
    PLT_count  -> Hemorrhage [label="PLT>1500\nrisk↑"];
    JAK2_AB    -> CMR        [label="<1%"];
    JAK2_AB    -> PMR        [label="≥50%↓"];
    PLT_count  -> WHO2016;
    IPSS_ET    -> ELN_resp;
    Sym_burden -> QoL_score;
    Thrombo_free -> OS_endpoint;
    CHR        -> Thrombo_free [label="associated"];

    /* Risk stratification */
    Age_risk   [label="Age >60\n& Prior Thrombosis\n(IPSS-ET High)", shape=note, fillcolor="#ffcdd2", color="#c62828"];
    Age_risk   -> IPSS_ET;
    JAK2_AB    -> IPSS_ET    [label="JAK2+ ↑risk"];

    /* Disease progression */
    TGF_b1     -> Post_ET_MF [color="#880e4f", penwidth=2.5];
    Reticulin  -> Post_ET_MF;
    Clonal_evol -> Post_ET_MF [color="#880e4f"];
    Add_mutation -> Blast_phase;
    Blast_phase -> AML_transf;
    Cytogen_abn -> Genomic_inst -> Clonal_evol;
    Add_mutation -> Clonal_evol;
    JAK2_expand -> Clonal_evol;
    Post_ET_MF -> EMH_spleen;
    Post_ET_MF -> Osteoscl;
    EMH_spleen -> Spleen_cm;
    BM_hyper   -> Reticulin;
    BM_angio   -> BM_hyper;
    Reticulin  -> Collagen_fib [label="progression\n(MF-2→MF-3)"];

    /* Co-mutations enhance progression */
    TET2_mut   -> Clonal_evol;
    ASXL1_mut  -> Clonal_evol;
    ASXL1_mut  -> Post_ET_MF   [color="#880e4f"];
    TP53_mut   -> Blast_phase  [color="#880e4f", penwidth=2];
    IDH1_2_mut -> AML_transf   [color="#880e4f", penwidth=2];
    EZH2_mut   -> Post_ET_MF;
    DNMT3A_mut -> Clonal_evol;

    /* JAK2 clone expansion */
    JAK2_V617F -> JAK2_expand  [label="self-renewal\nadvantage"];
    JAK2_expand -> BM_hyper;
    JAK2_V617F -> Art_thromb   [label="CHIP effect\n2× risk↑", color="#c62828", style=dashed];
}
