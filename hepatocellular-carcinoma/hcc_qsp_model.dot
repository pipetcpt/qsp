digraph HCC_QSP {
    graph [
        label = "Hepatocellular Carcinoma (HCC) QSP Model\nMechanistic Map: Oncogenesis · Angiogenesis · Tumor Immunity · Drug PK/PD · Clinical Endpoints"
        fontname = "Helvetica-Bold"
        fontsize = 20
        labelloc = t
        bgcolor = "#0d1117"
        rankdir = LR
        nodesep = 0.55
        ranksep = 1.1
        splines = curved
        concentrate = false
    ]
    node [fontname="Helvetica" fontsize=10 style=filled penwidth=1.2]
    edge [fontname="Helvetica" fontsize=8 color="#aaaaaa" penwidth=0.9]

    /* ============================================================
       CLUSTER 1: Risk Factors & Etiology
    ============================================================ */
    subgraph cluster_risk {
        label = "① Risk Factors & Etiology"
        style = filled
        fillcolor = "#1a0808"
        color = "#cc3333"
        fontcolor = "#ffcccc"
        fontsize = 13
        fontname = "Helvetica-Bold"

        HBV        [label="Hepatitis B\nVirus (HBV)"        shape=ellipse fillcolor="#8b1a1a" fontcolor=white]
        HCV        [label="Hepatitis C\nVirus (HCV)"        shape=ellipse fillcolor="#8b1a1a" fontcolor=white]
        Alcohol    [label="Chronic\nAlcohol Use"            shape=ellipse fillcolor="#7a3010" fontcolor=white]
        NAFLD      [label="NAFLD/NASH"                      shape=ellipse fillcolor="#7a3010" fontcolor=white]
        Aflatoxin  [label="Aflatoxin B1\nExposure"          shape=ellipse fillcolor="#7a3010" fontcolor=white]
        Cirrhosis  [label="Liver\nCirrhosis"                shape=box    fillcolor="#c0392b" fontcolor=white]
        ChronicInfl[label="Chronic\nInflammation"           shape=ellipse fillcolor="#e74c3c" fontcolor=white]
        OxStress   [label="Oxidative\nStress / ROS"         shape=ellipse fillcolor="#c0392b" fontcolor=white]
        PortalHTN  [label="Portal\nHypertension"            shape=ellipse fillcolor="#922b21" fontcolor=white]
        Fibrosis   [label="Hepatic\nFibrosis"               shape=box    fillcolor="#a93226" fontcolor=white]
    }

    /* ============================================================
       CLUSTER 2: Oncogenic Molecular Events
    ============================================================ */
    subgraph cluster_onco {
        label = "② Oncogenic Molecular Events"
        style = filled
        fillcolor = "#120a20"
        color = "#8855cc"
        fontcolor = "#ddccff"
        fontsize = 13
        fontname = "Helvetica-Bold"

        HBx        [label="HBx Viral\nProtein"              shape=ellipse fillcolor="#9b59b6" fontcolor=white]
        HCV_NS5A   [label="HCV NS5A\nProtein"               shape=ellipse fillcolor="#9b59b6" fontcolor=white]
        TP53_mut   [label="TP53\nMutation (R249S)"          shape=diamond fillcolor="#6a0dad" fontcolor=white]
        CTNNB1_mut [label="CTNNB1 Mut\n(β-catenin GOF)"     shape=diamond fillcolor="#6a0dad" fontcolor=white]
        TERT_mut   [label="TERT Promoter\nMutation"         shape=diamond fillcolor="#6a0dad" fontcolor=white]
        ARID1A_loss[label="ARID1A\nLoss (SWI/SNF)"          shape=diamond fillcolor="#6a0dad" fontcolor=white]
        AXIN1_mut  [label="AXIN1\nMutation"                 shape=diamond fillcolor="#6a0dad" fontcolor=white]
        DDR        [label="DNA Damage\nResponse (DDR)"       shape=box    fillcolor="#8e44ad" fontcolor=white]
        EpigenMod  [label="Epigenetic\nDysregulation"       shape=box    fillcolor="#76448a" fontcolor=white]
        TelomShort [label="Telomere\nShortening"            shape=ellipse fillcolor="#6c3483" fontcolor=white]
        ChromRem   [label="Chromatin\nRemodeling Defect"    shape=box    fillcolor="#7d3c98" fontcolor=white]
        DysNodule  [label="Dysplastic\nNodule"              shape=ellipse fillcolor="#5b2c6f" fontcolor=white]
    }

    /* ============================================================
       CLUSTER 3: Intracellular Signaling Networks
    ============================================================ */
    subgraph cluster_signal {
        label = "③ Intracellular Signaling"
        style = filled
        fillcolor = "#080f20"
        color = "#3366bb"
        fontcolor = "#bbccff"
        fontsize = 13
        fontname = "Helvetica-Bold"

        /* MAPK branch */
        RAS      [label="RAS\n(KRAS/NRAS/HRAS)" shape=ellipse fillcolor="#1a5276" fontcolor=white]
        RAF      [label="RAF\n(CRAF/BRAF)"       shape=ellipse fillcolor="#1a5276" fontcolor=white]
        MEK12    [label="MEK1/2"                 shape=ellipse fillcolor="#1a5276" fontcolor=white]
        ERK12    [label="ERK1/2"                 shape=ellipse fillcolor="#154360" fontcolor=white]
        cMYC     [label="c-MYC\nOncogene"        shape=ellipse fillcolor="#1e8bc3" fontcolor=white]

        /* PI3K/AKT branch */
        PI3K     [label="PI3K\n(p110α/p85)"      shape=ellipse fillcolor="#0e6655" fontcolor=white]
        PTEN     [label="PTEN\n(Tumor Supp.)"    shape=ellipse fillcolor="#1e8449" fontcolor=white]
        AKT      [label="AKT\n(PKB)"             shape=ellipse fillcolor="#0e6655" fontcolor=white]
        mTORC1   [label="mTORC1\n(Raptor)"       shape=ellipse fillcolor="#0e6655" fontcolor=white]
        mTORC2   [label="mTORC2\n(Rictor)"       shape=ellipse fillcolor="#0e6655" fontcolor=white]
        S6K1     [label="S6K1\n(Protein Synth.)" shape=box    fillcolor="#117a65" fontcolor=white]
        X4EBP1   [label="4E-BP1\n(Translation)"  shape=box    fillcolor="#117a65" fontcolor=white]
        FOXO     [label="FOXO1/3\n(Apoptosis)"   shape=ellipse fillcolor="#117a65" fontcolor=white]

        /* Wnt/β-catenin */
        Wnt      [label="Wnt\nLigands"           shape=ellipse fillcolor="#7e5109" fontcolor=white]
        Frizzled [label="Frizzled\nReceptor"     shape=box    fillcolor="#784212" fontcolor=white]
        DVL      [label="Dishevelled\n(DVL)"     shape=ellipse fillcolor="#784212" fontcolor=white]
        GSK3b    [label="GSK-3β"                 shape=ellipse fillcolor="#6e2f1a" fontcolor=white]
        APC_cpx  [label="APC Destruction\nComplex" shape=box  fillcolor="#7d6608" fontcolor=white]
        BetaCat_C[label="β-Catenin\n(Cytoplasm)" shape=ellipse fillcolor="#935116" fontcolor=white]
        BetaCat_N[label="β-Catenin\n(Nucleus)"   shape=ellipse fillcolor="#d68910" fontcolor=white]
        TCFLEF   [label="TCF/LEF\nTranscription"  shape=box   fillcolor="#b7950b" fontcolor=white]

        /* RTK receptors */
        EGFR     [label="EGFR (ErbB1)"           shape=box    fillcolor="#1f618d" fontcolor=white]
        EGF_lig  [label="EGF/TGFα\nLigands"      shape=ellipse fillcolor="#2874a6" fontcolor=white]
        MET_R    [label="MET Receptor"            shape=box    fillcolor="#1f618d" fontcolor=white]
        HGF_lig  [label="HGF Ligand"             shape=ellipse fillcolor="#2874a6" fontcolor=white]
        FGFR14   [label="FGFR1-4\nReceptors"     shape=box    fillcolor="#1f618d" fontcolor=white]
        FGF19_lig[label="FGF19/FGF4\nLigands"    shape=ellipse fillcolor="#2874a6" fontcolor=white]
        IGFR1    [label="IGF-1R"                  shape=box    fillcolor="#1f618d" fontcolor=white]
        IGF1_lig [label="IGF-1/IGF-2"            shape=ellipse fillcolor="#2874a6" fontcolor=white]

        /* JAK-STAT */
        IL6R_sig [label="IL-6 Receptor\n(gp130)"  shape=box   fillcolor="#1f618d" fontcolor=white]
        JAK      [label="JAK1/2"                   shape=ellipse fillcolor="#1a5276" fontcolor=white]
        STAT3    [label="STAT3\n(pTyr705)"         shape=ellipse fillcolor="#1a5276" fontcolor=white]
        NFkB     [label="NF-κB\n(p65/p50)"        shape=ellipse fillcolor="#1a5276" fontcolor=white]
    }

    /* ============================================================
       CLUSTER 4: Angiogenesis & Tumor Vasculature
    ============================================================ */
    subgraph cluster_angio {
        label = "④ Angiogenesis & Hypoxia"
        style = filled
        fillcolor = "#200808"
        color = "#dd4444"
        fontcolor = "#ffbbbb"
        fontsize = 13
        fontname = "Helvetica-Bold"

        HIF1a    [label="HIF-1α\n(Hypoxia Sensor)" shape=ellipse fillcolor="#922b21" fontcolor=white]
        HIF2a    [label="HIF-2α\n(EPAS1)"          shape=ellipse fillcolor="#922b21" fontcolor=white]
        VHL_t    [label="VHL\nTumor Supp."         shape=ellipse fillcolor="#7b241c" fontcolor=white]
        Hypoxia  [label="Intratumoral\nHypoxia"    shape=box    fillcolor="#641e16" fontcolor=white]

        VEGF_A   [label="VEGF-A\n(Angiogenin)"    shape=ellipse fillcolor="#c0392b" fontcolor=white]
        VEGF_CD  [label="VEGF-C/D\n(Lymphangio.)" shape=ellipse fillcolor="#c0392b" fontcolor=white]
        VEGFR1   [label="VEGFR1 (FLT1)"           shape=box    fillcolor="#922b21" fontcolor=white]
        VEGFR2   [label="VEGFR2 (KDR)"            shape=box    fillcolor="#a93226" fontcolor=white]
        VEGFR3   [label="VEGFR3 (FLT4)"           shape=box    fillcolor="#922b21" fontcolor=white]
        PDGF_BB  [label="PDGF-BB\nPericyte Factor" shape=ellipse fillcolor="#c0392b" fontcolor=white]
        PDGFRb   [label="PDGFRβ"                  shape=box    fillcolor="#a93226" fontcolor=white]
        ANG1_2   [label="Angiopoietin-1/2"        shape=ellipse fillcolor="#e74c3c" fontcolor=white]
        TIE2     [label="TIE2 Receptor"           shape=box    fillcolor="#c0392b" fontcolor=white]
        Pericytes[label="Pericyte\nRecruitment"   shape=ellipse fillcolor="#7b241c" fontcolor=white]
        TumorVasc[label="Tumor\nNeovasculature"   shape=box    fillcolor="#641e16" fontcolor=white]
        Notch_DLL[label="NOTCH/DLL4\nTip-Stalk"  shape=ellipse fillcolor="#922b21" fontcolor=white]
        PlGF     [label="PlGF\n(Placental GF)"    shape=ellipse fillcolor="#c0392b" fontcolor=white]
    }

    /* ============================================================
       CLUSTER 5: Tumor Cell Biology & EMT
    ============================================================ */
    subgraph cluster_tumor {
        label = "⑤ Tumor Cell Biology & EMT"
        style = filled
        fillcolor = "#080820"
        color = "#4444cc"
        fontcolor = "#bbbbff"
        fontsize = 13
        fontname = "Helvetica-Bold"

        Proliferation[label="Tumor Cell\nProliferation"   shape=box    fillcolor="#1c2833" fontcolor=white]
        ApoptRes    [label="Apoptosis\nResistance"        shape=box    fillcolor="#1c2833" fontcolor=white]
        BCL2_XL     [label="BCL-2/BCL-XL\n(Anti-apoptotic)" shape=ellipse fillcolor="#1c2833" fontcolor=white]
        BAX_BAK     [label="BAX/BAK\n(Pro-apoptotic)"    shape=ellipse fillcolor="#1c2833" fontcolor=white]
        CaspCasc    [label="Caspase Cascade\n(3/7/9)"    shape=box    fillcolor="#1c2833" fontcolor=white]
        CDK4_6      [label="CDK4/6–Cyclin D1"            shape=ellipse fillcolor="#2c3e50" fontcolor=white]
        RB1_tumor   [label="RB1\n(Tumor Supp.)"          shape=ellipse fillcolor="#2c3e50" fontcolor=white]
        CellCycle   [label="Cell Cycle\nProgression"     shape=box    fillcolor="#2c3e50" fontcolor=white]
        SNAIL       [label="SNAIL/SLUG/\nTWIST (EMT-TF)" shape=ellipse fillcolor="#1c2833" fontcolor=white]
        E_Cadh      [label="E-Cadherin ↓\n(Loss)"        shape=ellipse fillcolor="#1c2833" fontcolor=white]
        Vimentin    [label="Vimentin/\nN-Cadherin ↑"     shape=ellipse fillcolor="#1c2833" fontcolor=white]
        EMT         [label="EMT\nProgram"                shape=box    fillcolor="#273746" fontcolor=white]
        MMP29       [label="MMP-2/9\n(Matrix Proteases)" shape=ellipse fillcolor="#2c3e50" fontcolor=white]
        CSC         [label="Cancer Stem\nCells (CSC)"    shape=ellipse fillcolor="#273746" fontcolor=white]
        CD44_133    [label="CD44+/CD133+\nCSC Markers"   shape=ellipse fillcolor="#273746" fontcolor=white]
        Metastasis  [label="Intrahepatic/Vascular\nMetastasis" shape=box fillcolor="#1c2833" fontcolor=white]
        TumorBurden [label="Tumor Burden\n(# cells)"    shape=box    fillcolor="#17202a" fontcolor=white]
        AFP_tumor   [label="AFP Secretion\n(Biomarker)"  shape=ellipse fillcolor="#1f618d" fontcolor=white]
        AutophRes   [label="Autophagy\nReprogramming"    shape=ellipse fillcolor="#1c2833" fontcolor=white]
    }

    /* ============================================================
       CLUSTER 6: Tumor Immune Microenvironment (TME)
    ============================================================ */
    subgraph cluster_immune {
        label = "⑥ Tumor Immune Microenvironment (TME)"
        style = filled
        fillcolor = "#081808"
        color = "#33aa33"
        fontcolor = "#bbffbb"
        fontsize = 13
        fontname = "Helvetica-Bold"

        CD8T        [label="CD8+ T cells\n(Cytotoxic CTL)"  shape=ellipse fillcolor="#145a32" fontcolor=white]
        CD4T        [label="CD4+ T cells\n(Helper Th1/Th2)" shape=ellipse fillcolor="#145a32" fontcolor=white]
        Tregs       [label="Regulatory T\ncells (Tregs)"    shape=ellipse fillcolor="#1e8449" fontcolor=white]
        NK_cells    [label="NK Cells\n(Innate Killers)"     shape=ellipse fillcolor="#145a32" fontcolor=white]
        TAM_M1      [label="TAM M1\n(Anti-tumor)"           shape=ellipse fillcolor="#117a65" fontcolor=white]
        TAM_M2      [label="TAM M2\n(Pro-tumor)"            shape=ellipse fillcolor="#1e8449" fontcolor=white]
        MDSC        [label="MDSCs\n(Suppressors)"           shape=ellipse fillcolor="#1e8449" fontcolor=white]
        DCs         [label="Dendritic Cells\n(APCs)"        shape=ellipse fillcolor="#145a32" fontcolor=white]
        PD1_T       [label="PD-1\n(T cell checkpoint)"     shape=box    fillcolor="#186a3b" fontcolor=white]
        PDL1_tumor  [label="PD-L1\n(Tumor + TAM)"          shape=box    fillcolor="#186a3b" fontcolor=white]
        CTLA4_T     [label="CTLA-4\n(T cell checkpoint)"   shape=box    fillcolor="#186a3b" fontcolor=white]
        LAG3_T      [label="LAG-3\n(Exhaustion)"           shape=box    fillcolor="#186a3b" fontcolor=white]
        TIM3_T      [label="TIM-3\n(Exhaustion)"           shape=box    fillcolor="#186a3b" fontcolor=white]
        TIGIT_T     [label="TIGIT\n(Checkpoint)"           shape=box    fillcolor="#186a3b" fontcolor=white]
        IFNg        [label="IFN-γ\n(Anti-tumor)"           shape=ellipse fillcolor="#145a32" fontcolor=white]
        TNFa_immune [label="TNF-α\n(Cytotoxic)"           shape=ellipse fillcolor="#145a32" fontcolor=white]
        IL10        [label="IL-10\n(Immunosuppressive)"    shape=ellipse fillcolor="#1e8449" fontcolor=white]
        TGFb_immune [label="TGF-β\n(Immunosuppressive)"   shape=ellipse fillcolor="#1e8449" fontcolor=white]
        IL6_immune  [label="IL-6\n(Inflammatory)"         shape=ellipse fillcolor="#117a65" fontcolor=white]
        TCRActiv    [label="TCR Activation\n& Effector Fn" shape=box    fillcolor="#145a32" fontcolor=white]
        TumorLysis  [label="Tumor Cell\nLysis (Immune)"   shape=box    fillcolor="#145a32" fontcolor=white]
        ImExhaust   [label="T Cell\nExhaustion"           shape=ellipse fillcolor="#1e8449" fontcolor=white]
        KupfferCell [label="Kupffer Cells\n(Liver Macs.)" shape=ellipse fillcolor="#117a65" fontcolor=white]
    }

    /* ============================================================
       CLUSTER 7: Drug PK Compartments
    ============================================================ */
    subgraph cluster_pk {
        label = "⑦ Drug Pharmacokinetics (PK)"
        style = filled
        fillcolor = "#180e08"
        color = "#cc8833"
        fontcolor = "#ffddaa"
        fontsize = 13
        fontname = "Helvetica-Bold"

        /* Sorafenib (oral, 400 mg BID) */
        Sora_Gut    [label="Sorafenib\nGut Depot"          shape=box    fillcolor="#6e4c1e" fontcolor=white]
        Sora_Vc     [label="Sorafenib\nCentral (Vc=7.5L)"  shape=box    fillcolor="#784212" fontcolor=white]
        Sora_Vp     [label="Sorafenib\nPeripheral (Vp)"    shape=box    fillcolor="#6e4c1e" fontcolor=white]
        Sora_Met    [label="Sorafenib\nN-oxide Metabolite"  shape=ellipse fillcolor="#935116" fontcolor=white]

        /* Lenvatinib (oral, 12mg QD wt<60kg / 8mg QD) */
        Lenva_Gut   [label="Lenvatinib\nGut Depot"          shape=box    fillcolor="#5d4037" fontcolor=white]
        Lenva_Vc    [label="Lenvatinib\nCentral (Vc)"       shape=box    fillcolor="#6d4c41" fontcolor=white]
        Lenva_Vp    [label="Lenvatinib\nPeripheral (Vp)"    shape=box    fillcolor="#5d4037" fontcolor=white]

        /* Atezolizumab (IV, 1200mg q3w) */
        Atez_Vc     [label="Atezolizumab\nCentral (mAb)"   shape=box    fillcolor="#4a235a" fontcolor=white]
        Atez_Vp     [label="Atezolizumab\nPeripheral"      shape=box    fillcolor="#3b1a4a" fontcolor=white]

        /* Bevacizumab (IV, 15mg/kg q3w) */
        Beva_Vc     [label="Bevacizumab\nCentral (mAb)"    shape=box    fillcolor="#1a3a5a" fontcolor=white]
        Beva_Vp     [label="Bevacizumab\nPeripheral"       shape=box    fillcolor="#15304a" fontcolor=white]

        /* Nivolumab (IV, 240mg q2w) */
        Nivo_Vc     [label="Nivolumab\nCentral (mAb)"      shape=box    fillcolor="#1a4a3a" fontcolor=white]
        Nivo_Vp     [label="Nivolumab\nPeripheral"         shape=box    fillcolor="#15403a" fontcolor=white]

        /* Regorafenib (oral, 2nd-line, 160mg QD 3wk on/1wk off) */
        Rego_Gut    [label="Regorafenib\nGut Depot"         shape=box    fillcolor="#7d5c08" fontcolor=white]
        Rego_Vc     [label="Regorafenib\nCentral"           shape=box    fillcolor="#8d6708" fontcolor=white]

        /* Cabozantinib (oral, 2nd-line, 60mg QD) */
        Cabo_Gut    [label="Cabozantinib\nGut Depot"        shape=box    fillcolor="#5c4a08" fontcolor=white]
        Cabo_Vc     [label="Cabozantinib\nCentral"          shape=box    fillcolor="#6c5a10" fontcolor=white]

        /* Ramucirumab (IV, AFP≥400ng/mL) */
        Ramu_Vc     [label="Ramucirumab\nCentral (mAb)"    shape=box    fillcolor="#3a1a3a" fontcolor=white]

        /* Shared liver exposure node */
        LiverCu     [label="Liver\nFree Concentration (Cu)" shape=box   fillcolor="#a04000" fontcolor=white]
    }

    /* ============================================================
       CLUSTER 8: Drug PD Targets & Effects
    ============================================================ */
    subgraph cluster_pd {
        label = "⑧ Drug Targets & Pharmacodynamics"
        style = filled
        fillcolor = "#081808"
        color = "#22cc55"
        fontcolor = "#aaffcc"
        fontsize = 13
        fontname = "Helvetica-Bold"

        /* TKI target effects */
        VEGFR2_Inh  [label="VEGFR2\nInhibition"        shape=hexagon fillcolor="#1a7a4a" fontcolor=white]
        VEGFR13_Inh [label="VEGFR1/3\nInhibition"      shape=hexagon fillcolor="#1a7a4a" fontcolor=white]
        PDGFR_Inh   [label="PDGFRβ\nInhibition"        shape=hexagon fillcolor="#1a7a4a" fontcolor=white]
        RAF_Inh     [label="RAF Kinase\nInhibition"    shape=hexagon fillcolor="#1a7a4a" fontcolor=white]
        FGFR_Inh    [label="FGFR1-4\nInhibition"       shape=hexagon fillcolor="#1a7a4a" fontcolor=white]
        MET_Inh     [label="MET/RET\nInhibition"       shape=hexagon fillcolor="#1a7a4a" fontcolor=white]
        RET_Inh     [label="RET Kinase\nInhibition"    shape=hexagon fillcolor="#1a7a4a" fontcolor=white]
        KIT_Inh     [label="KIT\nInhibition"           shape=hexagon fillcolor="#1a7a4a" fontcolor=white]

        /* mAb target effects */
        PDL1_Block  [label="PD-L1 Blockade\n(Atezolizumab)" shape=hexagon fillcolor="#5a2080" fontcolor=white]
        PD1_Block   [label="PD-1 Blockade\n(Nivolumab)"     shape=hexagon fillcolor="#5a2080" fontcolor=white]
        VEGF_Neut   [label="VEGF-A\nNeutralization\n(Beva)" shape=hexagon fillcolor="#c0392b" fontcolor=white]
        VEGFR2_Block[label="VEGFR2 Blockade\n(Ramucirumab)" shape=hexagon fillcolor="#c0392b" fontcolor=white]

        /* Downstream PD effects */
        AngiogenInh [label="Angiogenesis\nInhibition"    shape=box    fillcolor="#117a65" fontcolor=white]
        MAPKInh     [label="MAPK Pathway\nInhibition"    shape=box    fillcolor="#117a65" fontcolor=white]
        ImmuneActiv [label="Immune\nActivation"          shape=box    fillcolor="#1e8449" fontcolor=white]
        TGInh       [label="Tumor Growth\nInhibition"    shape=box    fillcolor="#117a65" fontcolor=white]

        /* Resistance */
        SecMuts     [label="Secondary\nResistance Mutations" shape=ellipse fillcolor="#145a32" fontcolor=white]
        AltAngio    [label="Alternative Angio.\n(FGF/ANG escape)" shape=ellipse fillcolor="#145a32" fontcolor=white]
        Hyperprogi  [label="Hyperprogression\n(rare ICB)" shape=ellipse fillcolor="#1e8449" fontcolor=white]
    }

    /* ============================================================
       CLUSTER 9: Liver Function & Clinical Endpoints
    ============================================================ */
    subgraph cluster_endpoints {
        label = "⑨ Liver Function & Clinical Endpoints"
        style = filled
        fillcolor = "#141008"
        color = "#aaaa33"
        fontcolor = "#ffffaa"
        fontsize = 13
        fontname = "Helvetica-Bold"

        /* Liver function tests */
        ALT_AST     [label="ALT/AST\n(Hepatocellular Injury)" shape=ellipse fillcolor="#8d6e63" fontcolor=white]
        TotalBili   [label="Total Bilirubin\n(Conjugation)"   shape=ellipse fillcolor="#8d6e63" fontcolor=white]
        Albumin_lab [label="Serum Albumin\n(Synthesis)"       shape=ellipse fillcolor="#8d6e63" fontcolor=white]
        PT_INR      [label="PT/INR\n(Coagulation)"            shape=ellipse fillcolor="#8d6e63" fontcolor=white]
        GGT_ALP     [label="GGT/ALP\n(Cholestasis)"          shape=ellipse fillcolor="#8d6e63" fontcolor=white]
        Creatinine  [label="Creatinine\n(Renal Fn)"          shape=ellipse fillcolor="#8d6e63" fontcolor=white]
        AFP_lab     [label="AFP Level\n(ng/mL)"              shape=ellipse fillcolor="#1f618d" fontcolor=white]
        PIVKA2      [label="PIVKA-II (DCP)\n(HCC marker)"    shape=ellipse fillcolor="#1f618d" fontcolor=white]

        /* Scoring systems */
        ChildPugh   [label="Child-Pugh Score\n(A/B/C)"       shape=box    fillcolor="#5d4037" fontcolor=white]
        MELD_score  [label="MELD Score\n(6–40)"              shape=box    fillcolor="#5d4037" fontcolor=white]
        BCLC        [label="BCLC Stage\n(0→A→B→C→D)"        shape=box    fillcolor="#4e342e" fontcolor=white]
        Ascites_lab [label="Ascites\n(Clinical Sign)"        shape=ellipse fillcolor="#6d4c41" fontcolor=white]

        /* Imaging/Tumor */
        TumorVol    [label="Tumor Volume\n(cm³)"             shape=box    fillcolor="#37474f" fontcolor=white]
        TumorSize   [label="Sum of Diameters\n(RECIST 1.1)"  shape=box    fillcolor="#37474f" fontcolor=white]
        mRECIST_resp[label="mRECIST\nViable Enhancement"     shape=box    fillcolor="#37474f" fontcolor=white]
        ViableVol   [label="Viable Tumor\nVolume"            shape=box    fillcolor="#37474f" fontcolor=white]

        /* Efficacy endpoints */
        OS_HCC      [label="Overall Survival\n(Months)"      shape=box    fillcolor="#2e7d32" fontcolor=white]
        PFS_HCC     [label="Progression-Free\nSurvival (PFS)" shape=box   fillcolor="#2e7d32" fontcolor=white]
        TTP_HCC     [label="Time to\nProgression (TTP)"      shape=box    fillcolor="#2e7d32" fontcolor=white]
        ORR_HCC     [label="Objective Response\nRate (ORR)"  shape=box    fillcolor="#2e7d32" fontcolor=white]
        DCR_HCC     [label="Disease Control\nRate (DCR)"     shape=box    fillcolor="#2e7d32" fontcolor=white]
        DurResponse [label="Duration of\nResponse (DoR)"     shape=box    fillcolor="#2e7d32" fontcolor=white]

        /* Safety */
        HFSR        [label="Hand-Foot Skin\nReaction (HFSR)" shape=ellipse fillcolor="#4a4a00" fontcolor=white]
        Hypertension[label="Drug-Induced\nHypertension"      shape=ellipse fillcolor="#4a4a00" fontcolor=white]
        Hypothyroid [label="Drug-Induced\nHypothyroidism"    shape=ellipse fillcolor="#4a4a00" fontcolor=white]
        irAE        [label="Immune-related\nAEs (irAE)"      shape=ellipse fillcolor="#4a4a00" fontcolor=white]
    }

    /* ============================================================
       EDGES: Risk Factors → Molecular Events
    ============================================================ */
    HBV        -> HBx          [label="encodes"]
    HBV        -> DDR          [label="viral integration\n→ DSBs"]
    HBV        -> Cirrhosis    [label="chronic hepatitis"]
    HBV        -> ChronicInfl  [label="immune activation"]
    HCV        -> HCV_NS5A     [label="encodes"]
    HCV        -> ChronicInfl  [label="innate immune"]
    HCV        -> Cirrhosis    [label="fibrosis→cirrhosis"]
    Alcohol    -> OxStress     [label="acetaldehyde ROS"]
    Alcohol    -> Cirrhosis    [label="steatohepatitis"]
    NAFLD      -> OxStress     [label="lipotoxicity"]
    NAFLD      -> Cirrhosis    [label="NASH→fibrosis"]
    Aflatoxin  -> TP53_mut     [label="codon 249 mut" color="#ff6644"]
    Aflatoxin  -> DDR          [label="DNA adducts"]
    Cirrhosis  -> ChronicInfl  [label="cytokine storm"]
    Cirrhosis  -> PortalHTN    [label="↑portal pressure"]
    Cirrhosis  -> Fibrosis     [label="advanced stage"]
    Cirrhosis  -> OxStress     [label="mitochondrial"]
    ChronicInfl-> DDR          [label="reactive species"]
    ChronicInfl-> IL6_immune   [label="IL-6 secretion"]
    OxStress   -> DDR          [label="8-OHdG/DSBs"]
    DDR        -> TP53_mut     [label="selection pressure" color="#cc4400"]
    DDR        -> TelomShort   [label="replication stress"]
    DDR        -> DysNodule    [label="accumulation"]
    TelomShort -> DysNodule    [label="chromosomal instab."]
    DysNodule  -> TumorBurden  [label="HCC transformation"]

    HBx        -> TP53_mut     [label="inactivates p53" color="#ff4444"]
    HBx        -> NFkB         [label="activates" color="#ffaa44"]
    HBx        -> PI3K         [label="activates"]
    HBx        -> STAT3        [label="activates"]
    HBx        -> Wnt          [label="upregulates"]
    HCV_NS5A   -> PI3K         [label="activates"]
    HCV_NS5A   -> STAT3        [label="activates"]
    HCV_NS5A   -> Wnt          [label="upregulates"]
    CTNNB1_mut -> BetaCat_C    [label="GOF: no degradation" color="#ffaa44"]
    AXIN1_mut  -> APC_cpx      [label="disrupts complex" color="#ff4444"]
    ARID1A_loss-> ChromRem     [label="SWI/SNF loss" color="#ff4444"]
    EpigenMod  -> ChromRem     [label="DNMT3A/TET2"]
    TERT_mut   -> TumorBurden  [label="immortalization" color="#ffaa44"]

    /* ============================================================
       EDGES: Signaling Networks
    ============================================================ */
    /* RTK activation */
    EGF_lig    -> EGFR         [label="binds"]
    HGF_lig    -> MET_R        [label="binds"]
    FGF19_lig  -> FGFR14       [label="binds"]
    IGF1_lig   -> IGFR1        [label="binds"]
    IL6_immune -> IL6R_sig     [label="binds"]
    IL6R_sig   -> JAK          [label="activates"]
    JAK        -> STAT3        [label="pTyr705"]

    /* MAPK cascade */
    EGFR       -> RAS          [label="via GRB2/SOS"]
    MET_R      -> RAS          [label="via GAB1"]
    FGFR14     -> RAS          [label="via FRS2α"]
    IGFR1      -> RAS          [label="via IRS-1"]
    RAS        -> RAF          [label="GTP-bound acts"]
    RAF        -> MEK12        [label="phosphorylates"]
    MEK12      -> ERK12        [label="phosphorylates"]
    ERK12      -> cMYC         [label="stabilizes T58"]
    ERK12      -> SNAIL        [label="stabilizes"]
    ERK12      -> VEGF_A       [label="HRE transcription"]
    ERK12      -> Proliferation [label="cyclin D1/E"]
    cMYC       -> Proliferation [label="transcriptional prog"]
    cMYC       -> TumorBurden  [label="growth genes"]

    /* PI3K/AKT/mTOR */
    EGFR       -> PI3K         [label="via p85 SH2"]
    MET_R      -> PI3K         [label="direct"]
    IGFR1      -> PI3K         [label="via IRS-1"]
    PTEN       -> PI3K         [label="inhibits PIP3" color="#44aaff" style=dashed]
    PI3K       -> AKT          [label="PIP3 → PDK1"]
    AKT        -> mTORC1       [label="via TSC1/2"]
    AKT        -> mTORC2       [label="positive loop"]
    mTORC2     -> AKT          [label="S473 phospho"]
    mTORC1     -> S6K1         [label="T389 phospho"]
    mTORC1     -> X4EBP1       [label="inactivates" color="#44aaff" style=dashed]
    S6K1       -> Proliferation [label="ribosome biogen."]
    X4EBP1     -> Proliferation [label="cap-dep translation"]
    AKT        -> FOXO         [label="T24 phospho→nuc. excl" color="#44aaff" style=dashed]
    AKT        -> BCL2_XL      [label="stabilizes"]
    AKT        -> NFkB         [label="IKKα/β activ."]
    FOXO       -> ApoptRes     [label="BIM/PUMA transcription" color="#44aaff" style=dashed]

    /* Wnt/β-catenin */
    Wnt        -> Frizzled     [label="binds LRP5/6"]
    Frizzled   -> DVL          [label="recruits"]
    DVL        -> GSK3b        [label="inhibits" color="#44aaff" style=dashed]
    GSK3b      -> BetaCat_C    [label="S33/S37 phos→\ndegradation" color="#44aaff" style=dashed]
    APC_cpx    -> BetaCat_C    [label="scaffold ubiquitin" color="#44aaff" style=dashed]
    BetaCat_C  -> BetaCat_N   [label="nuclear transloc"]
    BetaCat_N  -> TCFLEF       [label="co-activator"]
    TCFLEF     -> Proliferation [label="CyclinD1, MYC"]
    TCFLEF     -> CSC          [label="LGRS/SOX2"]
    TCFLEF     -> VEGF_A       [label="transcription"]

    /* JAK-STAT */
    STAT3      -> PDL1_tumor   [label="transcription"]
    STAT3      -> Proliferation [label="CyclinD1/Bcl-2"]
    STAT3      -> VEGF_A       [label="transcription"]
    STAT3      -> SNAIL        [label="EMT driver"]
    NFkB       -> SNAIL        [label="transcription"]
    NFkB       -> BCL2_XL      [label="transcription"]
    NFkB       -> VEGF_A       [label="transcription"]
    NFkB       -> IL6_immune   [label="positive loop"]

    /* ============================================================
       EDGES: Angiogenesis
    ============================================================ */
    HIF1a      -> VEGF_A       [label="HRE-driven"]
    HIF1a      -> PDGF_BB      [label="transcription"]
    HIF1a      -> VEGF_CD      [label="transcription"]
    HIF2a      -> VEGF_A       [label="transcription"]
    HIF2a      -> TumorVasc    [label="CXCR4 recruit"]
    Hypoxia    -> HIF1a        [label="VHL bypass/stabilize"]
    Hypoxia    -> HIF2a        [label="stabilize"]
    TumorBurden-> Hypoxia      [label="O2 demand > supply"]
    VHL_t      -> HIF1a        [label="ubiquitin deg." color="#44aaff" style=dashed]
    VEGF_A     -> VEGFR2       [label="high affinity"]
    VEGF_A     -> VEGFR1       [label="decoy/trap"]
    VEGF_CD    -> VEGFR3       [label="lymphangio"]
    PDGF_BB    -> PDGFRb       [label="pericyte signal"]
    PDGFRb     -> Pericytes    [label="recruits/matures"]
    ANG1_2     -> TIE2         [label="vessel stability"]
    VEGFR2     -> TumorVasc    [label="endothel. prolif."]
    Pericytes  -> TumorVasc    [label="stabilizes vessels"]
    Notch_DLL  -> TumorVasc    [label="tip-stalk selection"]
    PlGF       -> VEGFR1       [label="binds"]
    TumorVasc  -> TumorBurden  [label="O2/nutrient supply"]
    TumorVasc  -> Metastasis   [label="intravascular route"]

    /* ============================================================
       EDGES: Tumor Biology
    ============================================================ */
    TP53_mut   -> ApoptRes     [label="loss of p21/PUMA" color="#ff4444"]
    TP53_mut   -> CellCycle    [label="G1 arrest failure" color="#ff4444"]
    FOXO       -> BAX_BAK      [label="BIM/PUMA activ."]
    BCL2_XL    -> CaspCasc     [label="inhibits" color="#44aaff" style=dashed]
    BAX_BAK    -> CaspCasc     [label="MOMP activation"]
    CaspCasc   -> TumorLysis   [label="Casp3/7 execution"]
    CDK4_6     -> RB1_tumor    [label="S780 phospho→inactiv." color="#44aaff" style=dashed]
    RB1_tumor  -> CellCycle    [label="G1 block release" color="#44aaff" style=dashed]
    CellCycle  -> TumorBurden  [label="mitotic progression"]
    Proliferation -> CellCycle [label="CDK/cyclin drive"]

    SNAIL      -> E_Cadh       [label="transcriptional repr." color="#44aaff" style=dashed]
    SNAIL      -> Vimentin     [label="induces"]
    E_Cadh     -> EMT          [label="loss enables"]
    Vimentin   -> EMT          [label="mesenchymal mark"]
    EMT        -> Metastasis   [label="invasion enabled"]
    EMT        -> CSC          [label="dedifferentiation"]
    MMP29      -> EMT          [label="matrix remodel"]
    MMP29      -> Metastasis   [label="BM degradation"]
    CSC        -> CD44_133     [label="markers"]
    CSC        -> ApoptRes     [label="resistance" color="#44aaff" style=dashed]
    CSC        -> TumorBurden  [label="self-renewal"]
    TumorBurden-> AFP_tumor    [label="secretion ↑"]
    TumorBurden-> TumorVol    [label="volume expansion"]
    TumorVol   -> TumorSize   [label="diameter calc"]
    TumorSize  -> mRECIST_resp [label="mRECIST viable"]
    ViableVol  -> mRECIST_resp [label="viable enhancement"]
    AutophRes  -> ApoptRes     [label="nutrient recycling" color="#44aaff" style=dashed]
    Metastasis -> TumorBurden  [label="satellite lesions"]

    /* ============================================================
       EDGES: Tumor Immunity
    ============================================================ */
    PD1_T      -> TCRActiv     [label="inhibits" color="#44aaff" style=dashed]
    PDL1_tumor -> PD1_T        [label="ligand binding" color="#ff4444"]
    CTLA4_T    -> TCRActiv     [label="inhibits" color="#44aaff" style=dashed]
