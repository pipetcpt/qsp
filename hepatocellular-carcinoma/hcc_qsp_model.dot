    IFNg       -> TAM_M1       [label="M1 polarization"]
    IFNg       -> TumorBurden  [label="anti-tumor" color="#44aaff" style=dashed]
    Tregs      -> CD8T         [label="suppress IL-2/granzyme" color="#44aaff" style=dashed]
    Tregs      -> IL10         [label="secretes"]
    Tregs      -> TGFb_immune  [label="secretes"]
    TAM_M1     -> TNFa_immune  [label="secretes"]
    TAM_M2     -> TGFb_immune  [label="secretes"]
    TAM_M2     -> IL10         [label="secretes"]
    TAM_M2     -> Tregs        [label="recruits"]
    TAM_M2     -> MDSC         [label="recruits"]
    MDSC       -> CD8T         [label="arginase/ROS suppress" color="#44aaff" style=dashed]
    IL10       -> CD8T         [label="suppresses" color="#44aaff" style=dashed]
    TGFb_immune-> CD8T         [label="suppresses" color="#44aaff" style=dashed]
    TGFb_immune-> Tregs        [label="induces"]
    TumorBurden-> PDL1_tumor   [label="IFNγ-driven ↑"]
    DCs        -> TCRActiv     [label="MHC-I/II Ag present."]
    DCs        -> CD8T         [label="cross-prime"]
    TNFa_immune-> TumorLysis   [label="TNFR1-mediated"]
    KupfferCell-> TAM_M2       [label="tumor educated M2"]
    KupfferCell-> IL6_immune   [label="homeostatic IL-6"]
    ImExhaust  -> CD8T         [label="dysfunctional" color="#44aaff" style=dashed]
    ImExhaust  -> LAG3_T       [label="upregulates"]
    ImExhaust  -> TIM3_T       [label="upregulates"]

    /* ============================================================
       EDGES: Drug PK
    ============================================================ */
    Sora_Gut   -> Sora_Vc      [label="ka=0.25/h\nF~38%" color="#f39c12"]
