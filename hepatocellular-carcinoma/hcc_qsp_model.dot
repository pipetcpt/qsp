    Lenva_Vp   -> Lenva_Vc     [label="CLD" color="#e67e22"]
    Lenva_Vc   -> LiverCu      [label="hepatic dist" color="#e67e22"]

    Atez_Vc    -> Atez_Vp      [label="CLD=0.41L/d" color="#9b59b6"]
    Atez_Vp    -> Atez_Vc      [label="CLD" color="#9b59b6"]

    Beva_Vc    -> Beva_Vp      [label="CLD=0.19L/d" color="#3498db"]
    Beva_Vp    -> Beva_Vc      [label="CLD" color="#3498db"]

