    Cabo_Gut   -> Cabo_Vc      [label="ka F~76%" color="#e8d44d"]

    /* ============================================================
       EDGES: Drug PD connections
    ============================================================ */
    LiverCu    -> VEGFR2_Inh   [label="Sora/Lenva/Rego" color="#88cc44"]
