digraph CKDMBD_QSP_Model {

    graph [
        rankdir    = "LR"
        fontname   = "Helvetica"
        fontsize   = 13
        splines    = true
        overlap    = false
        bgcolor    = "#FAFAFA"
        label      = "CKD-Mineral Bone Disorder (CKD-MBD)\nQSP Mechanistic Map — FGF23·Klotho·PTH·Vitamin D·Bone·Vascular Calcification·Drug PK/PD"
        labelloc   = "t"
        labeljust  = "c"
        nodesep    = 0.35
        ranksep    = 0.7
        pad        = 0.5
    ]

    node [
        fontname  = "Helvetica"
        fontsize  = 10
        style     = "filled,rounded"
        shape     = box
        width     = 1.5
        height    = 0.45
    ]

    edge [
        fontname  = "Helvetica"
        fontsize  = 8
        arrowsize = 0.7
    ]

    // ============================================================
    // CLUSTER 1 — KIDNEY FUNCTION
    // ============================================================
    subgraph cluster_kidney {
        label     = "① Kidney Function & Phosphate Handling"
        style     = filled
        fillcolor = "#E3F2FD"
        color     = "#0D47A1"
        fontsize  = 11

        GFR           [label="GFR\n(mL/min/1.73m²)"           fillcolor="#1565C0" fontcolor="white"]
        CKD_Stage     [label="CKD Stage\n(G1–G5)"              fillcolor="#1976D2" fontcolor="white"]
        ProxTubule    [label="Proximal\nTubule"                 fillcolor="#1E88E5" fontcolor="white"]
        NaPi2a        [label="NaPi-IIa/IIc\n(Phosphate cot.)" fillcolor="#42A5F5"]
        NaPi2c        [label="NaPi-IIc\n(Renal Pi return)"     fillcolor="#42A5F5"]
        TubPTH_R      [label="PTH Receptor\n(PT, Luminal)"     fillcolor="#64B5F6"]
        TubFGF23_R    [label="FGFR1c·Klotho\n(PT Complex)"    fillcolor="#64B5F6"]
        CYP27B1_k     [label="CYP27B1\n(Renal 1α-Hydroxylase)" fillcolor="#1565C0" fontcolor="white"]
        CYP24A1_k     [label="CYP24A1\n(24-Hydroxylase)"       fillcolor="#2196F3" fontcolor="white"]
        Klotho_mem    [label="Membrane Klotho\n(αKlotho/KL)"   fillcolor="#0D47A1" fontcolor="white"]
        sKlotho       [label="Soluble Klotho\n(sKlotho ↓ in CKD)" fillcolor="#1565C0" fontcolor="white"]
        TRPV5         [label="TRPV5\n(Ca²⁺ reabsorption)"      fillcolor="#90CAF9"]
        TRPV6         [label="TRPV6\n(Ca²⁺ uptake)"            fillcolor="#90CAF9"]

        GFR           -> CKD_Stage
        GFR           -> NaPi2a    [label="Pi excretion ↓"]
        GFR           -> NaPi2c    [label="Pi excretion ↓"]
        ProxTubule    -> NaPi2a
        ProxTubule    -> CYP27B1_k
        ProxTubule    -> CYP24A1_k
        ProxTubule    -> Klotho_mem
        Klotho_mem    -> sKlotho   [label="shed/cleave"]
        GFR           -> sKlotho   [label="↓ as GFR falls"]
    }

    // ============================================================
    // CLUSTER 2 — PHOSPHATE METABOLISM & FGF23
    // ============================================================
    subgraph cluster_phosphate {
        label     = "② Phosphate Metabolism & FGF23"
        style     = filled
        fillcolor = "#FFF3E0"
        color     = "#E65100"
        fontsize  = 11

        Pi_plasma     [label="Serum Phosphate\n(Pi, mg/dL)"           fillcolor="#E65100" fontcolor="white" shape=diamond]
        Pi_dietary    [label="Dietary Pi\nIntake (mg/day)"             fillcolor="#FF8F00"]
        Pi_intestinal [label="Intestinal Pi\nAbsorption (NaPi-IIb)"   fillcolor="#FF8F00"]
        Pi_bone_flux  [label="Pi Release\nfrom Bone"                   fillcolor="#FFA726"]
        FGF23_plasma  [label="FGF23\n(Plasma, pg/mL)"                  fillcolor="#BF360C" fontcolor="white" shape=diamond]
        FGF23_bone    [label="FGF23 Production\n(Osteocytes)"          fillcolor="#E64A19" fontcolor="white"]
        FGF23_liver   [label="FGF23 Cleavage\n(FURIN/SPC2 in Liver)"  fillcolor="#FF5722"]
        PHEX          [label="PHEX Protease\n(Pi metabolism regulator)" fillcolor="#FFCCBC"]
        DMP1          [label="DMP1\n(Matrix Mineral. Protein)"         fillcolor="#FFCCBC"]
        Sclerostin_P  [label="Sclerostin\n(Wnt Inhibitor, ↑ FGF23)"   fillcolor="#FFAB91"]
        GALNT3        [label="GALNT3\n(O-glycosylation FGF23)"         fillcolor="#FFCCBC"]
        FAM20C        [label="FAM20C Kinase\n(FGF23 phosphorylation)"  fillcolor="#FFCCBC"]
        CaP_product   [label="Ca × Pi Product\n(≥55: calcification risk)" fillcolor="#FF7043"]

        Pi_dietary    -> Pi_intestinal
        Pi_intestinal -> Pi_plasma    [label="absorbed"]
        Pi_bone_flux  -> Pi_plasma    [label="resorption flux"]
        Pi_plasma     -> FGF23_bone   [label="Pi↑ → FGF23↑"]
        FGF23_bone    -> FGF23_plasma
        FGF23_liver   -> FGF23_plasma [label="cleave (intact vs C-term)"]
        Pi_plasma     -> CaP_product
    }

    // ============================================================
    // CLUSTER 3 — VITAMIN D AXIS
    // ============================================================
    subgraph cluster_vitd {
        label     = "③ Vitamin D Axis"
        style     = filled
        fillcolor = "#FFFDE7"
        color     = "#F57F17"
        fontsize  = 11

        VitD3_skin    [label="Cholecalciferol\n(Vit D₃, Skin/Diet)"  fillcolor="#F9A825" fontcolor="white"]
        VitD25_liver  [label="25-OH-D₃\n(Calcidiol, ng/mL)"          fillcolor="#F57F17" fontcolor="white" shape=diamond]
        CYP2R1        [label="CYP2R1\n(Hepatic 25-Hydroxylase)"       fillcolor="#FBC02D"]
        VitD_active   [label="1,25-(OH)₂D₃\n(Calcitriol, pg/mL)"     fillcolor="#E65100" fontcolor="white" shape=diamond]
        DBP           [label="Vitamin D Binding\nProtein (DBP/GC)"    fillcolor="#FFF176"]
        VDR           [label="VDR (Vitamin D\nReceptor)"              fillcolor="#F9A825" fontcolor="white"]
        RXR           [label="RXR\n(Retinoid X Receptor)"             fillcolor="#FFF59D"]
        VDR_RXR       [label="VDR-RXR\nHeterodimer"                   fillcolor="#FBC02D"]
        VDRE          [label="VDRE\n(Vitamin D Response Element)"     fillcolor="#FFF176"]
        CaBP9k        [label="Calbindin D9k\n(Intestinal Ca transport)" fillcolor="#FFF59D"]
        PMCA          [label="PMCA1b\n(Ca²⁺ ATPase)"                  fillcolor="#FFF9C4"]
        FGF23_VDR     [label="FGF23 Gene\n(VDR-VDRE feedback)"        fillcolor="#FFCC02"]

        VitD3_skin    -> CYP2R1     [label="hydroxylate"]
        CYP2R1        -> VitD25_liver
        VitD25_liver  -> CYP27B1_k  [label="substrate"]
        CYP27B1_k     -> VitD_active [label="1α-hydroxylate"]
        CYP24A1_k     -> VitD_active [label="24-degrade" arrowhead=tee]
        VitD_active   -> VDR
        VDR           -> VDR_RXR
        VDR_RXR       -> VDRE
        VDRE          -> CaBP9k     [label="transcribe"]
        VDRE          -> PMCA       [label="transcribe"]
        VDR_RXR       -> FGF23_VDR  [label="induce FGF23↑"]
        VitD_active   -> CYP24A1_k  [label="auto-degrade feedback"]
    }

    // ============================================================
    // CLUSTER 4 — CALCIUM HOMEOSTASIS
    // ============================================================
    subgraph cluster_calcium {
        label     = "④ Calcium Homeostasis"
        style     = filled
        fillcolor = "#F3E5F5"
        color     = "#4A148C"
        fontsize  = 11

        Ca_plasma     [label="Serum Calcium\n(Ca²⁺, mg/dL)"           fillcolor="#7B1FA2" fontcolor="white" shape=diamond]
        Ca_ionized    [label="Ionized Ca²⁺\n(iCa, mmol/L)"            fillcolor="#8E24AA" fontcolor="white"]
        Ca_intestinal [label="Intestinal Ca\nAbsorption"               fillcolor="#CE93D8"]
        Ca_bone       [label="Bone Ca Pool\n(Hydroxyapatite)"          fillcolor="#9C27B0" fontcolor="white"]
        Ca_urine      [label="Urinary Ca\nExcretion"                   fillcolor="#BA68C8"]
        Ca_dialysis   [label="Dialysate Ca\n(in HD patients)"          fillcolor="#CE93D8"]
        CaSR_kidney   [label="CaSR\n(Kidney, Ca reabsorb.)"            fillcolor="#6A1B9A" fontcolor="white"]
        CLDN14        [label="Claudin-14\n(Paracellular Ca block)"     fillcolor="#E1BEE7"]
        Calcitonin    [label="Calcitonin\n(CT, bone anti-resorp.)"     fillcolor="#CE93D8"]
        Ca_supplement [label="Calcium\nSupplement (PO)"                fillcolor="#F3E5F5"]

        Ca_ionized    -> Ca_plasma
        Ca_intestinal -> Ca_plasma    [label="absorbed"]
        Ca_plasma     -> Ca_urine     [label="filtered"]
        CaSR_kidney   -> Ca_urine     [label="Ca↑→excrete"]
        Ca_bone       -> Ca_plasma    [label="resorption flux"]
        CaBP9k        -> Ca_intestinal [label="transport"]
    }

    // ============================================================
    // CLUSTER 5 — PARATHYROID GLAND
    // ============================================================
    subgraph cluster_ptg {
        label     = "⑤ Parathyroid Gland & Secondary HPT"
        style     = filled
        fillcolor = "#E8F5E9"
        color     = "#1B5E20"
        fontsize  = 11

        PTH_plasma    [label="Intact PTH\n(iPTH, pg/mL)"               fillcolor="#1B5E20" fontcolor="white" shape=diamond]
        PTH_secrete   [label="PTH Secretion\n(Chief Cell)"              fillcolor="#2E7D32" fontcolor="white"]
        PTG_mass      [label="Parathyroid\nGland Mass"                  fillcolor="#388E3C" fontcolor="white"]
        CaSR_ptg      [label="CaSR\n(Parathyroid)"                     fillcolor="#43A047" fontcolor="white"]
        VDR_ptg       [label="VDR\n(Parathyroid)"                      fillcolor="#4CAF50" fontcolor="white"]
        FGF23_ptg     [label="FGFR1-Klotho\n(Parathyroid)"             fillcolor="#66BB6A"]
        SecHPT        [label="Secondary\nHyperparathyroidism"          fillcolor="#2E7D32" fontcolor="white"]
        TerHPT        [label="Tertiary HPT\n(Autonomous)"              fillcolor="#1B5E20" fontcolor="white"]
        CyclinD1      [label="Cyclin D1\n(PTG proliferation)"          fillcolor="#81C784"]
        TGFa_PTG      [label="TGF-α Autocrine\n(PTG growth)"           fillcolor="#A5D6A7"]
        Nodular       [label="Nodular\nHyperplasia"                    fillcolor="#388E3C" fontcolor="white"]
        Parathyroid_Cx[label="Parathyroidectomy\n(PTx — surgical)"     fillcolor="#C8E6C9" shape=diamond]

        CaSR_ptg      -> PTH_secrete [label="Ca↑ → PTH↓" arrowhead=tee]
        VDR_ptg       -> PTH_secrete [label="VitD → PTH↓" arrowhead=tee]
        FGF23_ptg     -> PTH_secrete [label="FGF23 → PTH↓" arrowhead=tee]
        PTH_secrete   -> PTH_plasma
        PTG_mass      -> PTH_secrete [label="mass drives output"]
        PTG_mass      -> SecHPT
        SecHPT        -> Nodular
        Nodular       -> TerHPT
        CyclinD1      -> PTG_mass    [label="proliferate"]
        TGFa_PTG      -> PTG_mass    [label="autocrine growth"]
    }

    // ============================================================
    // CLUSTER 6 — BONE REMODELING
    // ============================================================
    subgraph cluster_bone {
        label     = "⑥ Bone Remodeling"
        style     = filled
        fillcolor = "#FBE9E7"
        color     = "#BF360C"
        fontsize  = 11

        Osteoblast    [label="Osteoblast\n(Bone Formation)"            fillcolor="#BF360C" fontcolor="white"]
        Osteoclast    [label="Osteoclast\n(Bone Resorption)"           fillcolor="#D84315" fontcolor="white"]
        Osteocyte     [label="Osteocyte\n(Mechano/Mineral Sensor)"     fillcolor="#E64A19" fontcolor="white"]
        PreOsteoblast [label="Pre-osteoblast\n(MSC differentiation)"   fillcolor="#FF7043"]
        PreOsteoclast [label="Osteoclast\nPrecursor (Monocyte)"        fillcolor="#FF8A65"]
        RANKL         [label="RANKL\n(OPG Ligand)"                     fillcolor="#BF360C" fontcolor="white"]
        OPG           [label="OPG\n(Osteoprotegerin)"                  fillcolor="#FF7043"]
        RANK          [label="RANK\n(Osteoclast receptor)"             fillcolor="#FF8A65"]
        M_CSF         [label="M-CSF\n(Macrophage CSF)"                 fillcolor="#FFAB91"]
        Sclerostin    [label="Sclerostin\n(SOST — Wnt inhibitor)"      fillcolor="#FFCCBC"]
        DKK1          [label="DKK1\n(Wnt-1 inhibitor)"                fillcolor="#FFCCBC"]
        Wnt_LRP5      [label="Wnt/LRP5-6\nSignaling"                  fillcolor="#FF8A65"]
        Runx2         [label="RUNX2\n(Osteoblast TF)"                  fillcolor="#FF7043"]
        BMP2          [label="BMP-2\n(Osteoblast inducer)"             fillcolor="#FFAB91"]
        Osterix       [label="Osterix/SP7\n(Osteoblast TF)"            fillcolor="#FFAB91"]
        Osteocalcin   [label="Osteocalcin\n(BGP, bone marker)"         fillcolor="#FFCCBC"]
        CollagenI     [label="Collagen Type I\n(Bone matrix)"          fillcolor="#FFCCBC"]
        BMD           [label="Bone Mineral\nDensity (BMD, g/cm²)"     fillcolor="#BF360C" fontcolor="white" shape=diamond]
        T_score       [label="T-score\n(DXA — osteoporosis)"           fillcolor="#D84315" fontcolor="white"]
        Fracture_risk [label="Fracture Risk\n(FRAX score)"             fillcolor="#E64A19" fontcolor="white"]
        P1NP          [label="P1NP\n(Bone formation marker)"           fillcolor="#FFCCBC"]
        CTX           [label="CTX-1\n(Bone resorption marker)"         fillcolor="#FFCCBC"]
        OstitisFib    [label="Osteitis\nFibrosa Cystica"               fillcolor="#BF360C" fontcolor="white"]
        AdynamicBone  [label="Adynamic\nBone Disease"                  fillcolor="#D84315" fontcolor="white"]

        PreOsteoblast -> Osteoblast
        PreOsteoclast -> Osteoclast
        RANKL         -> RANK      [label="bind/activate"]
        OPG           -> RANKL     [label="decoy receptor" arrowhead=tee]
        RANK          -> Osteoclast [label="differentiate"]
        M_CSF         -> Osteoclast [label="differentiate"]
        Sclerostin    -> Wnt_LRP5  [label="inhibit" arrowhead=tee]
        DKK1          -> Wnt_LRP5  [label="inhibit" arrowhead=tee]
        Wnt_LRP5      -> Runx2     [label="activate"]
        BMP2          -> Runx2     [label="activate"]
        BMP2          -> Osterix   [label="activate"]
        Runx2         -> Osteoblast
        Osterix       -> Osteoblast
        Osteoblast    -> CollagenI [label="secrete"]
        Osteoblast    -> Osteocalcin [label="secrete"]
        Osteoblast    -> P1NP      [label="produce"]
        Osteoclast    -> CTX       [label="produce"]
        Osteoblast    -> BMD       [label="build"]
        Osteoclast    -> BMD       [label="erode" arrowhead=tee]
        BMD           -> T_score
        T_score       -> Fracture_risk
        Osteocyte     -> Sclerostin [label="produce"]
        Osteocyte     -> RANKL     [label="produce"]
        Osteocyte     -> FGF23_bone [label="produce"]
    }

    // ============================================================
    // CLUSTER 7 — VASCULAR CALCIFICATION
    // ============================================================
    subgraph cluster_vasc_calc {
        label     = "⑦ Vascular Calcification"
        style     = filled
        fillcolor = "#EFEBE9"
        color     = "#3E2723"
        fontsize  = 11

        VSMC          [label="Vascular Smooth\nMuscle Cell (VSMC)"     fillcolor="#4E342E" fontcolor="white"]
        VSMC_osteo    [label="VSMC → Osteoblast\nTrans-differentiation" fillcolor="#5D4037" fontcolor="white"]
        BMP2_vasc     [label="BMP-2\n(Vascular)"                       fillcolor="#6D4C41"]
        RUNX2_vasc    [label="RUNX2\n(Vascular)"                       fillcolor="#795548"]
        MGP           [label="Matrix Gla Protein\n(MGP — calcification inhibitor)" fillcolor="#A1887F"]
        cMGP          [label="Carboxylated MGP\n(active inhibitor)"    fillcolor="#A1887F"]
        ucMGP         [label="Uncarboxylated MGP\n(inactive, ↑ in CKD)" fillcolor="#BCAAA4"]
        Fetuin_A      [label="Fetuin-A\n(CPP clearance, inhibitor)"    fillcolor="#8D6E63"]
        Pyrophosphate [label="Pyrophosphate (PPi)\n(calcification inhibitor)" fillcolor="#A1887F"]
        ENPP1         [label="ENPP1\n(PPi generator)"                  fillcolor="#BCAAA4"]
        ANKH          [label="ANKH\n(PPi transporter)"                 fillcolor="#BCAAA4"]
        TissNPP       [label="Tissue Non-specific\nAlkaline Phosphatase" fillcolor="#795548"]

        Hydroxyapatite[label="Hydroxyapatite\n(Ca₁₀(PO₄)₆(OH)₂)"    fillcolor="#3E2723" fontcolor="white"]
        Calciprotein  [label="Calciprotein\nParticles (CPP)"           fillcolor="#6D4C41"]
        MedialCalc    [label="Medial Artery\nCalcification"            fillcolor="#4E342E" fontcolor="white"]
        IntimalCalc   [label="Intimal\nAtherosclerotic Calcif."        fillcolor="#4E342E" fontcolor="white"]
        CarotidIMT    [label="Carotid IMT\n(mm)"                       fillcolor="#5D4037" fontcolor="white"]
        AortaCalc     [label="Aortic Calcification\nScore (ACS)"       fillcolor="#3E2723" fontcolor="white"]
        CoronaryCalc  [label="Coronary Artery\nCalcification (CAC)"    fillcolor="#3E2723" fontcolor="white"]
        LVH           [label="Left Ventricular\nHypertrophy (LVH)"     fillcolor="#4E342E" fontcolor="white"]
        VascStiff     [label="Vascular Stiffness\n(Pulse Wave Velocity)" fillcolor="#5D4037" fontcolor="white"]

        VSMC          -> VSMC_osteo  [label="Pi+Ca, BMP2 → transdiff."]
        VSMC_osteo    -> RUNX2_vasc
        RUNX2_vasc    -> BMP2_vasc   [label="amplify"]
        BMP2_vasc     -> RUNX2_vasc
        VSMC_osteo    -> Hydroxyapatite [label="mineralize"]
        CaP_product   -> Calciprotein
        Calciprotein  -> Hydroxyapatite [label="seed"]
        MGP           -> cMGP
        cMGP          -> Hydroxyapatite [label="inhibit" arrowhead=tee]
        ucMGP         -> Hydroxyapatite [label="fails to inhibit"]
        Fetuin_A      -> Calciprotein  [label="inhibit" arrowhead=tee]
        Pyrophosphate -> Hydroxyapatite [label="inhibit" arrowhead=tee]
        ENPP1         -> Pyrophosphate [label="generate"]
        TissNPP       -> Pyrophosphate [label="degrade" arrowhead=tee]
        Hydroxyapatite -> MedialCalc
        Hydroxyapatite -> IntimalCalc
        MedialCalc    -> AortaCalc
        MedialCalc    -> VascStiff
        IntimalCalc   -> CoronaryCalc
        VascStiff     -> LVH
        MedialCalc    -> CarotidIMT
    }

    // ============================================================
    // CLUSTER 8 — DRUG PK (Phosphate binders, Vitamin D, Calcimimetics)
    // ============================================================
    subgraph cluster_pk {
        label     = "⑧ Drug Pharmacokinetics"
        style     = filled
        fillcolor = "#E8EAF6"
        color     = "#1A237E"
        fontsize  = 11

        DoseAdmin     [label="Dose\nAdministration"   fillcolor="#283593" fontcolor="white" shape=diamond]

        // Phosphate binders
        Sevelamer_GI  [label="Sevelamer\nGI (Pi binding)"      fillcolor="#3949AB" fontcolor="white"]
        Sevelamer_Pi_bd [label="Sevelamer·Pi\nComplex (feces)" fillcolor="#5C6BC0"]
        LaCO3_GI      [label="Lanthanum\nCarbonate GI"         fillcolor="#3949AB" fontcolor="white"]
        CaCO3_GI      [label="Calcium Carbonate\nGI (Pi binder)" fillcolor="#3949AB" fontcolor="white"]
        CaCO3_Ca_abs  [label="Ca Absorbed\nfrom CaCO₃"         fillcolor="#5C6BC0"]

        // Cinacalcet (calcimimetic)
        Cinacalcet_gut [label="Cinacalcet\nGI (oral)"           fillcolor="#1565C0" fontcolor="white"]
        Cinacalcet_cp  [label="Cinacalcet\nPlasma (ng/mL)"      fillcolor="#0D47A1" fontcolor="white"]
        Cinacalcet_met [label="Cinacalcet\nMetabolites"         fillcolor="#1976D2"]

        // Paricalcitol (vitamin D analog)
        Parical_dose   [label="Paricalcitol\n(IV/PO dose, μg)"  fillcolor="#4527A0" fontcolor="white"]
        Parical_plasma [label="Paricalcitol\nPlasma (pg/mL)"    fillcolor="#512DA8" fontcolor="white"]

        // Calcitriol
        Calcitriol_dose[label="Calcitriol\n(dose, μg)"          fillcolor="#4527A0" fontcolor="white"]
        Calcitriol_cp  [label="Calcitriol\nPlasma (pg/mL)"      fillcolor="#512DA8" fontcolor="white"]

        // Etelcalcetide (IV calcimimetic)
        Etelcal_dose   [label="Etelcalcetide\n(IV dose, mg)"    fillcolor="#1565C0" fontcolor="white"]
        Etelcal_plasma [label="Etelcalcetide\nPlasma (ng/mL)"   fillcolor="#0D47A1" fontcolor="white"]

        // Denosumab
        Denosumab_dose [label="Denosumab\n(60 mg SC q6mo)"      fillcolor="#3949AB" fontcolor="white"]
        Denosumab_cp   [label="Denosumab\nPlasma (μg/mL)"       fillcolor="#5C6BC0"]

        // PK parameters
        Bioavail_cin   [label="Cinacalcet F\n(~35%, CYP3A4)"    fillcolor="#9FA8DA"]
        tHalf_cin      [label="Cinacalcet t½\n(~40h)"           fillcolor="#9FA8DA"]
        VDR_occupancy  [label="VDR Occupancy\n(paricalcitol vs calcitriol)" fillcolor="#9FA8DA"]

        DoseAdmin      -> Sevelamer_GI
        Sevelamer_GI   -> Sevelamer_Pi_bd [label="bind Pi in gut"]
        DoseAdmin      -> LaCO3_GI
        DoseAdmin      -> CaCO3_GI
        CaCO3_GI       -> CaCO3_Ca_abs
        DoseAdmin      -> Cinacalcet_gut
        Cinacalcet_gut -> Cinacalcet_cp   [label="F~35%"]
        Cinacalcet_cp  -> Cinacalcet_met  [label="CYP3A4/1A2"]
        DoseAdmin      -> Parical_dose
        Parical_dose   -> Parical_plasma
        DoseAdmin      -> Calcitriol_dose
        Calcitriol_dose -> Calcitriol_cp
        DoseAdmin      -> Etelcal_dose
        Etelcal_dose   -> Etelcal_plasma
        DoseAdmin      -> Denosumab_dose
        Denosumab_dose -> Denosumab_cp
    }

    // ============================================================
    // CLUSTER 9 — DRUG PD / PHARMACOLOGICAL TARGETS
    // ============================================================
    subgraph cluster_pd {
        label     = "⑨ Drug Pharmacodynamics & Targets"
        style     = filled
        fillcolor = "#E0F7FA"
        color     = "#006064"
        fontsize  = 11

        CaSR_act      [label="CaSR Allosteric\nActivation (calcimimetic)"  fillcolor="#00695C" fontcolor="white"]
        VDR_act       [label="VDR Activation\n(D analog)"                  fillcolor="#00838F" fontcolor="white"]
        Pi_bind_GI    [label="GI Phosphate\nBinding (binder)"              fillcolor="#0097A7" fontcolor="white"]
        RANKL_inh     [label="RANKL Inhibition\n(denosumab)"               fillcolor="#00ACC1"]
        FGF23_lower   [label="FGF23 Lowering\n(indirect, via Pi↓)"         fillcolor="#00BCD4"]
        PTH_suppress  [label="PTH Suppression\n(drug effect)"              fillcolor="#00838F" fontcolor="white"]

        PD_Pi_reduction [label="Serum Pi\nReduction Target"               fillcolor="#26C6DA"]
        PD_Ca_correct   [label="Calcium\nNormalization"                    fillcolor="#26C6DA"]
        PD_PTH_target   [label="iPTH Target\n(KDIGO: 2–9× ULN in G5)"    fillcolor="#26C6DA"]
        PD_FGF23_down   [label="FGF23 Reduction\n(treatment goal)"        fillcolor="#4DD0E1"]

        Emax_CaSR     [label="CaSR Emax Model\n(PTH suppression)"         fillcolor="#80DEEA"]
        EC50_Cinacalcet [label="EC50 Cinacalcet\n(~2 ng/mL for PTH)"     fillcolor="#80DEEA"]
        Emax_VDR      [label="VDR Emax Model\n(FGF23/RANKL suppress.)"    fillcolor="#80DEEA"]

        Cinacalcet_cp  -> CaSR_act    [label="allosteric"]
        Etelcal_plasma -> CaSR_act    [label="IV allosteric"]
        CaSR_act       -> PTH_suppress
        CaSR_act       -> Emax_CaSR
        EC50_Cinacalcet -> Emax_CaSR
        Parical_plasma -> VDR_act
        Calcitriol_cp  -> VDR_act
        VDR_act        -> Emax_VDR
        Sevelamer_Pi_bd -> Pi_bind_GI
        LaCO3_GI       -> Pi_bind_GI
        CaCO3_GI       -> Pi_bind_GI
        Denosumab_cp   -> RANKL_inh
        Pi_bind_GI     -> PD_Pi_reduction
        PTH_suppress   -> PD_PTH_target
        RANKL_inh      -> PD_FGF23_down  [label="indirect: OC→FGF23↓"]
    }

    // ============================================================
    // CLUSTER 10 — CLINICAL OUTCOMES & BIOMARKERS
    // ============================================================
    subgraph cluster_outcomes {
        label     = "⑩ Clinical Outcomes & Biomarkers"
        style     = filled
        fillcolor = "#ECEFF1"
        color     = "#263238"
        fontsize  = 11

        // Lab biomarkers
        iPTH_lab      [label="Intact PTH\n(pg/mL, KDIGO target)"     fillcolor="#37474F" fontcolor="white"]
        Pi_lab        [label="Serum Pi\n(mg/dL, target 2.5–4.5)"     fillcolor="#455A64" fontcolor="white"]
        Ca_lab        [label="Serum Ca\n(mg/dL, target 8.4–10.2)"    fillcolor="#546E7A" fontcolor="white"]
        VitD_lab      [label="25-OH-D\n(ng/mL, >30 target)"          fillcolor="#607D8B" fontcolor="white"]
        ALP_lab       [label="Alkaline Phosphatase\n(ALP, U/L)"      fillcolor="#78909C"]
        FGF23_lab     [label="FGF23\n(pg/mL, early ↑ marker)"        fillcolor="#90A4AE"]

        // Imaging
        DXA_BMD       [label="DXA BMD\n(g/cm², total hip)"           fillcolor="#78909C"]
        XR_bone       [label="X-Ray\n(subperiosteal resorption)"      fillcolor="#90A4AE"]
        Echo_LV       [label="Echocardiography\n(LV mass, EF)"       fillcolor="#B0BEC5"]

        // Cardiovascular
        CV_event      [label="Cardiovascular\nEvent Risk"             fillcolor="#263238" fontcolor="white"]
        MACE          [label="MACE\n(MI/Stroke/CV death)"            fillcolor="#37474F" fontcolor="white"]
        HD_mortality  [label="Dialysis\nMortality"                    fillcolor="#263238" fontcolor="white"]

        // CKD progression
        GFR_decline   [label="GFR Decline\n(FGF23 contribution)"     fillcolor="#455A64" fontcolor="white"]
        ESRD          [label="ESRD\n(End-Stage Renal)"                fillcolor="#1C313A" fontcolor="white"]

        // Quality of life
        BoneSymptoms  [label="Bone Pain /\nProximal Myopathy"        fillcolor="#CFD8DC"]
        Pruritis      [label="Pruritus\n(CKD-associated)"            fillcolor="#CFD8DC"]

        iPTH_lab      -> XR_bone     [label="osteitis fibrosa"]
        iPTH_lab      -> ALP_lab     [label="bone turnover"]
        ALP_lab       -> DXA_BMD    [label="correlate"]
        CoronaryCalc  -> CV_event
        AortaCalc     -> CV_event
        LVH           -> MACE
        CV_event      -> MACE
        MACE          -> HD_mortality
        GFR_decline   -> ESRD
        Fracture_risk -> BoneSymptoms
        Pi_lab        -> CaP_product
        Ca_lab        -> CaP_product
    }

    // ============================================================
    // INTER-CLUSTER CONNECTIONS
    // ============================================================

    // CKD → FGF23/Phosphate
    GFR           -> Pi_plasma    [label="↓GFR→Pi retention" color="#0D47A1"]
    GFR           -> CYP27B1_k   [label="↓GFR→↓1α-OH" color="#0D47A1"]
    GFR           -> Klotho_mem  [label="↓GFR→↓Klotho" color="#0D47A1"]
    GFR           -> GFR_decline  [label="FGF23 drives GFR↓" color="#0D47A1"]

    // FGF23 → Kidney
    FGF23_plasma  -> TubFGF23_R   [label="bind FGFR1c/Klotho"]
    TubFGF23_R    -> CYP27B1_k   [label="suppress 1α-OH" color="#BF360C" arrowhead=tee]
    TubFGF23_R    -> CYP24A1_k   [label="induce 24-OH" color="#BF360C"]
    TubFGF23_R    -> NaPi2a       [label="↓Pi reabsorption" arrowhead=tee]
    FGF23_plasma  -> FGF23_ptg    [label="→PTG via Klotho"]
    FGF23_plasma  -> VSMC         [label="→LVH/fibrosis" color="#E64A19"]
    FGF23_plasma  -> LVH          [label="direct cardiac" color="#E64A19"]
    Klotho_mem    -> TubFGF23_R   [label="co-receptor"]
    sKlotho       -> FGF23_plasma [label="facilitate clearance" arrowhead=tee]

    // FGF23 → bone (positive feedback)
    VitD_active   -> FGF23_bone   [label="stimulate FGF23↑"]
    Pi_plasma     -> FGF23_bone   [label="Pi↑→FGF23↑"]

    // Vitamin D axis
    VitD_active   -> Ca_intestinal [label="↑absorption" color="#F57F17"]
    VitD_active   -> CaSR_ptg      [label="↑CaSR expression"]
    VitD_active   -> VDR_ptg       [label="activate"]
    VitD_active   -> OPG           [label="↑OPG" color="#F57F17"]
    VitD_active   -> RANKL         [label="↓RANKL" arrowhead=tee color="#F57F17"]
    VitD_active   -> Calcitonin    [label="↑CT" color="#F57F17"]
    VitD25_liver  -> Pi_lab        [label="reflects status"]

    // PTH effects
    PTH_plasma    -> TubPTH_R      [label="bind tubular PT receptor"]
    TubPTH_R      -> NaPi2a        [label="↓PT reabsorption (phosphaturia)" arrowhead=tee]
    TubPTH_R      -> CYP27B1_k     [label="↑1α-OH" color="#1B5E20"]
    PTH_plasma    -> RANKL         [label="↑RANKL (bone resorp.)" color="#1B5E20"]
    PTH_plasma    -> Osteoclast    [label="activate osteoclast" color="#1B5E20"]
    PTH_plasma    -> Osteoblast    [label="pulsatile→anabolic"]
    PTH_plasma    -> OstitisFib   [label="excess → OFC"]
    PTH_plasma    -> Pi_bone_flux  [label="bone Ca/Pi release"]
    Ca_ionized    -> CaSR_ptg      [label="Ca↑ → PTH↓" arrowhead=tee]
    VitD_active   -> PTH_plasma    [label="suppress PTH" arrowhead=tee color="#F57F17"]
    VitD_active   -> PTG_mass      [label="suppress growth" arrowhead=tee color="#F57F17"]

    // Calcium loops
    PTH_plasma    -> Ca_plasma     [label="↑Ca via bone/kidney"]
    CaSR_kidney   -> TubFGF23_R
    Ca_plasma     -> Ca_ionized
    Ca_ionized    -> CaSR_ptg      [label="feedback"]
    Ca_plasma     -> CaP_product

    // Bone → outcomes
    Osteoclast    -> Pi_bone_flux  [label="release Pi"]
    Osteoclast    -> Ca_bone       [label="release Ca"]
    Ca_bone       -> Ca_plasma     [label="resorption"]
    Pi_bone_flux  -> Pi_plasma
    RANKL         -> Osteoclast    [label="differentiate via RANK"]
    PTH_plasma    -> Sclerostin    [label="suppress SOST" arrowhead=tee]
    OstitisFib    -> Fracture_risk [label="bone fragility"]
    AdynamicBone  -> Fracture_risk [label="bone fragility"]

    // Vascular calcification loops
    Pi_plasma     -> CaP_product   [label="product"]
    Pi_plasma     -> Calciprotein  [label="load"]
    Pi_plasma     -> VSMC_osteo    [label="Pi → VSMC transdiff."]
    CaP_product   -> Hydroxyapatite [label="crystalize if ≥55"]
    FGF23_plasma  -> CoronaryCalc  [label="FGF23 → calcification proxy"]
    sKlotho       -> VSMC          [label="atheroprotective" arrowhead=tee]
    Fetuin_A      -> CaP_product   [label="stabilize→clear CPP" arrowhead=tee]
    VitK2         [label="Vitamin K₂\n(MGP carboxylation)"          fillcolor="#A5D6A7"]
    VitK2         -> cMGP          [label="carboxylate"]
    ucMGP         -> MedialCalc    [label="promotes when ucMGP↑"]

    // Drug effects on pathophysiology
    Pi_bind_GI    -> Pi_plasma     [label="reduce absorption" arrowhead=tee color="#006064"]
    Pi_plasma     -> Pi_lab
    CaSR_act      -> CaSR_ptg      [label="sensitize CaSR" color="#006064"]
    PTH_suppress  -> PTH_plasma    [label="reduce PTH" arrowhead=tee color="#006064"]
    VDR_act       -> VDR_ptg       [label="activate" color="#006064"]
    VDR_act       -> VitD_active   [label="VDR agonist effect" color="#006064"]
    VDR_act       -> FGF23_bone    [label="D-analog FGF23↑ risk"]
    RANKL_inh     -> RANKL         [label="decoy" arrowhead=tee color="#006064"]
    CaCO3_Ca_abs  -> Ca_plasma     [label="↑Ca" color="#3949AB"]
    PD_Pi_reduction -> Pi_lab      [label="clinical goal"]
    PD_PTH_target -> iPTH_lab      [label="clinical goal"]

    // Biomarker connections
    FGF23_plasma  -> FGF23_lab
    PTH_plasma    -> iPTH_lab
    Pi_plasma     -> Pi_lab
    Ca_plasma     -> Ca_lab
    VitD25_liver  -> VitD_lab
    P1NP          -> ALP_lab       [label="parallel formation marker"]
    CTX           -> XR_bone       [label="correlate"]
    BMD           -> DXA_BMD
    LVH           -> Echo_LV
    CoronaryCalc  -> Echo_LV

    // CKD progression
    FGF23_plasma  -> GFR_decline   [label="FGF23 directly toxic"]
    Pi_plasma     -> GFR_decline   [label="Pi nephrotoxic"]
    AortaCalc     -> GFR_decline   [label="ischemia" color="#3E2723"]
    GFR_decline   -> ESRD
}
