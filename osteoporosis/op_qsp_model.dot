digraph OsteoporosisQSP {
  graph [
    label="Osteoporosis QSP Mechanistic Map\nBone Remodeling · RANK/RANKL/OPG · PTH · Estrogen · Drug PK/PD"
    labelloc=t fontsize=22 fontname="Helvetica-Bold"
    bgcolor="#FAFAFA" rankdir=LR splines=true nodesep=0.35 ranksep=0.7
    pad=0.5
  ]
  node [shape=box style="filled,rounded" fontname="Helvetica" fontsize=10 margin="0.12,0.06"]
  edge [fontname="Helvetica" fontsize=9 arrowsize=0.7]

  /* ============================================================
     CLUSTER 1: Bone Remodeling Unit (BMU) — Microarchitecture
  ============================================================ */
  subgraph cluster_bmu {
    label="Bone Remodeling Unit (BMU)" style=filled fillcolor="#E8F4FD" color="#1A6FA3" penwidth=2
    node [fillcolor="#D6EAF8"]

    BMU_Activation [label="BMU Activation\n(Remodeling Cycle)"]
    Resorption_Phase [label="Resorption Phase\n(2–4 wk)"]
    Reversal_Phase [label="Reversal Phase\n(1–2 wk)"]
    Formation_Phase [label="Formation Phase\n(3–4 mo)"]
    Quiescence [label="Quiescence\n(Resting Surface)"]
    Bone_Surface [label="Bone Surface\n(Lining Cells)"]
    Canalicular_Network [label="Canalicular Network\n(Osteocyte Communication)"]
    Haversian_Canal [label="Haversian Canal\n(Blood Supply)"]
    Bone_Matrix_Reservoir [label="Bone Matrix Reservoir\n(Ca²⁺, PO₄³⁻)"]
    Remodeling_Balance [label="Remodeling Balance\n(Formation ↔ Resorption)"]
  }

  /* ============================================================
     CLUSTER 2: Osteoclast Biology
  ============================================================ */
  subgraph cluster_osteoclast {
    label="Osteoclast Biology" style=filled fillcolor="#FDEDEC" color="#C0392B" penwidth=2
    node [fillcolor="#FADBD8"]

    HSC [label="Hematopoietic Stem Cell\n(HSC)"]
    Monocyte_Precursor [label="Monocyte Precursor\n(CFU-M)"]
    Pre_OC [label="Pre-Osteoclast\n(RANK+)"]
    OC [label="Osteoclast\n(Active, multinucleated)"]
    OC_Apoptosis [label="Osteoclast Apoptosis"]
    RANK [label="RANK Receptor\n(on Pre-OC/OC)"]
    RANKL_OC [label="RANKL Binding → RANK\n→ NF-κB, JNK, MAPK"]
    TRAF6 [label="TRAF6\n(Signaling Adaptor)"]
    NFATc1 [label="NFATc1\n(Master OC Transcription Factor)"]
    cFos [label="c-Fos / AP-1"]
    DC_STAMP [label="DC-STAMP\n(Fusion Factor)"]
    CathepsinK [label="Cathepsin K\n(Collagen Degradation)"]
    TRAP [label="TRAP\n(Tartrate-Resistant Acid Phosphatase)"]
    MMP9_OC [label="MMP-9\n(Matrix Metalloprotease)"]
    HCl_Secretion [label="H⁺/Cl⁻ Secretion\n(Ruffled Border)"]
    Resorption_Lacuna [label="Resorption Lacuna\n(Howship's Lacuna)"]
    CTX [label="CTX\n(C-telopeptide, serum marker)"]
    NTX [label="NTX\n(N-telopeptide, urine marker)"]
    TRACP5b [label="TRACP5b\n(Osteoclast Activity Marker)"]
  }

  /* ============================================================
     CLUSTER 3: Osteoblast Biology
  ============================================================ */
  subgraph cluster_osteoblast {
    label="Osteoblast Biology" style=filled fillcolor="#E9F7EF" color="#1E8449" penwidth=2
    node [fillcolor="#D5F5E3"]

    MSC [label="Mesenchymal Stem Cell\n(MSC)"]
    Pre_OB [label="Pre-Osteoblast\n(Runx2+)"]
    OB [label="Osteoblast\n(Active, ALP+)"]
    OB_Embedding [label="Osteocyte Embedding\n(Matrix Entrapment)"]
    OB_Apoptosis [label="Osteoblast Apoptosis"]
    Runx2 [label="Runx2/Cbfa1\n(OB Master Regulator)"]
    Osterix [label="Osterix (Sp7)\n(OB Differentiation)"]
    BMP24 [label="BMP-2/4\n(OB Induction)"]
    Wnt_Canonical [label="Wnt/β-Catenin\n(Canonical Signaling)"]
    LRP56 [label="LRP5/6 Co-Receptor\n(Wnt Signaling)"]
    Sclerostin [label="Sclerostin (SOST)\n(Wnt Inhibitor)"]
    DKK1 [label="DKK-1\n(Wnt Antagonist)"]
    ALP [label="Alkaline Phosphatase\n(ALP, bone-specific)"]
    Osteocalcin [label="Osteocalcin (OC/BGLAP)\n(Bone Formation Marker)"]
    P1NP [label="P1NP\n(Procollagen Type I N-propeptide)"]
    Collagen_I [label="Type I Collagen\n(90% of Bone Matrix)"]
    Hydroxyapatite [label="Hydroxyapatite\n(Mineralization)"]
    OPG_OB [label="OPG (Osteoprotegerin)\n(Secreted by OB/Stromal)"]
    RANKL_OB [label="RANKL\n(Membrane/Soluble, OB/T cell)"]
  }

  /* ============================================================
     CLUSTER 4: Osteocyte & Mechanosensing
  ============================================================ */
  subgraph cluster_osteocyte {
    label="Osteocyte & Mechanosensing" style=filled fillcolor="#FEF9E7" color="#B7950B" penwidth=2
    node [fillcolor="#FCF3CF"]

    Osteocyte [label="Osteocyte\n(Long-lived, Lacunocanalicular)"]
    Mechanosensing [label="Mechanosensing\n(Fluid Shear Stress)"]
    Sclerostin_OC [label="Sclerostin Production\n(Load-regulated)"]
    FGF23_OC [label="FGF23\n(Phosphate Regulator)"]
    RANKL_OC2 [label="RANKL (Osteocyte)\n(Major RANKL Source)"]
    OPG_OC [label="OPG (Osteocyte)"]
    PGE2 [label="PGE2\n(Prostaglandin E2)"]
    NO_Mech [label="Nitric Oxide\n(Anabolic Signal)"]
    Cx43_Gap [label="Connexin-43\n(Gap Junctions)"]
    Apoptosis_OC_cell [label="Osteocyte Apoptosis\n(Glucocorticoid, Microfracture)"]
  }

  /* ============================================================
     CLUSTER 5: Systemic Hormonal Regulation
  ============================================================ */
  subgraph cluster_hormones {
    label="Systemic Hormonal Regulation" style=filled fillcolor="#F4ECF7" color="#7D3C98" penwidth=2
    node [fillcolor="#E8DAEF"]

    PTH_gland [label="Parathyroid Gland\n(Chief Cells)"]
    PTH [label="PTH (1-84)\n(Bone Anabolic/Catabolic)"]
    PTHrP [label="PTHrP\n(Local Regulator)"]
    PTH1R [label="PTH1R\n(cAMP/PKA Signaling)"]
    VitD3_skin [label="Vitamin D₃ (Skin)\n(UV→Cholecalciferol)"]
    VitD3_liver [label="25(OH)D₃\n(Liver Hydroxylation)"]
    VitD3_kidney [label="1,25(OH)₂D₃ (Calcitriol)\n(Kidney CYP27B1)"]
    VDR [label="VDR\n(Vitamin D Receptor)"]
    Calcitonin [label="Calcitonin\n(Thyroid C-cells)"]
    Estrogen [label="Estrogen (E2)\n(Ovarian/Peripheral)"]
    ER_alpha [label="ERα\n(Bone Receptor)"]
    Testosterone [label="Testosterone/DHEA\n(Aromatized → E2)"]
    IGF1 [label="IGF-1\n(GH-mediated, Anabolic)"]
    GH [label="Growth Hormone\n(GH)"]
    Cortisol [label="Cortisol\n(GIO risk)"]
    GR [label="Glucocorticoid Receptor\n(GR)"]
    Leptin [label="Leptin\n(Adipokine, Indirect Bone)"]
    Insulin_bone [label="Insulin\n(Anabolic to Bone)"]
    Ca_serum [label="Serum Calcium\n(8.5–10.5 mg/dL)"]
    PO4_serum [label="Serum Phosphate\n(2.5–4.5 mg/dL)"]
    CaSR [label="Calcium-Sensing Receptor\n(CaSR)"]
  }

  /* ============================================================
     CLUSTER 6: Immune / Inflammatory Regulation of Bone
  ============================================================ */
  subgraph cluster_immune_bone {
    label="Immune-Bone Crosstalk (Osteoimmunology)" style=filled fillcolor="#FDF2E9" color="#E67E22" penwidth=2
    node [fillcolor="#FAE5D3"]

    TNFa_bone [label="TNF-α\n(Pro-resorptive)"]
    IL1b_bone [label="IL-1β\n(RANKL Inducer)"]
    IL6_bone [label="IL-6\n(OC Differentiation)"]
    IL17_bone [label="IL-17\n(RANKL Induction)"]
    IL10_bone [label="IL-10\n(Anti-inflammatory)"]
    Th17_bone [label="Th17 Cells\n(IL-17 Source)"]
    Treg_bone [label="Treg Cells\n(OPG Induction)"]
    Macrophage_bone [label="Bone Macrophage\n(Osteomac)"]
    M1_M2 [label="M1/M2 Polarization\n(Pro/Anti-resorptive)"]
    IFNg_bone [label="IFN-γ\n(OC Inhibition)"]
    OPG_immune [label="OPG (Immune Cells)\n(T/B cell source)"]
    CD40L_bone [label="CD40L\n(T cell, RANKL inducer)"]
    Semaphorin3A [label="Semaphorin 3A\n(Neural Wnt activator)"]
  }

  /* ============================================================
     CLUSTER 7: Drug PK — Bisphosphonates, Denosumab, Teriparatide, Romosozumab
  ============================================================ */
  subgraph cluster_drug_pk {
    label="Drug Pharmacokinetics" style=filled fillcolor="#EBF5FB" color="#1A5276" penwidth=2
    node [fillcolor="#D6EAF8"]

    /* Bisphosphonate */
    ALN_oral [label="Alendronate (oral)\n70mg/week"]
    ALN_gut [label="GI Absorption\n(F ≈ 0.7%)"]
    ALN_plasma [label="Alendronate (Plasma)\nCmax rapid, t½ short"]
    ALN_bone [label="Alendronate (Bone)\nt½ >10 years"]
    ALN_renal [label="Renal Excretion\n(50% unchanged)"]

    ZOL_iv [label="Zoledronic Acid (IV)\n5mg/year"]
    ZOL_plasma [label="ZOL Plasma\nt½ α 0.24h, β 1.75h"]
    ZOL_bone [label="ZOL Bone Depot\nt½ >1 year"]

    /* Denosumab */
    DMAB_sc [label="Denosumab (SC)\n60mg/6mo"]
    DMAB_depot [label="SC Depot\n(Absorption)"]
    DMAB_plasma [label="Denosumab (Plasma)\nCmax ~6µg/mL"]
    DMAB_nonlinear [label="TMDD (RANKL binding)\nTarget-Mediated Disposition"]

    /* Teriparatide */
    TPTD_sc [label="Teriparatide (SC)\n20µg/day"]
    TPTD_depot [label="SC Depot\n(Absorption ka≈5/h)"]
    TPTD_plasma [label="Teriparatide (Plasma)\nt½ ≈1h (anabolic window)"]

    /* Romosozumab */
    ROMO_sc [label="Romosozumab (SC)\n210mg/month"]
    ROMO_depot [label="SC Depot"]
    ROMO_plasma [label="Romosozumab (Plasma)\nt½ ≈12 days"]
    ROMO_periph [label="Peripheral Compartment\n(Romosozumab)"]
  }

  /* ============================================================
     CLUSTER 8: Drug PD — Mechanism of Action
  ============================================================ */
  subgraph cluster_drug_pd {
    label="Drug Pharmacodynamics" style=filled fillcolor="#EAFAF1" color="#1E8449" penwidth=2
    node [fillcolor="#D5F5E3"]

    BP_FPP [label="BP → FPP Synthase\n(Mevalonate Pathway Block)"]
    BP_Prenyl [label="↓Protein Prenylation\n(Ras/Rho GTPase)"]
    BP_OC_Apop [label="↑Osteoclast Apoptosis\n(Bisphosphonate PD)"]
    BP_OC_Inhib [label="↓Osteoclast Function\n(Ruffled Border Disruption)"]

    DMAB_RANKL_block [label="Denosumab → RANKL Block\n(Anti-RANKL mAb, Kd≈3pM)"]
    DMAB_OC_reduce [label="↓Osteoclast Formation\n& Activity"]
    DMAB_reversible [label="Reversible Effect\n(Rebound on DC)"]

    TPTD_PTH1R_sig [label="Teriparatide → PTH1R\n(Intermittent cAMP burst)"]
    TPTD_OB_anabolic [label="↑Osteoblast\nDifferentiation & Survival"]
    TPTD_Wnt_up [label="↑Wnt Signaling\n(Sclerostin ↓ transiently)"]
    TPTD_RANKL_up [label="↑RANKL (short-term)\n→ coupling signal"]

    ROMO_SOST_block [label="Romosozumab → Sclerostin\n(Anti-SOST mAb)"]
    ROMO_Wnt_enhance [label="↑Wnt/β-Catenin\n(OB Anabolism)"]
    ROMO_OC_reduce [label="↓OPG downregulation\n→ mild anti-resorptive"]
    ROMO_dual [label="Dual Action:\nAnabolic + Anti-resorptive"]
  }

  /* ============================================================
     CLUSTER 9: Bone Mineral Density & Fracture Risk
  ============================================================ */
  subgraph cluster_bmd {
    label="BMD, Microarchitecture & Fracture Risk" style=filled fillcolor="#F9EBEA" color="#922B21" penwidth=2
    node [fillcolor="#F5CBA7"]

    BMD_LS [label="Lumbar Spine BMD\n(DXA, g/cm²)"]
    BMD_TH [label="Total Hip BMD\n(DXA, g/cm²)"]
    BMD_FN [label="Femoral Neck BMD\n(DXA, g/cm²)"]
    T_score [label="T-score\n(SD from Young-Normal)"]
    Z_score [label="Z-score\n(SD from Age-Matched)"]
    Trabecular_BV [label="Trabecular BV/TV\n(µCT/HR-pQCT)"]
    Cortical_Thick [label="Cortical Thickness\n(µCT, mm)"]
    Trabecular_Number [label="Trabecular Number\n(Tb.N, /mm)"]
    Trabecular_Separat [label="Trabecular Separation\n(Tb.Sp, mm)"]
    FRAX_score [label="FRAX Score\n(10-year fracture probability)"]
    Vertebral_Fx [label="Vertebral Fracture\n(Clinical/Morphometric)"]
    Hip_Fx [label="Hip Fracture\n(Femoral Neck/Trochanter)"]
    NonVert_Fx [label="Non-vertebral Fracture\n(Wrist, Rib, Humerus)"]
    Fx_RR [label="Fracture Risk Reduction\n(HR vs placebo)"]
    BTM_composite [label="Bone Turnover Markers\n(BTM) Composite"]
  }

  /* ============================================================
     CLUSTER 10: Clinical Risk Factors & Patient Profile
  ============================================================ */
  subgraph cluster_risk {
    label="Clinical Risk Factors & Patient Profile" style=filled fillcolor="#FDFEFE" color="#616A6B" penwidth=2
    node [fillcolor="#F2F3F4"]

    Age_risk [label="Age\n(Peak Bone Mass loss)"]
    Sex_risk [label="Sex\n(Postmenopausal F, Hypogonadal M)"]
    Menopause [label="Menopause\n(Estrogen ↓ → Bone ↓)"]
    BMI_risk [label="BMI\n(<18.5 = risk factor)"]
    Family_Hx [label="Family History\n(Hip Fracture Parent)"]
    Prior_Fx [label="Prior Fragility Fracture\n(Strongest predictor)"]
    Smoking [label="Smoking\n(↑OC activity)"]
    Alcohol [label="Alcohol\n(>3 units/day)"]
    GC_use [label="Glucocorticoid Use\n(≥7.5mg/day ≥3mo)"]
    Secondary_OP [label="Secondary Causes\n(RA, IBD, CKD, etc.)"]
    Falls_risk [label="Falls Risk\n(Gait, Balance, Vision)"]
    Calcium_intake [label="Calcium Intake\n(1000–1200mg/day)"]
    VitD_status [label="Vitamin D Status\n(25(OH)D target >30ng/mL)"]
    Exercise [label="Weight-bearing Exercise\n(Anabolic stimulus)"]
    Peak_Bone_Mass [label="Peak Bone Mass\n(Achieved ~30yr)"]
  }

  /* ============================================================
     ADDITIONAL PATHWAY NODES
  ============================================================ */
  Mevalonate_path [label="Mevalonate Pathway\n(HMG-CoA Reductase)" shape=box fillcolor="#FEF9E7" style="filled,rounded"]
  Statin_cross [label="Statin Cross-Talk\n(Mild OB anabolic?)" shape=box fillcolor="#FEF9E7" style="filled,rounded"]
  Ca_absorption_gut [label="Intestinal Ca²⁺\nAbsorption (VDR→TRPV6)" shape=box fillcolor="#E8DAEF" style="filled,rounded"]
  Ca_reabsorption_kidney [label="Renal Ca²⁺ Reabsorption\n(PTH→CaSR→TRPV5)" shape=box fillcolor="#E8DAEF" style="filled,rounded"]
  Klotho [label="Klotho\n(FGF23 Co-receptor)" shape=box fillcolor="#FCF3CF" style="filled,rounded"]
  Periosteal_Apposition [label="Periosteal Apposition\n(Outer Bone Growth)" shape=box fillcolor="#D5F5E3" style="filled,rounded"]
  Endosteal_Resorption [label="Endosteal Resorption\n(Inner Cortex Loss)" shape=box fillcolor="#FADBD8" style="filled,rounded"]
  SRE_RANKL [label="Soluble RANKL\n(sRANKL, plasma)" shape=box fillcolor="#FAE5D3" style="filled,rounded"]
  RANKL_OPG_ratio [label="RANKL/OPG Ratio\n(Key determinant)" shape=box fillcolor="#FAE5D3" style="filled,rounded"]
  ERK_MAPK [label="ERK/MAPK Signaling\n(OB Proliferation)" shape=box fillcolor="#D5F5E3" style="filled,rounded"]
  mTOR_bone [label="mTOR Signaling\n(OB/OC Metabolism)" shape=box fillcolor="#D5F5E3" style="filled,rounded"]
  Autophagy_bone [label="Autophagy\n(Bone Cell Survival)" shape=box fillcolor="#FCF3CF" style="filled,rounded"]
  ROS_bone [label="Reactive Oxygen Species\n(Oxidative Stress)" shape=box fillcolor="#FADBD8" style="filled,rounded"]
  Bisphosphonate_class [label="Bisphosphonate Class\n(N-containing: ALN, ZOL, RIS, IBN)" shape=box fillcolor="#D6EAF8" style="filled,rounded"]
  GIOP_mech [label="Glucocorticoid-Induced OP\n(↑Osteocyte Apop, ↓OB, ↑OC)" shape=box fillcolor="#FAE5D3" style="filled,rounded"]
  Denosumab_holiday [label="Drug Holiday\n(BP: OK; DMAB: Rebound Risk)" shape=box fillcolor="#D6EAF8" style="filled,rounded"]
  Sequential_therapy [label="Sequential Therapy\n(ROMO→DMAB; TPTD→BP)" shape=box fillcolor="#D6EAF8" style="filled,rounded"]
  HRpQCT [label="HR-pQCT\n(3D Microarchitecture)" shape=box fillcolor="#F5CBA7" style="filled,rounded"]
  DXA_scan [label="DXA Scanner\n(Bone Mineral Density)" shape=box fillcolor="#F5CBA7" style="filled,rounded"]
  QCT_spine [label="QCT\n(Volumetric BMD)" shape=box fillcolor="#F5CBA7" style="filled,rounded"]

  /* ============================================================
     EDGES — BMU Cycle
  ============================================================ */
  Bone_Surface -> BMU_Activation [label="Trigger\n(Microdamage,\nHormones)"]
  BMU_Activation -> Resorption_Phase
  Resorption_Phase -> Reversal_Phase
  Reversal_Phase -> Formation_Phase
  Formation_Phase -> Quiescence
  Quiescence -> Bone_Surface [style=dashed label="Resting"]
  Canalicular_Network -> BMU_Activation [label="Osteocyte\nsignal"]
  Haversian_Canal -> Resorption_Phase [label="Vasculature\ndelivery"]
  Bone_Matrix_Reservoir -> Ca_serum [label="Resorption\nrelease"]
  Remodeling_Balance -> BMD_LS [label="Net effect"]

  /* ============================================================
     EDGES — Osteoclast Differentiation
  ============================================================ */
  HSC -> Monocyte_Precursor -> Pre_OC -> OC
  RANKL_OB -> RANK [color="#C0392B" label="Binds"]
  RANKL_OC2 -> RANK [color="#C0392B"]
  SRE_RANKL -> RANK [color="#C0392B"]
  RANK -> TRAF6 -> NFATc1 -> DC_STAMP [label="Fusion"]
  NFATc1 -> CathepsinK [label="Transcription"]
  NFATc1 -> TRAP
  NFATc1 -> MMP9_OC
  NFATc1 -> cFos [dir=both]
  OC -> HCl_Secretion -> Resorption_Lacuna
  CathepsinK -> Resorption_Lacuna [label="Collagen\ndigestion"]
  OC -> CTX [label="Releases"]
  OC -> NTX [label="Releases"]
  OC -> TRACP5b [label="Marker"]
  OPG_OB -> RANKL_OB [label="Decoy\nreceptor" color="#1E8449" arrowhead=tee]
  OPG_OC -> RANKL_OC2 [color="#1E8449" arrowhead=tee]
  OPG_immune -> SRE_RANKL [color="#1E8449" arrowhead=tee]
  RANKL_OPG_ratio -> OC [label="Drives OC\nactivity"]
  RANKL_OB -> RANKL_OPG_ratio
  OPG_OB -> RANKL_OPG_ratio [arrowhead=tee]

  OC -> Resorption_Phase [label="Executes"]
  OC -> OC_Apoptosis [label="BP\naccelerates" style=dashed]

  /* ============================================================
     EDGES — Osteoblast Differentiation
  ============================================================ */
  MSC -> Pre_OB -> OB
  Runx2 -> Pre_OB [label="Drives"]
  BMP24 -> Runx2 [label="Activates"]
  Wnt_Canonical -> LRP56 -> Runx2 [label="Canonical\nWnt"]
  Sclerostin -> LRP56 [arrowhead=tee label="Inhibits\nLRP5/6"]
  DKK1 -> LRP56 [arrowhead=tee]
  Sclerostin_OC -> Sclerostin [label="Produces"]
  Osterix -> OB [label="Matures"]
  OB -> ALP
  OB -> Osteocalcin
  OB -> P1NP [label="Secretes"]
  OB -> Collagen_I -> Hydroxyapatite [label="Mineralizes"]
  OB -> OB_Embedding -> Osteocyte
  OB -> OB_Apoptosis [label="Cortisol\naccelerates" style=dashed]
  OB -> OPG_OB [label="Secretes"]
  OB -> RANKL_OB [label="Expresses"]
  ERK_MAPK -> OB [label="Proliferation"]
  mTOR_bone -> OB [label="Metabolism"]
  OB -> Formation_Phase [label="Executes"]
  Periosteal_Apposition -> OB [label="Anabolic"]
  IGF1 -> OB [label="Anabolic"]
  Insulin_bone -> OB [label="Anabolic"]

  /* ============================================================
     EDGES — Osteocyte
  ============================================================ */
  Osteocyte -> Sclerostin_OC
  Osteocyte -> FGF23_OC -> Klotho [label="Co-receptor"]
  Osteocyte -> RANKL_OC2
  Osteocyte -> OPG_OC
  Osteocyte -> PGE2 [label="Mechanical\nstimulus"]
  Osteocyte -> NO_Mech
  Osteocyte -> Cx43_Gap -> Canalicular_Network
  Mechanosensing -> Sclerostin_OC [arrowhead=tee label="Load ↓\nSclerostin"]
  Exercise -> Mechanosensing [label="Anabolic\nstimulus"]
  Apoptosis_OC_cell -> Osteocyte [label="Cortisol\ntriggers" style=dashed]
  GIOP_mech -> Apoptosis_OC_cell

  /* ============================================================
     EDGES — Hormonal Regulation
  ============================================================ */
  PTH_gland -> PTH
  CaSR -> PTH_gland [arrowhead=tee label="High Ca²⁺\nsuppresses"]
  Ca_serum -> CaSR
  PTH -> PTH1R -> Runx2 [label="Intermittent\nanabolic" style=dashed]
  PTH -> PTH1R -> RANKL_OB [label="Continuous\ncatabolic"]
  PTH -> Ca_reabsorption_kidney [label="↑Ca²⁺\nreabsorption"]
  PTH -> VitD3_kidney [label="↑CYP27B1\nactivation"]
  VitD3_skin -> VitD3_liver -> VitD3_kidney
  VitD3_kidney -> VDR -> Ca_absorption_gut [label="Genomic\neffect"]
  VDR -> OPG_OB [label="Modest ↑"]
  Ca_absorption_gut -> Ca_serum
  Ca_reabsorption_kidney -> Ca_serum
  Calcitonin -> OC [arrowhead=tee label="Inhibits\nacutely"]
  Estrogen -> ER_alpha -> OPG_OB [label="↑OPG"]
  Estrogen -> ER_alpha -> OC_Apoptosis [label="↑Apoptosis"]
  Estrogen -> ER_alpha -> RANKL_OB [arrowhead=tee label="↓RANKL"]
  Menopause -> Estrogen [arrowhead=tee label="E2 ↓ 80%"]
  Menopause -> TNFa_bone [label="↑Immune\nactivation"]
  Testosterone -> Estrogen [label="Aromatase"]
  GH -> IGF1 -> OB
  Cortisol -> GR -> OB_Apoptosis [label="Promotes"]
  Cortisol -> GR -> RANKL_OB [label="↑"]
  GR -> OPG_OB [arrowhead=tee label="↓OPG"]
  Leptin -> OB [label="CNS-indirect\nanabolic"]
  FGF23_OC -> PO4_serum [arrowhead=tee label="↓Phosphate"]

  /* ============================================================
     EDGES — Immune/Osteoimmunology
  ============================================================ */
  TNFa_bone -> RANKL_OB [label="Synergy"]
  TNFa_bone -> OC [label="Direct\ndifferentiation"]
  IL1b_bone -> RANKL_OB [label="Induces"]
  IL6_bone -> Pre_OC [label="Maturation"]
  IL17_bone -> RANKL_OB [label="Induces"]
  Th17_bone -> IL17_bone
  Treg_bone -> OPG_immune [label="Induces"]
  IFNg_bone -> OC [arrowhead=tee label="Inhibits\nfusion"]
  Macrophage_bone -> M1_M2
  M1_M2 -> TNFa_bone
  CD40L_bone -> RANKL_OB [label="T cell"]
  Semaphorin3A -> Wnt_Canonical [label="Neural\nbone axis"]
  IL10_bone -> TNFa_bone [arrowhead=tee label="Counter-\nregulates"]

  /* ============================================================
     EDGES — Drug PK
  ============================================================ */
  ALN_oral -> ALN_gut [label="F≈0.7%"]
  ALN_gut -> ALN_plasma [label="Rapid\nCmax"]
  ALN_plasma -> ALN_bone [label="20–50%\nbound"]
  ALN_plasma -> ALN_renal [label="50%\nUnchanged"]
  ZOL_iv -> ZOL_plasma [label="IV bolus"]
  ZOL_plasma -> ZOL_bone [label="High\naffinity"]
  DMAB_sc -> DMAB_depot -> DMAB_plasma [label="ka≈0.005/h"]
  DMAB_plasma -> DMAB_nonlinear [label="RANKL\nbinding"]
  TPTD_sc -> TPTD_depot -> TPTD_plasma [label="ka≈5/h"]
  ROMO_sc -> ROMO_depot -> ROMO_plasma [label="ka≈0.01/h"]
  ROMO_plasma -> ROMO_periph [label="2-cmt"]

  /* ============================================================
     EDGES — Drug PD
  ============================================================ */
  ALN_bone -> BP_FPP [label="IPP\naccumulates"]
  ZOL_bone -> BP_FPP
  BP_FPP -> Mevalonate_path [arrowhead=tee]
  Mevalonate_path -> BP_Prenyl
  BP_Prenyl -> BP_OC_Apop [label="Apoptosis\nCaspase-3"]
  BP_Prenyl -> BP_OC_Inhib
  BP_OC_Apop -> OC_Apoptosis
  BP_OC_Inhib -> HCl_Secretion [arrowhead=tee]
  BP_OC_Inhib -> Resorption_Phase [arrowhead=tee label="Inhibits"]

  DMAB_plasma -> DMAB_RANKL_block [label="Anti-RANKL\nmAb"]
  DMAB_RANKL_block -> SRE_RANKL [arrowhead=tee label="Blocks"]
  DMAB_RANKL_block -> RANKL_OPG_ratio [arrowhead=tee]
  DMAB_RANKL_block -> DMAB_OC_reduce -> OC [arrowhead=tee]
  DMAB_OC_reduce -> DMAB_reversible [label="No bone\nbinding"]

  TPTD_plasma -> TPTD_PTH1R_sig [label="Intermittent\nPTH1R burst"]
  TPTD_PTH1R_sig -> TPTD_OB_anabolic -> OB [label="Wnt+\nBMP2 ↑"]
  TPTD_PTH1R_sig -> TPTD_Wnt_up -> Wnt_Canonical
  TPTD_PTH1R_sig -> TPTD_RANKL_up -> RANKL_OB [label="Coupling\n(transient)"]

  ROMO_plasma -> ROMO_SOST_block [label="Anti-SOST\nmAb"]
  ROMO_SOST_block -> Sclerostin [arrowhead=tee label="Neutralizes"]
  ROMO_SOST_block -> ROMO_Wnt_enhance -> Wnt_Canonical [label="Disinhibit\nLRP5/6"]
  ROMO_Wnt_enhance -> ROMO_OC_reduce [label="↑OPG\n↓RANKL"]
  ROMO_OC_reduce -> OPG_OB [label="↑"]
  ROMO_SOST_block -> ROMO_dual

  Statin_cross -> Mevalonate_path [arrowhead=tee style=dashed label="Possible\nanabolic"]
  Denosumab_holiday -> DMAB_reversible [label="Risk of\nrebound"]
  Sequential_therapy -> ROMO_SOST_block [label="ROMO→DMAB"]

  /* ============================================================
     EDGES — BMD & Fracture Outcomes
  ============================================================ */
  Remodeling_Balance -> BMD_LS
  Remodeling_Balance -> BMD_TH
  Remodeling_Balance -> BMD_FN
  BMD_FN -> T_score
  BMD_LS -> T_score
  T_score -> Z_score [style=dashed]
  Trabecular_BV -> Trabecular_Number
  Trabecular_BV -> Trabecular_Separat
  Cortical_Thick -> Hip_Fx [label="Bone\nstrength"]
  BMD_TH -> FRAX_score
  Prior_Fx -> FRAX_score [label="Weight 2×"]
  Age_risk -> FRAX_score
  Family_Hx -> FRAX_score
  GC_use -> FRAX_score
  Smoking -> FRAX_score
  Alcohol -> FRAX_score
  FRAX_score -> Vertebral_Fx [label="Predicts"]
  FRAX_score -> Hip_Fx
  FRAX_score -> NonVert_Fx
  T_score -> FRAX_score
  CTX -> BTM_composite
  NTX -> BTM_composite
  P1NP -> BTM_composite
  ALP -> BTM_composite
  BTM_composite -> Fx_RR [label="Treatment\nmonitoring"]

  /* Imaging nodes */
  DXA_scan -> BMD_LS
  DXA_scan -> BMD_TH
  HRpQCT -> Trabecular_BV
  QCT_spine -> BMD_LS

  /* Risk factors → bone metabolism */
  Menopause -> RANKL_OB [label="↑RANKL\n(E2 ↓)"]
  GC_use -> GIOP_mech
  Secondary_OP -> RANKL_OB [label="Disease\neffect"]
  Calcium_intake -> Ca_serum
  VitD_status -> VitD3_kidney
  Falls_risk -> Hip_Fx [label="Biomechanical\nrisk"]
  Peak_Bone_Mass -> T_score [label="Baseline"]
  Sex_risk -> Menopause
  Age_risk -> OB_Apoptosis [label="Aging ↑"]
  BMI_risk -> Estrogen [label="Adipose\naromatase"]
  ROS_bone -> OB_Apoptosis [label="Oxidative\nstress"]
  Autophagy_bone -> Osteocyte [label="Survival"]

  /* Endosteal loss and cortical */
  Endosteal_Resorption -> Cortical_Thick [arrowhead=tee label="Thins"]
  OC -> Endosteal_Resorption [label="Cortical\nremodeling"]
  Periosteal_Apposition -> Cortical_Thick [label="Compensates"]

  /* Bisphosphonate drug class note */
  Bisphosphonate_class -> ALN_oral [style=dashed]
  Bisphosphonate_class -> ZOL_iv [style=dashed]
}
