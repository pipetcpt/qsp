digraph AIE_QSP {
  graph [
    rankdir=LR,
    fontname="Helvetica",
    fontsize=11,
    compound=true,
    splines=ortho,
    nodesep=0.25,
    ranksep=0.5,
    label="Anti-NMDA Receptor Encephalitis (AIE) – QSP Mechanistic Map\nDalmau & Graus 2018 · Lancaster & Dalmau 2012",
    labelloc=t,
    fontsize=14,
    bgcolor="#FAFAFA"
  ]
  node [shape=box, style="rounded,filled", fontsize=8, fontname="Helvetica", width=1.4, height=0.35]
  edge [fontsize=7, fontname="Helvetica", arrowsize=0.7]

  // ============================================================
  // CLUSTER 1: PERIPHERAL IMMUNE TRIGGER
  // ============================================================
  subgraph cluster_trigger {
    label="① Peripheral Immune Initiation"
    style=filled; fillcolor="#FFF3E0"; color="#E65100"; fontcolor="#E65100"; fontsize=10

    OvTer       [label="Ovarian Teratoma\n(NMDAR-expressing)", fillcolor="#FFCC80"]
    HerpesVirus [label="Herpes Simplex\nVirus (HSV)", fillcolor="#FFCC80"]
    HSV_Enc     [label="Post-HSV Encephalitis\n(Molecular Mimicry)", fillcolor="#FFAB40"]
    UnkTrig     [label="Unknown Trigger /\nIdiopathic (≈55%)", fillcolor="#FFE0B2", style="rounded,dashed,filled"]
    NMDAR_Ag    [label="NMDAR NR1/NR2B\nPeptide Antigen", fillcolor="#FF8A65"]
    APC         [label="Dendritic Cell /\nMacrophage (APC)", fillcolor="#FFAB40"]
    MHC_II      [label="MHC-II Peptide\nComplex", fillcolor="#FFAB40"]
    CD4_Tfh     [label="Tfh Cell\n(CXCR5+, PD-1+)", fillcolor="#FFA726"]
    CD4_Th17    [label="Th17 Effector\n(IL-17, IL-21, IL-22)", fillcolor="#FFA726"]
    CD4_Treg    [label="Regulatory T Cell\n(FoxP3+, Treg)", fillcolor="#C8E6C9"]
    CXCL13_peri [label="CXCL13 (Peripheral)\nGC Recruitment Signal", fillcolor="#FFE082"]
    IL21_peri   [label="IL-21\nB Cell Help Signal", fillcolor="#FFE082"]
    IL17_peri   [label="IL-17A / IL-17F\nPeripheral", fillcolor="#FFE082"]
    Treg_supp   [label="Treg Suppression\n(↓TGF-β, ↓IL-10)", fillcolor="#C8E6C9"]
    ICOS_CD28   [label="ICOS / CD28\nCo-stimulation", fillcolor="#FFCC80"]
  }

  // ============================================================
  // CLUSTER 2: B CELL DIFFERENTIATION & GC REACTION
  // ============================================================
  subgraph cluster_Bcell {
    label="② B Cell Differentiation & Germinal Center"
    style=filled; fillcolor="#E8EAF6"; color="#1A237E"; fontcolor="#1A237E"; fontsize=10

    NaiveB      [label="Naive B Cell\n(IgM+ IgD+ CD20+)", fillcolor="#C5CAE9"]
    ActivatedB  [label="Activated B Cell\n(CD19+ CD20+ CD27-)", fillcolor="#9FA8DA"]
    GCB         [label="Germinal Center B Cell\n(Ki67+ GL7+ CXCR4+)", fillcolor="#7986CB"]
    DarkZone    [label="Dark Zone B Cell\n(CXCR4hi, Proliferating)", fillcolor="#5C6BC0"]
    LightZone   [label="Light Zone B Cell\n(CXCR5hi, Selection)", fillcolor="#7986CB"]
    AID         [label="AID\n(Activation-Induced\nCytidine Deaminase)", fillcolor="#9FA8DA"]
    SHM         [label="Somatic Hypermutation\n(Affinity Maturation)", fillcolor="#9FA8DA"]
    ClassSwitch [label="Class Switch Recomb.\nIgM → IgG1/IgG4", fillcolor="#9FA8DA"]
    Plasmablast [label="Plasmablast\n(Short-Lived CD138+ CD20-)", fillcolor="#5C6BC0"]
    MemoryB     [label="Memory B Cell\n(CD27+ IgG+ CD20+)", fillcolor="#7986CB"]
    LLPC        [label="Long-Lived Plasma Cell\n(LLPC, CXCR4+ CD138+)", fillcolor="#3949AB", fontcolor=white]
    BAFF_BLyS   [label="BAFF / BLyS\n(B Cell Survival Factor)", fillcolor="#9FA8DA"]
    APRIL       [label="APRIL\n(Plasma Cell Survival)", fillcolor="#9FA8DA"]
    BCR_signal  [label="BCR Signaling\n(Syk, BTK, PI3Kδ)", fillcolor="#C5CAE9"]
    IL10_Breg   [label="IL-10 (Breg)\nRegulatory Suppression", fillcolor="#C8E6C9"]
    GC_FDC      [label="Follicular DC\n(FDC, Ag depot)", fillcolor="#C5CAE9"]
  }

  // ============================================================
  // CLUSTER 3: ANTIBODY DYNAMICS
  // ============================================================
  subgraph cluster_Ab {
    label="③ Anti-NMDAR Antibody Dynamics"
    style=filled; fillcolor="#FCE4EC"; color="#880E4F"; fontcolor="#880E4F"; fontsize=10

    IgG_NR1     [label="Anti-NR1 IgG\n(Dominant epitope)", fillcolor="#F48FB1"]
    IgG_NR2B    [label="Anti-NR2B IgG\n(GluN2B subunit)", fillcolor="#F48FB1"]
    IgG_serum   [label="Serum Anti-NMDAR IgG\n(nmol/L, CSF > serum)", fillcolor="#E91E63", fontcolor=white]
    FcRn_peri   [label="FcRn (Peripheral)\nIgG Recycling & t1/2", fillcolor="#F48FB1"]
    IgG_CSF     [label="CSF Anti-NMDAR IgG\n(Intrathecal Synthesis)", fillcolor="#E91E63", fontcolor=white]
    FcRn_CNS    [label="FcRn Transcytosis\n(BBB Endothelium)", fillcolor="#F48FB1"]
    Complement  [label="Complement Activation\n(C1q → C3b → MAC)", fillcolor="#EF9A9A"]
    ADCC_Ab     [label="ADCC via NK /\nMacrophage", fillcolor="#EF9A9A"]
    Ab_crosslink [label="NMDAR Crosslinking\n(Bivalent IgG)", fillcolor="#C62828", fontcolor=white]
    IgG_Index   [label="CSF IgG Index\n(Intrathecal ratio)", fillcolor="#F48FB1"]
    Ab_catab    [label="IgG Catabolism\n(t½ ≈ 23 d, FcRn)", fillcolor="#F8BBD0"]
  }

  // ============================================================
  // CLUSTER 4: BLOOD-BRAIN BARRIER
  // ============================================================
  subgraph cluster_BBB {
    label="④ Blood-Brain Barrier Dynamics"
    style=filled; fillcolor="#E0F7FA"; color="#006064"; fontcolor="#006064"; fontsize=10

    EndoBBB     [label="BBB Endothelial Cell\n(Tight Junction Scaffold)", fillcolor="#80DEEA"]
    Claudin5    [label="Claudin-5\n(TJ, ↓ in AIE)", fillcolor="#80DEEA"]
    Occludin    [label="Occludin\n(TJ Protein)", fillcolor="#80DEEA"]
    ZO1         [label="ZO-1\n(Scaffold/Adaptor)", fillcolor="#80DEEA"]
    MMP9_BBB    [label="MMP-9\n(TJ Degradation ↑)", fillcolor="#FF7043"]
    VEGF_BBB    [label="VEGF\n(Permeability ↑)", fillcolor="#FF7043"]
    Pericyte    [label="Pericyte\n(BBB Structural Support)", fillcolor="#80DEEA"]
    Astro_endfeet [label="Astrocyte Endfeet\n(BBB Maintenance)", fillcolor="#80DEEA"]
    BBB_perm    [label="BBB Permeability\n(% Disruption Index)", fillcolor="#26C6DA"]
    CXCL10_BBB  [label="CXCL10 / IP-10\n(T Cell Chemoattractant)", fillcolor="#FFAB40"]
    Tcell_CNS   [label="CD4/CD8 T Cell\nCNS Infiltration", fillcolor="#FFAB40"]
    Ab_transcyt  [label="IgG Transcytosis\n(→ CSF / Parenchyma)", fillcolor="#B2EBF2"]
    P_gp        [label="P-glycoprotein\n(Drug Efflux at BBB)", fillcolor="#B2EBF2"]
  }

  // ============================================================
  // CLUSTER 5: CNS NEUROINFLAMMATION
  // ============================================================
  subgraph cluster_neuro {
    label="⑤ CNS Neuroinflammation (Microglia / Astrocytes)"
    style=filled; fillcolor="#F3E5F5"; color="#4A148C"; fontcolor="#4A148C"; fontsize=10

    MG_rest     [label="Resting Microglia\n(M0 Homeostatic)", fillcolor="#CE93D8"]
    MG_M1       [label="M1 Microglia\n(Pro-inflammatory, CD68+)", fillcolor="#AB47BC"]
    MG_M2       [label="M2 Microglia\n(Anti-inflammatory, CD206+)", fillcolor="#7B1FA2", fontcolor=white]
    AST_react   [label="Reactive Astrocyte\n(GFAP↑, Vimentin↑)", fillcolor="#CE93D8"]
    AST_A1      [label="A1 Neurotoxic\n(C3+ IL-6+ LCN2+)", fillcolor="#AB47BC"]
    AST_A2      [label="A2 Neuroprotective\n(S100β+ GDNF+)", fillcolor="#9C27B0", fontcolor=white]
    TNFa_CNS    [label="TNF-α (CNS)\n↑ MG/AST", fillcolor="#EF5350"]
    IL6_CNS     [label="IL-6 (CNS)\n↑ BBB Permeability", fillcolor="#EF5350"]
    IL1b_CNS    [label="IL-1β (CNS)\n(NLRP3 Inflammasome)", fillcolor="#EF5350"]
    IFNg_CNS    [label="IFN-γ (CNS)\n(MHC-I ↑)", fillcolor="#EF5350"]
    ROS_CNS     [label="ROS / Nitric Oxide\n(Oxidative Stress)", fillcolor="#EF9A9A"]
    iNOS_CNS    [label="iNOS → NO\n(Neuronal Damage)", fillcolor="#EF9A9A"]
    C1q_syn     [label="C1q Tagging\n(Synaptic Pruning ↑)", fillcolor="#CE93D8"]
    Phago_strip [label="Synaptic Stripping\n(Microglia-mediated)", fillcolor="#AB47BC"]
    NLRP3       [label="NLRP3\nInflammasome", fillcolor="#CE93D8"]
    CSF1R       [label="CSF1R\n(Microglia Survival)", fillcolor="#E1BEE7"]
  }

  // ============================================================
  // CLUSTER 6: SYNAPTIC NMDA-R PATHOPHYSIOLOGY
  // ============================================================
  subgraph cluster_NMDAR {
    label="⑥ Synaptic NMDA-R Pathophysiology"
    style=filled; fillcolor="#E8F5E9"; color="#1B5E20"; fontcolor="#1B5E20"; fontsize=10

    NMDAR_surf  [label="Surface NMDA-R\n(% of Normal Density)", fillcolor="#81C784"]
    NMDAR_NR1   [label="NR1 Subunit (GluN1)\n(Obligatory, Glycine site)", fillcolor="#66BB6A"]
    NMDAR_NR2B  [label="NR2B Subunit (GluN2B)\n(Glutamate binding)", fillcolor="#66BB6A"]
    NMDAR_NR2A  [label="NR2A Subunit (GluN2A)\n(Synaptic plasticity)", fillcolor="#A5D6A7"]
    EphB2       [label="EphB2 Receptor\n(NMDAR Clustering)", fillcolor="#A5D6A7"]
    PSD95       [label="PSD-95\n(Postsynaptic Scaffold)", fillcolor="#A5D6A7"]
    CaMKII      [label="CaMKII\n(Ca²⁺/CaM Kinase II)", fillcolor="#66BB6A"]
    Ab_NR1_bind [label="IgG–NR1 Binding\n(Epitope: aa346-375)", fillcolor="#EF9A9A"]
    NMDAR_cross [label="NMDAR Crosslinking\n(Bivalent IgG → Raft)", fillcolor="#EF5350"]
    Clathrin_e  [label="Clathrin-Mediated\nEndocytosis (↑Rate)", fillcolor="#EF9A9A"]
    NMDAR_int   [label="Internalized NMDAR\n(Endosome Pool)", fillcolor="#EF5350"]
    Ub_proteasome [label="Ubiquitin-Proteasome\nDegradation", fillcolor="#EF9A9A"]
    nNOS_NMDAR  [label="nNOS Uncoupling\n(↓ Neuronal NO)", fillcolor="#A5D6A7"]
    AMPAR_surf  [label="AMPAR Surface\n(Secondary ↓)", fillcolor="#A5D6A7"]
    mGluR5      [label="mGluR5 (Group I)\n(Synergistic)", fillcolor="#C8E6C9"]
    Calcineurin [label="Calcineurin\nAMPAR Regulation", fillcolor="#C8E6C9"]
    Synapsin_I  [label="Synapsin-I\n(Vesicle Release)", fillcolor="#C8E6C9"]
    Ca_influx   [label="Ca²⁺ Influx\n(Via NMDAR)", fillcolor="#66BB6A"]
  }

  // ============================================================
  // CLUSTER 7: E/I IMBALANCE
  // ============================================================
  subgraph cluster_EI {
    label="⑦ E/I Imbalance & Neurotransmitter Dynamics"
    style=filled; fillcolor="#FFFDE7"; color="#F57F17"; fontcolor="#F57F17"; fontsize=10

    Glu_syn     [label="Synaptic Glutamate\n(↑ in AIE, mM)", fillcolor="#FFF176"]
    Glu_extra   [label="Extrasynaptic\nGlutamate (↑↑ Toxic)", fillcolor="#FFEE58"]
    GABA_tone   [label="GABAergic Tone\n(↓ Inhibition)", fillcolor="#A5D6A7"]
    GABA_A_R    [label="GABA-A Receptor\n(Cl⁻ Channel)", fillcolor="#81C784"]
    GABA_B_R    [label="GABA-B Receptor\n(K⁺ Channel)", fillcolor="#81C784"]
    PV_intern   [label="PV+ Interneuron\n(NMDAR-Dependent, ↓)", fillcolor="#FFD54F"]
    SST_intern  [label="SST+ Interneuron\n(Somatostatin+)", fillcolor="#FFD54F"]
    DA_meso     [label="Dopamine\n(Mesolimbic ↑↑)", fillcolor="#FFAB40"]
    D2R         [label="D2 Receptor\n(Hyperactivated)", fillcolor="#FFA726"]
    D1R         [label="D1 Receptor (PFC)\n(Hypoactivated)", fillcolor="#FFA726"]
    Serotonin   [label="5-HT Serotonin\n(Dysregulated)", fillcolor="#FFCC02"]
    EI_balance  [label="E/I Balance Index\n(E ↑↑, I ↓)", fillcolor="#FF8F00"]
    Dserine     [label="D-Serine\n(NMDAR Co-agonist)", fillcolor="#FFF9C4"]
    Glycine_co  [label="Glycine Co-agonist\n(GlyT1 transport)", fillcolor="#FFF9C4"]
    KynAcid     [label="Kynurenic Acid\n(Endogenous NMDAR Blocker)", fillcolor="#FFE082"]
    ACh         [label="Acetylcholine\n(↓ Hippocampal)", fillcolor="#FFE082"]
    Neurosteroid [label="Neurosteroid\n(Allopregnanolone)", fillcolor="#FFFDE7"]
  }

  // ============================================================
  // CLUSTER 8: NEURAL CIRCUITS & CLINICAL MANIFESTATIONS
  // ============================================================
  subgraph cluster_clinical {
    label="⑧ Neural Circuits & Clinical Manifestations"
    style=filled; fillcolor="#FBE9E7"; color="#BF360C"; fontcolor="#BF360C"; fontsize=10

    Hippocampus [label="Hippocampus\n(CA1/CA3, NMDAR↓ → Atrophy)", fillcolor="#FFAB40"]
    LTP         [label="Long-Term Potentiation\n(↓↓ in AIE)", fillcolor="#FF8A65"]
    LTD         [label="Long-Term Depression\n(Abnormal)", fillcolor="#FF8A65"]
    PFC         [label="Prefrontal Cortex\n(Working Memory ↓)", fillcolor="#FFAB40"]
    Amygdala    [label="Amygdala\n(Emotion/Fear Dysreg.)", fillcolor="#FFAB40"]
    Thalamus    [label="Thalamus\n(Sleep Gating ↑↑)", fillcolor="#FFAB40"]
    BG_Str      [label="Basal Ganglia/Striatum\n(Movement Disorder)", fillcolor="#FFAB40"]

    Seizures    [label="Seizures / Status\nEpilepticus (74%)", fillcolor="#C62828", fontcolor=white, shape=hexagon]
    Psychosis   [label="Psychosis /\nHallucinations (77%)", fillcolor="#C62828", fontcolor=white, shape=hexagon]
    Cognitive   [label="Cognitive Impairment\n(Memory, MoCA↓)", fillcolor="#D32F2F", fontcolor=white, shape=hexagon]
    Movement    [label="Movement Disorder\n(Orofacial Dyskinesia)", fillcolor="#D32F2F", fontcolor=white, shape=hexagon]
    Autonomic   [label="Autonomic Dysfunction\n(HR↑/↓, HTN, Hyperthermia)", fillcolor="#D32F2F", fontcolor=white, shape=hexagon]
    LOC         [label="Decreased\nConsciousness (54%)", fillcolor="#D32F2F", fontcolor=white, shape=hexagon]
    Memory_def  [label="Memory Deficit\n(Anterograde)", fillcolor="#EF9A9A", shape=hexagon]
    Sleep_dis   [label="Sleep Disorder\n(Hypersomnia, REM↑)", fillcolor="#EF9A9A", shape=hexagon]
    Lang_def    [label="Language Deficit\n(Aphasia, Mutism)", fillcolor="#EF9A9A", shape=hexagon]
    mRS         [label="mRS Score\n(0-6 scale)", fillcolor="#B71C1C", fontcolor=white, shape=ellipse]
  }

  // ============================================================
  // CLUSTER 9: DRUG PK — FIRST LINE
  // ============================================================
  subgraph cluster_PK1 {
    label="⑨ Drug PK: First-Line Immunotherapy"
    style=filled; fillcolor="#E8F5E9"; color="#1B5E20"; fontcolor="#1B5E20"; fontsize=10

    IVIG_dose   [label="IVIG\n2 g/kg over 5 d", shape=component, fillcolor="#A5D6A7"]
    IVIG_C1     [label="IVIG Central (Vc 3.7 L)\nCL 0.24 L/d", fillcolor="#81C784"]
    IVIG_C2     [label="IVIG Peripheral\n(Vp 25 L)", fillcolor="#C8E6C9"]
    FcRn_IVIG   [label="FcRn Saturation\nAccelerated IgG Clearance", fillcolor="#A5D6A7"]

    MP_dose     [label="IV Methylprednisolone\n1 g/d × 3-5 d", shape=component, fillcolor="#A5D6A7"]
    MP_C1       [label="MP Central\n(Vc ≈ 0.55 L/kg, t½ 2-3h)", fillcolor="#81C784"]
    MP_C2       [label="MP Peripheral\n(Vp ≈ 1.0 L/kg)", fillcolor="#C8E6C9"]
    GR_bind     [label="GR Binding\n(Kd ≈ 5 nM)", fillcolor="#C8E6C9"]

    PE_proc     [label="Plasmapheresis\n5 exchanges ×3-5 L", shape=component, fillcolor="#A5D6A7"]
    PE_Ab_rem   [label="PE: IgG Removal\n~60-80% per cycle", fillcolor="#81C784"]

    Pred_oral   [label="Oral Prednisolone\n(Maintenance 0.5-1 mg/kg/d)", shape=component, fillcolor="#C8E6C9"]
  }

  // ============================================================
  // CLUSTER 10: DRUG PK — SECOND LINE
  // ============================================================
  subgraph cluster_PK2 {
    label="⑩ Drug PK: Second-Line Immunotherapy"
    style=filled; fillcolor="#EDE7F6"; color="#4527A0"; fontcolor="#4527A0"; fontsize=10

    RTX_dose    [label="Rituximab\n375 mg/m² ×4 wkly OR\n1000 mg ×2 (2 wk apart)", shape=component, fillcolor="#CE93D8"]
    RTX_C1      [label="RTX Central\n(Vc 3.4 L, t½ 21 d)", fillcolor="#BA68C8"]
    RTX_C2      [label="RTX Peripheral\n(Vp 4.4 L)", fillcolor="#9575CD"]
    RTX_CSF_c   [label="RTX in CSF\n(< 0.1% serum)", fillcolor="#9575CD"]

    CPX_dose    [label="Cyclophosphamide\n500-750 mg/m² q4wk", shape=component, fillcolor="#CE93D8"]
    CPX_prod    [label="Cyclophosphamide\n(Prodrug, CYP2B6)", fillcolor="#BA68C8"]
    CPX_active  [label="4-OH-Cyclophosphamide\n(Active Alkylating)", fillcolor="#7E57C2", fontcolor=white]
    CPX_acrolein [label="Acrolein\n(Bladder Toxicity)", fillcolor="#EF9A9A"]

    TCZ_dose    [label="Tocilizumab\n8 mg/kg q4wk IV", shape=component, fillcolor="#CE93D8"]
    TCZ_C1      [label="TCZ Central\n(Vc 3.5 L, t½ 11-13 d)", fillcolor="#BA68C8"]
    TCZ_C2      [label="TCZ Peripheral\n(Vp 2.9 L)", fillcolor="#9575CD"]

    AZA_dose    [label="Azathioprine\n2-3 mg/kg/d", shape=component, fillcolor="#EDE7F6"]
    MMF_dose    [label="Mycophenolate Mofetil\n1.5 g BID", shape=component, fillcolor="#EDE7F6"]
    MMF_MPA     [label="MPA (Active Metabolite)\nIMPDH Inhibition", fillcolor="#B39DDB"]
    Bort_dose   [label="Bortezomib\n(Refractory LLPC Depletion)", shape=component, fillcolor="#D1C4E9"]
  }

  // ============================================================
  // CLUSTER 11: DRUG PD MECHANISMS
  // ============================================================
  subgraph cluster_PD {
    label="⑪ Drug PD: Mechanisms of Action"
    style=filled; fillcolor="#FFF8E1"; color="#F57F17"; fontcolor="#F57F17"; fontsize=10

    RTX_CD20    [label="RTX → CD20 Binding\n(ADCC + CDC)", fillcolor="#FFE082"]
    CD20_dep    [label="B Cell Depletion\n(>99% CD20+ cells)", fillcolor="#FF8F00"]
    IVIG_FcRn_s [label="IVIG FcRn Saturation\n(Peripheral)", fillcolor="#FFE082"]
    IVIG_accel  [label="Accelerated Endogenous\nIgG Catabolism", fillcolor="#FFC107"]
    IVIG_Fc_inh [label="FcγR Inhibition\n(↓ ADCC, ↑ ITIM)", fillcolor="#FFE082"]
    IVIG_Treg   [label="IVIG → Treg ↑\n(IL-10, TGF-β)", fillcolor="#A5D6A7"]
    GR_trans_r  [label="GR Transrepression\n(↓ NF-κB, ↓ AP-1)", fillcolor="#FFE082"]
    GR_trans_a  [label="GR Transactivation\n(↑ IκBα, ↑ GILZ)", fillcolor="#C8E6C9"]
    TCZ_IL6R    [label="TCZ → IL-6R Blockade\n(sIL-6R + mIL-6R)", fillcolor="#FFE082"]
    IL6_sig_blk [label="IL-6 / JAK/STAT3\nSignaling Blocked", fillcolor="#FFC107"]
    CPX_DNA_alk [label="4-OH-CPX → DNA\nAlkylation (Cross-link)", fillcolor="#EF9A9A"]
    AZA_6TG     [label="AZA → 6-TG\n(IMPDH ↓ Purine Synth)", fillcolor="#FFCC02"]
    MMF_IMPDH   [label="MMF → MPA\n(IMPDH Inhibition)", fillcolor="#FFCC02"]
    PE_mech     [label="PE → Direct\nIgG/Cytokine Removal", fillcolor="#FFE082"]
    Bort_UPR    [label="Bortezomib →\nUPR → LLPC Apoptosis", fillcolor="#FFB74D"]
    Nat_RTX     [label="Natalizumab\n(α4-integrin, CNS T cell ↓)", fillcolor="#EDE7F6"]
  }

  // ============================================================
  // CLUSTER 12: BIOMARKERS & DIAGNOSTICS
  // ============================================================
  subgraph cluster_BM {
    label="⑫ Biomarkers & Diagnostics"
    style=filled; fillcolor="#ECEFF1"; color="#263238"; fontcolor="#263238"; fontsize=10

    CSF_pleo    [label="CSF Pleocytosis\n(>5 WBC/μL, 80%)", fillcolor="#B0BEC5"]
    CSF_IgG_idx [label="CSF IgG Index\n(>0.7 = Intrathecal Synth)", fillcolor="#90A4AE"]
    NMDAR_titer [label="NMDAR Ab Titer\n(CSF > Serum, crucial)", fillcolor="#78909C"]
    EEG_delta   [label="EEG Delta Brush\n(Pathognomonic, 30%)", fillcolor="#B0BEC5"]
    EEG_PLED    [label="EEG PLEDs /\nSeizure Pattern", fillcolor="#B0BEC5"]
    MRI_FLAIR   [label="MRI FLAIR\nHyperintensity (35%)", fillcolor="#B0BEC5"]
    FDG_PET     [label="FDG-PET\nHyper/Hypometabolism", fillcolor="#B0BEC5"]
    NFL_CSF     [label="CSF NfL\n(Neuroaxonal Damage Marker)", fillcolor="#90A4AE"]
    GFAP_CSF    [label="CSF GFAP\n(Astrocyte Damage)", fillcolor="#90A4AE"]
    IL6_CSF_bm  [label="CSF IL-6\n(↑ Active Disease)", fillcolor="#90A4AE"]
    CXCL13_CSF  [label="CSF CXCL13\n(GC Reaction Marker)", fillcolor="#90A4AE"]
    Overlap_Ab  [label="CASPR2 / LGI1 /\nAMPAR Ab (Overlap)", fillcolor="#B0BEC5"]
    mRS_out     [label="mRS Outcome\n(0=Normal, 6=Dead)", fillcolor="#78909C"]
    MMSE_out    [label="MMSE / MoCA\n(Cognitive Outcome)", fillcolor="#78909C"]
    TMA_biopsy  [label="Tumor Workup\n(CT/MRI/PET, Teratoma)", fillcolor="#CFD8DC"]
  }

  // ============================================================
  // EDGES — TRIGGER → IMMUNE
  // ============================================================
  OvTer -> NMDAR_Ag [label="releases Ag"]
  HerpesVirus -> HSV_Enc [label="infection"]
  HSV_Enc -> NMDAR_Ag [label="mimicry"]
  UnkTrig -> NMDAR_Ag [style=dashed]
  NMDAR_Ag -> APC [label="uptake"]
  APC -> MHC_II [label="presents"]
  MHC_II -> CD4_Tfh [label="activates"]
  MHC_II -> CD4_Th17 [label="activates"]
  ICOS_CD28 -> CD4_Tfh [label="co-stim"]
  CD4_Tfh -> CXCL13_peri [label="secretes"]
  CD4_Tfh -> IL21_peri [label="secretes"]
  CD4_Th17 -> IL17_peri [label="secretes"]
  CD4_Treg -> Treg_supp [label="mediates"]
  Treg_supp -> CD4_Th17 [arrowhead=tee, label="inhibits"]
  Treg_supp -> GCB [arrowhead=tee, label="limits GC"]

  // TRIGGER → B CELL
  IL21_peri -> GCB [label="promotes GC"]
  CXCL13_peri -> GCB [label="recruits"]
  NaiveB -> ActivatedB [label="activation"]
  ActivatedB -> GCB [label="enters GC"]
  BCR_signal -> NaiveB [label="activates"]
  GCB -> DarkZone [label="proliferates"]
  GCB -> LightZone [label="selection"]
  DarkZone -> AID [label="expresses"]
  AID -> SHM [label="catalyzes"]
  SHM -> ClassSwitch [label="→ IgG"]
  LightZone -> Plasmablast [label="differentiation"]
