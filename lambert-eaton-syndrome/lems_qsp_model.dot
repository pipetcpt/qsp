digraph LEMS_QSP {
    graph [
        label="Lambert-Eaton Myasthenic Syndrome (LEMS)\nQuantitative Systems Pharmacology Model"
        labelloc="t"
        fontsize=22
        fontname="Helvetica-Bold"
        bgcolor="#f8f9fa"
        rankdir=TB
        splines=ortho
        nodesep=0.5
        ranksep=0.8
        compound=true
    ]
    node [fontname="Helvetica" fontsize=10 style="filled,rounded" shape=box]
    edge [fontname="Helvetica" fontsize=9 arrowsize=0.8]

    /* =========================================================
       SUBGRAPH 1: SCLC Tumor / Paraneoplastic Trigger
       ========================================================= */
    subgraph cluster_tumor {
        label="Small Cell Lung Cancer (SCLC) — Paraneoplastic Trigger"
        style=filled
        fillcolor="#fff3e0"
        color="#e65100"
        fontcolor="#e65100"
        fontsize=13

        SCLC_Tumor         [label="SCLC Tumor\n(Primary)" fillcolor="#ff8f00"]
        Tumor_Growth       [label="Tumor Growth\n(Exponential/Logistic)" fillcolor="#ffa726"]
        SCLC_VGCC_Ptype    [label="VGCC P/Q-type\nExpressed by SCLC" fillcolor="#ffb74d"]
        Tumor_Ag_Release   [label="Tumor Antigen\nRelease" fillcolor="#ffcc80"]
        Cross_Reactive_Ep  [label="Cross-reactive\nEpitopes\n(VGCC α1A)" fillcolor="#ffe0b2"]
        Tumor_Burden       [label="Tumor Burden\n(CT Response)" fillcolor="#ffca28"]
        Micro_Mets         [label="Micrometastases\n(Occult)" fillcolor="#ffd54f"]
        Paraneoplastic_IgG [label="Paraneoplastic\nAnti-VGCC IgG" fillcolor="#ffe082"]
    }

    /* =========================================================
       SUBGRAPH 2: Oncology Treatment
       ========================================================= */
    subgraph cluster_onco_tx {
        label="Oncology Treatment"
        style=filled
        fillcolor="#fce4ec"
        color="#880e4f"
        fontcolor="#880e4f"
        fontsize=13

        Chemotherapy       [label="Chemotherapy\n(Platinum-Etoposide)" fillcolor="#f48fb1"]
        Immunooncology     [label="Anti-PD1/PD-L1\nImmunotherapy" fillcolor="#f06292"]
        Radiotherapy       [label="Radiotherapy\n(Thoracic RT)" fillcolor="#e91e63"]
        Tumor_Response     [label="Tumor Response\n(Objective Response)" fillcolor="#ad1457"]
        Immune_Activation_IO [label="Immune Activation\nby IO Therapy" fillcolor="#f8bbd9"]
    }

    /* =========================================================
       SUBGRAPH 3: Immune System — Autoantibody Production
       ========================================================= */
    subgraph cluster_immune {
        label="Immune System & Autoantibody Production"
        style=filled
        fillcolor="#e8f5e9"
        color="#1b5e20"
        fontcolor="#1b5e20"
        fontsize=13

        Molecular_Mimicry  [label="Molecular Mimicry\n(Tumor vs NMJ VGCC)" fillcolor="#a5d6a7"]
        DC_Activation      [label="Dendritic Cell\nActivation & Maturation" fillcolor="#81c784"]
        MHC_II_Present     [label="MHC-II Antigen\nPresentation" fillcolor="#66bb6a"]
        CD4_Th2            [label="CD4+ Th2 Cells\n(IL-4, IL-13)" fillcolor="#4caf50"]
        Tfh_Cells          [label="T Follicular Helper\nCells (CXCR5+)" fillcolor="#43a047"]
        Germinal_Center    [label="Germinal Center\nReaction" fillcolor="#388e3c"]
        B_Cell_Activation  [label="B Cell Activation\n(Anti-VGCC specific)" fillcolor="#2e7d32"]
        Plasma_Cells       [label="Long-lived\nPlasma Cells" fillcolor="#1b5e20" fontcolor="white"]
        Memory_B_cells     [label="Memory B Cells" fillcolor="#4caf50"]
        IL4                [label="IL-4" fillcolor="#c8e6c9" shape=ellipse]
        IL10               [label="IL-10" fillcolor="#c8e6c9" shape=ellipse]
        IL21               [label="IL-21" fillcolor="#c8e6c9" shape=ellipse]
        BAFF               [label="BAFF / APRIL\n(B-cell survival)" fillcolor="#dcedc8" shape=ellipse]
        Treg_cells         [label="Regulatory T Cells\n(FoxP3+)" fillcolor="#b9f6ca"]
        HLA_B8_DR3         [label="HLA-B8/DR3\n(Genetic Risk)" fillcolor="#e8f5e9" shape=diamond]
    }

    /* =========================================================
       SUBGRAPH 4: VGCC Autoantibody Dynamics
       ========================================================= */
    subgraph cluster_antibody {
        label="VGCC Autoantibody — Dynamics & Clearance"
        style=filled
        fillcolor="#e3f2fd"
        color="#0d47a1"
        fontcolor="#0d47a1"
        fontsize=13

        Ab_VGCC_total      [label="Anti-VGCC IgG\n(Total Serum Level)" fillcolor="#90caf9"]
        Ab_P_type          [label="Anti-P/Q VGCC\nIgG" fillcolor="#64b5f6"]
        Ab_N_type          [label="Anti-N-type VGCC\nIgG" fillcolor="#42a5f5"]
        Complement_Activ   [label="Complement\nActivation (C1q)" fillcolor="#2196f3"]
        MAC_formation      [label="Membrane Attack\nComplex (MAC)" fillcolor="#1e88e5"]
        FcRn_Recycling     [label="FcRn-mediated\nIgG Recycling" fillcolor="#1976d2"]
        Ab_Clearance       [label="Antibody\nCatabolism/Clearance" fillcolor="#1565c0"]
        IgG_halflife       [label="IgG Half-life\n~21 days" fillcolor="#e3f2fd" shape=note]
    }

    /* =========================================================
       SUBGRAPH 5: Presynaptic Terminal
       ========================================================= */
    subgraph cluster_presynaptic {
        label="Presynaptic Motor Nerve Terminal"
        style=filled
        fillcolor="#ede7f6"
        color="#4a148c"
        fontcolor="#4a148c"
        fontsize=13

        Nerve_AP           [label="Motor Nerve\nAction Potential" fillcolor="#ce93d8"]
        VGCC_free          [label="Functional VGCC\n(P/Q-type, free)" fillcolor="#ba68c8"]
        VGCC_blocked       [label="Ab-blocked VGCC\n(Dysfunctional)" fillcolor="#ab47bc"]
        Ca_influx          [label="Ca2+ Influx\n(Presynaptic)" fillcolor="#9c27b0"]
        Ca_pre             [label="[Ca2+]pre\n(Local concentration)" fillcolor="#8e24aa" fontcolor="white"]
        Calmodulin_Ca      [label="Ca2+-Calmodulin\nComplex" fillcolor="#7b1fa2" fontcolor="white"]
        PKC_activation     [label="PKC Activation" fillcolor="#6a1b9a" fontcolor="white"]
        SNAP25             [label="SNAP-25\n(SNARE protein)" fillcolor="#c3a0d4"]
        Synaptobrevin      [label="Synaptobrevin/\nVAMP2" fillcolor="#c3a0d4"]
        Syntaxin           [label="Syntaxin-1A" fillcolor="#c3a0d4"]
        SNARE_complex      [label="SNARE Complex\nAssembly" fillcolor="#7e57c2"]
        RRP_vesicles       [label="Ready-Release Pool\n(RRP) Vesicles" fillcolor="#9575cd"]
        Reserve_pool       [label="Reserve Vesicle\nPool" fillcolor="#b39ddb"]
        Recycling_pool     [label="Recycling\nVesicle Pool" fillcolor="#d1c4e9"]
        ACh_vesicle_fusion [label="ACh Vesicle\nFusion (Exocytosis)" fillcolor="#7c4dff" fontcolor="white"]
        ACh_release        [label="ACh Released into\nSynaptic Cleft" fillcolor="#651fff" fontcolor="white"]
        ACh_synthesis      [label="ACh Synthesis\n(ChAT)" fillcolor="#c5cae9"]
        ChAT               [label="Choline\nAcetyltransferase" fillcolor="#e8eaf6" shape=ellipse]
        Facilitation       [label="Post-activation\nFacilitation" fillcolor="#d1c4e9"]
    }

    /* =========================================================
       SUBGRAPH 6: Neuromuscular Junction & Postsynaptic
       ========================================================= */
    subgraph cluster_postsynaptic {
        label="Neuromuscular Junction & Postsynaptic Muscle Cell"
        style=filled
        fillcolor="#fff8e1"
        color="#f57f17"
        fontcolor="#f57f17"
        fontsize=13

        Synaptic_cleft     [label="Synaptic Cleft\n(ACh diffusion)" fillcolor="#fff9c4"]
        AChE               [label="AChE\n(Acetylcholinesterase)" fillcolor="#fff176" shape=ellipse]
        nAChR              [label="nAChR\n(Post-synaptic)" fillcolor="#ffee58"]
        nAChR_binding      [label="ACh-nAChR\nBinding" fillcolor="#fdd835"]
        EPSP               [label="Endplate Potential\n(EPP amplitude)" fillcolor="#fbc02d"]
        Safety_factor      [label="Safety Factor\n(EPP/AP threshold)" fillcolor="#f9a825"]
        Muscle_AP          [label="Muscle Action\nPotential" fillcolor="#f57f17"]
        ECC                [label="Excitation-\nContraction Coupling" fillcolor="#ef6c00"]
        RyR                [label="Ryanodine\nReceptor (RyR2)" fillcolor="#e65100"]
        Ca_SR              [label="SR Ca2+ Release" fillcolor="#bf360c"]
        Actin_Myosin       [label="Actin-Myosin\nCross-bridge Cycling" fillcolor="#dd2c00" fontcolor="white"]
        Muscle_Force       [label="Muscle Force\n(Contraction)" fillcolor="#b71c1c" fontcolor="white"]
        CMAP_amplitude     [label="CMAP Amplitude\n(mV)" fillcolor="#ffb300"]
    }

    /* =========================================================
       SUBGRAPH 7: Autonomic Nervous System
       ========================================================= */
    subgraph cluster_autonomic {
        label="Autonomic Nervous System Dysfunction"
        style=filled
        fillcolor="#e0f7fa"
        color="#006064"
        fontcolor="#006064"
        fontsize=13

        Autonomic_VGCC     [label="Autonomic Nerve\nVGCC (P/Q-type)" fillcolor="#80deea"]
        ACh_autonomic      [label="ACh Release\n(Autonomic terminals)" fillcolor="#4dd0e1"]
        Sympathetic_ganglia [label="Sympathetic\nGanglia VGCC" fillcolor="#26c6da"]
        Parasympathetic_g  [label="Parasympathetic\nGanglia VGCC" fillcolor="#00bcd4"]
        Autonomic_dysf     [label="Autonomic\nDysfunction" fillcolor="#0097a7"]
        Dry_mouth          [label="Xerostomia\n(Dry Mouth)" fillcolor="#b2ebf2"]
        Constipation       [label="Constipation" fillcolor="#b2ebf2"]
        Erectile_dysf      [label="Erectile\nDysfunction" fillcolor="#b2ebf2"]
        Orthostatic_hypo   [label="Orthostatic\nHypotension" fillcolor="#b2ebf2"]
        Anhidrosis         [label="Anhidrosis\n(Reduced sweating)" fillcolor="#b2ebf2"]
        Bladder_dysf       [label="Bladder\nDysfunction" fillcolor="#b2ebf2"]
        Pupil_reflex       [label="Impaired Pupil\nLight Reflex" fillcolor="#e0f7fa"]
    }

    /* =========================================================
       SUBGRAPH 8: Drug PK — Amifampridine (3,4-DAP)
       ========================================================= */
    subgraph cluster_amifampridine_pk {
        label="Amifampridine (3,4-DAP) Pharmacokinetics"
        style=filled
        fillcolor="#f3e5f5"
        color="#4a148c"
        fontcolor="#4a148c"
        fontsize=13

        Amif_dose          [label="Amifampridine\nOral Dose\n(5-25 mg TID-QID)" fillcolor="#e1bee7"]
        Amif_gut           [label="GI Tract\n(Absorption Compartment)" fillcolor="#ce93d8"]
        Amif_central       [label="Central Compartment\n(Blood/Plasma)" fillcolor="#ba68c8"]
        Amif_peripheral    [label="Peripheral Compartment\n(Tissue Distribution)" fillcolor="#ab47bc"]
        Amif_NAcetyl       [label="N-Acetylamifampridine\n(Metabolite)" fillcolor="#9c27b0" fontcolor="white"]
        Amif_renal_cl      [label="Renal Excretion\n(~15% unchanged)" fillcolor="#7b1fa2" fontcolor="white"]
        Amif_hepatic_cl    [label="Hepatic Metabolism\n(N-acetyltransferase)" fillcolor="#6a1b9a" fontcolor="white"]
        Amif_halflife      [label="t1/2 ~ 2.5 h\n(rapid clearance)" fillcolor="#f3e5f5" shape=note]
        Amif_Tmax          [label="Tmax ~ 1 h\n(rapid absorption)" fillcolor="#f3e5f5" shape=note]
    }

    /* =========================================================
       SUBGRAPH 9: Drug PK — Prednisolone / Immunosuppressants
       ========================================================= */
    subgraph cluster_immuno_pk {
        label="Immunosuppressant Pharmacokinetics"
        style=filled
        fillcolor="#fbe9e7"
        color="#bf360c"
        fontcolor="#bf360c"
        fontsize=13

        Pred_dose          [label="Prednisolone\nOral Dose" fillcolor="#ffccbc"]
        Pred_absorption    [label="GI Absorption\n(Prednisolone)" fillcolor="#ffab91"]
        Pred_central       [label="Prednisolone\nPlasma" fillcolor="#ff8a65"]
        Pred_tissue        [label="Prednisolone\nTissue Distribution" fillcolor="#ff7043"]
        Pred_clearance     [label="Hepatic Clearance\n(Prednisolone)" fillcolor="#f4511e"]
        AZA_dose           [label="Azathioprine\nOral Dose" fillcolor="#ffccbc"]
        AZA_6MP            [label="6-Mercaptopurine\n(Active metabolite)" fillcolor="#ffab91"]
        MMF_dose           [label="Mycophenolate\nMofetil Dose" fillcolor="#ffccbc"]
        MPA_active         [label="MPA\n(Mycophenolic acid)" fillcolor="#ff8a65"]
        IVIG_infusion      [label="IVIG Infusion\n(2 g/kg)" fillcolor="#ffccbc"]
        PE_procedure       [label="Plasma Exchange\n(PE)" fillcolor="#ffab91"]
    }

    /* =========================================================
       SUBGRAPH 10: Drug PD — Amifampridine Mechanism
       ========================================================= */
    subgraph cluster_amifampridine_pd {
        label="Amifampridine Pharmacodynamics"
        style=filled
        fillcolor="#e8eaf6"
        color="#283593"
        fontcolor="#283593"
        fontsize=13

        K_channel_block    [label="Voltage-gated K+\nChannel Blockade" fillcolor="#9fa8da"]
        Prolonged_AP       [label="Prolonged Nerve\nAction Potential" fillcolor="#7986cb"]
        Enhanced_Ca_influx [label="Enhanced Ca2+\nInflux (VGCC)" fillcolor="#5c6bc0"]
        Increased_ACh      [label="Increased ACh\nRelease (Drug PD)" fillcolor="#3949ab"]
        PD_CMAP_increase   [label="CMAP Amplitude\nIncrease" fillcolor="#303f9f" fontcolor="white"]
    }

    /* =========================================================
       SUBGRAPH 11: Drug PD — Immunosuppression
       ========================================================= */
    subgraph cluster_immuno_pd {
        label="Immunosuppressant Pharmacodynamics"
        style=filled
        fillcolor="#efebe9"
        color="#3e2723"
        fontcolor="#3e2723"
        fontsize=13

        GR_activation      [label="Glucocorticoid\nReceptor (GR)\nActivation" fillcolor="#bcaaa4"]
        GR_nuclear         [label="GR Nuclear\nTranslocation" fillcolor="#a1887f"]
        NF_kB_inhib        [label="NF-κB\nInhibition" fillcolor="#8d6e63"]
        AP1_inhib          [label="AP-1\nInhibition" fillcolor="#795548"]
        Bcell_suppression  [label="B Cell\nSuppression" fillcolor="#6d4c41" fontcolor="white"]
        Ab_prod_inhib      [label="Antibody Production\nInhibition" fillcolor="#5d4037" fontcolor="white"]
        Tcell_suppression  [label="T Cell\nSuppression" fillcolor="#4e342e" fontcolor="white"]
        IVIG_Ab_neutraliz  [label="IVIG Ab\nNeutralization/\nAnti-idiotype" fillcolor="#bcaaa4"]
        PE_Ab_removal      [label="PE: Rapid Ab\nRemoval" fillcolor="#a1887f"]
    }

    /* =========================================================
       SUBGRAPH 12: Clinical Endpoints & Biomarkers
       ========================================================= */
    subgraph cluster_endpoints {
        label="Clinical Endpoints & Biomarkers"
        style=filled
        fillcolor="#e8f5e9"
        color="#1b5e20"
        fontcolor="#1b5e20"
        fontsize=13

        CMAP_resting       [label="Resting CMAP\nAmplitude (mV)" fillcolor="#a5d6a7"]
        CMAP_post_exercise [label="Post-exercise CMAP\n(Facilitation)" fillcolor="#81c784"]
        Facilitation_ratio [label="Facilitation Ratio\n(Post/Pre exercise)" fillcolor="#66bb6a"]
        RNS_increment      [label="Repetitive Nerve\nStimulation Increment\n(>60% at 20-50 Hz)" fillcolor="#4caf50"]
        QMG_score          [label="QMG Score\n(Quantitative MG)" fillcolor="#43a047"]
        LEMS_score         [label="LEMS Diagnostic\nScore (0-10)" fillcolor="#388e3c"]
        MRC_sum            [label="MRC Sum Score\n(Muscle Strength)" fillcolor="#2e7d32"]
        Proximal_weakness  [label="Proximal\nLimb Weakness\n(Legs>Arms)" fillcolor="#1b5e20" fontcolor="white"]
        DTR_areflexia      [label="DTR Areflexia/\nHyporeflexia" fillcolor="#c8e6c9"]
        DTR_facilitation   [label="Lambert's Sign\n(DTR after contraction)" fillcolor="#a5d6a7"]
        Ptosis             [label="Ptosis\n(Mild, <MG)" fillcolor="#c8e6c9"]
        Diplopia           [label="Diplopia\n(Rare)" fillcolor="#dcedc8"]
        Autonomic_scale    [label="Composite\nAutonomic Score" fillcolor="#b9f6ca"]
        SF36_score         [label="SF-36 QoL\nScore" fillcolor="#ccff90"]
        Tumor_response_RECIST [label="Tumor Response\n(RECIST)" fillcolor="#b2ff59"]
    }

    /* =========================================================
       EDGES — Disease Mechanism
       ========================================================= */
    /* Tumor triggers paraneoplastic response */
    SCLC_Tumor -> Tumor_Growth [label="proliferates"]
    SCLC_Tumor -> SCLC_VGCC_Ptype [label="expresses"]
    SCLC_Tumor -> Micro_Mets [label="spreads"]
    SCLC_VGCC_Ptype -> Tumor_Ag_Release [label="sheds antigens"]
    Tumor_Ag_Release -> Cross_Reactive_Ep [label="molecular mimicry"]
    Cross_Reactive_Ep -> Molecular_Mimicry
    Micro_Mets -> Tumor_Burden

    /* Immune activation */
    Molecular_Mimicry -> DC_Activation [label="activates DCs"]
    DC_Activation -> MHC_II_Present
    MHC_II_Present -> CD4_Th2 [label="IL-4"]
    CD4_Th2 -> Tfh_Cells [label="differentiates"]
    Tfh_Cells -> Germinal_Center [label="supports GC"]
    Germinal_Center -> B_Cell_Activation
    B_Cell_Activation -> Plasma_Cells [label="differentiates"]
    B_Cell_Activation -> Memory_B_cells
    Plasma_Cells -> Ab_VGCC_total [label="secretes"]
    IL4 -> B_Cell_Activation [label="promotes"]
    IL21 -> Germinal_Center [label="drives"]
    BAFF -> Plasma_Cells [label="survival"]
    HLA_B8_DR3 -> DC_Activation [label="genetic risk\npredisposes"]
    Treg_cells -> B_Cell_Activation [label="suppresses" color="red" style=dashed]
    Treg_cells -> CD4_Th2 [label="suppresses" color="red" style=dashed]

    /* Antibody dynamics */
    Ab_VGCC_total -> Ab_P_type
    Ab_VGCC_total -> Ab_N_type
    Ab_P_type -> Complement_Activ [label="activates"]
    Complement_Activ -> MAC_formation [label="C5b-9"]
    FcRn_Recycling -> Ab_VGCC_total [label="maintains\nlevel"]
    Ab_Clearance -> Ab_VGCC_total [label="clears" style=dashed arrowhead=tee]
    Paraneoplastic_IgG -> Ab_VGCC_total [label="adds to pool"]

    /* VGCC blocking */
    Ab_P_type -> VGCC_free [label="binds &\ndownregulates" color="#0d47a1" style=bold]
    Ab_P_type -> VGCC_blocked [label="creates blocked\nVGCC" color="red"]

    /* Presynaptic physiology */
    Nerve_AP -> VGCC_free [label="opens VGCC"]
    VGCC_free -> Ca_influx [label="Ca2+ enters"]
    Ca_influx -> Ca_pre [label="increases [Ca2+]"]
    Ca_pre -> Calmodulin_Ca [label="Ca-calmodulin forms"]
    Calmodulin_Ca -> PKC_activation
    Ca_pre -> ACh_vesicle_fusion [label="triggers\nexocytosis"]
    SNAP25 -> SNARE_complex [label="assembles"]
    Synaptobrevin -> SNARE_complex
    Syntaxin -> SNARE_complex
    SNARE_complex -> ACh_vesicle_fusion [label="mediates"]
    RRP_vesicles -> ACh_vesicle_fusion [label="fuses"]
    Reserve_pool -> RRP_vesicles [label="replenishes"]
    Recycling_pool -> RRP_vesicles [label="refills\nafter use"]
    ACh_vesicle_fusion -> ACh_release
    ACh_synthesis -> RRP_vesicles [label="fills vesicles"]
    ChAT -> ACh_synthesis [label="catalyzes"]
    VGCC_blocked -> Ca_influx [label="reduces" color="red" arrowhead=tee]
    Facilitation -> Ca_pre [label="post-tetanic\naugments Ca2+"]
    PKC_activation -> RRP_vesicles [label="mobilizes vesicles"]

    /* NMJ signal */
    ACh_release -> Synaptic_cleft
    Synaptic_cleft -> nAChR_binding [label="ACh binds nAChR"]
    AChE -> Synaptic_cleft [label="hydrolyzes ACh" arrowhead=tee]
    nAChR -> nAChR_binding [label="receptor\navailable"]
    nAChR_binding -> EPSP [label="generates EPP"]
    EPSP -> Safety_factor [label="EPP/threshold ratio"]
    Safety_factor -> Muscle_AP [label="if > 1, generates AP"]
    Muscle_AP -> ECC
    ECC -> RyR [label="activates"]
    RyR -> Ca_SR [label="releases SR Ca2+"]
    Ca_SR -> Actin_Myosin [label="activates\ncross-bridges"]
    Actin_Myosin -> Muscle_Force
    Muscle_Force -> CMAP_amplitude [label="reflected in"]

    /* Autonomic */
    Ab_P_type -> Autonomic_VGCC [label="also blocks"]
    Autonomic_VGCC -> ACh_autonomic [label="reduces release"]
    ACh_autonomic -> Autonomic_dysf
    Sympathetic_ganglia -> Autonomic_dysf
    Parasympathetic_g -> Autonomic_dysf
    Ab_P_type -> Sympathetic_ganglia [label="impairs"]
    Ab_P_type -> Parasympathetic_g [label="impairs"]
    Autonomic_dysf -> Dry_mouth
    Autonomic_dysf -> Constipation
    Autonomic_dysf -> Erectile_dysf
    Autonomic_dysf -> Orthostatic_hypo
    Autonomic_dysf -> Anhidrosis
    Autonomic_dysf -> Bladder_dysf
    Autonomic_dysf -> Pupil_reflex

    /* =========================================================
       EDGES — Treatment Mechanisms
       ========================================================= */
    /* Oncology treatment */
    Chemotherapy -> Tumor_Burden [label="reduces" color="#880e4f" style=bold]
    Chemotherapy -> SCLC_Tumor [label="kills tumor cells" color="#880e4f"]
    Immunooncology -> Immune_Activation_IO [label="activates T cells"]
    Immune_Activation_IO -> SCLC_Tumor [label="anti-tumor\nimmunity" color="#880e4f"]
    Radiotherapy -> Tumor_Burden [label="reduces" color="#880e4f"]
    Tumor_Burden -> Tumor_Ag_Release
    Chemotherapy -> Tumor_Ag_Release [label="releases antigens"]
    Tumor_Response -> Ab_VGCC_total [label="decreases\nantigen source" color="red" style=dashed arrowhead=tee]

    /* Amifampridine PK */
    Amif_dose -> Amif_gut [label="Ka ~ 0.7 h⁻¹"]
    Amif_gut -> Amif_central [label="absorption\n~100% bioavail"]
    Amif_central -> Amif_peripheral [label="distribution"]
    Amif_peripheral -> Amif_central [label="redistribution"]
    Amif_central -> Amif_NAcetyl [label="N-acetylation\n(NAT1/NAT2)"]
    Amif_central -> Amif_renal_cl [label="renal excretion"]
    Amif_NAcetyl -> Amif_hepatic_cl [label="eliminated"]

    /* Amifampridine PD */
    Amif_central -> K_channel_block [label="K+ channel\nblockade"]
    K_channel_block -> Prolonged_AP [label="prolongs\nnerve AP"]
    Prolonged_AP -> Enhanced_Ca_influx [label="more VGCC\nopen time"]
    Enhanced_Ca_influx -> Increased_ACh [label="more ACh\nrelease"]
    Increased_ACh -> PD_CMAP_increase [label="improves NMJ\ntransmission"]
    PD_CMAP_increase -> CMAP_amplitude [label="increases"]

    /* Prednisolone PK/PD */
    Pred_dose -> Pred_absorption [label="Ka"]
    Pred_absorption -> Pred_central
    Pred_central -> Pred_tissue [label="distribution"]
    Pred_tissue -> Pred_central
    Pred_central -> Pred_clearance
    Pred_central -> GR_activation [label="binds GR"]
    GR_activation -> GR_nuclear [label="translocates"]
    GR_nuclear -> NF_kB_inhib
    GR_nuclear -> AP1_inhib
    NF_kB_inhib -> Bcell_suppression
    NF_kB_inhib -> Tcell_suppression
    AP1_inhib -> Ab_prod_inhib
    Bcell_suppression -> Ab_VGCC_total [label="reduces\nproduction" color="red" arrowhead=tee]
    Ab_prod_inhib -> Plasma_Cells [label="suppresses\nsecretion" color="red" arrowhead=tee]

    /* Azathioprine/MMF */
    AZA_dose -> AZA_6MP [label="HPRT converts"]
    AZA_6MP -> B_Cell_Activation [label="blocks\nproliferation" color="red" arrowhead=tee]
    MMF_dose -> MPA_active
    MPA_active -> Germinal_Center [label="suppresses GC" color="red" arrowhead=tee]
    MPA_active -> B_Cell_Activation [label="suppresses" color="red" arrowhead=tee]

    /* IVIG/PE */
    IVIG_infusion -> IVIG_Ab_neutraliz [label="neutralizes"]
    IVIG_Ab_neutraliz -> Ab_VGCC_total [label="rapid reduction" color="red" arrowhead=tee]
    IVIG_Ab_neutraliz -> FcRn_Recycling [label="FcRn saturation\n→ faster Ab clearance"]
    PE_procedure -> PE_Ab_removal [label="removes"]
    PE_Ab_removal -> Ab_VGCC_total [label="rapid removal\n(50-70%/session)" color="red" arrowhead=tee]

    /* =========================================================
       EDGES — Clinical Endpoints
       ========================================================= */
    CMAP_amplitude -> CMAP_resting
    CMAP_amplitude -> CMAP_post_exercise [label="after 10s\nmax contraction"]
    CMAP_post_exercise -> Facilitation_ratio [label="post/pre"]
    CMAP_resting -> RNS_increment [label="increment at\nhigh-freq RNS"]
    CMAP_resting -> QMG_score [label="contributes"]
    Muscle_Force -> MRC_sum [label="reflects\nstrength"]
    MRC_sum -> Proximal_weakness [label="lower MRC =\nmore weakness"]
    MRC_sum -> LEMS_score [label="component"]
    CMAP_amplitude -> LEMS_score [label="component"]
    DTR_areflexia -> LEMS_score [label="component"]
    Safety_factor -> DTR_areflexia [label="low safety\nfactor → areflexia"]
    Facilitation -> DTR_facilitation [label="Lambert's sign"]
    Autonomic_dysf -> Autonomic_scale
    Autonomic_scale -> QMG_score [label="component"]
    Muscle_Force -> Ptosis [label="if ocular\nmuscle weak"]
    Muscle_Force -> Diplopia
    QMG_score -> SF36_score [label="impacts QoL"]
    Tumor_Burden -> Tumor_response_RECIST [label="measured by"]
}
