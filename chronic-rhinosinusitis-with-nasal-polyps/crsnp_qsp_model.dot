digraph CRSwNP_QSP {

  graph [
    rankdir=LR
    bgcolor="#F8FBFF"
    fontname="Helvetica"
    fontsize=11
    compound=true
    splines=polyline
    nodesep=0.35
    ranksep=0.75
    label="Chronic Rhinosinusitis with Nasal Polyps (CRSwNP)\nQuantitative Systems Pharmacology Model"
    labelloc=t
    labeljust=c
    fontsize=14
  ]

  node [shape=box style="rounded,filled" fontname="Helvetica" fontsize=8 margin="0.08,0.04"]
  edge [fontname="Helvetica" fontsize=7 color="#555555" arrowsize=0.7]

  // ============================================================
  // CLUSTER 1: Epithelial Barrier & Alarmins
  // ============================================================
  subgraph cluster_epithelial {
    label="Epithelial Barrier & Innate Alarmins"
    color="#2471A3"
    style="filled"
    fillcolor="#EBF5FB"
    fontsize=10
    fontcolor="#1A5276"

    EpiCell     [label="Sinonasal\nEpithelial Cells" fillcolor="#AED6F1"]
    BarrierInt  [label="Epithelial Barrier\nIntegrity (0-1)" fillcolor="#AED6F1"]
    TightJunc   [label="Tight Junctions\n(Claudin-1/4\nOccludin)" fillcolor="#AED6F1"]
    Cilia       [label="Mucociliary\nClearance (MCC)" fillcolor="#AED6F1"]
    CFTR        [label="CFTR\n(Cl⁻ channel)" fillcolor="#AED6F1"]
    SPDEF       [label="SPDEF\n(Goblet Cell TF)" fillcolor="#D6EAF8"]
    NO_epi      [label="Nasal Nitric Oxide\n(nNO, ppm)" fillcolor="#AED6F1"]
    Periostin   [label="Periostin\n(POSTN, ECM)" fillcolor="#D6EAF8"]
    EpiDamage   [label="Epithelial Damage\n(Allergens/Pathogens\n/Pollutants)" fillcolor="#F9EBEA" color="#C0392B"]
    TSLP        [label="TSLP\n(Thymic Stromal\nLymphopoietin)" fillcolor="#F8D7DA" color="#C0392B"]
    IL33        [label="IL-33\n(Alarmin, nuclear)" fillcolor="#F8D7DA" color="#C0392B"]
    IL25        [label="IL-25/IL-17E\n(Tuft cell alarmin)" fillcolor="#F8D7DA" color="#C0392B"]
    SAM_SEB     [label="Staphylococcal\nEnterotoxins\n(SAM/SEB)" fillcolor="#FADBD8" color="#E74C3C"]
    Biofilm     [label="Biofilm\n(S.aureus,\nH.influenzae)" fillcolor="#FADBD8" color="#E74C3C"]
    HMGB1       [label="HMGB1\n(Late alarmin)" fillcolor="#F8D7DA" color="#C0392B"]
  }

  // ============================================================
  // CLUSTER 2: Innate Immune Response
  // ============================================================
  subgraph cluster_innate {
    label="Innate Immune Response"
    color="#1E8449"
    style="filled"
    fillcolor="#EAFAF1"
    fontsize=10
    fontcolor="#145A32"

    ILC2        [label="ILC2\n(Innate Lymphoid\nCells Type 2)" fillcolor="#A9DFBF"]
    MastCell    [label="Mast Cells\n(Tissue-resident)" fillcolor="#A9DFBF"]
    Basophil    [label="Basophils\n(Blood/Tissue)" fillcolor="#A9DFBF"]
    NKcell      [label="NK Cells\n(Cytotoxic)" fillcolor="#A9DFBF"]
    DCimm       [label="Dendritic Cells\n(Immature/pDC)" fillcolor="#A9DFBF"]
    DCmatur     [label="Dendritic Cells\n(Mature, Th2-\npolarizing)" fillcolor="#A9DFBF"]
    Monocyte    [label="Monocytes /\nMacrophages (M2)" fillcolor="#A9DFBF"]
    Neutrophil  [label="Neutrophils\n(Non-eosinophilic\nCRS endotype)" fillcolor="#D5F5E3"]
    ST2_R       [label="ST2/IL1RL1\n(IL-33 Receptor)" fillcolor="#D5F5E3"]
    CRTH2       [label="CRTH2/DP2\n(PGD2 Receptor\non ILC2/Th2/Eos)" fillcolor="#D5F5E3"]
    FcERI       [label="FcεRI\n(High-affinity\nIgE Receptor)" fillcolor="#D5F5E3"]
    Tryptase    [label="Tryptase\n(Mast cell marker)" fillcolor="#A9DFBF"]
    Chymase     [label="Chymase\n(Mast cell protease)" fillcolor="#A9DFBF"]
    PAF         [label="PAF\n(Platelet-Activating\nFactor)" fillcolor="#D5F5E3"]
    Complement  [label="Complement\n(C3a/C5a)" fillcolor="#D5F5E3"]
    Alarmin_R   [label="TSLPR/IL-7Rα\n(TSLP Receptor\nComplex)" fillcolor="#D5F5E3"]
    IL17RB      [label="IL-17RB\n(IL-25 Receptor\non ILC2)" fillcolor="#D5F5E3"]
  }

  // ============================================================
  // CLUSTER 3: Adaptive Immune Response
  // ============================================================
  subgraph cluster_adaptive {
    label="Adaptive Immune Response (Type 2 Polarization)"
    color="#7D3C98"
    style="filled"
    fillcolor="#F4ECF7"
    fontsize=10
    fontcolor="#512E5F"

    Th0         [label="Naive CD4+\nT Cells" fillcolor="#D2B4DE"]
    Th2         [label="Th2 Cells\n(GATA3+, CRTh2+)" fillcolor="#C39BD3"]
    Th1         [label="Th1 Cells\n(T-bet+, IFNγ+)" fillcolor="#D2B4DE"]
    Th17        [label="Th17 Cells\n(RORγt+, IL-17+)" fillcolor="#D2B4DE"]
    Treg        [label="Tregs\n(FoxP3+, IL-10+,\nTGF-β+)" fillcolor="#D2B4DE"]
    Tfh         [label="Tfh Cells\n(CXCR5+, PD-1+)\nGerminal Center" fillcolor="#D2B4DE"]
    CD8T        [label="CD8+ T Cells\n(Cytotoxic)" fillcolor="#D2B4DE"]
    Bcell       [label="B Cells\n(Naive)" fillcolor="#D2B4DE"]
    GCBcell     [label="Germinal Center\nB Cells" fillcolor="#D2B4DE"]
    Plasmacell  [label="IgE-Secreting\nPlasma Cells" fillcolor="#C39BD3"]
    GATA3       [label="GATA3\n(Th2 Master TF)" fillcolor="#D2B4DE"]
    FoxP3       [label="FoxP3\n(Treg Master TF)" fillcolor="#D2B4DE"]
    Tbet        [label="T-bet\n(Th1 TF)" fillcolor="#D2B4DE"]
    STAT6       [label="STAT6\n(IL-4/IL-13\nSignaling)" fillcolor="#D2B4DE"]
    IL4Ra       [label="IL-4Rα\n(Shared IL-4/IL-13\nReceptor subunit)" fillcolor="#C39BD3"]
  }

  // ============================================================
  // CLUSTER 4: Cytokine & Mediator Network
  // ============================================================
  subgraph cluster_cytokines {
    label="Cytokine, Chemokine & Lipid Mediator Network"
    color="#B7350D"
    style="filled"
    fillcolor="#FDEDEC"
    fontsize=10
    fontcolor="#7B241C"

    IL4         [label="IL-4\n(Th2 signature\ncytokine)" fillcolor="#FADBD8"]
    IL5         [label="IL-5\n(Eosinophil\nsurvival/activation)" fillcolor="#FADBD8"]
    IL13        [label="IL-13\n(Goblet/fibrosis\ndriver)" fillcolor="#FADBD8"]
    IL9         [label="IL-9\n(Mast cell growth\nfactor)" fillcolor="#F9EBEA"]
    IL10        [label="IL-10\n(Anti-inflammatory\nregulatory)" fillcolor="#F9EBEA"]
    IL6         [label="IL-6\n(B cell help\nacute phase)" fillcolor="#FADBD8"]
    IL17A       [label="IL-17A\n(Non-eosinophilic\nCRS endotype)" fillcolor="#F9EBEA"]
    IL22        [label="IL-22\n(Epithelial\nregeneration)" fillcolor="#F9EBEA"]
    IL31        [label="IL-31\n(Itch/neurogenic\ninflammation)" fillcolor="#FADBD8"]
    TNFa        [label="TNF-α\n(Pro-inflammatory)" fillcolor="#FADBD8"]
    TGFB        [label="TGF-β1\n(Fibrosis driver\nTreg polarizer)" fillcolor="#FADBD8"]
    Eotaxin3    [label="Eotaxin-3\n(CCL26)\nEosinophil chemoattr." fillcolor="#FADBD8"]
    Eotaxin1    [label="Eotaxin-1\n(CCL11)" fillcolor="#F9EBEA"]
    MCP4        [label="MCP-4\n(CCL13)\nBasophil chemoattr." fillcolor="#F9EBEA"]
    CXCL8       [label="CXCL8/IL-8\n(Neutrophil\nchemoattractant)" fillcolor="#F9EBEA"]
    RANTES      [label="RANTES/CCL5\n(T cell/eosinophil)" fillcolor="#F9EBEA"]
    GM_CSF      [label="GM-CSF\n(Eosinophil/mast\ncell survival)" fillcolor="#FADBD8"]
    IL3         [label="IL-3\n(Basophil/mast\ncell growth)" fillcolor="#F9EBEA"]
    PGD2        [label="PGD2\n(Prostaglandin D2\nMast cell product)" fillcolor="#FADBD8"]
    LTC4_D4     [label="LTC4/LTD4\n(Cysteinyl\nLeukotrienes)" fillcolor="#FADBD8"]
    LTB4        [label="LTB4\n(Neutrophil\nchemoattractant)" fillcolor="#F9EBEA"]
    VEGF        [label="VEGF-A\n(Angiogenesis\nfactor)" fillcolor="#FADBD8"]
    ECP         [label="ECP\n(Eosinophil Cationic\nProtein)" fillcolor="#FADBD8"]
    MBP         [label="MBP\n(Major Basic\nProtein)" fillcolor="#FADBD8"]
    EPX         [label="EPX\n(Eosinophil\nPeroxidase)" fillcolor="#F9EBEA"]
    Histamine   [label="Histamine\n(Mast cell/basophil)" fillcolor="#FADBD8"]
    PGE2        [label="PGE2\n(Bronchoprotective\nunder ASA-inhibition)" fillcolor="#F9EBEA"]
    CysLT_R     [label="CysLT1/2R\n(Leukotriene\nReceptors)" fillcolor="#FADBD8"]
    IFNg        [label="IFN-γ\n(Type 1 response)" fillcolor="#F9EBEA"]
  }

  // ============================================================
  // CLUSTER 5: Eosinophil Biology
  // ============================================================
  subgraph cluster_eosinophil {
    label="Eosinophil Biology (Central to CRSwNP Pathogenesis)"
    color="#D68910"
    style="filled"
    fillcolor="#FEF9E7"
    fontsize=10
    fontcolor="#7E5109"

    EosProg     [label="Eosinophil\nProgenitors (BM)" fillcolor="#FAD7A0"]
    EosBlood    [label="Blood Eosinophils\n(cells/μL)" fillcolor="#F0B27A"]
    EosTissue   [label="Tissue Eosinophils\n(NP, mucosa)" fillcolor="#F0B27A"]
    EosAct      [label="Activated\nEosinophils" fillcolor="#F0B27A"]
    IL5Ra       [label="IL-5Rα\n(Eosinophil\nIL-5 Receptor)" fillcolor="#FAD7A0"]
    Siglec8     [label="Siglec-8\n(Eosinophil apoptosis\nreceptor; benralizumab\ntarget proximity)" fillcolor="#FAD7A0"]
    EosApop     [label="Eosinophil\nApoptosis" fillcolor="#FAD7A0"]
    EosDegran   [label="Eosinophil\nDegranulation\n(ECP/MBP/EPX)" fillcolor="#FAD7A0"]
    EosEET      [label="Eosinophil\nExtracellular Traps\n(EETs)" fillcolor="#FAD7A0"]
    Galectin10  [label="Galectin-10\n(Charcot-Leyden\nCrystal protein)" fillcolor="#FAD7A0"]
    CC3_Eos     [label="CCR3\n(Eosinophil\nchemokine receptor)" fillcolor="#FAD7A0"]
  }

  // ============================================================
  // CLUSTER 6: Immunoglobulin E Axis
  // ============================================================
  subgraph cluster_ige {
    label="IgE Axis & FcεRI-Mediated Activation"
    color="#1F618D"
    style="filled"
    fillcolor="#D6EAF8"
    fontsize=10
    fontcolor="#1A5276"

    IgE_free    [label="Free Serum IgE\n(Total, kU/L)" fillcolor="#AED6F1"]
    IgE_spec    [label="Allergen-Specific\nIgE" fillcolor="#AED6F1"]
    IgE_bound   [label="FcεRI-Bound\nIgE (Sensitized\nMast Cells)" fillcolor="#85C1E9"]
    IgA         [label="IgA\n(Mucosal\nimmunity)" fillcolor="#AED6F1"]
    IgG4        [label="IgG4\n(Anti-inflammatory\nblocking Ab)" fillcolor="#AED6F1"]
    IgE_Switch  [label="IgE Class\nSwitching\n(IL-4/IL-13 + IL-21)" fillcolor="#85C1E9"]
    FcgRIIB     [label="FcγRIIB\n(Inhibitory\nreceptor)" fillcolor="#AED6F1"]
    CD23        [label="CD23/FcεRII\n(Low-affinity\nIgE receptor)" fillcolor="#AED6F1"]
  }

  // ============================================================
  // CLUSTER 7: Tissue Remodeling & Polyp Formation
  // ============================================================
  subgraph cluster_remodeling {
    label="Tissue Remodeling & Nasal Polyp Growth"
    color="#148F77"
    style="filled"
    fillcolor="#E8F8F5"
    fontsize=10
    fontcolor="#0E6655"

    PolypVol    [label="Nasal Polyp\nVolume (cm³)" fillcolor="#A2D9CE"]
    NPS_score   [label="Nasal Polyp Score\n(NPS, 0–8)" fillcolor="#76D7C4"]
    Edema       [label="Stromal\nEdema" fillcolor="#A2D9CE"]
    Fibrosis    [label="Fibrosis\n(Collagen\nDeposition)" fillcolor="#A2D9CE"]
    Angiogen    [label="Angiogenesis\n(Vascular\nProliferation)" fillcolor="#A2D9CE"]
    Fibrin_dep  [label="Fibrin\nDeposition\n(AERD-specific)" fillcolor="#A2D9CE"]
    MMP9        [label="MMP-9\n(ECM\nDegradation)" fillcolor="#A2D9CE"]
    TIMP1       [label="TIMP-1\n(MMP Inhibitor)" fillcolor="#A2D9CE"]
    ColIV       [label="Collagen IV\n(BM component)" fillcolor="#A2D9CE"]
    GobletCell  [label="Goblet Cell\nHyperplasia" fillcolor="#A2D9CE"]
    SubepFib    [label="Subepithelial\nFibrosis" fillcolor="#A2D9CE"]
    Mucin       [label="Mucin\n(MUC5AC/B)\nHypersecretion" fillcolor="#A2D9CE"]
    AlbuminExud [label="Albumin\nExudation\n(Plasma leakage)" fillcolor="#A2D9CE"]
    WntPath     [label="Wnt/β-catenin\n(Polyp stromal\ncell signaling)" fillcolor="#D0ECE7"]
    Hedgehog    [label="Hedgehog\n(Stromal\nremodeling)" fillcolor="#D0ECE7"]
  }

  // ============================================================
  // CLUSTER 8: Drug PK/PD — Biologics & Small Molecules
  // ============================================================
  subgraph cluster_drugs {
    label="Drug PK/PD — Biologics & Small Molecules"
    color="#922B21"
    style="filled"
    fillcolor="#F9EBEA"
    fontsize=10
    fontcolor="#641E16"

    // Biologic drugs
    Dupilumab   [label="Dupilumab\n(anti-IL-4Rα)\n300 mg SC q2w" fillcolor="#F1948A" shape=diamond]
    Mepolizumab [label="Mepolizumab\n(anti-IL-5)\n100 mg SC q4w" fillcolor="#F1948A" shape=diamond]
    Benralizumab[label="Benralizumab\n(anti-IL-5Rα)\n30 mg SC q4-8w" fillcolor="#F1948A" shape=diamond]
    Omalizumab  [label="Omalizumab\n(anti-free IgE)\n75-600 mg SC q2-4w" fillcolor="#F1948A" shape=diamond]
    Tezepelumab [label="Tezepelumab\n(anti-TSLP)\n210 mg SC q4w" fillcolor="#F1948A" shape=diamond]

    // PK compartments
    DupuSC      [label="Dupilumab SC\nDepot (mg)" fillcolor="#FDEBD0"]
    DupuCp      [label="Dupilumab Cp\n(μg/mL)\nCentral" fillcolor="#FDEBD0"]
    DupuPer     [label="Dupilumab\nPeripheral" fillcolor="#FDEBD0"]
    MepoCp      [label="Mepolizumab Cp\n(μg/mL)" fillcolor="#FDEBD0"]
    BenraCp     [label="Benralizumab Cp\n(μg/mL)" fillcolor="#FDEBD0"]
    OmaliCp     [label="Omalizumab Cp\n(μg/mL)" fillcolor="#FDEBD0"]
    TezeCp      [label="Tezepelumab Cp\n(μg/mL)" fillcolor="#FDEBD0"]

    // Small molecules & local treatments
    INCS        [label="INCS\n(Mometasone/\nFluticasone)\nIntranasal" fillcolor="#F9A825" shape=diamond]
    SystCS      [label="Systemic\nCorticosteroid\n(Prednisolone)" fillcolor="#F9A825" shape=diamond]
    Montelukast [label="Montelukast\n(LTD4 Receptor\nAntagonist)" fillcolor="#F9A825" shape=diamond]
    Antihistam  [label="Antihistamine\n(H1 Blocker)" fillcolor="#F9A825" shape=diamond]
    AsprDesens  [label="Aspirin\nDesensitization\n(AERD therapy)" fillcolor="#F9A825" shape=diamond]
    FESS        [label="FESS\n(Sinus Surgery\nMechanical)" fillcolor="#B2BABB" shape=diamond]

    // Pharmacodynamic intermediates
    GR_act      [label="Glucocorticoid\nReceptor (GR)\nActivation" fillcolor="#F9EBEA"]
    NFkB_inhib  [label="NF-κB\nInhibition\n(by CS/GR)" fillcolor="#F9EBEA"]
    ADCC_benra  [label="ADCC\n(Benralizumab-\nmediated Eos\ndepletion)" fillcolor="#F9EBEA"]
  }

  // ============================================================
  // CLUSTER 9: Neurogenic Inflammation & Sensory Symptoms
  // ============================================================
  subgraph cluster_neuro {
    label="Neurogenic Inflammation & Sensory Symptoms"
    color="#5D6D7E"
    style="filled"
    fillcolor="#F2F3F4"
    fontsize=10
    fontcolor="#2E4053"

    SensNerve   [label="Sensory Nerve\nFibers (C-fiber,\nAδ-fiber)" fillcolor="#CCD1D1"]
    SubstP      [label="Substance P\n(Neuropeptide)" fillcolor="#CCD1D1"]
    CGRP        [label="CGRP\n(Calcitonin Gene-\nRelated Peptide)" fillcolor="#CCD1D1"]
    VIP_np      [label="VIP\n(Vasoactive\nIntestinal Peptide)" fillcolor="#CCD1D1"]
    TRPV1       [label="TRPV1\n(Capsaicin/heat\nsensor)" fillcolor="#BFC9CA"]
    TRPA1       [label="TRPA1\n(Chemical/cold\nsensor)" fillcolor="#BFC9CA"]
    NK1R        [label="NK1R\n(Substance P\nReceptor)" fillcolor="#BFC9CA"]
    NGF_n       [label="NGF\n(Nerve Growth\nFactor)" fillcolor="#CCD1D1"]
    Olfact      [label="Olfactory\nEpithelium\n(Dysfunction)" fillcolor="#BFC9CA"]
    H1R         [label="Histamine\nH1 Receptor" fillcolor="#BFC9CA"]
    NasalObstr  [label="Nasal\nObstruction\n(VAS 0-10)" fillcolor="#85929E"]
    Rhinorrhea  [label="Rhinorrhea /\nPostnasal Drip" fillcolor="#85929E"]
    FacialPress [label="Facial Pressure\n/ Pain" fillcolor="#85929E"]
    SneezeItch  [label="Sneezing /\nNasal Itch" fillcolor="#85929E"]
    Hyposmia    [label="Hyposmia /\nAnosmia" fillcolor="#85929E"]
  }

  // ============================================================
  // CLUSTER 10: Clinical Endpoints & Biomarkers
  // ============================================================
  subgraph cluster_endpoints {
    label="Clinical Endpoints & Validated Biomarkers"
    color="#1F618D"
    style="filled"
    fillcolor="#EBF5FB"
    fontsize=10
    fontcolor="#154360"

    SNOT22      [label="SNOT-22\n(0-110)\nPrimary PRO" fillcolor="#5DADE2"]
    TNSS        [label="TNSS\n(Total Nasal\nSymptom Score)" fillcolor="#AED6F1"]
    PNIF        [label="PNIF\n(Peak Nasal\nInspiratory Flow)" fillcolor="#AED6F1"]
    UPSIT       [label="UPSIT/SST\n(Olfactory Test)" fillcolor="#AED6F1"]
    LMcKay      [label="Lund-Mackay\nCT Score (0-24)" fillcolor="#AED6F1"]
    Blood_Eos   [label="Blood Eos\n(cells/μL)\nBiomarker" fillcolor="#5DADE2"]
    Serum_IgE   [label="Total Serum\nIgE (kU/L)" fillcolor="#AED6F1"]
    Blood_Perio [label="Blood Periostin\n(ng/mL)" fillcolor="#AED6F1"]
    Blood_ECP   [label="Blood ECP\n(μg/L)" fillcolor="#AED6F1"]
    FeNO        [label="FeNO\n(ppb)\nFractional\nExhaled NO" fillcolor="#AED6F1"]
    PGIC        [label="PGIC\n(Patient Global\nImpression)" fillcolor="#AED6F1"]
    SurgNeed    [label="Surgery/Rescue\nOral CS Rate" fillcolor="#AED6F1"]
    NPS_L       [label="NPS Left\nNostril (0-4)" fillcolor="#AED6F1"]
    NPS_R       [label="NPS Right\nNostril (0-4)" fillcolor="#AED6F1"]
    OBS_VAS     [label="Nasal Obstruction\nVAS (0-10)" fillcolor="#5DADE2"]
  }

  // ============================================================
  // CLUSTER 11: Comorbidities & Endotypes
  // ============================================================
  subgraph cluster_comorbid {
    label="Disease Endotypes & Comorbidities"
    color="#884EA0"
    style="filled"
    fillcolor="#F5EEF8"
    fontsize=10
    fontcolor="#6C3483"

    EosCRS      [label="Eosinophilic\nCRSwNP\n(Type 2 endotype\nWestern)" fillcolor="#C39BD3"]
    NonEosCRS   [label="Non-Eosinophilic\nCRSwNP\n(Asian endotype,\nTh17-driven)" fillcolor="#D2B4DE"]
    Th2High     [label="Type 2-High\nEndotype\n(High IL-4/5/13)" fillcolor="#C39BD3"]
    IL17Endo    [label="IL-17/Th17\nEndotype\n(CXCL8↑, Neut↑)" fillcolor="#D2B4DE"]
    Asthma_co   [label="Comorbid\nAsthma\n(50-70% of CRSwNP)" fillcolor="#C39BD3"]
    AERD        [label="AERD\n(Aspirin-Exacerbated\nRespiratory Disease\nSamter's Triad)" fillcolor="#A569BD"]
    AtopDerm_co [label="Atopic\nDermatitis\n(30-40%)" fillcolor="#C39BD3"]
    AllerRhin_co[label="Allergic\nRhinitis\n(60-80%)" fillcolor="#D2B4DE"]
    ABRS        [label="Acute\nBacterial\nRhinosinusitis" fillcolor="#D2B4DE"]
    COX1_inh    [label="COX-1\nInhibition\n(ASA/NSAIDs)" fillcolor="#D2B4DE"]
    COX2_path   [label="COX-2\n(Inflammatory\nPathway)" fillcolor="#D2B4DE"]
    EGID        [label="EGID\n(Eosinophilic GI\nDisease)" fillcolor="#D2B4DE"]
    Aspirin_R   [label="15-HETE\nUpregulation\n(AERD mechanism)" fillcolor="#D2B4DE"]
  }

  // ============================================================
  // EDGES — Biological Connections
  // ============================================================

  // Epithelial damage → Alarmins
  EpiDamage -> TSLP       [label="releases" color="#C0392B"]
  EpiDamage -> IL33        [label="releases" color="#C0392B"]
  EpiDamage -> IL25        [label="tuft cell" color="#C0392B"]
  EpiDamage -> HMGB1       [label="late release" color="#C0392B"]
  EpiDamage -> BarrierInt  [label="decreases" color="#C0392B"]
  SAM_SEB -> Bcell         [label="polyclonal\nactivation" color="#E74C3C"]
  SAM_SEB -> Plasmacell    [label="IgE secretion↑" color="#E74C3C"]
  Biofilm -> EpiDamage     [label="perpetuates" color="#E74C3C"]
  Biofilm -> SAM_SEB       [label="produces" color="#E74C3C"]
  EpiCell -> TSLP          [label="constitutive\nlow-level" color="#5D6D7E"]
  EpiCell -> NO_epi        [label="produces" color="#5D6D7E"]
  EpiCell -> Periostin     [label="IL-13 → POSTN" color="#5D6D7E"]
  TightJunc -> BarrierInt  [label="maintains"]
  Cilia -> BarrierInt      [label="clears\npathogens"]
  CFTR -> Cilia            [label="enables\nMCC"]
  SPDEF -> GobletCell      [label="drives\ndifferentiation"]
  IL13 -> SPDEF            [label="induces" color="#E74C3C"]
  BarrierInt -> EpiDamage  [label="inverse" style=dashed color="#999999"]

  // Alarmins → Innate Immune
  TSLP -> Alarmin_R        [label="binds"]
  Alarmin_R -> ILC2        [label="activates" color="#27AE60"]
  Alarmin_R -> DCmatur     [label="matures DC\nTh2-polarizing" color="#27AE60"]
  Alarmin_R -> MastCell    [label="primes" color="#27AE60"]
  IL33 -> ST2_R            [label="binds"]
  ST2_R -> ILC2            [label="activates" color="#27AE60"]
  ST2_R -> MastCell        [label="activates" color="#27AE60"]
  ST2_R -> Basophil        [label="activates" color="#27AE60"]
  ST2_R -> Th2             [label="amplifies" color="#27AE60"]
  IL25 -> IL17RB           [label="binds"]
  IL17RB -> ILC2           [label="activates" color="#27AE60"]
  HMGB1 -> DCimm           [label="matures DC" color="#27AE60"]
  DCimm -> DCmatur         [label="maturation"]
