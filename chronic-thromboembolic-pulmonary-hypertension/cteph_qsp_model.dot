digraph CTEPH_QSP {
    graph [
        label="Chronic Thromboembolic Pulmonary Hypertension (CTEPH)\nQuantitative Systems Pharmacology Model\nPipetcpt QSP Library — 2026",
        labelloc="t",
        fontsize=22,
        fontname="Helvetica-Bold",
        rankdir=TB,
        splines=ortho,
        nodesep=0.4,
        ranksep=0.6,
        bgcolor="#F8F9FA",
        compound=true
    ]
    node [fontname="Helvetica", fontsize=10, style="filled,rounded", shape=box, margin="0.15,0.08"]
    edge [fontname="Helvetica", fontsize=8, arrowsize=0.7]

    /* ================================================================
       CLUSTER 1: Thrombotic Origin & Acute PE
    ================================================================ */
    subgraph cluster_thrombosis {
        label="Thrombotic Origin & Acute PE"
        style=filled
        color="#C0392B"
        fillcolor="#FADBD8"
        fontsize=13
        fontcolor="#922B21"

        acute_pe [label="Acute Pulmonary\nEmbolism (PE)", fillcolor="#E74C3C", fontcolor=white, shape=ellipse]
        recurrent_pe [label="Recurrent PE\nEvents", fillcolor="#C0392B", fontcolor=white]
        thrombus_burden [label="Initial Thrombus\nBurden", fillcolor="#E74C3C", fontcolor=white]
        incomplete_resolution [label="Incomplete Thrombus\nResolution", fillcolor="#E8856A"]
        organized_thrombus [label="Organized\nThrombus", fillcolor="#CB4335", fontcolor=white]
        neointima [label="Neointimal\nFormation", fillcolor="#E8856A"]
        fibrosis_thrombus [label="Thrombotic\nFibrosis", fillcolor="#E8856A"]
        fixed_obstruction [label="Fixed Mechanical\nObstruction", fillcolor="#922B21", fontcolor=white, shape=hexagon]
        thrombophilia [label="Thrombophilic\nState", fillcolor="#FADBD8"]
        vwf_elevated [label="Elevated vWF\n& Factor VIII", fillcolor="#FADBD8"]
        platelet_activation [label="Platelet\nActivation", fillcolor="#FADBD8"]
        clot_retraction [label="Impaired Clot\nRetraction", fillcolor="#FADBD8"]
        erythrocyte_stiffness [label="Red Cell Membrane\nStiffness↑", fillcolor="#FADBD8"]
        fibrinogen_abnormal [label="Abnormal\nFibrinogen", fillcolor="#FADBD8"]
        splenectomy_risk [label="Post-Splenectomy\nRisk Factor", fillcolor="#FADBD8"]
    }

    /* ================================================================
       CLUSTER 2: Fibrinolysis Dysfunction
    ================================================================ */
    subgraph cluster_fibrinolysis {
        label="Fibrinolysis Dysfunction"
        style=filled
        color="#E67E22"
        fillcolor="#FDEBD0"
        fontsize=13
        fontcolor="#784212"

        tpa_deficiency [label="tPA\nDeficiency", fillcolor="#F39C12", fontcolor=white]
        pai1_elevation [label="PAI-1\nElevation↑", fillcolor="#F39C12", fontcolor=white]
        plasminogen_defect [label="Plasminogen\nActivation Defect", fillcolor="#F5B041"]
        fibrin_crosslink [label="Abnormal Fibrin\nCross-linking", fillcolor="#F5B041"]
        complement_c3c4 [label="Complement\nC3/C4 Activation", fillcolor="#FDEBD0"]
        lipoprotein_a [label="Elevated Lp(a)\nAnti-fibrinolytic", fillcolor="#FDEBD0"]
        thrombin_persist [label="Persistent Thrombin\nGeneration", fillcolor="#F5B041"]
        fibrin_fibronectin [label="Fibrin-Fibronectin\nComplex", fillcolor="#FDEBD0"]
        neutrophil_nets [label="Neutrophil\nExtracellular Traps", fillcolor="#FDEBD0"]
        macrophage_fibrinolysis [label="Macrophage-Mediated\nFibrinolysis↓", fillcolor="#FDEBD0"]
        plasmin_reduced [label="Plasmin Activity\nReduced↓", fillcolor="#F39C12", fontcolor=white]
        collagen_thrombus [label="Collagen Deposition\nin Thrombus", fillcolor="#FDEBD0"]
    }

    /* ================================================================
       CLUSTER 3: Pulmonary Vascular Remodeling
    ================================================================ */
    subgraph cluster_remodeling {
        label="Pulmonary Vascular Remodeling"
        style=filled
        color="#8E44AD"
        fillcolor="#EAD7F7"
        fontsize=13
        fontcolor="#6C3483"

        endothelial_dysfn [label="Endothelial\nDysfunction", fillcolor="#9B59B6", fontcolor=white, shape=ellipse]
        endothelin1 [label="Endothelin-1 (ET-1)\nOverproduction", fillcolor="#8E44AD", fontcolor=white]
        no_deficiency [label="Nitric Oxide (NO)\nDeficiency↓", fillcolor="#9B59B6", fontcolor=white]
        pgi2_deficiency [label="Prostacyclin (PGI₂)\nDeficiency↓", fillcolor="#9B59B6", fontcolor=white]
        pdgf_signal [label="PDGF-BB\nSignaling↑", fillcolor="#BB8FCE"]
        vegf_imbalance [label="VEGF/VEGFR\nImbalance", fillcolor="#BB8FCE"]
        tgf_beta [label="TGF-β/BMPR2\nPathway", fillcolor="#BB8FCE"]
        smc_prolif [label="Smooth Muscle Cell\nProliferation", fillcolor="#8E44AD", fontcolor=white]
        smc_migration [label="SMC Migration\nto Intima", fillcolor="#BB8FCE"]
        adventitial_fibr [label="Adventitial\nFibrosis", fillcolor="#BB8FCE"]
        medial_hypertrophy [label="Medial\nHypertrophy", fillcolor="#8E44AD", fontcolor=white]
        intimal_hyperplasia [label="Intimal\nHyperplasia", fillcolor="#9B59B6", fontcolor=white]
        plexiform_lesion [label="Plexiform Lesion\nFormation", fillcolor="#BB8FCE"]
        collateral_vessel [label="Bronchial Artery\nCollateral Formation", fillcolor="#D2B4DE"]
        hypoxic_pvc [label="Hypoxic Pulmonary\nVasoconstriction", fillcolor="#D2B4DE"]
        rho_kinase [label="RhoA/ROCK\nActivation", fillcolor="#D2B4DE"]
    }

    /* ================================================================
       CLUSTER 4: Hemodynamics & Pulmonary Circulation
    ================================================================ */
    subgraph cluster_hemodynamics {
        label="Hemodynamics & Pulmonary Circulation"
        style=filled
        color="#1A5276"
        fillcolor="#D6EAF8"
        fontsize=13
        fontcolor="#1A5276"

        mpap [label="mPAP\n(mmHg)", fillcolor="#2980B9", fontcolor=white, shape=ellipse]
        pvr [label="Total PVR\n(dyn·s/cm⁵)", fillcolor="#1A5276", fontcolor=white, shape=ellipse]
        pvr_fixed [label="Fixed PVR\n(Thrombus)", fillcolor="#1F618D", fontcolor=white]
        pvr_variable [label="Variable PVR\n(Vasomotor)", fillcolor="#2980B9", fontcolor=white]
        pcwp [label="Pulmonary Capillary\nWedge Pressure", fillcolor="#5DADE2"]
        cardiac_output [label="Cardiac Output\n(L/min)", fillcolor="#2980B9", fontcolor=white, shape=ellipse]
        svr [label="Systemic Vascular\nResistance", fillcolor="#7FB3D3"]
        tpg [label="Transpulmonary\nGradient (TPG)", fillcolor="#7FB3D3"]
        dpg [label="Diastolic Pressure\nGradient (DPG)", fillcolor="#7FB3D3"]
        pap_systolic [label="Systolic PAP\n(mmHg)", fillcolor="#5DADE2"]
        rvsp [label="RV Systolic\nPressure", fillcolor="#5DADE2"]
        mrap [label="Mean Right Atrial\nPressure (mRAP)", fillcolor="#7FB3D3"]
        papi [label="Pulmonary Artery\nPulsatility Index", fillcolor="#AED6F1"]
        pvri [label="Pulmonary Vascular\nResistance Index", fillcolor="#AED6F1"]
    }

    /* ================================================================
       CLUSTER 5: Right Ventricular Remodeling
    ================================================================ */
    subgraph cluster_rv {
        label="Right Ventricular Remodeling & Failure"
        style=filled
        color="#E74C3C"
        fillcolor="#FDEDEC"
        fontsize=13
        fontcolor="#7B241C"

        rv_pressure_overload [label="RV Pressure\nOverload", fillcolor="#EC7063", shape=ellipse]
        rv_hypertrophy [label="RV Adaptive\nHypertrophy", fillcolor="#EC7063"]
        rv_dilation [label="RV\nDilatation", fillcolor="#E74C3C", fontcolor=white]
        rv_dysfunction [label="RV Systolic\nDysfunction", fillcolor="#C0392B", fontcolor=white]
        rv_fibrosis [label="RV Myocardial\nFibrosis", fillcolor="#E74C3C", fontcolor=white]
        iv_septum_shift [label="IV Septal\nFlattening/Shift", fillcolor="#EC7063"]
        tapse [label="TAPSE\nReduction↓", fillcolor="#EC7063"]
        rv_ef [label="RV Ejection\nFraction↓", fillcolor="#E74C3C", fontcolor=white]
        rv_stroke_work [label="RV Stroke Work\nIndex↓", fillcolor="#EC7063"]
        tricuspid_regurg [label="Tricuspid\nRegurgitation", fillcolor="#EC7063"]
        rv_ischemia [label="RV Subendocardial\nIschemia", fillcolor="#C0392B", fontcolor=white]
        ra_dilation [label="Right Atrial\nDilatation", fillcolor="#EC7063"]
        rv_afterload [label="RV Afterload\nCoupling (Ea/Ees)", fillcolor="#FADBD8"]
    }

    /* ================================================================
       CLUSTER 6: Gas Exchange & Hypoxemia
    ================================================================ */
    subgraph cluster_gas_exchange {
        label="Gas Exchange & Respiratory"
        style=filled
        color="#1E8449"
        fillcolor="#D5F5E3"
        fontsize=13
        fontcolor="#1E8449"

        vq_mismatch [label="V/Q\nMismatch", fillcolor="#27AE60", fontcolor=white, shape=ellipse]
        dead_space [label="Increased Dead\nSpace (Vd/Vt)↑", fillcolor="#1E8449", fontcolor=white]
        pao2 [label="PaO₂\n(mmHg)↓", fillcolor="#52BE80"]
        paco2 [label="PaCO₂\n(mmHg)↓", fillcolor="#52BE80"]
        sao2 [label="SaO₂\n(%)↓", fillcolor="#27AE60", fontcolor=white]
        dlco [label="DLCO\nReduction↓", fillcolor="#52BE80"]
        hypoxemia [label="Systemic\nHypoxemia", fillcolor="#1E8449", fontcolor=white, shape=ellipse]
        hyperventilation [label="Compensatory\nHyperventilation", fillcolor="#A9DFBF"]
        resp_alkalosis [label="Respiratory\nAlkalosis", fillcolor="#A9DFBF"]
        ve_vco2 [label="VE/VCO₂ Slope\nElevation↑", fillcolor="#52BE80"]
    }

    /* ================================================================
       CLUSTER 7: Neurohumoral Activation & Biomarkers
    ================================================================ */
    subgraph cluster_neurohumoral {
        label="Neurohumoral Activation & Biomarkers"
        style=filled
        color="#7D6608"
        fillcolor="#FEF9E7"
        fontsize=13
        fontcolor="#7D6608"

        bnp_nt [label="BNP / NT-proBNP\n(pg/mL)↑", fillcolor="#F1C40F", shape=ellipse]
        raas_activation [label="RAAS\nActivation", fillcolor="#D4AC0D", fontcolor=white]
        angiotensin_ii [label="Angiotensin II\nElevation", fillcolor="#F1C40F"]
        aldosterone [label="Aldosterone\nRetention", fillcolor="#F1C40F"]
        sympathetic [label="Sympathetic\nActivation", fillcolor="#D4AC0D", fontcolor=white]
        norepinephrine [label="Norepinephrine\nElevation", fillcolor="#F1C40F"]
        troponin_ck [label="Troponin-I\nElevation", fillcolor="#F5B041"]
        uric_acid [label="Uric Acid\nElevation", fillcolor="#FAD7A0"]
        crp_il6 [label="CRP / IL-6\nElevation", fillcolor="#FAD7A0"]
        galectin3 [label="Galectin-3\nBiomarker", fillcolor="#FAD7A0"]
        gdf15 [label="GDF-15\nElevation", fillcolor="#FAD7A0"]
        ddimer [label="D-Dimer\nPersistence↑", fillcolor="#F5B041"]
    }

    /* ================================================================
       CLUSTER 8: Riociguat PK/PD
    ================================================================ */
    subgraph cluster_riociguat {
        label="Riociguat PK/PD (sGC Stimulator)"
        style=filled
        color="#1A5276"
        fillcolor="#EBF5FB"
        fontsize=13
        fontcolor="#1A5276"

        riociguat_dose [label="Riociguat\n0.5–2.5 mg TID", fillcolor="#2471A3", fontcolor=white, shape=parallelogram]
        riociguat_gut [label="GI Absorption\n(Foral ~94%)", fillcolor="#5DADE2"]
        riociguat_central [label="Riociguat\nCentral (Vc)", fillcolor="#2980B9", fontcolor=white]
        riociguat_peripheral [label="Riociguat\nPeripheral (Vp)", fillcolor="#5DADE2"]
        riociguat_metabolite [label="M1 Active\nMetabolite", fillcolor="#7FB3D3"]
        sgc_stimulation [label="sGC Direct\nStimulation+Sensitization", fillcolor="#1A5276", fontcolor=white, shape=ellipse]
        cgmp_production [label="cGMP\nProduction↑", fillcolor="#2980B9", fontcolor=white]
        pde5_cgmp [label="PDE5\ncGMP Degradation↓", fillcolor="#5DADE2"]
        cgmp_pka [label="cGMP-PKA\nSignaling↑", fillcolor="#7FB3D3"]
        rio_vasodilation [label="Pulmonary\nVasodilation", fillcolor="#AED6F1"]
        rio_antiproliferative [label="Anti-Proliferative\nEffect on VSMC", fillcolor="#AED6F1"]
    }

    /* ================================================================
       CLUSTER 9: ERA PK/PD (Macitentan/Bosentan)
    ================================================================ */
    subgraph cluster_era {
        label="ERA PK/PD (Endothelin Receptor Antagonist)"
        style=filled
        color="#6C3483"
        fillcolor="#F5EEF8"
        fontsize=13
        fontcolor="#6C3483"

        macitentan_dose [label="Macitentan\n10 mg QD", fillcolor="#8E44AD", fontcolor=white, shape=parallelogram]
        macitentan_central [label="Macitentan\nCentral (Vc)", fillcolor="#9B59B6", fontcolor=white]
        macitentan_peripheral [label="Macitentan\nPeripheral (Vp)", fillcolor="#BB8FCE"]
        macitentan_metabolite [label="ACT-132577\nActive Metabolite", fillcolor="#BB8FCE"]
        bosentan_alt [label="Bosentan\n125 mg BID (Alt)", fillcolor="#D2B4DE", shape=parallelogram]
        era_eta_block [label="ETA Receptor\nBlockade", fillcolor="#8E44AD", fontcolor=white, shape=ellipse]
        era_etb_block [label="ETB Receptor\nBlockade", fillcolor="#9B59B6", fontcolor=white]
        et1_plasma_rise [label="ET-1 Plasma\nIncrease (biomarker)", fillcolor="#D2B4DE"]
        era_pvr_reduction [label="PVR Reduction\nvia ERA", fillcolor="#BB8FCE"]
        era_hepatotox [label="Liver Function\nMonitoring (AST/ALT)", fillcolor="#D2B4DE"]
        era_antiproliferative [label="Anti-Fibrotic\nAnti-Remodeling", fillcolor="#D2B4DE"]
    }

    /* ================================================================
       CLUSTER 10: Prostacyclin Analog PK/PD
    ================================================================ */
    subgraph cluster_prostacyclin {
        label="Prostacyclin Analog PK/PD"
        style=filled
        color="#0E6655"
        fillcolor="#E8F8F5"
        fontsize=13
        fontcolor="#0E6655"

        treprostinil_dose [label="Treprostinil SC/Inhaled\n(escalating dose)", fillcolor="#148F77", fontcolor=white, shape=parallelogram]
        treprostinil_central [label="Treprostinil\nCentral (Vc)", fillcolor="#1ABC9C", fontcolor=white]
        selexipag_alt [label="Selexipag 200–1600\nμg BID (Alt/IP Ago)", fillcolor="#A9DFBF", shape=parallelogram]
        ip_receptor [label="IP Receptor\n(Prostacyclin R) Activation", fillcolor="#148F77", fontcolor=white, shape=ellipse]
        camp_production [label="cAMP\nProduction↑", fillcolor="#1ABC9C", fontcolor=white]
        pka_activation [label="PKA\nActivation", fillcolor="#52BE80"]
        pgi2_vasodilation [label="Pulmonary\nVasodilation", fillcolor="#A9DFBF"]
        platelet_inhibit [label="Platelet\nAggregation↓", fillcolor="#A9DFBF"]
        pgi2_antiproliferative [label="Anti-Proliferative\nEffect", fillcolor="#A9DFBF"]
        pgi2_vasoremodel [label="Anti-Remodeling\nEffect", fillcolor="#A9DFBF"]
    }

    /* ================================================================
       CLUSTER 11: Surgical & Procedural Interventions
    ================================================================ */
    subgraph cluster_interventions {
        label="Surgical & Procedural Interventions"
        style=filled
        color="#1B2631"
        fillcolor="#EAECEE"
        fontsize=13
        fontcolor="#1B2631"

        pea_surgery [label="Pulmonary\nEndarterectomy (PEA)", fillcolor="#2C3E50", fontcolor=white, shape=hexagon]
        bpa_procedure [label="Balloon Pulmonary\nAngioplasty (BPA)", fillcolor="#2C3E50", fontcolor=white, shape=hexagon]
        pea_pvr_reduction [label="PVR Reduction\n(Mechanical)", fillcolor="#5D6D7E", fontcolor=white]
        bpa_pvr_reduction [label="Incremental PVR\nReduction (BPA)", fillcolor="#7F8C8D"]
        anticoagulation [label="Lifelong\nAnticoagulation", fillcolor="#95A5A6", shape=parallelogram]
        warfarin_vka [label="Warfarin / VKA\n(INR 2-3)", fillcolor="#BDC3C7"]
        doac_therapy [label="DOAC\n(Rivaroxaban/Apixaban)", fillcolor="#BDC3C7"]
        ivc_filter [label="IVC Filter\n(selected cases)", fillcolor="#D5D8DC"]
        oxygen_therapy [label="Supplemental\nO₂ Therapy", fillcolor="#D5D8DC", shape=parallelogram]
        diuretic_therapy [label="Diuretic Therapy\n(Furosemide/Torsemide)", fillcolor="#D5D8DC", shape=parallelogram]
        rehabilitation [label="Pulmonary\nRehabilitation", fillcolor="#D5D8DC"]
    }

    /* ================================================================
       CLUSTER 12: Clinical Endpoints & Functional Assessment
    ================================================================ */
    subgraph cluster_endpoints {
        label="Clinical Endpoints & Functional Assessment"
        style=filled
        color="#145A32"
        fillcolor="#EAFAF1"
        fontsize=13
        fontcolor="#145A32"

        sixmwd [label="6-Minute Walk\nDistance (6MWD)↑", fillcolor="#27AE60", fontcolor=white, shape=ellipse]
        who_fc [label="WHO Functional\nClass (I-IV)", fillcolor="#1E8449", fontcolor=white, shape=ellipse]
        dyspnea [label="Dyspnea Score\n(mMRC/Borg)", fillcolor="#52BE80"]
        qol [label="Quality of Life\n(SF-36, EQ-5D)", fillcolor="#58D68D"]
        clinical_worsening [label="Clinical Worsening\nEvents", fillcolor="#C0392B", fontcolor=white, shape=ellipse]
        survival [label="Overall Survival\n(Mortality)", fillcolor="#922B21", fontcolor=white, shape=ellipse]
        hospitalization [label="Hospitalization\nRate", fillcolor="#E74C3C", fontcolor=white]
        echo_params [label="Echocardiographic\nParameters", fillcolor="#76D7C4"]
        rh_cath [label="Right Heart\nCatheterization", fillcolor="#76D7C4"]
        ct_pa [label="CT-PA Findings\nObstruction Score", fillcolor="#76D7C4"]
        perf_scan [label="V/Q Perfusion\nScan Improvement", fillcolor="#A9DFBF"]
        time_to_cworsening [label="Time to Clinical\nWorsening (TTCW)", fillcolor="#E74C3C", fontcolor=white]
    }

    /* ================================================================
       EDGES - Pathophysiology
    ================================================================ */
    /* Thrombotic cascade */
    thrombophilia -> acute_pe [color="#C0392B"]
    vwf_elevated -> platelet_activation [color="#C0392B"]
    platelet_activation -> thrombus_burden [color="#C0392B"]
    fibrinogen_abnormal -> clot_retraction [color="#E74C3C"]
    clot_retraction -> incomplete_resolution [color="#E74C3C"]
    acute_pe -> thrombus_burden [color="#C0392B", penwidth=2]
    recurrent_pe -> thrombus_burden [color="#C0392B"]
    splenectomy_risk -> acute_pe [color="#C0392B", style=dashed]
    erythrocyte_stiffness -> incomplete_resolution [color="#E74C3C"]
    thrombus_burden -> incomplete_resolution [color="#C0392B", penwidth=2]

    /* Fibrinolysis links */
    tpa_deficiency -> plasmin_reduced [color="#E67E22", penwidth=2]
    pai1_elevation -> plasmin_reduced [color="#E67E22", penwidth=2]
    plasminogen_defect -> plasmin_reduced [color="#E67E22"]
    lipoprotein_a -> pai1_elevation [color="#F39C12"]
    fibrin_crosslink -> incomplete_resolution [color="#E67E22", penwidth=2]
    complement_c3c4 -> neutrophil_nets [color="#E67E22"]
    neutrophil_nets -> fibrin_crosslink [color="#E67E22"]
    macrophage_fibrinolysis -> plasmin_reduced [color="#E67E22"]
    thrombin_persist -> fibrin_crosslink [color="#F39C12"]
    collagen_thrombus -> organized_thrombus [color="#E67E22"]
    plasmin_reduced -> incomplete_resolution [color="#E67E22", penwidth=2]
    fibrin_fibronectin -> collagen_thrombus [color="#E67E22"]

    incomplete_resolution -> organized_thrombus [color="#C0392B", penwidth=2]
    organized_thrombus -> neointima [color="#C0392B", penwidth=2]
    neointima -> fibrosis_thrombus [color="#922B21", penwidth=2]
    fibrosis_thrombus -> fixed_obstruction [color="#922B21", penwidth=3]
    organized_thrombus -> fibrosis_thrombus [color="#C0392B"]

    /* Vascular remodeling from obstruction */
    fixed_obstruction -> endothelial_dysfn [color="#8E44AD", penwidth=2]
    fixed_obstruction -> pvr_fixed [color="#1A5276", penwidth=3, lhead=cluster_hemodynamics]
    endothelial_dysfn -> endothelin1 [color="#8E44AD", penwidth=2]
    endothelial_dysfn -> no_deficiency [color="#8E44AD", penwidth=2]
    endothelial_dysfn -> pgi2_deficiency [color="#8E44AD", penwidth=2]
    endothelin1 -> smc_prolif [color="#8E44AD", penwidth=2]
    endothelin1 -> hypoxic_pvc [color="#8E44AD"]
    endothelin1 -> rho_kinase [color="#8E44AD"]
    pdgf_signal -> smc_prolif [color="#8E44AD"]
    pdgf_signal -> smc_migration [color="#8E44AD"]
    tgf_beta -> adventitial_fibr [color="#8E44AD"]
    tgf_beta -> medial_hypertrophy [color="#8E44AD"]
    vegf_imbalance -> plexiform_lesion [color="#8E44AD"]
    smc_prolif -> medial_hypertrophy [color="#8E44AD", penwidth=2]
    smc_migration -> intimal_hyperplasia [color="#8E44AD"]
    adventitial_fibr -> pvr_variable [color="#1A5276"]
    medial_hypertrophy -> pvr_variable [color="#1A5276", penwidth=2]
    intimal_hyperplasia -> pvr_variable [color="#1A5276", penwidth=2]
    hypoxic_pvc -> pvr_variable [color="#1A5276"]
    rho_kinase -> smc_prolif [color="#8E44AD"]
    collateral_vessel -> vq_mismatch [color="#27AE60"]

    /* Hemodynamics */
    pvr_fixed -> pvr [color="#1A5276", penwidth=2]
    pvr_variable -> pvr [color="#1A5276", penwidth=2]
    pvr -> mpap [color="#1A5276", penwidth=3]
    pvr -> rv_pressure_overload [color="#E74C3C", penwidth=3, lhead=cluster_rv]
    mpap -> pap_systolic [color="#2980B9"]
    mpap -> rvsp [color="#2980B9"]
    mpap -> tpg [color="#1A5276"]
    mpap -> dpg [color="#1A5276"]
    pvr -> pvri [color="#1A5276"]
    cardiac_output -> mpap [color="#2980B9", style=dashed, dir=back]
    cardiac_output -> svr [color="#2980B9"]
    mrap -> cardiac_output [color="#1A5276", style=dashed]
    pcwp -> dpg [color="#1A5276"]
    papi -> rv_dysfunction [color="#E74C3C"]

    /* RV remodeling */
    rv_pressure_overload -> rv_hypertrophy [color="#E74C3C", penwidth=2]
    rv_pressure_overload -> rv_ischemia [color="#C0392B"]
    rv_hypertrophy -> rv_dilation [color="#E74C3C"]
    rv_dilation -> rv_dysfunction [color="#C0392B", penwidth=2]
    rv_dilation -> tricuspid_regurg [color="#E74C3C"]
    rv_dilation -> iv_septum_shift [color="#E74C3C"]
    rv_dysfunction -> rv_fibrosis [color="#C0392B"]
    rv_dysfunction -> tapse [color="#E74C3C"]
    rv_dysfunction -> rv_ef [color="#E74C3C"]
    rv_dysfunction -> rv_stroke_work [color="#E74C3C"]
    rv_dysfunction -> ra_dilation [color="#E74C3C"]
    rv_dysfunction -> rv_afterload [color="#E74C3C"]
    iv_septum_shift -> cardiac_output [color="#2980B9", style=dashed]
    rv_ischemia -> rv_fibrosis [color="#C0392B"]
    rv_ef -> cardiac_output [color="#2980B9", penwidth=2]

    /* Gas exchange */
    pvr_fixed -> vq_mismatch [color="#27AE60", penwidth=2]
    pvr_variable -> vq_mismatch [color="#27AE60"]
    vq_mismatch -> dead_space [color="#1E8449", penwidth=2]
    vq_mismatch -> pao2 [color="#1E8449", penwidth=2]
    pao2 -> sao2 [color="#27AE60", penwidth=2]
    pao2 -> hypoxemia [color="#1E8449", penwidth=2]
    hypoxemia -> endothelial_dysfn [color="#8E44AD", style=dashed]
    hypoxemia -> hypoxic_pvc [color="#8E44AD"]
    hypoxemia -> hyperventilation [color="#1E8449"]
    hyperventilation -> paco2 [color="#27AE60"]
    hyperventilation -> resp_alkalosis [color="#27AE60"]
    dead_space -> ve_vco2 [color="#1E8449"]
    dlco -> vq_mismatch [color="#27AE60", style=dashed]

    /* Neurohumoral */
    rv_dysfunction -> bnp_nt [color="#D4AC0D", penwidth=2]
    rv_ischemia -> troponin_ck [color="#F5B041"]
    raas_activation -> angiotensin_ii [color="#D4AC0D"]
    raas_activation -> aldosterone [color="#D4AC0D"]
    angiotensin_ii -> raas_activation [color="#D4AC0D", style=dashed]
    cardiac_output -> raas_activation [color="#D4AC0D", style=dashed]
    sympathetic -> norepinephrine [color="#D4AC0D"]
    norepinephrine -> cardiac_output [color="#2980B9", style=dashed]
    hypoxemia -> uric_acid [color="#FAD7A0"]
    endothelial_dysfn -> crp_il6 [color="#FAD7A0"]
    rv_fibrosis -> galectin3 [color="#FAD7A0"]
    ddimer -> thrombus_burden [color="#C0392B", style=dashed]
    bnp_nt -> who_fc [color="#1E8449"]
    gdf15 -> clinical_worsening [color="#C0392B"]

    /* ================================================================
       EDGES - Drug PK/PD
    ================================================================ */
    /* Riociguat PK */
    riociguat_dose -> riociguat_gut [color="#2471A3", penwidth=2, style=bold]
    riociguat_gut -> riociguat_central [color="#2471A3", penwidth=2]
    riociguat_central -> riociguat_peripheral [color="#2471A3"]
    riociguat_peripheral -> riociguat_central [color="#2471A3", style=dashed]
    riociguat_central -> riociguat_metabolite [color="#5DADE2"]

    /* Riociguat PD */
    riociguat_central -> sgc_stimulation [color="#1A5276", penwidth=2]
    no_deficiency -> sgc_stimulation [color="#1A5276", style=dashed, label="synergy"]
    sgc_stimulation -> cgmp_production [color="#1A5276", penwidth=2]
    pde5_cgmp -> cgmp_production [color="#2980B9", style=dashed, arrowhead=tee, label="inhibits"]
    cgmp_production -> cgmp_pka [color="#2980B9"]
    cgmp_pka -> rio_vasodilation [color="#AED6F1", penwidth=2]
    cgmp_pka -> rio_antiproliferative [color="#AED6F1"]
    rio_vasodilation -> pvr_variable [color="#1A5276", penwidth=2, arrowhead=tee]
    rio_vasodilation -> endothelin1 [color="#8E44AD", arrowhead=tee]
    rio_antiproliferative -> smc_prolif [color="#8E44AD", arrowhead=tee]

    /* Macitentan PK */
    macitentan_dose -> macitentan_central [color="#8E44AD", penwidth=2, style=bold]
    macitentan_central -> macitentan_peripheral [color="#9B59B6"]
    macitentan_peripheral -> macitentan_central [color="#9B59B6", style=dashed]
    macitentan_central -> macitentan_metabolite [color="#BB8FCE"]
    bosentan_alt -> era_eta_block [color="#D2B4DE", style=dashed]

    /* ERA PD */
    macitentan_central -> era_eta_block [color="#8E44AD", penwidth=2]
    macitentan_metabolite -> era_eta_block [color="#9B59B6"]
    macitentan_central -> era_etb_block [color="#9B59B6"]
    era_eta_block -> pvr_variable [color="#1A5276", penwidth=2, arrowhead=tee]
    era_eta_block -> smc_prolif [color="#8E44AD", arrowhead=tee]
    era_etb_block -> et1_plasma_rise [color="#D2B4DE"]
    era_eta_block -> era_pvr_reduction [color="#BB8FCE"]
    era_pvr_reduction -> mpap [color="#2980B9", arrowhead=tee]
    era_eta_block -> era_antiproliferative [color="#D2B4DE"]
    era_antiproliferative -> fibrosis_thrombus [color="#C0392B", arrowhead=tee, style=dashed]
    era_hepatotox -> macitentan_dose [color="#E74C3C", style=dotted]

    /* Treprostinil PK */
    treprostinil_dose -> treprostinil_central [color="#148F77", penwidth=2, style=bold]
    selexipag_alt -> ip_receptor [color="#A9DFBF", style=dashed]

    /* Prostacyclin PD */
    treprostinil_central -> ip_receptor [color="#1ABC9C", penwidth=2]
    pgi2_deficiency -> ip_receptor [color="#148F77", style=dashed, label="replaces"]
    ip_receptor -> camp_production [color="#1ABC9C", penwidth=2]
    camp_production -> pka_activation [color="#52BE80"]
    pka_activation -> pgi2_vasodilation [color="#A9DFBF", penwidth=2]
    pka_activation -> platelet_inhibit [color="#A9DFBF"]
    pka_activation -> pgi2_antiproliferative [color="#A9DFBF"]
    pgi2_vasodilation -> pvr_variable [color="#1A5276", penwidth=2, arrowhead=tee]
    platelet_inhibit -> thrombus_burden [color="#C0392B", arrowhead=tee]
    pgi2_antiproliferative -> smc_prolif [color="#8E44AD", arrowhead=tee]
    pgi2_vasoremodel -> medial_hypertrophy [color="#8E44AD", arrowhead=tee]
    pgi2_antiproliferative -> pgi2_vasoremodel [color="#A9DFBF"]

    /* ================================================================
       EDGES - Surgical/Procedural
    ================================================================ */
    pea_surgery -> pea_pvr_reduction [color="#2C3E50", penwidth=2, style=bold]
    pea_pvr_reduction -> pvr_fixed [color="#1A5276", penwidth=3, arrowhead=tee]
    pea_pvr_reduction -> organized_thrombus [color="#C0392B", arrowhead=tee]
    bpa_procedure -> bpa_pvr_reduction [color="#2C3E50", penwidth=2]
    bpa_pvr_reduction -> pvr_fixed [color="#1A5276", penwidth=2, arrowhead=tee]
    anticoagulation -> recurrent_pe [color="#C0392B", arrowhead=tee, penwidth=2]
    warfarin_vka -> anticoagulation [color="#95A5A6"]
    doac_therapy -> anticoagulation [color="#95A5A6"]
    ivc_filter -> recurrent_pe [color="#C0392B", arrowhead=tee, style=dashed]
    oxygen_therapy -> hypoxemia [color="#1E8449", arrowhead=tee]
    oxygen_therapy -> hypoxic_pvc [color="#8E44AD", arrowhead=tee]
    diuretic_therapy -> mrap [color="#1A5276", arrowhead=tee]
    rehabilitation -> sixmwd [color="#27AE60"]

    /* ================================================================
       EDGES - Clinical Endpoints
    ================================================================ */
    cardiac_output -> sixmwd [color="#27AE60", penwidth=2]
    sao2 -> sixmwd [color="#27AE60"]
    rv_stroke_work -> sixmwd [color="#27AE60", style=dashed]
    pvr -> who_fc [color="#1E8449", penwidth=2]
    rv_dysfunction -> who_fc [color="#1E8449", penwidth=2]
    hypoxemia -> dyspnea [color="#52BE80", penwidth=2]
    ve_vco2 -> dyspnea [color="#52BE80"]
    who_fc -> qol [color="#58D68D"]
    sixmwd -> qol [color="#58D68D"]
    clinical_worsening -> survival [color="#922B21", penwidth=2]
    hospitalization -> clinical_worsening [color="#E74C3C"]
    rv_dysfunction -> clinical_worsening [color="#C0392B", penwidth=2]
    bnp_nt -> clinical_worsening [color="#E74C3C", style=dashed]
    troponin_ck -> clinical_worsening [color="#E74C3C", style=dashed]
    tapse -> echo_params [color="#76D7C4"]
    rv_ef -> echo_params [color="#76D7C4"]
    iv_septum_shift -> echo_params [color="#76D7C4"]
    mpap -> rh_cath [color="#76D7C4"]
    pvr -> rh_cath [color="#76D7C4"]
    cardiac_output -> rh_cath [color="#76D7C4"]
    pvr_fixed -> ct_pa [color="#76D7C4"]
    vq_mismatch -> perf_scan [color="#76D7C4"]
    clinical_worsening -> time_to_cworsening [color="#E74C3C"]
    survival -> time_to_cworsening [color="#922B21"]

    /* ================================================================
       Cross-Cluster Feedback Loops
    ================================================================ */
    rv_dysfunction -> cardiac_output [color="#2980B9", penwidth=2]
    cardiac_output -> hypoxemia [color="#1E8449", style=dashed]
    hypoxemia -> endothelin1 [color="#8E44AD", style=dashed]
    endothelin1 -> pvr_variable [color="#1A5276", style=dashed, penwidth=2]
    rv_ischemia -> rv_dysfunction [color="#C0392B"]
    raas_activation -> rv_fibrosis [color="#C0392B", style=dashed]
    aldosterone -> rv_fibrosis [color="#C0392B", style=dashed]
    sympathetic -> rv_hypertrophy [color="#E74C3C", style=dashed]
    norepinephrine -> pvr_variable [color="#1A5276", style=dashed]

    /* ================================================================
       LEGEND
    ================================================================ */
    subgraph cluster_legend {
        label="Legend"
        style=filled
        fillcolor="#FDFEFE"
        color="#BDC3C7"
        fontsize=11

        leg_path [label="Disease Pathway", fillcolor="#E74C3C", fontcolor=white, shape=box]
        leg_drug [label="Drug/Treatment", fillcolor="#2471A3", fontcolor=white, shape=parallelogram]
        leg_endpoint [label="Clinical Endpoint", fillcolor="#27AE60", fontcolor=white, shape=ellipse]
        leg_biomarker [label="Biomarker", fillcolor="#F1C40F", shape=box]
        leg_inhibit [label="Inhibitory Edge", fillcolor=white, shape=plaintext]
        leg_inhibit_edge [label="", shape=point, width=0]
        leg_inhibit_edge2 [label="", shape=point, width=0]
        leg_inhibit_edge -> leg_inhibit_edge2 [arrowhead=tee, label="inhibits"]
    }
}
