digraph T2DM_QSP {
  graph [
    rankdir=TB,
    fontname="Helvetica",
    fontsize=12,
    bgcolor="#f5f7fa",
    compound=true,
    splines=curved,
    nodesep=0.35,
    ranksep=0.55,
    label="Type 2 Diabetes Mellitus — Quantitative Systems Pharmacology Map\nDrug Classes: Metformin · SGLT2i (Empagliflozin) · GLP-1RA (Semaglutide) · DPP-4i (Sitagliptin) · Sulfonylurea · Insulin Degludec · TZD (Pioglitazone)",
    labelloc=t,
    labeljust=c,
    fontsize=15
  ];
  node [fontname="Helvetica", fontsize=8, style="filled,rounded", shape=box, margin="0.08,0.05"];
  edge [fontsize=7, arrowsize=0.6];

  // ============================================================
  // CLUSTER 0: Drug PK — Pharmacokinetics
  // ============================================================
  subgraph cluster_pk {
    label="Drug Pharmacokinetics";
    style=filled; color="#dce8f7"; fillcolor="#eef4fb";
    node [fillcolor="#bbdefb"];

    D_met     [label="Metformin\n(oral, BID)", shape=diamond, fillcolor="#1565c0", fontcolor=white, fontsize=8];
    C_met1    [label="Metformin\nCentral (C₁)"];
    C_met2    [label="Metformin\nPeripheral (C₂)"];
    met_gut   [label="Metformin\nGut Absorption"];

    D_empa    [label="Empagliflozin\n(oral, QD)", shape=diamond, fillcolor="#1565c0", fontcolor=white, fontsize=8];
    C_empa    [label="Empagliflozin\nPlasma"];
    empa_gut  [label="Empagliflozin\nAbsorption (F=86%)"];

    D_sema    [label="Semaglutide\n(SC weekly)", shape=diamond, fillcolor="#1565c0", fontcolor=white, fontsize=8];
    C_sema_sc [label="Semaglutide\nSC Depot"];
    C_sema    [label="Semaglutide\nPlasma (t½≈168h)"];

    D_dpp4i   [label="Sitagliptin\n(oral, QD)", shape=diamond, fillcolor="#1565c0", fontcolor=white, fontsize=8];
    C_dpp4i   [label="Sitagliptin\nPlasma"];

    D_su      [label="Glimepiride\n(oral, QD)", shape=diamond, fillcolor="#1565c0", fontcolor=white, fontsize=8];
    C_su      [label="Glimepiride\nPlasma"];

    D_ins     [label="Insulin Degludec\n(SC, QD)", shape=diamond, fillcolor="#1565c0", fontcolor=white, fontsize=8];
    C_ins_sc  [label="Insulin Degludec\nSC Depot (hexamer)"];
    C_ins_exo [label="Exogenous Insulin\nPlasma"];

    D_piog    [label="Pioglitazone\n(oral, QD)", shape=diamond, fillcolor="#1565c0", fontcolor=white, fontsize=8];
    C_piog    [label="Pioglitazone\nPlasma"];

    pk_CL_met  [label="Renal/Tubular\nElimination (Met)"];
    pk_CL_empa [label="Renal/Fecal\nElimination (Empa)"];
    pk_CL_sema [label="Metabolic\nClearance (Sema)"];
  }

  // ============================================================
  // CLUSTER 1: Incretin/GLP-1 System
  // ============================================================
  subgraph cluster_incretin {
    label="Incretin System (Gut–Pancreas Axis)";
    style=filled; color="#e8d5f0"; fillcolor="#f3e5f5";
    node [fillcolor="#e1bee7"];

    nutrient_sense [label="Luminal Nutrient\nSensing (glucose/fat)"];
    L_cell         [label="L-cell (ileum/colon)\nGLP-1 Secretion"];
    K_cell         [label="K-cell (duodenum)\nGIP Secretion"];
    DPP4_plasma    [label="DPP-4\n(plasma protease)"];
    GLP1_intact    [label="Active GLP-1\n(7-36) pmol/L"];
    GIP_intact     [label="Active GIP\n(1-42) pmol/L"];
    GLP1_inactive  [label="Inactive GLP-1\n(9-36) — DPP-4 product"];
    portal_gluc    [label="Portal Glucose\nSignal"];
    GLP1_renal_CL  [label="GLP-1 Renal &\nProtease Clearance"];
    vagal_signal   [label="Vagal Afferent\n(gut→brainstem)"];
  }

  // ============================================================
  // CLUSTER 2: Pancreatic Islet
  // ============================================================
  subgraph cluster_islet {
    label="Pancreatic Islet (β-cell / α-cell)";
    style=filled; color="#f5e642"; fillcolor="#fffde7";
    node [fillcolor="#fff9c4"];

    beta_mass    [label="β-cell Mass\n(M_β, normalized)", shape=ellipse, fillcolor="#f9a825"];
    beta_func    [label="β-cell Function\n(F_β, 0–1)"];
    alpha_cell   [label="α-cell"];
    glucagon_Gc  [label="Glucagon (Gc)\npg/mL", shape=ellipse, fillcolor="#f9a825"];
    GK_beta      [label="Glucokinase (GK)\nGlucose Sensor"];
    KATP_chan    [label="K_ATP Channel\n(SUR1/Kir6.2)"];
    Ca_influx    [label="Ca²⁺ Influx\n(VDCC)"];
    insulin_exo  [label="Insulin Exocytosis\n(1st + 2nd phase)"];
    insulin_bio  [label="Insulin Biosynthesis\n(preproinsulin)"];
    insulin_gran [label="Insulin\nGranule Pool"];
    proinsulin   [label="Proinsulin\nProcessing"];
    C_peptide    [label="C-peptide\n(equimolar to Ins)"];
    SUR1_target  [label="SUR1 Receptor\n(SU binding site)"];
    beta_prolif  [label="β-cell\nProliferation"];
    beta_apop    [label="β-cell\nApoptosis"];
    ER_stress    [label="ER Stress\n(UPR activation)"];
    ox_stress_b  [label="Oxidative Stress\n(β-cell ROS)"];
    IL1b_islet   [label="IL-1β\n(islet)"];
    NLRP3_inf    [label="NLRP3\nInflammasome"];
    GLP1R_beta   [label="GLP-1R\n(β-cell surface)"];
    GIPR_beta    [label="GIP-R\n(β-cell surface)"];
    cAMP_beta    [label="cAMP (β-cell)\nPKA activation"];
    gluc_sense_b [label="β-cell Glucose\nSensing (GCK→ATP)"];
  }

  // ============================================================
  // CLUSTER 3: Insulin Signaling & Resistance
  // ============================================================
  subgraph cluster_ins_sig {
    label="Insulin Signaling & Molecular Insulin Resistance";
    style=filled; color="#a5d6a7"; fillcolor="#e8f5e9";
    node [fillcolor="#c8e6c9"];

    IR_rec      [label="Insulin Receptor\n(IR, RTK)"];
    IRS1        [label="IRS-1\n(tyrosine phos.)"];
    PI3K_p85    [label="PI3K\n(p85/p110)"];
    PDK1        [label="PDK1"];
    Akt_PKB     [label="Akt/PKB\n(Ser473)"];
    AS160       [label="AS160\n(Rab-GAP)"];
    GLUT4_v     [label="GLUT4\nIntracellular Vesicle"];
    GLUT4_m     [label="GLUT4\nPlasma Membrane"];
    GSK3b       [label="GSK-3β\n(inactivated by Akt)"];
    GS_active   [label="Glycogen Synthase\n(activated)"];
    FOXO1_n     [label="FOXO1\n(nuclear, active)"];
    FOXO1_c     [label="FOXO1\n(cytoplasmic, inactive)"];
    PTP1B       [label="PTP1B\n(IR deactivation)"];
    IRS1_pSer   [label="IRS-1 pSer\n(inhibitory)"];
    mTORC1      [label="mTORC1"];
    S6K1        [label="S6K1→IRS-1\npSer feedback"];
    PKCtheta    [label="PKCθ\n(DAG-mediated)"];
    TLR4_sig    [label="TLR4 Signaling\n(FFA-mediated)"];
    IKKb        [label="IKKβ\n(NF-κB pathway)"];
  }

  // ============================================================
  // CLUSTER 4: Hepatic Glucose Metabolism
  // ============================================================
  subgraph cluster_liver {
    label="Hepatic Glucose Metabolism";
    style=filled; color="#f48fb1"; fillcolor="#fce4ec";
    node [fillcolor="#f8bbd0"];

    HGP          [label="Hepatic Glucose\nProduction (HGP)", shape=ellipse, fillcolor="#e91e63", fontcolor=white];
    glycogenol_H [label="Glycogenolysis\n(hepatic)"];
    gluconeo_H   [label="Gluconeogenesis\n(PEPCK, G6Pase)"];
    hep_glycogen [label="Hepatic\nGlycogen"];
    GK_liver     [label="Glucokinase\n(liver GK)"];
    PEPCK_enz    [label="PEPCK\n(gluconeo rate-limiter)"];
    G6Pase_enz   [label="G6Pase\n(glucose-6-phosphatase)"];
    FBPase2      [label="FBPase-2\n(fructose-2,6-BP)"];
    PGC1a_H      [label="PGC-1α\n(hepatic gluconeo)"];
    FOXO1_liver  [label="FOXO1\n(liver, drives PEPCK)"];
    hepatic_IR   [label="Hepatic Insulin\nResistance (↑HGP)"];
    NAFLD_node   [label="Hepatic Lipid\nAccumulation (NAFLD)"];
    VLDL_sec     [label="VLDL\nSecretion"];
    AMPK_liver   [label="AMPK (liver)\n[Met target]"];
    MetCI_target [label="Complex I Inhibition\n[Metformin MoA]"];
    autophagy_H  [label="Lipophagy /\nAutophagy"];
    glucagon_rec [label="Glucagon Receptor\n(liver)"];
  }

  // ============================================================
  // CLUSTER 5: Peripheral Glucose (Muscle / Adipose)
  // ============================================================
  subgraph cluster_periph {
    label="Peripheral Tissues — Skeletal Muscle & Adipose";
    style=filled; color="#80deea"; fillcolor="#e0f7fa";
    node [fillcolor="#b2ebf2"];

    muscle_uptake  [label="Skeletal Muscle\nGlucose Uptake (Rd)"];
    adipose_uptake [label="Adipose\nGlucose Uptake"];
    GLUT4_muscle   [label="GLUT4 (muscle)\ntranslocation"];
    GLUT4_adipose  [label="GLUT4 (adipose)\ntranslocation"];
    muscle_glycogen[label="Muscle\nGlycogen"];
    lactate_prod   [label="Lactate Production\n(anaerobic)"];
    lipolysis_AT   [label="Lipolysis\n(HSL, ATGL)"];
    FFA_release    [label="FFA Release\n(from adipocytes)"];
    adiponectin    [label="Adiponectin\n(anti-inflam adipokine)"];
    leptin_adipose [label="Leptin\n(satiety signal)"];
    TNFa_AT        [label="TNF-α\n(adipose)"];
    IL6_AT         [label="IL-6\n(adipose tissue)"];
    AMPK_muscle    [label="AMPK (muscle)\n[exercise/Met]"];
    ceramide_node  [label="Ceramide\n(lipotoxic intermediate)"];
    ROS_muscle     [label="Mitochondrial ROS\n(peripheral)"];
    PPARg_AT       [label="PPARγ\n[TZD target]"];
    adipogenesis   [label="Adipogenesis\n(PPARγ-driven)"];
    resistin       [label="Resistin"];
    visfatin       [label="Visfatin\n(NAMPT)"];
  }

  // ============================================================
  // CLUSTER 6: Glucose Compartments & Renal Handling
  // ============================================================
  subgraph cluster_gluc {
    label="Glucose Compartments & Renal Glucose Handling";
    style=filled; color="#dce775"; fillcolor="#f9fbe7";
    node [fillcolor="#f0f4c3"];

    Gp           [label="Plasma Glucose (Gp)\nmg/dL", shape=ellipse, fillcolor="#afb42b", fontcolor=white];
    Gt           [label="Tissue Glucose (Gt)\nmg/dL", shape=ellipse, fillcolor="#c0ca33"];
    Ra_gut       [label="Glucose Appearance\n(Ra, gut absorption)"];
    EGP_node     [label="Endogenous Glucose\nProduction (EGP)"];
    Rd_total     [label="Total Glucose\nDisposal (Rd)"];
    GFR_gluc     [label="Glomerular Glucose\nFiltration"];
    SGLT2_trans  [label="SGLT2\n(Na-glucose cotransporter-2)"];
    SGLT1_gut    [label="SGLT1\n(gut glucose absorption)"];
    Tm_glucose   [label="Tmax glucose\n(reabsorption capacity)"];
    UGE_node     [label="Urinary Glucose\nExcretion (UGE)"];
    RGT_node     [label="Renal Glucose\nThreshold (~180 mg/dL)"];
    osmotic_diur [label="Osmotic Diuresis\n(natriuresis)"];
    sodium_bal   [label="Sodium Balance\n(↓plasma volume)"];
    volume_stat  [label="Plasma Volume /\nBlood Pressure"];
    ketogenesis  [label="Ketogenesis\n(mild, SGLT2i-mediated)"];
    uric_acid    [label="Uric Acid\n(↓ by SGLT2i)"];
  }

  // ============================================================
  // CLUSTER 7: Diabetic Complications
  // ============================================================
  subgraph cluster_compl {
    label="Diabetic Complications & Vascular End-Organ Damage";
    style=filled; color="#bcaaa4"; fillcolor="#efebe9";
    node [fillcolor="#d7ccc8"];

    AGE_form    [label="AGE Formation\n(non-enzymatic glycation)"];
    RAGE_act    [label="RAGE Activation\n(receptor for AGE)"];
    hex_path    [label="Hexosamine\nPathway (O-GlcNAc)"];
    PKC_act     [label="PKC Activation\n(DAG→PKC)"];
    polyol_path [label="Polyol Pathway\n(aldose reductase)"];
    ox_vasc     [label="Vascular\nOxidative Stress"];
    eNOS_dysfn  [label="eNOS Dysfunction\n(↓NO)"];
    endo_dysfn  [label="Endothelial\nDysfunction"];
    intima_thick[label="Intimal\nThickening"];
    ASCVD_risk  [label="ASCVD Risk\n(MACE endpoint)", shape=ellipse, fillcolor="#6d4c41", fontcolor=white];
    UACR_clin   [label="UACR\n(μg/mg creatinine)", shape=ellipse, fillcolor="#6d4c41", fontcolor=white];
    eGFR_clin   [label="eGFR\n(mL/min/1.73m²)", shape=ellipse, fillcolor="#6d4c41", fontcolor=white];
    TGFb_kidney [label="TGF-β\n(renal fibrosis)"];
    mesangial_X [label="Mesangial\nExpansion"];
    tubular_inj [label="Tubular\nInjury (proximal)"];
    VEGF_retina [label="VEGF-A\n(retinal)"];
    retinal_perm[label="Retinal\nPermeability ↑"];
    neuro_sens  [label="Peripheral\nNeuropathy"];
    myelin_loss [label="Myelin Sheath\nLoss"];
    HbA1c_node  [label="HbA1c (%)\n(3-month glycemic avg)", shape=ellipse, fillcolor="#4e342e", fontcolor=white];
    ox_LDL      [label="ox-LDL\n(atherogenic)"];
    ICAM1_node  [label="ICAM-1 / VCAM-1\n(adhesion molecules)"];
    PAI1_node   [label="PAI-1\n(thrombotic risk)"];
    fibrinogen  [label="Fibrinogen\n(coagulation)"];
  }

  // ============================================================
  // CLUSTER 8: Hypothalamus / CNS Regulation
  // ============================================================
  subgraph cluster_cns {
    label="Hypothalamus & Central Nervous System Regulation";
    style=filled; color="#b39ddb"; fillcolor="#ede7f6";
    node [fillcolor="#d1c4e9"];

    hypo_IR     [label="Hypothalamic\nInsulin Resistance"];
    NPY_AgRP    [label="NPY/AgRP\n(orexigenic neurons)"];
    POMC_CART   [label="POMC/CART\n(anorexigenic neurons)"];
    food_intake [label="Food Intake\n(kcal/day)", shape=ellipse, fillcolor="#7e57c2", fontcolor=white];
    energy_exp  [label="Energy Expenditure\n(kcal/day)"];
    leptin_CNS  [label="Leptin Signaling\n(hypothalamus)"];
    GLP1R_brain [label="GLP-1R\n(brainstem/hypothalamus)"];
    vagal_efferents[label="Vagal Efferents\n(gut motility)"];
    satiety_sig [label="Satiety\nSignaling"];
    circadian   [label="Circadian Clock\n(CLOCK/BMAL1)"];
    cortisol_HPA[label="Cortisol\n(HPA axis)"];
    sympath_NS  [label="Sympathetic Tone\n(catecholamines)"];
    GE_rate     [label="Gastric Emptying\nRate"];
    ghrelin     [label="Ghrelin\n(hunger hormone)"];
  }

  // ============================================================
  // CLUSTER 9: Systemic Inflammation
  // ============================================================
  subgraph cluster_inflam {
    label="Systemic Low-Grade Inflammation";
    style=filled; color="#ffcc80"; fillcolor="#fff3e0";
    node [fillcolor="#ffe0b2"];

    ATM_macrophage [label="Adipose Tissue\nMacrophage (ATM, M1)"];
    MCP1_node   [label="MCP-1 (CCL2)\nchemokine"];
    NFkB_node   [label="NF-κB\n(master inflammatory TF)"];
    IL6_sys     [label="IL-6\n(systemic)"];
    CRP_node    [label="hsCRP\n(acute phase)"];
    IL18_node   [label="IL-18\n(NLRP3 product)"];
    FFA_TLR4    [label="FFA → TLR4\nActivation"];
    ox_LDL_inf  [label="ox-LDL →\nFoam Cell Formation"];
    ICAM1_inf   [label="Leukocyte\nAdhesion"];
    hepcidin    [label="Hepcidin\n(iron metabolism)"];
    adipsin     [label="Adipsin\n(complement D)"];
    IFNg_T      [label="IFN-γ\n(Th1 adipose)"];
  }

  // ============================================================
  // CLUSTER 10: Body Weight & Adiposity
  // ============================================================
  subgraph cluster_weight {
    label="Body Weight, Adiposity & Lipid Metabolism";
    style=filled; color="#9fa8da"; fillcolor="#e8eaf6";
    node [fillcolor="#c5cae9"];

    body_wt     [label="Body Weight (kg)", shape=ellipse, fillcolor="#3949ab", fontcolor=white];
    BMI_node    [label="BMI (kg/m²)"];
    VAT_node    [label="Visceral Adipose\nTissue (VAT)"];
    SAT_node    [label="Subcutaneous\nAdipose (SAT)"];
    lipolysis_B [label="Lipolysis\n(β-adrenergic, HSL)"];
    lipid_store [label="Lipid Storage\n(LPL-mediated)"];
    FFA_plasma  [label="Plasma FFA\n(NEFA)"];
    TG_plasma   [label="Plasma TG"];
    LDL_c       [label="LDL-C"];
    HDL_c       [label="HDL-C"];
    sdLDL       [label="Small Dense LDL\n(atherogenic)"];
    waist_circ  [label="Waist\nCircumference (cm)"];
    ketone_BHB  [label="β-hydroxybutyrate\n(ketone)"];
    CETP_node   [label="CETP\n(cholesterol ester transfer)"];
  }

  // ============================================================
  // EDGES — Drug PK connections
  // ============================================================

  D_met -> met_gut [label="oral dose"];
  met_gut -> C_met1 [label="ka_met=1.2/h\nF=55%"];
  C_met1 -> C_met2 [label="k12_met"];
  C_met2 -> C_met1 [label="k21_met"];
  C_met1 -> pk_CL_met [label="CL_met/Vc"];

  D_empa -> empa_gut [label="oral dose"];
  empa_gut -> C_empa [label="ka_empa=0.6/h\nF=86%"];
  C_empa -> pk_CL_empa [label="CL_empa/Vc"];

  D_sema -> C_sema_sc [label="SC inj"];
  C_sema_sc -> C_sema [label="ka_sema=0.01/h\nF=89%"];
  C_sema -> pk_CL_sema [label="CL_sema (low)"];

  D_dpp4i -> C_dpp4i [label="ka_dpp4i=0.8/h\nF=87%"];
  D_su -> C_su [label="ka_su=0.5/h"];
  D_ins -> C_ins_sc [label="SC depot"];
  C_ins_sc -> C_ins_exo [label="ka_ins=0.05/h\nhexamer→monomer"];
  D_piog -> C_piog [label="ka_piog=0.7/h"];

  // Drug → PD effects
  C_met1 -> MetCI_target [label="Complex I\ninhibition", style=dashed, color="#1565c0", arrowhead=tee];
  MetCI_target -> AMPK_liver [label="↓AMP/ATP →\nAMPK ↑"];
  C_empa -> SGLT2_trans [label="Km-based\ninhibition", style=dashed, color="#1565c0", arrowhead=tee];
  C_sema -> GLP1R_beta [label="GLP-1R\nagonism", style=dashed, color="#6a1b9a"];
  C_sema -> GLP1R_brain [label="CNS GLP-1R\nagonism", style=dashed, color="#6a1b9a"];
  C_dpp4i -> DPP4_plasma [label="competitive\ninhibition", style=dashed, color="#1565c0", arrowhead=tee];
  C_su -> SUR1_target [label="SUR1 closure\n→ KATP close", style=dashed, color="#1565c0"];
  C_ins_exo -> IR_rec [label="exogenous\ninsulin→IR", style=dashed, color="#1565c0"];
  C_piog -> PPARg_AT [label="PPARγ\nactivation", style=dashed, color="#1565c0"];

  // ============================================================
  // Incretin System Edges
  // ============================================================
  nutrient_sense -> L_cell [label="glucose/SCFA/fat\nstimulus"];
  nutrient_sense -> K_cell;
  portal_gluc -> L_cell [label="portal\nglucose"];
  vagal_signal -> L_cell [label="vagal\nstimulus"];
  L_cell -> GLP1_intact [label="secretion"];
  K_cell -> GIP_intact;
  DPP4_plasma -> GLP1_inactive [label="N-terminal\ncleavage"];
  GLP1_intact -> GLP1_inactive [label="DPP-4\ndegradation"];
  GLP1_intact -> GLP1_renal_CL [label="renal\nclearance"];
  GLP1_intact -> GLP1R_beta;
  GIP_intact -> GIPR_beta;
  GLP1_intact -> GLP1R_brain;
  GLP1R_beta -> cAMP_beta [label="Gs→AC\n→cAMP↑"];
  GIPR_beta -> cAMP_beta;
  cAMP_beta -> insulin_exo [label="PKA→\nexocytosis↑"];
  cAMP_beta -> beta_prolif [label="↑β-cell\nproliferation"];
  cAMP_beta -> beta_apop [arrowhead=tee, label="↓apoptosis"];
  GLP1R_brain -> satiety_sig;
  GLP1R_brain -> food_intake [arrowhead=tee, label="↓food intake"];
  GLP1R_brain -> GE_rate [arrowhead=tee, label="↓gastric\nemptying"];
  GE_rate -> Ra_gut [label="controls\nglucose abs"];

  // ============================================================
  // Pancreatic Islet Edges
  // ============================================================
  Gp -> gluc_sense_b [label="glucose\ntransport (GLUT2)"];
  gluc_sense_b -> GK_beta [label="glucose→\nG6P (GK)"];
  GK_beta -> KATP_chan [label="↑ATP/ADP\n→channel close"];
  KATP_chan -> Ca_influx [label="depolarization\n→VDCC open"];
  Ca_influx -> insulin_exo [label="Ca²⁺→\ngranule fusion"];
  SUR1_target -> KATP_chan [label="SU binding →\nchannel close"];
  insulin_bio -> insulin_gran [label="proinsulin\nprocessing"];
  insulin_gran -> insulin_exo;
  insulin_exo -> proinsulin;
  proinsulin -> C_peptide;
  beta_mass -> insulin_exo [label="mass × fxn\n→total capacity"];
  beta_func -> insulin_exo [label="modulatory"];
  beta_apop -> beta_mass [arrowhead=tee, label="mass loss"];
  beta_prolif -> beta_mass [label="↑mass"];
  ER_stress -> beta_apop [label="UPR→apoptosis"];
  ox_stress_b -> ER_stress;
  IL1b_islet -> NLRP3_inf;
  NLRP3_inf -> IL1b_islet [label="auto-amplif\nloop"];
  NLRP3_inf -> beta_apop;
  Gp -> ox_stress_b [label="glucotoxicity\n→ROS"];
  FFA_plasma -> ox_stress_b [label="lipotoxicity\n→β-cell ROS"];
  alpha_cell -> glucagon_Gc [label="secretion"];
  Gp -> alpha_cell [arrowhead=tee, label="↑Gp\n→↓glucagon"];
  GLP1R_beta -> alpha_cell [arrowhead=tee, label="↓glucagon\nfrom α-cell"];
  glucagon_Gc -> glucagon_rec [label="→liver"];
  beta_mass -> beta_func [label="mass-function\ncoupling"];

  // ============================================================
  // Insulin Signaling Edges
  // ============================================================
  IR_rec -> IRS1 [label="tyrosine phos\n(Y972, Y1158)"];
  IRS1 -> PI3K_p85;
  PI3K_p85 -> PDK1 [label="PIP₃→PDK1"];
  PDK1 -> Akt_PKB;
  Akt_PKB -> AS160 [label="pThr642\nactivation"];
  AS160 -> GLUT4_v [label="Rab10-GTP\nactivates"];
  GLUT4_v -> GLUT4_m [label="translocation\nto membrane"];
  Akt_PKB -> GSK3b [label="inhibition", arrowhead=tee];
  GSK3b -> GS_active [arrowhead=tee, label="disinhibit\nglycogen syn"];
  Akt_PKB -> FOXO1_n [label="pSer256\n→nuclear export", arrowhead=tee];
  FOXO1_n -> FOXO1_c [label="Akt-mediated\nexclusion"];
  PTP1B -> IR_rec [arrowhead=tee, label="dephosphoryl\n(resistance)"];
  mTORC1 -> S6K1;
  S6K1 -> IRS1_pSer [label="Ser307/636\n→inhibit IRS-1"];
  IRS1_pSer -> IRS1 [arrowhead=tee, label="feed-forward\nresistance"];
  PKCtheta -> IRS1_pSer [label="Ser307"];
  ceramide_node -> PKCtheta;
  TLR4_sig -> IKKb;
  IKKb -> IRS1_pSer;
  FFA_plasma -> TLR4_sig [label="NEFA→TLR4/MD2"];
  Akt_PKB -> FOXO1_liver [arrowhead=tee, label="hepatic\nFOXO1 exclusion"];

  // ============================================================
  // Hepatic Glucose Metabolism Edges
  // ============================================================
  HGP -> EGP_node [label="main source\nof EGP"];
  glycogenol_H -> HGP;
  gluconeo_H -> HGP;
  hep_glycogen -> glycogenol_H [label="glycogen\nbreakdown"];
  PEPCK_enz -> gluconeo_H;
  G6Pase_enz -> gluconeo_H;
  FBPase2 -> gluconeo_H;
  PGC1a_H -> PEPCK_enz [label="transcriptional\nactivation"];
  PGC1a_H -> G6Pase_enz;
  FOXO1_liver -> PGC1a_H;
  FOXO1_liver -> PEPCK_enz [label="G6P"];
  GK_liver -> hep_glycogen [label="glucose→G6P\n→glycogen"];
  Gp -> GK_liver;
  hepatic_IR -> gluconeo_H [label="↑gluconeo\n(IR-mediated)"];
  NAFLD_node -> hepatic_IR [label="lipotoxicity\n→↑IR"];
  NAFLD_node -> VLDL_sec;
  VLDL_sec -> TG_plasma;
  AMPK_liver -> gluconeo_H [arrowhead=tee, label="AMPK↑\n→gluconeo↓"];
  AMPK_liver -> NAFLD_node [arrowhead=tee, label="↓fat accum"];
  MetCI_target -> AMPK_liver;
  autophagy_H -> NAFLD_node [arrowhead=tee];
  FFA_plasma -> NAFLD_node [label="hepatic FFA\nuptake"];
  glucagon_rec -> PGC1a_H [label="glucagon→\ncAMP→PGC-1α"];
  glucagon_rec -> glycogenol_H [label="PKA→\nphosphorylase"];

  // ============================================================
  // Peripheral Tissue Edges
  // ============================================================
  GLUT4_m -> muscle_uptake;
  GLUT4_muscle -> muscle_uptake [label="insulin-mediated"];
  GLUT4_adipose -> adipose_uptake;
  muscle_uptake -> muscle_glycogen;
  muscle_uptake -> lactate_prod;
  lactate_prod -> gluconeo_H [label="lactate→\npyruvate (Cori)"];
  lipolysis_AT -> FFA_release;
  FFA_release -> FFA_plasma;
  adiponectin -> AMPK_muscle [label="adiponectin\nactivates AMPK"];
  adiponectin -> AMPK_liver;
  adiponectin -> hepatic_IR [arrowhead=tee, label="↓hepatic IR"];
  leptin_adipose -> NPY_AgRP [arrowhead=tee, label="leptin signal"];
  leptin_adipose -> POMC_CART;
  TNFa_AT -> IRS1_pSer [label="TNF-α→\nSer phos"];
  TNFa_AT -> NFkB_node;
  IL6_AT -> hepatic_IR [label="IL-6→SOCS3\n→IR"];
  IL6_AT -> IL6_sys;
  AMPK_muscle -> muscle_uptake [label="non-insulin\nGLUT4 transl"];
  ceramide_node -> ROS_muscle;
  ROS_muscle -> ox_stress_b;
  PPARg_AT -> adipogenesis [label="PPARγ→\ndifferentiation"];
  adipogenesis -> SAT_node;
  PPARg_AT -> adiponectin [label="↑adiponectin\nsecretion"];
  PPARg_AT -> TNFa_AT [arrowhead=tee, label="↓TNF-α"];
  resistin -> IR_rec [arrowhead=tee, label="↓insulin\nsignaling"];
  resistin -> hepatic_IR;
  visfatin -> IR_rec [label="insulin-like\neffect"];

  // ============================================================
  // Glucose Compartment Edges
  // ============================================================
  Ra_gut -> Gp [label="gut glucose\n→plasma"];
  EGP_node -> Gp [label="liver\noutput"];
  Gp -> Gt [label="mass action\ntransfer"];
  Gt -> Rd_total [label="tissue\nuptake"];
  muscle_uptake -> Rd_total;
  adipose_uptake -> Rd_total;
  Rd_total -> Gt [arrowhead=tee, label="removes\nfrom tissue"];
  Gp -> GFR_gluc [label="GFR × Gp\n(filtered load)"];
  GFR_gluc -> SGLT2_trans [label="filtered\nglucose"];
  SGLT2_trans -> Tm_glucose [label="cotransport\n→reabsorption"];
  Tm_glucose -> UGE_node [label="spill-over\nif Gp>RGT"];
  RGT_node -> UGE_node;
  SGLT1_gut -> Ra_gut [label="intestinal\nglucose abs"];
  UGE_node -> osmotic_diur [label="glucosuria→\nosmotic effect"];
  osmotic_diur -> sodium_bal;
  sodium_bal -> volume_stat;
  volume_stat -> ASCVD_risk [arrowhead=tee, label="↓BP→↓CV\nrisk"];
  SGLT2_trans -> ketogenesis [label="↓glucose →\n↑ketone prod"];
  ketogenesis -> ketone_BHB;
  UGE_node -> body_wt [arrowhead=tee, label="caloric loss\n~70g/d"];
  UGE_node -> uric_acid [arrowhead=tee, label="SGLT2i→\n↓uric acid"];

  // ============================================================
  // Complications Edges
  // ============================================================
  Gp -> AGE_form [label="non-enzymatic\nglycation"];
  AGE_form -> RAGE_act;
  RAGE_act -> NFkB_node;
  RAGE_act -> ox_vasc;
  Gp -> hex_path [label="hexosamine\npathway (>5%)"];
  Gp -> PKC_act [label="DAG\naccumulation"];
  Gp -> polyol_path [label="aldose\nreductase"];
  polyol_path -> ox_vasc [label="↓NADPH\n→ROS"];
  PKC_act -> ox_vasc;
  ox_vasc -> eNOS_dysfn;
  eNOS_dysfn -> endo_dysfn;
  endo_dysfn -> intima_thick;
  intima_thick -> ASCVD_risk;
  ox_LDL -> intima_thick;
  NFkB_node -> ICAM1_node;
  ICAM1_node -> intima_thick;
  PAI1_node -> ASCVD_risk;
  fibrinogen -> ASCVD_risk;
  Gp -> HbA1c_node [label="3-month\nglyco avg"];
  HbA1c_node -> UACR_clin [label="glycemic load\n→nephropathy"];
  HbA1c_node -> retinal_perm;
  HbA1c_node -> neuro_sens;
  ox_vasc -> TGFb_kidney;
  TGFb_kidney -> mesangial_X;
  mesangial_X -> UACR_clin;
  UACR_clin -> eGFR_clin [arrowhead=tee, label="progressive\nCKD"];
  TGFb_kidney -> tubular_inj;
  ox_vasc -> VEGF_retina;
  VEGF_retina -> retinal_perm;
  neuro_sens -> myelin_loss [label="axonal\ndegeneration"];

  // ============================================================
  // CNS / Hypothalamus Edges
  // ============================================================
  leptin_CNS -> NPY_AgRP [arrowhead=tee];
  leptin_CNS -> POMC_CART;
  hypo_IR -> NPY_AgRP [label="↑orexigenic\n(IR→leptin resist)"];
  NPY_AgRP -> food_intake [label="↑hunger\n↑appetite"];
  POMC_CART -> food_intake [arrowhead=tee, label="↓appetite"];
  satiety_sig -> food_intake [arrowhead=tee];
  food_intake -> body_wt;
  energy_exp -> body_wt [arrowhead=tee];
  GLP1R_brain -> satiety_sig;
  GLP1R_brain -> energy_exp [label="↑EE (BAT\nactivation)"];
  leptin_adipose -> leptin_CNS;
  vagal_signal -> GLP1R_brain [label="vagal afferent\naxis"];
  vagal_efferents -> GE_rate [label="↑vagal→\nslows GE"];
  circadian -> insulin_exo [label="circadian\noscillation of Ins"];
  circadian -> glucagon_Gc [label="dawn\nphenomenon"];
  cortisol_HPA -> hepatic_IR [label="cortisol→\nIR↑"];
  cortisol_HPA -> gluconeo_H [label="glucocorticoid\n→gluconeo↑"];
  sympath_NS -> alpha_cell [label="NE→α-cell\n→glucagon↑"];
  sympath_NS -> lipolysis_AT [label="β-adrenergic\n→lipolysis↑"];
  ghrelin -> NPY_AgRP [label="ghrelin→\nhunger↑"];
  ghrelin -> food_intake;

  // ============================================================
  // Systemic Inflammation Edges
  // ============================================================
  FFA_plasma -> FFA_TLR4;
  FFA_TLR4 -> NFkB_node [label="TLR4/MyD88\n→NF-κB"];
  NFkB_node -> IL6_sys;
  NFkB_node -> MCP1_node;
  NFkB_node -> PAI1_node;
  NFkB_node -> fibrinogen;
  NFkB_node -> IL18_node;
  IL18_node -> NLRP3_inf [label="IL-18/IL-1β\namplification"];
  IL6_sys -> CRP_node;
  IL6_sys -> hepatic_IR;
  MCP1_node -> ATM_macrophage [label="↑M1\nrecruitment"];
  ATM_macrophage -> TNFa_AT;
  ATM_macrophage -> IL6_AT;
  ATM_macrophage -> MCP1_node [label="amplification\nloop"];
  ATM_macrophage -> IL1b_islet [label="macrophage→\nβ-cell IL-1β"];
  ox_LDL_inf -> ATM_macrophage [label="foam cell\nformation"];
  ICAM1_inf -> ASCVD_risk;
  adipsin -> complement_act [label="complement\nactivation"];
  complement_act [label="Complement\nActivation (C3a/C5a)"];
  IFNg_T -> ATM_macrophage [label="Th1→M1\npolarization"];

  // ============================================================
  // Body Weight / Adiposity Edges
  // ============================================================
  body_wt -> BMI_node;
  body_wt -> VAT_node;
  body_wt -> SAT_node;
  VAT_node -> FFA_plasma [label="portal FFA\nefflux"];
  VAT_node -> adiponectin [arrowhead=tee, label="↓adiponectin"];
  VAT_node -> TNFa_AT;
  VAT_node -> resistin;
  VAT_node -> IL6_AT;
  lipolysis_B -> FFA_release;
  lipid_store -> lipolysis_B [arrowhead=tee];
  FFA_plasma -> TG_plasma;
  TG_plasma -> CETP_node [label="CETP-mediated\nCE transfer"];
  CETP_node -> LDL_c;
  CETP_node -> HDL_c [arrowhead=tee, label="↓HDL"];
  LDL_c -> sdLDL [label="TG exchange\n→sdLDL↑"];
  sdLDL -> ox_LDL [label="oxidation"];
  HDL_c -> ASCVD_risk [arrowhead=tee, label="protective"];
  LDL_c -> ASCVD_risk;
  body_wt -> waist_circ;
  ketone_BHB -> energy_exp [label="ketone\nmetab"];

  // ============================================================
  // Cross-Cluster Critical Links
  // ============================================================
  // Insulin secretion → plasma insulin
  insulin_exo -> Ip_plasma [label="portal\nsecretion"];
  C_ins_exo -> Ip_plasma [label="exogenous\naddition"];
  Ip_plasma [label="Plasma Insulin (Ip)\nmU/L", shape=ellipse, fillcolor="#e65100", fontcolor=white];
  Ip_plasma -> IR_rec [label="→IR activation"];
  Ip_plasma -> X_action [label="remote compartment\n(insulin action)"];
  X_action [label="Remote Insulin\nAction (X)"];
  X_action -> Rd_total [label="Rd = Rd_basal +\nSI×X×Gt"];
  X_action -> HGP [arrowhead=tee, label="↓HGP"];
  glucagon_Gc -> EGP_node [label="glucagon\n→↑EGP"];
  Ip_plasma -> glucagon_Gc [arrowhead=tee, label="paracrine\n↓glucagon"];
  Ip_plasma -> lipolysis_AT [arrowhead=tee, label="anti-lipolytic"];
  Ip_plasma -> adipogenesis [label="lipogenesis\nstimulation"];

  // Glucose → insulin feedback
  Gp -> insulin_exo [label="glucose-stimulated\ninsulin secretion (GSIS)"];
  Gp -> beta_func [label="chronic hyperglycemia\n→glucotoxicity"];

  // Weight → IR feedback
  VAT_node -> hepatic_IR;
  VAT_node -> IRS1_pSer [label="VAT→FFA\n→ceramide→PKCθ"];
  body_wt -> hypo_IR [label="obesity→\nhypo IR"];

  // HbA1c endpoint
  Gp -> HbA1c_node;
  Ip_plasma -> HbA1c_node [arrowhead=tee, label="↑Ins →\n↓HbA1c"];
}
