digraph BLCA_QSP {
  graph [
    label="방광암 (Urothelial Bladder Cancer — BLCA)\nQSP Mechanistic Map"
    labelloc=t fontname="Helvetica-Bold" fontsize=18
    rankdir=LR splines=polyline overlap=false
    nodesep=0.35 ranksep=1.2 bgcolor="#FAFAFA"
    compound=true
  ]
  node [fontname="Helvetica" fontsize=9 style="filled,rounded" shape=box]
  edge [fontname="Helvetica" fontsize=7.5 arrowsize=0.7]

  // ==================== CLUSTER 1: Risk Factors ====================
  subgraph cluster_risk {
    label="위험 인자\n(Risk Factors)"
    style=filled fillcolor="#FFF3E0" color="#BF360C" fontcolor="#BF360C" fontsize=11
    Smoking      [label="흡연\n(Smoking)" fillcolor="#FFCC80"]
    Arylamines   [label="방향족 아민\n(Arylamines, 4-ABP)" fillcolor="#FFCC80"]
    Acrolein     [label="아크롤레인\n(Acrolein, Urinary Metabolite)" fillcolor="#FFCC80"]
    OccExposure  [label="직업적 노출\n(Benzidine, 2-Naphthylamine)" fillcolor="#FFCC80"]
    Arsenic      [label="비소 노출\n(Arsenic in Drinking Water)" fillcolor="#FFCC80"]
    PelvicRad    [label="골반 방사선 과거력\n(Prior Pelvic Radiation)" fillcolor="#FFCC80"]
    CycloPhos    [label="사이클로포스파미드\n(Prior Cyclophosphamide)" fillcolor="#FFCC80"]
    ChronicUTI   [label="만성 요로감염/주혈흡충\n(Chronic UTI/Schistosoma haematobium)" fillcolor="#FFCC80"]
    MaleAge      [label="남성·고령 (>60세)\n(Male Sex, Age>60)" fillcolor="#FFCC80"]
    GeneticSusc  [label="유전 다형성\n(NAT2, GSTM1, GSTT1 polymorphisms)" fillcolor="#FFCC80"]
  }

  // ==================== CLUSTER 2: Molecular Alterations ====================
  subgraph cluster_molecular {
    label="분자 변이\n(Molecular Alterations)"
    style=filled fillcolor="#E8F5E9" color="#1B5E20" fontcolor="#1B5E20" fontsize=11
    FGFR3mut   [label="FGFR3 돌연변이/융합\n(FGFR3 mut/fusion, ~60% NMIBC)" fillcolor="#A5D6A7"]
    TP53mut    [label="TP53 변이\n(TP53, ~50% MIBC)" fillcolor="#A5D6A7"]
    RB1del     [label="RB1 소실\n(RB1 Deletion, ~25%)" fillcolor="#A5D6A7"]
    CDKN2Adel  [label="CDKN2A(p16) 소실\n(CDKN2A Deletion, ~50%)" fillcolor="#A5D6A7"]
    PIK3CAmut  [label="PIK3CA 변이\n(PIK3CA, ~20%)" fillcolor="#A5D6A7"]
    ERBB2amp   [label="HER2/ERBB2 증폭\n(HER2 Amplification, ~15%)" fillcolor="#A5D6A7"]
    MYCamp     [label="MYC 증폭\n(MYC Amplification)" fillcolor="#A5D6A7"]
    KDM6Amut   [label="KDM6A(UTX) 변이\n(Chromatin Remodeling, ~30%)" fillcolor="#A5D6A7"]
    STAG2mut   [label="STAG2 변이\n(Cohesin Complex, ~35%)" fillcolor="#A5D6A7"]
    TERT_prom  [label="TERT 프로모터 변이\n(TERT Promoter Mutation, ~65%)" fillcolor="#A5D6A7"]
    Nectin4hi  [label="Nectin-4 고발현\n(Nectin-4/PVRL4 High Expression)" fillcolor="#81C784"]
    TROP2hi    [label="TROP2 고발현\n(TROP2/TACSTD2 High)" fillcolor="#81C784"]
    PDL1expr   [label="PD-L1(CD274) 발현\n(PD-L1 Expression)" fillcolor="#81C784"]
    MSIstat    [label="MSI-H / TMB-H\n(Microsatellite Instability-High)" fillcolor="#66BB6A"]
  }

  // ==================== CLUSTER 3: Oncogenic Signaling ====================
  subgraph cluster_signaling {
    label="종양 신호 전달\n(Oncogenic Signaling)"
    style=filled fillcolor="#E3F2FD" color="#0D47A1" fontcolor="#0D47A1" fontsize=11
    FGFR3sig   [label="FGFR3-RAS 신호\n(FGFR3 Signaling Cascade)" fillcolor="#90CAF9"]
    RASact     [label="RAS 활성화\n(RAS/RAF)" fillcolor="#90CAF9"]
    MAPKpath   [label="MEK/ERK 경로\n(MAPK Proliferation Pathway)" fillcolor="#90CAF9"]
    PI3Kpath   [label="PI3K/AKT/mTOR\n(Survival and Growth)" fillcolor="#90CAF9"]
    STAT3sig   [label="JAK/STAT3 활성화\n(STAT3 Oncogenic Signaling)" fillcolor="#90CAF9"]
    NFkBtumor  [label="NF-κB (종양)\n(Tumor NF-κB Survival)" fillcolor="#90CAF9"]
    WNTsig     [label="Wnt/β-카테닌\n(Wnt/β-catenin Pathway)" fillcolor="#90CAF9"]
    p53loss    [label="p53 기능 상실\n(p53 Loss of Function)" fillcolor="#90CAF9"]
    BCL2sig    [label="BCL-2/BCL-XL\n(Anti-apoptotic Proteins)" fillcolor="#90CAF9"]
    CyclD1     [label="사이클린 D1(CCND1)\n(G1/S Cell Cycle Driver)" fillcolor="#64B5F6"]
    CellCycle  [label="세포 주기 진행\n(G1→S→G2/M Progression)" fillcolor="#64B5F6"]
    Proliferat [label="종양 세포 증식\n(Tumor Proliferation, kgrow)" fillcolor="#42A5F5"]
    Apop_inh   [label="세포사멸 억제\n(Apoptosis Inhibition)" fillcolor="#90CAF9"]
    EMT        [label="상피-간질 전환\n(EMT, Invasion/Migration)" fillcolor="#1E88E5"]
    Angiogen   [label="혈관신생\n(VEGF-driven Angiogenesis)" fillcolor="#1E88E5"]
  }

  // ==================== CLUSTER 4: Tumor Microenvironment ====================
  subgraph cluster_tme {
    label="종양 미세환경\n(Tumor Microenvironment)"
    style=filled fillcolor="#FCE4EC" color="#880E4F" fontcolor="#880E4F" fontsize=11
    TumorCells   [label="종양 세포\n(Tumor Cells, T(t))" fillcolor="#F48FB1"]
    MDSC_tme     [label="MDSC\n(Myeloid-derived Suppressor Cells)" fillcolor="#F48FB1"]
    Treg_tme     [label="조절 T세포\n(Regulatory T cells, Foxp3+)" fillcolor="#F48FB1"]
    TAM_M2       [label="M2 TAM\n(Tumor-associated Macrophage, M2)" fillcolor="#F48FB1"]
    CAF_tme      [label="암 관련 섬유아세포\n(Cancer-associated Fibroblasts)" fillcolor="#F48FB1"]
    TGFb_tme     [label="TGF-β\n(Immunosuppressive Cytokine)" fillcolor="#F48FB1"]
    IL10_tme     [label="IL-10\n(Anti-inflammatory Cytokine)" fillcolor="#F48FB1"]
    VEGF_tme     [label="VEGF\n(Vascular Endothelial Growth Factor)" fillcolor="#EC407A"]
    IDO1_tme     [label="IDO1\n(Tryptophan→Kynurenine Pathway)" fillcolor="#F48FB1"]
    Hypoxia_tme  [label="저산소증 (HIF-1α)\n(Tumor Hypoxia)" fillcolor="#F48FB1"]
    Btme         [label="종양 침윤 B세포\n(Tumor-infiltrating B cells, Breg)" fillcolor="#F48FB1"]
    NeutroTME    [label="종양 연관 호중구\n(Tumor-associated Neutrophils)" fillcolor="#F48FB1"]
  }

  // ==================== CLUSTER 5: Immune System ====================
  subgraph cluster_immune {
    label="면역 반응\n(Immune System)"
    style=filled fillcolor="#F3E5F5" color="#4A148C" fontcolor="#4A148C" fontsize=11
    BCGstim    [label="BCG 면역자극\n(BCG Immunostimulation, TLR)" fillcolor="#CE93D8"]
    TLR2_4     [label="TLR2/TLR4 활성화\n(Pattern Recognition Receptors)" fillcolor="#CE93D8"]
    DC_mature  [label="수지상 세포 성숙\n(DC Maturation, Antigen Presentation)" fillcolor="#CE93D8"]
    IL12_imm   [label="IL-12\n(Th1 Polarization Cytokine)" fillcolor="#CE93D8"]
    IL2_imm    [label="IL-2\n(T cell Proliferation)" fillcolor="#CE93D8"]
    CD4_Th1    [label="CD4+ Th1 세포\n(IFN-γ Producer)" fillcolor="#BA68C8"]
    CD8_eff    [label="CD8+ CTL\n(Cytotoxic T Lymphocytes)" fillcolor="#AB47BC"]
    NK_cells   [label="NK 세포\n(Natural Killer Cells)" fillcolor="#CE93D8"]
    IFNg_imm   [label="IFN-γ\n(Anti-tumor, PD-L1 Inducer)" fillcolor="#9C27B0"]
    TNFa_imm   [label="TNF-α\n(Cytotoxic Cytokine)" fillcolor="#CE93D8"]
    CTLA4_expr [label="CTLA-4\n(Early Checkpoint, Ipilimumab Target)" fillcolor="#CE93D8"]
    PD1_expr   [label="PD-1\n(T cell Exhaustion Marker)" fillcolor="#CE93D8"]
    LAG3_expr  [label="LAG-3\n(Co-inhibitory Receptor)" fillcolor="#CE93D8"]
    TIM3_expr  [label="TIM-3\n(Late Exhaustion Marker)" fillcolor="#CE93D8"]
  }

  // ==================== CLUSTER 6: Drug PK — BCG & Chemotherapy ====================
  subgraph cluster_pk_conv {
    label="약동학 — BCG & 화학요법\n(PK — BCG & Chemotherapy)"
    style=filled fillcolor="#FFFDE7" color="#E65100" fontcolor="#E65100" fontsize=11
    BCG_depot  [label="BCG (방광 내 주입)\n(BCG 81mg Intravesical)" fillcolor="#FFF176"]
    BCG_eff    [label="BCG 방광벽 효과\n(BCG Bladder Wall Effect Conc.)" fillcolor="#FFF176"]
    Cis_plasm  [label="시스플라틴 혈중농도\n(Cisplatin 70mg/m² IV)" fillcolor="#FFF176"]
    Gem_plasm  [label="젬시타빈 혈중농도\n(Gemcitabine 1000mg/m² IV)" fillcolor="#FFF176"]
    Cis_DNA    [label="Pt-DNA 부가물\n(Cisplatin-DNA Adducts)" fillcolor="#FFD54F"]
    Gem_act    [label="dFdCTP (활성 대사체)\n(Gemcitabine Triphosphate)" fillcolor="#FFD54F"]
  }

  // ==================== CLUSTER 7: Drug PK — Checkpoint Inhibitors ====================
  subgraph cluster_pk_io {
    label="약동학 — 면역관문 억제제\n(PK — Checkpoint Inhibitors)"
    style=filled fillcolor="#E0F7FA" color="#004D40" fontcolor="#004D40" fontsize=11
    Pembro_c   [label="펨브롤리주맙 중심 구획\n(Pembrolizumab 200mg q3w, Central)" fillcolor="#80DEEA"]
    Pembro_p   [label="펨브롤리주맙 말초 구획\n(Pembrolizumab Peripheral)" fillcolor="#80DEEA"]
    Atezo_c    [label="아테졸리주맙 중심 구획\n(Atezolizumab 1200mg q3w, Central)" fillcolor="#80DEEA"]
    Atezo_p    [label="아테졸리주맙 말초 구획\n(Atezolizumab Peripheral)" fillcolor="#80DEEA"]
    Pembro_RO  [label="펨브롤리주맙 PD-1 RO\n(PD-1 Receptor Occupancy)" fillcolor="#4DD0E1"]
    Atezo_RO   [label="아테졸리주맙 PD-L1 RO\n(PD-L1 Receptor Occupancy)" fillcolor="#4DD0E1"]
  }

  // ==================== CLUSTER 8: Drug PK — Targeted & ADC ====================
  subgraph cluster_pk_tgt {
    label="약동학 — 표적 치료제 & ADC\n(PK — Targeted Therapies & ADCs)"
    style=filled fillcolor="#EFEBE9" color="#3E2723" fontcolor="#3E2723" fontsize=11
    Erda_dep   [label="에르다피티닙 흡수 구획\n(Erdafitinib 8mg PO QD depot)" fillcolor="#D7CCC8"]
    Erda_plasm [label="에르다피티닙 혈중농도\n(Erdafitinib Plasma, FGFR1-4 inhib)" fillcolor="#D7CCC8"]
    EnFV_c     [label="엔포르투맙 베도틴\n(Enfortumab Vedotin 1.25mg/kg IV)" fillcolor="#D7CCC8"]
    EV_Nectin4 [label="EV-Nectin4 복합체\n(EV–Nectin-4 Internalized Complex)" fillcolor="#BCAAA4"]
    MMAE_ic    [label="MMAE 세포 내 농도\n(MMAE Intracellular, Tubulin Disrupt)" fillcolor="#BCAAA4"]
    SG_c       [label="사시투주맙 고비테칸\n(Sacituzumab Govitecan 10mg/kg IV)" fillcolor="#D7CCC8"]
    SG_TROP2   [label="SG-TROP2 복합체\n(SG–TROP2 Internalized)" fillcolor="#BCAAA4"]
    SN38_ic    [label="SN-38 세포 내\n(SN-38 Intracellular, TopoisomeraseI)" fillcolor="#BCAAA4"]
  }

  // ==================== CLUSTER 9: PD Effects ====================
  subgraph cluster_pd {
    label="약력학 / 종양 반응\n(Pharmacodynamics — Tumor Kill)"
    style=filled fillcolor="#E8EAF6" color="#1A237E" fontcolor="#1A237E" fontsize=11
    Kill_BCG   [label="BCG 매개 종양 사멸\n(BCG-mediated Tumor Kill)" fillcolor="#9FA8DA"]
    Kill_Chemo [label="화학요법 종양 사멸\n(GC Chemotherapy Kill)" fillcolor="#9FA8DA"]
    Kill_IO    [label="CTL 매개 면역 사멸\n(IO-enhanced CTL Tumor Kill)" fillcolor="#7986CB"]
    Kill_Erda  [label="FGFR 억제 종양 사멸\n(Erdafitinib FGFR Kill)" fillcolor="#9FA8DA"]
    Kill_EV    [label="EV-ADC 종양 사멸\n(Enfortumab Vedotin Kill)" fillcolor="#9FA8DA"]
    Kill_SG    [label="SG-ADC 종양 사멸\n(Sacituzumab Govitecan Kill)" fillcolor="#9FA8DA"]
    ImmuneRes  [label="면역 회복\n(IO: PD-1/PD-L1 Blockade → CTL)" fillcolor="#5C6BC0"]
    TumShrink  [label="종양 감소\n(Tumor Burden Decrease, SLD↓)" fillcolor="#3949AB"]
    ResistMech [label="내성 기전\n(Antigen Loss, EMT, PD-L1↑, TME remodel)" fillcolor="#9FA8DA"]
  }

  // ==================== CLUSTER 10: Clinical Outcomes ====================
  subgraph cluster_outcomes {
    label="임상 결과\n(Clinical Outcomes)"
    style=filled fillcolor="#FFEBEE" color="#B71C1C" fontcolor="#B71C1C" fontsize=11
    NMIBC_s    [label="비침습성 방광암\n(NMIBC: Ta/T1/CIS)" fillcolor="#FFCDD2"]
    MIBC_s     [label="근층 침습성 방광암\n(MIBC: T2-T4a)" fillcolor="#FFCDD2"]
    Metastatic [label="전이성 방광암\n(Metastatic UBC, Stage IV)" fillcolor="#EF9A9A"]
    CRR_out    [label="완전 반응률\n(CRR — BCG NMIBC)" fillcolor="#FFCDD2"]
    ORR_out    [label="객관적 반응률\n(ORR — advanced UBC)" fillcolor="#FFCDD2"]
    RFS_out    [label="재발 없는 생존\n(Recurrence-free Survival, RFS)" fillcolor="#FFCDD2"]
    PFS_out    [label="무진행 생존\n(Progression-free Survival, PFS)" fillcolor="#FFCDD2"]
    OS_out     [label="전체 생존\n(Overall Survival, OS)" fillcolor="#EF9A9A"]
    BladPres   [label="방광 보존율\n(Bladder Preservation Rate)" fillcolor="#FFCDD2"]
    Cystoscopy [label="방광경 종양 부담\n(Cystoscopy Tumor Burden, SLD)" fillcolor="#FFCDD2"]
  }

  // ==================== CLUSTER 11: Biomarkers ====================
  subgraph cluster_bio {
    label="바이오마커\n(Biomarkers)"
    style=filled fillcolor="#F1F8E9" color="#33691E" fontcolor="#33691E" fontsize=11
    FGFR3_ctDNA  [label="소변 FGFR3 ctDNA\n(Urinary FGFR3 Mutation ctDNA)" fillcolor="#DCEDC8"]
    Plasma_ctDNA [label="혈중 ctDNA\n(Plasma ctDNA Tumor Fraction)" fillcolor="#DCEDC8"]
    NMP22_bio    [label="NMP22 소변\n(NMP22 Urinary Marker)" fillcolor="#DCEDC8"]
    PDL1_IHC     [label="PD-L1 IHC\n(CPS/TC Score — KEYNOTE-045)" fillcolor="#DCEDC8"]
    TMB_bio      [label="TMB-H\n(Tumor Mutational Burden High)" fillcolor="#DCEDC8"]
    Nectin4_IHC  [label="Nectin-4 IHC\n(EV Eligibility: H-score)" fillcolor="#DCEDC8"]
    TROP2_IHC    [label="TROP2 IHC\n(SG Eligibility: H-score)" fillcolor="#DCEDC8"]
    CRP_bio      [label="혈청 CRP\n(Serum C-reactive Protein)" fillcolor="#DCEDC8"]
    Fibronectin  [label="소변 피브로넥틴\n(Urinary Fibronectin)" fillcolor="#DCEDC8"]
  }

  // ========================= EDGES =========================

  // Risk → Molecular
  Smoking -> Arylamines [label="combustion\nproducts"]
  Smoking -> Acrolein
  Arylamines -> FGFR3mut
  Arylamines -> TP53mut
  Acrolein   -> TP53mut
  OccExposure -> FGFR3mut
  OccExposure -> TP53mut
  Arsenic -> TP53mut
  Arsenic -> RB1del
  PelvicRad -> RB1del
  PelvicRad -> CDKN2Adel
  CycloPhos -> TP53mut
  ChronicUTI -> PIK3CAmut [label="chronic\ninflammation"]
  MaleAge -> FGFR3mut [label="sex/age\nbias"]
  GeneticSusc -> FGFR3mut [label="carcinogen\nactivation"]
  GeneticSusc -> TP53mut

  // Molecular → Signaling
  FGFR3mut  -> FGFR3sig [label="gain-of-function"]
  FGFR3sig  -> RASact -> MAPKpath -> Proliferat
  FGFR3sig  -> PI3Kpath
  PIK3CAmut -> PI3Kpath -> Proliferat
  PI3Kpath  -> Apop_inh
  PI3Kpath  -> BCL2sig -> Apop_inh
  ERBB2amp  -> MAPKpath
  ERBB2amp  -> STAT3sig -> Proliferat
  MYCamp    -> Proliferat
  TERT_prom -> Proliferat [label="telomere\nmaintain"]
  KDM6Amut  -> TP53mut [style=dashed label="chromatin\nremodel"]
  TP53mut   -> p53loss -> CellCycle -> Proliferat
  p53loss   -> Apop_inh
  RB1del    -> CellCycle
  CDKN2Adel -> CyclD1 [label="CDK4/6\nde-repressed"]
  CyclD1    -> CellCycle
  NFkBtumor -> Proliferat
  NFkBtumor -> Apop_inh
  WNTsig    -> Proliferat
  WNTsig    -> EMT [label="β-catenin\nnuclear"]
  STAT3sig  -> BCL2sig
  Proliferat -> TumorCells
  EMT       -> TumorCells [label="invasion"]
  EMT       -> Metastatic [label="distant\nspread"]

  // Tumor → TME
  TumorCells -> VEGF_tme [label="HIF-1α"]
  TumorCells -> TGFb_tme
  TumorCells -> IL10_tme
  TumorCells -> IDO1_tme
  TumorCells -> PDL1expr [label="IFN-γ\ninduction"]
  TumorCells -> Hypoxia_tme
  Hypoxia_tme -> VEGF_tme
  Hypoxia_tme -> IDO1_tme
  VEGF_tme   -> Angiogen
  VEGF_tme   -> CAF_tme [label="stroma\nrecruitment"]
  CAF_tme    -> TGFb_tme
  TGFb_tme   -> MDSC_tme [label="recruit/\nexpand"]
  TGFb_tme   -> Treg_tme [label="induce\nFoxp3+"]
  IL10_tme   -> MDSC_tme
  IL10_tme   -> TAM_M2 [label="M2\npolarize"]
  IDO1_tme   -> Treg_tme [label="kynurenine\ndrive"]
  TAM_M2     -> IL10_tme [label="M2 secrete"]
  TAM_M2     -> TGFb_tme
  NeutroTME  -> TGFb_tme
  Btme       -> IL10_tme [label="Breg\nfunction" style=dashed]

  // TME → immune suppression
  MDSC_tme -> CD8_eff [label="suppress CTL" color="#AD1457"]
  Treg_tme -> CD8_eff [label="suppress" color="#AD1457" constraint=false]
  TGFb_tme -> CD8_eff [label="inhibit" color="#AD1457" constraint=false]

  // Immune activation
  BCGstim -> TLR2_4 -> DC_mature
  DC_mature -> IL12_imm -> CD4_Th1 -> IL2_imm -> CD8_eff
  CD4_Th1   -> IFNg_imm
  CD8_eff   -> IFNg_imm
  NK_cells  -> TNFa_imm -> Kill_BCG
  NK_cells  -> IFNg_imm
  IFNg_imm  -> PDL1expr [label="IFN-γ\nupregulates\nPD-L1"]
  IFNg_imm  -> Kill_BCG
  IFNg_imm  -> Kill_IO
  MSIstat   -> TMB_bio [label="high\nneoantigen"]
  MSIstat   -> CD8_eff [label="neoantigen\nload"]

  // T cell exhaustion
  PD1_expr  -> CD8_eff [label="exhaust" color="#AD1457" constraint=false]
  PDL1expr  -> PD1_expr [label="engage\ncheckpoint" constraint=false]
  LAG3_expr -> CD8_eff [label="co-inhibit" color="#AD1457" constraint=false]
  TIM3_expr -> CD8_eff [label="co-inhibit" color="#AD1457" constraint=false]
  CTLA4_expr -> DC_mature [label="block\nco-stimul" color="#AD1457" constraint=false]

  // ---- BCG PK ----
  BCG_depot -> BCG_eff [label="kabs_BCG\n(bladder wall)"]
  BCG_eff   -> BCGstim [label="TLR activation"]
  BCG_eff   -> Kill_BCG

  // ---- Chemo PK ----
  Cis_plasm -> Cis_DNA  [label="DNA crosslink"]
  Gem_plasm -> Gem_act  [label="phosphorylation\n→ dFdCTP"]
  Cis_DNA   -> Kill_Chemo
  Gem_act   -> Kill_Chemo

  // ---- IO PK ----
  Pembro_c -> Pembro_p [label="CL2 dist" constraint=false]
  Pembro_p -> Pembro_c [label="redist" constraint=false]
  Pembro_c -> Pembro_RO [label="PD-1 binding"]
  Atezo_c  -> Atezo_p  [label="CL2 dist" constraint=false]
  Atezo_p  -> Atezo_c  [label="redist" constraint=false]
  Atezo_c  -> Atezo_RO [label="PD-L1 binding"]
  Pembro_RO -> ImmuneRes [label="PD-1\nblockade"]
  Atezo_RO  -> ImmuneRes [label="PD-L1\nblockade"]
  ImmuneRes -> CD8_eff [label="CTL rescue" constraint=false]
  ImmuneRes -> Kill_IO

  // ---- Erdafitinib PK ----
  Erda_dep   -> Erda_plasm [label="oral Fabs~70%"]
  Erda_plasm -> FGFR3sig   [label="FGFR1-4\ninhibition" color="#0D47A1"]
  FGFR3sig   -> Kill_Erda  [constraint=false]

  // ---- Enfortumab vedotin PK ----
  EnFV_c   -> EV_Nectin4 [label="Nectin-4 bind"]
  Nectin4hi -> EV_Nectin4
  EV_Nectin4 -> MMAE_ic  [label="internalize/\nprotease cleavage"]
  MMAE_ic    -> Kill_EV   [label="tubulin\ndisruption"]

  // ---- Sacituzumab govitecan PK ----
  SG_c     -> SG_TROP2  [label="TROP2 bind"]
  TROP2hi  -> SG_TROP2
  SG_TROP2 -> SN38_ic   [label="internalize\n/pH cleavage"]
  SN38_ic  -> Kill_SG   [label="TopoisomeraseI\ninhibit"]

  // PD → Tumor burden
  Kill_BCG   -> TumShrink
  Kill_Chemo -> TumShrink
  Kill_IO    -> TumShrink
  Kill_Erda  -> TumShrink
  Kill_EV    -> TumShrink
  Kill_SG    -> TumShrink
  TumShrink  -> TumorCells [label="reduce" constraint=false]
  TumorCells -> ResistMech [label="clonal\nevolution" constraint=false]
  ResistMech -> PFS_out    [label="limit\nbenefit" constraint=false]

  // Clinical staging
  TumorCells -> NMIBC_s [label="early\nstage"]
  EMT        -> MIBC_s
  MIBC_s     -> Metastatic [label="stage\nprogression" constraint=false]

  // Clinical outcomes
  NMIBC_s    -> RFS_out
  TumShrink  -> CRR_out  [label="NMIBC\ncomplete\nresponse"]
  TumShrink  -> ORR_out  [label="advanced\nUBC response"]
  ORR_out    -> PFS_out
  PFS_out    -> OS_out   [constraint=false]
  TumorCells -> Cystoscopy
  Cystoscopy -> CRR_out
  CRR_out    -> BladPres

  // Biomarkers
  FGFR3mut    -> FGFR3_ctDNA
  TumorCells  -> Plasma_ctDNA
  TumorCells  -> NMP22_bio
  PDL1expr    -> PDL1_IHC
  MSIstat     -> TMB_bio
  Nectin4hi   -> Nectin4_IHC
  TROP2hi     -> TROP2_IHC
  TGFb_tme    -> CRP_bio
  TumorCells  -> Fibronectin

  // Nectin-4/TROP2 expressed on tumor cells
  TumorCells  -> Nectin4hi
  TumorCells  -> TROP2hi

  // IFN-gamma → BCG amplification
  IFNg_imm -> BCGstim [label="amplify" constraint=false]

  // Biomarker → treatment eligibility (dashed)
  FGFR3_ctDNA -> Erda_dep  [label="FGFR-altered\npatient" style=dashed color="#0D47A1"]
  PDL1_IHC    -> Pembro_c  [label="CPS≥10\nselection" style=dashed color="#004D40"]
  Nectin4_IHC -> EnFV_c    [label="Nectin-4+\nselection" style=dashed color="#3E2723"]
  TROP2_IHC   -> SG_c      [label="TROP2+\nselection" style=dashed color="#3E2723"]
}
