digraph BPH_QSP {
    rankdir=LR;
    graph [fontname="Helvetica", fontsize=11, splines=ortho, nodesep=0.4, ranksep=0.8, bgcolor="#FAFAFA"];
    node  [fontname="Helvetica", fontsize=9, shape=box, style=filled, fillcolor=white, margin="0.12,0.06"];
    edge  [fontname="Helvetica", fontsize=8];

    /* ================================================================
       CLUSTER 1 — Hormonal / HPG Axis
    ================================================================ */
    subgraph cluster_hormonal {
        label="Hormonal / HPG Axis";
        style=filled; fillcolor="#FFF5EE"; color="#CC6600"; fontsize=12; fontcolor="#CC6600";

        GnRH            [label="GnRH\n(hypothalamus)",  fillcolor="#FFD700", style=filled];
        LH              [label="LH\n(pituitary)",       fillcolor="#FFD700", style=filled];
        Testosterone    [label="Testosterone\n(total)",  fillcolor="#FFD700", style=filled];
        SHBG            [label="SHBG",                  fillcolor="#90EE90", style=filled];
        free_T          [label="Free Testosterone",     fillcolor="#90EE90", style=filled];
        Leydig_cells    [label="Leydig Cells\n(testes)"];
        adrenal_DHEA    [label="Adrenal DHEA"];
        aromatase       [label="Aromatase\n(CYP19A1)",  fillcolor="#FFD700", style=filled];
        estradiol       [label="Estradiol (E2)"];
        ERalpha         [label="ERα\n(ER-alpha)"];
        ERbeta          [label="ERβ\n(ER-beta)"];
        RAAS_local      [label="Local RAAS\n(prostatic)"];
        prostatic_AngII [label="Prostatic\nAngiotensin II"];
        AT1R            [label="AT1R\n(prostate)"];
    }

    /* ================================================================
       CLUSTER 2 — 5-Alpha Reductase System
    ================================================================ */
    subgraph cluster_5AR {
        label="5-Alpha Reductase System";
        style=filled; fillcolor="#FFFACD"; color="#B8860B"; fontsize=12; fontcolor="#B8860B";

        SRD5A2                      [label="SRD5A2\n(type-2 5α-reductase)", fillcolor="#FFD700", style=filled];
        SRD5A1                      [label="SRD5A1\n(type-1 5α-reductase)", fillcolor="#FFD700", style=filled];
        DHT_formation               [label="DHT Formation\n(prostate)"];
        DHT_plasma                  [label="DHT\n(plasma)",                 fillcolor="#90EE90", style=filled];
        DHT_prostate                [label="DHT\n(prostatic tissue)",       fillcolor="#90EE90", style=filled];
        NADPH                       [label="NADPH\n(co-factor)"];
        intracellular_DHT           [label="Intracellular DHT"];
        threealpha_diol             [label="3α-diol\n(inactive metabolite)"];
        threebeta_diol_ERbeta_ligand[label="3β-diol\n(ERβ ligand)"];
        finasteride_5AR2_inhibition [label="Finasteride\n5AR2 Inhibition",  fillcolor="#FFB347", style=filled];
        dutasteride_dual_inhibition [label="Dutasteride\nDual 5AR Inhibition", fillcolor="#FFB347", style=filled];
    }

    /* ================================================================
       CLUSTER 3 — Androgen Receptor Signaling
    ================================================================ */
    subgraph cluster_AR {
        label="Androgen Receptor (AR) Signaling";
        style=filled; fillcolor="#F0FFF0"; color="#228B22"; fontsize=12; fontcolor="#228B22";

        AR_inactive     [label="AR\n(inactive / cytoplasmic)"];
        Hsp90           [label="Hsp90\n(chaperone complex)"];
        AR_DHT_complex  [label="AR·DHT\nComplex",              fillcolor="#FFD700", style=filled];
        AR_nuclear      [label="AR\n(nuclear / active)",       fillcolor="#FFD700", style=filled];
        ARE             [label="ARE\n(Androgen Response Element)"];
        PSA_KLK3_gene   [label="PSA/KLK3 Gene\nExpression",   fillcolor="#90EE90", style=filled];
        IGF1_expr       [label="IGF-1\n(AR-driven expression)"];
        KGF_FGF7_expr   [label="KGF/FGF7\n(AR-driven expression)"];
        VEGF_expr       [label="VEGF\n(AR-driven expression)"];
        Bcl2_antiapoptosis [label="Bcl-2\n(anti-apoptosis)"];
        Cyclin_D1       [label="Cyclin D1"];
        CDK4            [label="CDK4"];
        p21_Waf1        [label="p21 (Waf1)\nCDK inhibitor"];
        p27_Kip1        [label="p27 (Kip1)\nCDK inhibitor"];
        AR_target_genes [label="AR Target Genes\n(broad panel)"];
    }

    /* ================================================================
       CLUSTER 4 — Adrenergic / Sympathetic Nervous System
    ================================================================ */
    subgraph cluster_adrenergic {
        label="Adrenergic / Sympathetic Signaling";
        style=filled; fillcolor="#FFF0F5"; color="#8B0000"; fontsize=12; fontcolor="#8B0000";

        SNS_activity            [label="Sympathetic Nervous\nSystem Activity",  fillcolor="#FFD700", style=filled];
        Norepinephrine          [label="Norepinephrine\n(NE)"];
        Alpha1A_AR              [label="α1A-Adrenoceptor\n(prostate dominant)", fillcolor="#FFD700", style=filled];
        Alpha1B_AR              [label="α1B-Adrenoceptor\n(vasculature)"];
        Alpha1D_AR              [label="α1D-Adrenoceptor\n(bladder/urethra)"];
        Gq_protein              [label="Gq Protein"];
        PLC_beta                [label="PLCβ\n(phospholipase C-β)"];
        IP3                     [label="IP3\n(inositol trisphosphate)"];
        DAG                     [label="DAG\n(diacylglycerol)"];
        PKC                     [label="PKC\n(protein kinase C)"];
        Ca2_intracellular       [label="Intracellular Ca²⁺\n↑ release",         fillcolor="#FFD700", style=filled];
        MLCK                    [label="MLCK\n(myosin light chain kinase)"];
        MLC_phosphorylation     [label="MLC Phosphorylation"];
        smooth_muscle_contraction [label="Smooth Muscle\nContraction",          fillcolor="#FFD700", style=filled];
        RhoA_ROCK               [label="RhoA/ROCK\npathway"];
        dynamic_obstruction     [label="Dynamic Obstruction\n(tone-dependent)", fillcolor="#87CEEB", style=filled];
        urethral_resistance     [label="Urethral Resistance\n(dynamic)",         fillcolor="#87CEEB", style=filled];
        tamsulosin_alpha1_block [label="Tamsulosin\nα1-Blocker",                fillcolor="#FFB347", style=filled];
        silodosin_alpha1A_selective [label="Silodosin\nα1A-Selective",          fillcolor="#FFB347", style=filled];
    }

    /* ================================================================
       CLUSTER 5 — NO/cGMP Pathway
    ================================================================ */
    subgraph cluster_cGMP {
        label="NO / cGMP Smooth Muscle Relaxation";
        style=filled; fillcolor="#E6F3FF"; color="#003399"; fontsize=12; fontcolor="#003399";

        eNOS                [label="eNOS\n(endothelial NOS)"];
        nNOS                [label="nNOS\n(neuronal NOS)"];
        L_arginine          [label="L-Arginine\n(substrate)"];
        NO_production       [label="Nitric Oxide (NO)\nProduction",      fillcolor="#FFD700", style=filled];
        sGC                 [label="sGC\n(soluble guanylate cyclase)",   fillcolor="#FFD700", style=filled];
        cGMP                [label="cGMP",                               fillcolor="#90EE90", style=filled];
        PKG_I               [label="PKG-I\n(protein kinase G)"];
        MLCP                [label="MLCP\n(MLC phosphatase)"];
        MLC_dephosphorylation [label="MLC Dephosphorylation"];
        smooth_muscle_relaxation [label="Smooth Muscle\nRelaxation",    fillcolor="#FFD700", style=filled];
        PDE5_enzyme         [label="PDE5\n(phosphodiesterase-5)",        fillcolor="#FFD700", style=filled];
        PDE5A_gene          [label="PDE5A Gene\n(expression)"];
        cGMP_degradation    [label="cGMP Degradation\n(↓ relaxation)"];
        tadalafil_PDE5_complex [label="Tadalafil\nPDE5 Complex",        fillcolor="#FFB347", style=filled];
        vardenafil_PDE5     [label="Vardenafil\nPDE5 Inhibitor",        fillcolor="#FFB347", style=filled];
    }

    /* ================================================================
       CLUSTER 6 — Growth Factors & Proliferation Signaling
    ================================================================ */
    subgraph cluster_growth_factors {
        label="Growth Factors & Proliferation Signaling";
        style=filled; fillcolor="#F5F0FF"; color="#6A0DAD"; fontsize=12; fontcolor="#6A0DAD";

        EGF             [label="EGF\n(epidermal growth factor)"];
        EGFR            [label="EGFR\n(ErbB1)",             fillcolor="#FFD700", style=filled];
        FGF7_KGF        [label="FGF7/KGF\n(keratinocyte GF)"];
        FGFR2IIIb       [label="FGFR2IIIb\n(receptor)"];
        IGF_1           [label="IGF-1\n(insulin-like GF-1)"];
        IGF1R           [label="IGF-1R\n(receptor)"];
        TGF_beta1       [label="TGF-β1",                   fillcolor="#FFD700", style=filled];
        TGF_betaR1_R2   [label="TGFβR1/R2\n(receptor complex)"];
        Smad2_3         [label="Smad2/3"];
        Smad4           [label="Smad4"];
        PI3K            [label="PI3K\n(p110α/p85)",         fillcolor="#FFD700", style=filled];
        Akt             [label="Akt\n(PKB)",                fillcolor="#FFD700", style=filled];
        mTORC1          [label="mTORC1"];
        ERK1_2          [label="ERK1/2\n(p42/p44 MAPK)",   fillcolor="#FFD700", style=filled];
        MEK             [label="MEK\n(MAP2K1/2)"];
        Raf             [label="Raf\n(BRAF/CRAF)"];
        Ras             [label="Ras\n(KRAS/HRAS)"];
        MAPK_cascade    [label="MAPK Cascade"];
        HIF1alpha       [label="HIF-1α\n(hypoxia-inducible)"];
        Wnt_beta_catenin[label="Wnt/β-catenin\nPathway"];
    }

    /* ================================================================
       CLUSTER 7 — Inflammation & Immune Microenvironment
    ================================================================ */
    subgraph cluster_inflammation {
        label="Inflammation & Immune Microenvironment";
        style=filled; fillcolor="#FFF8DC"; color="#8B4513"; fontsize=12; fontcolor="#8B4513";

        NF_kB               [label="NF-κB\n(activation)",        fillcolor="#FFD700", style=filled];
        IkBa                [label="IκBα\n(inhibitor)"];
        IL_1beta            [label="IL-1β",                       fillcolor="#90EE90", style=filled];
        TNF_alpha           [label="TNF-α",                       fillcolor="#90EE90", style=filled];
        IL_6                [label="IL-6",                        fillcolor="#90EE90", style=filled];
        IL_8                [label="IL-8 / CXCL8"];
        MCP_1               [label="MCP-1 / CCL2"];
        COX_2               [label="COX-2\n(PTGS2)",              fillcolor="#FFD700", style=filled];
        PGE2                [label="PGE2\n(prostaglandin E2)"];
        EP1_EP3             [label="EP1/EP3\nReceptors"];
        mast_cells          [label="Mast Cells\n(infiltrating)"];
        macrophages         [label="Macrophages\n(M1/M2)"];
        T_lymphocytes       [label="T Lymphocytes\n(CD4+/CD8+)"];
        ROS                 [label="ROS\n(reactive O₂ species)"];
        oxidative_stress    [label="Oxidative Stress"];
        complement_activation [label="Complement\nActivation"];
    }

    /* ================================================================
       CLUSTER 8 — Cellular Compartments & Tissue Remodeling
    ================================================================ */
    subgraph cluster_cells {
        label="Prostatic Cellular Compartments & Remodeling";
        style=filled; fillcolor="#F0F8FF"; color="#00008B"; fontsize=12; fontcolor="#00008B";

        prostate_stroma_fibroblasts [label="Prostatic Stroma\nFibroblasts"];
        prostate_smooth_muscle_cells [label="Prostatic Smooth\nMuscle Cells"];
        luminal_epithelial          [label="Luminal Epithelial\nCells"];
        basal_epithelial            [label="Basal Epithelial\nCells"];
        neuroendocrine_cells        [label="Neuroendocrine\nCells (NE)"];
        prostatic_stem_cells        [label="Prostatic Stem\nCells"];
        stromal_epithelial_crosstalk[label="Stromal–Epithelial\nCrosstalk",     fillcolor="#FFD700", style=filled];
        transition_zone             [label="Transition Zone\n(BPH locus)",      fillcolor="#FFD700", style=filled];
        peripheral_zone             [label="Peripheral Zone\n(PCa locus)"];
        apoptosis                   [label="Apoptosis\n(cell death)",            fillcolor="#90EE90", style=filled];
        proliferation_index         [label="Proliferation Index\n(Ki-67)",       fillcolor="#90EE90", style=filled];
        ECM_remodeling              [label="ECM Remodeling\n(MMP/TIMP)"];
        collagen_deposition         [label="Collagen Deposition\n↑ stiffness"];
        BPH_nodule_formation        [label="BPH Nodule\nFormation",             fillcolor="#FFD700", style=filled];
        prostate_volume_growth      [label="Prostate Volume\nGrowth (cc/yr)",   fillcolor="#87CEEB", style=filled];
    }

    /* ================================================================
       CLUSTER 9 — Pharmacokinetics (PK)
    ================================================================ */
    subgraph cluster_PK {
        label="Pharmacokinetics (PK) — Approved Agents";
        style=filled; fillcolor="#FFE4E1"; color="#8B0000"; fontsize=12; fontcolor="#8B0000";

        tamsulosin_oral             [label="Tamsulosin\n(oral 0.4 mg)",          fillcolor="#FFB347", style=filled];
        tamsulosin_GI_absorption    [label="Tamsulosin GI\nAbsorption (F~100%)",  fillcolor="#FFB347", style=filled];
        tamsulosin_plasma_Cmax      [label="Tamsulosin Cmax\n(~10 ng/mL)",        fillcolor="#90EE90", style=filled];
        tamsulosin_CYP2D6_CYP3A4   [label="Tamsulosin\nCYP2D6/3A4 Metabolism"];
        finasteride_oral            [label="Finasteride\n(oral 5 mg)",            fillcolor="#FFB347", style=filled];
        finasteride_Cmax            [label="Finasteride Cmax\n(~37 ng/mL)",       fillcolor="#90EE90", style=filled];
        finasteride_CYP3A4          [label="Finasteride\nCYP3A4 Metabolism"];
        dutasteride_oral            [label="Dutasteride\n(oral 0.5 mg)",          fillcolor="#FFB347", style=filled];
        dutasteride_Cmax_long_t12   [label="Dutasteride Cmax\n(t½ ~5 weeks)",     fillcolor="#90EE90", style=filled];
        dutasteride_CYP3A4          [label="Dutasteride\nCYP3A4 Metabolism"];
        tadalafil_oral              [label="Tadalafil\n(oral 5 mg/day)",          fillcolor="#FFB347", style=filled];
        tadalafil_CYP3A4            [label="Tadalafil\nCYP3A4 Metabolism"];
        tadalafil_t12_17h           [label="Tadalafil t½\n~17 h",                 fillcolor="#90EE90", style=filled];
        combination_therapy_interactions [label="Combination Therapy\nPK Interactions", fillcolor="#FFB347", style=filled];
    }

    /* ================================================================
       CLUSTER 10 — Clinical Endpoints
    ================================================================ */
    subgraph cluster_endpoints {
        label="Clinical Endpoints & Outcome Measures";
        style=filled; fillcolor="#E0F7FA"; color="#006064"; fontsize=12; fontcolor="#006064";

        IPSS_total          [label="IPSS Total Score\n(0–35)",              fillcolor="#87CEEB", style=filled];
        IPSS_irritative     [label="IPSS Irritative\nSub-score",            fillcolor="#87CEEB", style=filled];
        IPSS_obstructive    [label="IPSS Obstructive\nSub-score",           fillcolor="#87CEEB", style=filled];
        IPSS_QoL            [label="IPSS QoL\n(0–6)",                       fillcolor="#87CEEB", style=filled];
        Qmax_mL_s           [label="Q_max\n(mL/s — uroflow)",               fillcolor="#87CEEB", style=filled];
        Qavg                [label="Q_avg\n(mL/s)",                         fillcolor="#87CEEB", style=filled];
        PVR_mL              [label="PVR\n(post-void residual, mL)",          fillcolor="#87CEEB", style=filled];
        PSA_total_ng_mL     [label="PSA Total\n(ng/mL)",                    fillcolor="#90EE90", style=filled];
        PSA_free            [label="Free PSA\n(ng/mL)",                     fillcolor="#90EE90", style=filled];
        prostate_volume_cc  [label="Prostate Volume\n(cc, TRUS/MRI)",       fillcolor="#87CEEB", style=filled];
        AUR_risk            [label="AUR Risk\n(acute urinary retention)",   fillcolor="#87CEEB", style=filled];
        BPH_progression_risk[label="BPH Progression\nRisk",                fillcolor="#87CEEB", style=filled];
        TURP_risk           [label="TURP/Surgery\nRisk",                    fillcolor="#87CEEB", style=filled];
        nocturia_episodes   [label="Nocturia\n(episodes/night)",            fillcolor="#87CEEB", style=filled];
        OAB_score           [label="OAB Score\n(overactive bladder)",       fillcolor="#87CEEB", style=filled];
    }

    /* ================================================================
       CLUSTER 11 — Comorbidities & Risk Links
    ================================================================ */
    subgraph cluster_comorbidities {
        label="Comorbidities & Cross-Disease Links";
        style=filled; fillcolor="#F5F5DC"; color="#556B2F"; fontsize=12; fontcolor="#556B2F";

        erectile_dysfunction            [label="Erectile Dysfunction\n(ED)",    fillcolor="#87CEEB", style=filled];
        ejaculatory_dysfunction_retrograde [label="Ejaculatory Dysfunction\n(retrograde)", fillcolor="#87CEEB", style=filled];
        metabolic_syndrome_BPH          [label="Metabolic Syndrome\n↔ BPH"];
        T2DM_BPH_link                   [label="T2DM ↔ BPH\n(insulin/IGF axis)"];
        hypertension_BPH_link           [label="Hypertension ↔ BPH\n(SNS/RAAS)"];
        OAB_overlap                     [label="OAB Overlap\n(storage LUTS)"];
        prostatitis_component           [label="Prostatitis\nComponent (NIH-IIIB)"];
        prostate_cancer_risk            [label="Prostate Cancer\nRisk (PCa)",   fillcolor="#87CEEB", style=filled];
        cardiovascular_risk_LUTS        [label="Cardiovascular Risk\n↔ LUTS"];
    }

    /* ================================================================
       INTER-CLUSTER EDGES — Hormonal Axis
    ================================================================ */
    // HPG axis cascade
    GnRH            -> LH               [color=navy, arrowhead=normal];
    LH              -> Leydig_cells     [color=navy, arrowhead=normal];
    Leydig_cells    -> Testosterone     [color=navy, arrowhead=normal];
    adrenal_DHEA    -> Testosterone     [color=navy, arrowhead=normal, style=dashed];
    Testosterone    -> SHBG             [color=navy, arrowhead=normal, label="binding"];
    SHBG            -> free_T           [color=red,  arrowhead=tee,    label="sequesters"];
    Testosterone    -> free_T           [color=navy, arrowhead=normal];
    Testosterone    -> aromatase        [color=navy, arrowhead=normal, label="substrate"];
    aromatase       -> estradiol        [color=navy, arrowhead=normal];
    estradiol       -> ERalpha          [color=navy, arrowhead=normal];
    estradiol       -> ERbeta           [color=navy, arrowhead=normal];

    // Local RAAS
    RAAS_local      -> prostatic_AngII  [color=navy, arrowhead=normal];
    prostatic_AngII -> AT1R             [color=navy, arrowhead=normal];
    AT1R            -> SNS_activity     [color=navy, arrowhead=normal, label="crosstalk"];

    /* ================================================================
       Hormonal → 5AR
    ================================================================ */
    free_T          -> SRD5A2           [color=navy, arrowhead=normal, label="substrate\n(prostate)"];
    free_T          -> SRD5A1           [color=navy, arrowhead=normal, label="substrate\n(skin/liver)"];
    NADPH           -> DHT_formation    [color=navy, arrowhead=normal, label="co-factor"];
    SRD5A2          -> DHT_formation    [color=navy, arrowhead=normal];
    SRD5A1          -> DHT_formation    [color=navy, arrowhead=normal];
    DHT_formation   -> DHT_plasma       [color=navy, arrowhead=normal];
    DHT_formation   -> DHT_prostate     [color=navy, arrowhead=normal];
    DHT_prostate    -> intracellular_DHT[color=navy, arrowhead=normal];
    DHT_prostate    -> threealpha_diol  [color=navy, arrowhead=normal, label="3α-HSD"];
    threealpha_diol -> threebeta_diol_ERbeta_ligand [color=navy, arrowhead=normal, label="isomerisation"];

    // 5AR inhibitor nodes → enzyme (inhibitory)
    finasteride_5AR2_inhibition -> SRD5A2 [color=red, arrowhead=tee, label="IC50~1nM"];
    dutasteride_dual_inhibition -> SRD5A1 [color=red, arrowhead=tee];
    dutasteride_dual_inhibition -> SRD5A2 [color=red, arrowhead=tee];

    /* ================================================================
       5AR → AR Signaling
    ================================================================ */
    intracellular_DHT -> AR_inactive    [color=navy, arrowhead=normal, label="ligand\nbinding"];
    AR_inactive       -> Hsp90          [color=navy, arrowhead=normal, label="associates"];
    Hsp90             -> AR_DHT_complex [color=red,  arrowhead=tee,    label="dissociates\non DHT"];
    AR_inactive       -> AR_DHT_complex [color=navy, arrowhead=normal, label="+DHT"];
    AR_DHT_complex    -> AR_nuclear     [color=navy, arrowhead=normal, label="nuclear\ntransport"];
    AR_nuclear        -> ARE            [color=navy, arrowhead=normal, label="binds ARE"];
    ARE               -> AR_target_genes[color=navy, arrowhead=normal, label="transcription"];
    AR_target_genes   -> PSA_KLK3_gene  [color=navy, arrowhead=normal];
    AR_target_genes   -> IGF1_expr      [color=navy, arrowhead=normal];
    AR_target_genes   -> KGF_FGF7_expr  [color=navy, arrowhead=normal];
    AR_target_genes   -> VEGF_expr      [color=navy, arrowhead=normal];
    AR_target_genes   -> Bcl2_antiapoptosis [color=navy, arrowhead=normal];
    AR_target_genes   -> Cyclin_D1      [color=navy, arrowhead=normal];
    Cyclin_D1         -> CDK4           [color=navy, arrowhead=normal, label="activates"];
    CDK4              -> p21_Waf1       [color=red,  arrowhead=tee,    label="inhibits"];
    CDK4              -> p27_Kip1       [color=red,  arrowhead=tee,    label="inhibits"];

    // ERβ ligand loop (negative feedback / antiproliferative)
    threebeta_diol_ERbeta_ligand -> ERbeta [color=navy, arrowhead=normal];
    ERbeta           -> AR_nuclear      [color=red, arrowhead=tee, label="co-repressor", style=dashed];

    /* ================================================================
       AR → Cells (Proliferation)
    ================================================================ */
    IGF1_expr        -> prostate_stroma_fibroblasts  [color=navy, arrowhead=normal];
    KGF_FGF7_expr    -> luminal_epithelial           [color=navy, arrowhead=normal, label="paracrine"];
    VEGF_expr        -> ECM_remodeling               [color=navy, arrowhead=normal, label="angiogenesis"];
    Bcl2_antiapoptosis -> apoptosis                  [color=red,  arrowhead=tee,    label="suppresses"];
    Cyclin_D1        -> proliferation_index          [color=navy, arrowhead=normal];
    p21_Waf1         -> proliferation_index          [color=red,  arrowhead=tee];
    p27_Kip1         -> proliferation_index          [color=red,  arrowhead=tee];

    /* ================================================================
       Adrenergic Signaling → Smooth Muscle Contraction
    ================================================================ */
    SNS_activity     -> Norepinephrine          [color=navy, arrowhead=normal];
    Norepinephrine   -> Alpha1A_AR              [color=navy, arrowhead=normal];
    Norepinephrine   -> Alpha1B_AR              [color=navy, arrowhead=normal];
    Norepinephrine   -> Alpha1D_AR              [color=navy, arrowhead=normal];
    Alpha1A_AR       -> Gq_protein              [color=navy, arrowhead=normal, label="couples"];
    Gq_protein       -> PLC_beta               [color=navy, arrowhead=normal, label="activates"];
    PLC_beta         -> IP3                    [color=navy, arrowhead=normal];
    PLC_beta         -> DAG                    [color=navy, arrowhead=normal];
    IP3              -> Ca2_intracellular      [color=navy, arrowhead=normal, label="ER Ca²⁺\nrelease"];
    DAG              -> PKC                    [color=navy, arrowhead=normal, label="activates"];
    Ca2_intracellular -> MLCK                  [color=navy, arrowhead=normal, label="Ca²⁺-CaM"];
    MLCK             -> MLC_phosphorylation    [color=navy, arrowhead=normal];
    PKC              -> RhoA_ROCK              [color=navy, arrowhead=normal];
    RhoA_ROCK        -> MLC_phosphorylation    [color=navy, arrowhead=normal, label="Ca²⁺\nsensitization"];
    MLC_phosphorylation -> smooth_muscle_contraction [color=navy, arrowhead=normal];
    smooth_muscle_contraction -> dynamic_obstruction  [color=navy, arrowhead=normal];
    dynamic_obstruction -> urethral_resistance        [color=navy, arrowhead=normal];

    // Alpha-blocker inhibitory edges
    tamsulosin_alpha1_block     -> Alpha1A_AR  [color=red, arrowhead=tee, label="Kd~0.02nM"];
    tamsulosin_alpha1_block     -> Alpha1B_AR  [color=red, arrowhead=tee];
    tamsulosin_alpha1_block     -> Alpha1D_AR  [color=red, arrowhead=tee];
    silodosin_alpha1A_selective -> Alpha1A_AR  [color=red, arrowhead=tee, label="uroselecti-\nve"];

    /* ================================================================
       NO/cGMP → Smooth Muscle Relaxation
    ================================================================ */
    L_arginine     -> eNOS              [color=navy, arrowhead=normal, label="substrate"];
    L_arginine     -> nNOS              [color=navy, arrowhead=normal, label="substrate"];
    eNOS           -> NO_production    [color=navy, arrowhead=normal];
    nNOS           -> NO_production    [color=navy, arrowhead=normal];
    NO_production  -> sGC              [color=navy, arrowhead=normal, label="activates"];
    sGC            -> cGMP             [color=navy, arrowhead=normal, label="GTP→cGMP"];
    cGMP           -> PKG_I            [color=navy, arrowhead=normal, label="activates"];
    PKG_I          -> MLCP             [color=navy, arrowhead=normal, label="activates"];
    MLCP           -> MLC_dephosphorylation [color=navy, arrowhead=normal];
    MLC_dephosphorylation -> smooth_muscle_relaxation [color=navy, arrowhead=normal];
    smooth_muscle_relaxation -> urethral_resistance   [color=red, arrowhead=tee, label="reduces\nresistance"];

    // PDE5 degrades cGMP
    PDE5A_gene     -> PDE5_enzyme      [color=navy, arrowhead=normal];
    PDE5_enzyme    -> cGMP_degradation [color=navy, arrowhead=normal, label="hydrolyses"];
    cGMP_degradation -> cGMP           [color=red, arrowhead=tee, label="depletes"];

    // PDE5 inhibitor edges
    tadalafil_PDE5_complex -> PDE5_enzyme [color=red, arrowhead=tee, label="IC50~0.94nM"];
    vardenafil_PDE5        -> PDE5_enzyme [color=red, arrowhead=tee];

    /* ================================================================
       Growth Factors → Cells
    ================================================================ */
    EGF         -> EGFR           [color=navy, arrowhead=normal, label="ligand"];
    EGFR        -> Ras            [color=navy, arrowhead=normal, label="Grb2/SOS"];
    Ras         -> Raf            [color=navy, arrowhead=normal];
    Raf         -> MEK            [color=navy, arrowhead=normal];
    MEK         -> ERK1_2         [color=navy, arrowhead=normal];
    ERK1_2      -> MAPK_cascade   [color=navy, arrowhead=normal];
    MAPK_cascade -> proliferation_index [color=navy, arrowhead=normal];

    FGF7_KGF    -> FGFR2IIIb      [color=navy, arrowhead=normal, label="ligand"];
    FGFR2IIIb  -> PI3K            [color=navy, arrowhead=normal];
    IGF_1       -> IGF1R          [color=navy, arrowhead=normal, label="ligand"];
    IGF1R       -> PI3K           [color=navy, arrowhead=normal, label="IRS-1"];
    PI3K        -> Akt             [color=navy, arrowhead=normal, label="PIP3"];
    Akt         -> mTORC1         [color=navy, arrowhead=normal];
    mTORC1      -> proliferation_index [color=navy, arrowhead=normal, label="S6K/4EBP1"];

    TGF_beta1   -> TGF_betaR1_R2  [color=navy, arrowhead=normal, label="ligand"];
    TGF_betaR1_R2 -> Smad2_3      [color=navy, arrowhead=normal, label="phospho"];
    Smad2_3     -> Smad4          [color=navy, arrowhead=normal, label="complex"];
    Smad4       -> collagen_deposition [color=navy, arrowhead=normal, label="pro-fibrotic\ngene expression"];

    HIF1alpha   -> VEGF_expr      [color=navy, arrowhead=normal, label="trans-\nactivates"];
    Wnt_beta_catenin -> proliferation_index [color=navy, arrowhead=normal, label="TCF/LEF"];

    /* ================================================================
       Inflammation → Cells & Growth Factors
    ================================================================ */
    IL_1beta    -> NF_kB          [color=navy, arrowhead=normal, label="activates"];
    TNF_alpha   -> NF_kB          [color=navy, arrowhead=normal, label="activates"];
    NF_kB       -> IkBa           [color=red,  arrowhead=tee,    label="IκBα\ndegrades"];
    NF_kB       -> IL_6           [color=navy, arrowhead=normal, label="transcription"];
    NF_kB       -> IL_8           [color=navy, arrowhead=normal];
    NF_kB       -> MCP_1          [color=navy, arrowhead=normal];
    NF_kB       -> COX_2          [color=navy, arrowhead=normal];
    COX_2       -> PGE2           [color=navy, arrowhead=normal];
    PGE2        -> EP1_EP3        [color=navy, arrowhead=normal];
    EP1_EP3     -> Ca2_intracellular [color=navy, arrowhead=normal, label="Ca²⁺\nrelease"];
    mast_cells  -> IL_1beta       [color=navy, arrowhead=normal, label="secretes"];
    macrophages -> TNF_alpha      [color=navy, arrowhead=normal];
    T_lymphocytes -> IL_1beta     [color=navy, arrowhead=normal];
    ROS         -> oxidative_stress [color=navy, arrowhead=normal];
    oxidative_stress -> NF_kB     [color=navy, arrowhead=normal, label="activates"];
    complement_activation -> mast_cells [color=navy, arrowhead=normal];
    IL_6        -> prostate_stroma_fibroblasts [color=navy, arrowhead=normal, label="promotes\nproliferation"];
    MCP_1       -> macrophages    [color=navy, arrowhead=normal, label="recruits"];

    /* ================================================================
       Cells → Tissue Remodeling → Endpoints
    ================================================================ */
    prostate_stroma_fibroblasts  -> stromal_epithelial_crosstalk [color=navy, arrowhead=normal];
    prostate_smooth_muscle_cells -> stromal_epithelial_crosstalk [color=navy, arrowhead=normal];
    luminal_epithelial           -> stromal_epithelial_crosstalk [color=navy, arrowhead=normal];
    basal_epithelial             -> prostatic_stem_cells         [color=navy, arrowhead=normal, label="niche"];
    prostatic_stem_cells         -> proliferation_index          [color=navy, arrowhead=normal];
    neuroendocrine_cells         -> nNOS                         [color=navy, arrowhead=normal, label="NO\nsynthesis"];
    stromal_epithelial_crosstalk -> BPH_nodule_formation         [color=navy, arrowhead=normal];
    BPH_nodule_formation         -> transition_zone              [color=navy, arrowhead=normal];
    transition_zone              -> prostate_volume_growth       [color=navy, arrowhead=normal];
    ECM_remodeling               -> collagen_deposition          [color=navy, arrowhead=normal];
    collagen_deposition          -> BPH_nodule_formation         [color=navy, arrowhead=normal];
    proliferation_index          -> BPH_nodule_formation         [color=navy, arrowhead=normal];
    apoptosis                    -> BPH_nodule_formation         [color=red, arrowhead=tee, label="reduces\nnodule growth"];

    /* ================================================================
       Cells → Clinical Endpoints
    ================================================================ */
    prostate_volume_growth -> prostate_volume_cc  [color=navy, arrowhead=normal];
    prostate_volume_growth -> static_obstruction  [color=navy, arrowhead=normal];
    static_obstruction     [label="Static Obstruction\n(bulk/volume)", fillcolor="#FFD700", style=filled];
    static_obstruction     -> IPSS_obstructive    [color=navy, arrowhead=normal];
    urethral_resistance    -> IPSS_obstructive    [color=navy, arrowhead=normal];
    urethral_resistance    -> Qmax_mL_s           [color=red,  arrowhead=tee, label="reduces flow"];
    urethral_resistance    -> Qavg                [color=red,  arrowhead=tee];
    urethral_resistance    -> PVR_mL              [color=navy, arrowhead=normal, label="increases\nresidue"];
    IPSS_obstructive       -> IPSS_total          [color=navy, arrowhead=normal];
    IPSS_irritative        -> IPSS_total          [color=navy, arrowhead=normal];
    IPSS_total             -> IPSS_QoL            [color=navy, arrowhead=normal];
    PSA_KLK3_gene          -> PSA_total_ng_mL     [color=navy, arrowhead=normal];
    PSA_total_ng_mL        -> PSA_free            [color=navy, arrowhead=normal];
    PVR_mL                 -> AUR_risk            [color=navy, arrowhead=normal];
    prostate_volume_cc     -> AUR_risk            [color=navy, arrowhead=normal];
    PSA_total_ng_mL        -> BPH_progression_risk [color=navy, arrowhead=normal];
    AUR_risk               -> TURP_risk           [color=navy, arrowhead=normal];
    BPH_progression_risk   -> TURP_risk           [color=navy, arrowhead=normal];
    nocturia_episodes      -> IPSS_irritative     [color=navy, arrowhead=normal];
    OAB_score              -> IPSS_irritative     [color=navy, arrowhead=normal];

    /* ================================================================
       PK → Drug Targets
    ================================================================ */
    tamsulosin_oral          -> tamsulosin_GI_absorption   [color=navy, arrowhead=normal];
    tamsulosin_GI_absorption -> tamsulosin_plasma_Cmax     [color=navy, arrowhead=normal];
    tamsulosin_plasma_Cmax   -> tamsulosin_CYP2D6_CYP3A4   [color=navy, arrowhead=normal, label="metabolism"];
    tamsulosin_plasma_Cmax   -> tamsulosin_alpha1_block     [color=navy, arrowhead=normal, label="PK→PD"];

    finasteride_oral         -> finasteride_Cmax            [color=navy, arrowhead=normal];
    finasteride_Cmax         -> finasteride_CYP3A4          [color=navy, arrowhead=normal];
    finasteride_Cmax         -> finasteride_5AR2_inhibition [color=navy, arrowhead=normal, label="PK→PD"];

    dutasteride_oral         -> dutasteride_Cmax_long_t12   [color=navy, arrowhead=normal];
    dutasteride_Cmax_long_t12 -> dutasteride_CYP3A4         [color=navy, arrowhead=normal];
    dutasteride_Cmax_long_t12 -> dutasteride_dual_inhibition [color=navy, arrowhead=normal, label="PK→PD"];

    tadalafil_oral           -> tadalafil_t12_17h           [color=navy, arrowhead=normal];
    tadalafil_t12_17h        -> tadalafil_CYP3A4            [color=navy, arrowhead=normal];
    tadalafil_t12_17h        -> tadalafil_PDE5_complex      [color=navy, arrowhead=normal, label="PK→PD"];

    combination_therapy_interactions -> tamsulosin_plasma_Cmax    [color=navy, arrowhead=normal, style=dashed, label="DDI"];
    combination_therapy_interactions -> tadalafil_t12_17h         [color=navy, arrowhead=normal, style=dashed];
    combination_therapy_interactions -> dutasteride_Cmax_long_t12 [color=navy, arrowhead=normal, style=dashed];

    /* ================================================================
       Comorbidities ↔ Relevant Pathways
    ================================================================ */
    erectile_dysfunction         -> NO_production               [color=red,  arrowhead=tee, label="↓NO\nsignaling"];
    erectile_dysfunction         -> PDE5_enzyme                 [color=navy, arrowhead=normal, label="↑PDE5\nexpression"];
    ejaculatory_dysfunction_retrograde -> Alpha1A_AR            [color=navy, arrowhead=normal, label="α1A\nrelevance"];
    metabolic_syndrome_BPH       -> IGF_1                       [color=navy, arrowhead=normal, label="hyperinsulin-\naemia"];
    metabolic_syndrome_BPH       -> estradiol                   [color=navy, arrowhead=normal, label="↑aromatization"];
    T2DM_BPH_link                -> IGF1R                       [color=navy, arrowhead=normal, label="insulin\nresistance"];
    T2DM_BPH_link                -> Akt                         [color=navy, arrowhead=normal, label="PI3K/Akt\noveractivation"];
    hypertension_BPH_link        -> SNS_activity                [color=navy, arrowhead=normal, label="↑SNS\ntone"];
    hypertension_BPH_link        -> RAAS_local                  [color=navy, arrowhead=normal];
    OAB_overlap                  -> nocturia_episodes           [color=navy, arrowhead=normal];
    OAB_overlap                  -> OAB_score                   [color=navy, arrowhead=normal];
    prostatitis_component        -> IL_1beta                    [color=navy, arrowhead=normal, label="chronic\ninflammation"];
    prostatitis_component        -> NF_kB                       [color=navy, arrowhead=normal];
    prostate_cancer_risk         -> PSA_total_ng_mL             [color=navy, arrowhead=normal, label="↑PSA\nmonitoring"];
    prostate_cancer_risk         -> peripheral_zone             [color=navy, arrowhead=normal, label="PCa\nlocus"];
    cardiovascular_risk_LUTS     -> SNS_activity                [color=navy, arrowhead=normal, label="autonomic\ndysfunction"];
    cardiovascular_risk_LUTS     -> erectile_dysfunction        [color=navy, arrowhead=normal, label="shared\nendothelial"];

    /* ================================================================
       Additional cross-pathway biological edges
    ================================================================ */
    // AR feeds back into growth factor axis
    AR_nuclear      -> EGF              [color=navy, arrowhead=normal, style=dashed, label="↑EGF\nligand shedding"];
    AR_nuclear      -> TGF_beta1        [color=navy, arrowhead=normal, style=dashed, label="↑TGFβ1\nexpression"];

    // 5AR inhibition effect on PSA (clinical monitoring)
    finasteride_5AR2_inhibition -> PSA_total_ng_mL [color=red, arrowhead=tee, label="↓PSA ~50%"];
    dutasteride_dual_inhibition -> PSA_total_ng_mL [color=red, arrowhead=tee, label="↓PSA ~50%"];

    // Inflammation activates ROS
    macrophages     -> ROS              [color=navy, arrowhead=normal, label="NADPH\noxidase"];
    mast_cells      -> ROS              [color=navy, arrowhead=normal];

    // HIF1α in hypoxic BPH nodules
    BPH_nodule_formation -> HIF1alpha   [color=navy, arrowhead=normal, label="hypoxia\nin nodule"];

    // cGMP in erectile function
    cGMP            -> erectile_dysfunction [color=red, arrowhead=tee, label="sufficient cGMP\nprevents ED"];

    // Prostate volume → static obstruction → PSA
    prostate_volume_cc -> PSA_total_ng_mL [color=navy, arrowhead=normal, label="epithelial\nmass"];

    // PGE2/EP — bladder effects
    PGE2            -> OAB_overlap      [color=navy, arrowhead=normal, label="bladder\nhypersensitivity"];

    // Wnt in stroma
    ERalpha         -> Wnt_beta_catenin [color=navy, arrowhead=normal, label="stromal\nWnt induction"];

    // ROCK feeds smooth muscle tone
    RhoA_ROCK       -> smooth_muscle_contraction [color=navy, arrowhead=normal];

    // Testosterone negative feedback on GnRH/LH
    Testosterone    -> GnRH             [color=red, arrowhead=tee, label="neg.\nfeedback"];
    Testosterone    -> LH               [color=red, arrowhead=tee, label="neg.\nfeedback"];
}
