digraph PHPT_QSP {
    rankdir=TB;
    fontname="Helvetica";
    fontsize=11;
    compound=true;
    splines=polyline;
    nodesep=0.35;
    ranksep=0.55;

    node [fontname="Helvetica", fontsize=9, style="filled", shape=box, margin="0.12,0.06"];
    edge [fontname="Helvetica", fontsize=8, arrowsize=0.7];

    // =============================================
    // CLUSTER 1: Parathyroid Gland & PTH Secretion
    // =============================================
    subgraph cluster_ptgland {
        label="Parathyroid Gland\n(PTH Secretion)";
        style=filled; fillcolor="#FFF3E0"; color="#E65100"; fontsize=10; fontcolor="#E65100";

        CaSR [label="CaSR\n(Ca-Sensing Receptor)", fillcolor="#FFB74D", shape=ellipse];
        ChiefCell [label="Chief Cell", fillcolor="#FFCC80"];
        PTH_synthesis [label="PTH mRNA\nSynthesis", fillcolor="#FFE0B2"];
        PTH_degradation [label="Intracellular PTH\nDegradation", fillcolor="#FFE0B2"];
        PTH_secretion [label="PTH Secretion\n(pulse + tonic)", fillcolor="#FF8F00", fontcolor=white];
        PTH_plasma [label="PTH\n[Plasma]\n(intact iPTH)", fillcolor="#FF6F00", fontcolor=white];
        PTH_halflife [label="PTH Clearance\n(t¬Ĺ ~4 min)", fillcolor="#FFB74D"];
        VDR_ptg [label="VDR\n(Parathyroid)", fillcolor="#FFCC80", shape=ellipse];
        FGF23_ptg [label="FGF23\nReceptor (FGFR1/Klotho)", fillcolor="#FFCC80", shape=ellipse];
        Mgcell [label="Mg¬≤‚Āļ\n(Permissive)", fillcolor="#FFE0B2"];
        Adenoma [label="Parathyroid\nAdenoma", fillcolor="#EF5350", fontcolor=white, shape=octagon];
        Hyperplasia [label="Parathyroid\nHyperplasia", fillcolor="#EF9A9A"];
        Autonomous [label="Autonomous\nHypersecretion", fillcolor="#B71C1C", fontcolor=white, shape=diamond];
    }

    // =============================================
    // CLUSTER 2: Calcium & Phosphate Homeostasis
    // =============================================
    subgraph cluster_calcium {
        label="Calcium & Phosphate Homeostasis";
        style=filled; fillcolor="#E8F5E9"; color="#2E7D32"; fontsize=10; fontcolor="#2E7D32";

        Ca_plasma [label="Ionized Ca¬≤‚Āļ\n[Plasma]\n(ref: 1.1-1.3 mM)", fillcolor="#66BB6A", shape=ellipse];
        Ca_total [label="Total Ca\n[Plasma]\n(ref: 2.2-2.6 mM)", fillcolor="#81C784"];
        Albumin [label="Albumin\n(Ca binding)", fillcolor="#A5D6A7"];
        Ca_urine [label="Urine Ca\n(CaU g/day)", fillcolor="#C8E6C9"];
        Ca_bone_pool [label="Bone Ca\nPool\n(~1000 g)", fillcolor="#4CAF50", fontcolor=white];
        Ca_cell [label="Intracellular\nCa¬≤‚Āļ", fillcolor="#A5D6A7"];
        PO4_plasma [label="Phosphate\n[Plasma]\n(ref: 0.8-1.5 mM)", fillcolor="#80CBC4"];
        PO4_urine [label="Urine PO4\n(FEPi)", fillcolor="#B2DFDB"];
        Ca_PO4_product [label="Ca√óPO4\nProduct", fillcolor="#80CBC4"];
        Calcitonin [label="Calcitonin\n(C-cells, thyroid)", fillcolor="#B2EBF2"];
        PTHrP [label="PTHrP\n(PTH-related peptide)", fillcolor="#B2EBF2"];
    }

    // =============================================
    // CLUSTER 3: Vitamin D Metabolism
    // =============================================
    subgraph cluster_vitD {
        label="Vitamin D Metabolism";
        style=filled; fillcolor="#E3F2FD"; color="#1565C0"; fontsize=10; fontcolor="#1565C0";

        VitD_skin [label="Pre-VitD3\n(7-DHC ‚Üí UV)", fillcolor="#90CAF9"];
        VitD_diet [label="Dietary\nVit D2/D3", fillcolor="#BBDEFB"];
        VitD_25 [label="25(OH)D\n[Plasma]\n(CYP2R1/27A1, liver)", fillcolor="#42A5F5", fontcolor=white];
        VitD_125 [label="1,25(OH)‚āāD\n(Calcitriol)\n[Plasma]", fillcolor="#1565C0", fontcolor=white, shape=ellipse];
        CYP27B1 [label="CYP27B1\n(1őĪ-hydroxylase,\nkidney PT cells)", fillcolor="#1E88E5", fontcolor=white, shape=ellipse];
        CYP24A1 [label="CYP24A1\n(24-hydroxylase,\nkidney/intestine)", fillcolor="#42A5F5", fontcolor=white, shape=ellipse];
        VDR_intestine [label="VDR\n(Intestine)", fillcolor="#90CAF9", shape=ellipse];
        VDR_bone [label="VDR\n(Bone)", fillcolor="#90CAF9", shape=ellipse];
        VDR_kidney [label="VDR\n(Kidney)", fillcolor="#90CAF9", shape=ellipse];
        VDBP [label="VitD Binding\nProtein (VDBP)", fillcolor="#BBDEFB"];
        VitD_25_storage [label="VitD-25\nAdipose Storage", fillcolor="#BBDEFB"];
    }

    // =============================================
    // CLUSTER 4: Bone Remodeling
    // =============================================
    subgraph cluster_bone {
        label="Bone Remodeling Unit (BMU)";
        style=filled; fillcolor="#F3E5F5"; color="#6A1B9A"; fontsize=10; fontcolor="#6A1B9A";

        OB_precursor [label="Osteoblast\nPrecursor", fillcolor="#CE93D8"];
        OB_active [label="Active\nOsteoblast\n(bone formation)", fillcolor="#9C27B0", fontcolor=white];
        OB_lining [label="Lining Cell\n(quiescent OB)", fillcolor="#CE93D8"];
        OC_precursor [label="Osteoclast\nPrecursor\n(monocyte/macrophage)", fillcolor="#EF9A9A"];
        OC_active [label="Active\nOsteoclast\n(bone resorption)", fillcolor="#C62828", fontcolor=white];
        RANKL [label="RANKL\n(OB surface/secreted)", fillcolor="#AB47BC", fontcolor=white, shape=ellipse];
        OPG [label="OPG\n(osteoprotegerin,\ndecoy receptor)", fillcolor="#7B1FA2", fontcolor=white, shape=ellipse];
        RANK [label="RANK\n(OC surface receptor)", fillcolor="#EF9A9A", shape=ellipse];
        M_CSF [label="M-CSF\n(OC differentiation)", fillcolor="#FFCCBC", shape=ellipse];
        Sclerostin [label="Sclerostin\n(Wnt inhibitor, osteocyte)", fillcolor="#CE93D8", shape=ellipse];
        WNT [label="Wnt/ő≤-catenin\n(OB promotion)", fillcolor="#E1BEE7", shape=ellipse];
        BMD_cortical [label="Cortical BMD\n(g/cm¬≤)", fillcolor="#7B1FA2", fontcolor=white, shape=parallelogram];
        BMD_trabecular [label="Trabecular BMD\n(g/cm¬≤)", fillcolor="#9C27B0", fontcolor=white, shape=parallelogram];
        BMD_lumbar [label="Lumbar Spine\nBMD (L1-L4)", fillcolor="#AB47BC", fontcolor=white, shape=parallelogram];
        BMD_femur [label="Femoral Neck\nBMD", fillcolor="#BA68C8", fontcolor=white, shape=parallelogram];
        CTX [label="CTX\n(C-telopeptide,\nbone resorption marker)", fillcolor="#E1BEE7"];
        P1NP [label="P1NP\n(procollagen,\nbone formation marker)", fillcolor="#E1BEE7"];
        ALP [label="Bone ALP\n(bone-specific)", fillcolor="#E1BEE7"];
        Fracture_risk [label="Fracture Risk\n(FRAX)", fillcolor="#EF5350", fontcolor=white, shape=octagon];
    }

    // =============================================
    // CLUSTER 5: Kidney - PTH Effects
    // =============================================
    subgraph cluster_kidney {
        label="Kidney ‚ÄĒ PTH & Mineral Handling";
        style=filled; fillcolor="#E0F7FA"; color="#00695C"; fontsize=10; fontcolor="#00695C";

        PT_cell [label="Proximal Tubule\nCell", fillcolor="#80DEEA"];
        DCT_cell [label="Distal Convoluted\nTubule Cell", fillcolor="#4DD0E1"];
        TAL_cell [label="Thick Ascending\nLimb (TAL)", fillcolor="#80DEEA"];
        NaPi2a [label="NaPi-IIa/IIc\n(PO4 reabsorption)", fillcolor="#80DEEA", shape=ellipse];
        TRPV5 [label="TRPV5\n(Ca¬≤‚Āļ reabsorption,\nDCT)", fillcolor="#4DD0E1", shape=ellipse];
        Calbindin [label="Calbindin-D28k\n(intracellular Ca\ntransport)", fillcolor="#B2EBF2"];
        PMCA [label="PMCA1b\n(basolateral Ca\nextrusion)", fillcolor="#80DEEA", shape=ellipse];
        PTH1R_kidney [label="PTH1R\n(kidney, cAMP/PKA)", fillcolor="#00838F", fontcolor=white, shape=ellipse];
        TmCa [label="Tubular Max\nCa Reabsorption", fillcolor="#B2EBF2"];
        GFR [label="eGFR\n(ml/min/1.73m¬≤)", fillcolor="#00695C", fontcolor=white, shape=parallelogram];
        Creatinine [label="Serum Creatinine\n(nephrocalcinosis)", fillcolor="#80DEEA"];
        FECa [label="FECa\n(fractional Ca\nexcretion)", fillcolor="#B2EBF2"];
        Nephrolithiasis [label="Nephrolithiasis\n(Ca-oxalate stones)", fillcolor="#EF5350", fontcolor=white, shape=octagon];
        Nephrocalcinosis [label="Nephrocalcinosis\n(medullary Ca deposit)", fillcolor="#EF9A9A", shape=octagon];
        cAMP_urine [label="Urine cAMP\n(PTH bioactivity proxy)", fillcolor="#B2EBF2"];
    }

    // =============================================
    // CLUSTER 6: Intestine ‚ÄĒ Ca & VitD Absorption
    // =============================================
    subgraph cluster_intestine {
        label="Intestinal Ca/Vitamin D Absorption";
        style=filled; fillcolor="#FFF9C4"; color="#F57F17"; fontsize=10; fontcolor="#F57F17";

        Duodenum [label="Duodenum\n(active Ca transport)", fillcolor="#FFF176"];
        Jejunum [label="Jejunum\n(paracellular Ca)", fillcolor="#FFFDE7"];
        TRPV6 [label="TRPV6\n(apical Ca entry)", fillcolor="#FFD54F", shape=ellipse];
        Calbindin9k [label="Calbindin-D9k\n(intracellular Ca)", fillcolor="#FFF176"];
        Ca_absorption [label="Net Ca\nAbsorption\n(mg/day)", fillcolor="#FF8F00", fontcolor=white];
        Ca_dietary [label="Dietary Ca\nIntake (mg/day)", fillcolor="#FFFDE7"];
        Vit_D_effect_int [label="VitD‚ÜíTRPV6/\nCalbindin9k‚ÜĎ", fillcolor="#FFF176"];
        PTH_indirect_int [label="PTH‚ÜíCYP27B1‚Üí\n1,25D‚ÜĎ‚ÜíCa absorb‚ÜĎ", fillcolor="#FFE082"];
    }

    // =============================================
    // CLUSTER 7: Clinical Manifestations
    // =============================================
    subgraph cluster_clinical {
        label="Clinical Manifestations & Endpoints";
        style=filled; fillcolor="#FCE4EC"; color="#880E4F"; fontsize=10; fontcolor="#880E4F";

        Hypercalcemia [label="Hypercalcemia\n(Ca > 2.6 mM)", fillcolor="#E91E63", fontcolor=white, shape=diamond];
        Hyperphosphaturia [label="Hyperphosphaturia\n(low PO4, high FEPi)", fillcolor="#F48FB1"];
        Hypercalciuria [label="Hypercalciuria\n(Ca > 300 mg/day)", fillcolor="#F48FB1"];
        Bones [label="Osteitis Fibrosa Cystica\n(severe PHPT)", fillcolor="#E91E63", fontcolor=white];
        NeuroPsych [label="Neuropsychiatric\nSymptoms\n(depression, cognitive)", fillcolor="#FCE4EC"];
        GI_symptoms [label="GI Symptoms\n(nausea, constipation,\npancreatitis)", fillcolor="#F8BBD9"];
        CV_effects [label="Cardiovascular\nEffects\n(HTN, LVH, calcification)", fillcolor="#E91E63", fontcolor=white];
        QoL [label="Quality of Life\n(SF-36)", fillcolor="#F48FB1", shape=parallelogram];
        Asymptomatic [label="Asymptomatic\nPHPT\n(75-80% of cases)", fillcolor="#FCE4EC", shape=octagon];
        Normocalcemic [label="Normocalcemic\nPHPT", fillcolor="#F8BBD9", shape=octagon];
        Crisis [label="Hypercalcemic\nCrisis\n(Ca > 3.5 mM)", fillcolor="#B71C1C", fontcolor=white, shape=diamond];
    }

    // =============================================
    // CLUSTER 8: FGF23-Klotho Axis
    // =============================================
    subgraph cluster_fgf23 {
        label="FGF23-Klotho Axis";
        style=filled; fillcolor="#E8EAF6"; color="#283593"; fontsize=10; fontcolor="#283593";

        FGF23 [label="FGF23\n(osteocyte secretion)", fillcolor="#5C6BC0", fontcolor=white, shape=ellipse];
        Klotho [label="őĪ-Klotho\n(co-receptor)", fillcolor="#7986CB", fontcolor=white, shape=ellipse];
        FGF23_kidney [label="FGF23 Action\n‚Üí NaPi‚Üď, CYP27B1‚Üď\nCYP24A1‚ÜĎ, PTH‚Üď", fillcolor="#9FA8DA"];
        FGF23_parathyroid [label="FGF23 ‚Üí PTG\n(FGFR1/Klotho)\n‚Üí PTH‚Üď", fillcolor="#9FA8DA"];
        Phosphatonin [label="Phosphatonin\nEffect\n(PO4 wasting)", fillcolor="#C5CAE9"];
    }

    // =============================================
    // CLUSTER 9: Drug PK ‚ÄĒ Cinacalcet
    // =============================================
    subgraph cluster_cinacalcet {
        label="Drug PK/PD ‚ÄĒ Cinacalcet (Calcimimetic)";
        style=filled; fillcolor="#E8F5E9"; color="#1B5E20"; fontsize=10; fontcolor="#1B5E20";

        Cin_oral [label="Cinacalcet\nOral Dose\n(30-180 mg/day)", fillcolor="#A5D6A7"];
        Cin_gut [label="Cinacalcet\nGut [A]", fillcolor="#81C784"];
        Cin_central [label="Cinacalcet\nCentral [C1]\n(Vd1~55 L)", fillcolor="#4CAF50", fontcolor=white];
        Cin_peripheral [label="Cinacalcet\nPeripheral [C2]\n(high distribution)", fillcolor="#66BB6A"];
        Cin_CYP3A4 [label="CYP3A4/1A2/2D6\nMetabolism (liver)", fillcolor="#A5D6A7"];
        Cin_Cmax [label="Cinacalcet\nCmax (ng/mL)", fillcolor="#C8E6C9"];
        Cin_effect [label="CaSR Allosteric\nSensitization\n(lowers Ca set-point)", fillcolor="#2E7D32", fontcolor=white, shape=ellipse];
        PTH_suppression [label="PTH Suppression\n(E_max model)", fillcolor="#388E3C", fontcolor=white];
    }

    // =============================================
    // CLUSTER 10: Drug PK ‚ÄĒ Denosumab
    // =============================================
    subgraph cluster_denosumab {
        label="Drug PK/PD ‚ÄĒ Denosumab (Anti-RANKL)";
        style=filled; fillcolor="#FFF3E0"; color="#BF360C"; fontsize=10; fontcolor="#BF360C";

        Deno_SC [label="Denosumab\nSC Dose\n(60 mg q6mo)", fillcolor="#FFCCBC"];
        Deno_absorption [label="Denosumab\nAbsorption\n(F~62%, Tmax~10d)", fillcolor="#FFAB91"];
        Deno_central [label="Denosumab\n[Plasma]\n(Vd~3.1 L, mAb)", fillcolor="#FF7043", fontcolor=white];
        Deno_TMDD [label="RANKL-Denosumab\nComplex (TMDD)", fillcolor="#E64A19", fontcolor=white];
        Deno_clearance [label="Linear + TMDD\nClearance\n(t¬Ĺ~28 d)", fillcolor="#FFAB91"];
        RANKL_free [label="Free RANKL\n(target)", fillcolor="#FF8A65"];
        RANKL_bound [label="Bound RANKL\n(drug-target complex)", fillcolor="#FF5722", fontcolor=white];
        OC_suppression [label="OC Suppression\n(E_max model,\nEC50~1 ¬Ķg/mL)", fillcolor="#BF360C", fontcolor=white];
        BMD_increase [label="BMD Increase\n(LS ~5%/year)", fillcolor="#FFCCBC"];
    }

    // =============================================
    // CLUSTER 11: Drug ‚ÄĒ Bisphosphonates
    // =============================================
    subgraph cluster_bisphosphonate {
        label="Drug PK/PD ‚ÄĒ Bisphosphonates";
        style=filled; fillcolor="#F9FBE7"; color="#827717"; fontsize=10; fontcolor="#827717";

        Alen_oral [label="Alendronate\nOral\n(70 mg/wk)", fillcolor="#E6EE9C"];
        Alen_gut [label="GI Absorption\n(F~0.6%)", fillcolor="#F0F4C3"];
        Alen_plasma [label="Alendronate\n[Plasma]", fillcolor="#DCE775"];
        Alen_bone [label="Bone Binding\n(hydroxyapatite)", fillcolor="#CDDC39", fontcolor="#333333"];
        Alen_OC [label="Farnesyl-PP\nSynthase Inhibition\n(OC apoptosis)", fillcolor="#827717", fontcolor=white];
        Zol_IV [label="Zoledronate\nIV\n(5 mg/year)", fillcolor="#C0CA33"];
        BP_CTX_reduction [label="CTX Reduction\n(50-70%)", fillcolor="#F0F4C3"];
        BP_BMD_effect [label="BMD Stabilization\n(no increase in PHPT)", fillcolor="#E6EE9C"];
    }

    // =============================================
    // CLUSTER 12: Surgery (Parathyroidectomy)
    // =============================================
    subgraph cluster_surgery {
        label="Parathyroidectomy (PTx)";
        style=filled; fillcolor="#EFEBE9"; color="#3E2723"; fontsize=10; fontcolor="#3E2723";

        PTx_indication [label="PTx Indication\n(Ca > 1 mg/dL above normal\nor age < 50, eGFR < 60)", fillcolor="#BCAAA4"];
        PTx_procedure [label="Minimally Invasive\nParathyroidectomy\n(MIP) / 4-gland explore", fillcolor="#8D6E63", fontcolor=white];
        Intraop_PTH [label="Intraop PTH\nMonitoring\n(Miami criterion: >50%‚Üď)", fillcolor="#A1887F"];
        Cure_rate [label="Cure Rate\n(>95% for adenoma)", fillcolor="#5D4037", fontcolor=white, shape=diamond];
        PostPTx_Ca [label="Post-PTx Ca\nNormalization\n(<24-72h)", fillcolor="#BCAAA4"];
        HBS [label="Hungry Bone\nSyndrome\n(severe hypocalcemia)", fillcolor="#EF5350", fontcolor=white, shape=octagon];
        Persistent_PHPT [label="Persistent/\nRecurrent PHPT", fillcolor="#EF9A9A"];
        IOPTH_protocol [label="IOPTH Protocol\n(Roth/Miami criteria)", fillcolor="#BCAAA4"];
    }

    // =============================================
    // INTER-CLUSTER EDGES
    // =============================================

    // Parathyroid gland internal
    Ca_plasma -> CaSR [label="(‚Äď) feedback", color="#2E7D32", fontcolor="#2E7D32"];
    CaSR -> ChiefCell [label="Ca¬≤‚Āļ‚ÜĎ ‚Üí CaSR activ ‚Üí PTH‚Üď", color="#C62828"];
    ChiefCell -> PTH_synthesis [label="low Ca ‚Üí PTH gene‚ÜĎ"];
    ChiefCell -> PTH_degradation [label="high Ca ‚Üí C-frag‚ÜĎ"];
    PTH_synthesis -> PTH_secretion;
    PTH_degradation -> PTH_secretion [label="net PTH", style=dashed];
    PTH_secretion -> PTH_plasma [label="portal ‚Üí systemic"];
    PTH_plasma -> PTH_halflife [label="liver/kidney\nclearance (~4 min)"];
    VDR_ptg -> PTH_synthesis [label="1,25D ‚Üí PTH gene repression", color="#1565C0"];
    FGF23_ptg -> PTH_secretion [label="FGF23 ‚Üí PTH‚Üď", color="#283593"];
    Mgcell -> PTH_secretion [label="Mg¬≤‚Āļ required for\nPTH release", color="gray"];
    Adenoma -> Autonomous [color="#B71C1C", style=bold];
    Hyperplasia -> Autonomous [color="#B71C1C"];
    Autonomous -> PTH_plasma [label="unregulated PTH‚ÜĎ‚ÜĎ", color="#B71C1C", fontcolor="#B71C1C", style=bold];

    // PTH ‚Üí kidney
    PTH_plasma -> PTH1R_kidney [label="PTH binds PTH1R", color="#E65100"];
    PTH1R_kidney -> NaPi2a [label="PTH ‚Üí NaPi2a\ninternalization ‚Üí PO4‚Üď", color="#E65100"];
    PTH1R_kidney -> TRPV5 [label="PTH ‚Üí TRPV5‚ÜĎ\n‚Üí Ca reabsorb‚ÜĎ", color="#E65100"];
    PTH1R_kidney -> CYP27B1 [label="PTH ‚Üí CYP27B1‚ÜĎ\n‚Üí 1,25D‚ÜĎ", color="#E65100"];
    PTH1R_kidney -> cAMP_urine [label="PTH ‚Üí cAMP‚ÜĎ"];
    TRPV5 -> Calbindin [label="Ca entry ‚Üí Calbin"];
    Calbindin -> PMCA [label="‚Üí basolateral efflux"];
    PMCA -> Ca_plasma [label="Ca ‚Üí blood"];
    NaPi2a -> PO4_urine [label="‚Üď Pi reabsorb ‚Üí ‚ÜĎ FEPi"];
    NaPi2a -> PO4_plasma [label="‚Üí hypophosphatemia", color="#2E7D32"];
    Ca_plasma -> Ca_urine [label="filtered load"];
    TmCa -> Ca_urine [label="tubular max"];
    PTH1R_kidney -> TmCa [label="PTH‚ÜĎ ‚Üí TmCa‚ÜĎ\n(paradox: Ca reabsorb‚ÜĎ)", color="#E65100"];
    Ca_urine -> Hypercalciuria [label="Ca > 300 mg/d", color="#880E4F"];
    Hypercalciuria -> Nephrolithiasis [label="CaOx/CaP\nsupersaturation"];
    Hypercalciuria -> Nephrocalcinosis [label="medullary Ca\ndeposition"];
    Nephrocalcinosis -> GFR [label="tubular damage ‚Üí GFR‚Üď", color="#C62828"];
    GFR -> Creatinine [label="‚ÜďGFR ‚Üí Cr‚ÜĎ"];

    // Vitamin D metabolism
    VitD_skin -> VitD_25 [label="sun exposure\n(liver 25-hydrox)"];
    VitD_diet -> VitD_25 [label="dietary D2/D3\n(liver)"];
    VitD_25 -> VDBP [label="bound (88%)"];
    VitD_25 -> VitD_25_storage [label="adipose sequester"];
    CYP27B1 -> VitD_125 [label="25D ‚Üí 1,25D\n(kidney)"];
    VitD_125 -> CYP24A1 [label="1,25D ‚Üí CYP24A1‚ÜĎ\n(autoinduction)"];
    CYP24A1 -> VitD_125 [label="catabolism ‚Üí\n24,25(OH)‚āāD", color="#C62828", arrowhead=tee];
    VitD_125 -> VDR_intestine [label="1,25D ‚Üí VDR\ntranslocation"];
    VitD_125 -> VDR_bone [label="1,25D ‚Üí bone\nOB/OC effects"];
    VitD_125 -> VDR_kidney [label="1,25D ‚Üí kidney\nCa handling"];
    VitD_125 -> VDR_ptg [label="1,25D ‚Üí PTG\nPTH suppression"];
    VDR_intestine -> Vit_D_effect_int [label="TRPV6/Calbindin9k\nupregulation"];
    Vit_D_effect_int -> Ca_absorption;

    // Intestine
    Ca_dietary -> Duodenum [label="ingested Ca"];
    Ca_dietary -> Jejunum [label="paracellular"];
    Duodenum -> TRPV6;
    TRPV6 -> Calbindin9k;
    Calbindin9k -> Ca_absorption;
    Jejunum -> Ca_absorption [label="passive diffusion"];
    Ca_absorption -> Ca_plasma [label="net Ca into blood"];
    PTH_indirect_int -> Ca_absorption [label="PTH‚Üí1,25D‚Üí\nCa absorb‚ÜĎ"];

    // PTH ‚Üí intestine (indirect)
    PTH_plasma -> PTH_indirect_int [label="PTH‚ÜíCYP27B1\n(indirect pathway)", color="#E65100", style=dashed];

    // Calcium homeostasis
    Ca_plasma -> Ca_total [label="total = ionized\n+ protein-bound"];
    Albumin -> Ca_total [label="~45% protein-bound\n(albumin correction)"];
    Ca_plasma -> Hypercalcemia [label="Ca > 2.6 mM", color="#880E4F"];
    Ca_plasma -> Crisis [label="Ca > 3.5 mM\n(emergency)", color="#B71C1C"];
    Calcitonin -> OC_active [label="Calcitonin ‚Üí OC\nactivity‚Üď (acute)", color="#283593", arrowhead=tee];
    PTHrP -> PTH1R_kidney [label="PTHrP binds\nPTH1R (humoral)", style=dashed, color="gray"];

    // Bone remodeling
    PTH_plasma -> OB_precursor [label="PTH ‚Üí OB\nPTH1R ‚Üí intermittent\n= anabolic", color="#E65100"];
    PTH_plasma -> RANKL [label="PTH ‚Üí OB\nRANKL‚ÜĎ (cAMP/PKA)", color="#E65100", style=bold];
    PTH_plasma -> OPG [label="PTH ‚Üí OPG‚Üď", color="#C62828", arrowhead=tee];
    OB_active -> RANKL [label="membrane-bound\nRANKL", fontcolor="#880E4F"];
    OB_active -> OPG [label="secreted OPG\n(decoy for RANKL)", color="#2E7D32"];
    RANKL -> RANK [label="RANKL binds RANK"];
