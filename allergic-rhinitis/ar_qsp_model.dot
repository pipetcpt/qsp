digraph AllergicRhinitisQSP {
    graph [
        label="Allergic Rhinitis: Quantitative Systems Pharmacology Model\nAllergen Sensitization · IgE/Mast Cell Axis · Th2 Inflammation · Drug PK/PD · Clinical Endpoints"
        fontsize=28 fontname="Helvetica-Bold"
        rankdir=LR
        bgcolor="#F8F9FA"
        splines=ortho
        nodesep=0.4
        ranksep=1.2
        compound=true
    ]
    node [fontname="Helvetica" fontsize=10 style="filled,rounded" shape=box]
    edge [fontname="Helvetica" fontsize=8]

    // =====================================================================
    // CLUSTER 1: Allergen Exposure & Environmental Triggers
    // =====================================================================
    subgraph cluster_allergen {
        label="Allergen Exposure & Environmental Triggers"
        style="filled,rounded" fillcolor="#E8F5E9" color="#2E7D32" penwidth=2
        fontsize=14 fontcolor="#1B5E20"

        POLLEN [label="Seasonal Pollen\n(Grass/Tree/Weed)" fillcolor="#A5D6A7" shape=cylinder]
        HDM [label="House Dust Mite\n(Der p1, Der f1\nDermatophagoides)" fillcolor="#A5D6A7" shape=cylinder]
        ANIMAL [label="Animal Dander\n(Cat Fel d1\nDog Can f1)" fillcolor="#A5D6A7" shape=cylinder]
        MOLD [label="Mold Spores\n(Alternaria\nCladosporium)" fillcolor="#A5D6A7" shape=cylinder]
        COCKROACH [label="Cockroach Allergen\n(Bla g2, Per a7)" fillcolor="#C8E6C9" shape=cylinder]
        NASAL_DEPOSITION [label="Nasal Mucosal\nAllergen Deposition" fillcolor="#66BB6A"]
        ALLERGEN_LOAD [label="Nasal Allergen Load\n(Ag, μg/m³)" fillcolor="#43A047" fontcolor=white]
        ALLERGEN_ELUTE [label="Allergen Elution\n(Mucus contact)" fillcolor="#66BB6A"]
        PROTEASE_ACTIVITY [label="Allergen Protease\nActivity\n(Der p1 cysteine\nprotease)" fillcolor="#81C784"]

        POLLEN -> NASAL_DEPOSITION
        HDM -> NASAL_DEPOSITION
        ANIMAL -> NASAL_DEPOSITION
        MOLD -> NASAL_DEPOSITION
        COCKROACH -> NASAL_DEPOSITION
        NASAL_DEPOSITION -> ALLERGEN_LOAD
        ALLERGEN_LOAD -> ALLERGEN_ELUTE
        HDM -> PROTEASE_ACTIVITY [label="cleaves\noccludin/\ntight junctions"]
    }

    // =====================================================================
    // CLUSTER 2: Epithelial Barrier & Innate Immune Alarmins
    // =====================================================================
    subgraph cluster_epithelium {
        label="Epithelial Barrier & Innate Alarmins"
        style="filled,rounded" fillcolor="#E3F2FD" color="#1565C0" penwidth=2
        fontsize=14 fontcolor="#0D47A1"

        NASAL_EPITHELIUM [label="Nasal Pseudostratified\nEpithelium\n(Ciliated/Goblet/Basal)" fillcolor="#90CAF9"]
        TIGHT_JUNCTION [label="Tight Junction Integrity\n(Occludin/Claudin/ZO-1)" fillcolor="#BBDEFB"]
        TSLP [label="TSLP\n(Thymic Stromal\nLymphopoietin)" fillcolor="#1E88E5" fontcolor=white]
        IL25 [label="IL-25 (IL-17E)\n(Epithelial cytokine)" fillcolor="#42A5F5"]
        IL33 [label="IL-33\n(Nuclear alarmin)" fillcolor="#1565C0" fontcolor=white]
        HMGB1 [label="HMGB1\n(DAMP)" fillcolor="#64B5F6"]
        URIC_ACID [label="Uric Acid\n(Damage signal)" fillcolor="#90CAF9"]
        ILC2 [label="ILC2\n(Group 2 Innate\nLymphoid Cell)" fillcolor="#0D47A1" fontcolor=white]
        NLRP3_EPI [label="NLRP3 Inflammasome\n(Epithelial)" fillcolor="#42A5F5"]
        MUCUS_LAYER [label="Mucus Layer\n(MUC5AC/MUC5B)" fillcolor="#BBDEFB"]
        CILIARY_BEAT [label="Mucociliary Clearance\n(CBF ~12 Hz)" fillcolor="#90CAF9"]

        NASAL_EPITHELIUM -> TIGHT_JUNCTION
        PROTEASE_ACTIVITY -> TIGHT_JUNCTION [label="barrier\ndisruption" color="#F44336"]
        ALLERGEN_ELUTE -> NASAL_EPITHELIUM [label="contact\nstimulus"]
        NASAL_EPITHELIUM -> TSLP [label="mechanical\nstress/allergen"]
        NASAL_EPITHELIUM -> IL25
        TIGHT_JUNCTION -> IL33 [label="cell damage\nreleases"]
        NASAL_EPITHELIUM -> HMGB1
        NASAL_EPITHELIUM -> URIC_ACID
        TSLP -> ILC2
        IL25 -> ILC2
        IL33 -> ILC2
        NLRP3_EPI -> IL33 [label="processing"]
        NASAL_EPITHELIUM -> MUCUS_LAYER
        NASAL_EPITHELIUM -> CILIARY_BEAT
    }

    // =====================================================================
    // CLUSTER 3: Dendritic Cell & Sensitization
    // =====================================================================
    subgraph cluster_dc {
        label="Antigen Presenting Cells & Th2 Sensitization"
        style="filled,rounded" fillcolor="#FFF3E0" color="#E65100" penwidth=2
        fontsize=14 fontcolor="#BF360C"

        PLASMACYTOID_DC [label="Plasmacytoid DC\n(pDC, IFN-α producer)" fillcolor="#FFB74D"]
        MYELOID_DC [label="Myeloid DC (mDC)\n(TSLP-primed)" fillcolor="#FF8F00" fontcolor=white]
        NAIVECD4 [label="Naïve CD4+ T Cell\n(Th0)" fillcolor="#FFCC80"]
        TH2_CELL [label="Th2 Cell\n(GATA3+, CRTh2+)" fillcolor="#E65100" fontcolor=white]
        TH1_CELL [label="Th1 Cell\n(T-bet+, IFN-γ)" fillcolor="#F57C00" fontcolor=white]
        TREG_CELL [label="Regulatory T Cell\n(Foxp3+, CD25+)" fillcolor="#4CAF50" fontcolor=white]
        TFH_CELL [label="T Follicular Helper\n(CXCR5+, PD-1+)" fillcolor="#FFB300"]
        OX40L_DC [label="OX40L/TSLP\nDC Activation" fillcolor="#FFA726"]
        COSTIMULATION [label="CD80/CD86\n(Co-stimulatory Mol.)" fillcolor="#FFCC80"]
        MHC2_PEPTIDE [label="MHC II-Allergen\nPeptide Complex" fillcolor="#FFCC80"]
        MHCI_XP [label="MHC I Cross-\nPresentation" fillcolor="#FFCC80"]

        ALLERGEN_ELUTE -> MYELOID_DC [label="capture\n& uptake"]
        TSLP -> MYELOID_DC [label="primes\npro-Th2"]
        MYELOID_DC -> MHC2_PEPTIDE
        MYELOID_DC -> COSTIMULATION
        MYELOID_DC -> OX40L_DC
        MYELOID_DC -> MHCI_XP
        MHC2_PEPTIDE -> NAIVECD4 [label="TCR\nengagement"]
        COSTIMULATION -> NAIVECD4
        OX40L_DC -> NAIVECD4 [label="Th2\npolarization"]
        NAIVECD4 -> TH2_CELL [label="IL-4+TSLP\ndriven"]
        NAIVECD4 -> TH1_CELL [label="IL-12\ndriven"]
        NAIVECD4 -> TREG_CELL [label="TGF-β+\nIL-10 driven"]
        NAIVECD4 -> TFH_CELL [label="ICOS+\nIL-21"]
        ILC2 -> TH2_CELL [label="IL-13\nparacrine\nreinforcement"]
    }

    // =====================================================================
    // CLUSTER 4: B Cell Activation & IgE Class Switching
    // =====================================================================
    subgraph cluster_bcell {
        label="B Cell Activation & IgE Class Switch Recombination"
        style="filled,rounded" fillcolor="#F3E5F5" color="#6A1B9A" penwidth=2
        fontsize=14 fontcolor="#4A148C"

        BCELL_NAIVE [label="Naïve B Cell" fillcolor="#CE93D8"]
        GERMINAL_CENTER [label="Germinal Center\nReaction" fillcolor="#9C27B0" fontcolor=white]
        CLASS_SWITCH [label="Class Switch\nRecombination\nIgM→IgE\n(ε locus)" fillcolor="#7B1FA2" fontcolor=white]
        PLASMA_CELL [label="Long-lived IgE\nPlasma Cell\n(Bone Marrow/Tissue)" fillcolor="#6A1B9A" fontcolor=white]
        MEMORY_B [label="Memory B Cell\n(IgE+)" fillcolor="#AB47BC"]
        FREE_IGE [label="Free IgE\n(Serum, ng/mL→IU/mL)" fillcolor="#BA68C8"]
        TOTAL_IGE_SERUM [label="Total IgE\n(Biomarker, IU/mL)" fillcolor="#E1BEE7"]
        SPECIFIC_IGE [label="Allergen-specific IgE\n(ImmunoCAP, kUA/L)" fillcolor="#CE93D8"]
        CD23_BCELL [label="CD23 (FcεRII)\nB Cell Low-affinity\nIgE Receptor" fillcolor="#E1BEE7"]
        IGG4_BLOCK [label="Allergen-specific\nIgG4 (Blocking Ab)\n(Immunotherapy product)" fillcolor="#BA68C8"]

        TFH_CELL -> GERMINAL_CENTER [label="CD40L\nIL-21"]
        TH2_CELL -> BCELL_NAIVE [label="IL-4, IL-13\nCD40L"]
        BCELL_NAIVE -> GERMINAL_CENTER
        GERMINAL_CENTER -> CLASS_SWITCH [label="IL-4, IL-13\nCD40-CD40L"]
        CLASS_SWITCH -> PLASMA_CELL
        CLASS_SWITCH -> MEMORY_B
        PLASMA_CELL -> FREE_IGE [label="secretes"]
        FREE_IGE -> TOTAL_IGE_SERUM
        FREE_IGE -> SPECIFIC_IGE
        BCELL_NAIVE -> CD23_BCELL
        ALLERGEN_LOAD -> SPECIFIC_IGE [label="sensitization\ntest endpoint"]
    }

    // =====================================================================
    // CLUSTER 5: Mast Cell & Basophil Activation
    // =====================================================================
    subgraph cluster_mast {
        label="Mast Cell Sensitization & Allergen-Triggered Activation"
        style="filled,rounded" fillcolor="#FCE4EC" color="#880E4F" penwidth=2
        fontsize=14 fontcolor="#880E4F"

        TISSUE_MAST [label="Nasal Tissue Mast Cell\n(MCT, SCF-dependent)" fillcolor="#880E4F" fontcolor=white]
        FCER1_MAST [label="FcεRI\n(High-affinity IgE Rec.\nα/β/γ2 tetramers)" fillcolor="#C62828" fontcolor=white]
        SENSITIZED_MAST [label="IgE-Sensitized\nMast Cell\n(Ready state)" fillcolor="#E91E63" fontcolor=white]
        CROSSLINK [label="IgE-Allergen\nCrosslink Event\n(≥2 IgE bridges needed)" fillcolor="#F06292"]
        DEGRANULATION [label="Mast Cell\nDegranulation\n(Rapid <5 min)" fillcolor="#F48FB1"]
        BASOPHIL [label="Circulating Basophil\n(FcεRI+, Blood\n0.5-1% of WBC)" fillcolor="#F8BBD9"]
        BASO_ACTIVATION [label="Basophil Activation\n(CD63+, CD203c+)" fillcolor="#F48FB1"]
        SCF [label="Stem Cell Factor\n(SCF/c-KIT signal)" fillcolor="#F48FB1"]
        SPHK1 [label="Sphingosine Kinase 1\n(S1P production)" fillcolor="#FFCDD2"]
        S1P [label="Sphingosine-1-Phosphate\n(S1P, pro-degranulation)" fillcolor="#FFCDD2"]
        FCER1_DOWNREG [label="FcεRI Downregulation\n(by Anti-IgE therapy)" fillcolor="#FCE4EC"]

        SCF -> TISSUE_MAST [label="survival\n& expansion"]
        FREE_IGE -> FCER1_MAST [label="IgE\nbinds FcεRI"]
        TISSUE_MAST -> SENSITIZED_MAST
        FCER1_MAST -> SENSITIZED_MAST [label="IgE loading"]
        ALLERGEN_ELUTE -> CROSSLINK [label="re-exposure\ncrosslinking"]
        SENSITIZED_MAST -> CROSSLINK
        CROSSLINK -> DEGRANULATION [label="tyrosine\nkinase\ncascade\n(Syk/PLCγ)"]
        CROSSLINK -> SPHK1
        SPHK1 -> S1P
        S1P -> DEGRANULATION [label="amplifies"]
        FREE_IGE -> BASOPHIL [label="FcεRI\nbinding"]
        ALLERGEN_ELUTE -> BASO_ACTIVATION [label="crosslink"]
        BASOPHIL -> BASO_ACTIVATION
        FCER1_MAST -> FCER1_DOWNREG [label="reduced by\nlow IgE"]
    }

    // =====================================================================
    // CLUSTER 6: Preformed & Newly Synthesized Mediators
    // =====================================================================
    subgraph cluster_mediators {
        label="Mast Cell Mediators (Early Phase, <30 min)"
        style="filled,rounded" fillcolor="#FFFDE7" color="#F57F17" penwidth=2
        fontsize=14 fontcolor="#E65100"

        // Preformed granule mediators
        HISTAMINE [label="Histamine\n(Preformed granule\n3-8 pg/cell)" fillcolor="#F57F17" fontcolor=white]
        TRYPTASE [label="Tryptase\n(α/β-tryptase\nserum biomarker)" fillcolor="#FF8F00" fontcolor=white]
        CHYMASE [label="Chymase\n(Connective Tissue\nMast Cell)" fillcolor="#FFA000"]
        HEPARIN_MC [label="Heparin\n(Proteoglycan)" fillcolor="#FFCA28"]
        TNF_GRANULE [label="TNF-α\n(Preformed granule)" fillcolor="#FFD54F"]

        // Newly synthesized lipid mediators
        AA_CASCADE [label="Arachidonic Acid\n(AA Cascade via\nPLA2 activation)" fillcolor="#FFEE58"]
        PGD2 [label="PGD2\n(Prostaglandin D2\nCOX-1 major product)" fillcolor="#FFF176"]
        TXA2 [label="TXA2\n(Thromboxane A2)" fillcolor="#FFF9C4"]
        LTC4_MC [label="LTC4\n(Cysteinyl Leukotriene\n5-LO/FLAP pathway)" fillcolor="#FFD700"]
        LTD4_MC [label="LTD4\n(Metabolite of LTC4\nmost potent CysLT)" fillcolor="#FFD700"]
        LTE4_MC [label="LTE4\n(Urinary biomarker\nof CysLT activity)" fillcolor="#FFF9C4"]
        LTB4_MC [label="LTB4\n(Neutrophil/Eos\nchemoattractant)" fillcolor="#FFECB3"]
        PAF_MC [label="PAF\n(Platelet Activating\nFactor)" fillcolor="#FFE082"]

        // Neuropeptides
        SP_MC [label="Substance P\n(Sensory neuropeptide)" fillcolor="#FFCC80"]
        CGRP_MC [label="CGRP\n(Vasodilator,\nNANC nerve)" fillcolor="#FFCC80"]
        VIP [label="VIP\n(Vasoactive Intestinal\nPeptide)" fillcolor="#FFCC80"]

        DEGRANULATION -> HISTAMINE [label="immediate\nrelease"]
        DEGRANULATION -> TRYPTASE
        DEGRANULATION -> CHYMASE
        DEGRANULATION -> HEPARIN_MC
        DEGRANULATION -> TNF_GRANULE
        DEGRANULATION -> AA_CASCADE [label="PLA2\nactivation"]
        AA_CASCADE -> PGD2 [label="COX-1/2"]
        AA_CASCADE -> TXA2 [label="COX-1"]
        AA_CASCADE -> LTC4_MC [label="5-LO/\nFLAP"]
        LTC4_MC -> LTD4_MC [label="GGT\n(extracellular)"]
        LTD4_MC -> LTE4_MC [label="DP"]
        AA_CASCADE -> LTB4_MC [label="5-LO\n(LTA4→LTB4)"]
        DEGRANULATION -> PAF_MC
        BASO_ACTIVATION -> HISTAMINE [label="basophil\nhistamine"]
        BASO_ACTIVATION -> LTC4_MC
    }

    // =====================================================================
    // CLUSTER 7: Receptor-Mediated Nasal Physiology
    // =====================================================================
    subgraph cluster_receptors {
        label="Receptor Activation & Nasal Physiological Responses"
        style="filled,rounded" fillcolor="#E8EAF6" color="#283593" penwidth=2
        fontsize=14 fontcolor="#1A237E"

        H1R [label="H1 Receptor\n(Gq-coupled\nNasal/Vessel/Gland/\nNerve)" fillcolor="#283593" fontcolor=white]
        H2R [label="H2 Receptor\n(Gs-coupled)" fillcolor="#3949AB" fontcolor=white]
        H4R [label="H4 Receptor\n(Gi-coupled\nChemotaxis)" fillcolor="#3F51B5" fontcolor=white]
        DP1R [label="DP1 Receptor\n(PGD2, Gs-coupled\nVasodilation)" fillcolor="#5C6BC0" fontcolor=white]
        CRTH2 [label="CRTH2/DP2\n(PGD2/Th2/Eos\nchemotaxis)" fillcolor="#7986CB"]
        CYSLTR1 [label="CysLT1 Receptor\n(LTC4/LTD4/LTE4\nGq/Gi-coupled)" fillcolor="#9FA8DA"]
        CYSLTR2 [label="CysLT2 Receptor\n(LTC4/LTD4)" fillcolor="#C5CAE9"]
        PAF_R [label="PAFR\n(PAF Receptor)" fillcolor="#9FA8DA"]
        TNFR1 [label="TNFR1\n(NF-κB signaling)" fillcolor="#7986CB"]
        TRKR [label="TrkA/TRPV1\n(Sensory Nerve\nActivation)" fillcolor="#5C6BC0" fontcolor=white]
        ALPHAR [label="α1/α2 Adrenoceptor\n(Nasal Vessels\nVasoconstriction)" fillcolor="#1A237E" fontcolor=white]

        // Receptor signaling
        H1R_SIGNAL [label="H1R Signaling\n(IP3/DAG/Ca²⁺\nglandular secretion\nnerve activation)" fillcolor="#7986CB"]
        PGD2_VASC [label="PGD2 Vasodilation\n(DP1/CRTH2)" fillcolor="#9FA8DA"]
        LT_VASC [label="CysLT Vascular\nPermeability ↑" fillcolor="#C5CAE9"]

        HISTAMINE -> H1R [label="binds"]
        HISTAMINE -> H2R [label="binds"]
        HISTAMINE -> H4R [label="binds\n(Eos\nchemotaxis)"]
        PGD2 -> DP1R [label="binds"]
        PGD2 -> CRTH2 [label="binds\nTh2/ILC2/Eos"]
        LTC4_MC -> CYSLTR1 [label="binds"]
        LTD4_MC -> CYSLTR1 [label="high\naffinity"]
        LTE4_MC -> CYSLTR1 [label="binds"]
        LTC4_MC -> CYSLTR2 [label="binds"]
        PAF_MC -> PAF_R [label="binds"]
        TNF_GRANULE -> TNFR1
        SP_MC -> TRKR [label="TRPV1\nactivation"]
        H1R -> H1R_SIGNAL
        DP1R -> PGD2_VASC
        CRTH2 -> PGD2_VASC
        CYSLTR1 -> LT_VASC
    }

    // =====================================================================
    // CLUSTER 8: Late Phase Reaction & Eosinophil Inflammation
    // =====================================================================
    subgraph cluster_late {
        label="Late Phase Reaction & Eosinophil Inflammation (4–24h)"
        style="filled,rounded" fillcolor="#E0F2F1" color="#00695C" penwidth=2
        fontsize=14 fontcolor="#004D40"

        IL4_TH2 [label="IL-4\n(Th2/ILC2 secretion\nIgE class switch)" fillcolor="#00695C" fontcolor=white]
        IL5_TH2 [label="IL-5\n(Eosinophil maturation\n& survival)" fillcolor="#00796B" fontcolor=white]
        IL13_TH2 [label="IL-13\n(Goblet metaplasia\nMUC5AC ↑)" fillcolor="#00897B" fontcolor=white]
        IL9_TH2 [label="IL-9\n(Mast cell priming\n& ILC2 amplification)" fillcolor="#009688"]
        IL31_TH2 [label="IL-31\n(Itch/Pruritus)" fillcolor="#26A69A"]
        TSLP_LATE [label="TSLP (Late)\n(Amplification\nloop)" fillcolor="#4DB6AC"]
        EOTAXIN1 [label="Eotaxin-1 (CCL11)\n(Eosinophil\nchemotaxis)" fillcolor="#4DB6AC"]
        EOTAXIN3 [label="Eotaxin-3 (CCL26)" fillcolor="#80CBC4"]
        RANTES [label="RANTES (CCL5)\n(Eos/Bas/Th2\nchemotaxis)" fillcolor="#80CBC4"]
        MCP4 [label="MCP-4 (CCL13)\n(Eosinophil attract.)" fillcolor="#B2DFDB"]
        EOS_BLOOD [label="Blood Eosinophil\n(>300 cells/μL\nType 2 marker)" fillcolor="#004D40" fontcolor=white]
        EOS_NASAL [label="Nasal Tissue\nEosinophilia\n(Endpoint)" fillcolor="#00695C" fontcolor=white]
        MBP_EOS [label="Major Basic Protein\n(MBP, cytotoxic)" fillcolor="#26A69A"]
        ECP_EOS [label="Eosinophil Cationic\nProtein (ECP)" fillcolor="#26A69A"]
        EPX_EOS [label="Eosinophil Peroxidase\n(EPX)" fillcolor="#4DB6AC"]
        EDN_EOS [label="Eosinophil-Derived\nNeurotoxin (EDN)" fillcolor="#80CBC4"]
        NEUTROPHIL_LATE [label="Neutrophil Infiltration\n(Late/Severe AR)" fillcolor="#B2DFDB"]

        TH2_CELL -> IL4_TH2
        TH2_CELL -> IL5_TH2
        TH2_CELL -> IL13_TH2
        TH2_CELL -> IL9_TH2
        TH2_CELL -> IL31_TH2
        ILC2 -> IL5_TH2 [label="early\nIL-5"]
        ILC2 -> IL13_TH2 [label="early\nIL-13"]
        TISSUE_MAST -> EOTAXIN1 [label="late release"]
        TISSUE_MAST -> RANTES
        NASAL_EPITHELIUM -> EOTAXIN1
        NASAL_EPITHELIUM -> EOTAXIN3
        NASAL_EPITHELIUM -> MCP4
        IL5_TH2 -> EOS_BLOOD [label="maturation\nmobilization"]
        EOTAXIN1 -> EOS_NASAL [label="chemotaxis"]
        EOTAXIN3 -> EOS_NASAL
        RANTES -> EOS_NASAL
        MCP4 -> EOS_NASAL
        EOS_BLOOD -> EOS_NASAL [label="tissue\nmigration"]
        EOS_NASAL -> MBP_EOS
        EOS_NASAL -> ECP_EOS
        EOS_NASAL -> EPX_EOS
        EOS_NASAL -> EDN_EOS
        IL4_TH2 -> CLASS_SWITCH [label="IgE class\nswitch signal"]
        IL13_TH2 -> NASAL_EPITHELIUM [label="goblet\nhyperplasia"]
        TSLP_LATE -> TH2_CELL [label="amplification\nloop"]
        H4R -> EOS_NASAL [label="histamine-driven\nEos chemotaxis"]
        CRTH2 -> EOS_NASAL [label="PGD2-driven\nEos chemotaxis"]
        LTB4_MC -> NEUTROPHIL_LATE
        LTB4_MC -> EOS_NASAL
        TSLP -> TSLP_LATE
    }

    // =====================================================================
    // CLUSTER 9: Nasal Physiology & Clinical Symptoms
    // =====================================================================
    subgraph cluster_symptoms {
        label="Nasal Pathophysiology & Clinical Symptom Endpoints"
        style="filled,rounded" fillcolor="#FBE9E7" color="#BF360C" penwidth=2
        fontsize=14 fontcolor="#B71C1C"

        NASAL_VASODIL [label="Nasal Vasodilation\n& Venous Sinus\nEngorgement" fillcolor="#B71C1C" fontcolor=white]
        NASAL_SECRETION [label="Seromucinous\nGland Hypersecretion\n(Parasympathetic)" fillcolor="#C62828" fontcolor=white]
        SENSORY_NERVE [label="Trigeminal Sensory\nNerve Activation\n(C-fiber/Aδ)" fillcolor="#D32F2F" fontcolor=white]
        AXON_REFLEX [label="Axon Reflex\n(Antidromic\nneuropeptide release)" fillcolor="#E53935" fontcolor=white]
        VASCULAR_PERM [label="Vascular Permeability ↑\n(Plasma exudation)" fillcolor="#EF5350"]
        GOBLET_HYPERPLAS [label="Goblet Cell\nHyperplasia\n(MUC5AC ↑)" fillcolor="#EF9A9A"]
        REMODELING [label="Nasal Mucosa\nRemodeling\n(Chronic AR)" fillcolor="#FFCDD2"]
        SUBMUCOSAL_EDEMA [label="Submucosal Edema\n(Plasma protein\nexudation)" fillcolor="#FFCDD2"]

        // Symptom endpoints (diamond)
        SYM_SNEEZE [label="Sneezing\n(Symptom Score 0-3)" fillcolor="#F44336" fontcolor=white shape=diamond]
        SYM_RHINORRHEA [label="Rhinorrhea\n(Symptom Score 0-3)" fillcolor="#E53935" fontcolor=white shape=diamond]
        SYM_CONGESTION [label="Nasal Congestion\n(Symptom Score 0-3)" fillcolor="#D32F2F" fontcolor=white shape=diamond]
        SYM_PRURITUS [label="Nasal/Ocular\nPruritus\n(Score 0-3)" fillcolor="#C62828" fontcolor=white shape=diamond]
        SYM_ANOSMIA [label="Hyposmia/Anosmia\n(Olfactory)" fillcolor="#EF5350" shape=diamond]

        // Composite scores
        TNSS [label="TNSS\n(Total Nasal Symptom Score\n= sum of 4 × 0-3\nmax 12)" fillcolor="#7F0000" fontcolor=white shape=ellipse]
        TOSS [label="TOSS\n(Total Ocular Symptom\nScore)" fillcolor="#7F0000" fontcolor=white shape=ellipse]
        RQLQ [label="RQLQ\n(Rhinoconjunctivitis\nQoL Questionnaire)" fillcolor="#4A148C" fontcolor=white shape=ellipse]

        H1R_SIGNAL -> SENSORY_NERVE [label="pruritus\nsneezing\ntrigger"]
        H1R_SIGNAL -> NASAL_SECRETION [label="glandular\nstimulation"]
        H1R_SIGNAL -> NASAL_VASODIL [label="vasodilation"]
        PGD2_VASC -> NASAL_VASODIL [label="DP1\nvasodilation"]
        LT_VASC -> VASCULAR_PERM [label="permeability\n↑"]
        LT_VASC -> NASAL_VASODIL [label="congestion"]
        VASCULAR_PERM -> SUBMUCOSAL_EDEMA
        CGRP_MC -> NASAL_VASODIL [label="NANC"]
        SP_MC -> SENSORY_NERVE [label="NANC"]
        VIP -> NASAL_SECRETION [label="glandular\nstimulation"]
        IL13_TH2 -> GOBLET_HYPERPLAS
        MBP_EOS -> REMODELING [label="chronic damage"]
        ECP_EOS -> REMODELING
        SENSORY_NERVE -> SYM_SNEEZE
        SENSORY_NERVE -> SYM_PRURITUS
        SENSORY_NERVE -> AXON_REFLEX
        AXON_REFLEX -> SP_MC
        AXON_REFLEX -> CGRP_MC
        NASAL_VASODIL -> SYM_CONGESTION
        SUBMUCOSAL_EDEMA -> SYM_CONGESTION
        NASAL_SECRETION -> SYM_RHINORRHEA
        GOBLET_HYPERPLAS -> SYM_RHINORRHEA
        EOS_NASAL -> SYM_ANOSMIA [label="olfactory\ndysfunction"]
        SYM_SNEEZE -> TNSS
        SYM_RHINORRHEA -> TNSS
        SYM_CONGESTION -> TNSS
        SYM_PRURITUS -> TNSS
        TNSS -> RQLQ
        TOSS -> RQLQ
    }

    // =====================================================================
    // CLUSTER 10: PK – Oral H1-Antihistamines
    // =====================================================================
    subgraph cluster_pk_ah {
        label="PK/PD: Oral H1-Antihistamines (2nd Generation)"
        style="filled,rounded" fillcolor="#E1F5FE" color="#01579B" penwidth=2
        fontsize=14 fontcolor="#01579B"

        CETIRIZINE_DOSE [label="Cetirizine\n10 mg q.d. oral\n(Zyrtec®)" fillcolor="#0277BD" fontcolor=white shape=cylinder]
        LORATADINE_DOSE [label="Loratadine\n10 mg q.d. oral\n(Claritin®)" fillcolor="#0288D1" fontcolor=white shape=cylinder]
        FEXOFENADINE_DOSE [label="Fexofenadine\n120/180 mg q.d. oral\n(Allegra®)" fillcolor="#039BE5" fontcolor=white shape=cylinder]
        BILASTINE_DOSE [label="Bilastine\n20 mg q.d. oral\n(Blexten®)" fillcolor="#03A9F4" fontcolor=white shape=cylinder]
        RUPATADINE_DOSE [label="Rupatadine\n10 mg q.d. oral\n(+PAF block)" fillcolor="#29B6F6" shape=cylinder]

        AH_GI_ABS [label="GI Absorption\n(Tmax: Cet 1h, Lora 1.5h\nFexo 1-3h, Bila 1.5h)" fillcolor="#4FC3F7"]
        AH_PLASMA_CP [label="Plasma Concentration\n(Cp, ng/mL)" fillcolor="#81D4FA"]
        AH_PROTEIN_BIND [label="Plasma Protein\nBinding (93% Cet,\n97% Lora, 60-70% Fexo)" fillcolor="#B3E5FC"]
        AH_NASAL_CT [label="Nasal Mucosal\nConc. (Ct, ng/g)" fillcolor="#81D4FA"]
        AH_CNS_PENET [label="CNS Penetration\n(1st gen high, 2nd gen\nminimal P-gp efflux)" fillcolor="#B3E5FC"]
        AH_H1RO [label="H1 Receptor Occupancy\n(RO% ≥80% at Css)\n(PET-measured)" fillcolor="#4FC3F7"]
        AH_INHIBITION [label="Histamine-Wheal\nInhibition\n(Skin Test % ↓)" fillcolor="#29B6F6"]

        CETIRIZINE_DOSE -> AH_GI_ABS
        LORATADINE_DOSE -> AH_GI_ABS
        FEXOFENADINE_DOSE -> AH_GI_ABS
        BILASTINE_DOSE -> AH_GI_ABS
        RUPATADINE_DOSE -> AH_GI_ABS
        AH_GI_ABS -> AH_PLASMA_CP
        AH_PLASMA_CP -> AH_PROTEIN_BIND
        AH_PLASMA_CP -> AH_NASAL_CT
        AH_PLASMA_CP -> AH_CNS_PENET
        AH_NASAL_CT -> AH_H1RO [label="Emax/Kd\nmodel"]
        AH_H1RO -> AH_INHIBITION
        AH_H1RO -> H1R [label="competitive\nblock" color="#F44336" style=dashed arrowhead=tee]
        PAF_R -> RUPATADINE_DOSE [label="additional\nPAF block" style=dotted]
    }

    // =====================================================================
    // CLUSTER 11: PK/PD – Intranasal Corticosteroids (INCS)
    // =====================================================================
    subgraph cluster_pk_incs {
        label="PK/PD: Intranasal Corticosteroids (INCS)"
        style="filled,rounded" fillcolor="#F9FBE7" color="#558B2F" penwidth=2
        fontsize=14 fontcolor="#33691E"

        FLUTICASONE_DOSE [label="Fluticasone Propionate\n50 μg/spray × 2/nostril\nq.d. (Flonase®)" fillcolor="#33691E" fontcolor=white shape=cylinder]
        MOMETASONE_DOSE [label="Mometasone Furoate\n50 μg/spray × 2/nostril\nq.d. (Nasonex®)" fillcolor="#388E3C" fontcolor=white shape=cylinder]
        BUDESONIDE_DOSE [label="Budesonide\n64 μg/spray × 2\nq.d. (Rhinocort®)" fillcolor="#43A047" fontcolor=white shape=cylinder]
        TRIAMCINOLONE_DOSE [label="Triamcinolone\nAcetonide 55 μg/spray\nq.d. (Nasacort®)" fillcolor="#4CAF50" fontcolor=white shape=cylinder]

        INCS_NASAL_DEP [label="Nasal Deposition\n(Spray pattern,\nparticle size <10μm)" fillcolor="#8BC34A"]
        INCS_MUCOSAL [label="Nasal Mucosal\nConc. (nM-μM range)" fillcolor="#AED581"]
        INCS_SYSTEMIC [label="Systemic Exposure\n(<2% BA for FP/MF\n~35% for BUD)" fillcolor="#C5E1A5"]
        GR_LIGAND [label="Glucocorticoid Receptor\nLigand (GR-GRE)" fillcolor="#558B2F" fontcolor=white]
        GR_NUCLEAR [label="GR Nuclear\nTranslocation\n(GR monomer/dimer)" fillcolor="#689F38" fontcolor=white]
        GR_TRANSREP [label="GR Transrepression\n(NF-κB ↓, AP-1 ↓\nHDAC2 recruitment)" fillcolor="#7CB342"]
        GR_TRANSACT [label="GR Transactivation\n(GILZ ↑, SLPI ↑,\nMKP-1 ↑)" fillcolor="#8BC34A"]
        INCS_CYTOKINE_INH [label="Pro-inflammatory\nCytokine Inhibition\n(IL-4, IL-5, IL-13\nTNF-α, GM-CSF ↓)" fillcolor="#AED581"]
        INCS_EOS_APO [label="Eosinophil Apoptosis\n↑ / Recruitment ↓" fillcolor="#DCEDC8"]

        FLUTICASONE_DOSE -> INCS_NASAL_DEP
        MOMETASONE_DOSE -> INCS_NASAL_DEP
        BUDESONIDE_DOSE -> INCS_NASAL_DEP
        TRIAMCINOLONE_DOSE -> INCS_NASAL_DEP
        INCS_NASAL_DEP -> INCS_MUCOSAL
        INCS_MUCOSAL -> INCS_SYSTEMIC [label="<2%\nfirst-pass"]
        INCS_MUCOSAL -> GR_LIGAND
        GR_LIGAND -> GR_NUCLEAR
        GR_NUCLEAR -> GR_TRANSREP
        GR_NUCLEAR -> GR_TRANSACT
        GR_TRANSREP -> INCS_CYTOKINE_INH
        GR_TRANSACT -> INCS_EOS_APO
        INCS_CYTOKINE_INH -> IL4_TH2 [label="↓" color="#558B2F" style=dashed arrowhead=tee]
        INCS_CYTOKINE_INH -> IL5_TH2 [label="↓" color="#558B2F" style=dashed arrowhead=tee]
        INCS_CYTOKINE_INH -> IL13_TH2 [label="↓" color="#558B2F" style=dashed arrowhead=tee]
        INCS_CYTOKINE_INH -> EOTAXIN1 [label="↓" color="#558B2F" style=dashed arrowhead=tee]
        INCS_EOS_APO -> EOS_NASAL [label="↓ tissue\neosinophilia" color="#558B2F" style=dashed arrowhead=tee]
    }

    // =====================================================================
    // CLUSTER 12: Biologics & Immunotherapy
    // =====================================================================
    subgraph cluster_biologics {
        label="Biologics, LTRA & Allergen Immunotherapy"
        style="filled,rounded" fillcolor="#EDE7F6" color="#4527A0" penwidth=2
        fontsize=14 fontcolor="#311B92"

        // LTRAs
        MONTELUKAST_DOSE [label="Montelukast\n10 mg q.d. oral\n(Singulair®)" fillcolor="#4527A0" fontcolor=white shape=cylinder]
        MONTELUKAST_CP [label="Montelukast Plasma\n(Tmax 3-4h, t½ 3-6h)" fillcolor="#512DA8" fontcolor=white]
        CYSLTR1_BLOCK_ML [label="CysLT1 Receptor\nOccupancy\n(>95% at Css)" fillcolor="#673AB7" fontcolor=white]

        // Anti-IgE
        OMALIZUMAB_DOSE [label="Omalizumab\n75-600 mg SC q4w/q2w\n(Xolair® Anti-IgE)" fillcolor="#1A237E" fontcolor=white shape=cylinder]
        OMA_PLASMA_PK [label="Omalizumab Plasma\n(2-comp PK, t½ ~26d)" fillcolor="#283593" fontcolor=white]
        OMA_IGE_COMPLEX [label="Omalizumab-IgE\nImmune Complex\n(Non-functional)" fillcolor="#3949AB" fontcolor=white]
        FREE_IGE_REDUCED [label="Free IgE ↓\n(>95% reduction\nwithin 1-3 days)" fillcolor="#5C6BC0"]
        FCER1_REDUCED [label="FcεRI Downregulation\n(weeks, ~75% ↓)" fillcolor="#7986CB"]

        // Anti-IL4Rα
        DUPILUMAB_DOSE [label="Dupilumab\n300 mg SC q2w\n(Dupixent® Anti-IL4Rα)" fillcolor="#880E4F" fontcolor=white shape=cylinder]
        DUP_PLASMA_PK [label="Dupilumab Plasma\n(t½ ~21d)" fillcolor="#AD1457" fontcolor=white]
        IL4RA_BLOCK [label="IL-4Rα Block\n(IL-4+IL-13 sig. ↓)" fillcolor="#C2185B" fontcolor=white]

        // Anti-IL5
        MEPOLIZUMAB_DOSE [label="Mepolizumab\n100 mg SC q4w\n(Nucala® Anti-IL-5)" fillcolor="#006064" fontcolor=white shape=cylinder]
        IL5_BLOCK [label="IL-5 Neutralization\n(↓ Eos maturation)" fillcolor="#00838F" fontcolor=white]

        // Immunotherapy
        SCIT [label="SCIT\n(Subcutaneous\nImmunotheray\n3-5 yr)" fillcolor="#1B5E20" fontcolor=white shape=cylinder]
        SLIT [label="SLIT\n(Sublingual\nImmunotherapy\n3-5 yr)" fillcolor="#2E7D32" fontcolor=white shape=cylinder]
        AIT_TOLERANCE [label="Allergen Immunotherapy\nTolerance Induction\n(Desensitization)" fillcolor="#388E3C" fontcolor=white]
        TREG_EXPANSION [label="Treg Expansion\n(IL-10 ↑, TGF-β ↑)" fillcolor="#43A047"]
        TH2_SUPPRESSION [label="Th2 Suppression\n(Th1 shift, GATA3 ↓)" fillcolor="#4CAF50"]
        IGG4_BLOCKING [label="Allergen-specific\nIgG4 (Blocking Ab)\n↑ after AIT" fillcolor="#66BB6A"]
        MAST_DESENSIT [label="Mast Cell\nDesensitization\n(FcεRI internalization)" fillcolor="#81C784"]

        // Decongestants
        OXYMETAZOLINE_DOSE [label="Oxymetazoline\n0.05% 2-3 sprays BID\nmax 3-5 days\n(α1/α2 agonist)" fillcolor="#5D4037" fontcolor=white shape=cylinder]
        ALPHA_VASOCONSTR [label="α-Receptor\nVasoconstriction\n(Nasal Vessels)" fillcolor="#795548" fontcolor=white]

        MONTELUKAST_DOSE -> MONTELUKAST_CP
        MONTELUKAST_CP -> CYSLTR1_BLOCK_ML
        CYSLTR1_BLOCK_ML -> CYSLTR1 [label="competitive\nblock" color="#9C27B0" style=dashed arrowhead=tee]
        CYSLTR1_BLOCK_ML -> LT_VASC [label="↓" color="#9C27B0" style=dashed arrowhead=tee]

        OMALIZUMAB_DOSE -> OMA_PLASMA_PK
        OMA_PLASMA_PK -> OMA_IGE_COMPLEX [label="binds\nFree IgE"]
        FREE_IGE -> OMA_IGE_COMPLEX [label="captured"]
        OMA_IGE_COMPLEX -> FREE_IGE_REDUCED
        FREE_IGE_REDUCED -> SENSITIZED_MAST [label="↓ FcεRI\nloading" color="#1A237E" style=dashed arrowhead=tee]
        FREE_IGE_REDUCED -> FCER1_REDUCED
        FCER1_REDUCED -> DEGRANULATION [label="↓ trigger\ncapacity" color="#1A237E" style=dashed arrowhead=tee]

        DUPILUMAB_DOSE -> DUP_PLASMA_PK
        DUP_PLASMA_PK -> IL4RA_BLOCK
        IL4RA_BLOCK -> IL4_TH2 [label="↓ signaling" color="#C2185B" style=dashed arrowhead=tee]
        IL4RA_BLOCK -> IL13_TH2 [label="↓ signaling" color="#C2185B" style=dashed arrowhead=tee]
        IL4RA_BLOCK -> CLASS_SWITCH [label="↓ IgE CSR" color="#C2185B" style=dashed arrowhead=tee]

        MEPOLIZUMAB_DOSE -> IL5_BLOCK
        IL5_BLOCK -> IL5_TH2 [label="neutralizes" color="#006064" style=dashed arrowhead=tee]
        IL5_BLOCK -> EOS_BLOOD [label="↓ Eos" color="#006064" style=dashed arrowhead=tee]

        SCIT -> AIT_TOLERANCE
        SLIT -> AIT_TOLERANCE
        AIT_TOLERANCE -> TREG_EXPANSION
        AIT_TOLERANCE -> TH2_SUPPRESSION
        AIT_TOLERANCE -> IGG4_BLOCKING
        AIT_TOLERANCE -> MAST_DESENSIT
        TREG_EXPANSION -> TREG_CELL [label="expands"]
        TREG_CELL -> TH2_CELL [label="suppresses" color="#4CAF50" style=dashed arrowhead=tee]
        IGG4_BLOCKING -> CROSSLINK [label="blocks\nallergen" color="#2E7D32" style=dashed arrowhead=tee]
        MAST_DESENSIT -> DEGRANULATION [label="↓ reactivity" color="#2E7D32" style=dashed arrowhead=tee]
        TH2_SUPPRESSION -> TH2_CELL [label="↓ GATA3" color="#2E7D32" style=dashed arrowhead=tee]

        OXYMETAZOLINE_DOSE -> ALPHA_VASOCONSTR
        ALPHA_VASOCONSTR -> ALPHAR [label="activates"]
        ALPHAR -> NASAL_VASODIL [label="vasoconstriction\n↓ congestion" color="#795548" style=dashed arrowhead=tee]
    }

    // =====================================================================
    // Cross-cluster edges for key regulatory loops
    // =====================================================================
    TRYPTASE -> NASAL_EPITHELIUM [label="PAR-2\nprotease" style=dotted]
    CHYMASE -> TSLP [label="activates" style=dotted]
    TREG_CELL -> BCELL_NAIVE [label="↓ IgE\nclass switch" color="#4CAF50" style=dashed arrowhead=tee]
    MBP_EOS -> NASAL_EPITHELIUM [label="epithelial\ndamage" color="#F44336"]
    ECP_EOS -> SENSORY_NERVE [label="nerve\ndamage"]
    TNF_GRANULE -> NASAL_EPITHELIUM [label="TSLP\nupregulation"]
    ILC2 -> BASO_ACTIVATION [label="IL-3\npriming"]
    SPECIFIC_IGE -> SENSITIZED_MAST [label="diagnostic\nmarker →\nclinical endpoint"]
    CILIARY_BEAT -> SYM_CONGESTION [label="impaired\nclearance\n→ worsens" style=dotted]
    REMODELING -> SYM_CONGESTION [label="chronic\ncongestion" style=dotted]
}
