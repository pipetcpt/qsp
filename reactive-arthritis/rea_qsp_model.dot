digraph ReactiveArthritis_QSP {
    rankdir=TB;
    graph [
        fontname="Helvetica",
        fontsize=12,
        label="Reactive Arthritis (ReA) — QSP Mechanistic Map\nInfection-triggered Immune Arthropathy: Innate Immunity · HLA-B27 · Adaptive T cells · Joint Pathology · PK/PD",
        labelloc=t,
        labelfontsize=15,
        splines=true,
        overlap=false,
        pad=0.5
    ];
    node [fontname="Helvetica", fontsize=9, style=filled, shape=box];
    edge [fontname="Helvetica", fontsize=8, arrowsize=0.7];

    /* ================================================================
       CLUSTER 1: Triggering Infection (GI & GU pathogens)
       ================================================================ */
    subgraph cluster_infection {
        label="1. Triggering Infection";
        style=filled; color="#CC0000"; fillcolor="#FFF0F0";
        fontname="Helvetica Bold"; fontsize=11;

        salmonella   [label="Salmonella\n(GI, non-typhi)", fillcolor="#FF6B6B"];
        campylobacter [label="Campylobacter\njejuni (GI)",   fillcolor="#FF6B6B"];
        yersinia     [label="Yersinia\n(GI/ileocecal)",     fillcolor="#FF6B6B"];
        shigella     [label="Shigella\n(GI, dysentery)",    fillcolor="#FF6B6B"];
        chlamydia    [label="Chlamydia\ntrachomatis (GU)",  fillcolor="#FF8C69"];
        ureaplasma   [label="Ureaplasma\nurealyticum (GU)", fillcolor="#FF8C69"];
        LPS          [label="Bacterial LPS\n(endotoxin)",   fillcolor="#FFA07A", shape=ellipse];
        chlamydia_LPS[label="Chlamydial LPS\n& HSP60",      fillcolor="#FFA07A", shape=ellipse];
        gut_barrier  [label="Gut Barrier\nDisruption",      fillcolor="#FFC0CB", shape=hexagon];
        GU_mucosa    [label="GU Mucosal\nInfection",        fillcolor="#FFC0CB", shape=hexagon];
        bact_peptides[label="Arthritogenic\nBacterial Peptides", fillcolor="#FFD700", shape=diamond];
        chlamydia_persist[label="Chlamydia Synovial\nPersistence (viable)", fillcolor="#FF4444", fontcolor=white];
        reactive_O   [label="Reactive Oxygen\nSpecies (ROS)", fillcolor="#FF8888", shape=ellipse];

        salmonella    -> LPS;
        campylobacter -> LPS;
        yersinia      -> LPS;
        shigella      -> LPS;
        chlamydia     -> chlamydia_LPS;
        chlamydia     -> bact_peptides;
        salmonella    -> bact_peptides;
        yersinia      -> bact_peptides;
        campylobacter -> bact_peptides;
        LPS           -> gut_barrier;
        chlamydia     -> GU_mucosa;
        ureaplasma    -> GU_mucosa;
        gut_barrier   -> bact_peptides;
        GU_mucosa     -> bact_peptides;
        chlamydia     -> chlamydia_persist [label="synovial\nmigration"];
        chlamydia_persist -> reactive_O;
    }

    /* ================================================================
       CLUSTER 2: Innate Immune Response
       ================================================================ */
    subgraph cluster_innate {
        label="2. Innate Immune Response";
        style=filled; color="#4B0082"; fillcolor="#F0E8FF";
        fontname="Helvetica Bold"; fontsize=11;

        TLR4   [label="TLR4\nActivation",       fillcolor="#9370DB", fontcolor=white];
        TLR2   [label="TLR2\nActivation",       fillcolor="#9370DB", fontcolor=white];
        TLR9   [label="TLR9\nActivation",       fillcolor="#9370DB", fontcolor=white];
        NLRP3  [label="NLRP3\nInflammasome",    fillcolor="#8A2BE2", fontcolor=white, shape=ellipse];
        NFkB   [label="NF-κB\nActivation",      fillcolor="#6A0DAD", fontcolor=white, shape=ellipse];
        neutrophils [label="Neutrophil\nRecruitment & Activation", fillcolor="#4B0082", fontcolor=white];
        macrophages [label="Macrophage\nActivation (M1)", fillcolor="#4B0082", fontcolor=white];
        NK_cells    [label="NK Cell\nActivation",          fillcolor="#6600CC", fontcolor=white];
        DCs         [label="Dendritic Cell\nMaturation",   fillcolor="#4B0082", fontcolor=white];
        mast_cells  [label="Mast Cell\nDegranulation",     fillcolor="#800080", fontcolor=white, shape=ellipse];
        complement  [label="Complement\nC3a / C5a",        fillcolor="#9932CC", fontcolor=white, shape=ellipse];
        NETosis     [label="NETosis\n(NETs formation)",    fillcolor="#FF69B4", shape=ellipse];
        IL1beta_inn [label="IL-1β\n(innate release)",      fillcolor="#DDA0DD", shape=box];
        IL18        [label="IL-18\nRelease",               fillcolor="#DDA0DD", shape=box];
        IL12_inn    [label="IL-12\n(DC-derived)",          fillcolor="#CC77FF", shape=box];
        IL23_inn    [label="IL-23\n(DC-derived)",          fillcolor="#CC77FF", shape=box];
        type1_IFN   [label="Type I IFN\n(IFN-α/β)",       fillcolor="#BB88EE", shape=box];
        HMGB1       [label="HMGB1\n(DAMPs)",               fillcolor="#EE99FF", shape=ellipse];

        LPS          -> TLR4;
        chlamydia_LPS-> TLR2;
        chlamydia_LPS-> TLR9;
        TLR4 -> NFkB;
        TLR2 -> NFkB;
        TLR9 -> NFkB;
        TLR9 -> type1_IFN;
        NFkB -> NLRP3;
        NFkB -> neutrophils;
        NFkB -> macrophages;
        NFkB -> DCs;
        NLRP3 -> IL1beta_inn;
        NLRP3 -> IL18;
        complement -> mast_cells;
        LPS -> complement;
        neutrophils -> NETosis;
        neutrophils -> reactive_O;
        macrophages -> IL12_inn;
        macrophages -> IL23_inn;
        DCs -> IL12_inn;
        DCs -> IL23_inn;
        macrophages -> HMGB1;
        HMGB1 -> NFkB [label="RAGE\nsignaling", style=dashed];
        IL1beta_inn -> macrophages [label="amplification"];
    }

    /* ================================================================
       CLUSTER 3: HLA-B27 & Molecular Mimicry
       ================================================================ */
    subgraph cluster_HLA {
        label="3. HLA-B27 & Molecular Mimicry";
        style=filled; color="#006400"; fillcolor="#F0FFF4";
        fontname="Helvetica Bold"; fontsize=11;

        HLAB27         [label="HLA-B27\n(Risk Allele ~75% ReA)", fillcolor="#228B22", fontcolor=white, shape=box];
        HLAB27_misfold [label="HLA-B27\nMisfolding (UPR)", fillcolor="#32CD32", shape=ellipse];
        HLAB27_homodim [label="HLA-B27\nβ2m-free Homodimers", fillcolor="#3CB371", shape=ellipse];
        ER_stress       [label="ER Stress\nResponse (UPR)", fillcolor="#2E8B57", fontcolor=white, shape=ellipse];
        HLAB27_IL23up  [label="IL-23\nUpregulation (UPR→IL-23)", fillcolor="#006400", fontcolor=white];
        mol_mimicry     [label="Molecular Mimicry\n(Bacterial vs. Self peptides)", fillcolor="#ADFF2F", shape=diamond];
        self_pep_cross  [label="Self-Peptide\nCross-Reactivity (CTL)", fillcolor="#FFD700", shape=diamond];
        MHC_I_pres      [label="Arthritogenic Peptide\n→ MHC-I Presentation", fillcolor="#FFFF00", shape=diamond];
        CD8_autoimmune  [label="Autoreactive\nCD8+ CTL Activation", fillcolor="#8B8B00", fontcolor=white];

        HLAB27 -> HLAB27_misfold;
        HLAB27 -> HLAB27_homodim;
        HLAB27_misfold -> ER_stress;
        ER_stress -> HLAB27_IL23up;
        bact_peptides -> MHC_I_pres;
        MHC_I_pres -> mol_mimicry;
        mol_mimicry -> self_pep_cross;
        self_pep_cross -> CD8_autoimmune;
        HLAB27_homodim -> NK_cells [label="KIR3DL2\nligand"];
        HLAB27_IL23up -> IL23_inn [label="amplifies", style=dashed];
    }

    /* ================================================================
       CLUSTER 4: Adaptive Immune Response
       ================================================================ */
    subgraph cluster_adaptive {
        label="4. Adaptive Immune Response";
        style=filled; color="#8B6914"; fillcolor="#FFFACD";
        fontname="Helvetica Bold"; fontsize=11;

        CD4_naive   [label="Naive CD4+\nT Cells", fillcolor="#DAA520"];
        CD8_naive   [label="Naive CD8+\nT Cells", fillcolor="#DAA520"];
        Th1         [label="Th1 Cells\n(IFN-γ, TNF)", fillcolor="#B8860B", fontcolor=white];
        Th17        [label="Th17 Cells\n(IL-17A, IL-17F, IL-22)", fillcolor="#B8860B", fontcolor=white];
        Treg        [label="Treg Cells\n(IL-10, TGF-β)", fillcolor="#8B6914", fontcolor=white];
        CD8_eff     [label="CD8+ Effector CTL\n(perforin, granzyme)", fillcolor="#8B4513", fontcolor=white];
        Bnaive      [label="Naive B Cells",          fillcolor="#CD853F"];
        plasma_cells[label="Plasma Cells\n(Ab secreting)", fillcolor="#A0522D", fontcolor=white, shape=ellipse];
        memory_T    [label="Memory T Cells\n(→ chronicity)", fillcolor="#8B0000", fontcolor=white];
        germinal_ctr[label="Germinal Center\nReaction (LN)", fillcolor="#CD853F", shape=ellipse];
        IgA_serum   [label="Serum IgA\n(mucosal origin)", fillcolor="#D2691E", shape=ellipse];
        IgG_anti_bact[label="IgG Anti-bacterial\nAntibodies (diagnostic)", fillcolor="#D2691E", shape=ellipse];
        IFNgamma    [label="IFN-γ\n(Th1 effector)", fillcolor="#FF8C00", shape=ellipse];
        TNFalpha    [label="TNF-α\n(master pro-inflam)", fillcolor="#FF4500", fontcolor=white, shape=ellipse];
        IL17A       [label="IL-17A\n(key effector cytokine)", fillcolor="#FF6347", fontcolor=white, shape=ellipse];
        IL17F       [label="IL-17F",            fillcolor="#FF6347", fontcolor=white, shape=ellipse];
        IL22        [label="IL-22\n(mucosal barrier)", fillcolor="#FF8C00", shape=ellipse];
        IL6_cyt     [label="IL-6\n(acute phase, Th17)", fillcolor="#FF7F50", shape=ellipse];
        IL10        [label="IL-10\n(regulatory/anti-inflam)", fillcolor="#32CD32", shape=ellipse];
        TGFbeta     [label="TGF-β\n(fibrosis/Treg induction)", fillcolor="#3CB371", shape=ellipse];
        IL21        [label="IL-21\n(B cell help)", fillcolor="#FFA500", shape=ellipse];
        BAFF        [label="BAFF/BLyS\n(B cell survival)", fillcolor="#FFB347", shape=ellipse];

        DCs -> CD4_naive;
        DCs -> CD8_naive;
        IL12_inn -> Th1;
        IL23_inn -> Th17;
        HLAB27_IL23up -> Th17 [label="HLA-B27\namplifcation", style=dashed];
        CD4_naive -> Th1;
        CD4_naive -> Th17;
        CD4_naive -> Treg;
        CD8_naive -> CD8_eff;
        CD8_autoimmune -> CD8_eff;
        MHC_I_pres -> CD8_eff [label="CTL\nactivation"];
        Th1  -> IFNgamma;
        Th1  -> TNFalpha;
        Th17 -> IL17A;
        Th17 -> IL17F;
        Th17 -> IL22;
        Treg -> IL10;
        Treg -> TGFbeta;
        Bnaive -> germinal_ctr;
        germinal_ctr -> plasma_cells;
        plasma_cells -> IgA_serum;
        plasma_cells -> IgG_anti_bact;
        CD4_naive -> memory_T;
        Th1 -> memory_T [label="immune\nmemory"];
        macrophages -> IL6_cyt;
        macrophages -> TNFalpha;
        IFNgamma -> macrophages [label="M1 activation\nfeedback", style=dashed];
        IL21 -> Bnaive;
        Th17 -> IL21;
        macrophages -> BAFF;
        BAFF -> Bnaive;
    }

    /* ================================================================
       CLUSTER 5: Synovial Joint Pathology
       ================================================================ */
    subgraph cluster_synovial {
        label="5. Synovial Joint Pathology";
        style=filled; color="#00008B"; fillcolor="#E8F0FF";
        fontname="Helvetica Bold"; fontsize=11;

        synovial_fluid  [label="Synovial Fluid\nAccumulation (effusion)", fillcolor="#4169E1", fontcolor=white];
        synoviocyte_A   [label="Synoviocyte Type A\n(Macrophage-like, FLS-A)", fillcolor="#4682B4", fontcolor=white];
        synoviocyte_B   [label="Synoviocyte Type B\n(Fibroblast-like, FLS-B)", fillcolor="#4682B4", fontcolor=white];
        pannus          [label="Pannus\nFormation",                             fillcolor="#191970", fontcolor=white];
        VEGF            [label="VEGF\n(Angiogenesis)",                          fillcolor="#1E90FF", shape=ellipse];
        MMP3            [label="MMP-3\n(Stromelysin-1)",                        fillcolor="#00BFFF", shape=ellipse];
        MMP9            [label="MMP-9\n(Gelatinase B)",                         fillcolor="#00BFFF", shape=ellipse];
        MMP13           [label="MMP-13\n(Collagenase-3)",                       fillcolor="#00BFFF", shape=ellipse];
        RANKL           [label="RANKL\n(Osteoclast activator)",                 fillcolor="#6495ED"];
        OPG             [label="OPG\n(RANKL decoy receptor)",                   fillcolor="#87CEEB"];
        osteoclasts_syn [label="Osteoclast\nActivation",                        fillcolor="#4169E1", fontcolor=white];
        joint_destruct  [label="Joint Space Narrowing\n& Erosion (mSASSS)",     fillcolor="#000080", fontcolor=white];
        enthesitis      [label="Enthesitis\n(tendon/ligament insertion)",        fillcolor="#0000CD", fontcolor=white];
        CXCL8           [label="CXCL8/IL-8\n(neutrophil chemoattractant)",      fillcolor="#87CEFA", shape=ellipse];
        CCL2            [label="CCL2/MCP-1\n(monocyte chemoattractant)",        fillcolor="#87CEFA", shape=ellipse];
        CXCL1           [label="CXCL1/GROα\n(neutrophil migration)",           fillcolor="#87CEFA", shape=ellipse];
        PGE2            [label="PGE2\n(pain/vasodilation)",                     fillcolor="#1E90FF", shape=ellipse];
        COX2_syn        [label="COX-2\n(PG synthesis, inducible)",              fillcolor="#4682B4", shape=ellipse];
        LTB4            [label="LTB4\n(neutrophil chemoattractant)",            fillcolor="#1E90FF", shape=ellipse];
        bradykinin      [label="Bradykinin\n(kinin system, pain)",              fillcolor="#6495ED", shape=ellipse];
        substance_P     [label="Substance P\n(neuropeptide, pain amplifier)",   fillcolor="#00CED1", shape=ellipse];
        synovial_neut   [label="Synovial\nNeutrophilia (>90% PMN)",            fillcolor="#4B0082", fontcolor=white];
        complement_syn  [label="Complement\nActivation (synovial)", fillcolor="#8B008B", fontcolor=white, shape=ellipse];

        TNFalpha -> synoviocyte_A;
        TNFalpha -> synoviocyte_B;
        IL17A  -> CXCL8;
        IL17A  -> CXCL1;
        IL17A  -> MMP3;
        IL17A  -> MMP9;
        IL17A  -> MMP13;
        IL1beta_inn -> COX2_syn;
        TNFalpha -> COX2_syn;
        IL6_cyt -> COX2_syn;
        CXCL8 -> synovial_neut;
        CXCL1 -> synovial_neut;
        CCL2 -> macrophages;
        macrophages -> synoviocyte_A;
        synoviocyte_A -> TNFalpha [label="autocrine\nloop", style=dashed];
        synoviocyte_B -> VEGF;
        synoviocyte_B -> pannus;
        synoviocyte_B -> MMP3;
        synoviocyte_B -> CCL2;
        VEGF -> pannus;
        TNFalpha -> RANKL;
        IL17A -> RANKL;
        IL1beta_inn -> RANKL;
        RANKL -> osteoclasts_syn;
        OPG -> RANKL [label="inhibits", style=dashed, color=red];
        osteoclasts_syn -> joint_destruct;
        pannus -> joint_destruct;
        MMP3 -> joint_destruct;
        MMP9 -> joint_destruct;
        MMP13 -> joint_destruct;
        COX2_syn -> PGE2;
        PGE2 -> bradykinin [label="sensitizes"];
        LTB4 -> synovial_neut;
        TNFalpha -> LTB4;
        enthesitis -> substance_P;
        VEGF -> enthesitis;
        IL17A -> enthesitis;
        synovial_neut -> synovial_fluid;
        IL1beta_inn -> synovial_fluid;
        chlamydia_persist -> synoviocyte_A [label="direct\ninvasion"];
        complement -> complement_syn;
        complement_syn -> synovial_neut;
    }

    /* ================================================================
       CLUSTER 6: Extra-Articular Manifestations (ReA Triad)
       ================================================================ */
    subgraph cluster_extra {
        label="6. Extra-Articular Manifestations (Classic Triad)";
        style=filled; color="#8B0000"; fillcolor="#FFF5F5";
        fontname="Helvetica Bold"; fontsize=11;

        uveitis      [label="Anterior Uveitis\n(~30%, HLA-B27+)", fillcolor="#FF4500", fontcolor=white];
        conjunctivitis[label="Mucopurulent\nConjunctivitis",        fillcolor="#FF6347", fontcolor=white];
        urethritis   [label="Urethritis /\nCervicitis (GU origin)", fillcolor="#FF7F50", fontcolor=white];
        keratoderma  [label="Keratoderma\nBlennorrhagica (skin)",   fillcolor="#FF8C00", fontcolor=white];
        balanitis_cir[label="Circinate\nBalanitis",                 fillcolor="#FFA500"];
        oral_ulcers  [label="Oral Ulcers\n(painless, ~10%)",        fillcolor="#FFD700"];
        aortitis_AV  [label="Aortitis / AV\nConduction Defect",     fillcolor="#DC143C", fontcolor=white];
        sacroiliitis [label="Sacroiliitis\n(10–40%, HLA-B27+)",     fillcolor="#C71585", fontcolor=white];
        spondylitis_ax[label="Axial Spondylitis\n(HLA-B27 strongly linked)", fillcolor="#B22222", fontcolor=white];
        nail_dystrophy[label="Nail Dystrophy\n(onycholysis)",        fillcolor="#FFA07A"];
        psoriasiform [label="Psoriasiform\nSkin Rash",              fillcolor="#FF8C69"];
        nephropathy  [label="IgA Nephropathy\n(rare renal overlap)", fillcolor="#8B0000", fontcolor=white];
        reiter_triad [label="ReA Triad\n(Urethritis+Arthritis+Conjunctivitis)", fillcolor="#FF0000", fontcolor=white, shape=diamond];

        IL17A -> uveitis;
        TNFalpha -> uveitis;
        HLAB27 -> uveitis [label="risk factor"];
        chlamydia -> urethritis;
        ureaplasma -> urethritis;
        IL17A -> keratoderma;
        IL22 -> keratoderma;
        TNFalpha -> aortitis_AV;
        HLAB27 -> sacroiliitis;
        HLAB27 -> spondylitis_ax;
        spondylitis_ax -> sacroiliitis;
        IL17A -> nail_dystrophy;
        IL22 -> psoriasiform;
        IL1beta_inn -> uveitis;
        urethritis -> reiter_triad;
        synovial_fluid -> reiter_triad;
        conjunctivitis -> reiter_triad;
    }

    /* ================================================================
       CLUSTER 7: Bone & Cartilage Remodeling
       ================================================================ */
    subgraph cluster_bone {
        label="7. Bone & Cartilage Remodeling";
        style=filled; color="#556B2F"; fillcolor="#F5FFEA";
        fontname="Helvetica Bold"; fontsize=11;

        chondrocytes   [label="Chondrocyte\nApoptosis",                fillcolor="#8B8B00", fontcolor=white];
        aggrecan_deg   [label="Aggrecan\nDegradation",                  fillcolor="#808000", shape=ellipse];
        collagen_II    [label="Type II Collagen\nDestruction",          fillcolor="#6B8E23", shape=ellipse];
        subchondral    [label="Subchondral Bone\nErosion",              fillcolor="#556B2F", fontcolor=white];
        osteoblasts    [label="Osteoblast\nActivity",                   fillcolor="#6B8E23", fontcolor=white];
        bone_formation [label="New Bone Formation\n(enthesophytes, syndesmophytes)", fillcolor="#8FBC8F"];
        Wnt_path       [label="Wnt Signaling\n(bone formation)",        fillcolor="#90EE90", shape=ellipse];
        DKK1           [label="DKK1\n(Wnt inhibitor, TNF-driven)",      fillcolor="#228B22", fontcolor=white, shape=ellipse];
        sclerostin     [label="Sclerostin / SOST\n(Wnt inhibitor)",     fillcolor="#228B22", fontcolor=white, shape=ellipse];
        BMP_path       [label="BMP-2/4 Signaling\n(osteogenesis)",      fillcolor="#32CD32", shape=ellipse];
        ADAMTS4        [label="ADAMTS-4\n(aggrecanase)",                fillcolor="#7CFC00", shape=ellipse];
        ADAMTS5        [label="ADAMTS-5\n(aggrecanase)",                fillcolor="#7CFC00", shape=ellipse];
        tissue_fibro   [label="Periarticular\nFibrosis (chronic)",      fillcolor="#808000"];

        MMP3 -> aggrecan_deg;
        MMP9 -> collagen_II;
        MMP13 -> collagen_II;
        osteoclasts_syn -> subchondral;
        chondrocytes -> aggrecan_deg;
        chondrocytes -> collagen_II;
        TNFalpha -> chondrocytes [label="apoptosis"];
        IL17A -> chondrocytes;
        Wnt_path -> bone_formation;
        DKK1 -> Wnt_path [style=dashed, color=red, label="inhibits"];
        sclerostin -> Wnt_path [style=dashed, color=red, label="inhibits"];
        BMP_path -> bone_formation;
        osteoblasts -> bone_formation;
        TNFalpha -> DKK1 [label="induces"];
        IL17A -> DKK1 [label="induces"];
        ADAMTS4 -> aggrecan_deg;
        ADAMTS5 -> aggrecan_deg;
        IL1beta_inn -> ADAMTS4;
        TGFbeta -> tissue_fibro;
        IL6_cyt -> osteoclasts_syn;
    }

    /* ================================================================
       CLUSTER 8: Drug PK/PD — NSAIDs & Antibiotics
       ================================================================ */
    subgraph cluster_NSAIDs {
        label="8. Drug PK/PD — NSAIDs & Antibiotics";
        style=filled; color="#8B4513"; fillcolor="#FFF8DC";
        fontname="Helvetica Bold"; fontsize=11;

        NSAID_dose      [label="NSAID Dose\n(Naproxen 500 mg BID\nIndomethacin 50 mg TID)", fillcolor="#FF8C00", fontcolor=white];
        NSAID_gut       [label="NSAID GI\nAbsorption (F~95%)",                               fillcolor="#FFB347", shape=ellipse];
        NSAID_plasma    [label="NSAID Plasma\nConcentration Cp (µg/mL)",                     fillcolor="#FFA500", fontcolor=white, shape=ellipse];
        NSAID_synovium  [label="NSAID Synovial\nFluid Penetration (~50% Cp)",                fillcolor="#FFDAB9", shape=ellipse];
        COX1_inhib      [label="COX-1\nInhibition",  fillcolor="#DC143C", fontcolor=white];
        COX2_inhib      [label="COX-2\nInhibition",  fillcolor="#B22222", fontcolor=white];
        PGE2_reduce     [label="PGE2 ↓\n(Pain/Fever)", fillcolor="#FF6347", fontcolor=white];
        TXA2_reduce     [label="TXA2 ↓\n(Anti-platelet)", fillcolor="#FF6347", fontcolor=white];
        GI_tox          [label="GI Toxicity\n(PG-mediated mucosal)", fillcolor="#8B0000", fontcolor=white];
        renal_NSAID     [label="Renal PG\nReduction (vasoconstriction)", fillcolor="#8B0000", fontcolor=white];
        celecoxib_note  [label="Selective COX-2i\n(Celecoxib)\nSpares COX-1", fillcolor="#FF9966"];

        // Antibiotics
        doxycycline     [label="Doxycycline\n100 mg BID (for Chlamydia ReA)", fillcolor="#8B4513", fontcolor=white];
        azithromycin    [label="Azithromycin\n1g stat or 500mg/d×3", fillcolor="#A0522D", fontcolor=white];
        abx_plasma      [label="Antibiotic\nPlasma & Tissue Levels",           fillcolor="#CD853F", shape=ellipse];
        abx_pathogen    [label="Pathogen\nEradication (acute)",                fillcolor="#D2691E", fontcolor=white];
        abx_chron       [label="Chronic Chlamydia\nPathogen Reduction",        fillcolor="#8B4513", fontcolor=white];

        NSAID_dose -> NSAID_gut;
        NSAID_gut -> NSAID_plasma;
        NSAID_plasma -> NSAID_synovium;
        NSAID_plasma -> COX1_inhib;
        NSAID_synovium -> COX2_inhib;
        COX2_inhib -> PGE2_reduce;
        COX1_inhib -> TXA2_reduce;
        COX1_inhib -> GI_tox;
        COX1_inhib -> renal_NSAID;
        celecoxib_note -> COX2_inhib [label="selective", style=dashed];
        doxycycline -> abx_plasma;
        azithromycin -> abx_plasma;
        abx_plasma -> abx_pathogen;
        abx_plasma -> abx_chron;
        abx_pathogen -> LPS [style=dashed, color=blue, label="reduces"];
        abx_chron -> chlamydia_persist [style=dashed, color=blue, label="reduces"];
    }

    /* ================================================================
       CLUSTER 9: Drug PK/PD — DMARDs & Biologics
       ================================================================ */
    subgraph cluster_DMARDs {
        label="9. Drug PK/PD — DMARDs & Biologics";
        style=filled; color="#006400"; fillcolor="#E8FFE8";
        fontname="Helvetica Bold"; fontsize=11;

        // Sulfasalazine
        SSZ_dose     [label="Sulfasalazine\n2–3 g/day PO",                   fillcolor="#006400", fontcolor=white];
        SSZ_plasma   [label="SSZ Plasma\nConcentration (µg/mL)",              fillcolor="#008000", fontcolor=white, shape=ellipse];
        SSZ_metab    [label="Sulfapyridine/5-ASA\nMetabolites",               fillcolor="#228B22", fontcolor=white, shape=ellipse];
        SSZ_IL_supp  [label="IL-6, IL-12\nSuppression",                      fillcolor="#32CD32", shape=box];
        SSZ_NF_supp  [label="NF-κB\nSuppression",                            fillcolor="#32CD32", shape=box];
        SSZ_TNF_supp [label="TNF-α\nSuppression",                            fillcolor="#32CD32", shape=box];

        // Methotrexate
        MTX_dose     [label="Methotrexate\n7.5–25 mg/wk SC/PO",              fillcolor="#004400", fontcolor=white];
        MTX_plasma   [label="MTX Plasma\n(µmol/L)",                           fillcolor="#006400", fontcolor=white, shape=ellipse];
        MTX_PG       [label="MTX-Polyglutamates\n(intracellular active form)",fillcolor="#006400", fontcolor=white, shape=ellipse];
        DHFR_inhib   [label="DHFR Inhibition\n(folate antagonism)",           fillcolor="#228B22", fontcolor=white];
        AICAR_acc    [label="AICAR Accumulation\n→ Adenosine ↑",              fillcolor="#32CD32", shape=ellipse];
        MTX_immuno   [label="T Cell Suppression\n(Th1, Th17 ↓)",             fillcolor="#3CB371", fontcolor=white];
        MTX_tox      [label="MTX Toxicity\n(hepatotoxicity, mucositis)",      fillcolor="#8B0000", fontcolor=white];

        // TNF inhibitors
        ETN_dose     [label="Etanercept\n50 mg/wk SC\n(p75 TNFR-Fc fusion)", fillcolor="#00CED1", fontcolor=white];
        ADA_dose     [label="Adalimumab\n40 mg Q2W SC\n(anti-TNF mAb)",      fillcolor="#00CED1", fontcolor=white];
        TNFi_depot   [label="TNFi SC Depot\n(absorption Tmax~48-72h)",        fillcolor="#20B2AA", fontcolor=white, shape=ellipse];
        TNFi_plasma  [label="TNFi Plasma\nConcentration (µg/mL)",             fillcolor="#008B8B", fontcolor=white, shape=ellipse];
        TNFi_synov   [label="TNFi Synovial\nFluid Penetration",              fillcolor="#008B8B", fontcolor=white, shape=ellipse];
        TNF_neutraliz[label="TNF-α\nNeutralization",                          fillcolor="#006666", fontcolor=white];
        ADA_antibodies[label="Anti-Drug Antibodies\n(ADA, immunogenicity)",   fillcolor="#DC143C", fontcolor=white, shape=ellipse];

        // IL-17 inhibitors
        SECU_dose    [label="Secukinumab\n300 mg SC monthly\n(anti-IL-17A mAb)", fillcolor="#9400D3", fontcolor=white];
        IXEK_dose    [label="Ixekizumab\n80 mg Q4W SC",                          fillcolor="#9400D3", fontcolor=white];
        IL17i_depot  [label="IL-17i SC Depot\n(Tmax~5-6 days)",                  fillcolor="#8B008B", fontcolor=white, shape=ellipse];
        IL17i_plasma [label="IL-17i Plasma\nConcentration (µg/mL)",              fillcolor="#800080", fontcolor=white, shape=ellipse];
        IL17_neutraliz[label="IL-17A\nNeutralization",                           fillcolor="#660066", fontcolor=white];
        IL17i_tox    [label="IL-17i Safety\n(mucosal candidiasis, IBD risk)",    fillcolor="#8B0000", fontcolor=white];

        SSZ_dose -> SSZ_plasma;
        SSZ_plasma -> SSZ_metab;
        SSZ_metab -> SSZ_IL_supp;
        SSZ_metab -> SSZ_NF_supp;
        SSZ_metab -> SSZ_TNF_supp;

        MTX_dose -> MTX_plasma;
        MTX_plasma -> MTX_PG;
        MTX_PG -> DHFR_inhib;
        MTX_PG -> AICAR_acc;
        AICAR_acc -> MTX_immuno;
        MTX_plasma -> MTX_tox [style=dashed];

        ETN_dose -> TNFi_depot;
        ADA_dose -> TNFi_depot;
        TNFi_depot -> TNFi_plasma;
        TNFi_plasma -> TNFi_synov;
        TNFi_synov -> TNF_neutraliz;
        ADA_antibodies -> TNFi_plasma [style=dashed, color=red, label="↓ drug level"];

        SECU_dose -> IL17i_depot;
        IXEK_dose -> IL17i_depot;
        IL17i_depot -> IL17i_plasma;
        IL17i_plasma -> IL17_neutraliz;
        IL17_neutraliz -> IL17i_tox [style=dashed];
    }

    /* ================================================================
       CLUSTER 10: Clinical Endpoints & Disease Course
       ================================================================ */
    subgraph cluster_clinical {
        label="10. Clinical Endpoints & Disease Course";
        style=filled; color="#2F2F2F"; fillcolor="#F8F8F8";
        fontname="Helvetica Bold"; fontsize=11;

        SJC28         [label="SJC/TJC\n(swollen/tender 28-joint)", fillcolor="#696969", fontcolor=white];
        VAS_pain      [label="VAS Pain\n(0–100 mm)",                fillcolor="#696969", fontcolor=white];
        BASDAI        [label="BASDAI\n(0–10 axial SpA activity)",   fillcolor="#808080", fontcolor=white];
        BASFI         [label="BASFI\n(functional index)",            fillcolor="#808080", fontcolor=white];
        HAQ           [label="HAQ-DI\n(functional disability)",     fillcolor="#808080", fontcolor=white];
        CRP_lab       [label="CRP (mg/L)\n[Normal <5]",             fillcolor="#A9A9A9", fontcolor=white, shape=ellipse];
        ESR_lab       [label="ESR (mm/hr)\n[Normal <20]",           fillcolor="#A9A9A9", fontcolor=white, shape=ellipse];
        WBC_lab       [label="WBC (×10³/µL)\n[Normal 4.5–11]",     fillcolor="#A9A9A9", fontcolor=white, shape=ellipse];
        synovial_biopsy[label="Synovial Biopsy\n(bacterial DNA, neutrophilia)", fillcolor="#C0C0C0"];
        MRI_SI        [label="MRI Sacroiliac\nBone Marrow Edema",   fillcolor="#808080", fontcolor=white];
        XR_radiograph [label="Radiographic\nProgression (mSASSS)",  fillcolor="#505050", fontcolor=white];
        anti_chlamydia[label="Anti-Chlamydia IgG/IgA\n(diagnostic serology)", fillcolor="#A0A0A0", shape=ellipse];
        HLA_B27_result[label="HLA-B27 Test\n(+/−, risk stratification)", fillcolor="#C0C0C0"];
        self_limiting [label="Self-Limiting Course\n(~50% resolve in 3–6 months)", fillcolor="#2E8B57", fontcolor=white];
        chronic_ReA   [label="Chronic ReA\n(>6 months, ~15–30%)",   fillcolor="#8B0000", fontcolor=white];
        undiff_SpA    [label="Undifferentiated SpA\n(→ AS, PsA classification)", fillcolor="#800000", fontcolor=white];

        joint_destruct -> SJC28;
        PGE2 -> VAS_pain;
        substance_P -> VAS_pain;
        bradykinin -> VAS_pain;
        pannus -> VAS_pain;
        IL6_cyt -> CRP_lab;
        IL6_cyt -> ESR_lab;
        TNFalpha -> CRP_lab;
        neutrophils -> WBC_lab;
        chlamydia_persist -> synovial_biopsy;
        sacroiliitis -> MRI_SI;
        pannus -> XR_radiograph;
        osteoclasts_syn -> XR_radiograph;
        IgG_anti_bact -> anti_chlamydia;
        HLAB27 -> HLA_B27_result;
        HLAB27 -> chronic_ReA [label="risk ↑"];
        memory_T -> chronic_ReA [label="persistent\nimmune activation"];
        chlamydia_persist -> chronic_ReA;
        chronic_ReA -> undiff_SpA;
        HLAB27 -> spondylitis_ax;
        spondylitis_ax -> undiff_SpA;
        enthesitis -> BASDAI;
        sacroiliitis -> BASDAI;
        VAS_pain -> HAQ;
        SJC28 -> HAQ;
        BASDAI -> BASFI;
    }

    /* ================================================================
       Cross-cluster connections
       ================================================================ */
    // Infection → Innate
    LPS -> TLR4;
    chlamydia_LPS -> TLR2;
    chlamydia_LPS -> TLR9;
    gut_barrier -> bact_peptides;
    GU_mucosa -> bact_peptides;

    // Innate → Adaptive
    DCs -> IL12_inn;
    DCs -> IL23_inn;
    macrophages -> IL12_inn;
    macrophages -> IL23_inn;
    NK_cells -> IFNgamma;
    IL18 -> NK_cells [label="ILC activation"];

    // HLA-B27 → NK cells
    HLAB27_homodim -> NK_cells [label="KIR3DL2\nligand"];

    // Adaptive → Synovial
    TNFalpha -> synovial_fluid;
    IL1beta_inn -> synovial_fluid;
    IFNgamma -> macrophages;

    // Drug effects on disease
    PGE2_reduce -> VAS_pain [style=dashed, color=blue, label="↓ pain"];
    COX2_inhib -> COX2_syn [style=dashed, color=blue, label="blocks"];
    TNF_neutraliz -> TNFalpha [style=dashed, color=blue, label="neutralizes"];
    TNF_neutraliz -> CRP_lab [style=dashed, color=blue, label="↓"];
    IL17_neutraliz -> IL17A [style=dashed, color=blue, label="neutralizes"];
    IL17_neutraliz -> enthesitis [style=dashed, color=blue, label="↓"];
    SSZ_IL_supp -> IL6_cyt [style=dashed, color=blue, label="↓"];
    SSZ_NF_supp -> NFkB [style=dashed, color=blue, label="↓"];
    SSZ_TNF_supp -> TNFalpha [style=dashed, color=blue, label="↓"];
    MTX_immuno -> Th1 [style=dashed, color=blue, label="↓"];
    MTX_immuno -> Th17 [style=dashed, color=blue, label="↓"];
    MTX_immuno -> TNFalpha [style=dashed, color=blue, label="↓"];

    // Self-resolution pathway
    IL10 -> macrophages [style=dashed, color=green, label="M2 switch"];
    IL10 -> TNFalpha [style=dashed, color=green, label="suppresses"];
    TGFbeta -> Treg [label="Treg\nmaintenance", style=dashed];
    Treg -> self_limiting [style=dashed, color=green, label="promotes\nresolution"];
    memory_T -> self_limiting [style=dashed, color=red, label="may impair"];
}
