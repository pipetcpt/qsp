digraph CHB_QSP_Model {

  graph [
    rankdir=LR
    compound=true
    fontname="Helvetica-Bold"
    fontsize=16
    label="Chronic Hepatitis B (CHB) — QSP Mechanistic Map\nHBV Virology · Innate & Adaptive Immunity · Liver Pathology · Fibrosis · Drug PK/PD · Clinical Endpoints"
    labelloc=t
    nodesep=0.35
    ranksep=0.55
    bgcolor="white"
    splines=ortho
  ]
  node [fontname="Helvetica" fontsize=9 style=filled shape=ellipse width=1.1 height=0.4]
  edge [fontname="Helvetica" fontsize=8 arrowsize=0.7]

  /* =========================================================
     CLUSTER 1: HBV Entry & cccDNA Formation
     ========================================================= */
  subgraph cluster_entry {
    label="HBV Entry & cccDNA Formation"
    style=filled
    fillcolor="#FFF9C4"
    fontcolor="#5D4037"
    fontsize=12

    HBV_Particle       [label="HBV Virion\n(3.2 kb DNA)" fillcolor="#FFEB3B"]
    LHBsAg             [label="Large HBsAg\n(PreS1+PreS2+S)" fillcolor="#FFF176"]
    PreS1_domain       [label="PreS1 Domain\n(aa 1-119)" fillcolor="#FFF9C4"]
    PreS2_domain       [label="PreS2 Domain\n(aa 120-174)" fillcolor="#FFF9C4"]
    SHBsAg             [label="Small HBsAg\n(S protein)" fillcolor="#FFF176"]
    HSPG_receptor      [label="HSPG\n(Heparan Sulfate\nProteoglycan)" fillcolor="#E0F7FA" shape=diamond]
    NTCP_receptor      [label="NTCP\n(SLC10A1)\nNa-Taurocholate\nCo-transporter" fillcolor="#B2EBF2" shape=diamond]
    Endocytosis        [label="Receptor-mediated\nEndocytosis" fillcolor="#E3F2FD" shape=hexagon]
    Nucleocapsid_unc   [label="Nucleocapsid\nUncoating" fillcolor="#FFF9C4"]
    RC_DNA             [label="Relaxed Circular\nDNA (rcDNA)" fillcolor="#FFCC02"]
    Nuclear_import     [label="Nuclear\nImport" fillcolor="#FFF9C4" shape=hexagon]
    cccDNA_minichr     [label="cccDNA\nMinichromosome\n(Nucleus)" fillcolor="#FF8F00" fontcolor="white"]
    HBx_protein        [label="HBx Protein\n(Transactivator)" fillcolor="#FFB300"]
    APOBEC3            [label="APOBEC3A/B\n(Restriction Factor)" fillcolor="#FFCCBC"]
    Histone_mod        [label="Histone\nAcetylation/\nMethylation" fillcolor="#FFF9C4"]
    cccDNA_pool        [label="Intrahepatic\ncccDNA Pool\n(~1-50 copies/cell)" fillcolor="#FF6F00" fontcolor="white"]
  }

  /* =========================================================
     CLUSTER 2: HBV Transcription & Replication
     ========================================================= */
  subgraph cluster_replication {
    label="HBV Transcription & Replication"
    style=filled
    fillcolor="#F3E5F5"
    fontcolor="#4A148C"
    fontsize=12

    RNA_Pol_II         [label="RNA Polymerase II\n(Host)" fillcolor="#E1BEE7" shape=diamond]
    CpG_methylation    [label="CpG Island\nMethylation\n(Epigenetic silencing)" fillcolor="#CE93D8"]
    pgRNA_3kb          [label="Pregenomic RNA\n(pgRNA, 3.5 kb)" fillcolor="#AB47BC" fontcolor="white"]
    preS1_RNA          [label="PreS1 mRNA\n(2.4 kb)" fillcolor="#E1BEE7"]
    preS2_RNA          [label="PreS2/S mRNA\n(2.1 kb)" fillcolor="#E1BEE7"]
    HBx_RNA            [label="HBx mRNA\n(0.7 kb)" fillcolor="#E1BEE7"]
    Epsilon_signal     [label="Epsilon\nEncapsidation\nSignal" fillcolor="#F3E5F5"]
    HBc_protein        [label="Core (HBc)\nProtein\nCapsid subunit" fillcolor="#AB47BC" fontcolor="white"]
    HBe_precursor      [label="HBeAg\nPrecursor\n(preC protein)" fillcolor="#CE93D8"]
    RT_polymerase      [label="HBV RT/DNA\nPolymerase\n(P protein)" fillcolor="#8E24AA" fontcolor="white"]
    Minus_strand_DNA   [label="(−) Strand DNA\n(via RT)" fillcolor="#E1BEE7"]
    Plus_strand_DNA    [label="(+) Strand DNA\n(incomplete)" fillcolor="#E1BEE7"]
    Mature_nucleocap   [label="Mature\nNucleocapsid" fillcolor="#AB47BC" fontcolor="white"]
    HBV_SVP           [label="Subviral Particles\n(SVPs, ~1000-fold\nexcess HBsAg)" fillcolor="#CE93D8"]
    HBV_secretion      [label="Virion\nSecretion\n(ESCRT pathway)" fillcolor="#F3E5F5" shape=hexagon]
    rcDNA_recycling    [label="cccDNA\nAmplification\n(rcDNA→cccDNA)" fillcolor="#7B1FA2" fontcolor="white"]
  }

  /* =========================================================
     CLUSTER 3: Innate Immunity
     ========================================================= */
  subgraph cluster_innate {
    label="Innate Immune Response"
    style=filled
    fillcolor="#E8F5E9"
    fontcolor="#1B5E20"
    fontsize=12

    TLR2               [label="TLR2\n(HBsAg sensing)" fillcolor="#C8E6C9" shape=diamond]
    TLR4               [label="TLR4\n(LPS co-sensor)" fillcolor="#C8E6C9" shape=diamond]
    TLR7               [label="TLR7\n(ssRNA sensing)" fillcolor="#C8E6C9" shape=diamond]
    TLR9               [label="TLR9\n(CpG DNA sensing)" fillcolor="#C8E6C9" shape=diamond]
    RIG_I              [label="RIG-I\n(Cytosolic\nRNA sensor)" fillcolor="#A5D6A7" shape=diamond]
    cGAS               [label="cGAS\n(Cytosolic\nDNA sensor)" fillcolor="#A5D6A7" shape=diamond]
    STING              [label="STING\n(cGAMP sensor)" fillcolor="#81C784"]
    MAVS               [label="MAVS\n(Mitochondrial\nAdaptor)" fillcolor="#81C784"]
    MyD88              [label="MyD88\n(TLR Adaptor)" fillcolor="#66BB6A"]
    IRF3               [label="IRF3\n(Phosphorylated)" fillcolor="#4CAF50" fontcolor="white"]
    IRF7               [label="IRF7\n(pIRF7)" fillcolor="#43A047" fontcolor="white"]
    NF_kB_innate       [label="NF-κB\n(p50/p65)" fillcolor="#388E3C" fontcolor="white"]
    IFN_alpha          [label="IFN-α\n(Type I)" fillcolor="#1B5E20" fontcolor="white"]
    IFN_beta           [label="IFN-β\n(Type I)" fillcolor="#2E7D32" fontcolor="white"]
    JAK_STAT_innate    [label="JAK1/TYK2\nSTAT1/STAT2\nIRF9 → ISGF3" fillcolor="#A5D6A7"]
    ISGs               [label="Interferon-\nStimulated Genes\n(MxA, OAS, ISG15,\nPKR, IFIT1)" fillcolor="#81C784"]
    IFN_evasion_HBx    [label="HBx-mediated\nIFN Evasion\n(IRF3 degradation)" fillcolor="#FFCDD2"]
  }

  /* =========================================================
     CLUSTER 4: Adaptive Immunity & T-cell Exhaustion
     ========================================================= */
  subgraph cluster_adaptive {
    label="Adaptive Immunity & T-cell Exhaustion"
    style=filled
    fillcolor="#E3F2FD"
    fontcolor="#0D47A1"
    fontsize=12

    Kupffer_cell       [label="Kupffer Cell\n(Liver Macrophage)" fillcolor="#90CAF9"]
    Dendritic_cell     [label="Dendritic Cell\n(pDC/mDC)" fillcolor="#90CAF9"]
    MHC_I              [label="MHC Class I\n(Peptide presentation\nto CD8+)" fillcolor="#64B5F6" shape=diamond]
    MHC_II             [label="MHC Class II\n(Peptide presentation\nto CD4+)" fillcolor="#64B5F6" shape=diamond]
    CD4_Th1            [label="CD4+ Th1 Cell\n(IFN-γ, IL-2)" fillcolor="#42A5F5"]
    CD4_Tfh            [label="CD4+ Tfh Cell\n(IL-21, B cell help)" fillcolor="#42A5F5"]
    Treg               [label="CD4+ Treg\n(IL-10, TGF-β)" fillcolor="#29B6F6"]
    CD8_naive          [label="CD8+ T cell\n(Naïve)" fillcolor="#1E88E5" fontcolor="white"]
    CD8_activated      [label="CD8+ CTL\n(Activated)\nHBV-specific" fillcolor="#1565C0" fontcolor="white"]
    CD8_exhausted      [label="CD8+ CTL\n(Exhausted)\n(High viral antigen load)" fillcolor="#B0BEC5"]
    PD1                [label="PD-1\n(Checkpoint)" fillcolor="#78909C" fontcolor="white" shape=diamond]
    PDL1               [label="PD-L1\n(Hepatocyte/\nKupffer)" fillcolor="#78909C" fontcolor="white" shape=diamond]
    TIM3               [label="TIM-3\n(Exhaustion\nmarker)" fillcolor="#90A4AE" shape=diamond]
    LAG3               [label="LAG-3\n(Exhaustion\nmarker)" fillcolor="#90A4AE" shape=diamond]
    CTLA4              [label="CTLA-4\n(Co-inhibitory)" fillcolor="#78909C" fontcolor="white" shape=diamond]
    IFN_gamma          [label="IFN-γ\n(Non-cytolytic\nHBV clearance)" fillcolor="#42A5F5"]
    IL_12              [label="IL-12\n(Th1 polarization)" fillcolor="#64B5F6"]
    B_cell             [label="B Cell\n(HBsAg-specific)" fillcolor="#90CAF9"]
    HBsAb              [label="Anti-HBs\n(Protective Ab)" fillcolor="#BBDEFB"]
    HBeAb              [label="Anti-HBe\n(Seroconversion\nmarker)" fillcolor="#BBDEFB"]
    Anti_HBc           [label="Anti-HBc\n(IgM/IgG)" fillcolor="#BBDEFB"]
    IL_10_adaptive     [label="IL-10\n(Immunosuppressive)" fillcolor="#B0BEC5"]
    TGF_beta_Treg      [label="TGF-β\n(Treg-derived)" fillcolor="#CFD8DC"]
  }

  /* =========================================================
     CLUSTER 5: Liver Pathology
     ========================================================= */
  subgraph cluster_liver_path {
    label="Liver Pathology & Hepatocyte Biology"
    style=filled
    fillcolor="#FBE9E7"
    fontcolor="#BF360C"
    fontsize=12

    Hepatocyte_healthy [label="Healthy\nHepatocyte\n(Target Cell T)" fillcolor="#A5D6A7"]
    Hepatocyte_infect  [label="HBV-Infected\nHepatocyte\n(Infected Cell I)" fillcolor="#FFCC80"]
    Hepatocyte_injured [label="Injured\nHepatocyte\n(Cytolysis)" fillcolor="#FF8A65"]
    ALT_release        [label="ALT Release\n(IU/L)" fillcolor="#FF7043" fontcolor="white"]
    AST_release        [label="AST Release\n(IU/L)" fillcolor="#FF8A65"]
    FasL_pathway       [label="Fas/FasL\nApoptosis\nPathway" fillcolor="#FFCCBC"]
    TRAIL_pathway      [label="TRAIL\nApoptosis\nPathway" fillcolor="#FFCCBC"]
    Caspase3_8         [label="Caspase-3/8\n(Executioner)" fillcolor="#FF7043" fontcolor="white"]
    TNF_alpha_liver    [label="TNF-α\n(Kupffer-derived)" fillcolor="#EF9A9A"]
    Necroinflam        [label="Necroinflammation\n(Knodell HAI score)" fillcolor="#EF5350" fontcolor="white"]
    Portal_inflam      [label="Portal\nInflammation" fillcolor="#EF9A9A"]
    Lobular_inflam     [label="Lobular\nInflammation" fillcolor="#EF9A9A"]
    Ductular_react     [label="Ductular\nReaction\n(Progenitor cells)" fillcolor="#FFCCBC"]
  }

  /* =========================================================
     CLUSTER 6: Fibrosis & Portal Hypertension
     ========================================================= */
  subgraph cluster_fibrosis {
    label="Hepatic Fibrosis & Portal Hypertension"
    style=filled
    fillcolor="#FCE4EC"
    fontcolor="#880E4F"
    fontsize=12

    HSC_quiescent      [label="Quiescent HSC\n(Vitamin A store)" fillcolor="#F8BBD9"]
    HSC_activated      [label="Activated HSC\n(α-SMA+)" fillcolor="#F48FB1"]
    Myofibroblast      [label="Myofibroblast\n(Portal fibroblast)" fillcolor="#EC407A" fontcolor="white"]
    TGF_beta1_fibro    [label="TGF-β1\n(Pro-fibrotic\nmaster regulator)" fillcolor="#C2185B" fontcolor="white"]
    Smad2_3            [label="Smad 2/3\n(Canonical pathway)" fillcolor="#E91E63" fontcolor="white"]
    Smad7              [label="Smad 7\n(Negative feedback)" fillcolor="#F8BBD9"]
    PDGF               [label="PDGF\n(HSC mitogen)" fillcolor="#F48FB1"]
    Collagen_I_III     [label="Collagen I/III\n(ECM Deposition)" fillcolor="#C2185B" fontcolor="white"]
    MMP2_9             [label="MMP-2/-9\n(Matrix Degradation)" fillcolor="#F48FB1"]
    TIMP1              [label="TIMP-1\n(MMP inhibitor)" fillcolor="#F8BBD9"]
    Fibrosis_score     [label="Fibrosis Score\n(Metavir F0→F4)" fillcolor="#880E4F" fontcolor="white"]
    Portal_pressure    [label="Portal Pressure\n(HVPG mmHg)" fillcolor="#AD1457" fontcolor="white"]
    Splenomegaly       [label="Splenomegaly\n(Platelet sequestration)" fillcolor="#F8BBD9"]
  }

  /* =========================================================
     CLUSTER 7: Viral Immune Evasion & Persistence
     ========================================================= */
  subgraph cluster_evasion {
    label="Viral Immune Evasion & Persistence"
    style=filled
    fillcolor="#FFF3E0"
    fontcolor="#E65100"
    fontsize=12

    HBsAg_excess       [label="HBsAg Excess\n(SVP immunodecoy)" fillcolor="#FFCC80"]
    cccDNA_persist     [label="cccDNA Nuclear\nPersistence\n(Half-life: years)" fillcolor="#FF8F00" fontcolor="white"]
    Epigenetic_sil     [label="Epigenetic\nSilencing\n(CpG methylation)" fillcolor="#FFA726"]
    HBe_tolerogen      [label="HBeAg\n(Tolerogenic;\nimmunosuppressive)" fillcolor="#FFB300"]
    Integrated_HBV     [label="Integrated HBV\nDNA (HCC driver)" fillcolor="#E65100" fontcolor="white"]
    Viral_mutants      [label="Viral Mutants\n(rtM204I/V ETV-R\nrtA194T TDF-R)" fillcolor="#FF5722" fontcolor="white"]
    sAg_escape         [label="Surface Antigen\nEscape Mutants\n(sG145R)" fillcolor="#FF8A65"]
    HBx_NFkB_stim     [label="HBx→NF-κB\n(Survival signaling\nin infected cells)" fillcolor="#FFCC80"]
    IL10_induction     [label="IL-10 Induction\n(Viral-mediated\nimmunosuppression)" fillcolor="#FFF9C4"]
    DNAtol             [label="Immune Tolerant\nPhase (HBeAg+,\nhigh DNA, norm ALT)" fillcolor="#FFE0B2"]
    Clearance_phase    [label="Immune Clearance\nPhase (HBeAg+,\nhigh ALT)" fillcolor="#FFCC80"]
  }

  /* =========================================================
     CLUSTER 8: Drug PK/PD
     ========================================================= */
  subgraph cluster_drugs {
    label="Drug PK/PD: Nucleos(t)ide Analogues · Peg-IFN · Novel Agents"
    style=filled
    fillcolor="#E8EAF6"
    fontcolor="#1A237E"
    fontsize=12

    /* Entecavir (ETV) */
    ETV_dose           [label="Entecavir\n0.5 mg PO QD\n(naïve)\n1.0 mg (LamivR)" fillcolor="#C5CAE9" shape=box]
    ETV_gut            [label="ETV\nGut (A1)" fillcolor="#9FA8DA"]
    ETV_plasma         [label="ETV Plasma\n(Cmax ~4 ng/mL)" fillcolor="#7986CB"]
    ETV_liver          [label="ETV Liver\nUptake" fillcolor="#5C6BC0"]
    ETV_TP             [label="ETV-TP\n(Active Triphosphate\nIC50 0.004 µM)" fillcolor="#3949AB" fontcolor="white"]
    ETV_RT_inhib       [label="RT Inhibition\n(ETV): Priming\nReverse Trans\nDNA-dep DNA syn" fillcolor="#1A237E" fontcolor="white"]

    /* Tenofovir DF / TAF */
    TDF_dose           [label="TDF 300 mg\nor TAF 25 mg\nPO QD" fillcolor="#C5CAE9" shape=box]
    TDF_gut            [label="TDF/TAF\nGut (A2)" fillcolor="#9FA8DA"]
    TDF_plasma         [label="TFV Plasma\n(Cmax 300 ng/mL)" fillcolor="#7986CB"]
    TFV_DP             [label="TFV-DP\n(Active Diphosphate\nIC50 0.5 µM)" fillcolor="#3949AB" fontcolor="white"]
    TDF_RT_inhib       [label="RT Inhibition\n(TFV): Chain\nTerminator" fillcolor="#1A237E" fontcolor="white"]

    /* Peg-IFN-α2a */
    PegIFN_dose        [label="Peg-IFNα-2a\n180 µg SC\nQW × 48 wks" fillcolor="#B39DDB" shape=box]
    PegIFN_SC          [label="PegIFN SC\nDepot (A3)" fillcolor="#9575CD"]
    PegIFN_plasma      [label="PegIFN Plasma\n(t½ ~70-140 h)" fillcolor="#7E57C2"]
    IFN_JAKSTAT        [label="JAK-STAT\nActivation\n(IFNAR→ISGs)" fillcolor="#673AB7" fontcolor="white"]
    IFN_antiHBV        [label="IFN Antiviral\nEffect on cccDNA\n& viral replication" fillcolor="#4527A0" fontcolor="white"]
    IFN_immuno         [label="IFN Immune\nModulation\n(NK, CTL boost)" fillcolor="#512DA8" fontcolor="white"]

    /* Novel Agents */
    Bulevirtide        [label="Bulevirtide\n(2 mg SC QD)\nNTCP Inhibitor" fillcolor="#B3E5FC" shape=box]
    siRNA_GalNAc       [label="GalNAc-siRNA\n(JNJ-3989,\nVIR-2218)\nHBsAg knockdown" fillcolor="#B3E5FC" shape=box]
    CpAM               [label="CpAM\n(Capsid Assembly\nModulator\nJNJ-56136379)" fillcolor="#B3E5FC" shape=box]
  }

  /* =========================================================
     CLUSTER 9: Long-term Complications
     ========================================================= */
  subgraph cluster_complications {
    label="Long-term Complications"
    style=filled
    fillcolor="#EFEBE9"
    fontcolor="#3E2723"
    fontsize=12

    Comp_cirrhosis     [label="Compensated\nCirrhosis\n(Child A)" fillcolor="#BCAAA4"]
    Decomp_cirrhosis   [label="Decompensated\nCirrhosis\n(Child B/C)" fillcolor="#8D6E63" fontcolor="white"]
    Varices            [label="Esophageal\nVarices\n(Bleeding risk)" fillcolor="#795548" fontcolor="white"]
    Ascites_HE         [label="Ascites /\nHepatic\nEncephalopathy" fillcolor="#6D4C41" fontcolor="white"]
    HCC                [label="Hepatocellular\nCarcinoma (HCC)" fillcolor="#4E342E" fontcolor="white"]
    AFP_marker         [label="AFP Biomarker\n(>20 ng/mL)" fillcolor="#A1887F"]
    HCC_surveillance   [label="HCC Surveillance\n(US + AFP q6m)" fillcolor="#BCAAA4"]
    Liver_failure      [label="Liver Failure\n(MELD >15)" fillcolor="#5D4037" fontcolor="white"]
    Liver_transplant   [label="Liver\nTransplantation\n(HBIg + ETV/TDF)" fillcolor="#8D6E63" fontcolor="white"]
    HBV_reactivation   [label="HBV Reactivation\n(Immunosuppression\nB-cell depletion)" fillcolor="#A1887F"]
    Extrahepatic       [label="Extrahepatic\nManifestations\n(PAN, GN, serum\nsickness)" fillcolor="#D7CCC8"]
  }

  /* =========================================================
     CLUSTER 10: Clinical Endpoints & Monitoring
     ========================================================= */
  subgraph cluster_endpoints {
    label="Clinical Endpoints & Monitoring"
    style=filled
    fillcolor="#F1F8E9"
    fontcolor="#1B5E20"
    fontsize=12

    HBV_DNA_monitor    [label="Serum HBV DNA\n(IU/mL, log scale)\nTarget: <20 IU/mL" fillcolor="#DCEDC8"]
    HBsAg_monitor      [label="HBsAg Titer\n(IU/mL)\nLoss = functional cure" fillcolor="#C5E1A5"]
    HBeAg_status       [label="HBeAg Status\n(+/−)\n& Anti-HBe" fillcolor="#AED581"]
    Functional_cure    [label="Functional Cure\n(HBsAg loss +\nanti-HBs)" fillcolor="#7CB342" fontcolor="white"]
    ALT_norm           [label="ALT Normalization\n(<40 IU/L = 1×ULN)" fillcolor="#8BC34A"]
    Histo_response     [label="Histologic\nResponse\n(≥2-point HAI↓)" fillcolor="#9CCC65"]
    FIB4_score         [label="FIB-4 Score\n(<1.45 low risk\n>3.25 high risk)" fillcolor="#AED581"]
    LSM_kPa            [label="Liver Stiffness\n(Elastography\nkPa)" fillcolor="#DCEDC8"]
    MELD_score         [label="MELD Score\n(Bili + INR + Cr)" fillcolor="#558B2F" fontcolor="white"]
    Child_Pugh         [label="Child-Pugh Score\n(A/B/C)" fillcolor="#33691E" fontcolor="white"]
    HCC_risk_score     [label="HCC Risk Score\n(PAGE-B / REACH-B)" fillcolor="#1B5E20" fontcolor="white"]
    Complete_viro      [label="Complete\nVirologic\nResponse\n(HBV DNA undetect.)" fillcolor="#7CB342" fontcolor="white"]
    Biochem_resp       [label="Biochemical\nResponse\n(ALT norm + DNA<20)" fillcolor="#8BC34A"]
    Treat_endpoint     [label="Treatment\nEndpoint\n(HBeAg loss/\nHBsAg loss)" fillcolor="#558B2F" fontcolor="white"]
  }

  /* =========================================================
     EDGES: Cluster 1 → Cluster 2 (HBV Entry → Replication)
     ========================================================= */
  HBV_Particle -> LHBsAg [label="Surface\nenveloped by"]
  LHBsAg -> PreS1_domain [label="contains"]
  LHBsAg -> PreS2_domain [label="contains"]
  LHBsAg -> SHBsAg [label="contains S"]
  PreS1_domain -> HSPG_receptor [label="initial\nattachment"]
  PreS1_domain -> NTCP_receptor [label="high-affinity\nbinding" color="red" penwidth=2]
  HSPG_receptor -> Endocytosis [label="tethering"]
  NTCP_receptor -> Endocytosis [label="entry\nreceptor" color="red" penwidth=2]
  Endocytosis -> Nucleocapsid_unc [label="pH-dependent"]
  Nucleocapsid_unc -> RC_DNA [label="releases"]
  RC_DNA -> Nuclear_import [label="→ nucleus"]
  Nuclear_import -> cccDNA_minichr [label="conversion\n(gap repair)" color="red" penwidth=2]
  cccDNA_minichr -> Histone_mod [label="chromatin\nremodeling"]
  HBx_protein -> cccDNA_minichr [label="transactivates\n(DDB1-CRL4)" color="orange" penwidth=1.5]
  cccDNA_minichr -> cccDNA_pool [label="accumulates"]
  APOBEC3 -> cccDNA_minichr [label="deaminates\n(restriction)" color="blue"]
  cccDNA_pool -> HBx_protein [label="encodes"]

  /* Cluster 1 → Cluster 2 */
  cccDNA_pool -> RNA_Pol_II [label="template\nfor transcription"]
  CpG_methylation -> cccDNA_pool [label="silences\n(epigenetic)" color="blue"]
  cccDNA_pool -> pgRNA_3kb [label="transcribes" color="red" penwidth=2]
  cccDNA_pool -> preS1_RNA [label="transcribes"]
  cccDNA_pool -> preS2_RNA [label="transcribes"]
  cccDNA_pool -> HBx_RNA [label="transcribes"]
  pgRNA_3kb -> Epsilon_signal [label="5'-epsilon\nstructure"]
  pgRNA_3kb -> HBc_protein [label="encodes\ncapsid"]
  pgRNA_3kb -> HBe_precursor [label="encodes\nHBeAg"]
  pgRNA_3kb -> RT_polymerase [label="encodes P\nprotein"]
  Epsilon_signal -> RT_polymerase [label="P binds\n(priming)"]
  HBc_protein -> Mature_nucleocap [label="self-assembles"]
  RT_polymerase -> Minus_strand_DNA [label="reverse\ntranscribes" color="red" penwidth=2]
  Minus_strand_DNA -> Plus_strand_DNA [label="DNA pol\n(partial)"]
  Plus_strand_DNA -> Mature_nucleocap [label="packaged\nrcDNA"]
  Mature_nucleocap -> HBV_secretion [label="enveloped by\nHBsAg"]
  Mature_nucleocap -> rcDNA_recycling [label="→ nucleus\n(amplification)"]
  rcDNA_recycling -> cccDNA_pool [label="maintains\npool" color="red" penwidth=2]
  HBV_secretion -> HBV_Particle [label="new virion"]
  preS2_RNA -> SHBsAg [label="encodes"]
  SHBsAg -> HBV_SVP [label="excess\nSVPs" color="orange"]
  HBV_SVP -> HBsAg_excess [style=dashed lhead=cluster_evasion]

  /* Cluster 1 → Cluster 3 (Innate) */
  HBV_Particle -> TLR2 [label="HBsAg\ntrigger" style=dashed color="#2E7D32"]
  pgRNA_3kb -> RIG_I [label="dsRNA\nintermediates" style=dashed color="#2E7D32"]
  RC_DNA -> cGAS [label="cytosolic\nDNA sensing" style=dashed color="#2E7D32"]
  TLR2 -> MyD88 [color="#2E7D32"]
  TLR7 -> MyD88 [color="#2E7D32"]
  TLR9 -> MyD88 [color="#2E7D32"]
  TLR4 -> MyD88 [color="#2E7D32"]
  cGAS -> STING [label="cGAMP" color="#2E7D32"]
  RIG_I -> MAVS [color="#2E7D32"]
  STING -> IRF3 [color="#2E7D32"]
  MAVS -> IRF3 [color="#2E7D32"]
  MyD88 -> NF_kB_innate [color="#2E7D32"]
  MyD88 -> IRF7 [color="#2E7D32"]
  IRF3 -> IFN_beta [color="#2E7D32" penwidth=2]
  IRF7 -> IFN_alpha [color="#2E7D32" penwidth=2]
  NF_kB_innate -> TNF_alpha_liver [style=dashed lhead=cluster_liver_path]
  IFN_alpha -> JAK_STAT_innate [color="#2E7D32"]
  IFN_beta -> JAK_STAT_innate [color="#2E7D32"]
  JAK_STAT_innate -> ISGs [color="#2E7D32" penwidth=2]
  ISGs -> RT_polymerase [label="inhibit\nreplication" color="blue" style=dashed]
  HBx_protein -> IFN_evasion_HBx [label="suppresses\nIRF3" color="red"]
  IFN_evasion_HBx -> IRF3 [label="degrades" color="red" arrowhead=tee]
  HBx_protein -> NF_kB_innate [label="activates\n(pro-survival)" color="orange"]

  /* Cluster 3/4 interaction */
  IFN_alpha -> Dendritic_cell [style=dashed color="#1565C0"]
  IFN_alpha -> CD8_naive [label="activates" style=dashed color="#1565C0"]
  IL_12 -> CD4_Th1 [color="#1565C0"]
  IL_12 -> CD8_activated [color="#1565C0"]
  Kupffer_cell -> IL_12 [color="#1565C0"]
  Kupffer_cell -> TNF_alpha_liver [color="#bf360c"]
  Dendritic_cell -> MHC_I [color="#1565C0"]
  Dendritic_cell -> MHC_II [color="#1565C0"]
  MHC_I -> CD8_naive [label="antigen\npresentation" color="#1565C0"]
  MHC_II -> CD4_Th1 [label="antigen\npresentation" color="#1565C0"]
  CD8_naive -> CD8_activated [label="priming\n+ expansion" color="#1565C0" penwidth=2]
  CD4_Th1 -> CD8_activated [label="CD4 help\nIL-2" color="#1565C0"]
  CD4_Tfh -> B_cell [label="help via\nIL-21" color="#1565C0"]
  B_cell -> HBsAb [label="class switch\n(upon HBsAg loss)"]
  B_cell -> HBeAb [label="upon HBeAg\nseroconversion"]
  B_cell -> Anti_HBc [label="persistent\nmarker"]
  CD8_activated -> IFN_gamma [color="#1565C0"]
  IFN_gamma -> cccDNA_pool [label="non-cytolytic\nclearance" color="blue" style=dashed arrowhead=tee]
  IFN_gamma -> HBV_Particle [label="suppresses\nreplication" color="blue" style=dashed arrowhead=tee]

  /* T cell Exhaustion */
  HBsAg_excess -> PD1 [label="chronic\nantigen → PD-1↑" color="#78909C"]
  HBeAg_tolerogen -> Treg [label="tolerization" color="orange" lhead=cluster_evasion]
  PD1 -> PDL1 [label="PD-1/PD-L1\ninteraction" color="#78909C"]
  PDL1 -> CD8_activated [label="inhibits" color="red" arrowhead=tee]
  TIM3 -> CD8_activated [label="coinhibitory" color="red" arrowhead=tee]
  LAG3 -> CD8_activated [label="coinhibitory" color="red" arrowhead=tee]
  CTLA4 -> CD4_Th1 [label="inhibits\nactivation" color="red" arrowhead=tee]
  CD8_activated -> CD8_exhausted [label="chronic\nstimulation" color="#78909C"]
  CD8_exhausted -> PD1 [label="upregulates"]
  CD8_exhausted -> TIM3 [label="upregulates"]
  CD8_exhausted -> LAG3 [label="upregulates"]
  Treg -> IL_10_adaptive [label="secretes"]
  Treg -> TGF_beta_Treg [label="secretes"]
  IL_10_adaptive -> CD8_activated [label="suppresses" color="red" arrowhead=tee style=dashed]
  IL_10_adaptive -> IL_12 [label="suppresses" color="red" arrowhead=tee style=dashed]

  /* Cluster 4 → Cluster 5 (Liver Pathology) */
  CD8_activated -> Hepatocyte_infect [label="cytotoxic\nkilling" color="red" penwidth=2]
  CD8_activated -> FasL_pathway [label="FasL-mediated\napoptosis" color="red"]
  TNF_alpha_liver -> TRAIL_pathway [color="red"]
  FasL_pathway -> Caspase3_8 [color="red"]
  TRAIL_pathway -> Caspase3_8 [color="red"]
  Caspase3_8 -> Hepatocyte_injured [color="red" penwidth=2]
  Hepatocyte_injured -> ALT_release [color="red" penwidth=2]
  Hepatocyte_injured -> AST_release [color="red"]
  Hepatocyte_infect -> Necroinflam [label="pro-inflam\ncytokines"]
  ALT_release -> Necroinflam [label="marker of\nliver damage"]
  Necroinflam -> Portal_inflam
  Necroinflam -> Lobular_inflam
  Hepatocyte_healthy -> Hepatocyte_infect [label="HBV infection\n(β × T × V)" color="orange" penwidth=2]
  Hepatocyte_infect -> Hepatocyte_injured [label="apoptosis/\nnecrosis"]
  Ductular_react -> Hepatocyte_healthy [label="regeneration\nattempt"]

  /* Cluster 5 → Cluster 6 (Fibrosis) */
  Necroinflam -> TGF_beta1_fibro [label="activates\nHSC" color="#880E4F" penwidth=2]
  TNF_alpha_liver -> HSC_quiescent [label="activates" color="#880E4F"]
  TGF_beta_Treg -> TGF_beta1_fibro [color="#880E4F"]
  TGF_beta1_fibro -> Smad2_3 [color="#880E4F" penwidth=2]
  Smad2_3 -> Collagen_I_III [color="#880E4F" penwidth=2]
  Smad2_3 -> TIMP1 [color="#880E4F"]
  Smad7 -> Smad2_3 [label="inhibits\n(feedback)" color="blue" arrowhead=tee]
  TGF_beta1_fibro -> Smad7 [label="induces\nfeedback"]
  PDGF -> HSC_quiescent [label="proliferation\nsignal" color="#880E4F"]
  HSC_quiescent -> HSC_activated [label="activation\n(TGF-β/PDGF)" color="#880E4F" penwidth=2]
  HSC_activated -> Myofibroblast [label="differentiation"]
  Myofibroblast -> Collagen_I_III [label="synthesizes" color="#880E4F" penwidth=2]
  Myofibroblast -> MMP2_9 [label="activates"]
  Myofibroblast -> TIMP1 [label="secretes"]
  TIMP1 -> MMP2_9 [label="inhibits" color="blue" arrowhead=tee]
  Collagen_I_III -> Fibrosis_score [label="progressive\ndeposition" color="#880E4F" penwidth=2]
  Fibrosis_score -> Portal_pressure [label="F3-F4:\nPH develops" color="#880E4F"]
  Portal_pressure -> Splenomegaly [color="#880E4F"]

  /* Cluster 6 → Cluster 9 (Complications) */
  Fibrosis_score -> Comp_cirrhosis [label="F4\ncirrhosis" color="#3E2723" penwidth=2]
  Comp_cirrhosis -> Decomp_cirrhosis [label="bacterial\ninfection,\nbleeding" color="#3E2723"]
  Portal_pressure -> Varices [label="HVPG\n>10 mmHg" color="#3E2723"]
  Varices -> Decomp_cirrhosis [label="bleeding\nepisode" color="#3E2723"]
  Portal_pressure -> Ascites_HE [label="HVPG\n>12 mmHg" color="#3E2723"]
  Decomp_cirrhosis -> Liver_failure [color="#3E2723" penwidth=2]
  Liver_failure -> Liver_transplant [color="#3E2723"]
  Integrated_HBV -> HCC [label="insertional\nmutagenesis" color="#4E342E" penwidth=2]
  Fibrosis_score -> HCC [label="cirrhosis-\nassociated\nHCC risk" color="#4E342E"]
  HCC -> AFP_marker [label="produces"]
  HCC -> HCC_surveillance [label="detected by"]
  HCC -> Liver_failure [label="advanced\ndisease"]
  HBV_reactivation -> Hepatocyte_infect [label="reinfection"]

  /* Viral evasion → persistence connections */
  cccDNA_pool -> cccDNA_persist [label="nuclear\nstability"]
  cccDNA_minichr -> Epigenetic_sil [label="methylation\nsilences"]
  HBe_precursor -> HBe_tolerogen [lhead=cluster_evasion]
  RT_polymerase -> Viral_mutants [label="error-prone\nreplication"]
  SHBsAg -> sAg_escape [label="mutation\npressure"]
  HBx_protein -> HBx_NFkB_stim [lhead=cluster_evasion]
  HBx_NFkB_stim -> Hepatocyte_infect [label="anti-apoptotic\nsurvival" color="orange"]
  cccDNA_persist -> Integrated_HBV [label="integration\ninto host DNA"]
  HBsAg_excess -> IL10_induction [color="orange"]
  IL10_induction -> CD8_activated [label="suppresses" color="red" arrowhead=tee style=dashed]
  DNAtol -> Clearance_phase [label="immune\nclearance"]
  Clearance_phase -> HBeAg_status [style=dashed lhead=cluster_endpoints]

  /* Drug PK/PD connections */
  ETV_dose -> ETV_gut [label="oral\nabsorption\nF~37%"]
  ETV_gut -> ETV_plasma [label="ka=0.9/h\nVc=73 L" color="#1A237E"]
  ETV_plasma -> ETV_liver [label="hepatic\nuptake" color="#1A237E"]
  ETV_liver -> ETV_TP [label="phosphorylation\n(kinases)" color="#1A237E" penwidth=2]
  ETV_TP -> ETV_RT_inhib [label="competitive\ninhibition\nIC50=0.004 µM" color="#1A237E" penwidth=2]
  ETV_RT_inhib -> RT_polymerase [label="inhibits RT\n(priming + rev. trans.)" color="blue" arrowhead=tee penwidth=2]
  ETV_RT_inhib -> rcDNA_recycling [label="reduces\ncccDNA\nreplenishment" color="blue" arrowhead=tee style=dashed]

  TDF_dose -> TDF_gut [label="oral\nF~25%(TDF)\n~80%(TAF)"]
  TDF_gut -> TDF_plasma [label="ka=0.5/h" color="#1A237E"]
  TDF_plasma -> TFV_DP [label="intracellular\nphosphorylation" color="#1A237E" penwidth=2]
  TFV_DP -> TDF_RT_inhib [label="chain\ntermination\nIC50=0.5 µM" color="#1A237E" penwidth=2]
  TDF_RT_inhib -> RT_polymerase [label="inhibits" color="blue" arrowhead=tee penwidth=2]
  TDF_RT_inhib -> Minus_strand_DNA [label="terminates" color="blue" arrowhead=tee]

  PegIFN_dose -> PegIFN_SC [label="SC injection\nDepot"]
  PegIFN_SC -> PegIFN_plasma [label="absorption\nt½=10-20h\nka=0.04/h" color="#4527A0"]
  PegIFN_plasma -> IFN_JAKSTAT [label="IFNAR\nbinding" color="#4527A0" penwidth=2]
  IFN_JAKSTAT -> IFN_antiHBV [label="ISGs→\nantiviral state" color="#4527A0" penwidth=2]
  IFN_JAKSTAT -> IFN_immuno [label="NK/CTL\nactivation" color="#4527A0"]
  IFN_antiHBV -> cccDNA_pool [label="reduces\ncccDNA" color="blue" arrowhead=tee penwidth=2]
  IFN_antiHBV -> pgRNA_3kb [label="reduces\ntranscription" color="blue" arrowhead=tee]
  IFN_immuno -> CD8_activated [label="enhances\nCTL" color="blue"]
  IFN_immuno -> CD8_exhausted [label="may reverse\nexhaustion" color="blue" style=dashed]

  Bulevirtide -> NTCP_receptor [label="competitive\nblockade\nIC50~0.3 nM" color="blue" arrowhead=tee penwidth=2]
  siRNA_GalNAc -> HBsAg_excess [label="HBsAg\nknockdown\n>90%" color="blue" arrowhead=tee penwidth=2]
  siRNA_GalNAc -> HBV_SVP [label="reduces\nSVP" color="blue" arrowhead=tee]
  CpAM -> Mature_nucleocap [label="incorrect\nassembly\n(empty capsids)" color="blue" arrowhead=tee]
  CpAM -> pgRNA_3kb [label="misdirects\npgRNA" color="blue" arrowhead=tee style=dashed]

  /* Endpoints connections */
  HBV_Particle -> HBV_DNA_monitor [label="serum\nviremia" style=dashed]
  HBV_SVP -> HBsAg_monitor [label="dominant\nHBsAg source" style=dashed]
  HBeAg_precursor -> HBeAg_status [style=dashed lhead=cluster_endpoints]
  HBsAb -> Functional_cure [label="anti-HBs\nappears"]
  HBsAg_monitor -> Functional_cure [label="HBsAg\nloss (<0.05 IU/mL)" color="green" penwidth=2]
  ALT_release -> ALT_norm [style=dashed]
  Necroinflam -> Histo_response [label="liver\nbiopsy" style=dashed]
  Fibrosis_score -> FIB4_score [label="correlated" style=dashed]
  Fibrosis_score -> LSM_kPa [label="elastography" style=dashed]
  Decomp_cirrhosis -> MELD_score [label="calculates"]
  Comp_cirrhosis -> Child_Pugh [label="scores"]
  Fibrosis_score -> HCC_risk_score [label="cirrhosis\nincreases risk"]
  HBV_DNA_monitor -> Complete_viro [label="<20 IU/mL\n= undetectable" color="green" penwidth=2]
  Complete_viro -> Biochem_resp [color="green"]
  ALT_norm -> Biochem_resp [color="green"]
  HBeAg_status -> Treat_endpoint [color="green"]
  Functional_cure -> Treat_endpoint [color="green" penwidth=2]
  Biochem_resp -> Treat_endpoint [color="green"]
}
