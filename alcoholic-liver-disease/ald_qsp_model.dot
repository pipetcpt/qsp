digraph ALD_QSP {
  graph [
    rankdir=LR
    splines=true
    overlap=false
    nodesep=0.35
    ranksep=0.8
    fontname="Helvetica"
    fontsize=11
    label="Alcoholic Liver Disease (ALD) — QSP Mechanistic Map\nEthanol Metabolism · Oxidative Stress · Gut–Liver Axis · Kupffer Cell/NLRP3 · Neutrophil Infiltration · Hepatocyte Death & Regeneration · Fibrosis · Drug PK/PD · Clinical Endpoints"
    labelloc=t
    labeljust=c
    bgcolor="#FAFAFA"
  ]
  node [
    shape=box
    style="filled,rounded"
    fontname="Helvetica"
    fontsize=9
    width=1.4
    height=0.35
    fillcolor="#FFFFFF"
    color="#666666"
  ]
  edge [
    fontname="Helvetica"
    fontsize=8
    color="#888888"
    arrowsize=0.7
  ]

  //=========================================================
  // CLUSTER 1: ETHANOL METABOLISM
  //=========================================================
  subgraph cluster_ethanol {
    label="① Ethanol Metabolism"
    style=filled
    fillcolor="#FFF3E0"
    color="#E65100"
    fontcolor="#E65100"
    fontsize=11

    ethanol_intake    [label="Ethanol\nIntake (g/day)"   fillcolor="#FFCCBC" color="#E64A19"]
    stomach_absorp    [label="Stomach\nAbsorption"        fillcolor="#FFE0B2"]
    small_int_absorp  [label="Small Intestine\nAbsorption" fillcolor="#FFE0B2"]
    portal_ethanol    [label="Portal Vein\nEthanol"       fillcolor="#FFD54F"]
    blood_ethanol     [label="Blood Ethanol\n(BAC, mg/dL)" fillcolor="#FFCC02" color="#F57F17"]
    liver_ethanol     [label="Liver Ethanol\n(Hepatocyte)" fillcolor="#FFB74D" color="#E65100"]

    ADH1B             [label="ADH1B/1C/4\n(cytosolic)"   fillcolor="#CE93D8" color="#7B1FA2"]
    CYP2E1            [label="CYP2E1\n(microsomal MEOS)" fillcolor="#CE93D8" color="#7B1FA2"]
    catalase_etoh     [label="Catalase\n(peroxisomal)"   fillcolor="#CE93D8" color="#7B1FA2"]
    ALDH2             [label="ALDH2\n(mitochondrial)"    fillcolor="#CE93D8" color="#7B1FA2"]
    ALDH1A1           [label="ALDH1A1\n(cytosolic)"      fillcolor="#CE93D8" color="#7B1FA2"]

    acetaldehyde      [label="Acetaldehyde\n(toxic)"     fillcolor="#EF9A9A" color="#C62828"]
    acetate           [label="Acetate →\nAcetyl-CoA"     fillcolor="#C8E6C9"]
    NADH_cytosol      [label="NADH↑ / NAD+↓\n(cytosol redox shift)" fillcolor="#FFAB91" color="#BF360C"]
    NADH_mito         [label="NADH↑\n(mitochondrial)"   fillcolor="#FFAB91" color="#BF360C"]
    protein_adducts   [label="Protein\nAdducts (MAA)"   fillcolor="#EF9A9A" color="#B71C1C"]
    DNA_adducts       [label="DNA Adducts\n(mutagenic)"  fillcolor="#EF9A9A" color="#B71C1C"]
    FA_oxid_inhib     [label="β-Oxidation\nInhibited"   fillcolor="#FFCDD2"]
    triglyceride_accum[label="Triglyceride\nAccumulation" fillcolor="#FFCDD2"]
    SIAH1             [label="SIAH1\nCYP2E1 inducer"    fillcolor="#E1BEE7"]
    CYP2E1_induced    [label="CYP2E1\nInduction (chronic)" fillcolor="#CE93D8" color="#7B1FA2"]

    ethanol_intake -> stomach_absorp
    ethanol_intake -> small_int_absorp
    stomach_absorp -> blood_ethanol
    small_int_absorp -> portal_ethanol
    portal_ethanol -> liver_ethanol
    blood_ethanol -> liver_ethanol
    liver_ethanol -> ADH1B [label="primary\nlow-dose"]
    liver_ethanol -> CYP2E1 [label="chronic/high\ndose"]
    liver_ethanol -> catalase_etoh [label="minor"]
    ADH1B -> acetaldehyde
    ADH1B -> NADH_cytosol
    CYP2E1 -> acetaldehyde
    catalase_etoh -> acetaldehyde
    acetaldehyde -> ALDH2 [label="→ detox"]
    acetaldehyde -> ALDH1A1 [label="→ detox"]
    ALDH2 -> acetate
    ALDH2 -> NADH_mito
    ALDH1A1 -> acetate
    acetaldehyde -> protein_adducts [label="covalent\nbinding"]
    acetaldehyde -> DNA_adducts
    NADH_cytosol -> FA_oxid_inhib [label="NADH/NAD+↑"]
    NADH_mito -> FA_oxid_inhib
    FA_oxid_inhib -> triglyceride_accum
    SIAH1 -> CYP2E1_induced [label="transcription"]
    CYP2E1_induced -> CYP2E1 [label="upregulates"]
  }

  //=========================================================
  // CLUSTER 2: OXIDATIVE STRESS
  //=========================================================
  subgraph cluster_oxidative {
    label="② Oxidative Stress & Antioxidant Defense"
    style=filled
    fillcolor="#FCE4EC"
    color="#AD1457"
    fontcolor="#AD1457"
    fontsize=11

    superoxide        [label="Superoxide (O₂•⁻)"       fillcolor="#F48FB1" color="#880E4F"]
    H2O2              [label="Hydrogen Peroxide\n(H₂O₂)" fillcolor="#F48FB1" color="#880E4F"]
    OH_radical        [label="Hydroxyl Radical\n(•OH)"  fillcolor="#F06292" color="#880E4F"]
    lipid_perox       [label="Lipid Peroxidation\n(mtGPX4↓)" fillcolor="#E91E63" color="#880E4F" style="filled,bold"]
    HNE_4             [label="4-HNE\n(toxic aldehyde)"  fillcolor="#F48FB1" color="#880E4F"]
    MDA               [label="MDA\n(oxidative marker)"  fillcolor="#F48FB1" color="#880E4F"]

    GSH               [label="GSH\n(reduced glutathione)" fillcolor="#A5D6A7" color="#1B5E20" style="filled,bold"]
    GSSG              [label="GSSG\n(oxidized)"          fillcolor="#C8E6C9" color="#1B5E20"]
    GPX1              [label="GPX1\n(glutathione\nperoxidase)" fillcolor="#81C784" color="#1B5E20"]
    GPX4              [label="GPX4\n(phospholipid\nhydroperoxide)" fillcolor="#66BB6A" color="#1B5E20"]
    GR                [label="Glutathione\nReductase"    fillcolor="#81C784" color="#1B5E20"]
    SOD1_2            [label="SOD1/SOD2\n(dismutation)"  fillcolor="#A5D6A7" color="#1B5E20"]
    catalase_ox       [label="Catalase\n(H₂O₂ → H₂O)"  fillcolor="#A5D6A7" color="#1B5E20"]
    NADPH_ox          [label="NADPH Oxidase\n(NOX2/NOX4)" fillcolor="#F48FB1" color="#880E4F"]
    xanthine_ox       [label="Xanthine Oxidase\n(XO)"   fillcolor="#F48FB1" color="#880E4F"]
    mito_ETC          [label="Mitochondrial ETC\nLeakage" fillcolor="#F48FB1" color="#880E4F"]

    Nrf2              [label="NRF2\n(master antioxidant\ntranscription factor)" fillcolor="#FFCC02" color="#F57F17" style="filled,bold"]
    KEAP1             [label="KEAP1\n(NRF2 repressor)"  fillcolor="#FFAB91" color="#BF360C"]
    ARE               [label="ARE\n(antioxidant response\nelement)"            fillcolor="#FFF9C4"]
    NQO1              [label="NQO1\n(NRF2 target)"      fillcolor="#C8E6C9"]
    GCLC              [label="GCLC/GCLM\n(GSH synthesis)" fillcolor="#C8E6C9"]
    HMOX1             [label="HO-1\n(heme oxygenase-1)" fillcolor="#C8E6C9"]
    thioredoxin       [label="Thioredoxin\n(TXN/TXNRD1)" fillcolor="#C8E6C9"]
    ferroptosis       [label="Ferroptosis\n(iron-dependent\nlipid peroxidation)" fillcolor="#EF9A9A" color="#B71C1C" style="filled,bold"]
    fer_iron          [label="Free Iron (Fe²⁺)\nLabile Pool" fillcolor="#F48FB1"]

    CYP2E1 -> superoxide [label="O₂•⁻ leak"]
    NADPH_ox -> superoxide
    xanthine_ox -> superoxide
    mito_ETC -> superoxide [label="complex I/III\nleak"]
    NADH_mito -> mito_ETC [label="electron donor"]
    superoxide -> SOD1_2 [label="dismutation"]
    SOD1_2 -> H2O2
    H2O2 -> catalase_ox [label="detox"]
    H2O2 -> fer_iron [label="Fenton\nreaction"]
    fer_iron -> OH_radical
    OH_radical -> lipid_perox [label="initiates"]
    lipid_perox -> HNE_4
    lipid_perox -> MDA
    GPX1 -> H2O2 [style=dashed label="neutralizes" dir=back]
    GPX4 -> lipid_perox [style=dashed label="inhibits" dir=back]
    GSH -> GPX1 [label="cofactor"]
    GSH -> GPX4 [label="cofactor"]
    GPX1 -> GSSG
    GPX4 -> GSSG
    GSSG -> GR [label="→ GSH\n(NADPH)"]
    GR -> GSH
    KEAP1 -> Nrf2 [label="ubiquitination\n→ proteasomal\ndegradation" style=dashed]
    superoxide -> KEAP1 [label="Cys oxidation\n→ releases\nNRF2"]
    OH_radical -> KEAP1 [label="oxidizes\ncysteine"]
    Nrf2 -> ARE [label="binds"]
    ARE -> NQO1
    ARE -> GCLC
    ARE -> HMOX1
    ARE -> thioredoxin
    GCLC -> GSH [label="rate-limiting\nstep"]
    GPX4 -> ferroptosis [style=dashed label="prevents" dir=back]
    fer_iron -> ferroptosis [label="catalyst"]
    lipid_perox -> ferroptosis [label="when GPX4↓"]
  }

  //=========================================================
  // CLUSTER 3: GUT-LIVER AXIS
  //=========================================================
  subgraph cluster_gut {
    label="③ Gut–Liver Axis (Dysbiosis & PAMPs)"
    style=filled
    fillcolor="#E8F5E9"
    color="#2E7D32"
    fontcolor="#2E7D32"
    fontsize=11

    gut_microbiome    [label="Gut Microbiome\n(dysbiosis)"   fillcolor="#A5D6A7" color="#1B5E20" style="filled,bold"]
    gram_neg_bact     [label="Gram-negative\nBacteria↑"     fillcolor="#C8E6C9"]
    gram_pos_bact     [label="Gram-positive\nBacteria"      fillcolor="#C8E6C9"]
    fungal_overgrowth [label="Fungal Overgrowth\n(Candida)"  fillcolor="#DCEDC8"]
    LPS_gut           [label="LPS (Endotoxin)\nGut → Portal" fillcolor="#EF9A9A" color="#B71C1C" style="filled,bold"]
    LTA               [label="Lipoteichoic Acid\n(LTA)"     fillcolor="#FFCCBC"]
    flagellin         [label="Flagellin\n(TLR5 ligand)"     fillcolor="#FFCCBC"]
    beta_glucan_gut   [label="β-Glucan\n(Dectin-1 ligand)"  fillcolor="#DCEDC8"]
    SCFA              [label="Short-chain FA\n(acetate,butyrate,\npropionate)↓" fillcolor="#FFCC02"]
    bile_acids        [label="Bile Acids\n(secondary BA)↓"  fillcolor="#FFCC02"]
    FXR_gut           [label="FXR\n(gut epithelium)"        fillcolor="#C5E1A5"]

    tight_junctions   [label="Tight Junctions\n(ZO-1, Occludin)"  fillcolor="#A5D6A7" color="#1B5E20"]
    ZO1               [label="ZO-1\n(disrupted)"           fillcolor="#FFCDD2"]
    occludin          [label="Occludin↓\nClaudin↓"         fillcolor="#FFCDD2"]
    barrier_dysfunct  [label="Intestinal Barrier\nDysfunction"    fillcolor="#EF9A9A" color="#B71C1C"]
    intestinal_perm   [label="Intestinal\nPermeability↑"          fillcolor="#F48FB1" color="#880E4F" style="filled,bold"]

    portal_LPS        [label="Portal Vein LPS\n(endotoxemia)"     fillcolor="#EF9A9A" color="#B71C1C"]
    TLR4              [label="TLR4\n(LPS receptor)"        fillcolor="#CE93D8" color="#7B1FA2" style="filled,bold"]
    TLR2              [label="TLR2\n(LTA/PGN)"             fillcolor="#CE93D8" color="#7B1FA2"]
    TLR5              [label="TLR5\n(flagellin)"            fillcolor="#CE93D8" color="#7B1FA2"]
    TLR9              [label="TLR9\n(bacterial CpG)"        fillcolor="#CE93D8" color="#7B1FA2"]
    MD2               [label="MD-2\n(TLR4 co-receptor)"    fillcolor="#E1BEE7"]
    CD14              [label="CD14\n(LPS\npresentation)"   fillcolor="#E1BEE7"]
    LBP               [label="LBP\n(LPS binding protein)"  fillcolor="#E1BEE7"]
    MyD88             [label="MyD88\n(TLR adaptor)"        fillcolor="#EDE7F6"]
    TRIF              [label="TRIF/TRAM\n(TLR4 adaptor)"   fillcolor="#EDE7F6"]
    REG3_defensin     [label="REG3β/γ\nDefensin↓"         fillcolor="#DCEDC8"]
    mucus_layer       [label="Mucus Layer↓\n(Goblet cells)" fillcolor="#C8E6C9"]

    ethanol_intake -> gut_microbiome [label="dysbiosis"]
    gut_microbiome -> gram_neg_bact [label="↑"]
    gut_microbiome -> gram_pos_bact
    gut_microbiome -> fungal_overgrowth
    gut_microbiome -> SCFA [label="↓ production"]
    gram_neg_bact -> LPS_gut
    gram_pos_bact -> LTA
    gram_pos_bact -> flagellin
    fungal_overgrowth -> beta_glucan_gut
    ethanol_intake -> tight_junctions [label="disrupts"]
    tight_junctions -> ZO1
    tight_junctions -> occludin
    ZO1 -> barrier_dysfunct [label="↓ZO-1"]
    occludin -> barrier_dysfunct [label="↓occludin"]
    barrier_dysfunct -> intestinal_perm
    SCFA -> tight_junctions [label="protects\n(butyrate)" style=dashed]
    bile_acids -> FXR_gut -> REG3_defensin [label="→ defense"]
    mucus_layer -> barrier_dysfunct [label="↓protection"]
    LPS_gut -> portal_LPS [label="paracellular\ntransport"]
    LTA -> portal_LPS
    flagellin -> portal_LPS
    LBP -> LPS_gut [label="binds\nLPS"]
    portal_LPS -> LBP
    LBP -> CD14 -> TLR4 [label="presents LPS"]
    portal_LPS -> MD2 -> TLR4 [label="co-receptor"]
    TLR4 -> MyD88 [label="NF-κB\narm"]
    TLR4 -> TRIF [label="IRF3\narm"]
    LTA -> TLR2 -> MyD88
    flagellin -> TLR5 -> MyD88
  }

  //=========================================================
  // CLUSTER 4: KUPFFER CELL ACTIVATION
  //=========================================================
  subgraph cluster_kupffer {
    label="④ Kupffer Cell / Macrophage Activation"
    style=filled
    fillcolor="#EDE7F6"
    color="#4527A0"
    fontcolor="#4527A0"
    fontsize=11

    KC_resting        [label="Kupffer Cell\n(Resting M0)"   fillcolor="#D1C4E9"]
    KC_activated      [label="Kupffer Cell\n(Activated M1)" fillcolor="#9575CD" color="#311B92" style="filled,bold"]
    KC_M2             [label="Kupffer Cell\n(Resolution M2)" fillcolor="#B39DDB"]
    BMDM_recruit      [label="Recruited Bone\nMarrow Macrophages" fillcolor="#CE93D8"]

    NFkB              [label="NF-κB\n(p65/p50)"            fillcolor="#7E57C2" color="#1A237E" style="filled,bold"]
    IkBa              [label="IκBα\n(NF-κB inhibitor)"     fillcolor="#B39DDB"]
    IKK_complex       [label="IKK Complex\n(IKKβ/NEMO)"    fillcolor="#9575CD"]
    AP1_KC            [label="AP-1\n(JNK/c-Jun)"           fillcolor="#7E57C2" color="#1A237E"]
    IRF3              [label="IRF3\n(type I IFN)"          fillcolor="#9575CD"]

    NLRP3             [label="NLRP3\nInflammasome"         fillcolor="#E53935" color="#B71C1C" style="filled,bold"]
    ASC               [label="ASC Speck\n(adaptor)"        fillcolor="#EF9A9A"]
    pro_casp1         [label="Pro-caspase-1"               fillcolor="#FFCDD2"]
    casp1             [label="Caspase-1\n(active)"         fillcolor="#F44336" color="#B71C1C"]
    pro_IL1B_KC       [label="Pro-IL-1β\n(inactive)"       fillcolor="#FFCDD2"]
    IL1B_KC           [label="IL-1β\n(mature, secreted)"   fillcolor="#F44336" color="#B71C1C" style="filled,bold"]
    GSDMD             [label="Gasdermin D\n(pyroptotic pore)" fillcolor="#EF9A9A" color="#B71C1C"]
    pyroptosis        [label="Pyroptosis\n(KC death)"      fillcolor="#EF9A9A" color="#B71C1C"]

    TNF_KC            [label="TNF-α\n(hepatotoxic)"        fillcolor="#E53935" color="#B71C1C" style="filled,bold"]
    IL6_KC            [label="IL-6\n(acute phase)"         fillcolor="#EF5350" color="#B71C1C"]
    MCP1              [label="MCP-1/CCL2\n(macrophage\nrecruitment)" fillcolor="#EF9A9A"]
    CXCL1_KC          [label="CXCL1/CXCL8\n(neutrophil\nchemoattractant)" fillcolor="#EF9A9A" style="filled,bold"]
    IL10_KC           [label="IL-10\n(anti-inflammatory)"  fillcolor="#C8E6C9"]
    TGFb1_KC          [label="TGF-β1\n(pro-fibrotic)"     fillcolor="#FFB74D" color="#E65100"]
    ROS_KC            [label="ROS\n(oxidative burst)"      fillcolor="#F48FB1"]
    NO_KC             [label="iNOS/NO\n(nitrosative stress)" fillcolor="#F48FB1"]
    osteopontin       [label="Osteopontin (OPN)\n(KC activation marker)" fillcolor="#D1C4E9"]
    complement_KC     [label="Complement\n(C3a/C5a)"       fillcolor="#E1BEE7"]

    MyD88 -> IKK_complex [label="TAK1\nactivates"]
    IKK_complex -> IkBa [label="phosphorylation\n→ degradation"]
    IkBa -> NFkB [label="inhibits" style=dashed dir=back]
    IKK_complex -> NFkB [label="releases\nNF-κB"]
    TRIF -> IRF3 [label="TBK1/IKKε"]
    TRIF -> NFkB [label="RIP1"]
    MyD88 -> AP1_KC [label="JNK arm"]
    KC_resting -> KC_activated [label="TLR4/NLRP3\nsignaling"]
    KC_activated -> NFkB
    KC_activated -> NLRP3 [label="signal 1\n(priming)"]
    acetaldehyde -> NLRP3 [label="signal 2\n(activation)"]
    ROS_KC -> NLRP3 [label="signal 2"]
    H2O2 -> NLRP3 [label="signal 2"]
    uric_acid_DAMP    [label="Uric Acid\n(DAMP)"           fillcolor="#FFCCBC"]
    uric_acid_DAMP -> NLRP3 [label="signal 2"]
    NLRP3 -> ASC -> pro_casp1 -> casp1
    casp1 -> pro_IL1B_KC [label="cleaves"]
    pro_IL1B_KC -> IL1B_KC
    casp1 -> GSDMD [label="cleaves N-terminal"]
    GSDMD -> pyroptosis
    NFkB -> TNF_KC [label="transcription"]
    NFkB -> IL6_KC
    NFkB -> MCP1
    NFkB -> CXCL1_KC
    NFkB -> pro_IL1B_KC [label="transcription\n(signal 1)"]
    AP1_KC -> TNF_KC
    AP1_KC -> MCP1
    MCP1 -> BMDM_recruit [label="→ liver\ninfiltration"]
    BMDM_recruit -> KC_activated [label="differentiate"]
    KC_activated -> IL10_KC [label="M2 shift"]
    KC_M2 -> IL10_KC
    KC_M2 -> TGFb1_KC
    KC_activated -> TGFb1_KC [label="fibrosis\nstimulus"]
    KC_activated -> ROS_KC [label="oxidative\nburst"]
    KC_activated -> NO_KC [label="iNOS"]
    complement_KC -> KC_activated [label="C5a\nactivates"]
    osteopontin -> KC_activated [label="paracrine"]
  }

  //=========================================================
  // CLUSTER 5: NEUTROPHIL INFILTRATION
  //=========================================================
  subgraph cluster_neutrophil {
    label="⑤ Neutrophil Infiltration & Tissue Damage"
    style=filled
    fillcolor="#E3F2FD"
    color="#1565C0"
    fontcolor="#1565C0"
    fontsize=11

    BM_neut           [label="Bone Marrow\nNeutrophils"   fillcolor="#BBDEFB"]
    circ_neut         [label="Circulating\nNeutrophils"   fillcolor="#90CAF9" style="filled,bold"]
    CXCR2_neut        [label="CXCR2\n(CXCL8 receptor)"   fillcolor="#64B5F6"]
    liver_neut        [label="Liver-Infiltrating\nNeutrophils" fillcolor="#1E88E5" color="#0D47A1" style="filled,bold"]
    tissue_neut       [label="Activated Tissue\nNeutrophils" fillcolor="#1565C0" color="#0D47A1"]

    NETs              [label="NETs\n(neutrophil\nextracellular traps)" fillcolor="#EF9A9A" color="#B71C1C"]
    MPO               [label="MPO\n(myeloperoxidase)"     fillcolor="#F48FB1" color="#880E4F"]
    elastase          [label="Neutrophil\nElastase (NE)"  fillcolor="#F48FB1" color="#880E4F"]
    proteinase3       [label="Proteinase-3\n(PR3)"        fillcolor="#FFCDD2"]
    ROS_neut          [label="ROS\n(oxidative burst)"     fillcolor="#F48FB1"]
    HOCl              [label="HOCl\n(MPO product)"        fillcolor="#F48FB1" color="#880E4F"]
    IL17A_neut        [label="IL-17A\n(tissue damage)"   fillcolor="#EF9A9A"]
    IL1B_neut_prod    [label="IL-1β\n(neutrophil source)" fillcolor="#EF9A9A"]

    platelet_act      [label="Platelet Activation\n(sinusoidal)"       fillcolor="#FFCC02" color="#F57F17"]
    microthrombus     [label="Microthrombus\nFormation"               fillcolor="#FFB74D" color="#E65100"]
    hepatic_ischemia  [label="Hepatic\nIschemia/Hypoxia"             fillcolor="#FFCDD2"]
    ICAM1             [label="ICAM-1\n(endothelial)"                  fillcolor="#90CAF9"]
    Eselectin         [label="E-selectin / P-selectin\n(rolling)"     fillcolor="#90CAF9"]
    b2_integrin       [label="β2-integrin\n(CD18/CD11b)"             fillcolor="#64B5F6"]
    NK_cell           [label="NK/NKT Cells\n(innate lymphocyte)"      fillcolor="#C5CAE9"]
    gamma_delta_T     [label="γδ T Cells\n(hepatic)"                 fillcolor="#C5CAE9"]

    CXCL1_KC -> CXCR2_neut [label="gradient"]
    CXCL1_KC -> liver_neut [label="chemoattractant"]
    BM_neut -> circ_neut [label="release\n(GCSF stimulus)"]
    circ_neut -> CXCR2_neut
    circ_neut -> Eselectin [label="rolling"]
    circ_neut -> ICAM1 [label="adhesion"]
    Eselectin -> liver_neut [label="extravasation"]
    ICAM1 -> b2_integrin -> liver_neut
    liver_neut -> tissue_neut [label="activation"]
    tissue_neut -> NETs [label="NETosis"]
    tissue_neut -> MPO [label="degranulation"]
    tissue_neut -> elastase
    tissue_neut -> proteinase3
    tissue_neut -> ROS_neut [label="NADPH\noxidase"]
    MPO -> HOCl [label="Cl⁻ oxidation"]
    NETs -> hepatocyte_necrosis [label="damage\nDAMPs"]
    HOCl -> hepatocyte_necrosis [label="cytotoxic"]
    elastase -> TGFb1_stim_neut [label="ECM\ncleavage"]
    TGFb1_stim_neut   [label="TGF-β1\nRelease (matrix)" fillcolor="#FFB74D"]
    tissue_neut -> IL17A_neut
    tissue_neut -> IL1B_neut_prod
    IL17A_neut -> KC_activated [label="amplify\ninflammation"]
    platelet_act -> microthrombus -> hepatic_ischemia
    NK_cell -> liver_neut [label="regulate"]
    gamma_delta_T -> IL17A_neut [label="produce"]
    hepatocyte_necrosis [label="Hepatocyte\nNecrosis"  fillcolor="#EF9A9A" color="#B71C1C" style="filled,bold"]
  }

  //=========================================================
  // CLUSTER 6: HEPATOCYTE DEATH & REGENERATION
  //=========================================================
  subgraph cluster_hepatocyte {
    label="⑥ Hepatocyte Death Pathways & Regeneration"
    style=filled
    fillcolor="#FFF8E1"
    color="#F57F17"
    fontcolor="#F57F17"
    fontsize=11

    hepatocyte_healthy [label="Healthy Hepatocyte\n(T_H)"              fillcolor="#C8E6C9" color="#1B5E20" style="filled,bold"]
    hepatocyte_stressed[label="Stressed Hepatocyte\n(lipid/acetaldehyde/ROS)" fillcolor="#FFF9C4"]
    hepatocyte_injured [label="Injured Hepatocyte\n(pre-death)"        fillcolor="#FFCC80"]
    hepatocyte_dead    [label="Dead Hepatocyte\n(apoptotic/necrotic)"  fillcolor="#EF9A9A" color="#B71C1C"]
    steatosis_hep      [label="Steatosis\n(macro/microvesicular)"      fillcolor="#FFD54F" color="#F57F17" style="filled,bold"]

    // Apoptosis
    FAS_FASL          [label="FasL/FAS\n(extrinsic)"                   fillcolor="#FFCCBC"]
    TNFR1             [label="TNFR1\n(TNF receptor)"                   fillcolor="#FFCCBC"]
    TRAIL_DR          [label="TRAIL-DR4/5\n(death receptor)"           fillcolor="#FFCCBC"]
