digraph AsymptomaticHyperuricemia {
    graph [
        label="Asymptomatic Hyperuricemia (AHY)\nQuantitative Systems Pharmacology Model\n무증상 고요산혈증 QSP 기계론적 지도"
        labelloc=t
        fontsize=22
        fontname="Helvetica-Bold"
        rankdir=LR
        bgcolor="#FAFAFA"
        splines=ortho
        nodesep=0.4
        ranksep=0.8
        compound=true
    ]
    node [fontname="Helvetica" fontsize=10 style=filled shape=box]
    edge [fontname="Helvetica" fontsize=8]

    /* =============================================
       CLUSTER 1: DIETARY & EXOGENOUS INPUTS
       ============================================= */
    subgraph cluster_diet {
        label="1. 외부 퓨린 입력\n(Dietary & Exogenous Purine Input)"
        style=filled fillcolor="#FFF8E7" color="#E8A000" penwidth=2
        fontname="Helvetica-Bold" fontsize=13

        DietPurine     [label="식이 퓨린\n(Dietary Purines)" fillcolor="#FFE082"]
        DietFructose   [label="과당\n(Dietary Fructose)" fillcolor="#FFE082"]
        Alcohol        [label="알코올\n(Ethanol)" fillcolor="#FFE082"]
        RedMeat        [label="적색육/내장육\n(Red Meat/Organ)" fillcolor="#FFE082"]
        Seafood        [label="해산물\n(Seafood)" fillcolor="#FFE082"]
        SugarDrinks    [label="가당 음료\n(Sugary Beverages)" fillcolor="#FFE082"]
        GIAbsorption   [label="장관 흡수\n(GI Absorption)" shape=ellipse fillcolor="#FFD54F"]
    }

    /* =============================================
       CLUSTER 2: PURINE DE NOVO BIOSYNTHESIS
       ============================================= */
    subgraph cluster_denovo {
        label="2. 퓨린 생합성 (De Novo Purine Synthesis)"
        style=filled fillcolor="#E8F5E9" color="#2E7D32" penwidth=2
        fontname="Helvetica-Bold" fontsize=13

        PRPP           [label="PRPP\n(5-phosphoribosyl-1-PP)" fillcolor="#A5D6A7"]
        PRPP_synthetase [label="PRPP 합성효소\n(PRPP Synthetase)" shape=diamond fillcolor="#66BB6A"]
        ATPP_feedback  [label="AMP/GMP 피드백\n(Purine Feedback)" shape=ellipse fillcolor="#81C784"]
        IMP            [label="IMP\n(Inosinate)" fillcolor="#A5D6A7"]
        AMP            [label="AMP\n(Adenosine 5'-MP)" fillcolor="#A5D6A7"]
        GMP            [label="GMP\n(Guanosine 5'-MP)" fillcolor="#A5D6A7"]
        ATP            [label="ATP" fillcolor="#A5D6A7"]
        GTP            [label="GTP" fillcolor="#A5D6A7"]
        AdenyloSucc    [label="아데닐로숙신산\n(Adenylosuccinate)" fillcolor="#C8E6C9"]
        XMP            [label="XMP\n(Xanthylate)" fillcolor="#C8E6C9"]
        FGAM           [label="FGAM\n(Formylglycinamidine)" fillcolor="#C8E6C9"]
        SAICAR         [label="SAICAR 단계\n(Bicyclic intermediate)" fillcolor="#C8E6C9"]
    }

    /* =============================================
       CLUSTER 3: PURINE CATABOLISM & SALVAGE
       ============================================= */
    subgraph cluster_catabolism {
        label="3. 퓨린 이화 및 재이용 (Purine Catabolism & Salvage)"
        style=filled fillcolor="#E3F2FD" color="#1565C0" penwidth=2
        fontname="Helvetica-Bold" fontsize=13

        Adenosine      [label="아데노신\n(Adenosine)" fillcolor="#90CAF9"]
        Inosine        [label="이노신\n(Inosine)" fillcolor="#90CAF9"]
        Hypoxanthine   [label="히포잔틴\n(Hypoxanthine)" fillcolor="#64B5F6"]
        Xanthine       [label="잔틴\n(Xanthine)" fillcolor="#42A5F5"]
        UricAcid_prod  [label="요산 생성\n(Uric Acid Production)" fillcolor="#1E88E5"]
        Guanosine      [label="과노신\n(Guanosine)" fillcolor="#90CAF9"]
        Guanine        [label="구아닌\n(Guanine)" fillcolor="#64B5F6"]
        ADA            [label="ADA\n(Adenosine Deaminase)" shape=diamond fillcolor="#42A5F5"]
        PNP            [label="PNP\n(Purine Nucleoside\nPhosphorylase)" shape=diamond fillcolor="#42A5F5"]
        XO             [label="XO/XDH\n(Xanthine Oxidase/\nDehydrogenase)" shape=diamond fillcolor="#1565C0" fontcolor=white]
        HGPRT          [label="HGPRT\n(Hypoxanthine-Guanine\nPhosphoribosyl Transferase)" shape=diamond fillcolor="#1E88E5" fontcolor=white]
        APRT           [label="APRT\n(Adenine\nPhosphoribosyl Transferase)" shape=diamond fillcolor="#42A5F5"]
        H2O2_ROS       [label="H₂O₂/ROS\n(Oxidative Stress)" fillcolor="#BBDEFB"]
        Superoxide     [label="슈퍼옥사이드\n(Superoxide O₂⁻)" fillcolor="#BBDEFB"]
    }

    /* =============================================
       CLUSTER 4: RENAL URIC ACID HANDLING
       ============================================= */
    subgraph cluster_renal {
        label="4. 신장 요산 처리 (Renal Uric Acid Handling)"
        style=filled fillcolor="#F3E5F5" color="#6A1B9A" penwidth=2
        fontname="Helvetica-Bold" fontsize=13

        GFR            [label="사구체 여과율\n(GFR, mL/min)" fillcolor="#CE93D8"]
        FilteredUA     [label="여과 요산\n(Filtered UA, ~70%)" fillcolor="#BA68C8"]
        S1_reabs       [label="S1 재흡수 (~98%)\n근위세뇨관전반부" fillcolor="#AB47BC"]
        S2_secr        [label="S2 분비\n근위세뇨관중반부" fillcolor="#9C27B0" fontcolor=white]
        S3_postsecr    [label="S3 분비후 재흡수\n근위세뇨관후반부" fillcolor="#8E24AA" fontcolor=white]
        URAT1          [label="URAT1\n(SLC22A12)\n재흡수 수송체" shape=diamond fillcolor="#CE93D8"]
        GLUT9          [label="GLUT9\n(SLC2A9)\n기저측 수송체" shape=diamond fillcolor="#CE93D8"]
        OAT1           [label="OAT1\n(SLC22A6)\n분비 수송체" shape=diamond fillcolor="#BA68C8"]
        OAT3           [label="OAT3\n(SLC22A8)\n분비 수송체" shape=diamond fillcolor="#BA68C8"]
        OAT4           [label="OAT4\n(SLC22A11)\n재흡수 수송체" shape=diamond fillcolor="#BA68C8"]
        NPT1           [label="NPT1\n(SLC17A1)\n분비 수송체" shape=diamond fillcolor="#CE93D8"]
        NPT4           [label="NPT4\n(SLC17A3)\n분비 수송체" shape=diamond fillcolor="#CE93D8"]
        ABCG2_renal    [label="ABCG2\n(신장 분비)" shape=diamond fillcolor="#AB47BC"]
        FractExcretion [label="분획 배설율\n(FEUA, 3-10%)" fillcolor="#CE93D8"]
        UrinaryUA      [label="요중 요산\n(Urinary UA, mg/day)" fillcolor="#CE93D8"]
        CrystalRisk    [label="결정 석출 위험\n(Crystal Formation Risk)" shape=hexagon fillcolor="#EF9A9A"]
    }

    /* =============================================
       CLUSTER 5: INTESTINAL HANDLING
       ============================================= */
    subgraph cluster_gut {
        label="5. 장관 요산 분비 (Intestinal UA Secretion)"
        style=filled fillcolor="#FFF3E0" color="#E65100" penwidth=2
        fontname="Helvetica-Bold" fontsize=13

        ABCG2_gut      [label="장관 ABCG2\n(SLC → Gut Lumen)" shape=diamond fillcolor="#FFCC80"]
        GutSecretion   [label="장관 분비량\n(~33% of total\nexcretion)" fillcolor="#FFB74D"]
        GutMicrobiome  [label="장내 세균총\n(Gut Microbiome:\nUricase+/-)" fillcolor="#FFA726"]
        FecalUA        [label="분변 요산\n(Fecal UA)" fillcolor="#FF9800"]
        Uricase_micro  [label="세균 Uricase\n(Microbial Uricase→\nAllantoin)" shape=diamond fillcolor="#FFCC80"]
        BacterialAllantoin [label="알란토인\n(Allantoin,\nfrom microbiome)" fillcolor="#FFB74D"]
    }

    /* =============================================
       CLUSTER 6: SERUM URIC ACID POOL
       ============================================= */
    subgraph cluster_SUA {
        label="6. 혈청 요산 풀 (Serum Uric Acid Pool & Saturation)"
        style=filled fillcolor="#FCE4EC" color="#880E4F" penwidth=2
        fontname="Helvetica-Bold" fontsize=13

        SUA            [label="혈청 요산\n(SUA, mg/dL)\n정상: ♂<7.0, ♀<6.0\nAHY: ≥7.0" shape=octagon fillcolor="#F48FB1" fontsize=12]
        SUA_saturation [label="MSU 포화점\n(Saturation: 6.8mg/dL)" fillcolor="#F06292"]
        MSU_crystal    [label="MSU 결정 형성\n(Monosodium Urate\nCrystal Nucleation)" shape=hexagon fillcolor="#EC407A"]
        BodyPool_UA    [label="체내 총 요산 풀\n(Body UA Pool\n~1000-1500mg 정상)" fillcolor="#F48FB1"]
        Tophus_risk    [label="토파이 형성 위험\n(Tophus Formation\nRisk Score)" shape=hexagon fillcolor="#E91E63"]
        GoutFlare_risk [label="통풍 발작 위험\n(Gout Flare Risk:\n>9mg/dL ↑10x)" shape=hexagon fillcolor="#AD1457" fontcolor=white]
    }

    /* =============================================
       CLUSTER 7: CARDIOVASCULAR EFFECTS
       ============================================= */
    subgraph cluster_cardio {
        label="7. 심혈관계 영향 (Cardiovascular Effects)"
        style=filled fillcolor="#E8EAF6" color="#283593" penwidth=2
        fontname="Helvetica-Bold" fontsize=13

        Endothelium    [label="혈관 내피세포\n(Vascular Endothelium)" fillcolor="#9FA8DA"]
        eNOS_inhibit   [label="eNOS 활성 억제\n(eNOS↓ → NO↓)" fillcolor="#7986CB"]
        NO_deficiency  [label="산화질소 결핍\n(NO↓ → Vasodilation↓)" fillcolor="#5C6BC0"]
        RAAS_activ     [label="RAAS 활성화\n(AngII↑, Aldosterone↑)" fillcolor="#3949AB"]
        BP_elevation   [label="혈압 상승\n(Hypertension risk)" shape=hexagon fillcolor="#EF5350"]
        Oxidative_CV   [label="혈관 산화스트레스\n(Vascular ROS↑)" fillcolor="#7986CB"]
        Inflammation_CV [label="혈관 염증\n(Vascular\nInflammation: CRP↑)" fillcolor="#7986CB"]
        Platelet_activ [label="혈소판 활성화\n(Platelet Activation↑)" fillcolor="#9FA8DA"]
        Thrombosis_risk [label="혈전 위험\n(Thrombosis Risk)" shape=hexagon fillcolor="#EF5350"]
        LDL_oxidation  [label="LDL 산화\n(ox-LDL↑)" fillcolor="#9FA8DA"]
        Atherogenesis  [label="죽상동맥경화\n(Atherosclerosis\nProgression)" shape=hexagon fillcolor="#C62828" fontcolor=white]
        CV_events      [label="심혈관 이벤트\n(CV Events: MI, Stroke\n위험 +27%)" shape=hexagon fillcolor="#B71C1C" fontcolor=white]
        CardiacHyp     [label="심장 비대\n(Cardiac Hypertrophy)" fillcolor="#7986CB"]
        HeartFailure_risk [label="심부전 위험\n(Heart Failure Risk)" shape=hexagon fillcolor="#EF5350"]
    }

    /* =============================================
       CLUSTER 8: RENAL & METABOLIC EFFECTS
       ============================================= */
    subgraph cluster_renal_eff {
        label="8. 신장 및 대사 영향 (Renal & Metabolic Effects)"
        style=filled fillcolor="#E0F7FA" color="#00695C" penwidth=2
        fontname="Helvetica-Bold" fontsize=13

        RenalTubular   [label="세뇨관 손상\n(Tubular Injury)" fillcolor="#80DEEA"]
        TubuloInters   [label="신세뇨관-간질 섬유화\n(Tubulointerstitial\nFibrosis)" fillcolor="#4DD0E1"]
        GFR_decline    [label="GFR 감소\n(GFR Decline:\nCKD Progression)" shape=hexagon fillcolor="#EF5350"]
        Afferent_art   [label="수입 세동맥 수축\n(Afferent Arteriole\nConstriction)" fillcolor="#26C6DA"]
        RAAS_renal     [label="신장 RAAS 활성\n(Intra-renal RAAS↑)" fillcolor="#00BCD4"]
        Microalbumin   [label="미세알부민뇨\n(Microalbuminuria)" shape=hexagon fillcolor="#EF5350"]
        InsulinResist  [label="인슐린 저항성\n(Insulin Resistance)" fillcolor="#80DEEA"]
        HyperTG        [label="고중성지방혈증\n(Hypertriglyceridemia)" fillcolor="#4DD0E1"]
        FattyLiver_risk [label="지방간 위험\n(NAFLD Risk)" shape=hexagon fillcolor="#FF8F00"]
        Hyperglycemia  [label="고혈당\n(Hyperglycemia↑)" fillcolor="#80DEEA"]
        MetSyn_assoc   [label="대사증후군 연관\n(MetSyn Association)" shape=hexagon fillcolor="#FF8F00"]
    }

    /* =============================================
       CLUSTER 9: INFLAMMATORY PATHWAY
       ============================================= */
    subgraph cluster_inflam {
        label="9. 염증 경로 (Subclinical Inflammation Pathway)"
        style=filled fillcolor="#FFEFFE" color="#7B1FA2" penwidth=2
        fontname="Helvetica-Bold" fontsize=13

        NLRP3          [label="NLRP3\n인플라마좀\n(NLRP3 Inflammasome)" shape=diamond fillcolor="#CE93D8"]
        Caspase1       [label="카스파제-1\n(Caspase-1)" shape=diamond fillcolor="#BA68C8"]
        IL1beta        [label="IL-1β\n(Interleukin-1β)" fillcolor="#AB47BC"]
        IL6            [label="IL-6\n(Interleukin-6)" fillcolor="#9C27B0" fontcolor=white]
        TNFalpha       [label="TNF-α\n(Tumor Necrosis Factor-α)" fillcolor="#8E24AA" fontcolor=white]
        NFkB           [label="NF-κB\n(활성화 전사인자)" shape=diamond fillcolor="#6A1B9A" fontcolor=white]
        CRP            [label="CRP\n(C-반응단백: hs-CRP↑)" fillcolor="#CE93D8"]
        Neutrophils    [label="호중구 활성\n(Neutrophil Activation)" fillcolor="#BA68C8"]
        MacroInfil     [label="대식세포 침윤\n(Macrophage Infiltration)" fillcolor="#AB47BC"]
        MAPK           [label="MAPK/JNK 경로\n(Stress Signaling)" shape=diamond fillcolor="#CE93D8"]
        Pyroptosis     [label="파이롭토시스\n(Pyroptosis)" fillcolor="#E1BEE7"]
    }

    /* =============================================
       CLUSTER 10: DRUG PK/PD — ALLOPURINOL
       ============================================= */
    subgraph cluster_allopurinol {
        label="10. 약물 PK/PD — 알로퓨리놀 (Allopurinol PK/PD)"
        style=filled fillcolor="#E8F5E9" color="#1B5E20" penwidth=2
        fontname="Helvetica-Bold" fontsize=13

        Allopurinol_dose [label="알로퓨리놀 투여\n(Allopurinol\n100-900mg/day)" fillcolor="#A5D6A7"]
        Allopurinol_abs  [label="알로퓨리놀 흡수\n(F=0.90)" fillcolor="#81C784"]
        Allopurinol_C    [label="혈중 알로퓨리놀\n(Cmax: 2-3μg/mL\nt½=1-2h)" fillcolor="#66BB6A"]
        Oxypurinol_form  [label="옥시퓨리놀 형성\n(Oxypurinol Formation\nby XO/AO)" shape=diamond fillcolor="#4CAF50"]
        Oxypurinol_C     [label="혈중 옥시퓨리놀\n(Active Metabolite\nCss=5-15mg/L\nt½=18-30h)" fillcolor="#388E3C" fontcolor=white]
        Oxypurinol_renal [label="옥시퓨리놀 신배설\n(Renal Clearance\nCL=30mL/min)" fillcolor="#2E7D32" fontcolor=white]
        XO_inhibit_all   [label="XO 경쟁적/비가역\n억제\n(XO Inhibition)" shape=diamond fillcolor="#1B5E20" fontcolor=white]
        UA_reduction_all [label="요산 감소 효과\n(SUA↓ 30-40%)" shape=hexagon fillcolor="#C8E6C9"]
        Allo_tox         [label="독성 위험\n(Stevens-Johnson\nSyn: HLA-B*58:01)" shape=hexagon fillcolor="#FFCDD2"]
    }

    /* =============================================
       CLUSTER 11: DRUG PK/PD — FEBUXOSTAT
       ============================================= */
    subgraph cluster_febuxostat {
        label="11. 약물 PK/PD — 페북소스타트 (Febuxostat PK/PD)"
        style=filled fillcolor="#FFF8E1" color="#F57F17" penwidth=2
        fontname="Helvetica-Bold" fontsize=13

        Febux_dose     [label="페북소스타트 투여\n(Febuxostat 40-120mg/day)" fillcolor="#FFE082"]
        Febux_abs      [label="흡수\n(F=0.84, Tmax=1-1.5h)" fillcolor="#FFD54F"]
        Febux_C        [label="혈중 농도\n(Cmax: 5.4μg/mL at 120mg\nt½=5-8h)" fillcolor="#FFCA28"]
        Febux_met      [label="대사\n(CYP1A2, 2C8, UGT\nAcyl glucuronide)" fillcolor="#FFC107"]
        XO_inhibit_feb [label="XO 선택적 억제\n(Non-purine scaffold\nIC50=0.6nM)" shape=diamond fillcolor="#FF8F00" fontcolor=white]
        UA_reduction_feb [label="요산 감소 효과\n(SUA↓ 40-53%\nvs allopurinol)" shape=hexagon fillcolor="#FFE082"]
        Febux_CV_risk  [label="CV 안전성\n(CARES Trial:\nCV death↑ vs. Allo)" shape=hexagon fillcolor="#FF7043"]
        Febux_renal    [label="신장 안전성\n(CKD에서 선호)" fillcolor="#FFE082"]
    }

    /* =============================================
       CLUSTER 12: DRUG PK/PD — URICOSURICS
       ============================================= */
    subgraph cluster_uricosuric {
        label="12. 약물 PK/PD — 요산배설촉진제 (Uricosuric Agents PK/PD)"
        style=filled fillcolor="#E0F2F1" color="#004D40" penwidth=2
        fontname="Helvetica-Bold" fontsize=13

        Probenecid_dose [label="프로베네시드 투여\n(Probenecid 500-2000mg/day)" fillcolor="#80CBC4"]
        Probenecid_C    [label="혈중 프로베네시드\n(t½=6-12h, CL=12mL/min)" fillcolor="#4DB6AC"]
        URAT1_inhibit  [label="URAT1 억제\n(신장 재흡수 차단)" shape=diamond fillcolor="#26A69A"]
        UA_excr_incr   [label="요중 요산 증가\n(Uricosuria↑)" fillcolor="#80CBC4"]
        Lesinurad_dose [label="레시누라드 투여\n(Lesinurad 200-400mg/day)" fillcolor="#80CBC4"]
        Lesinurad_C    [label="혈중 레시누라드\n(t½=5h, F=1.00)" fillcolor="#4DB6AC"]
        URAT1_OAT4_inh [label="URAT1+OAT4 이중억제\n(Dual URAT1/OAT4\nInhibition)" shape=diamond fillcolor="#00897B" fontcolor=white]
        Dotinurad_dose [label="도티누라드 투여\n(Dotinurad 0.5-4mg/day)" fillcolor="#80CBC4"]
        URAT1_ABCG2_sel [label="URAT1 선택적 억제\n(vs. Probenecid)" shape=diamond fillcolor="#00796B" fontcolor=white]
        SUA_uricosuric [label="요산 감소 효과\n(SUA↓ 15-30%)" shape=hexagon fillcolor="#B2DFDB"]
        Urolith_risk   [label="신결석 위험\n(Urolithiasis Risk↑\n+수분섭취 필요)" shape=hexagon fillcolor="#FFCDD2"]
    }

    /* =============================================
       CLUSTER 13: BIOLOGICAL — PEGLOTICASE
       ============================================= */
    subgraph cluster_biologic {
        label="13. 생물학적 제제 — 페글로티카제 (Pegloticase/Uricase Biologics)"
        style=filled fillcolor="#EDE7F6" color="#4527A0" penwidth=2
        fontname="Helvetica-Bold" fontsize=13

        Pegloticase_dose [label="페글로티카제 투여\n(Pegloticase 8mg IV\nq2weeks)" fillcolor="#D1C4E9"]
        Pegloti_C      [label="혈중 농도\n(t½=6-14days\nPEGylated uricase)" fillcolor="#B39DDB"]
        Uricase_rxn    [label="우리카제 반응\n(UA→Allantoin\n5-10x 용해성↑)" shape=diamond fillcolor="#9575CD"]
        Allantoin_prod [label="알란토인 생성\n(Allantoin\n신배설 용이)" fillcolor="#7E57C2" fontcolor=white]
        SUA_rapid_drop [label="급격한 요산 감소\n(SUA↓ >80%\n<6mg/dL in 24h)" shape=hexagon fillcolor="#B39DDB"]
        AntiPEG_Ab     [label="항PEG 항체\n(Anti-PEG Antibody\n→ ADA 실패)" shape=hexagon fillcolor="#EF5350"]
        Infusion_rxn   [label="주입 반응\n(Infusion Reaction\n26-47%)" shape=hexagon fillcolor="#FFCDD2"]
    }

    /* =============================================
       CLUSTER 14: GENETIC FACTORS
       ============================================= */
    subgraph cluster_genetics {
        label="14. 유전적 요인 (Genetic Determinants)"
        style=filled fillcolor="#F1F8E9" color="#33691E" penwidth=2
        fontname="Helvetica-Bold" fontsize=13

        ABCG2_Q141K    [label="ABCG2 Q141K\n(rs2231142)\n분비 기능 50%↓" fillcolor="#DCEDC8"]
        SLC22A12_var   [label="SLC22A12 변이\n(URAT1\n재흡수↑)" fillcolor="#DCEDC8"]
        SLC2A9_var     [label="SLC2A9 변이\n(GLUT9\n재흡수↑)" fillcolor="#DCEDC8"]
        HLAB5801       [label="HLA-B*58:01\n(알로퓨리놀\n독성 위험↑)" fillcolor="#FFCDD2"]
        XDH_var        [label="XDH 변이\n(XO 과활성\n→ 생성↑)" fillcolor="#DCEDC8"]
        PRPPS_var      [label="PRPP 합성효소\nX연관 돌연변이\n(XL Superactivity)" fillcolor="#DCEDC8"]
        HGPRT_def      [label="HGPRT 결핍\n(Lesch-Nyhan\n부분형)" fillcolor="#FFCDD2"]
        Polygenic_SUA  [label="다유전자 SUA\n(Polygenic SUA\nScore: GWAS\n180+ loci)" fillcolor="#C5E1A5"]
    }

    /* =============================================
       CLUSTER 15: CLINICAL ENDPOINTS & MONITORING
       ============================================= */
    subgraph cluster_endpoints {
        label="15. 임상 지표 및 목표 (Clinical Endpoints & Treatment Targets)"
        style=filled fillcolor="#FFEBEE" color="#B71C1C" penwidth=2
        fontname="Helvetica-Bold" fontsize=13

        SUA_target     [label="SUA 치료 목표\n(Target SUA\n<6.0mg/dL 일반\n<5.0mg/dL 통풍)" shape=octagon fillcolor="#FFCDD2"]
        Flare_freq     [label="통풍 발작 빈도\n(Gout Flare Freq.\n1회/년 이상→치료)" shape=hexagon fillcolor="#EF5350"]
        Tophus_resolve [label="토파이 감소\n(Tophus Resolution\n>1년 치료 필요)" shape=hexagon fillcolor="#E53935"]
        Renal_protect  [label="신장 보호\n(Renal Protection\nSUA<6→GFR 보존)" shape=hexagon fillcolor="#D32F2F" fontcolor=white]
        CV_protect     [label="심혈관 보호\n(CV Protection\n논란: SUA<6?)" shape=hexagon fillcolor="#C62828" fontcolor=white]
        JointDamage    [label="관절 손상\n(Joint Damage\nX-ray 침식)" shape=hexagon fillcolor="#EF5350"]
        QoL            [label="삶의 질\n(Quality of Life\nHAQ/SF-36)" shape=hexagon fillcolor="#E53935"]
        Treatment_dur  [label="치료 기간 결정\n(AHY: 언제 치료?\nAsymptomatic vs.\n>9mg/dL 고위험)" shape=octagon fillcolor="#FFCDD2"]
    }

    /* =============================================
       INTER-CLUSTER EDGES
       ============================================= */

    /* Dietary inputs → GI absorption */
    DietPurine -> GIAbsorption [label="장흡수" color="#E8A000"]
    DietFructose -> GIAbsorption [label="과당→퓨린" color="#E8A000"]
    RedMeat -> GIAbsorption [color="#E8A000"]
    Seafood -> GIAbsorption [color="#E8A000"]
    Alcohol -> GIAbsorption [label="에탄올→UA" color="#E8A000"]
    SugarDrinks -> GIAbsorption [color="#E8A000"]

    /* GI absorption → purines */
    GIAbsorption -> AMP [color="#1565C0"]
    GIAbsorption -> GMP [color="#1565C0"]
    GIAbsorption -> Hypoxanthine [color="#1565C0"]
    GIAbsorption -> Guanine [color="#1565C0"]

    /* De novo synthesis */
    PRPP_synthetase -> PRPP [color="#2E7D32"]
    PRPP -> FGAM [color="#2E7D32"]
    FGAM -> SAICAR [color="#2E7D32"]
    SAICAR -> IMP [color="#2E7D32"]
    IMP -> AdenyloSucc [color="#2E7D32"]
    AdenyloSucc -> AMP [color="#2E7D32"]
    IMP -> XMP [color="#2E7D32"]
    XMP -> GMP [color="#2E7D32"]
    AMP -> ATP [color="#2E7D32"]
    GMP -> GTP [color="#2E7D32"]
    ATPP_feedback -> PRPP_synthetase [label="피드백 억제" color="#C62828" style=dashed]
    AMP -> ATPP_feedback [color="#C62828" style=dashed]
    GMP -> ATPP_feedback [color="#C62828" style=dashed]

    /* Catabolism pathway */
    ATP -> AMP [label="ATPase" color="#1565C0"]
    AMP -> Adenosine [label="5'-NT" color="#1565C0"]
    Adenosine -> Inosine [label="ADA" color="#1565C0"]
    ADA -> Inosine [style=dashed color="#1565C0"]
    Inosine -> Hypoxanthine [label="PNP" color="#1565C0"]
    PNP -> Hypoxanthine [style=dashed color="#1565C0"]
    GTP -> GMP [label="GTPase" color="#1565C0"]
    GMP -> Guanosine [label="5'-NT" color="#1565C0"]
    Guanosine -> Guanine [label="PNP" color="#1565C0"]
    Guanine -> Hypoxanthine [label="Guanase" color="#1565C0"]
    Hypoxanthine -> Xanthine [label="XO" color="#0D47A1" penwidth=2]
    XO -> Xanthine [style=dashed color="#0D47A1"]
    Xanthine -> UricAcid_prod [label="XO" color="#0D47A1" penwidth=2]
    XO -> UricAcid_prod [style=dashed color="#0D47A1"]
    UricAcid_prod -> H2O2_ROS [label="XO 부산물" color="#EF5350"]
    UricAcid_prod -> Superoxide [color="#EF5350"]

    /* Salvage */
    Hypoxanthine -> IMP [label="HGPRT" color="#2196F3" style=dashed]
    HGPRT -> IMP [style=dashed color="#2196F3"]
    Guanine -> GMP [label="HGPRT" color="#2196F3" style=dashed]
    Adenosine -> AMP [label="APRT" color="#2196F3" style=dashed]

    /* UA production → SUA pool */
    UricAcid_prod -> SUA [color="#AD1457" penwidth=2]
    SUA -> SUA_saturation [color="#880E4F"]
    SUA_saturation -> MSU_crystal [label=">6.8mg/dL" color="#880E4F" penwidth=2]
    SUA -> BodyPool_UA [color="#880E4F"]
    MSU_crystal -> Tophus_risk [color="#E91E63"]
    MSU_crystal -> GoutFlare_risk [color="#E91E63"]
    GoutFlare_risk -> NLRP3 [color="#7B1FA2" penwidth=2]

    /* Renal handling */
    GFR -> FilteredUA [color="#6A1B9A" penwidth=2]
    SUA -> FilteredUA [color="#6A1B9A"]
    FilteredUA -> S1_reabs [color="#6A1B9A"]
    URAT1 -> S1_reabs [style=dashed color="#6A1B9A"]
    GLUT9 -> S1_reabs [style=dashed color="#6A1B9A"]
    S1_reabs -> S2_secr [color="#6A1B9A"]
    OAT1 -> S2_secr [style=dashed color="#6A1B9A"]
    OAT3 -> S2_secr [style=dashed color="#6A1B9A"]
    NPT1 -> S2_secr [style=dashed color="#6A1B9A"]
    NPT4 -> S2_secr [style=dashed color="#6A1B9A"]
    S2_secr -> S3_postsecr [color="#6A1B9A"]
    OAT4 -> S3_postsecr [style=dashed color="#6A1B9A"]
    ABCG2_renal -> S2_secr [style=dashed color="#6A1B9A"]
    S3_postsecr -> FractExcretion [color="#6A1B9A"]
    FractExcretion -> UrinaryUA [color="#6A1B9A" penwidth=2]
    UrinaryUA -> CrystalRisk [label="고요산뇨" color="#EF5350"]

    /* Gut handling */
    SUA -> ABCG2_gut [color="#E65100"]
    ABCG2_gut -> GutSecretion [color="#E65100"]
    GutSecretion -> GutMicrobiome [color="#E65100"]
    GutMicrobiome -> Uricase_micro [color="#E65100" style=dashed]
    Uricase_micro -> BacterialAllantoin [color="#E65100"]
    GutSecretion -> FecalUA [color="#E65100"]

    /* UA → SUA removal */
    UrinaryUA -> SUA [label="배설" color="#880E4F" style=dashed dir=back]
    FecalUA -> SUA [label="배설" color="#880E4F" style=dashed dir=back]

    /* CV effects */
    H2O2_ROS -> Endothelium [color="#1565C0" penwidth=2]
    Superoxide -> Endothelium [color="#1565C0"]
    SUA -> Endothelium [label="UA 직접독성" color="#880E4F" penwidth=2]
    Endothelium -> eNOS_inhibit [color="#283593"]
    eNOS_inhibit -> NO_deficiency [color="#283593"]
    NO_deficiency -> BP_elevation [color="#283593"]
    SUA -> RAAS_activ [color="#880E4F"]
    RAAS_activ -> BP_elevation [color="#283593"]
    H2O2_ROS -> Oxidative_CV [color="#283593"]
    Oxidative_CV -> Inflammation_CV [color="#283593"]
    Inflammation_CV -> Atherogenesis [color="#283593"]
    Oxidative_CV -> LDL_oxidation [color="#283593"]
    LDL_oxidation -> Atherogenesis [color="#283593"]
    BP_elevation -> CV_events [color="#B71C1C" penwidth=2]
    Atherogenesis -> CV_events [color="#B71C1C" penwidth=2]
    SUA -> Platelet_activ [color="#880E4F"]
    Platelet_activ -> Thrombosis_risk [color="#283593"]
    Thrombosis_risk -> CV_events [color="#B71C1C"]
    BP_elevation -> CardiacHyp [color="#283593"]
    CardiacHyp -> HeartFailure_risk [color="#283593"]

    /* Renal & metabolic effects */
    SUA -> RenalTubular [label="결정/독성" color="#880E4F"]
    H2O2_ROS -> RenalTubular [color="#EF5350"]
    RenalTubular -> TubuloInters [color="#00695C"]
    TubuloInters -> GFR_decline [color="#00695C" penwidth=2]
    SUA -> Afferent_art [color="#880E4F"]
    Afferent_art -> RAAS_renal [color="#00695C"]
    RAAS_renal -> RenalTubular [color="#00695C"]
    RAAS_renal -> Microalbumin [color="#00695C"]
    GFR_decline -> SUA [label="감소된 배설" color="#880E4F" style=dashed]
    SUA -> InsulinResist [color="#880E4F"]
    InsulinResist -> HyperTG [color="#00695C"]
    InsulinResist -> Hyperglycemia [color="#00695C"]
    InsulinResist -> MetSyn_assoc [color="#00695C"]
    HyperTG -> MetSyn_assoc [color="#00695C"]
    InsulinResist -> FattyLiver_risk [color="#00695C"]

    /* Fructose → PRPP */
    DietFructose -> PRPP_synthetase [label="Fructokinase→\nAMP↑" color="#E65100" penwidth=2]

    /* Alcohol → UA */
    Alcohol -> Hypoxanthine [label="ATP→AMP↑" color="#E65100"]
    Alcohol -> UrinaryUA [label="배설 경쟁" color="#E65100" style=dashed]

    /* Inflammation */
    MSU_crystal -> NLRP3 [color="#7B1FA2" penwidth=2]
    NLRP3 -> Caspase1 [color="#7B1FA2"]
    Caspase1 -> IL1beta [color="#7B1FA2" penwidth=2]
    IL1beta -> IL6 [color="#7B1FA2"]
    IL1beta -> NFkB [color="#7B1FA2"]
    NFkB -> TNFalpha [color="#7B1FA2"]
    NFkB -> CRP [color="#7B1FA2"]
    TNFalpha -> Inflammation_CV [color="#283593"]
    IL6 -> CRP [color="#7B1FA2"]
    NLRP3 -> Neutrophils [color="#7B1FA2"]
    NLRP3 -> MacroInfil [color="#7B1FA2"]
    Neutrophils -> Pyroptosis [color="#7B1FA2"]
    MacroInfil -> MAPK [color="#7B1FA2"]
    IL1beta -> InsulinResist [color="#00695C"]
    CRP -> CV_events [color="#B71C1C" style=dashed]

    /* Genetics */
    ABCG2_Q141K -> ABCG2_gut [label="기능↓" color="#33691E" style=dashed]
    ABCG2_Q141K -> ABCG2_renal [label="분비↓" color="#33691E" style=dashed]
    SLC22A12_var -> URAT1 [label="재흡수↑" color="#33691E" style=dashed]
    SLC2A9_var -> GLUT9 [label="재흡수↑" color="#33691E" style=dashed]
    XDH_var -> XO [label="활성↑" color="#33691E" style=dashed]
    PRPPS_var -> PRPP_synthetase [label="과활성" color="#33691E" style=dashed]
    HGPRT_def -> HGPRT [label="기능↓" color="#C62828" style=dashed]
    Polygenic_SUA -> SUA [label="GWAS" color="#33691E" style=dashed]
    HLAB5801 -> Allo_tox [color="#C62828" penwidth=2]

    /* Allopurinol PK/PD */
    Allopurinol_dose -> Allopurinol_abs [color="#1B5E20"]
    Allopurinol_abs -> Allopurinol_C [color="#1B5E20"]
    Allopurinol_C -> Oxypurinol_form [color="#1B5E20"]
    Oxypurinol_form -> Oxypurinol_C [color="#1B5E20" penwidth=2]
    Oxypurinol_C -> Oxypurinol_renal [color="#1B5E20"]
    Oxypurinol_C -> XO_inhibit_all [label="Tight-binding\nIC50=0.6nM" color="#1B5E20" penwidth=2]
    XO_inhibit_all -> XO [color="#C62828" penwidth=2]
    XO_inhibit_all -> UA_reduction_all [color="#1B5E20" penwidth=2]
    UA_reduction_all -> SUA [color="#880E4F" style=dashed dir=back penwidth=2]

    /* Febuxostat PK/PD */
    Febux_dose -> Febux_abs [color="#F57F17"]
    Febux_abs -> Febux_C [color="#F57F17"]
    Febux_C -> Febux_met [color="#F57F17"]
    Febux_C -> XO_inhibit_feb [label="Non-purine\nIC50=0.6nM" color="#F57F17" penwidth=2]
    XO_inhibit_feb -> XO [color="#C62828" penwidth=2]
    XO_inhibit_feb -> UA_reduction_feb [color="#F57F17" penwidth=2]
    UA_reduction_feb -> SUA [color="#880E4F" style=dashed dir=back penwidth=2]

    /* Uricosuric PK/PD */
    Probenecid_dose -> Probenecid_C [color="#004D40"]
    Probenecid_C -> URAT1_inhibit [color="#004D40"]
    URAT1_inhibit -> URAT1 [color="#C62828"]
    URAT1_inhibit -> UA_excr_incr [color="#004D40" penwidth=2]
    Lesinurad_dose -> Lesinurad_C [color="#004D40"]
    Lesinurad_C -> URAT1_OAT4_inh [color="#004D40"]
    URAT1_OAT4_inh -> URAT1 [color="#C62828"]
    URAT1_OAT4_inh -> OAT4 [color="#C62828"]
    Dotinurad_dose -> URAT1_ABCG2_sel [color="#004D40"]
    URAT1_ABCG2_sel -> URAT1 [color="#C62828"]
    UA_excr_incr -> SUA_uricosuric [color="#004D40" penwidth=2]
    SUA_uricosuric -> SUA [color="#880E4F" style=dashed dir=back]
    UA_excr_incr -> Urolith_risk [color="#EF5350"]

    /* Pegloticase */
    Pegloticase_dose -> Pegloti_C [color="#4527A0"]
    Pegloti_C -> Uricase_rxn [color="#4527A0"]
    Uricase_rxn -> Allantoin_prod [color="#4527A0"]
    Allantoin_prod -> UrinaryUA [label="알란토인 배설" color="#4527A0"]
    Uricase_rxn -> SUA_rapid_drop [color="#4527A0" penwidth=2]
    SUA_rapid_drop -> SUA [color="#880E4F" style=dashed dir=back penwidth=3]
    Pegloti_C -> AntiPEG_Ab [label="면역원성" color="#EF5350" style=dashed]

    /* Clinical outcomes */
    SUA -> SUA_target [color="#B71C1C" penwidth=2]
    GoutFlare_risk -> Flare_freq [color="#B71C1C"]
    Tophus_risk -> Tophus_resolve [color="#B71C1C"]
    GFR_decline -> Renal_protect [color="#B71C1C"]
    CV_events -> CV_protect [color="#B71C1C"]
    MSU_crystal -> JointDamage [color="#B71C1C"]
    Flare_freq -> QoL [color="#B71C1C"]
    JointDamage -> QoL [color="#B71C1C"]
    SUA -> Treatment_dur [color="#B71C1C" penwidth=2]
}
