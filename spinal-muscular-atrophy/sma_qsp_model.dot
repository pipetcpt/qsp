digraph SMA_QSP_Model {
    graph [
        label="Spinal Muscular Atrophy (SMA) — Quantitative Systems Pharmacology Model\nSMN Biology · Motor Neuron Degeneration · Nusinersen · Risdiplam · Onasemnogene"
        fontname="Helvetica"
        fontsize=22
        labelloc=t
        rankdir=LR
        splines=ortho
        nodesep=0.5
        ranksep=1.2
        bgcolor="#FAFAFA"
        compound=true
    ]
    node [fontname="Helvetica" fontsize=10 style=filled shape=box]
    edge [fontname="Helvetica" fontsize=9 color="#555555"]

    // =========================================================
    // CLUSTER 1: Genetic Basis
    // =========================================================
    subgraph cluster_genetics {
        label="Genetic & Chromosomal Basis (5q13.2)"
        fontsize=14 fontcolor="#1A237E"
        style=filled fillcolor="#E8EAF6"
        color="#3F51B5"

        SMN1_gene [label="SMN1 Gene\n(Telomeric copy)" fillcolor="#B3E5FC" shape=ellipse]
        SMN2_gene [label="SMN2 Gene\n(Centromeric copy, n=1–4)" fillcolor="#B3E5FC" shape=ellipse]
        chr5q_deletion [label="Chr 5q13.2\nHomozygous Deletion\n(95% of SMA cases)" fillcolor="#FFCDD2" shape=diamond]
        SMN2_copy_number [label="SMN2 Copy Number\n(modifier of severity)" fillcolor="#DCEDC8" shape=hexagon]
        C840T_transition [label="C840T Transversion\nin SMN2 Exon 7\n(disrupts ESE)" fillcolor="#FFE0B2" shape=note]
        SMN1_point_mutation [label="SMN1 Point Mutation\n(5% compound het.)" fillcolor="#FFE0B2" shape=note]
        NAIP_gene [label="NAIP Gene\n(neuronal apoptosis\ninhibitory protein)" fillcolor="#F3E5F5"]
        NCALD_gene [label="NCALD Gene\n(neuroprotective\nmodifier)" fillcolor="#DCEDC8"]
        PLS3_gene [label="PLS3 Gene\n(Plastin-3,\nX-linked modifier)" fillcolor="#DCEDC8"]

        chr5q_deletion -> SMN1_gene [label="deletion" color="#F44336"]
        SMN2_copy_number -> SMN2_gene [label="copy no." color="#4CAF50"]
        C840T_transition -> SMN2_gene [label="single nt\nchange" style=dashed]
        SMN1_point_mutation -> SMN1_gene [label="alt. mutation" style=dashed]
    }

    // =========================================================
    // CLUSTER 2: SMN2 Pre-mRNA Splicing
    // =========================================================
    subgraph cluster_splicing {
        label="SMN2 Pre-mRNA Alternative Splicing"
        fontsize=14 fontcolor="#1B5E20"
        style=filled fillcolor="#E8F5E9"
        color="#388E3C"

        SMN2_pre_mRNA [label="SMN2 Pre-mRNA\n(Exons 1–8)" fillcolor="#A5D6A7" shape=parallelogram]
        SMN1_pre_mRNA [label="SMN1 Pre-mRNA\n(Exons 1–8)" fillcolor="#A5D6A7" shape=parallelogram]
        exon7_ESE [label="Exon 7 ESE\n(Enhancer: SRSF1\nbinding site)" fillcolor="#C8E6C9"]
        exon7_ESS [label="Exon 7 ESS\n(Silencer: hnRNP A1/A2\nbinding)" fillcolor="#FFCDD2"]
        ISS_N1 [label="ISS-N1\n(Intronic Splicing\nSilencer, intron 7)" fillcolor="#FFCDD2"]
        SRSF1 [label="SRSF1\n(SF2/ASF\nsplicing factor)" fillcolor="#B2DFDB"]
        SRSF9 [label="SRSF9\n(SRp30c\nenhancer)" fillcolor="#B2DFDB"]
        hnRNP_A1 [label="hnRNP A1/A2\n(splicing repressor)" fillcolor="#FFCCBC"]
        Tra2b [label="Tra2β\n(splicing activator\nfor exon 7)" fillcolor="#B2DFDB"]
        RBFox [label="RBFox1/2/3\n(tissue-specific\nsplicing)" fillcolor="#B2DFDB"]
        FL_SMN_mRNA [label="FL-SMN mRNA\n(exon 7 included)\n~10% from SMN2" fillcolor="#69F0AE" shape=parallelogram]
        SMN_delta7_mRNA [label="SMN-Δ7 mRNA\n(exon 7 skipped)\n~90% from SMN2" fillcolor="#FF8A65" shape=parallelogram]
        exon7_inclusion_rate [label="Exon 7\nInclusion Rate\n(E7I, 0–1)" fillcolor="#DCEDC8" shape=hexagon]

        SMN2_gene -> SMN2_pre_mRNA [label="transcription"]
        SMN1_gene -> SMN1_pre_mRNA [label="transcription"]
        SMN2_pre_mRNA -> exon7_ESE
        SMN2_pre_mRNA -> exon7_ESS
        SMN2_pre_mRNA -> ISS_N1
        SRSF1 -> exon7_ESE [label="binds\n(promotes E7)" color="#4CAF50"]
        Tra2b -> exon7_ESE [label="activates" color="#4CAF50"]
        SRSF9 -> exon7_ESE [label="activates" color="#4CAF50"]
        hnRNP_A1 -> exon7_ESS [label="binds ISS-N1\n(represses E7)" color="#F44336"]
        hnRNP_A1 -> ISS_N1 [label="binds" color="#F44336"]
        RBFox -> SMN2_pre_mRNA [style=dashed color="#9E9E9E"]
        exon7_inclusion_rate -> FL_SMN_mRNA [label="10% baseline"]
        exon7_inclusion_rate -> SMN_delta7_mRNA [label="90% baseline"]
        SMN1_pre_mRNA -> FL_SMN_mRNA [label="100% inclusion"]
        C840T_transition -> exon7_ESE [label="disrupts SRSF1\nbinding" color="#F44336"]
    }

    // =========================================================
    // CLUSTER 3: SMN Protein & Complex Biology
    // =========================================================
    subgraph cluster_protein {
        label="SMN Protein & snRNP Assembly Complex"
        fontsize=14 fontcolor="#4A148C"
        style=filled fillcolor="#F3E5F5"
        color="#7B1FA2"

        FL_SMN_protein [label="Full-Length SMN Protein\n(294 aa, Tudor domain)" fillcolor="#CE93D8" shape=box3d]
        SMN_delta7_protein [label="SMN-Δ7 Protein\n(rapidly degraded,\nnon-functional)" fillcolor="#EF9A9A" shape=box3d]
        SMN_total_protein [label="Total SMN Protein Pool\n(critical threshold)" fillcolor="#CE93D8" shape=hexagon]
        Gemin2 [label="Gemin2\n(SMN binding\npartner)" fillcolor="#E1BEE7"]
        Gemin3 [label="Gemin3/4\n(DEAD-box helicase)" fillcolor="#E1BEE7"]
        Gemin5 [label="Gemin5\n(snRNA cap\nbinding)" fillcolor="#E1BEE7"]
        Gemin6_8 [label="Gemin6/7/8\n(complex\nstabilizers)" fillcolor="#E1BEE7"]
        Unrip [label="Unrip\n(SMN complex\nmember)" fillcolor="#E1BEE7"]
        WDR77 [label="WDR77\n(pICln, SMN\ninteractor)" fillcolor="#E1BEE7"]
        SMN_oligomer [label="SMN Oligomer\n(self-association via\nYG box)" fillcolor="#AB47BC"]
        Sm_proteins [label="Sm Proteins\n(B, D1, D2, D3,\nE, F, G)" fillcolor="#9C27B0" fontcolor=white]
        snRNA_U1 [label="U1 snRNA\n(5' splice site\nrecognition)" fillcolor="#B39DDB"]
        snRNA_U2 [label="U2 snRNA\n(branch point\nrecognition)" fillcolor="#B39DDB"]
        snRNA_U4U6 [label="U4/U6 snRNA\n(catalytic core)" fillcolor="#B39DDB"]
        snRNA_U5 [label="U5 snRNA\n(exon joining)" fillcolor="#B39DDB"]
        snRNP_assembly [label="snRNP Assembly\n(Sm core + snRNA)" fillcolor="#7B1FA2" fontcolor=white shape=component]
        spliceosome_function [label="Spliceosome Function\n(pre-mRNA processing)" fillcolor="#4A148C" fontcolor=white shape=component]
        mRNA_homeostasis [label="mRNA Homeostasis\n(bulk RNA splicing)" fillcolor="#D1C4E9"]
        axonal_mRNA_transport [label="Axonal mRNA Transport\n(beta-actin, GAP-43)" fillcolor="#D1C4E9"]
        ribosome_biogenesis [label="Ribosome Biogenesis\n(rDNA transcription)" fillcolor="#D1C4E9"]

        FL_SMN_mRNA -> FL_SMN_protein [label="translation"]
        SMN_delta7_mRNA -> SMN_delta7_protein [label="translation"]
        SMN_delta7_protein -> SMN_total_protein [label="minor contribution\n(unstable)" style=dashed color="#F44336"]
        FL_SMN_protein -> SMN_total_protein
        FL_SMN_protein -> SMN_oligomer [label="self-oligom.\nvia YG box"]
        SMN_oligomer -> Gemin2 [label="recruits"]
        SMN_oligomer -> Gemin3
        SMN_oligomer -> Gemin5
        SMN_oligomer -> Gemin6_8
        SMN_oligomer -> Unrip
        SMN_oligomer -> WDR77
        Gemin5 -> Sm_proteins [label="recruits\nSm proteins"]
        Sm_proteins -> snRNP_assembly [label="Sm ring\nformation"]
        snRNA_U1 -> snRNP_assembly
        snRNA_U2 -> snRNP_assembly
        snRNA_U4U6 -> snRNP_assembly
        snRNA_U5 -> snRNP_assembly
        snRNP_assembly -> spliceosome_function
        spliceosome_function -> mRNA_homeostasis
        FL_SMN_protein -> axonal_mRNA_transport [label="cytoplasmic\nfunction"]
        FL_SMN_protein -> ribosome_biogenesis [label="nuclear\nfunction"]
        SMN_total_protein -> snRNP_assembly [label="required for\nassembly" style=dashed]
    }

    // =========================================================
    // CLUSTER 4: Motor Neuron Biology
    // =========================================================
    subgraph cluster_motor_neuron {
        label="Motor Neuron Biology & Degeneration"
        fontsize=14 fontcolor="#B71C1C"
        style=filled fillcolor="#FFEBEE"
        color="#D32F2F"

        alpha_MN_pool [label="Alpha-Motor Neuron Pool\n(spinal cord, ventral horn)\nN(t)" fillcolor="#EF9A9A" shape=hexagon]
        gamma_MN [label="Gamma-Motor Neurons\n(spindle regulation)" fillcolor="#FFCDD2"]
        MN_survival_signal [label="MN Survival Signals\n(BDNF, VEGF, IGF-1,\nNT-3, CNTF)" fillcolor="#FFCDD2"]
        apoptosis_pathway [label="Apoptosis Pathway\n(Bcl-2/Bax,\ncaspase-3)" fillcolor="#F44336" fontcolor=white]
        p53_activation [label="p53 Activation\n(DNA damage\nresponse)" fillcolor="#EF5350" fontcolor=white]
        Bcl2 [label="Bcl-2 Family\n(anti-apoptotic)" fillcolor="#81C784"]
        Bax_Bak [label="Bax/Bak\n(pro-apoptotic)" fillcolor="#EF9A9A"]
        cytochrome_c [label="Cytochrome c\nRelease\n(mitochondria)" fillcolor="#FF8A65"]
        caspase_cascade [label="Caspase-3/7\nCascade" fillcolor="#F44336" fontcolor=white]
        MN_degeneration [label="Motor Neuron\nDegeneration\n(irreversible)" fillcolor="#B71C1C" fontcolor=white shape=diamond]
        axon_transport_defect [label="Axonal Transport\nDefect\n(retrograde failure)" fillcolor="#FFCDD2"]
        neurofilament_accum [label="Neurofilament\nAccumulation\n(NF-L, NF-H)" fillcolor="#FFCDD2"]
        mitochondria_MN [label="Mitochondrial\nDysfunction\n(oxidative stress)" fillcolor="#FF8A65"]
        excitotoxicity [label="Excitotoxicity\n(glutamate,\nCa2+ overload)" fillcolor="#FF5722" fontcolor=white]
        proprioception_loss [label="Proprioceptive Input\nLoss\n(IA afferent)" fillcolor="#FFCDD2"]
        NF_L_serum [label="Serum NF-L\n(biomarker of MN\ndamity)" fillcolor="#FFE082" shape=oval]

        SMN_total_protein -> alpha_MN_pool [label="SMN below\nthreshold" color="#F44336"]
        mRNA_homeostasis -> alpha_MN_pool [label="splicing\ndefect" color="#F44336"]
        axonal_mRNA_transport -> axon_transport_defect [label="SMN↓" color="#F44336"]
        axon_transport_defect -> MN_degeneration
        neurofilament_accum -> MN_degeneration [style=dashed]
        mitochondria_MN -> apoptosis_pathway
        excitotoxicity -> apoptosis_pathway
        MN_survival_signal -> Bcl2 [label="promotes" color="#4CAF50"]
        MN_survival_signal -> apoptosis_pathway [label="inhibits" color="#4CAF50" style=dashed]
        Bcl2 -> apoptosis_pathway [label="inhibits" color="#4CAF50" style=dashed]
        Bax_Bak -> cytochrome_c [label="releases"]
        cytochrome_c -> caspase_cascade
        apoptosis_pathway -> Bax_Bak [label="activates"]
        p53_activation -> Bax_Bak [label="upregulates"]
        caspase_cascade -> MN_degeneration [label="executes"]
        MN_degeneration -> alpha_MN_pool [label="cell death\n(irreversible)" color="#F44336"]
        alpha_MN_pool -> NF_L_serum [label="releases NF-L\non degeneration"]
        proprioception_loss -> alpha_MN_pool [style=dashed color="#9E9E9E"]
        SMN_total_protein -> axonal_mRNA_transport
        NCALD_gene -> apoptosis_pathway [label="neuroprotective\ninhibition" color="#4CAF50" style=dashed]
        PLS3_gene -> axon_transport_defect [label="compensates\nF-actin" color="#4CAF50" style=dashed]
    }

    // =========================================================
    // CLUSTER 5: Neuromuscular Junction
    // =========================================================
    subgraph cluster_NMJ {
        label="Neuromuscular Junction (NMJ) Biology"
        fontsize=14 fontcolor="#0D47A1"
        style=filled fillcolor="#E3F2FD"
        color="#1565C0"

        NMJ_presynaptic [label="Presynaptic Terminal\n(motor axon bouton)" fillcolor="#90CAF9" shape=box3d]
        SVP_pool [label="Synaptic Vesicle Pool\n(docked + reserve)" fillcolor="#64B5F6"]
        ACh_synthesis [label="Acetylcholine\nSynthesis\n(ChAT enzyme)" fillcolor="#64B5F6"]
        ACh_vesicle [label="ACh-filled Vesicle\n(quantal content)" fillcolor="#64B5F6"]
        VACHT [label="VAChT\n(vesicular ACh\ntransporter)" fillcolor="#42A5F5"]
        synaptic_cleft [label="Synaptic Cleft\n(50–80 nm gap)" fillcolor="#BBDEFB" shape=ellipse]
        ACh_postsynaptic [label="Acetylcholine\nin Cleft" fillcolor="#90CAF9"]
        AChE [label="Acetylcholinesterase\n(AChE, cleft enzyme)" fillcolor="#FF8A65"]
        nAChR [label="Nicotinic AChR\n(α2βγδ pentamer)\npostsynaptic" fillcolor="#1565C0" fontcolor=white]
        MuSK [label="MuSK\n(receptor tyrosine\nkinase)" fillcolor="#1976D2" fontcolor=white]
        Agrin [label="Motor Nerve\nAgrin\n(heparan sulfate PG)" fillcolor="#42A5F5"]
        Lrp4 [label="Lrp4\n(agrin co-receptor)" fillcolor="#42A5F5"]
        end_plate_potential [label="End-Plate Potential\n(EPP, mV)" fillcolor="#1E88E5" fontcolor=white shape=hexagon]
        NMJ_maturation [label="NMJ Maturation\n(score 0–1)" fillcolor="#0D47A1" fontcolor=white shape=hexagon]
        NMJ_transmission [label="NMJ Transmission\nEfficacy (0–1)" fillcolor="#1565C0" fontcolor=white shape=hexagon]
        SNAP25 [label="SNAP-25\n(SNARE complex,\nvesicle fusion)" fillcolor="#64B5F6"]
        synaptotagmin [label="Synaptotagmin\n(Ca2+ sensor)" fillcolor="#64B5F6"]
        Ca2_influx [label="Ca2+ Influx\n(voltage-gated\nCa2+ channels)" fillcolor="#90CAF9"]

        alpha_MN_pool -> NMJ_presynaptic [label="innervates"]
        NMJ_presynaptic -> SVP_pool
        ACh_synthesis -> ACh_vesicle
        VACHT -> ACh_vesicle [label="loads ACh"]
        SVP_pool -> ACh_vesicle
        ACh_vesicle -> SNAP25 [label="docking"]
        Ca2_influx -> synaptotagmin [label="Ca2+ trigger"]
        synaptotagmin -> SNAP25 [label="fusion trigger"]
        SNAP25 -> synaptic_cleft [label="exocytosis\nof ACh"]
        ACh_vesicle -> ACh_postsynaptic [label="release"]
        synaptic_cleft -> ACh_postsynaptic
        ACh_postsynaptic -> nAChR [label="binds AChR" color="#4CAF50"]
        AChE -> ACh_postsynaptic [label="hydrolyzes" color="#F44336"]
        nAChR -> end_plate_potential [label="ion flux\n(Na+/K+)"]
        Agrin -> Lrp4 [label="binds"]
        Lrp4 -> MuSK [label="activates"]
        MuSK -> nAChR [label="clustering\n(AChR aggregation)" color="#4CAF50"]
        MuSK -> NMJ_maturation [label="promotes" color="#4CAF50"]
        end_plate_potential -> NMJ_transmission
        NMJ_maturation -> NMJ_transmission
        MN_degeneration -> NMJ_presynaptic [label="denervation" color="#F44336"]
        SMN_total_protein -> NMJ_maturation [label="SMN required\nfor maturation" color="#4CAF50"]
    }

    // =========================================================
    // CLUSTER 6: Skeletal Muscle
    // =========================================================
    subgraph cluster_muscle {
        label="Skeletal Muscle Pathology"
        fontsize=14 fontcolor="#E65100"
        style=filled fillcolor="#FFF3E0"
        color="#EF6C00"

        muscle_fiber_typeI [label="Type I Fibers\n(slow-twitch,\noxidative)" fillcolor="#FFCC80" shape=box3d]
        muscle_fiber_typeII [label="Type II Fibers\n(fast-twitch,\nglycolytic)" fillcolor="#FFB74D" shape=box3d]
        sarcomere [label="Sarcomere\n(actin-myosin\ncross-bridge)" fillcolor="#FFB74D"]
        muscle_mass [label="Skeletal Muscle Mass\n(g, declining)" fillcolor="#EF6C00" fontcolor=white shape=hexagon]
        denervation_atrophy [label="Denervation Atrophy\n(fiber diameter ↓)" fillcolor="#FFCCBC"]
        reinnervation [label="Reinnervation\n(collateral sprouting)" fillcolor="#DCEDC8"]
        neurogenic_atrophy [label="Neurogenic Atrophy\n(angular fibers,\ngrouping)" fillcolor="#FFCCBC"]
        ubiquitin_proteasome [label="Ubiquitin-Proteasome\nSystem\n(MuRF1, MAFbx↑)" fillcolor="#FFCCBC"]
        autophagy_muscle [label="Autophagy\n(LC3B, p62)" fillcolor="#FFCCBC"]
        myostatin [label="Myostatin\n(GDF-8, negative\nregulator)" fillcolor="#EF9A9A"]
        IGF1_muscle [label="IGF-1/mTORC1\n(muscle hypertrophy\nsignaling)" fillcolor="#C8E6C9"]
        fiber_type_shift [label="Fiber Type Shift\n(IIb→IIa→I)" fillcolor="#FFB74D" shape=oval]
        fibrosis_muscle [label="Muscle Fibrosis\n(collagen deposition)" fillcolor="#FFCCBC"]

        NMJ_transmission -> muscle_fiber_typeI [label="innervates\n(proximal)"]
        NMJ_transmission -> muscle_fiber_typeII [label="innervates\n(distal)"]
        muscle_fiber_typeI -> muscle_mass
        muscle_fiber_typeII -> muscle_mass
        sarcomere -> muscle_fiber_typeI [label="contractile\nunit"]
        sarcomere -> muscle_fiber_typeII
        denervation_atrophy -> neurogenic_atrophy
        denervation_atrophy -> ubiquitin_proteasome [label="activates"]
        denervation_atrophy -> autophagy_muscle [label="activates"]
        ubiquitin_proteasome -> muscle_mass [label="reduces" color="#F44336"]
        autophagy_muscle -> muscle_mass [label="reduces" color="#F44336"]
        myostatin -> muscle_mass [label="inhibits" color="#F44336"]
        IGF1_muscle -> muscle_mass [label="promotes" color="#4CAF50"]
        reinnervation -> muscle_mass [label="preserves" color="#4CAF50"]
        NMJ_presynaptic -> reinnervation [label="collateral\nsprouting"]
        denervation_atrophy -> fibrosis_muscle [style=dashed]
        fiber_type_shift -> muscle_fiber_typeII
        MN_degeneration -> denervation_atrophy [label="denervates\nfibers" color="#F44336"]
    }

    // =========================================================
    // CLUSTER 7: Clinical Endpoints & Biomarkers
    // =========================================================
    subgraph cluster_clinical {
        label="Clinical Endpoints & Disease Biomarkers"
        fontsize=14 fontcolor="#006064"
        style=filled fillcolor="#E0F7FA"
        color="#00838F"

        CMAP_amplitude [label="CMAP Amplitude\n(mV, electrophysiology)" fillcolor="#80DEEA" shape=oval]
        CHOP_INTEND [label="CHOP-INTEND Score\n(0–64, SMA type I)" fillcolor="#4DD0E1" shape=oval]
        HFMSE [label="HFMSE Score\n(0–66, SMA type II/III)" fillcolor="#4DD0E1" shape=oval]
        RULM [label="RULM Score\n(0–37, upper limb)" fillcolor="#4DD0E1" shape=oval]
        MFM32 [label="MFM-32 Score\n(0–100, motor function)" fillcolor="#4DD0E1" shape=oval]
        FVC [label="FVC\n(% predicted,\nrespiratory)" fillcolor="#80DEEA" shape=oval]
        six_min_walk [label="6-Minute Walk Test\n(meters, SMA III/IV)" fillcolor="#80DEEA" shape=oval]
        ventilator_support [label="Ventilator Support\n(hours/day)" fillcolor="#FFCDD2" shape=oval]
        motor_milestone [label="Motor Milestones\n(sitting, standing,\nwalking)" fillcolor="#80DEEA" shape=diamond]
        time_to_death [label="Time to Death /\nPermanent Ventilation\n(survival endpoint)" fillcolor="#B71C1C" fontcolor=white shape=oval]
        NF_L_biomarker [label="Plasma/CSF NF-L\n(neurofilament light,\ndegeneration marker)" fillcolor="#FFE082" shape=oval]
        SMN_protein_level [label="SMN Protein Level\n(blood/CSF,\nPD biomarker)" fillcolor="#FFE082" shape=oval]
        creatinine_urine [label="Urine Creatinine/\nCreatine Ratio\n(muscle mass proxy)" fillcolor="#FFE082" shape=oval]

        muscle_mass -> CMAP_amplitude [label="correlates"]
        NMJ_transmission -> CMAP_amplitude [label="determines"]
        alpha_MN_pool -> CMAP_amplitude [label="# active MNs"]
        muscle_mass -> CHOP_INTEND [label="determines\n(type I)"]
        muscle_mass -> HFMSE [label="determines\n(type II/III)"]
        muscle_mass -> RULM [label="upper limb\nfunction"]
        muscle_mass -> six_min_walk [label="ambulation"]
        muscle_mass -> MFM32
        muscle_mass -> FVC [label="respiratory\nmuscles"]
        FVC -> ventilator_support [label="FVC<40%\ntriggers"]
        motor_milestone -> HFMSE [label="milestones\ncontribute"]
        motor_milestone -> CHOP_INTEND
        time_to_death -> ventilator_support [label="composite\nendpoint"]
        time_to_death -> FVC
        NF_L_serum -> NF_L_biomarker
        SMN_total_protein -> SMN_protein_level
        muscle_mass -> creatinine_urine
    }

    // =========================================================
    // CLUSTER 8: Nusinersen (Spinraza) PK/PD
    // =========================================================
    subgraph cluster_nusinersen {
        label="Nusinersen (Spinraza) — Antisense Oligonucleotide PK/PD"
        fontsize=14 fontcolor="#33691E"
        style=filled fillcolor="#F1F8E9"
        color="#558B2F"

        nusinersen_IT_dose [label="Intrathecal Injection\nNusinersen\n(12 mg/5 mL)" fillcolor="#AED581" shape=cds]
        nusinersen_loading [label="Loading: 4 doses\n(Day 0,14,28,63)" fillcolor="#CDDC39"]
        nusinersen_maintenance [label="Maintenance:\n12 mg q4months" fillcolor="#CDDC39"]
        C_CSF_lumbar [label="CSF Lumbar\nConc. (ng/mL)" fillcolor="#8BC34A" shape=hexagon]
        C_CSF_cervical [label="CSF Cervical\nConc. (ng/mL)" fillcolor="#8BC34A" shape=hexagon]
        C_CSF_flow [label="CSF Bulk Flow\n(rostrally directed)" fillcolor="#DCEDC8"]
        nusinersen_CNS_tissue [label="CNS Tissue\nConc. (ng/g)" fillcolor="#558B2F" fontcolor=white shape=hexagon]
        nusinersen_plasma [label="Plasma Nusinersen\n(Cmax ~1 ng/mL)" fillcolor="#C5E1A5"]
        ASO_degradation [label="ASO Degradation\n(endonuclease/\nexonuclease)" fillcolor="#FF8A65"]
        ISS_N1_block [label="ISS-N1 Blockade\n(ASO binds pre-mRNA)" fillcolor="#33691E" fontcolor=white shape=component]
        exon7_inclusion_NUS [label="Exon 7 Inclusion\n↑ (20→70%)" fillcolor="#8BC34A" shape=hexagon]
        FL_SMN_increase_NUS [label="FL-SMN Protein\nIncrease\n(3–5× baseline)" fillcolor="#33691E" fontcolor=white shape=hexagon]
        nusinersen_t_half [label="t½ ~135–177 days\n(CSF tissue)" fillcolor="#DCEDC8"]

        nusinersen_IT_dose -> C_CSF_lumbar [label="bolus\ninjection"]
        nusinersen_loading -> nusinersen_IT_dose
        nusinersen_maintenance -> nusinersen_IT_dose
        C_CSF_lumbar -> C_CSF_flow [label="bulk flow\n(0.3–0.4 mL/min)"]
        C_CSF_flow -> C_CSF_cervical [label="rostral\ndistribution"]
        C_CSF_lumbar -> nusinersen_CNS_tissue [label="uptake into\nspinal cord"]
        C_CSF_cervical -> nusinersen_CNS_tissue [label="uptake into\nbrain stem"]
        nusinersen_CNS_tissue -> ISS_N1_block [label="saturable\nbinding"]
        ISS_N1_block -> exon7_inclusion_NUS [label="sterically\nblocks ISS-N1" color="#4CAF50"]
        exon7_inclusion_NUS -> FL_SMN_increase_NUS [label="more FL-SMN\nmRNA→protein"]
        nusinersen_CNS_tissue -> ASO_degradation [label="slow\nelimination"]
        nusinersen_CNS_tissue -> nusinersen_plasma [label="minimal\nsystemic"]
        nusinersen_t_half -> ASO_degradation [style=dashed]
        FL_SMN_increase_NUS -> SMN_total_protein [label="↑ SMN pool" color="#4CAF50"]
    }

    // =========================================================
    // CLUSTER 9: Risdiplam (Evrysdi) PK/PD
    // =========================================================
    subgraph cluster_risdiplam {
        label="Risdiplam (Evrysdi) — Oral Small Molecule Splice Modifier PK/PD"
        fontsize=14 fontcolor="#1A237E"
        style=filled fillcolor="#E8EAF6"
        color="#283593"

        risdiplam_oral_dose [label="Oral Risdiplam\n(0.2 mg/kg/day,\nor 5 mg fixed)" fillcolor="#9FA8DA" shape=cds]
        risdiplam_gut [label="GI Absorption\n(F ~100%)" fillcolor="#C5CAE9"]
        C_plasma_ris [label="Plasma Risdiplam\nConc. (ng/mL)\nCmax ~220 ng/mL" fillcolor="#7986CB" shape=hexagon]
        C_CNS_ris [label="CNS Risdiplam\nConc.\n(Kp_brain ~0.5)" fillcolor="#5C6BC0" fontcolor=white shape=hexagon]
        C_periph_ris [label="Peripheral Tissue\nConc. (whole-body\ndistribution)" fillcolor="#7986CB" shape=hexagon]
        risdiplam_metabolism [label="CYP3A4/FMO\nMetabolism\n(t½ ~50 h)" fillcolor="#FF8A65"]
        risdiplam_protein_bind [label="Plasma Protein\nBinding\n(fu ~7%)" fillcolor="#C5CAE9"]
        splice_modifier_mech [label="SRSF1/Tra2β\nEnhancement\n(G1 intronic element)" fillcolor="#1A237E" fontcolor=white shape=component]
        exon7_inclusion_RIS [label="Exon 7 Inclusion\n↑ (systemic,\nbrain+periphery)" fillcolor="#7986CB" fontcolor=white shape=hexagon]
        FL_SMN_increase_RIS [label="FL-SMN Increase\n(2–3× baseline,\nsystemic)" fillcolor="#283593" fontcolor=white shape=hexagon]
        retinal_concern [label="Retinal Toxicity\nMonitoring\n(preclinical finding)" fillcolor="#FFCDD2" shape=note]

        risdiplam_oral_dose -> risdiplam_gut
        risdiplam_gut -> C_plasma_ris [label="Tmax ~1–4h"]
        C_plasma_ris -> risdiplam_protein_bind
        C_plasma_ris -> C_CNS_ris [label="CNS penetration\n(passive diffusion)"]
        C_plasma_ris -> C_periph_ris [label="tissue\ndistribution"]
        C_plasma_ris -> risdiplam_metabolism [label="hepatic\nelimination"]
        C_CNS_ris -> splice_modifier_mech [label="enhances\nSF binding"]
        C_periph_ris -> splice_modifier_mech [label="peripheral\nSMN↑"]
        splice_modifier_mech -> exon7_inclusion_RIS [label="promotes\nexon 7 inclusion"]
        exon7_inclusion_RIS -> FL_SMN_increase_RIS [label="more FL-SMN"]
        FL_SMN_increase_RIS -> SMN_total_protein [label="↑ systemic\nSMN" color="#4CAF50"]
        retinal_concern -> risdiplam_oral_dose [style=dashed color="#9E9E9E"]
    }

    // =========================================================
    // CLUSTER 10: Onasemnogene Abeparvovec (Zolgensma) PK/PD
    // =========================================================
    subgraph cluster_zolgensma {
        label="Onasemnogene Abeparvovec (Zolgensma) — AAV9 Gene Therapy PK/PD"
        fontsize=14 fontcolor="#880E4F"
        style=filled fillcolor="#FCE4EC"
        color="#AD1457"

        zolgensma_IV [label="Single IV Infusion\nZolgensma\n(1.1×10¹⁴ vg/kg)" fillcolor="#F48FB1" shape=cds]
        AAV9_vector [label="AAV9 Vector\n(recombinant, scAAV9\nshell + SMN1 transgene)" fillcolor="#F06292"]
        C_plasma_ZOL [label="Plasma Vector\nConc. (vg/mL)" fillcolor="#E91E63" fontcolor=white shape=hexagon]
        AAV9_distribution [label="Tissue Distribution\n(liver, CNS, heart,\nskeletal muscle)" fillcolor="#F48FB1"]
        BBB_crossing [label="Blood-Brain Barrier\nCrossing\n(AAV9 transcytosis)" fillcolor="#E91E63" fontcolor=white]
        MN_transduction [label="Motor Neuron\nTransduction\n(vg/nucleus)" fillcolor="#880E4F" fontcolor=white shape=hexagon]
        SMN1_transgene [label="SMN1 Transgene\n(CMV enhancer/\nCB promoter)" fillcolor="#AD1457" fontcolor=white]
        SMN1_mRNA_tg [label="Transgene-derived\nFL-SMN mRNA\n(persistent expression)" fillcolor="#F48FB1" shape=parallelogram]
        FL_SMN_ZOL [label="FL-SMN Protein\nfrom Transgene\n(long-lasting)" fillcolor="#880E4F" fontcolor=white shape=hexagon]
        AAV9_capsid_Ab [label="Anti-AAV9 Antibody\n(titer <1:50 required)" fillcolor="#FFCDD2"]
        complement_activation [label="Complement Activation\n(CARPA risk)" fillcolor="#FFCDD2"]
        hepatotoxicity_ZOL [label="Hepatotoxicity\n(ALT/AST elevation,\nsteroids given)" fillcolor="#FFCDD2"]
        TMA_risk [label="Thrombotic Microangiopathy\n(TMA, rare)" fillcolor="#FFCDD2" shape=note]
        episomal_persistence [label="Episomal DNA\n(non-integrating,\ndivision dilution)" fillcolor="#F48FB1"]
        corticosteroids_ZOL [label="Corticosteroids\n(prophylactic,\nday -1 to day 30)" fillcolor="#B2DFDB"]

        zolgensma_IV -> AAV9_vector
        AAV9_vector -> C_plasma_ZOL [label="IV admin"]
        C_plasma_ZOL -> AAV9_distribution [label="rapid\ndistribution"]
        AAV9_distribution -> BBB_crossing [label="AAV9 crosses BBB\n(receptor-mediated)"]
        BBB_crossing -> MN_transduction [label="endocytosis\n(galactose receptor)"]
        MN_transduction -> SMN1_transgene [label="nuclear\ndelivery"]
        SMN1_transgene -> SMN1_mRNA_tg [label="transcription\n(persistent)"]
        SMN1_mRNA_tg -> FL_SMN_ZOL [label="translation"]
        FL_SMN_ZOL -> SMN_total_protein [label="↑ SMN protein\n(durable)" color="#4CAF50"]
        AAV9_capsid_Ab -> MN_transduction [label="neutralizes\n(must titer <1:50)" color="#F44336"]
        complement_activation -> zolgensma_IV [style=dashed]
        hepatotoxicity_ZOL -> AAV9_distribution [label="liver tropism" color="#F44336"]
        episomal_persistence -> SMN1_transgene [label="episomal\nDNA template"]
        corticosteroids_ZOL -> hepatotoxicity_ZOL [label="prophylaxis" color="#4CAF50"]
        TMA_risk -> zolgensma_IV [style=dashed color="#9E9E9E"]
    }

    // =========================================================
    // CLUSTER 11: SMA Disease Types & Natural History
    // =========================================================
    subgraph cluster_natural_history {
        label="SMA Disease Types & Natural History"
        fontsize=14 fontcolor="#4E342E"
        style=filled fillcolor="#EFEBE9"
        color="#6D4C41"

        SMA_type0 [label="SMA Type 0\n(prenatal/neonatal,\n1 SMN2 copy, fatal)" fillcolor="#B71C1C" fontcolor=white shape=diamond]
        SMA_type1 [label="SMA Type I\n(Werdnig-Hoffmann,\n<6 months, 1–2 SMN2)" fillcolor="#E53935" fontcolor=white shape=diamond]
        SMA_type2 [label="SMA Type II\n(intermediate, 6–18 mo,\n3 SMN2 copies)" fillcolor="#EF5350" fontcolor=white shape=diamond]
        SMA_type3 [label="SMA Type III\n(Kugelberg-Welander,\n>18 mo, 3–4 SMN2)" fillcolor="#FF7043" fontcolor=white shape=diamond]
        SMA_type4 [label="SMA Type IV\n(adult onset,\n≥4 SMN2 copies)" fillcolor="#FF8A65" shape=diamond]
        presymptomatic [label="Presymptomatic\nSMA\n(NBS-detected)" fillcolor="#DCEDC8" shape=diamond]
        newborn_screening [label="Newborn Screening\n(NBS programs)" fillcolor="#DCEDC8"]
        SMN2_copy_severity [label="SMN2 Copy No.\n→ Disease Severity\n(inverse correlation)" fillcolor="#BCAAA4" shape=hexagon]
        respiratory_failure [label="Respiratory Failure\n(type I: <2 yrs)" fillcolor="#B71C1C" fontcolor=white]
        scoliosis [label="Scoliosis\n(progressive,\ntype II/III)" fillcolor="#8D6E63"]
        hip_contracture [label="Hip Contractures\n& Joint Deformity" fillcolor="#8D6E63"]
        bulbar_dysfunction [label="Bulbar Dysfunction\n(swallowing, feeding)" fillcolor="#A1887F"]
        nutrition_support [label="Nutritional Support\n(NGT, gastrostomy)" fillcolor="#D7CCC8"]
        physiotherapy [label="Physiotherapy &\nRehabilitation" fillcolor="#D7CCC8"]

        SMN2_copy_number -> SMN2_copy_severity
        SMN2_copy_severity -> SMA_type0
        SMN2_copy_severity -> SMA_type1
        SMN2_copy_severity -> SMA_type2
        SMN2_copy_severity -> SMA_type3
        SMN2_copy_severity -> SMA_type4
        newborn_screening -> presymptomatic [label="detects\npre-symptoms"]
        SMA_type1 -> respiratory_failure [label="untreated"]
        SMA_type2 -> scoliosis
        SMA_type3 -> hip_contracture
        SMA_type1 -> bulbar_dysfunction
        bulbar_dysfunction -> nutrition_support
        scoliosis -> physiotherapy
        physiotherapy -> muscle_mass [label="maintains" color="#4CAF50"]
    }

    // =========================================================
    // CLUSTER 12: Systemic Effects & Comorbidities
    // =========================================================
    subgraph cluster_systemic {
        label="Systemic Effects & Comorbidities"
        fontsize=14 fontcolor="#311B92"
        style=filled fillcolor="#EDE7F6"
        color="#4527A0"

        cardiac_involvement [label="Cardiac Involvement\n(congenital heart\ndefects, SMA 0/1)" fillcolor="#EF9A9A"]
        metabolic_dysfunction [label="Metabolic Dysfunction\n(fatty acid oxidation\ndefects)" fillcolor="#CE93D8"]
        pancreatic_insufficiency [label="Pancreatic\nInsufficiency\n(exocrine, type I)" fillcolor="#B39DDB"]
        bone_health [label="Bone Health\n(low BMD,\nfracture risk)" fillcolor="#B0BEC5"]
        vascular_anomalies [label="Vascular Anomalies\n(digital necrosis,\ntype I)" fillcolor="#EF9A9A"]
        autonomic_dysfunction [label="Autonomic\nDysfunction\n(bradycardia)" fillcolor="#CE93D8"]
        cognitive_function [label="Cognitive Function\n(typically preserved)" fillcolor="#C8E6C9"]
        quality_of_life [label="Quality of Life\n(QoL, HRQoL)" fillcolor="#80DEEA" shape=oval]

        SMA_type1 -> cardiac_involvement [style=dashed]
        SMA_type1 -> metabolic_dysfunction [style=dashed]
        SMA_type1 -> pancreatic_insufficiency [style=dashed]
        muscle_mass -> bone_health [label="immobility→\nosteoporosis"]
        SMA_type1 -> vascular_anomalies [style=dashed]
        SMA_type1 -> autonomic_dysfunction [style=dashed]
        CMAP_amplitude -> quality_of_life [label="correlates"]
        HFMSE -> quality_of_life
        FVC -> quality_of_life
        motor_milestone -> quality_of_life
    }

    // =========================================================
    // INTER-CLUSTER KEY CONNECTIONS
    // =========================================================
    // Genetic → Splicing
    SMN2_gene -> SMN2_pre_mRNA [ltail=cluster_genetics lhead=cluster_splicing style=bold color="#3F51B5"]

    // Splicing → Protein
    FL_SMN_mRNA -> FL_SMN_protein [ltail=cluster_splicing lhead=cluster_protein style=bold color="#7B1FA2"]

    // Protein → Motor Neuron
    SMN_total_protein -> alpha_MN_pool [ltail=cluster_protein lhead=cluster_motor_neuron style=bold color="#D32F2F" label="SMN < threshold\n→ MN death"]

    // Motor Neuron → NMJ
    alpha_MN_pool -> NMJ_presynaptic [ltail=cluster_motor_neuron lhead=cluster_NMJ style=bold color="#1565C0"]

    // NMJ → Muscle
    NMJ_transmission -> muscle_fiber_typeI [ltail=cluster_NMJ lhead=cluster_muscle style=bold color="#EF6C00"]

    // Muscle → Clinical
    muscle_mass -> CMAP_amplitude [ltail=cluster_muscle lhead=cluster_clinical style=bold color="#00838F"]

    // Drug → Protein (key PD effects)
    FL_SMN_increase_NUS -> FL_SMN_protein [ltail=cluster_nusinersen lhead=cluster_protein style=bold color="#558B2F" label="restored\nSMN"]
    FL_SMN_increase_RIS -> FL_SMN_protein [ltail=cluster_risdiplam lhead=cluster_protein style=bold color="#283593"]
    FL_SMN_ZOL -> FL_SMN_protein [ltail=cluster_zolgensma lhead=cluster_protein style=bold color="#880E4F"]
}
