digraph RelapsingPolychondritis {
  rankdir=LR;
  graph [
    fontname="Helvetica", fontsize=11,
    overlap=false, splines=true, bgcolor="white",
    label="Relapsing Polychondritis (RP) — Quantitative Systems Pharmacology (QSP) Model\nAutoantigen Presentation · T/B Cell Activation · Cytokine Networks · Cartilage Destruction · Organ Involvement · Drug PK/PD",
    labelloc=t, labeljust=c, fontsize=14
  ];
  node [fontname="Helvetica", fontsize=9, style=filled, fillcolor=white, shape=box, color=gray60];
  edge [fontname="Helvetica", fontsize=8, color=gray40, arrowsize=0.7];

  // ============================================================
  // CLUSTER 1: Triggers & Autoantigens
  // ============================================================
  subgraph cluster_trigger {
    label="Triggers & Autoantigens";
    style=filled; fillcolor="#FFF9E6"; color="#CC8800"; fontsize=11;

    TypeII_col   [label="Type II Collagen\n(Articular/Auricular)", fillcolor="#FFD700", shape=cylinder];
    Matrilin1    [label="Matrilin-1\n(MATN1)", fillcolor="#FFD700"];
    TypeIX_col   [label="Type IX Collagen", fillcolor="#FFE680"];
    TypeXI_col   [label="Type XI Collagen", fillcolor="#FFE680"];
    Aggrecan     [label="Aggrecan\n(Proteoglycan Core)", fillcolor="#FFE680"];
    COMPprotein  [label="COMP / Cartilage\nOligomeric Protein", fillcolor="#FFE680"];
    Molecular_mimicry [label="Molecular Mimicry\n(Viral/Bacterial Ag)", shape=ellipse, fillcolor="#FFE680", style="filled,dashed"];
    Trauma       [label="Physical Trauma\n/ Iatrogenic", shape=ellipse, fillcolor="#FFE680"];
    Autoantigen_rel [label="Autoantigen\nRelease from Cartilage", fillcolor="#FFCC44"];
    DAMP_release [label="DAMPs\n(HMGB1, HSP60)", fillcolor="#FFCC44"];
  }

  // ============================================================
  // CLUSTER 2: Innate Immunity
  // ============================================================
  subgraph cluster_innate {
    label="Innate Immunity";
    style=filled; fillcolor="#E6F3FF"; color="#0066CC"; fontsize=11;

    DC          [label="Dendritic Cells\n(pDC/mDC)", fillcolor="#B3D9FF"];
    Macro       [label="Macrophages\n(M1 polarized)", fillcolor="#B3D9FF"];
    Neutrophil  [label="Neutrophils\n(PMN)", fillcolor="#B3D9FF"];
    Mast_cell   [label="Mast Cells", fillcolor="#B3D9FF"];
    NK_cell     [label="NK Cells", fillcolor="#B3D9FF"];
    Eosinophil  [label="Eosinophils", fillcolor="#CCE5FF"];

    TLR2_4      [label="TLR2/TLR4\nSignaling", shape=diamond, fillcolor="#80BFFF"];
    TLR9        [label="TLR9\n(nucleic acids)", shape=diamond, fillcolor="#80BFFF"];
    NLRP3       [label="NLRP3\nInflammasome", shape=diamond, fillcolor="#4DA6FF"];
    NF_kB       [label="NF-κB\nActivation", shape=diamond, fillcolor="#4DA6FF"];
    IRF3        [label="IRF3/IRF7\n(Type I IFN)", shape=diamond, fillcolor="#99CCFF"];

    MHC_II      [label="MHC II\nPeptide Presentation", shape=parallelogram, fillcolor="#99CCFF"];
    MHC_I       [label="MHC I\nPresentation", shape=parallelogram, fillcolor="#99CCFF"];
    CD80_86     [label="CD80/86\n(Co-stimulation)", shape=parallelogram, fillcolor="#99CCFF"];

    ROS_innate  [label="ROS\n(Oxidative Burst)", fillcolor="#CCE5FF"];
    MPO         [label="Myeloperoxidase\n(MPO)", fillcolor="#CCE5FF"];
    NET         [label="NETs\n(Neutrophil Extracell Traps)", fillcolor="#CCE5FF"];
  }

  // ============================================================
  // CLUSTER 3: T Cell Immunity
  // ============================================================
  subgraph cluster_tcell {
    label="T Cell Adaptive Immunity";
    style=filled; fillcolor="#E6FFE6"; color="#006600"; fontsize=11;

    CD4_naive   [label="CD4+ Naive\nT Cells", fillcolor="#B3FFB3"];
    CD8_naive   [label="CD8+ Naive\nT Cells", fillcolor="#B3FFB3"];
    Th1         [label="Th1 Cells\n(IFN-γ dominant)", fillcolor="#66FF66"];
    Th2         [label="Th2 Cells\n(IL-4 dominant)", fillcolor="#66FF66"];
    Th17        [label="Th17 Cells\n(IL-17A/F)", fillcolor="#66FF66"];
    Treg        [label="Regulatory T\n(FoxP3+ Treg)", fillcolor="#00CC44", fontcolor="white"];
    CD8_CTL     [label="CD8+ Cytotoxic\nT Lymphocytes", fillcolor="#66FF66"];
    NKT         [label="NKT Cells", fillcolor="#99FF99"];
    Tfh         [label="Follicular Helper\nT (Tfh)", fillcolor="#99FF99"];

    TCR_act     [label="TCR Activation\n(HLA-DR4/B27/DQ)", shape=diamond, fillcolor="#80FF80"];
    CD28_B7     [label="CD28-B7\nCo-stimulation", shape=diamond, fillcolor="#80FF80"];
    CTLA4_ck    [label="CTLA-4\nCheckpoint", shape=diamond, fillcolor="#40FF40"];
    PD1_ck      [label="PD-1\nCheckpoint", shape=diamond, fillcolor="#40FF40"];
    OX40        [label="OX40/OX40L\n(Th survival)", shape=diamond, fillcolor="#99FF99"];

    IFNg        [label="IFN-γ", fillcolor="#CCFFCC"];
    IL2         [label="IL-2", fillcolor="#CCFFCC"];
    IL4         [label="IL-4", fillcolor="#CCFFCC"];
    IL5         [label="IL-5", fillcolor="#CCFFCC"];
    IL17A       [label="IL-17A", fillcolor="#CCFFCC"];
    IL17F       [label="IL-17F", fillcolor="#CCFFCC"];
    IL21        [label="IL-21", fillcolor="#CCFFCC"];
    IL22        [label="IL-22", fillcolor="#CCFFCC"];
    TGFb        [label="TGF-β", fillcolor="#CCFFCC"];
    IL10_T      [label="IL-10\n(Treg-derived)", fillcolor="#CCFFCC"];
    Perforin    [label="Perforin /\nGranzyme B", fillcolor="#CCFFCC"];
  }

  // ============================================================
  // CLUSTER 4: B Cells & Autoantibodies
  // ============================================================
  subgraph cluster_bcell {
    label="B Cell / Autoantibody";
    style=filled; fillcolor="#FFE6FF"; color="#660066"; fontsize=11;

    B_naive     [label="Naive B Cells", fillcolor="#FFB3FF"];
    GC_B        [label="Germinal Center\nB Cells", fillcolor="#FF80FF"];
    Plasma_cell [label="Plasma Cells", fillcolor="#FF66FF"];
    Memory_B    [label="Memory B Cells", fillcolor="#FF80FF"];
    Bregs       [label="Regulatory B\n(Breg IL-10)", fillcolor="#FFCCFF"];

    Anti_CII    [label="Anti-Type II\nCollagen IgG/IgM", shape=house, fillcolor="#FF33FF"];
    Anti_Matr1  [label="Anti-Matrilin-1\nIgG", shape=house, fillcolor="#FF33FF"];
    Anti_CIX    [label="Anti-CIX IgG", shape=house, fillcolor="#FF66FF"];
    Anti_COMP   [label="Anti-COMP IgG", shape=house, fillcolor="#FF66FF"];
    ANCA_B      [label="ANCA (subset)", shape=house, fillcolor="#FF99FF"];
    RF          [label="Rheumatoid\nFactor (IgM)", shape=house, fillcolor="#FF99FF"];

    BCR_act     [label="BCR Activation\n+ Signaling", shape=diamond, fillcolor="#FF99FF"];
    CD40L_40    [label="CD40L-CD40\nT-B Interaction", shape=diamond, fillcolor="#FF66FF"];
    IC_form     [label="Immune Complex\nFormation (Ag-Ab)", shape=octagon, fillcolor="#FF33FF"];
    IC_cart     [label="IC Deposition\nin Cartilage", shape=octagon, fillcolor="#CC00CC", fontcolor="white"];
  }

  // ============================================================
  // CLUSTER 5: Complement System
  // ============================================================
  subgraph cluster_complement {
    label="Complement System";
    style=filled; fillcolor="#FFF0E6"; color="#CC4400"; fontsize=11;

    C1q         [label="C1q\n(Classical)", fillcolor="#FFD9B3"];
    C4          [label="C4 Cleavage", fillcolor="#FFD9B3"];
    C3          [label="C3 Cleavage", fillcolor="#FFD9B3"];
    C3a         [label="C3a\nAnaphylatoxin", fillcolor="#FFB380"];
    C3b         [label="C3b\n(Opsonin)", fillcolor="#FFD9B3"];
    C5          [label="C5 Cleavage", fillcolor="#FFD9B3"];
    C5a         [label="C5a\nAnaphylatoxin", fillcolor="#FF8040"];
    MAC_comp    [label="MAC (C5b-9)\nMembrane Attack", shape=octagon, fillcolor="#CC4400", fontcolor="white"];

    CP_path     [label="Classical Pathway\n(IC → C1q)", shape=diamond, fillcolor="#FFCC99"];
    AP_path     [label="Alternative\nPathway", shape=diamond, fillcolor="#FFCC99"];
    LP_path     [label="Lectin Pathway\n(MBL)", shape=diamond, fillcolor="#FFCC99"];
    C3_conv     [label="C3 Convertase", shape=diamond, fillcolor="#FFB366"];
  }

  // ============================================================
  // CLUSTER 6: Cytokine / Mediator Network
  // ============================================================
  subgraph cluster_cytokine {
    label="Cytokine / Mediator Network";
    style=filled; fillcolor="#FFFCE6"; color="#887700"; fontsize=11;

    IL1b_cyt    [label="IL-1β", fillcolor="#FFF099"];
    IL6_cyt     [label="IL-6", fillcolor="#FFF099"];
    TNFa_cyt    [label="TNF-α", fillcolor="#FFF099"];
    IL8_cyt     [label="IL-8/CXCL8\n(Neutrophil chemoattr)", fillcolor="#FFF099"];
    MCP1        [label="MCP-1/CCL2\n(Monocyte recr)", fillcolor="#FFF099"];
    CXCL10      [label="CXCL10/IP-10\n(T cell recr)", fillcolor="#FFF099"];
    IL12_cyt    [label="IL-12\n(Th1 polariz)", fillcolor="#FFF099"];
    IL18_cyt    [label="IL-18", fillcolor="#FFF099"];
    IL23_cyt    [label="IL-23\n(Th17 stability)", fillcolor="#FFF099"];
    IL33_cyt    [label="IL-33\n(Alarmin/DAMP)", fillcolor="#FFF099"];
    TSLP        [label="TSLP\n(Thymic Stromal LP)", fillcolor="#FFEEAA"];
    HMGB1       [label="HMGB1\n(Late DAMP)", fillcolor="#FFEEAA"];
    S100A8_9    [label="S100A8/A9\n(Calprotectin)", fillcolor="#FFEEAA"];

    JAK_STAT3   [label="JAK1/JAK2\n→ STAT3", shape=diamond, fillcolor="#FFDD33"];
    JAK_STAT1   [label="JAK1/TYK2\n→ STAT1", shape=diamond, fillcolor="#FFDD33"];
    MAPK_path   [label="MAPK/ERK\n/ p38", shape=diamond, fillcolor="#FFDD33"];
    PI3K_AKT    [label="PI3K/AKT\nmTOR", shape=diamond, fillcolor="#FFDD33"];
    AP1         [label="AP-1\n(c-Jun/c-Fos)", shape=diamond, fillcolor="#FFDD33"];

    APR         [label="Acute Phase\nResponse", fillcolor="#FFE680"];
    CRP_sys     [label="CRP\n(systemic)", fillcolor="#FFE680"];
    SAA_sys     [label="Serum Amyloid\nA (SAA)", fillcolor="#FFE680"];
    Fibrinogen  [label="Fibrinogen\n↑ESR", fillcolor="#FFE680"];
    Ferritin    [label="Ferritin\n(elevated)", fillcolor="#FFE680"];
    PGE2_inf    [label="PGE2\n(COX-2)", fillcolor="#FFE680"];
    LTB4        [label="LTB4\n(5-LOX)", fillcolor="#FFE680"];
  }

  // ============================================================
  // CLUSTER 7: Cartilage Pathology
  // ============================================================
  subgraph cluster_cartilage {
    label="Cartilage Pathology";
    style=filled; fillcolor="#F0E6FF"; color="#330066"; fontsize=11;

    Chondrocyte [label="Chondrocytes\n(Active)", fillcolor="#CC99FF"];
    Chond_apop  [label="Chondrocyte\nApoptosis", shape=octagon, fillcolor="#6600CC", fontcolor="white"];
    ECM_cart    [label="ECM / Cartilage\nMatrix Integrity", fillcolor="#CC99FF"];
    Perichond   [label="Perichondrium\nInflammation", fillcolor="#CC99FF"];

    MMP1_e      [label="MMP-1\n(Interstitial Coll'ase)", fillcolor="#9966FF"];
    MMP3_e      [label="MMP-3\n(Stromelysin-1)", fillcolor="#9966FF"];
    MMP9_e      [label="MMP-9\n(Gelatinase B)", fillcolor="#9966FF"];
    MMP13_e     [label="MMP-13\n(Collagenase-3)", fillcolor="#9966FF"];
    ADAMTS4     [label="ADAMTS-4\n(Aggrecanase-1)", fillcolor="#9966FF"];
    ADAMTS5     [label="ADAMTS-5\n(Aggrecanase-2)", fillcolor="#9966FF"];
    TIMP1       [label="TIMP-1/3\n(MMP Inhibitors)", fillcolor="#CC99FF"];
    Cathepsin   [label="Cathepsin B/K/L\n(Lysosomal)", fillcolor="#9966FF"];

    Collagen_deg [label="Collagen\nDegradation (CTX-II)", shape=octagon, fillcolor="#4400BB", fontcolor="white"];
    PG_loss     [label="Proteoglycan\nLoss (sCOMP↑)", shape=octagon, fillcolor="#4400BB", fontcolor="white"];
    Chond_prolif [label="Chondrocyte\nProliferation/Repair", fillcolor="#CC99FF"];
    Fibrocart   [label="Fibrocartilage\nReplacement", fillcolor="#CC99FF"];
    Calcif      [label="Dystrophic\nCalcification", fillcolor="#CC99FF"];
    Perichond_fibrosis [label="Perichondrial\nFibrosis", fillcolor="#CC99FF"];
  }

  // ============================================================
  // CLUSTER 8: Organ System Involvement
  // ============================================================
  subgraph cluster_organs {
    label="Organ System Involvement";
    style=filled; fillcolor="#E6FFFA"; color="#004444"; fontsize=11;

    Ear_chond   [label="Auricular\nChondritis\n(bilateral pinna)", shape=folder, fillcolor="#80FFE6"];
    Nose_chond  [label="Nasal Chondritis\n(nasal bridge)", shape=folder, fillcolor="#80FFE6"];
    Tracheo     [label="Tracheobronchial\nTree", shape=folder, fillcolor="#80FFE6"];
    Larynx_cart [label="Laryngeal\nCartilage", shape=folder, fillcolor="#80FFE6"];
    Eye_inv     [label="Ocular Involvement\n(Scleritis/Episcleritis)", shape=folder, fillcolor="#80FFE6"];
    Joint_inv   [label="Arthritis\n(Seronegative)", shape=folder, fillcolor="#80FFE6"];
    Axial_inv   [label="Axial Skeletal\nInvolvement", shape=folder, fillcolor="#80FFE6"];
    Cardiac_inv [label="Cardiac Involvement\n(Aortic regurg/valve)", shape=folder, fillcolor="#40FFCC"];
    Renal_inv   [label="Renal Involvement\n(GN/proteinuria)", shape=folder, fillcolor="#40FFCC"];
    Skin_inv    [label="Skin\n(Neutrophilic dermatosis)", shape=folder, fillcolor="#80FFE6"];
    Vestib_coch [label="Vestibulocochlear\nDamage / SNHL", shape=folder, fillcolor="#80FFE6"];
    CNS_inv     [label="CNS Vasculitis\n/ Meningitis", shape=folder, fillcolor="#40FFCC"];

    Saddle_nose [label="Saddle Nose\nDeformity", shape=octagon, fillcolor="#00AA77", fontcolor="white"];
    Cauliflower_ear [label="Cauliflower Ear\nDeformity", shape=octagon, fillcolor="#00AA77", fontcolor="white"];
    Airway_coll [label="Airway Collapse\nTracheomalacia", shape=octagon, fillcolor="#004400", fontcolor="white"];
    Aortic_aneurysm [label="Aortic Aneurysm\n/ Dissection", shape=octagon, fillcolor="#004400", fontcolor="white"];
  }

  // ============================================================
  // CLUSTER 9: Drug PK/PD
  // ============================================================
  subgraph cluster_drugs {
    label="Drug PK / Pharmacodynamics";
    style=filled; fillcolor="#FFE6E6"; color="#CC0000"; fontsize=11;

    // Corticosteroids
    Prednisone_d  [label="Prednisone\n(Prodrug, oral)", shape=pill, fillcolor="#FF9999"];
    Prednisolone_d [label="Prednisolone\n(Active)", shape=pill, fillcolor="#FF6666"];
    Pred_C1       [label="Pred Central\nCp (mg/L)", fillcolor="#FFB3B3"];
    Pred_C2       [label="Pred Peripheral\nCt", fillcolor="#FFB3B3"];
    GR_free_c     [label="Free GR-α\n(nmol)", fillcolor="#FFB3B3"];
    GR_bound_c    [label="GR-Pred\nComplex", fillcolor="#FF6666"];
    GR_transrep   [label="GR Transrepression\n(NF-κB suppression)", shape=diamond, fillcolor="#FF3333"];
    GR_transact   [label="GR Transactivation\n(GRE genes)", shape=diamond, fillcolor="#FF3333"];

    // Dapsone
    Dapsone_d     [label="Dapsone\n100 mg/d", shape=pill, fillcolor="#FF9999"];
    Dap_C1        [label="Dapsone\nPlasma", fillcolor="#FFB3B3"];
    Dap_effect    [label="MPO/ROS\nInhibition", fillcolor="#FF8080"];

    // Methotrexate
    MTX_d         [label="Methotrexate\n7.5-25 mg/wk", shape=pill, fillcolor="#FF9999"];
    MTX_C1        [label="MTX Plasma\n(nM)", fillcolor="#FFB3B3"];
    MTX_PG        [label="MTX-Polyglutamates\n(intracell)", fillcolor="#FF8080"];
    MTX_DHFR      [label="DHFR/ATIC\nInhibition", shape=diamond, fillcolor="#FF3333"];

    // Tocilizumab (IL-6Ri)
    TCZ_d         [label="Tocilizumab\n8 mg/kg q4w IV", shape=pill, fillcolor="#FF9999"];
    TCZ_C1        [label="TCZ Central\n(mg/L)", fillcolor="#FFB3B3"];
    TCZ_C2        [label="TCZ Peripheral", fillcolor="#FFB3B3"];
    TCZ_effect    [label="IL-6R\nBlockade", shape=diamond, fillcolor="#FF3333"];

    // TNF inhibitors
    TNFi_d        [label="TNF-α Inhibitors\n(Infliximab/ADA)", shape=pill, fillcolor="#FF9999"];
    TNFi_C1       [label="TNF-i Plasma\n(µg/mL)", fillcolor="#FFB3B3"];
    TNFi_effect   [label="TNF-α\nNeutralization", shape=diamond, fillcolor="#FF3333"];

    // Abatacept
    ABA_d         [label="Abatacept\n(CTLA4-Ig) IV/SC", shape=pill, fillcolor="#FF9999"];
    ABA_C1        [label="Abatacept\nPlasma", fillcolor="#FFB3B3"];
    ABA_effect    [label="CD28-B7\nCostimulation Block", shape=diamond, fillcolor="#FF3333"];

    // Colchicine
    Colch_d       [label="Colchicine\n0.5-1 mg/d", shape=pill, fillcolor="#FF9999"];
    Colch_effect  [label="Tubulin / NLRP3\nInhibition", fillcolor="#FF8080"];

    // Cyclosporine
    CsA_d         [label="Cyclosporine A\n(CsA)", shape=pill, fillcolor="#FF9999"];
    CsA_effect    [label="Calcineurin\nInhibition (NFAT↓)", shape=diamond, fillcolor="#FF3333"];

    // NSAIDs
    NSAID_d       [label="NSAIDs\n(Naproxen/Indome)", shape=pill, fillcolor="#FF9999"];
    COX_inh       [label="COX-1/2\nInhibition", shape=diamond, fillcolor="#FF3333"];

    // Azathioprine
    AZA_d         [label="Azathioprine\n(AZA)", shape=pill, fillcolor="#FF9999"];
    AZA_effect    [label="HPRT / Purine\nSynthesis Inhibition", fillcolor="#FF8080"];

    // Rituximab
    RTX_d         [label="Rituximab\n(anti-CD20)", shape=pill, fillcolor="#FF9999"];
    RTX_effect    [label="B Cell\nDepletion", shape=diamond, fillcolor="#FF3333"];
  }

  // ============================================================
  // CLUSTER 10: Clinical Endpoints & Biomarkers
  // ============================================================
  subgraph cluster_endpoints {
    label="Clinical Endpoints & Biomarkers";
    style=filled; fillcolor="#F5F5F5"; color="#333333"; fontsize=11;

    RPDAI       [label="RPDAI\n(Disease Activity Index\n0-265)", shape=doubleoctagon, fillcolor="#BBBBBB"];
    BIRPAI      [label="BI-RPAI\n(Biological Index)", shape=doubleoctagon, fillcolor="#BBBBBB"];

    ESR_ep      [label="ESR (mm/h)", fillcolor="#DDDDDD"];
    CRP_ep      [label="CRP (mg/L)", fillcolor="#DDDDDD"];
    WBC_ep      [label="WBC Count", fillcolor="#DDDDDD"];
    Neut_ep     [label="ANC (×10⁹/L)", fillcolor="#DDDDDD"];
    sCOMP_ep    [label="sCOMP (ng/mL)\n(Serum)", fillcolor="#DDDDDD"];
    CTX2_ep     [label="CTX-II\n(Urine collagen)", fillcolor="#DDDDDD"];
    ACRP_ep     [label="Anti-CII Ab\nTiter (ELISA)", fillcolor="#DDDDDD"];

    Spirometry_ep [label="FEV1/FVC\nSpirometry", fillcolor="#DDDDDD"];
    Broncho_ep  [label="Airway Lumen\nDiameter (CT)", fillcolor="#DDDDDD"];
    CT_cartilage [label="CT / MRI\nCartilage Density", fillcolor="#DDDDDD"];
    PET_FDG     [label="18F-FDG PET\n(Inflammation)", fillcolor="#DDDDDD"];
    Echo_ep     [label="Echo / MRI\nAortic/Valvular", fillcolor="#DDDDDD"];
    Audio_ep    [label="Audiometry\n(SNHL)", fillcolor="#DDDDDD"];
    Biopsy_ep   [label="Biopsy\n(PMN infiltrate)", fillcolor="#DDDDDD"];

    Flare_freq  [label="Flare\nFrequency /yr", shape=doubleoctagon, fillcolor="#999999", fontcolor="white"];
    Remission_ep [label="Clinical\nRemission", shape=doubleoctagon, fillcolor="#666666", fontcolor="white"];
    QoL_ep      [label="QoL\n(SF-36 / HAQ)", shape=doubleoctagon, fillcolor="#BBBBBB"];
    Mortality_ep [label="Mortality Risk\n(Airway/Cardiac)", shape=doubleoctagon, fillcolor="#333333", fontcolor="white"];
  }

  // ============================================================
  // EDGES — Pathophysiology
  // ============================================================

  // --- Triggers → Innate ---
  TypeII_col   -> DC            [label="antigen uptake"];
  TypeII_col   -> Macro         [label="phagocytosis"];
  Matrilin1    -> DC;
  Aggrecan     -> DC;
  Molecular_mimicry -> DC       [style=dashed, label="cross-react"];
  Trauma       -> Autoantigen_rel [label="damage release"];
  Autoantigen_rel -> TypeII_col;
  Autoantigen_rel -> Matrilin1;
  Autoantigen_rel -> DAMP_release;
  DAMP_release -> HMGB1;
  DAMP_release -> IL33_cyt;
  DAMP_release -> S100A8_9;

  // --- Innate signaling ---
  DC      -> TLR2_4;
  Macro   -> TLR2_4;
  Neutrophil -> TLR2_4;
  HMGB1   -> TLR9;
  TLR2_4  -> NF_kB;
  TLR9    -> IRF3;
  TLR9    -> NF_kB;
  Macro   -> NLRP3              [label="crystal/DAMPs"];
  NLRP3   -> IL1b_cyt           [label="caspase-1"];
  NLRP3   -> IL18_cyt;
  NF_kB   -> IL6_cyt;
  NF_kB   -> TNFa_cyt;
  NF_kB   -> IL8_cyt;
  NF_kB   -> MCP1;
  NF_kB   -> MMP3_e;
  Macro   -> ROS_innate;
  Neutrophil -> ROS_innate;
  Neutrophil -> MPO;
  Neutrophil -> NET;
  MPO     -> ROS_innate;
  NET     -> DAMP_release;

  // --- DC → T cell priming ---
  DC      -> MHC_II;
  DC      -> MHC_I;
  DC      -> CD80_86;
  MHC_II  -> TCR_act;
  MHC_I   -> CD8_naive;
  CD80_86 -> CD28_B7;
  TCR_act -> CD4_naive;
  CD28_B7 -> CD4_naive            [label="activation"];

  // --- T cell differentiation ---
  CD4_naive -> Th1                [label="IL-12, IFN-γ"];
  CD4_naive -> Th2                [label="IL-4, IL-5"];
  CD4_naive -> Th17               [label="IL-6, TGFβ, IL-23"];
  CD4_naive -> Treg               [label="TGFβ, IL-2 (low)"];
  CD4_naive -> Tfh                [label="IL-21, CXCR5"];
  CD8_naive -> CD8_CTL            [label="IL-2, IFN-γ"];
  IL12_cyt  -> Th1;
  IL23_cyt  -> Th17               [label="stabilize"];
  TGFb      -> Treg;
  IL21      -> Tfh;

  // --- T cell cytokines ---
  Th1     -> IFNg;
  Th1     -> IL2;
  Th2     -> IL4;
  Th2     -> IL5;
  Th17    -> IL17A;
  Th17    -> IL17F;
  Th17    -> IL22;
  Treg    -> TGFb;
  Treg    -> IL10_T;
  Tfh     -> IL21;
  CD8_CTL -> Perforin;
  Perforin -> Chond_apop          [label="cytotoxic kill"];
  NKT     -> IFNg;
  NKT     -> IL4;

  // --- T→B and antibody ---
  Tfh     -> CD40L_40;
  Th2     -> CD40L_40;
  CD40L_40 -> B_naive -> BCR_act;
  BCR_act -> GC_B -> Plasma_cell;
  GC_B    -> Memory_B;
  GC_B    -> Bregs;
  Plasma_cell -> Anti_CII;
  Plasma_cell -> Anti_Matr1;
  Plasma_cell -> Anti_CIX;
  Plasma_cell -> Anti_COMP;
  Plasma_cell -> ANCA_B;
  Plasma_cell -> RF;
  Anti_CII   -> IC_form;
  Anti_Matr1 -> IC_form;
  IC_form    -> IC_cart;

  // --- Complement cascade ---
  IC_cart -> CP_path;
  IC_form -> CP_path;
  CP_path -> C1q -> C4 -> C3;
  LP_path -> C3;
  AP_path -> C3;
  C3      -> C3_conv;
  C3_conv -> C3a;
  C3_conv -> C3b;
  C3_conv -> C5;
  C3a     -> Mast_cell            [label="activation"];
  C3a     -> Neutrophil           [label="chemotaxis"];
  C5      -> C5a;
  C5a     -> Neutrophil           [label="major chemotaxis"];
  C5a     -> Macro                [label="activation"];
  C5      -> MAC_comp;
  MAC_comp -> Chond_apop          [label="lysis"];
  C3b     -> Macro                [label="opsonization"];

  // --- Cytokine network ---
  IL1b_cyt -> MAPK_path;
  IL1b_cyt -> NF_kB               [label="amplify"];
  TNFa_cyt -> MAPK_path;
  TNFa_cyt -> NF_kB;
  IL6_cyt  -> JAK_STAT3;
  IFNg     -> JAK_STAT1;
  JAK_STAT3 -> IL17A              [label="amplify via Th17"];
  JAK_STAT1 -> CXCL10;
  MAPK_path -> MMP1_e;
  MAPK_path -> MMP3_e;
  MAPK_path -> MMP13_e;
  AP1      -> MMP1_e;
  PI3K_AKT -> ADAMTS4;
  IL17A    -> MMP3_e;
  IL17A    -> MMP9_e;
  IL17A    -> ADAMTS4;
  IL17A    -> IL8_cyt             [label="synergy"];
  IL33_cyt -> Mast_cell;
  IL33_cyt -> Th2;
  HMGB1    -> TLR2_4;
  HMGB1    -> NF_kB;
  S100A8_9 -> TLR2_4;
  TSLP     -> DC;

  // --- Acute phase ---
  IL6_cyt  -> APR;
  IL1b_cyt -> APR;
  TNFa_cyt -> APR;
  APR -> CRP_sys;
  APR -> SAA_sys;
  APR -> Fibrinogen;
  APR -> Ferritin;
  IL6_cyt  -> Fibrinogen          [label="direct"];

  // --- Prostaglandins ---
  NF_kB    -> PGE2_inf            [label="COX-2↑"];
  PGE2_inf -> IL6_cyt             [label="autocrine"];
  Macro    -> LTB4;
  LTB4     -> Neutrophil          [label="recruitment"];

  // --- Cartilage destruction ---
  MMP1_e   -> Collagen_deg;
  MMP13_e  -> Collagen_deg;
  MMP9_e   -> Collagen_deg;
  MMP3_e   -> PG_loss;
  ADAMTS4  -> PG_loss;
  ADAMTS5  -> PG_loss;
  Cathepsin -> PG_loss;
  Cathepsin -> Collagen_deg;
  TIMP1    -> MMP1_e              [label="inhibit", style=dashed, color=blue];
  TIMP1    -> MMP3_e              [label="inhibit", style=dashed, color=blue];
  TIMP1    -> MMP9_e              [label="inhibit", style=dashed, color=blue];
  ROS_innate -> Chond_apop;
  ROS_innate -> Cathepsin         [label="activate"];
  Collagen_deg -> ECM_cart        [label="loss"];
  PG_loss     -> ECM_cart         [label="loss"];
  ECM_cart -> Chondrocyte;
  Chondrocyte -> Chond_apop       [label="cytokine-induced"];
  Chondrocyte -> Chond_prolif     [label="repair attempt"];
  Chond_prolif -> Fibrocart;
  Fibrocart -> Calcif;
  ECM_cart -> Perichond;
  Perichond -> Perichond_fibrosis;

  // --- Organ involvement ---
  TypeII_col -> Ear_chond         [label="primary target"];
  TypeII_col -> Nose_chond        [label="primary target"];
  TypeII_col -> Tracheo           [label="primary target"];
  TypeII_col -> Larynx_cart       [label="primary target"];
  TypeII_col -> Joint_inv         [label="target"];
  Collagen_deg -> Ear_chond;
  Collagen_deg -> Nose_chond;
  Collagen_deg -> Tracheo;
  PG_loss  -> Ear_chond;
  Chond_apop -> Ear_chond;
  Chond_apop -> Nose_chond;
  Chond_apop -> Tracheo;
  Chond_apop -> Larynx_cart;
  Ear_chond  -> Saddle_nose       [style=dashed, color=gray];
  Ear_chond  -> Cauliflower_ear;
  Ear_chond  -> Vestib_coch;
  Nose_chond -> Saddle_nose;
  Tracheo    -> Airway_coll;
  Larynx_cart -> Airway_coll;
  IC_cart    -> Eye_inv;
  Anti_CII   -> Renal_inv         [label="GN"];
  Anti_CII   -> Cardiac_inv       [label="aortic"];
  Cardiac_inv -> Aortic_aneurysm;
  ANCA_B     -> Renal_inv;
  CNS_inv    -> Neutrophil        [label="vasculitis"];

  // --- Clinical endpoints ---
  Ear_chond    -> RPDAI;
  Nose_chond   -> RPDAI;
  Tracheo      -> RPDAI;
  Eye_inv      -> RPDAI;
  Joint_inv    -> RPDAI;
  Cardiac_inv  -> RPDAI;
  Vestib_coch  -> RPDAI;
  CRP_sys      -> CRP_ep;
  Fibrinogen   -> ESR_ep;
  RPDAI        -> Flare_freq;
  CRP_ep       -> BIRPAI;
  ESR_ep       -> BIRPAI;
  WBC_ep       -> BIRPAI;
  Tracheo      -> Spirometry_ep;
  Tracheo      -> Broncho_ep;
  Airway_coll  -> Mortality_ep;
  Aortic_aneurysm -> Mortality_ep;
  Ear_chond    -> CT_cartilage;
  ECM_cart     -> sCOMP_ep;
  Collagen_deg -> CTX2_ep;
  Anti_CII     -> ACRP_ep;
  Cardiac_inv  -> Echo_ep;
  Vestib_coch  -> Audio_ep;
  IC_cart      -> Biopsy_ep;
  RPDAI        -> QoL_ep;
  Flare_freq   -> QoL_ep;
  Ear_chond    -> PET_FDG;
  Nose_chond   -> PET_FDG;

  // ============================================================
  // Drug PK/PD edges
  // ============================================================

  // Prednisolone
  Prednisone_d  -> Prednisolone_d  [label="hepatic conv"];
  Prednisolone_d -> Pred_C1        [label="absorption F=82%"];
  Pred_C1  -> Pred_C2              [label="distribution"];
  Pred_C2  -> Pred_C1              [label="return"];
  Pred_C1  -> GR_free_c            [label="binding kon"];
  GR_free_c -> GR_bound_c          [label="complex formation"];
  GR_bound_c -> GR_transrep        [label="nuclear transloc"];
  GR_bound_c -> GR_transact;
  GR_transrep -> NF_kB             [label="inhibit ↓", style=dashed, color=red];
  GR_transrep -> AP1               [label="inhibit ↓", style=dashed, color=red];
  GR_transrep -> IL1b_cyt          [label="↓", style=dashed, color=red];
  GR_transrep -> IL6_cyt           [label="↓", style=dashed, color=red];
  GR_transrep -> TNFa_cyt          [label="↓", style=dashed, color=red];
  GR_transrep -> IL8_cyt           [label="↓", style=dashed, color=red];
  GR_transact -> TIMP1             [label="↑", style=dashed, color=green];

  // Dapsone
  Dapsone_d -> Dap_C1;
  Dap_C1    -> Dap_effect;
  Dap_effect -> MPO               [label="inhibit ↓", style=dashed, color=red];
  Dap_effect -> ROS_innate        [label="↓", style=dashed, color=red];
  Dap_effect -> NET               [label="↓", style=dashed, color=red];

  // MTX
  MTX_d   -> MTX_C1;
  MTX_C1  -> MTX_PG               [label="polyglutam"];
  MTX_PG  -> MTX_DHFR;
  MTX_DHFR -> Th1                 [label="inhibit ↓", style=dashed, color=red];
  MTX_DHFR -> Th17                [label="inhibit ↓", style=dashed, color=red];
  MTX_DHFR -> Bact                [label="inhibit ↓", style=dashed, color=red];
  MTX_DHFR -> IL1b_cyt            [label="↓ (adenosine)", style=dashed, color=red];

  // Tocilizumab
  TCZ_d   -> TCZ_C1;
  TCZ_C1  -> TCZ_C2               [label="distrib"];
  TCZ_C2  -> TCZ_C1;
  TCZ_C1  -> TCZ_effect;
  TCZ_effect -> IL6_cyt           [label="IL-6R block ↓", style=dashed, color=red];
  TCZ_effect -> JAK_STAT3         [label="↓", style=dashed, color=red];
  TCZ_effect -> APR               [label="CRP↓", style=dashed, color=red];

  // TNF inhibitors
  TNFi_d  -> TNFi_C1;
  TNFi_C1 -> TNFi_effect;
  TNFi_effect -> TNFa_cyt         [label="neutralize ↓", style=dashed, color=red];
  TNFi_effect -> NF_kB            [label="↓", style=dashed, color=red];

  // Abatacept
  ABA_d   -> ABA_C1;
  ABA_C1  -> ABA_effect;
  ABA_effect -> CD28_B7           [label="block ↓", style=dashed, color=red];
  ABA_effect -> CTLA4_ck          [label="mimic", style=dashed, color=green];
  ABA_effect -> Th1               [label="suppress ↓", style=dashed, color=red];
  ABA_effect -> Th17              [label="↓", style=dashed, color=red];

  // Colchicine
  Colch_d -> Colch_effect;
  Colch_effect -> Neutrophil      [label="migration ↓", style=dashed, color=red];
  Colch_effect -> NLRP3           [label="↓", style=dashed, color=red];

  // Cyclosporine
  CsA_d   -> CsA_effect;
  CsA_effect -> Th1               [label="NFAT block ↓", style=dashed, color=red];
  CsA_effect -> Th17              [label="↓", style=dashed, color=red];
  CsA_effect -> IL2               [label="↓", style=dashed, color=red];

  // NSAIDs
  NSAID_d -> COX_inh;
  COX_inh -> PGE2_inf             [label="↓", style=dashed, color=red];
  COX_inh -> LTB4                 [label="COX path block"];

  // Azathioprine
  AZA_d   -> AZA_effect;
  AZA_effect -> Th1               [label="suppress ↓", style=dashed, color=red];
  AZA_effect -> B_naive           [label="↓", style=dashed, color=red];
  AZA_effect -> GC_B              [label="↓", style=dashed, color=red];

  // Rituximab
  RTX_d   -> RTX_effect;
  RTX_effect -> B_naive           [label="deplete ↓", style=dashed, color=red];
  RTX_effect -> GC_B              [label="↓", style=dashed, color=red];
  RTX_effect -> Plasma_cell       [label="↓", style=dashed, color=red];

  // ============================================================
  // Feedback loops (inhibitory)
  // ============================================================
  IL10_T  -> Macro                [label="inhibit", style=dashed, color=blue];
  IL10_T  -> NF_kB                [label="↓", style=dashed, color=blue];
  IL10_T  -> TNFa_cyt             [label="↓", style=dashed, color=blue];
  Treg    -> Th17                 [label="suppress", style=dashed, color=blue];
  Treg    -> Th1                  [label="suppress", style=dashed, color=blue];
  Treg    -> Bact                 [label="suppress", style=dashed, color=blue];
  CTLA4_ck -> TCR_act             [label="inhibit", style=dashed, color=blue];
  PD1_ck  -> CD8_CTL              [label="exhaustion", style=dashed, color=blue];
  Bregs   -> Th1                  [label="IL-10 ↓", style=dashed, color=blue];
  TIMP1   -> ADAMTS4              [label="inhibit", style=dashed, color=blue];
}
