digraph GoutQSP {
    graph [
        label="Gout: Quantitative Systems Pharmacology Model\nPurine Metabolism · Urate Transport · NLRP3 Inflammasome · Drug PK/PD · Clinical Endpoints"
        fontsize=28 fontname="Helvetica-Bold"
        rankdir=LR
        bgcolor="#F8F9FA"
        splines=ortho
        nodesep=0.4
        ranksep=1.2
        compound=true
    ]
    node [fontname="Helvetica" fontsize=10 style="filled,rounded" shape=box]
    edge [fontname="Helvetica" fontsize=8]

    // =====================================================================
    // CLUSTER 1: Purine Metabolism & Uric Acid Production
    // =====================================================================
    subgraph cluster_purine {
        label="Purine Metabolism & Urate Production"
        style="filled,rounded" fillcolor="#E8F5E9" color="#2E7D32" penwidth=2
        fontsize=14 fontcolor="#1B5E20"

        // Dietary input
        DietPurine [label="Dietary Purines\n(exogenous)" fillcolor="#A5D6A7" shape=cylinder]
        FructoseInput [label="Dietary Fructose\n(ATP depletion)" fillcolor="#A5D6A7" shape=cylinder]

        // Endogenous synthesis
        PRPP [label="PRPP\n(5-phosphoribosyl-\n1-pyrophosphate)" fillcolor="#C8E6C9"]
        DeNovoPurine [label="De Novo Purine\nSynthesis" fillcolor="#C8E6C9"]
        PRPP_synth [label="PRPP Synthetase\n(overactivity→gout)" fillcolor="#81C784" shape=ellipse]

        // Salvage pathway
        AMP [label="AMP\n(adenosine\nmonophosphate)" fillcolor="#C8E6C9"]
        GMP [label="GMP\n(guanosine\nmonophosphate)" fillcolor="#C8E6C9"]
        IMP [label="IMP\n(inosine\nmonophosphate)" fillcolor="#C8E6C9"]
        Adenosine [label="Adenosine" fillcolor="#C8E6C9"]
        Inosine [label="Inosine" fillcolor="#C8E6C9"]
        Guanosine [label="Guanosine" fillcolor="#C8E6C9"]
        Hypoxanthine [label="Hypoxanthine" fillcolor="#A5D6A7"]
        Xanthine [label="Xanthine" fillcolor="#A5D6A7"]
        UricAcid_prod [label="Uric Acid\n(production)" fillcolor="#4CAF50" fontcolor="white"]
        Guanine [label="Guanine" fillcolor="#C8E6C9"]

        // Enzymes
        HPRT [label="HPRT\n(salvage; deficiency→\nLesch-Nyhan)" fillcolor="#66BB6A" shape=ellipse]
        ADA [label="ADA\n(adenosine\ndeaminase)" fillcolor="#66BB6A" shape=ellipse]
        PNP [label="PNP\n(purine nucleoside\nphosphorylase)" fillcolor="#66BB6A" shape=ellipse]
        XO_enz [label="Xanthine Oxidase\n(XO/XDH)" fillcolor="#388E3C" shape=ellipse fontcolor="white"]
        AMP_deam [label="AMP Deaminase" fillcolor="#66BB6A" shape=ellipse]
    }

    // =====================================================================
    // CLUSTER 2: Pharmacokinetics — XO Inhibitors
    // =====================================================================
    subgraph cluster_pk_xoi {
        label="PK: Xanthine Oxidase Inhibitors"
        style="filled,rounded" fillcolor="#E3F2FD" color="#1565C0" penwidth=2
        fontsize=14 fontcolor="#0D47A1"

        Allo_dose [label="Allopurinol\nDose (oral)" fillcolor="#90CAF9" shape=cylinder]
        Allo_gut [label="Allopurinol\nGut (absorption)" fillcolor="#BBDEFB"]
        Allo_cent [label="Allopurinol\nCentral (plasma)" fillcolor="#BBDEFB"]
        Oxy_cent [label="Oxypurinol\n(active metabolite)\nCentral" fillcolor="#64B5F6"]
        Oxy_peri [label="Oxypurinol\nPeripheral" fillcolor="#64B5F6"]
        Oxy_renal [label="Oxypurinol\nRenal Clearance" fillcolor="#BBDEFB" shape=diamond]

        Febu_dose [label="Febuxostat\nDose (oral)" fillcolor="#90CAF9" shape=cylinder]
        Febu_gut [label="Febuxostat\nGut (absorption)" fillcolor="#BBDEFB"]
        Febu_cent [label="Febuxostat\nCentral (plasma)" fillcolor="#BBDEFB"]
        Febu_peri [label="Febuxostat\nPeripheral" fillcolor="#64B5F6"]
        Febu_met [label="Febuxostat\nMetabolism (CYP)" fillcolor="#BBDEFB" shape=diamond]
    }

    // =====================================================================
    // CLUSTER 3: Pharmacokinetics — Uricosurics
    // =====================================================================
    subgraph cluster_pk_urico {
        label="PK: Uricosuric Agents"
        style="filled,rounded" fillcolor="#FFF3E0" color="#E65100" penwidth=2
        fontsize=14 fontcolor="#BF360C"

        Probenecid_dose [label="Probenecid\nDose (oral)" fillcolor="#FFCC80" shape=cylinder]
        Probenecid_cent [label="Probenecid\nCentral (plasma)" fillcolor="#FFE0B2"]
        Probenecid_peri [label="Probenecid\nPeripheral" fillcolor="#FFE0B2"]

        Lesinurad_dose [label="Lesinurad\nDose (oral)" fillcolor="#FFCC80" shape=cylinder]
        Lesinurad_cent [label="Lesinurad\nCentral (plasma)" fillcolor="#FFE0B2"]
        Lesinurad_met [label="Lesinurad\nMetabolism (CYP2C9)" fillcolor="#FFE0B2" shape=diamond]
    }

    // =====================================================================
    // CLUSTER 4: Renal Urate Transport
    // =====================================================================
    subgraph cluster_renal {
        label="Renal Urate Transport & Excretion"
        style="filled,rounded" fillcolor="#FCE4EC" color="#880E4F" penwidth=2
        fontsize=14 fontcolor="#560027"

        GFR_node [label="Glomerular\nFiltration\n(GFR)" fillcolor="#F48FB1" shape=ellipse]
        Prox_tubule [label="Proximal Tubule\nLumen" fillcolor="#F8BBD9"]
        URAT1 [label="URAT1\n(SLC22A12)\nReabsorption" fillcolor="#E91E8C" shape=ellipse fontcolor="white"]
        OAT1 [label="OAT1\n(SLC22A6)\nSecretion" fillcolor="#E91E8C" shape=ellipse fontcolor="white"]
        OAT3 [label="OAT3\n(SLC22A8)\nSecretion" fillcolor="#E91E8C" shape=ellipse fontcolor="white"]
        OAT4 [label="OAT4\n(SLC22A11)\nReabsorption" fillcolor="#E91E8C" shape=ellipse fontcolor="white"]
        ABCG2_renal [label="ABCG2\n(BCRP)\nSecretion (renal)" fillcolor="#E91E8C" shape=ellipse fontcolor="white"]
        MRP4 [label="MRP4\n(ABCC4)\nSecretion" fillcolor="#E91E8C" shape=ellipse fontcolor="white"]
        UA_urine [label="Urine Urate\n(Excretion)" fillcolor="#F48FB1" shape=diamond]
        FEurate [label="Fractional\nExcretion\nof Urate (FEurate)" fillcolor="#FCE4EC"]
    }

    // =====================================================================
    // CLUSTER 5: Systemic Urate Distribution
    // =====================================================================
    subgraph cluster_sUA {
        label="Systemic Urate Compartments"
        style="filled,rounded" fillcolor="#F3E5F5" color="#4A148C" penwidth=2
        fontsize=14 fontcolor="#311B92"

        sUA [label="Serum Urate\n(sUA, mg/dL)\n[TARGET: <6.0]" fillcolor="#CE93D8" fontcolor="white"]
        UA_peri [label="Peripheral Tissue\nUrate Pool" fillcolor="#E1BEE7"]
        UA_synovial [label="Synovial Fluid\nUrate" fillcolor="#E1BEE7"]
        Tophi_pool [label="Tophus Urate\nPool (crystal)" fillcolor="#AB47BC" fontcolor="white"]
        Crystal_form [label="MSU Crystal\nFormation Rate" fillcolor="#9C27B0" shape=hexagon fontcolor="white"]
        Gut_excretion [label="Intestinal Urate\nSecretion (ABCG2)" fillcolor="#E1BEE7"]
        ABCG2_gut [label="ABCG2\n(Gut Secretion)" fillcolor="#AB47BC" shape=ellipse fontcolor="white"]
    }

    // =====================================================================
    // CLUSTER 6: Crystal-Induced Inflammation & NLRP3
    // =====================================================================
    subgraph cluster_inflammasome {
        label="MSU Crystal Inflammation & NLRP3 Inflammasome"
        style="filled,rounded" fillcolor="#FFF8E1" color="#F57F17" penwidth=2
        fontsize=14 fontcolor="#E65100"

        MSU_phagocyte [label="MSU Crystal\nPhagocytosis\n(Macrophage/Neutrophil)" fillcolor="#FFD54F"]
        ROS_prod [label="ROS Production\n(NADPH oxidase)" fillcolor="#FFB300"]
        Mitochondria_damage [label="Mitochondrial\nDamage / mtROS" fillcolor="#FF8F00"]
        Lysosome_rupture [label="Lysosomal\nRupture\n(Cathepsin B)" fillcolor="#FF6F00"]
        NLRP3_inactive [label="NLRP3\nInactive" fillcolor="#FFF176"]
        NLRP3_active [label="NLRP3\nActivated\n(Inflammasome)" fillcolor="#FF8F00" shape=hexagon]
        Signal1 [label="Signal 1\n(NF-κB priming)\nTLR2/TLR4" fillcolor="#FFF9C4"]
        Signal2 [label="Signal 2\n(crystal danger\nsignal)" fillcolor="#FFF9C4"]
        ProCasp1 [label="Pro-Caspase-1" fillcolor="#FFE082"]
        Casp1 [label="Caspase-1\n(active)" fillcolor="#FF8F00" shape=ellipse]
        ProIL1b [label="Pro-IL-1β" fillcolor="#FFE082"]
        IL1b [label="IL-1β\n(mature)" fillcolor="#FF6D00" shape=diamond fontcolor="white"]
        ProIL18 [label="Pro-IL-18" fillcolor="#FFE082"]
        IL18 [label="IL-18\n(mature)" fillcolor="#FF6D00" shape=diamond fontcolor="white"]
        Gasdermin [label="Gasdermin D\n(pyroptosis pore)" fillcolor="#FF8F00"]
        Pyroptosis [label="Pyroptosis\n(inflammatory\ncell death)" fillcolor="#E65100" fontcolor="white"]
    }

    // =====================================================================
    // CLUSTER 7: Inflammatory Cytokines & Mediators
    // =====================================================================
    subgraph cluster_cytokines {
        label="Inflammatory Mediators"
        style="filled,rounded" fillcolor="#FFEBEE" color="#B71C1C" penwidth=2
        fontsize=14 fontcolor="#7F0000"

        IL6 [label="IL-6" fillcolor="#EF9A9A"]
        TNFa [label="TNF-α" fillcolor="#EF9A9A"]
        IL8 [label="IL-8\n(CXCL8)" fillcolor="#EF9A9A"]
        IL17 [label="IL-17" fillcolor="#EF9A9A"]
        CXCL1 [label="CXCL1\n(KC/GRO-α)" fillcolor="#EF9A9A"]
        PGE2 [label="PGE₂\n(Prostaglandin E₂)" fillcolor="#FFCDD2"]
        LTB4 [label="LTB₄\n(Leukotriene B₄)" fillcolor="#FFCDD2"]
        Bradykinin [label="Bradykinin" fillcolor="#FFCDD2"]
        Complement [label="Complement\nActivation (C3a, C5a)" fillcolor="#FFCDD2"]
        MCP1 [label="MCP-1\n(CCL2)" fillcolor="#EF9A9A"]
        COX1 [label="COX-1\n(constitutive)" fillcolor="#EF5350" shape=ellipse fontcolor="white"]
        COX2 [label="COX-2\n(inducible)" fillcolor="#EF5350" shape=ellipse fontcolor="white"]
        AA [label="Arachidonic Acid\n(AA)" fillcolor="#FFCDD2"]
        NFkB [label="NF-κB\nActivation" fillcolor="#E53935" shape=hexagon fontcolor="white"]
        MAPK [label="MAPK\nPathway" fillcolor="#E53935" shape=hexagon fontcolor="white"]
    }

    // =====================================================================
    // CLUSTER 8: Cellular Response
    // =====================================================================
    subgraph cluster_cells {
        label="Cellular Inflammatory Response"
        style="filled,rounded" fillcolor="#E0F2F1" color="#004D40" penwidth=2
        fontsize=14 fontcolor="#00251A"

        Macrophage_M0 [label="Resting\nMacrophage (M0)" fillcolor="#80CBC4"]
        Macrophage_M1 [label="Activated\nMacrophage (M1)\nPro-inflammatory" fillcolor="#26A69A"]
        Neutrophil_circ [label="Circulating\nNeutrophils" fillcolor="#80CBC4"]
        Neutrophil_tiss [label="Tissue\nNeutrophils\n(joint)" fillcolor="#26A69A"]
        NET [label="NETs\n(Neutrophil\nExtracellular Traps)" fillcolor="#00897B" fontcolor="white"]
        Mast_cell [label="Mast Cell\nDegranulation" fillcolor="#80CBC4"]
        DendriticCell [label="Dendritic\nCell Activation" fillcolor="#80CBC4"]
        Tcell [label="T Cell\nActivation" fillcolor="#80CBC4"]
        Synoviocyte [label="Synoviocyte\nActivation (FLS)" fillcolor="#4DB6AC"]
        Chondrocyte [label="Chondrocyte\nDamage" fillcolor="#4DB6AC"]
        Urate_MSU [label="MSU Crystals\nin Joint Space" fillcolor="#00695C" fontcolor="white" shape=hexagon]
    }

    // =====================================================================
    // CLUSTER 9: PK — Anti-Inflammatory Drugs (Acute Gout)
    // =====================================================================
    subgraph cluster_pk_antiinf {
        label="PK: Anti-Inflammatory Agents (Acute Gout)"
        style="filled,rounded" fillcolor="#EDE7F6" color="#4527A0" penwidth=2
        fontsize=14 fontcolor="#311B92"

        Colch_dose [label="Colchicine\nDose (oral)" fillcolor="#CE93D8" shape=cylinder]
        Colch_cent [label="Colchicine\nCentral (plasma)" fillcolor="#E1BEE7"]
        Colch_peri [label="Colchicine\nPeripheral (tissue)" fillcolor="#E1BEE7"]
        Colch_met [label="Colchicine\nCYP3A4 Metabolism" fillcolor="#E1BEE7" shape=diamond]

        NSAID_dose [label="NSAID\n(Indomethacin)\nDose" fillcolor="#CE93D8" shape=cylinder]
        NSAID_cent [label="NSAID\nCentral (plasma)" fillcolor="#E1BEE7"]
        NSAID_tiss [label="NSAID\nTissue/Synovial" fillcolor="#E1BEE7"]
        NSAID_met [label="NSAID\nMetabolism" fillcolor="#E1BEE7" shape=diamond]

        GC_dose [label="Glucocorticoid\n(Prednisolone)\nDose" fillcolor="#CE93D8" shape=cylinder]
        GC_cent [label="Glucocorticoid\nCentral (plasma)" fillcolor="#E1BEE7"]
        GC_receptor [label="GR\n(Glucocorticoid\nReceptor complex)" fillcolor="#9575CD" shape=ellipse]
    }

    // =====================================================================
    // CLUSTER 10: PK — Biologic IL-1 Inhibitors
    // =====================================================================
    subgraph cluster_pk_biologic {
        label="PK: IL-1 Inhibitors (Biologics)"
        style="filled,rounded" fillcolor="#E8EAF6" color="#283593" penwidth=2
        fontsize=14 fontcolor="#1A237E"

        Ana_dose [label="Anakinra\n(IL-1Ra)\nDose (SC)" fillcolor="#9FA8DA" shape=cylinder]
        Ana_cent [label="Anakinra\nCentral (plasma)" fillcolor="#C5CAE9"]
        Ana_peri [label="Anakinra\nTissue/Synovial" fillcolor="#C5CAE9"]
        Ana_elim [label="Anakinra\nRenal Elimination" fillcolor="#C5CAE9" shape=diamond]

        Cana_dose [label="Canakinumab\n(anti-IL-1β IgG1)\nDose (SC)" fillcolor="#9FA8DA" shape=cylinder]
        Cana_cent [label="Canakinumab\nCentral (plasma)" fillcolor="#C5CAE9"]
        Cana_peri [label="Canakinumab\nPeripheral" fillcolor="#C5CAE9"]
        Cana_met [label="Canakinumab\nCatabolism" fillcolor="#C5CAE9" shape=diamond]
        IL1b_Cana_complex [label="IL-1β:Canakinumab\nComplex" fillcolor="#7986CB"]
    }

    // =====================================================================
    // CLUSTER 11: Clinical Endpoints & Disease Outcomes
    // =====================================================================
    subgraph cluster_endpoints {
        label="Clinical Endpoints & Disease Outcomes"
        style="filled,rounded" fillcolor="#ECEFF1" color="#37474F" penwidth=2
        fontsize=14 fontcolor="#263238"

        sUA_target [label="Serum Urate\nTarget < 6 mg/dL\n(or < 5 for tophaceous)" fillcolor="#B0BEC5" shape=diamond]
        Flare_risk [label="Gout Flare\nRisk (annual)" fillcolor="#CFD8DC"]
        Flare_severity [label="Flare Severity\n(NRS pain 0-10)" fillcolor="#CFD8DC"]
        Flare_duration [label="Flare Duration\n(days)" fillcolor="#CFD8DC"]
        Tophus_volume [label="Tophus\nVolume (cm³)\nregression rate" fillcolor="#90A4AE"]
        JointDamage [label="Cumulative\nJoint Damage" fillcolor="#90A4AE"]
        Renal_function [label="Renal Function\n(eGFR, CKD stage)" fillcolor="#78909C"]
        CV_risk [label="Cardiovascular\nRisk (MACE)" fillcolor="#78909C"]
        QoL [label="Quality of Life\n(SF-36, HAQ)" fillcolor="#90A4AE"]
        DAPSA [label="Disease Activity\nPAS-gout score" fillcolor="#B0BEC5"]
        CRP_ESR [label="CRP / ESR\n(inflammatory markers)" fillcolor="#CFD8DC"]
        WBC_count [label="WBC / Neutrophil\nCount (joint)" fillcolor="#CFD8DC"]
    }

    // =====================================================================
    // CLUSTER 12: Comorbidities & Metabolic Syndrome
    // =====================================================================
    subgraph cluster_comorbid {
        label="Comorbidities & Metabolic Risk"
        style="filled,rounded" fillcolor="#F9FBE7" color="#558B2F" penwidth=2
        fontsize=14 fontcolor="#33691E"

        Hypertension [label="Hypertension\n(RAAS interaction)" fillcolor="#DCE775"]
        CKD_comorbid [label="CKD\n(reduced UA excretion)" fillcolor="#DCE775"]
        MetSyn [label="Metabolic Syndrome\n(Insulin resistance)" fillcolor="#DCE775"]
        Obesity [label="Obesity\n(↑ UA production)" fillcolor="#DCE775"]
        Dyslipidemia [label="Dyslipidemia" fillcolor="#DCE775"]
        LeadExposure [label="Lead Exposure\n(saturine gout)" fillcolor="#DCE775"]
        Diuretics [label="Diuretic Use\n(thiazide/loop)" fillcolor="#DCEDC8"]
        Cyclosporin [label="Cyclosporine\n(↓ UA excretion)" fillcolor="#DCEDC8"]
        Alcohol [label="Alcohol\n(↑ UA production\n+ ↓ excretion)" fillcolor="#DCEDC8"]
        HighPurineFood [label="High-Purine Diet\n(meat, seafood,\nfructose drinks)" fillcolor="#DCEDC8"]
        Insulin_resist [label="Insulin Resistance\n(↓ URAT1 function)" fillcolor="#DCE775"]
        Urate_genetic [label="Genetic Factors\n(SLC22A12, ABCG2\nSLC2A9 polymorphisms)" fillcolor="#AED581"]
    }

    // =====================================================================
    // CLUSTER 13: Genetic & Epigenetic Factors
    // =====================================================================
    subgraph cluster_genetic {
        label="Genetic & Regulatory Factors"
        style="filled,rounded" fillcolor="#FFF9C4" color="#F57F17" penwidth=2
        fontsize=14 fontcolor="#E65100"

        SLC22A12_SNP [label="SLC22A12 SNPs\n(URAT1 variants)" fillcolor="#FFF176"]
        SLC2A9_SNP [label="SLC2A9 SNPs\n(GLUT9/urate\ntransporter)" fillcolor="#FFF176"]
        ABCG2_SNP [label="ABCG2 SNPs\n(Q141K: ↓ gut\nsecretion →↑sUA)" fillcolor="#FFF176"]
        HPRT_mut [label="HPRT Mutation\n(Lesch-Nyhan\nsyndrome)" fillcolor="#FFF176"]
        PRPS1_mut [label="PRPS1 Mutation\n(↑ purine synthesis)" fillcolor="#FFF176"]
        HLA_assoc [label="HLA-B*58:01\n(allopurinol\nhypersensitivity)" fillcolor="#FFF176"]
        Epigenetics [label="Epigenetic\nRegulation\n(miRNA, methylation)" fillcolor="#FFF9C4"]
    }

    // =====================================================================
    // EDGES — Purine Metabolism
    // =====================================================================
    DietPurine -> Hypoxanthine [label="absorption" color="#2E7D32"]
    DietPurine -> Guanine [label="absorption" color="#2E7D32"]
    FructoseInput -> AMP [label="ATP→AMP\n(rapid)" color="#2E7D32"]
    PRPP -> DeNovoPurine [label="de novo\nsynthesis" color="#2E7D32"]
    PRPP_synth -> PRPP [label="catalyzes" color="#2E7D32"]
    DeNovoPurine -> IMP [color="#2E7D32"]
    IMP -> AMP [color="#2E7D32"]
    IMP -> GMP [color="#2E7D32"]
    AMP -> AMP_deam [label="AMP deaminase" color="#2E7D32"]
    AMP_deam -> IMP [color="#2E7D32"]
    AMP -> Adenosine [color="#2E7D32"]
    Adenosine -> ADA [label="ADA catalyzes" color="#2E7D32"]
    ADA -> Inosine [color="#2E7D32"]
    GMP -> Guanosine [color="#2E7D32"]
    Guanosine -> PNP [label="PNP catalyzes" color="#2E7D32"]
    PNP -> Guanine [color="#2E7D32"]
    Guanine -> HPRT [color="#2E7D32"]
    HPRT -> IMP [label="salvage" color="#388E3C" style=dashed]
    Inosine -> PNP [color="#2E7D32"]
    PNP -> Hypoxanthine [color="#2E7D32"]
    Hypoxanthine -> XO_enz [label="XO\ncatalysis" color="#1B5E20"]
    XO_enz -> Xanthine [color="#1B5E20"]
    Xanthine -> XO_enz [label="XO\ncatalysis" color="#1B5E20"]
    XO_enz -> UricAcid_prod [color="#1B5E20"]

    // =====================================================================
    // EDGES — Drug PK (XO Inhibitors)
    // =====================================================================
    Allo_dose -> Allo_gut [label="ka=0.9 h⁻¹\nF=0.80" color="#1565C0"]
    Allo_gut -> Allo_cent [label="CL/F=9 L/h" color="#1565C0"]
    Allo_cent -> Oxy_cent [label="XO-mediated\noxidation" color="#1565C0"]
    Oxy_cent -> Oxy_peri [label="ktp=0.5 h⁻¹" color="#1565C0"]
    Oxy_peri -> Oxy_cent [label="kpt=0.2 h⁻¹" color="#1565C0"]
    Oxy_cent -> Oxy_renal [label="CLr=0.5 L/h" color="#1565C0"]

    Febu_dose -> Febu_gut [label="ka=1.2 h⁻¹\nF=0.49" color="#1565C0"]
    Febu_gut -> Febu_cent [label="CL/F=4 L/h" color="#1565C0"]
    Febu_cent -> Febu_peri [label="ktp=0.3 h⁻¹" color="#1565C0"]
    Febu_peri -> Febu_cent [label="kpt=0.15 h⁻¹" color="#1565C0"]
    Febu_cent -> Febu_met [label="CYP2C8/\nUGT" color="#1565C0"]

    // =====================================================================
    // EDGES — Drug PK (Uricosurics)
    // =====================================================================
    Probenecid_dose -> Probenecid_cent [label="ka=1.5 h⁻¹\nF=1.0" color="#E65100"]
    Probenecid_cent -> Probenecid_peri [label="ktp=0.4 h⁻¹" color="#E65100"]
    Probenecid_peri -> Probenecid_cent [label="kpt=0.2 h⁻¹" color="#E65100"]

    Lesinurad_dose -> Lesinurad_cent [label="ka=2.1 h⁻¹\nF=0.95" color="#E65100"]
    Lesinurad_cent -> Lesinurad_met [label="CYP2C9\nmetabolism" color="#E65100"]

    // =====================================================================
    // EDGES — Drug PD (XO inhibition → urate lowering)
    // =====================================================================
    Oxy_cent -> XO_enz [label="competitive\ninhibition (Ki=0.5µM)" color="#0D47A1" style=dashed arrowhead=tee]
    Febu_cent -> XO_enz [label="non-purine\ninhibition (Ki=1nM)" color="#0D47A1" style=dashed arrowhead=tee]

    // EDGES — Drug PD (Uricosurics → URAT1 inhibition)
    Probenecid_cent -> URAT1 [label="URAT1\ninhibition" color="#BF360C" style=dashed arrowhead=tee]
    Lesinurad_cent -> URAT1 [label="URAT1/OAT4\ninhibition" color="#BF360C" style=dashed arrowhead=tee]
    Lesinurad_cent -> OAT4 [label="OAT4\ninhibition" color="#BF360C" style=dashed arrowhead=tee]

    // =====================================================================
    // EDGES — Urate Systemic Distribution
    // =====================================================================
    UricAcid_prod -> sUA [label="absorption to\nplasma" color="#7B1FA2"]
    sUA -> UA_peri [label="tissue\ndistribution" color="#7B1FA2"]
    UA_peri -> sUA [label="return" color="#7B1FA2"]
    sUA -> UA_synovial [label="joint\npenetration" color="#7B1FA2"]
    UA_synovial -> Crystal_form [label="supersaturation\n>6.8 mg/dL" color="#6A1B9A"]
    Crystal_form -> Tophi_pool [label="crystal\ndeposition" color="#6A1B9A"]
    Tophi_pool -> sUA [label="crystal\ndissolution" color="#6A1B9A" style=dashed]
    sUA -> Gut_excretion [color="#7B1FA2"]
    ABCG2_gut -> Gut_excretion [label="active\nsecretion" color="#7B1FA2"]

    // =====================================================================
    // EDGES — Renal Urate Handling
    // =====================================================================
    sUA -> GFR_node [label="filtration\n(free fraction)" color="#880E4F"]
    GFR_node -> Prox_tubule [color="#880E4F"]
    Prox_tubule -> URAT1 [label="reabsorbs UA" color="#880E4F"]
    URAT1 -> sUA [label="reabsorption\n~90%" color="#880E4F"]
    Prox_tubule -> OAT1 [color="#880E4F"]
    Prox_tubule -> OAT3 [color="#880E4F"]
    OAT1 -> UA_urine [label="secretion" color="#880E4F"]
    OAT3 -> UA_urine [label="secretion" color="#880E4F"]
    ABCG2_renal -> UA_urine [label="secretion" color="#880E4F"]
    MRP4 -> UA_urine [label="secretion" color="#880E4F"]
