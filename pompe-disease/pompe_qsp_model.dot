digraph POMPE_QSP {
  graph [layout=dot, rankdir=LR, splines=polyline, nodesep=0.32, ranksep=0.55, overlap=false,
         fontname="Helvetica", fontsize=11, labelloc=t,
         label="Pompe Disease (GSDII) — Quantitative Systems Pharmacology Map\nGAA deficiency → lysosomal glycogen accumulation → autophagic block → cardiomyopathy/myopathy/respiratory failure\nERT (alglucosidase·avalglucosidase·cipaglucosidase+miglustat) · ADA · M6PR uptake · gene therapy"];
  node  [shape=box, style="rounded,filled", fontname="Helvetica", fontsize=10, color="#444444", penwidth=1];
  edge  [color="#666666", fontsize=9, arrowsize=0.7];

  /* ===================== 1. GENETICS & BIOSYNTHESIS ===================== */
  subgraph cluster_genetics {
    label="1. GAA gene & enzyme biosynthesis";
    style="rounded,filled"; fillcolor="#f4f0ff"; color="#7a5cc6";
    GAA_gene       [label="GAA gene\n17q25.3 / 20 exons", fillcolor="#e6dcff"];
    IVS1_var       [label="c.-32-13T>G\n(LOPD common, 50–70%)", fillcolor="#e6dcff"];
    Null_var       [label="c.525delT, c.del exon18\n(severe / CRIM-)", fillcolor="#e6dcff"];
    Missense_var   [label="Missense / splice\n(intermediate)", fillcolor="#e6dcff"];
    CRIM_status    [label="CRIM status\n(positive vs negative)", fillcolor="#e6dcff"];
    Pseudo_def     [label="Pseudo-deficiency\nc.[1726G>A;2065G>A] (Asian)", fillcolor="#e6dcff"];
    NBS_DBS        [label="Newborn screening\n(DBS GAA activity)", fillcolor="#e6dcff"];
    Tx_mRNA        [label="GAA mRNA\ntranscription", fillcolor="#e6dcff"];
    proGAA_110kDa  [label="proGAA 110 kDa\n(ER)", fillcolor="#e6dcff"];
    M6P_tag        [label="M6P / GlcNAc-1-P\ntagging (GNPTAB)", fillcolor="#e6dcff"];
    Golgi_proc     [label="Golgi processing\n→ 76/70 kDa mature", fillcolor="#e6dcff"];
    Lyso_targeting [label="CI-MPR / sortilin\nlysosomal targeting", fillcolor="#e6dcff"];
  }

  /* ===================== 2. LYSOSOMAL ENZYMOLOGY ===================== */
  subgraph cluster_lyso {
    label="2. Lysosomal acid α-glucosidase activity";
    style="rounded,filled"; fillcolor="#eef7ff"; color="#3a78c2";
    Acid_pH        [label="Lysosomal pH 4.5\n(v-ATPase)", fillcolor="#cfe4ff"];
    GAA_active     [label="Mature acid α-glucosidase\n(76 / 70 kDa active)", fillcolor="#cfe4ff"];
    GAA_activity   [label="GAA enzyme activity\n(nmol·h⁻¹·mg⁻¹)", fillcolor="#cfe4ff"];
    Glycogen_lyso  [label="Lysosomal glycogen\n(α-1,4 & α-1,6 chains)", fillcolor="#cfe4ff"];
    Glc_out        [label="Free glucose\nlysosomal exit (SLC2A8)", fillcolor="#cfe4ff"];
    Autophagosome  [label="Autophagosome (LC3-II)", fillcolor="#cfe4ff"];
    Lysosome_size  [label="Enlarged lysosome\n(LAMP1+ vacuoles)", fillcolor="#cfe4ff"];
    Lipofuscin     [label="Lipofuscin / Saposin\naccumulation", fillcolor="#cfe4ff"];
    TFEB_pathway   [label="TFEB nuclear translocation\n(lysosomal biogenesis)", fillcolor="#cfe4ff"];
    GCase_secondary[label="Secondary lysosomal\ndysfunction", fillcolor="#cfe4ff"];
  }

  /* ===================== 3. SKELETAL MUSCLE PATHOLOGY ===================== */
  subgraph cluster_muscle {
    label="3. Skeletal muscle pathology";
    style="rounded,filled"; fillcolor="#eaf6ee"; color="#3aa05e";
    Cyto_glycogen  [label="Cytoplasmic glycogen\n(Lange-rosettes)", fillcolor="#cfeacf"];
    Auto_buildup   [label="Autophagic buildup\n(LC3 / p62 accumulation)", fillcolor="#cfeacf"];
    Lyso_rupture   [label="Lysosomal rupture\n(membrane permeabilization)", fillcolor="#cfeacf"];
    Sarcomere_disr [label="Sarcomere disruption\nZ-line streaming", fillcolor="#cfeacf"];
    Fiber_typeII   [label="Type II fiber loss\n(fast-twitch atrophy)", fillcolor="#cfeacf"];
    Muscle_mass    [label="Muscle mass\n(LBM, kg)", fillcolor="#cfeacf"];
    CK_release     [label="Creatine kinase release\nCK (U/L)", fillcolor="#cfeacf"];
    Tetraglucose   [label="Urine Hex4 (glucose tetrasaccharide)", fillcolor="#cfeacf"];
    Mito_dysfunc   [label="Mitochondrial dysfunction\n(complex I/IV ↓)", fillcolor="#cfeacf"];
    Satellite_loss [label="Satellite cell exhaustion\nMyoD ↓", fillcolor="#cfeacf"];
    NMJ_dysfunc    [label="NMJ remodelling\n(MuSK/Agrin)", fillcolor="#cfeacf"];
    Inflam_M1      [label="Macrophage M1 / TNF-α", fillcolor="#cfeacf"];
    Fibrosis_M     [label="Endomysial fibrosis\nCollagen I", fillcolor="#cfeacf"];
  }

  /* ===================== 4. CARDIAC INVOLVEMENT (IOPD) ===================== */
  subgraph cluster_cardiac {
    label="4. Cardiac involvement (IOPD)";
    style="rounded,filled"; fillcolor="#fff0f0"; color="#c64a4a";
    CardiomyoGlyc  [label="Cardiomyocyte lysosomal\nglycogen", fillcolor="#ffd6d6"];
    LVMI_BSA       [label="LV mass index\n(g/m² BSA, Z-score)", fillcolor="#ffd6d6"];
    HCM_phen       [label="Hypertrophic cardiomyopathy\nshort PR, tall QRS", fillcolor="#ffd6d6"];
    LVOT_obs       [label="LVOT obstruction\n(dynamic gradient)", fillcolor="#ffd6d6"];
    EF_LV          [label="LV ejection fraction (%)", fillcolor="#ffd6d6"];
    NTproBNP_card  [label="NT-proBNP (pg/mL)", fillcolor="#ffd6d6"];
    Troponin_cT    [label="Cardiac troponin I/T", fillcolor="#ffd6d6"];
    Arrhythmia     [label="Conduction disease\nWPW-like, SVT", fillcolor="#ffd6d6"];
  }

  /* ===================== 5. RESPIRATORY SYSTEM ===================== */
  subgraph cluster_resp {
    label="5. Respiratory & diaphragm";
    style="rounded,filled"; fillcolor="#fff7e6"; color="#c68a2e";
    Diaph_glyc     [label="Diaphragm glycogen", fillcolor="#ffe8b8"];
    Diaph_weak     [label="Diaphragmatic weakness", fillcolor="#ffe8b8"];
    FVC_upright    [label="FVC upright (% predicted)", fillcolor="#ffe8b8"];
    FVC_supine     [label="FVC supine (% predicted)", fillcolor="#ffe8b8"];
    MIP_MEP        [label="MIP / MEP (cm H₂O)", fillcolor="#ffe8b8"];
    Sleep_disorder [label="Sleep-disordered breathing\n(SDB, AHI)", fillcolor="#ffe8b8"];
    NIV_use        [label="Non-invasive ventilation\nhours/day", fillcolor="#ffe8b8"];
    Resp_failure   [label="Respiratory failure\n(invasive ventilation)", fillcolor="#ffe8b8"];
    Sniff_NIP      [label="Sniff Nasal Inspiratory\nPressure (SNIP)", fillcolor="#ffe8b8"];
  }

  /* ===================== 6. CNS & OTHER ORGANS ===================== */
  subgraph cluster_other {
    label="6. CNS, vascular, hepatic involvement";
    style="rounded,filled"; fillcolor="#f5e6ff"; color="#7c2cbf";
    CNS_glycogen   [label="CNS glycogen\n(motor neurons, brainstem)", fillcolor="#e3cfff"];
    White_matter   [label="White-matter abnormalities\n(LOPD long-term)", fillcolor="#e3cfff"];
    Cog_decline    [label="Cognitive / speech delay", fillcolor="#e3cfff"];
    Bulbar_weak    [label="Bulbar / facial weakness\ndysphagia", fillcolor="#e3cfff"];
    Hearing_loss   [label="Sensorineural hearing loss", fillcolor="#e3cfff"];
    Vasculopathy   [label="Aneurysmal / arterial\nvasculopathy", fillcolor="#e3cfff"];
    Hepatomegaly   [label="Hepatomegaly\n(infantile)", fillcolor="#e3cfff"];
    Macroglossia   [label="Macroglossia (IOPD)", fillcolor="#e3cfff"];
    GI_dysmotility [label="GI dysmotility / gastroparesis", fillcolor="#e3cfff"];
  }

  /* ===================== 7. ERT — ALGLUCOSIDASE ALFA ===================== */
  subgraph cluster_alglu {
    label="7. ERT: alglucosidase alfa (Myozyme/Lumizyme)";
    style="rounded,filled"; fillcolor="#e6f7ff"; color="#1565c0";
    Alglu_IV       [label="Alglucosidase alfa\n20 mg/kg IV q2w", fillcolor="#cfeaff"];
    Alglu_plasma   [label="Plasma alglucosidase\nCL ≈ 0.27 mL/min/kg", fillcolor="#cfeaff"];
    Alglu_periph   [label="Peripheral compartment\n(V_p ≈ 60 mL/kg)", fillcolor="#cfeaff"];
    M6P_alglu      [label="Mannose-6-P content\n(low, ~2.5 mol/mol)", fillcolor="#cfeaff"];
    CIMPR_uptake_A [label="CI-MPR uptake\nKm ≈ 7 nM", fillcolor="#cfeaff"];
    Tissue_alglu   [label="Lysosomal delivery\nmuscle:plasma ratio", fillcolor="#cfeaff"];
    Hypersens_inf  [label="Infusion-associated\nreaction (IAR)", fillcolor="#cfeaff"];
  }

  /* ===================== 8. NEXT-GEN ERT ===================== */
  subgraph cluster_next_ert {
    label="8. Next-generation ERT";
    style="rounded,filled"; fillcolor="#e8f5e9"; color="#2e7d32";
    Aval_alfa      [label="Avalglucosidase alfa\n(Nexviazyme, M6P enrichment x15)", fillcolor="#d0e8d2"];
    Aval_uptake    [label="Enhanced CI-MPR\nbinding (Kd ~5 nM)", fillcolor="#d0e8d2"];
    Cipa_alfa      [label="Cipaglucosidase alfa\n(Pombiliti)", fillcolor="#d0e8d2"];
    Miglustat      [label="Miglustat 260 mg PO\n(enzyme stabiliser)", fillcolor="#d0e8d2"];
    Cipa_Mig_combo [label="Cipa + Miglustat\n(PROPEL trial)", fillcolor="#d0e8d2"];
    AT_GAA_chaperone [label="Pharmacologic chaperone\n(AT2220 etc.)", fillcolor="#d0e8d2"];
    Inhaled_ERT    [label="Inhaled GAA (research)", fillcolor="#d0e8d2"];
  }

  /* ===================== 9. GENE / mRNA THERAPY ===================== */
  subgraph cluster_gene {
    label="9. Gene & mRNA-based therapies";
    style="rounded,filled"; fillcolor="#fff3e0"; color="#ef6c00";
    AAV9_GAA       [label="AAV9-GAA IV\n(systemic)", fillcolor="#ffe0b2"];
    AAV8_GAA_liver [label="AAV8-LSP-GAA (liver depot)\n(SPK-3006, AT845)", fillcolor="#ffe0b2"];
    AAVrh74_IM     [label="AAVrh74 intramuscular", fillcolor="#ffe0b2"];
    mRNA_LNP_GAA   [label="mRNA-LNP GAA\n(research)", fillcolor="#ffe0b2"];
    HSC_GT         [label="ex vivo HSC GT\n(lentiviral)", fillcolor="#ffe0b2"];
    NeoGAA_engineered [label="Engineered GAA\n(IGF2-tagged)", fillcolor="#ffe0b2"];
    Liver_secreted_GAA [label="Hepatocyte-secreted GAA\n→ cross-correction", fillcolor="#ffe0b2"];
    Capsid_AAV_NAb [label="Pre-existing AAV NAb\n(seroprevalence)", fillcolor="#ffe0b2"];
  }

  /* ===================== 10. IMMUNOLOGY / ADA ===================== */
  subgraph cluster_immune {
    label="10. Anti-drug antibody (ADA) dynamics";
    style="rounded,filled"; fillcolor="#fff0f0"; color="#b71c1c";
    Naive_B        [label="Naive B-cell\n(GAA-specific)", fillcolor="#ffd6d6"];
    CD4_Tfh        [label="CD4 Tfh / IL-21", fillcolor="#ffd6d6"];
    Plasmablast    [label="Plasmablast", fillcolor="#ffd6d6"];
    LL_PC          [label="Long-lived plasma cell\n(BM niche)", fillcolor="#ffd6d6"];
    HSAT           [label="High sustained antibody titre\nHSAT ≥51,200", fillcolor="#ffd6d6"];
    Neutralising_Ab[label="Neutralising anti-GAA Ab\n(blocks CI-MPR uptake)", fillcolor="#ffd6d6"];
    Immune_tol     [label="ITI regimen\n(Rituximab + MTX ± IVIG)", fillcolor="#ffd6d6"];
    Sirolimus_imm  [label="Sirolimus / Bortezomib\nLLPC depletion", fillcolor="#ffd6d6"];
  }

  /* ===================== 11. CLINICAL ENDPOINTS ===================== */
  subgraph cluster_endpoints {
    label="11. Clinical endpoints";
    style="rounded,filled"; fillcolor="#f1f8e9"; color="#558b2f";
    six_MWT        [label="6-min walk test\n(meters)", fillcolor="#dcedc8"];
    GMFM_88        [label="GMFM-88 (infants)\nmotor milestones", fillcolor="#dcedc8"];
    Walker_free    [label="Ventilator-free survival\n(IOPD primary)", fillcolor="#dcedc8"];
    QMT            [label="Quantitative muscle\ntesting (QMT)", fillcolor="#dcedc8"];
    SF36_PCS       [label="SF-36 Physical Component\nscore", fillcolor="#dcedc8"];
    RPAct         [label="RPAct\n(Rasch-Pompe Activity)", fillcolor="#dcedc8"];
    Wheelchair     [label="Wheelchair use\n(% time)", fillcolor="#dcedc8"];
    Survival       [label="Overall survival (HR vs untreated)", fillcolor="#dcedc8"];
  }

  /* ===================== 12. BIOMARKERS & SAFETY ===================== */
  subgraph cluster_biomark {
    label="12. Biomarkers, safety & monitoring";
    style="rounded,filled"; fillcolor="#fce4ec"; color="#ad1457";
    DBS_GAA        [label="DBS GAA enzyme\n(diagnosis)", fillcolor="#f8bbd0"];
    LeukoGAA       [label="Leukocyte GAA activity", fillcolor="#f8bbd0"];
    Plasma_Hex4    [label="Plasma / urine Hex4\n(glucotetrasaccharide)", fillcolor="#f8bbd0"];
    Serum_CK_bio   [label="Serum CK (U/L)", fillcolor="#f8bbd0"];
    AST_ALT_b      [label="AST / ALT (U/L)", fillcolor="#f8bbd0"];
    LDH_b          [label="Lactate dehydrogenase", fillcolor="#f8bbd0"];
    MRI_fat_frac   [label="Muscle MRI fat fraction\n(Mercuri grade)", fillcolor="#f8bbd0"];
    DEXA_LBM       [label="DEXA lean body mass", fillcolor="#f8bbd0"];
    ADA_titre      [label="Anti-GAA ADA titre", fillcolor="#f8bbd0"];
    IAR_grade      [label="IAR grade (CTCAE)", fillcolor="#f8bbd0"];
    Cardiac_Echo   [label="Echo: LVMI, LVOT,\nEF, mitral inflow", fillcolor="#f8bbd0"];
  }

  /* ===================== EDGES — pathogenesis ===================== */
  GAA_gene -> IVS1_var; GAA_gene -> Null_var; GAA_gene -> Missense_var; GAA_gene -> Pseudo_def;
  IVS1_var -> CRIM_status; Null_var -> CRIM_status;
  GAA_gene -> Tx_mRNA -> proGAA_110kDa -> M6P_tag -> Golgi_proc -> Lyso_targeting -> GAA_active;
  CRIM_status -> GAA_active [label="severity"];
  Acid_pH -> GAA_active;
  GAA_active -> GAA_activity;
  GAA_activity -> Glycogen_lyso [label="hydrolysis", color="#1565c0"];
  Glycogen_lyso -> Glc_out;
  GAA_activity -> Lysosome_size [arrowhead=tee, color="#1565c0"];
  Lysosome_size -> Autophagosome; Lysosome_size -> Lipofuscin;
  TFEB_pathway -> Lysosome_size;
  Autophagosome -> Auto_buildup; Lipofuscin -> GCase_secondary;
  NBS_DBS -> DBS_GAA;

  /* Pathogenesis muscle */
  Lysosome_size -> Cyto_glycogen; Auto_buildup -> Lyso_rupture -> Sarcomere_disr -> Fiber_typeII;
  Fiber_typeII -> Muscle_mass [arrowhead=tee];
  Sarcomere_disr -> CK_release; Glycogen_lyso -> Tetraglucose [label="urine biomarker"];
  Auto_buildup -> Mito_dysfunc; Mito_dysfunc -> Satellite_loss;
  Sarcomere_disr -> NMJ_dysfunc; Auto_buildup -> Inflam_M1 -> Fibrosis_M;
  Fibrosis_M -> MRI_fat_frac;

  /* Pathogenesis cardiac */
  Lysosome_size -> CardiomyoGlyc -> LVMI_BSA -> HCM_phen -> LVOT_obs;
  LVMI_BSA -> EF_LV [arrowhead=tee]; HCM_phen -> NTproBNP_card; Sarcomere_disr -> Troponin_cT;
  HCM_phen -> Arrhythmia;

  /* Pathogenesis respiratory */
  Lysosome_size -> Diaph_glyc -> Diaph_weak; Diaph_weak -> FVC_upright [arrowhead=tee];
  Diaph_weak -> FVC_supine [arrowhead=tee]; Diaph_weak -> MIP_MEP [arrowhead=tee];
  FVC_supine -> Sleep_disorder; Sleep_disorder -> NIV_use; FVC_upright -> Resp_failure;
  Diaph_weak -> Sniff_NIP [arrowhead=tee];

  /* Other organs */
  Lysosome_size -> CNS_glycogen -> White_matter -> Cog_decline;
  CNS_glycogen -> Bulbar_weak; CNS_glycogen -> Hearing_loss;
  Lysosome_size -> Vasculopathy; Lysosome_size -> Hepatomegaly;
  Lysosome_size -> Macroglossia; CNS_glycogen -> GI_dysmotility;

  /* ERT alglucosidase */
  Alglu_IV -> Alglu_plasma -> Alglu_periph;
  Alglu_plasma -> M6P_alglu -> CIMPR_uptake_A -> Tissue_alglu;
  Tissue_alglu -> GAA_activity [label="ERT supplementation", color="#1565c0"];
  Alglu_plasma -> Hypersens_inf;

  /* Next-gen ERT */
  Aval_alfa -> Aval_uptake -> CIMPR_uptake_A; Aval_uptake -> Tissue_alglu [color="#2e7d32"];
  Cipa_alfa -> CIMPR_uptake_A; Cipa_alfa -> Cipa_Mig_combo;
  Miglustat -> Cipa_Mig_combo [label="stabilises\nplasma", color="#2e7d32"];
  Cipa_Mig_combo -> Tissue_alglu [color="#2e7d32"];
  AT_GAA_chaperone -> proGAA_110kDa [label="endogenous\nrescue"];
  Inhaled_ERT -> Diaph_glyc [arrowhead=tee];

  /* Gene therapy */
  AAV9_GAA -> GAA_activity [label="systemic transduction", color="#ef6c00"];
  AAV8_GAA_liver -> Liver_secreted_GAA -> Tissue_alglu [color="#ef6c00"];
  AAVrh74_IM -> GAA_activity [color="#ef6c00"];
  mRNA_LNP_GAA -> proGAA_110kDa; HSC_GT -> Liver_secreted_GAA;
  NeoGAA_engineered -> CIMPR_uptake_A; Capsid_AAV_NAb -> AAV9_GAA [arrowhead=tee];

  /* Immune / ADA */
  Alglu_IV -> Naive_B -> Plasmablast -> LL_PC -> HSAT;
  Plasmablast -> Neutralising_Ab; CD4_Tfh -> Plasmablast;
  HSAT -> Tissue_alglu [arrowhead=tee, color="#b71c1c"];
  Neutralising_Ab -> CIMPR_uptake_A [arrowhead=tee];
  Neutralising_Ab -> Hypersens_inf;
  Immune_tol -> Naive_B [arrowhead=tee]; Immune_tol -> Plasmablast [arrowhead=tee];
  Sirolimus_imm -> LL_PC [arrowhead=tee];
  HSAT -> ADA_titre;

  /* Endpoint mapping */
  Muscle_mass -> six_MWT; MIP_MEP -> six_MWT; Fiber_typeII -> QMT;
  GMFM_88 -> Walker_free; FVC_upright -> Walker_free;
  Sarcomere_disr -> SF36_PCS [arrowhead=tee]; Muscle_mass -> RPAct;
  Muscle_mass -> Wheelchair [arrowhead=tee]; Walker_free -> Survival;
  EF_LV -> Survival; FVC_upright -> Survival;

  /* Biomarkers */
  GAA_activity -> LeukoGAA; CK_release -> Serum_CK_bio;
  Tetraglucose -> Plasma_Hex4; Auto_buildup -> AST_ALT_b; CK_release -> LDH_b;
  Fibrosis_M -> MRI_fat_frac; Muscle_mass -> DEXA_LBM;
  HCM_phen -> Cardiac_Echo; Hypersens_inf -> IAR_grade; LL_PC -> ADA_titre;

  /* Cross-links: cardiac & resp coupling */
  Resp_failure -> Survival [arrowhead=tee];
  Arrhythmia -> Survival [arrowhead=tee];
}
