digraph PsA_QSP {
  /* ================================================================
     Psoriatic Arthritis (PsA) – Comprehensive QSP Mechanistic Map
     130+ nodes · 14 subgraph clusters
     Pathways: Genetic risk · Innate immunity · IL-23/Th17 axis ·
               Skin pathology · Enthesis · Synovium · Bone remodeling ·
               Gut-joint axis · Nail disease · Drug PK/PD ·
               Biomarkers · Clinical endpoints
  ================================================================ */

  graph [
    rankdir=LR
    fontname="Helvetica"
    fontsize=11
    bgcolor="#FAFAFA"
    splines=ortho
    nodesep=0.35
    ranksep=0.8
    label="Psoriatic Arthritis (PsA) — Quantitative Systems Pharmacology Model\nDrug targets: TNFi · IL-17Ai · IL-23i (IL-12/23p40 / IL-23p19) · JAKi (JAK1/2/3/TYK2) · PDE4i (Apremilast)"
    labelloc=t
    labeljust=c
    fontsize=14
  ]
  node [fontname="Helvetica" fontsize=9 style=filled shape=ellipse]
  edge [fontname="Helvetica" fontsize=8 arrowsize=0.7]

  /* ================================================================
     CLUSTER 1: Genetic & Environmental Risk
  ================================================================ */
  subgraph cluster_genetics {
    label="1. Genetic & Environmental Risk"
    style=filled fillcolor="#FFF9E6" color="#E6A817" penwidth=1.5
    node [fillcolor="#FFEDB3"]

    HLA_Cw6   [label="HLA-C*06:02\n(PSORS1)"]
    HLA_B27   [label="HLA-B27\n(axial/enthesitis)"]
    IL23R     [label="IL23R\npolymorphism"]
    PSORS_loci[label="PSORS2–9\nGene Loci"]
    TNFAIP3   [label="TNFAIP3 (A20)\nNF-κB regulation"]
    PTPN22    [label="PTPN22\nT-cell signaling"]
    LCE       [label="LCE3B/3C\ndeletion (barrier)"]
    Trigger   [label="Trigger: Trauma\nInfection · Stress"]
    Strep     [label="Strep guttate\ntrigger (HLA-Cw6)"]
    KoebnerPh [label="Koebner\nPhenomenon"]

    HLA_Cw6 -> Trigger [label="susceptibility"]
    HLA_B27 -> Trigger
    IL23R -> Trigger
    PSORS_loci -> Trigger
    TNFAIP3 -> Trigger
    PTPN22 -> Trigger
    LCE -> Trigger [label="epidermal\nbarrier defect"]
    Strep -> Trigger
    KoebnerPh -> Trigger
  }

  /* ================================================================
     CLUSTER 2: Innate Immune Activation
  ================================================================ */
  subgraph cluster_innate {
    label="2. Innate Immune Activation"
    style=filled fillcolor="#FFF0F5" color="#C0456E" penwidth=1.5
    node [fillcolor="#FFD6E7"]

    pDC       [label="Plasmacytoid DC\n(pDC)"]
    mDC       [label="Myeloid DC\n(mDC/cDC1)"]
    Macro_M1  [label="Macrophage M1\n(CD68+)"]
    Macro_M2  [label="Macrophage M2\n(CD163+)"]
    Neutro    [label="Neutrophil\n(CXCL1/8-driven)"]
    MastCell  [label="Mast Cell\n(tryptase+)"]
    ILC3      [label="ILC3\n(IL-22/IL-17 src)"]
    ILC2      [label="ILC2\n(IL-13/TSLP)"]
    NK_cell   [label="NK cell\n(KIR3DL2/HLA-B27)"]
    DAMP      [label="DAMPs\n(HMGB1·S100A8/9)"]
    TLR2_4    [label="TLR2/4\n(LPS · β-glucan)"]
    TLR7_9    [label="TLR7/9\n(self-RNA/DNA)"]
    NLRP3     [label="NLRP3\nInflammasome"]
    Casp1     [label="Caspase-1"]
    IFNalpha  [label="IFN-α\n(pDC derived)"]

    Trigger -> DAMP -> TLR2_4
    Trigger -> TLR7_9
    TLR7_9 -> pDC -> IFNalpha
    TLR2_4 -> Macro_M1
    TLR2_4 -> mDC
    Macro_M1 -> NLRP3 -> Casp1
    Macro_M1 -> Neutro [label="CXCL8"]
    MastCell -> ILC3
    IFNalpha -> mDC
    NK_cell -> Macro_M1 [label="IFN-γ"]
    ILC2 -> MastCell
    DAMP -> NLRP3
  }

  /* ================================================================
     CLUSTER 3: Adaptive Immunity – Th17/Th1/Treg Axis
  ================================================================ */
  subgraph cluster_adaptive {
    label="3. Adaptive Immunity — Th17 / Th1 / Treg Axis"
    style=filled fillcolor="#E8F5FF" color="#1A6FA8" penwidth=1.5
    node [fillcolor="#CCE5FF"]

    Th17      [label="Th17 cell\n(IL-17A/F · IL-22)"]
    Th1       [label="Th1 cell\n(IFN-γ · TNF-α)"]
    Th22      [label="Th22 cell\n(IL-22)"]
    Treg      [label="Treg\n(IL-10 · TGF-β)"]
    CD8T      [label="CD8+ CTL\n(skin/joint)"]
    Tfh       [label="Tfh\n(IL-21 · CXCR5)"]
    Bcell     [label="B cell\n(GC reaction)"]
    Plasma    [label="Plasma cell\n(IgA · IgG)"]
    MAIT      [label="MAIT cell\n(MR1 · IL-18)"]
    gdT       [label="γδ T cell\n(IL-17 · butyrophilin)"]
    IL23_node [label="IL-23\n(p19/p40 dimer)"]
    IL12_node [label="IL-12\n(p35/p40 dimer)"]
    RORgt     [label="RORγt\nTF (Th17 master)"]
    Tbet      [label="T-bet\nTF (Th1 master)"]
    STAT3     [label="STAT3\n(IL-23 signaling)"]
    STAT4     [label="STAT4\n(IL-12 signaling)"]
    STAT1     [label="STAT1\n(IFN-γ signaling)"]

    mDC -> IL23_node [label="p19+p40"]
    mDC -> IL12_node [label="p35+p40"]
    Macro_M1 -> IL23_node
    IL23_node -> STAT3 -> RORgt -> Th17
    IL12_node -> STAT4 -> Tbet -> Th1
    IFNalpha -> STAT1
    Th17 -> CD8T [label="amplify"]
    Th17 -> Tfh -> Bcell -> Plasma
    Treg -> Th17 [label="suppress" style=dashed color=red]
    MAIT -> Th17 [label="synergy"]
    gdT -> Th17
    ILC3 -> Th17 [label="IL-17"]
    Treg -> Th1 [style=dashed color=red]
  }

  /* ================================================================
     CLUSTER 4: Cytokine Network
  ================================================================ */
  subgraph cluster_cytokines {
    label="4. Key Cytokines & Signaling Mediators"
    style=filled fillcolor="#F0FFF0" color="#2E8B57" penwidth=1.5
    node [fillcolor="#C8F0C8"]

    IL17A     [label="IL-17A\n(Th17/ILC3/γδT)"]
    IL17F     [label="IL-17F\n(+ IL-17A homodimer)"]
    IL22      [label="IL-22\n(Th22/ILC3)"]
    TNFa      [label="TNF-α\n(Macro M1/Th1)"]
    IL1b      [label="IL-1β\n(NLRP3/Casp1)"]
    IL6       [label="IL-6\n(Macro/FLS)"]
    IL8_CXCL8 [label="IL-8/CXCL8\n(neutrophil chemo)"]
    IL18      [label="IL-18\n(NLRP3/Casp1)"]
    IL10      [label="IL-10\n(anti-inflam/Treg)"]
    IL36_sys  [label="IL-36α/β/γ\n(keratinocyte)"]
    IFNg      [label="IFN-γ\n(Th1/NK/CD8)"]
    TGFb1     [label="TGF-β1\n(fibrosis/Treg)"]
    VEGF_c    [label="VEGF\n(angiogenesis)"]
    MMP3      [label="MMP-3\n(stromelysin-1)"]
    S100A8_9  [label="S100A8/A9\n(calprotectin)"]
    CXCL10    [label="CXCL10/IP-10\n(T-cell recruit)"]
    CCL20     [label="CCL20/MIP-3α\n(CCR6→Th17)"]
    OSM       [label="OSM\n(gp130/JAK)"]

    Th17 -> IL17A -> IL17R [label="receptor"]
    Th17 -> IL17F
    Th17 -> IL22
    Th1 -> IFNg
    Th1 -> TNFa
    Macro_M1 -> TNFa
    Macro_M1 -> IL1b
    Macro_M1 -> IL6
    Macro_M1 -> IL8_CXCL8
    Casp1 -> IL1b
    Casp1 -> IL18
    Treg -> IL10
    MastCell -> IL36_sys
    Plasma -> S100A8_9 [label="indirect"]
    FLS_act [label="FLS\nActivated" fillcolor="#C8F0C8"]
    FLS_act -> MMP3
    FLS_act -> VEGF_c
    FLS_act -> IL6
    FLS_act -> OSM
    mDC -> CCL20 -> Th17 [label="CCR6"]
    mDC -> CXCL10
    IL17A -> IL8_CXCL8 [label="synergy"]
    IL17A -> IL6
    TGFb1 -> Treg [label="induce"]
    IL17R [label="IL-17RA/RC\nreceptor complex" fillcolor="#C8F0C8"]
  }

  /* ================================================================
     CLUSTER 5: JAK-STAT Intracellular Signaling
  ================================================================ */
  subgraph cluster_JAK {
    label="5. Intracellular Signaling (JAK-STAT / NF-κB / cAMP-PDE4)"
    style=filled fillcolor="#FFF5E6" color="#E67300" penwidth=1.5
    node [fillcolor="#FFE0B2"]

    JAK1      [label="JAK1\n(IL-6/IL-4/IFN-γ)"]
    JAK2      [label="JAK2\n(IL-12/IL-23/EPO)"]
    JAK3      [label="JAK3\n(γc chain cytokines)"]
    TYK2      [label="TYK2\n(IL-12/IL-23/IFN-α)"]
    STAT3_jak [label="STAT3\n(IL-6/IL-23 → Th17)"]
    STAT4_jak [label="STAT4\n(IL-12 → Th1)"]
    STAT6     [label="STAT6\n(IL-4/IL-13)"]
    NFKB      [label="NF-κB\n(p65/p50)"]
    IKK       [label="IKK complex\n(IKKα/β/γ)"]
    AP1       [label="AP-1\n(c-Fos/c-Jun)"]
    MAPK_p38  [label="p38 MAPK\n(stress/TNF)"]
    ERK12     [label="ERK1/2\n(MAPK cascade)"]
    PI3K_Akt  [label="PI3K/Akt\n(survival)"]
    PDE4      [label="PDE4\n(cAMP→5'AMP)"]
    cAMP      [label="cAMP\n(anti-inflam\nmessenger)"]
    PKA       [label="PKA\n(CREB phospho)"]
    mTOR      [label="mTOR\n(Th17 metabolism)"]

    JAK1 -> STAT3_jak
    JAK2 -> STAT3_jak
    JAK2 -> STAT4_jak
    TYK2 -> STAT4_jak
    JAK3 -> STAT6
    TNFa -> IKK -> NFKB
    TNFa -> MAPK_p38 -> AP1
    NFKB -> TNFa [label="+ feedback"]
    PDE4 -> cAMP [label="degrades" style=dashed color=red]
    cAMP -> PKA [label="activates"]
    PKA -> NFKB [label="inhibits" style=dashed color=red]
    PKA -> TNFa [label="↓" style=dashed color=red]
    ERK12 -> AP1
    PI3K_Akt -> mTOR -> Th17
    IL6 -> JAK1
    IL23_node -> JAK2 [label="STAT3"]
    IL23_node -> TYK2
    IL12_node -> TYK2
    IFNg -> JAK1 -> STAT1
  }

  /* ================================================================
     CLUSTER 6: Skin Pathology (Psoriasis)
  ================================================================ */
  subgraph cluster_skin {
    label="6. Skin Pathology — Plaque Psoriasis"
    style=filled fillcolor="#FFF0E6" color="#CC5500" penwidth=1.5
    node [fillcolor="#FFD6B3"]

    Keratinocyte [label="Keratinocyte\n(basal/suprabasal)"]
    KC_act    [label="KC Activated\n(IL-36/IL-17 driven)"]
    Epidermis [label="Hyperplasia\n(acanthosis/parakeratosis)"]
    Dermis    [label="Dermal\nInflammation"]
    Angio     [label="Angiogenesis\n(VEGF/angiopoietin)"]
    HF_axis   [label="Hair Follicle\n(pDC reservoir)"]
    AMP_skin  [label="AMPs: β-defensin\nLL-37 · Psoriasin"]
    IL36Ra    [label="IL-36Ra\n(endogenous antagonist)"]
    Filaggrin [label="Filaggrin↓\n(barrier defect)"]
    Parakeratosis[label="Parakeratosis\n(nucleated SC cells)"]
    MunroPust [label="Munro\nMicroabscess"]
    PASI      [label="PASI Score\n(clinical endpoint)"]
    BSA_skin  [label="BSA Involved\n(%)"]
    IGA_score [label="IGA Score\n(0–4)"]

    KC_act -> Epidermis
    KC_act -> AMP_skin [label="LL-37 auto-DNA"]
    IL17A -> KC_act [label="STAT3/NF-κB"]
    IL22 -> KC_act [label="STAT3 → prolif"]
    TNFa -> KC_act
    IL36_sys -> KC_act [label="amplify"]
    AMP_skin -> TLR7_9 [label="complex"]
    Filaggrin -> KC_act [label="defect"]
    Neutro -> MunroPust
    KC_act -> Parakeratosis
    Angio -> Dermis
    VEGF_c -> Angio
    HF_axis -> pDC [label="CXCL10"]
    Dermis -> PASI
    Epidermis -> PASI
    BSA_skin -> PASI
    IGA_score -> PASI [style=dashed]
    IL36Ra -> IL36_sys [label="antagonizes" style=dashed color=red]
  }

  /* ================================================================
     CLUSTER 7: Enthesis Pathology
  ================================================================ */
  subgraph cluster_enthesis {
    label="7. Enthesis Pathology"
    style=filled fillcolor="#F5E6FF" color="#7B00CC" penwidth=1.5
    node [fillcolor="#E0C3FF"]

    Enthesis_site [label="Enthesis\n(fibrocartilage)"]
    Mech_stress   [label="Mechanical\nStress/Microtrauma"]
    Entheseal_BM  [label="Bone Marrow\nnear Enthesis"]
    ILC3_enth     [label="ILC3\n(enthesis-resident)"]
    gdT_enth      [label="γδ T cell\n(enthesis)"]
    IL17_enth     [label="IL-17A\n(local production)"]
    IL23_enth     [label="IL-23\n(mDC / Macro)"]
    Calcification [label="Enthesophyte\n(new bone)"]
    Erosion_enth  [label="Entheseal\nErosion"]
    Dactylitis    [label="Dactylitis\n(sausage digit)"]
    SpineInvolv   [label="Axial Disease\n(sacroiliitis)"]

    Mech_stress -> Enthesis_site
    Enthesis_site -> Entheseal_BM
    Entheseal_BM -> ILC3_enth -> IL17_enth
    Entheseal_BM -> gdT_enth -> IL17_enth
    Mech_stress -> IL23_enth [label="DAMP"]
    IL23_enth -> ILC3_enth
    IL17_enth -> Erosion_enth [label="RANKL↑"]
    IL17_enth -> Calcification [label="BMP/Wnt↑"]
    Enthesis_site -> Dactylitis
    Enthesis_site -> SpineInvolv
    HLA_B27 -> SpineInvolv [label="misfolding → IL-23"]
  }

  /* ================================================================
     CLUSTER 8: Synovium & Joint Pathology
  ================================================================ */
  subgraph cluster_synovium {
    label="8. Synovium & Joint Pathology"
    style=filled fillcolor="#E6F0FF" color="#1A3A8A" penwidth=1.5
    node [fillcolor="#B3CCFF"]

    Synovium  [label="Synovial Membrane\n(intimal lining)"]
    FLS_q     [label="FLS Quiescent\n(type B synoviocyte)"]
    FLS_inv   [label="FLS Invasive\n(pannus-forming)"]
    Pannus    [label="Pannus\n(invasive tissue)"]
    ACPA_neg  [label="RF-/ACPA-\n(seroneg 60-70%)"]
    Vasodil   [label="Vasodilation\n(prostaglandins)"]
    Edema     [label="Joint Edema\n(bradykinin/PGE2)"]
    CartDeg   [label="Cartilage\nDegradation"]
    BoneEros  [label="Bone Erosion\n(subcortical)"]
    SJC66     [label="SJC66\n(swollen joints)"]
    TJC68     [label="TJC68\n(tender joints)"]
    DAPSA     [label="DAPSA Score\n(disease activity)"]
    MDA       [label="MDA\n(minimal disease activity)"]
    PsARC     [label="PsARC\n(response criteria)"]

    Synovium -> FLS_q
    FLS_q -> FLS_act
    FLS_act -> FLS_inv -> Pannus
    IL17A -> FLS_act
    TNFa -> FLS_act
    IL1b -> FLS_act
    IL6 -> FLS_act
    Pannus -> CartDeg [label="MMP-3/9/13"]
    Pannus -> BoneEros [label="RANKL"]
    FLS_inv -> VEGF_c [label="angiogenesis"]
    Vasodil -> Edema
    PGE2_s [label="PGE2\n(COX-2 product)" fillcolor="#B3CCFF"]
    COX2   [label="COX-2\n(TNF/IL-1 induced)" fillcolor="#B3CCFF"]
    TNFa -> COX2 -> PGE2_s -> Vasodil
    SJC66 -> DAPSA
    TJC68 -> DAPSA
    DAPSA -> MDA [label="DAPSA≤4"]
    DAPSA -> PsARC
    ACPA_neg -> Synovium [label="different from RA"]
  }

  /* ================================================================
     CLUSTER 9: Bone Remodeling
  ================================================================ */
  subgraph cluster_bone {
    label="9. Bone Remodeling — Dual Pathology"
    style=filled fillcolor="#FFF5E6" color="#996633" penwidth=1.5
    node [fillcolor="#FFE6B3"]

    Osteoclast [label="Osteoclast\n(multinucleated)"]
    Osteoblast [label="Osteoblast\n(bone forming)"]
    RANKL_bone [label="RANKL\n(TNFSF11)"]
    OPG        [label="OPG\n(TNFRSF11B, decoy)"]
    RANK_rec   [label="RANK\n(receptor, OC)"]
    MCSFr      [label="M-CSF\n(OC progenitor)"]
    DKK1       [label="DKK1\n(Wnt inhibitor)"]
    Sclerostin [label="Sclerostin\n(SOST, Wnt inhib)"]
    Wnt_path   [label="Wnt/β-catenin\n(OB activation)"]
    BMP_path   [label="BMP2/4/6\n(bone formation)"]
    Periostitis[label="Periostitis\n(new bone)"]
    Erosion_bone[label="Subcortical\nErosion"]
    BMD_change [label="BMD Change\n(DXA)"]
    SHS_score  [label="mTSS/SHS\n(joint damage)"]

    RANKL_bone -> RANK_rec -> Osteoclast [label="activate"]
    OPG -> RANK_rec [label="block" style=dashed color=red]
    MCSFr -> Osteoclast [label="proliferate"]
    TNFa -> RANKL_bone [label="↑"]
    IL17A -> RANKL_bone [label="↑"]
    IL1b -> RANKL_bone
    IL17A -> DKK1 [label="↑ (early)"]
    DKK1 -> Wnt_path [label="inhibit" style=dashed color=red]
    TNFa -> DKK1 [label="↑"]
    BMP_path -> Osteoblast
    Wnt_path -> Osteoblast [label="activate"]
    Wnt_path -> Periostitis
    BMP_path -> Periostitis
    Osteoclast -> Erosion_bone
    Osteoblast -> BMD_change
    Erosion_bone -> SHS_score
    Periostitis -> SHS_score
  }

  /* ================================================================
     CLUSTER 10: Gut–Skin–Joint Axis
  ================================================================ */
  subgraph cluster_gut {
    label="10. Gut – Skin – Joint Axis"
    style=filled fillcolor="#E6FFF0" color="#007744" penwidth=1.5
    node [fillcolor="#B3FFD6"]

    Gut_microbiome [label="Gut Microbiome\n(Akkermansia↓/Firmicutes↑)"]
    GutBarrier     [label="Gut Barrier\n(tight junctions)"]
    ILC3_gut       [label="ILC3 (gut)\n(IL-22/IL-17)"]
    sIgA           [label="Secretory IgA\n(barrier protection)"]
    LPS_gut        [label="LPS/Microbiota\nAntigens"]
    Liver_APR      [label="Liver\nAcute Phase"]
    CRP_serum      [label="CRP\n(acute phase protein)"]
    Fibrinogen     [label="Fibrinogen\n(acute phase)"]
    IBD_assoc      [label="IBD association\n(Crohn's/UC ~7%)"]

    Gut_microbiome -> GutBarrier [label="dysbiosis → permeability↑"]
    GutBarrier -> LPS_gut -> TLR4 [label="leaky gut"]
    TLR4 [label="TLR4\n(LPS receptor)" fillcolor="#B3FFD6"]
    TLR4 -> Macro_M1 [label="activate"]
    ILC3_gut -> ILC3 [label="trafficking"]
    GutBarrier -> sIgA [label="protect"]
    Macro_M1 -> CRP_serum [label="IL-6→liver"]
    IL6 -> Liver_APR -> CRP_serum
    IL6 -> Fibrinogen
    IBD_assoc -> GutBarrier
    Gut_microbiome -> IBD_assoc
  }

  /* ================================================================
     CLUSTER 11: Nail Disease & Comorbidities
  ================================================================ */
  subgraph cluster_comorbid {
    label="11. Nail Disease & Systemic Comorbidities"
    style=filled fillcolor="#F5F5FF" color="#5555AA" penwidth=1.5
    node [fillcolor="#D6D6FF"]

    NailPsoriasis [label="Nail Psoriasis\n(pitting/onycholysis)"]
    NAPSI         [label="NAPSI Score\n(nail assessment)"]
    Uveitis       [label="Uveitis\n(anterior, 7%)"]
    MetSyn        [label="Metabolic Syndrome\n(visceral adiposity)"]
    CV_risk       [label="CV Risk↑\n(MI/Stroke 1.3×)"]
    Depression    [label="Depression/Anxiety\n(37% prevalence)"]
    ObesityComor  [label="Obesity\n(adipokine drive)"]
    Leptin        [label="Leptin↑\n(pro-inflammatory)"]
    Adiponectin   [label="Adiponectin↓\n(anti-inflammatory)"]
    Fatty_liver   [label="Fatty Liver\n(NAFLD 47%)"]

    NailPsoriasis -> NAPSI
    Enthesis_site -> NailPsoriasis [label="nail matrix"]
    IL17A -> NailPsoriasis
    ObesityComor -> Leptin -> Macro_M1
    ObesityComor -> Adiponectin [label="↓" style=dashed color=red]
    Adiponectin -> NFKB [label="inhibits" style=dashed color=red]
    ObesityComor -> MetSyn
    MetSyn -> CV_risk
    Psoriasis -> CV_risk
    IL6 -> CV_risk
    ObesityComor -> Fatty_liver
    MetSyn -> Fatty_liver
    Psoriasis [label="Plaque Psoriasis\n(skin score)" fillcolor="#D6D6FF"]
    PASI -> Psoriasis
  }

  /* ================================================================
     CLUSTER 12: Drug PK Compartments
  ================================================================ */
  subgraph cluster_PK {
    label="12. Drug PK Compartments"
    style=filled fillcolor="#F0FFE6" color="#336600" penwidth=1.5
    node [fillcolor="#C3F0A0"]

    // TNFi – Adalimumab (SC)
    ADA_depot  [label="Adalimumab\nSC Depot"]
    ADA_C1     [label="Adalimumab\nCentral (C1)"]
    ADA_C2     [label="Adalimumab\nPeripheral (C2)"]
    ADA_tmdd   [label="ADA-TNF\nBound Complex"]

    // IL-17A inhibitor – Ixekizumab (SC)
    IXE_depot  [label="Ixekizumab\nSC Depot"]
    IXE_C1     [label="Ixekizumab\nCentral (C1)"]
    IXE_tmdd   [label="IXE-IL17A\nBound Complex"]

    // IL-23p19 inhibitor – Guselkumab / Risankizumab
    GUS_depot  [label="Guselkumab\nSC Depot"]
    GUS_C1     [label="Guselkumab\nCentral (C1)"]
    GUS_tmdd   [label="GUS-IL23p19\nBound"]

    // JAKi – Upadacitinib (oral)
    UPA_GI     [label="Upadacitinib\nGI (oral)"]
    UPA_C1     [label="Upadacitinib\nCentral (free)"]

    // PDE4i – Apremilast (oral)
    APR_GI     [label="Apremilast\nGI (oral)"]
    APR_C1     [label="Apremilast\nCentral (free)"]

    // FcRn recycling
    FcRn_node  [label="FcRn\nIgG Recycling"]

    ADA_depot -> ADA_C1 [label="ka_ADA"]
    ADA_C1 -> ADA_C2 [label="k12"]
    ADA_C2 -> ADA_C1 [label="k21"]
    ADA_C1 -> ADA_tmdd [label="kon·TNFa"]
    ADA_tmdd -> ADA_C1 [label="koff"]
    FcRn_node -> ADA_C1 [label="recycle"]

    IXE_depot -> IXE_C1 [label="ka_IXE"]
    IXE_C1 -> IXE_tmdd [label="kon·IL17A"]
    IXE_tmdd -> IXE_C1 [label="koff"]
    FcRn_node -> IXE_C1

    GUS_depot -> GUS_C1 [label="ka_GUS"]
    GUS_C1 -> GUS_tmdd [label="kon·IL23p19"]
    FcRn_node -> GUS_C1

    UPA_GI -> UPA_C1 [label="ka_UPA"]
    APR_GI -> APR_C1 [label="ka_APR"]
  }

  /* ================================================================
     CLUSTER 13: Drug Mechanisms / PD Targets
  ================================================================ */
  subgraph cluster_PD {
    label="13. Drug Mechanisms — PD Targets"
    style=filled fillcolor="#FFE6F5" color="#AA0066" penwidth=1.5
    node [fillcolor="#FFB3E0"]

    TNFi_mech    [label="TNFi\n(ADA/ETN/IFX/CZP/GOL)\nTNFα neutralization"]
    IL17Ai_mech  [label="IL-17Ai\n(IXE/SEC/BIM)\nIL-17A/F block"]
    IL23i_mech   [label="IL-23i\n(GUS/RIS/TIL)\nIL-23p19 block"]
    IL12_23i     [label="IL-12/23i\n(UST)\np40 block"]
    JAKi_mech    [label="JAKi\n(UPA/TOF/BAR/FIL)\nJAK1/2/3/TYK2 inhibit"]
    PDE4i_mech   [label="PDE4i\n(Apremilast)\ncAMP↑ → NF-κB↓"]
    CTLA4Ig_mech [label="CTLA4-Ig\n(Abatacept)\nCD80/86 block"]
    NSAID_mech   [label="NSAIDs\n(Naproxen/Ibu)\nCOX-1/2 inhibit"]
    MTX_cDMARD   [label="MTX\n(cDMARD)\nDHFR/AICAR → adenosine"]
    SSZ_cDMARD   [label="SSZ\n(cDMARD)\nNF-κB/5-ASA"]

    TNFi_mech -> TNFa [label="neutralize" style=dashed color=red arrowhead=tee]
    IL17Ai_mech -> IL17A [label="neutralize" style=dashed color=red arrowhead=tee]
    IL17Ai_mech -> IL17F [style=dashed color=red arrowhead=tee]
    IL23i_mech -> IL23_node [label="p19 block" style=dashed color=red arrowhead=tee]
    IL12_23i -> IL23_node [label="p40 block" style=dashed color=red arrowhead=tee]
    IL12_23i -> IL12_node [style=dashed color=red arrowhead=tee]
    JAKi_mech -> JAK1 [label="inhibit" style=dashed color=red arrowhead=tee]
    JAKi_mech -> JAK2 [style=dashed color=red arrowhead=tee]
    JAKi_mech -> TYK2 [style=dashed color=red arrowhead=tee]
    PDE4i_mech -> PDE4 [label="inhibit" style=dashed color=red arrowhead=tee]
    APR_C1 -> PDE4i_mech [label="drug effect"]
    UPA_C1 -> JAKi_mech
    ADA_C1 -> TNFi_mech
    IXE_C1 -> IL17Ai_mech
    GUS_C1 -> IL23i_mech
    CTLA4Ig_mech -> Th17 [label="T-cell costimul\nblock" style=dashed color=red arrowhead=tee]
    NSAID_mech -> COX2 [style=dashed color=red arrowhead=tee]
