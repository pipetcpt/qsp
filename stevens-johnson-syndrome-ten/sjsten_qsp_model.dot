digraph SJS_TEN_QSP {
  rankdir=LR;
  graph [splines=true, overlap=false, fontname="Helvetica", fontsize=11, compound=true, nodesep=0.32, ranksep=0.6, bgcolor="white"];
  node [fontname="Helvetica", fontsize=10, style="filled,rounded", shape=box, color="#444444"];
  edge [fontname="Helvetica", fontsize=9, color="#555555"];

  // =========================
  // 1) Culprit drugs & PK
  // =========================
  subgraph cluster_drug_pk {
    label="① Culprit Drugs & PK / Metabolism";
    style=filled; color="#FFEAEA";
    CBZ   [label="Carbamazepine\n(CBZ)\nCYP3A4→CBZ-10,11-epoxide", fillcolor="#FCA5A5"];
    OXC   [label="Oxcarbazepine\n(OXC)\nMHD active", fillcolor="#FCA5A5"];
    LTG   [label="Lamotrigine\n(LTG)\nUGT1A4 glucuronidation", fillcolor="#FCA5A5"];
    PHT   [label="Phenytoin (PHT)\nCYP2C9/CYP2C19", fillcolor="#FCA5A5"];
    ALL   [label="Allopurinol\n(ALL)→Oxypurinol\nXDH·CL renal", fillcolor="#FCA5A5"];
    SMX   [label="Sulfamethoxazole\n(SMX)\nN-acetyl·NHOH", fillcolor="#FCA5A5"];
    DAPS  [label="Dapsone\n(Dapsone hypersensitivity)", fillcolor="#FCA5A5"];
    NEV   [label="Nevirapine\n(NVP)\nCYP3A/2B6", fillcolor="#FCA5A5"];
    NSAID [label="Oxicam NSAIDs\n(Meloxicam·Piroxicam)", fillcolor="#FCA5A5"];
    ABC   [label="Abacavir (ABC)\n→HLA-B*57:01 AHS", fillcolor="#FCA5A5"];
    PD_metab [label="Reactive metabolite\n(NHOH-SMX·CBZ-EPX)", fillcolor="#FECACA"];
    CBZ   -> PD_metab;
    SMX   -> PD_metab;
    PHT   -> PD_metab;
    LTG   -> PD_metab;
    OXC   -> PD_metab;
  }

  // =========================
  // 2) Pharmacogenomics / HLA risk
  // =========================
  subgraph cluster_pgx {
    label="② Pharmacogenomics — HLA Risk Alleles";
    style=filled; color="#FFF3E0";
    HLAB1502 [label="HLA-B*15:02\n(CBZ, Asian)\nOR ≈ 113", fillcolor="#FCD34D"];
    HLAB5801 [label="HLA-B*58:01\n(Allopurinol)\nOR ≈ 580", fillcolor="#FCD34D"];
    HLAA3101 [label="HLA-A*31:01\n(CBZ, Eur/Japan)\nOR 8–25", fillcolor="#FCD34D"];
    HLAB5701 [label="HLA-B*57:01\n(Abacavir AHS)", fillcolor="#FCD34D"];
    HLAB1301 [label="HLA-B*13:01\n(Dapsone/CBZ Han)", fillcolor="#FCD34D"];
    HLAB3801 [label="HLA-B*38:01\n(SMX, Lamotrigine)", fillcolor="#FCD34D"];
    CYP2C9   [label="CYP2C9*3\n(PHT slow metab)", fillcolor="#FDE68A"];
    TCRclono [label="Restricted public TCR\nclonotypes (Vβ-22-1)\nKo 2011 PNAS", fillcolor="#FEF3C7"];
    HLAB1502 -> TCRclono;
    HLAB5801 -> TCRclono;
    HLAA3101 -> TCRclono;
  }

  // =========================
  // 3) Drug-HLA-TCR antigen presentation
  // =========================
  subgraph cluster_antigen {
    label="③ Drug–HLA–TCR Recognition (Hapten / p-i / Altered Repertoire)";
    style=filled; color="#FFF9C4";
    Hapten  [label="Hapten/prohapten\ncovalent peptide adduct\n(SMX-NHOH·Hg)", fillcolor="#FDE68A"];
    PI      [label="p-i concept\n(Pichler 2002)\ndirect HLA-TCR engagement", fillcolor="#FDE68A"];
    AlteredPep [label="Altered peptide repertoire\n(Illing 2012 Nature·ABC)", fillcolor="#FDE68A"];
    APC     [label="Skin DC / Langerhans\nMHC-I cross-presentation", fillcolor="#FBBF24"];
    HLA_peptide [label="HLA-I + Drug-peptide\ncomplex", fillcolor="#F59E0B", fontcolor="white"];
    TCR_act [label="CD8⁺ T-cell\nclonal activation", fillcolor="#F59E0B", fontcolor="white"];
    PD_metab -> Hapten;
    Hapten -> HLA_peptide;
    PI -> HLA_peptide;
    AlteredPep -> HLA_peptide;
    HLA_peptide -> APC;
    APC -> TCR_act;
    TCRclono -> TCR_act;
  }

  // =========================
  // 4) Cytotoxic effectors
  // =========================
  subgraph cluster_effectors {
    label="④ Cytotoxic Effectors & Cytokines";
    style=filled; color="#E0E7FF";
    CD8     [label="Drug-specific CD8⁺ CTL\n(skin-homing CLA⁺ CCR10⁺)", fillcolor="#818CF8", fontcolor="white"];
    NK      [label="NK / NKT cells\n(IL-15-licensed)", fillcolor="#818CF8", fontcolor="white"];
    Granulysin [label="Granulysin\n(15 kDa secretory)\nChung 2008 Nat Med", fillcolor="#A5B4FC"];
    Perforin  [label="Perforin / Granzyme B", fillcolor="#A5B4FC"];
    FasL    [label="Soluble FasL\n(sFasL)", fillcolor="#A5B4FC"];
    TNFa    [label="TNF-α", fillcolor="#A5B4FC"];
    IFNg    [label="IFN-γ", fillcolor="#A5B4FC"];
    IL15    [label="IL-15\nT-cell licensing", fillcolor="#A5B4FC"];
    HMGB1   [label="HMGB1\n(DAMP)", fillcolor="#C7D2FE"];
    miR     [label="miR-18a-5p\nblister fluid", fillcolor="#C7D2FE"];
    TCR_act -> CD8;
    CD8 -> Granulysin;
    CD8 -> Perforin;
    CD8 -> FasL;
    CD8 -> TNFa;
    CD8 -> IFNg;
    IL15 -> CD8;
    IL15 -> NK;
    NK -> Granulysin;
    NK -> FasL;
  }

  // =========================
  // 5) Keratinocyte death & epidermal pathology
  // =========================
  subgraph cluster_kerato {
    label="⑤ Keratinocyte Apoptosis / Necroptosis";
    style=filled; color="#FDE2E2";
    KC      [label="Epidermal keratinocyte", fillcolor="#FCA5A5"];
    Fas     [label="Fas (CD95)", fillcolor="#FDA4AF"];
    Caspase8 [label="Caspase-8", fillcolor="#FDA4AF"];
    Caspase3 [label="Caspase-3 cleaved", fillcolor="#FDA4AF"];
    Necroptosis [label="MLKL/RIPK3 necroptosis", fillcolor="#FDA4AF"];
    PoreLysis [label="Granulysin pore lysis", fillcolor="#FDA4AF"];
    KC_apop [label="Massive KC apoptosis\n(full thickness)", fillcolor="#F87171", fontcolor="white"];
    Epi_detach [label="Subepidermal\ndetachment / Nikolsky+", fillcolor="#EF4444", fontcolor="white"];
    FasL -> Fas;
    Fas -> Caspase8;
    Caspase8 -> Caspase3;
    Perforin -> Caspase3;
    Granulysin -> PoreLysis;
    Granulysin -> Necroptosis;
    TNFa -> Necroptosis;
    Caspase3 -> KC_apop;
    PoreLysis -> KC_apop;
    Necroptosis -> KC_apop;
    KC -> KC_apop;
    KC_apop -> Epi_detach;
    KC_apop -> HMGB1;
  }

  // =========================
  // 6) Clinical phenotype & SCORTEN
  // =========================
  subgraph cluster_clinical {
    label="⑥ Clinical Phenotype & Severity (SCORTEN)";
    style=filled; color="#E0F2FE";
    SJS     [label="SJS\nBSA detachment <10%", fillcolor="#7DD3FC"];
    Overlap [label="SJS/TEN overlap\n10–30%", fillcolor="#38BDF8", fontcolor="white"];
    TEN     [label="TEN\n>30% BSA detachment", fillcolor="#0EA5E9", fontcolor="white"];
    Mucositis [label="Mucosal involvement\nocular·oral·GU >90%", fillcolor="#BAE6FD"];
    SCORTEN [label="SCORTEN (Bastuji-Garin 2000)\nAge·BSA·HR·BUN·Glc·HCO3·Ca", fillcolor="#0284C7", fontcolor="white"];
    Mortality [label="Mortality\nSJS 5% · TEN 25–35%", fillcolor="#0369A1", fontcolor="white"];
    Epi_detach -> SJS;
    Epi_detach -> Overlap;
    Epi_detach -> TEN;
    SJS -> SCORTEN;
    TEN -> SCORTEN;
    SCORTEN -> Mortality;
    Mucositis -> SCORTEN;
  }

  // =========================
  // 7) Mucosal & systemic complications
  // =========================
  subgraph cluster_systemic {
    label="⑦ Mucosal & Systemic Complications";
    style=filled; color="#F3E8FF";
    Ocular  [label="Ocular sequelae\nsymblepharon·dry eye·blindness", fillcolor="#C4B5FD"];
    Oral    [label="Oral mucositis\nodynophagia·dehydration", fillcolor="#C4B5FD"];
    GU      [label="Urogenital erosion·strictures", fillcolor="#C4B5FD"];
    Sepsis  [label="Bacteremia / sepsis\nMRSA·Pseudomonas", fillcolor="#A78BFA", fontcolor="white"];
    ARDS    [label="Pulmonary epithelial\nshedding·ARDS", fillcolor="#A78BFA", fontcolor="white"];
    AKI     [label="Acute kidney injury\nhypovolemic / sepsis", fillcolor="#A78BFA", fontcolor="white"];
    GI_bld  [label="GI mucosal hemorrhage", fillcolor="#A78BFA", fontcolor="white"];
    Hypothermia [label="Hypothermia /\nthermoregulation loss", fillcolor="#C4B5FD"];
    Fluid   [label="Massive fluid loss\nhypovolemia·shock", fillcolor="#A78BFA", fontcolor="white"];
    Mucositis -> Ocular;
    Mucositis -> Oral;
    Mucositis -> GU;
    Epi_detach -> Sepsis;
    Epi_detach -> Fluid;
    Fluid -> AKI;
    Epi_detach -> Hypothermia;
    Mucositis -> ARDS;
    Mucositis -> GI_bld;
  }

  // =========================
  // 8) Pharmacologic interventions
  // =========================
  subgraph cluster_rx {
    label="⑧ Pharmacologic & Supportive Treatment";
    style=filled; color="#DCFCE7";
    Withdraw  [label="Prompt drug withdrawal\n(Garcia-Doval 2000 ADHR)", fillcolor="#86EFAC"];
    IVIG      [label="IVIG 1 g/kg/day×3-4\nanti-FasL\n(Viard 1998 Science)", fillcolor="#4ADE80"];
    CsA       [label="Cyclosporine 3–5 mg/kg/d\ncalcineurin block\n(Valeyrie-Allanore 2010)", fillcolor="#4ADE80"];
    Etanercept [label="Etanercept 25–50 mg SC\nanti-TNF\n(Wang 2018 JCI RCT)", fillcolor="#4ADE80"];
    Infliximab [label="Infliximab 5 mg/kg\nanti-TNF chim", fillcolor="#4ADE80"];
    Cortico   [label="Methylprednisolone\n1–2 mg/kg pulse", fillcolor="#4ADE80"];
    TPE       [label="Therapeutic plasma\nexchange (TPE)", fillcolor="#86EFAC"];
    JAKi      [label="JAK1/2 inhibitor\n(tofacitinib·ruxolitinib)\nKim 2020 Lancet", fillcolor="#86EFAC"];
    SupCare   [label="ICU / burn unit\nfluids·nutrition·wound", fillcolor="#86EFAC"];
    Antimicrob [label="Topical antiseptic\n+ targeted antibiotics", fillcolor="#86EFAC"];
    Wound     [label="Non-adhesive dressings\namnion / Biobrane", fillcolor="#86EFAC"];
    EyeCare   [label="Amniotic membrane\ntransplant (Gregory)", fillcolor="#86EFAC"];
    HLAscreen [label="Pre-prescription\nHLA-B*15:02/58:01 screen\n(Chen 2011 NEJM)", fillcolor="#86EFAC"];
    HLAscreen -> Withdraw [style=dashed];
    Withdraw -> CD8 [color=darkgreen, style=bold, arrowhead=tee, label="↓antigen"];
    IVIG -> FasL [color=darkgreen, style=bold, arrowhead=tee];
    CsA -> CD8 [color=darkgreen, style=bold, arrowhead=tee];
    Etanercept -> TNFa [color=darkgreen, style=bold, arrowhead=tee];
    Infliximab -> TNFa [color=darkgreen, style=bold, arrowhead=tee];
    Cortico -> CD8 [color=darkgreen, style=bold, arrowhead=tee];
    TPE -> Granulysin [color=darkgreen, style=bold, arrowhead=tee];
    JAKi -> IFNg [color=darkgreen, style=bold, arrowhead=tee];
    SupCare -> Mortality [color=darkgreen, style=bold, arrowhead=tee];
    Antimicrob -> Sepsis [color=darkgreen, style=bold, arrowhead=tee];
    Wound -> Epi_detach [color=darkgreen, style=bold, arrowhead=tee, label="re-epi"];
    EyeCare -> Ocular [color=darkgreen, style=bold, arrowhead=tee];
  }

  // =========================
  // 9) Biomarkers & companion diagnostics
  // =========================
  subgraph cluster_bio {
    label="⑨ Biomarkers & Companion Diagnostics";
    style=filled; color="#FCE7F3";
    Bio_GNLY  [label="Serum granulysin\nELISA (Fujita 2011)", fillcolor="#F472B6", fontcolor="white"];
    Bio_sFasL [label="Serum sFasL\n(Murata 2008)", fillcolor="#F472B6", fontcolor="white"];
    Bio_IL15  [label="Serum IL-15\nSu 2017", fillcolor="#F472B6", fontcolor="white"];
    Bio_HMGB1 [label="Serum HMGB1\nNakajima 2011", fillcolor="#F472B6", fontcolor="white"];
    LympTransf [label="Lymphocyte transformation\ntest (LTT)", fillcolor="#FBCFE8"];
    ELISpot   [label="IFN-γ ELISpot\ndrug-specific T cells", fillcolor="#FBCFE8"];
    SCORTENlab [label="BUN·Glc·HCO3·Ca\nSCORTEN labs", fillcolor="#FBCFE8"];
    Granulysin -> Bio_GNLY;
    FasL -> Bio_sFasL;
    IL15 -> Bio_IL15;
    HMGB1 -> Bio_HMGB1;
    CD8 -> ELISpot;
    PD_metab -> LympTransf;
    Bio_GNLY -> SCORTEN [style=dotted];
    Bio_sFasL -> SCORTEN [style=dotted];
  }

  // =========================
  // 10) Re-epithelialization & long-term sequelae
  // =========================
  subgraph cluster_reepi {
    label="⑩ Re-epithelialization & Long-term Sequelae";
    style=filled; color="#ECFCCB";
    StemKC   [label="Hair follicle bulge\nstem cells (LGR5)", fillcolor="#BEF264"];
    EGF      [label="EGF / KGF / TGF-α\nbasal proliferation", fillcolor="#BEF264"];
    ReEpi    [label="Re-epithelialization\n14–21 days", fillcolor="#A3E635"];
    Scarring [label="Hypertrophic scars\ndyspigmentation·nail dystrophy", fillcolor="#A3E635"];
    DryEye   [label="Chronic dry eye\nMeibomian dysfunction", fillcolor="#A3E635"];
    PTSD     [label="PTSD / depression\npost-SJS", fillcolor="#A3E635"];
    Recur    [label="Re-exposure / cross-reactive\ndrug recurrence", fillcolor="#A3E635"];
    StemKC -> EGF;
    EGF -> ReEpi;
    ReEpi -> Scarring;
    ReEpi -> DryEye;
    ReEpi -> PTSD;
    Withdraw -> Recur [arrowhead=tee, style=dashed, color="#15803D"];
  }

  // =========================
  // Cross-cluster regulators
  // =========================
  Pathways_NFkB [label="NF-κB / STAT1\ndownstream", fillcolor="#E5E7EB"];
  IFNg -> Pathways_NFkB;
  TNFa -> Pathways_NFkB;
  Pathways_NFkB -> KC_apop [style=dashed];

  Regulators_Treg [label="Treg dysfunction\nFOXP3↓", fillcolor="#E5E7EB"];
  Regulators_Treg -> CD8 [arrowhead=tee, label="↓suppression"];

  Genetics_TCR [label="TCR-V β skewing\n(Ko 2011·Tanaka 2024)", fillcolor="#E5E7EB"];
  Genetics_TCR -> TCR_act;

  Predisposition [label="Active autoimmune\nor viral infection\n(HHV-6·EBV·HIV)", fillcolor="#E5E7EB"];
  Predisposition -> CD8 [label="bystander"];

  // Endpoint nodes
  SCORTEN_predict [label="Predicted vs Actual\nMortality (Bastuji-Garin)", fillcolor="#9CA3AF", fontcolor="white"];
  SCORTEN -> SCORTEN_predict;
  SCORTEN_predict -> Mortality;

  TimeToReEpi [label="Time to re-epithelialization\n(t_re)", fillcolor="#9CA3AF", fontcolor="white"];
  ReEpi -> TimeToReEpi;

  // Drug PK -> APC link
  ALL -> APC [label="oxypurinol"];
  ABC -> AlteredPep;
  NEV -> APC;
  NSAID -> APC;
  DAPS -> APC;

  // SCORTEN labs to mortality
  SCORTENlab -> SCORTEN;

  // Final hazard
  Hazard [label="Per-day mortality hazard\nλ(t) = baseline × exp(β·SCORTEN)\n× treatment effect", fillcolor="#1F2937", fontcolor="white"];
  Mortality -> Hazard;
  IVIG -> Hazard [arrowhead=tee, color=darkgreen];
  CsA -> Hazard [arrowhead=tee, color=darkgreen];
  Etanercept -> Hazard [arrowhead=tee, color=darkgreen];
}
