digraph UrolithiasisQSP {
    graph [
        label="Chronic Recurrent Urolithiasis — Quantitative Systems Pharmacology Model\nCalcium Oxalate · Calcium Phosphate · Uric Acid · Struvite · Cystine Nephrolithiasis",
        fontsize=20, fontname="Helvetica-Bold",
        rankdir=LR, splines=curved, nodesep=0.4, ranksep=1.2,
        bgcolor="#FAFAFA", concentrate=true, overlap=false
    ]
    node [fontname="Helvetica", fontsize=9, style=filled, shape=box, margin="0.12,0.06"]
    edge [fontname="Helvetica", fontsize=7, arrowsize=0.6]

    // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
    // CLUSTER 1: Patient & Environmental Risk Factors
    // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
    subgraph cluster_patient {
        label="Patient & Environmental Risk Factors"
        style=filled bgcolor="#E3F2FD" color="#1565C0" penwidth=2 fontsize=13

        Age           [label="Age / Sex\n(male ↑ risk)", fillcolor="#90CAF9"]
        BMI           [label="BMI / Obesity", fillcolor="#90CAF9"]
        GeneticRisk   [label="Genetic Risk\n(SLC34A1, CaSR,\nCLCN5, UMOD)", fillcolor="#64B5F6"]
        DietCalcium   [label="Dietary Calcium\n(mg/day)", fillcolor="#80DEEA"]
        DietOxalate   [label="Dietary Oxalate\n(mg/day)", fillcolor="#80DEEA"]
        DietProtein   [label="Animal Protein\nIntake (g/day)", fillcolor="#80DEEA"]
        DietSodium    [label="Dietary Sodium\n(mEq/day)", fillcolor="#80DEEA"]
        DietFructose  [label="Fructose / Sugar\nIntake (g/day)", fillcolor="#80DEEA"]
        FluidIntake   [label="Fluid Intake\n(L/day)", fillcolor="#A5D6A7"]
        Urine_Volume  [label="Urine Volume\n(L/day)", fillcolor="#A5D6A7"]
        GutMicrobiome [label="Gut Microbiome\n(Oxalobacter\nformigenes)", fillcolor="#CE93D8"]
        IBD_Comorbid  [label="IBD / Bariatric\nSurgery / Fat\nMalabsorption", fillcolor="#CE93D8"]
        Hypert_Comorbid [label="Hypertension\nComorbidity", fillcolor="#EF9A9A"]
        MetabSyndrome [label="Metabolic\nSyndrome /\nInsulin Resistance", fillcolor="#EF9A9A"]
        HPT_Primary   [label="Primary\nHyperparathyroid-\nism (PTH↑↑)", fillcolor="#EF9A9A"]
        RaceEthnicity [label="Race/Ethnicity\n(White ↑ Ca risk,\nBlack ↓ risk)", fillcolor="#90CAF9"]
        Climate       [label="Hot Climate /\nHigh Temperature\n(dehydration)", fillcolor="#90CAF9"]
        Occupation    [label="Occupation\n(outdoor workers)", fillcolor="#90CAF9"]
        PriorStone    [label="Prior Stone\nHistory", fillcolor="#EF9A9A"]
    }

    // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
    // CLUSTER 2: Calcium Homeostasis
    // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
    subgraph cluster_calcium {
        label="Calcium Homeostasis"
        style=filled bgcolor="#FFFDE7" color="#F9A825" penwidth=2 fontsize=13

        PTH              [label="PTH\n(pg/mL)", fillcolor="#FFF176", shape=ellipse]
        VitD25           [label="25(OH)D\n(Calcidiol)\n(ng/mL)", fillcolor="#FFF176"]
        VitD3            [label="1,25(OH)₂D\n(Calcitriol)\n(pg/mL)", fillcolor="#FFD54F"]
        Calcitonin       [label="Calcitonin\n(pg/mL)", fillcolor="#FFF176"]
        FGF23            [label="FGF-23\n(RU/mL)", fillcolor="#FFB74D"]
        Klotho           [label="α-Klotho\n(co-receptor)", fillcolor="#FFCC02"]
        CaSR             [label="CaSR\n(Ca-Sensing\nReceptor)", fillcolor="#FFD54F"]
        SerumCa          [label="Serum Ca²⁺\n(mg/dL)", fillcolor="#FFD54F", shape=ellipse]
        IonizedCa        [label="Ionized Ca²⁺\n(mmol/L)", fillcolor="#FFD54F"]
        Albumin          [label="Serum Albumin\n(g/dL)", fillcolor="#FFF176"]
        GutCaAbsorption  [label="Intestinal Ca²⁺\nAbsorption\n(TRPV6, CB-D9k)", fillcolor="#FFD54F"]
        BoneResorption   [label="Bone Resorption\n(CTX, NTX ↑)", fillcolor="#FFCC80"]
        BoneFormation    [label="Bone Formation\n(P1NP, ALP)", fillcolor="#FFCC80"]
        RenalCaReabsorb  [label="Renal Ca²⁺\nReabsorption\n(DCT: TRPV5)", fillcolor="#FFD54F"]
        UrinaryCa        [label="Urinary Ca²⁺\n(mg/day)", fillcolor="#FF8F00", shape=ellipse]
        Hypercalciuria   [label="Hypercalciuria\n(>250 mg/d F\n>300 mg/d M)", fillcolor="#F4511E"]
        Absorptive_HCa   [label="Absorptive\nHypercalciuria\n(Type I/II/III)", fillcolor="#BF360C"]
        Renal_CaLeak     [label="Renal Calcium\nLeak (TRPV5 mut.)", fillcolor="#BF360C"]
        PTH_Resorp_HCa   [label="Resorptive\nHypercalciuria\n(HPT)", fillcolor="#BF360C"]
        BMD              [label="Bone Mineral\nDensity (BMD)", fillcolor="#FFCC80"]
        Fracture_Risk    [label="Fracture Risk\n(FRAX score)", fillcolor="#FFCC80"]
    }

    // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
    // CLUSTER 3: Oxalate Metabolism
    // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
    subgraph cluster_oxalate {
        label="Oxalate Metabolism"
        style=filled bgcolor="#E8F5E9" color="#2E7D32" penwidth=2 fontsize=13

        Glyoxylate_Hepatic [label="Hepatic Glyoxylate\nPathway\n(AGXT, GRHPR,\nHOGA1)", fillcolor="#A5D6A7"]
        Oxalate_Hepatic    [label="Hepatic Oxalate\nSynthesis\n(mg/day)", fillcolor="#81C784"]
        Ascorbate_Ox       [label="Ascorbate → OX\n(Vit C >1g/day)", fillcolor="#C8E6C9"]
        Hydroxyproline_Ox  [label="Hydroxyproline\n→ Glyoxylate\n(collagen catab.)", fillcolor="#C8E6C9"]
        Ox_GutAbsorption   [label="Dietary Oxalate\nGut Absorption\n(SLC26A1/A6)", fillcolor="#81C784"]
        Ox_Colonic_Degr    [label="Colonic Oxalate\nDegradation\n(Oxalobacter f.)", fillcolor="#A5D6A7"]
        VitB6              [label="Vitamin B6\n(AGXT cofactor\nfor AGXT)", fillcolor="#DCEDC8"]
        Ox_Plasma          [label="Plasma Oxalate\n(μmol/L)", fillcolor="#66BB6A", shape=ellipse]
        UrinaryOxalate     [label="Urinary Oxalate\n(mg/day)", fillcolor="#2E7D32", shape=ellipse]
        PH1_AGXT           [label="Primary Hyperox.\nType 1 (AGXT mut.)\n>80 mg/day", fillcolor="#1B5E20"]
        PH2_GRHPR          [label="Primary Hyperox.\nType 2 (GRHPR)", fillcolor="#1B5E20"]
        PH3_HOGA1          [label="Primary Hyperox.\nType 3 (HOGA1)", fillcolor="#1B5E20"]
        Enteric_Hyperox    [label="Enteric Hyperox.\n(fat malabsorption\n→ soap↑ → OX↑)", fillcolor="#2E7D32"]
        Dietary_Hyperox    [label="Dietary Hyperox.\n(>45 mg/day)", fillcolor="#388E3C"]
        Ox_Tubular         [label="Renal Tubular\nOxalate Handling\n(SLC26A1, Sat-1)", fillcolor="#A5D6A7"]
    }

    // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
    // CLUSTER 4: Uric Acid Metabolism
    // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
    subgraph cluster_uricacid {
        label="Uric Acid Metabolism"
        style=filled bgcolor="#FCE4EC" color="#880E4F" penwidth=2 fontsize=13

        Purine_Diet       [label="Dietary Purines\n(meat, organ,\nseafood)", fillcolor="#F8BBD9"]
        Purine_Endogenous [label="Endogenous Purine\nSynthesis /\nCell Turnover", fillcolor="#F8BBD9"]
        Xanthine_Ox       [label="Xanthine Oxidase\n(XO / XDH)", fillcolor="#F48FB1", shape=ellipse]
        Hypoxanthine      [label="Hypoxanthine\n→ Xanthine", fillcolor="#F8BBD9"]
        UA_Plasma         [label="Plasma Uric Acid\n(mg/dL)", fillcolor="#EC407A", shape=ellipse]
        URAT1             [label="URAT1\n(SLC22A12)\nrenal reabsorption", fillcolor="#F48FB1"]
        OAT1_OAT3         [label="OAT1/OAT3\ntubular secretion", fillcolor="#F48FB1"]
        ABCG2             [label="ABCG2\nIntestinal /\nrenal secretion", fillcolor="#F48FB1"]
        GLUT9             [label="GLUT9/SLC2A9\nproximal tubule", fillcolor="#F48FB1"]
        NPT4              [label="NPT4/SLC17A3\nurate secretion", fillcolor="#F8BBD9"]
        UrinaryUA         [label="Urinary Uric Acid\n(mg/day)", fillcolor="#AD1457", shape=ellipse]
        Hyperuricosuria   [label="Hyperuricosuria\n(>750 mg/d F\n>800 mg/d M)", fillcolor="#880E4F"]
        Urine_pH_UA       [label="Urine pH <5.5\n→ UA pptn.", fillcolor="#880E4F"]
        Ammonia_Prod      [label="Renal NH₄⁺\nProduction\n(NH₃ buffer)", fillcolor="#F8BBD9"]
        Insulin_Resist    [label="Insulin Resistance\n→ ↓NH₄⁺ excretion\n→ pH ↓", fillcolor="#F48FB1"]
    }

    // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
    // CLUSTER 5: Renal Tubular & Citrate Handling
    // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
    subgraph cluster_renal_tubular {
        label="Renal Tubular Handling"
        style=filled bgcolor="#EDE7F6" color="#4527A0" penwidth=2 fontsize=13

        GFR              [label="GFR\n(mL/min/1.73m²)", fillcolor="#D1C4E9", shape=ellipse]
        Proximal_Tubule  [label="Proximal Tubule\n(NHE3, NaPi-IIa/c)", fillcolor="#B39DDB"]
        TAL              [label="Thick Ascending\nLimb (NKCC2)", fillcolor="#9575CD"]
        DCT              [label="Distal Convoluted\nTubule (NCC, TRPV5)", fillcolor="#9575CD"]
        Citrate_Renal    [label="Renal Citrate\nReabsorption\n(NaDC-1/SLC13A2)", fillcolor="#B39DDB"]
        Citrate_Urine    [label="Urinary Citrate\n(mg/day)", fillcolor="#7E57C2", shape=ellipse]
        Hypocitraturia   [label="Hypocitraturia\n(<320 mg/day)", fillcolor="#4527A0"]
        Phosphate_Renal  [label="Renal Phosphate\nHandling (NaPi)", fillcolor="#B39DDB"]
        UrinaryPO4       [label="Urinary Phosphate\n(mg/day)", fillcolor="#9575CD"]
        Urine_pH         [label="Urine pH\n(4.5 – 8.0)", fillcolor="#7E57C2", shape=ellipse]
        Urine_OsM        [label="Urine Osmolality\n(mOsm/kg)", fillcolor="#B39DDB"]
        MagUrine         [label="Urinary Mg²⁺\n(mg/day)", fillcolor="#B39DDB"]
        Bicarbonate      [label="Renal HCO₃⁻\nHandling\n(AE1, H-ATPase)", fillcolor="#9575CD"]
        RTA_Type1        [label="Distal RTA\n(Type 1)\nalkalized urine", fillcolor="#4527A0"]
        RTA_Type2        [label="Proximal RTA\n(Fanconi)", fillcolor="#4527A0"]
        SodiumExcretion  [label="Urinary Na⁺\n(mEq/day)", fillcolor="#B39DDB"]
        KExcretion       [label="Urinary K⁺\n(mEq/day)", fillcolor="#B39DDB"]
        CreatinineUrine  [label="Urinary Creatinine\n(mg/day)", fillcolor="#D1C4E9"]
    }

    // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
    // CLUSTER 6: Urine Supersaturation & Crystal Formation
    // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
    subgraph cluster_supersaturation {
        label="Urine Supersaturation & Crystal Formation"
        style=filled bgcolor="#FBE9E7" color="#BF360C" penwidth=2 fontsize=13

        CaOx_SS        [label="CaOx Supersatur.\n(EQUIL2/LithoRisk)", fillcolor="#FFAB91", shape=ellipse]
        CaP_SS         [label="CaP (Brushite)\nSupersatur.", fillcolor="#FF8A65", shape=ellipse]
        UA_SS          [label="Uric Acid\nSupersatur.", fillcolor="#FF7043", shape=ellipse]
        Cystine_SS     [label="Cystine\nSupersatur.", fillcolor="#FF5722", shape=ellipse]
        Struvite_SS    [label="Struvite (MAP)\nSupersatur.", fillcolor="#E64A19"]
        Ion_Activity   [label="Ionic Activity\nProduct (IAP)", fillcolor="#FFAB91"]
        Ksp_CaOx       [label="Ksp CaOx\n(2.57×10⁻⁹)", fillcolor="#FFF3E0"]
        Ksp_CaP        [label="Ksp Brushite\n(2.35×10⁻⁷)", fillcolor="#FFF3E0"]
        Nucleation_Hom [label="Homogeneous\nNucleation\n(IAP >> Ksp)", fillcolor="#FF8A65"]
        Nucleation_Het [label="Heterogeneous\nNucleation\n(on existing crystals)", fillcolor="#FF8A65"]
        Crystal_Growth [label="Crystal Growth\nKinetics\n(dV/dt ∝ σⁿ)", fillcolor="#FF7043"]
        Crystal_Aggr   [label="Crystal\nAggregation /\nAgglomeration", fillcolor="#FF7043"]
        Crystal_Inhib  [label="Crystal Growth\nInhibitors\n(OPN, THP, Bikunin)", fillcolor="#FBE9E7"]
        Nephrocalcin   [label="Osteopontin\n(OPN / SPP1)", fillcolor="#E8D5B7"]
        THP            [label="Tamm-Horsfall\nProtein (Uromodulin)", fillcolor="#E8D5B7"]
        Bikunin        [label="Bikunin\n(Crystal inhibitor)", fillcolor="#E8D5B7"]
        Prothrombin_F1 [label="Prothrombin\nFragment 1", fillcolor="#E8D5B7"]
        Crystal_Retain [label="Crystal Retention\nat Epithelium", fillcolor="#D84315"]
        Randalls_Plaque[label="Randall's Plaque\n(subepithelial\napatite deposits)", fillcolor="#BF360C"]
        Stone_Nucleus  [label="Stone Nucleus\nFormation", fillcolor="#BF360C"]
        Stone_Growth   [label="Stone Growth\n(mm/year)", fillcolor="#BF360C"]
        CaOx_SS_ratio  [label="CaOx SS Ratio\n(target <1.0)", fillcolor="#FFAB91"]
    }

    // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
    // CLUSTER 7: Stone Types & Composition
    // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
    subgraph cluster_stone_types {
        label="Stone Types & Composition"
        style=filled bgcolor="#F3E5F5" color="#6A1B9A" penwidth=2 fontsize=13

        CaOx_Stone    [label="Calcium Oxalate\n(70-75%)\nWhewellite /\nWeddellite", fillcolor="#CE93D8"]
        CaP_Stone     [label="Calcium Phosphate\n(5-15%)\nHydroxyapatite /\nBrushite", fillcolor="#BA68C8"]
        UA_Stone      [label="Uric Acid Stone\n(8-10%)\nRadiolucent on\nplain X-ray", fillcolor="#AB47BC"]
        Struvite_Stone[label="Struvite (MAP)\nInfection Stone\nNH₄MgPO₄·6H₂O", fillcolor="#9C27B0"]
        Cystine_Stone [label="Cystine Stone\n(<1%)\n(Cystinuria:\nSLC3A1/SLC7A9)", fillcolor="#7B1FA2"]
        Mixed_Stone   [label="Mixed Composition\n(CaOx + CaP\nor UA + CaOx)", fillcolor="#D1C4E9"]
        Stone_Size    [label="Stone Size\n(mm)", fillcolor="#CE93D8", shape=ellipse]
        Stone_Location[label="Stone Location\n(Calyx/UPJ/\nUreter/Bladder)", fillcolor="#CE93D8"]
        Stone_Burden  [label="Total Stone\nBurden (cm²)", fillcolor="#AB47BC", shape=ellipse]
        Spontaneous_P [label="Spontaneous\nPassage Rate\n<5mm:70%,5-10mm:50%\n>10mm:<20%", fillcolor="#7E57C2"]
        Stone_Morphol [label="Stone Morphology\n(smooth/spiky)\nHU on CT", fillcolor="#CE93D8"]
        Staghorn      [label="Staghorn\nCalculus\n(full/partial)", fillcolor="#6A1B9A"]
    }

    // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
    // CLUSTER 8: Drug PK / PD
    // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
    subgraph cluster_drug {
        label="Drug PK/PD & Therapeutic Interventions"
        style=filled bgcolor="#E8F5E9" color="#1B5E20" penwidth=2 fontsize=13

        // ── Thiazide diuretics ──
        HCTZ_Dose     [label="HCTZ/Chlorthalidone\nDose (mg/day)", fillcolor="#A5D6A7", shape=diamond]
        HCTZ_Gut      [label="Thiazide Gut\nAbsorption (F=0.65)", fillcolor="#81C784"]
        HCTZ_Plasma   [label="Thiazide Plasma\nConc. (mg/L)", fillcolor="#66BB6A"]
        HCTZ_DCT      [label="NCC Inhibition\n(DCT Na⁺-Cl⁻\ncotransporter)", fillcolor="#43A047"]
        HCTZ_Ca       [label="↑Distal Ca²⁺\nReabsorption\n→ Hypocalciuria", fillcolor="#2E7D32"]

        // ── Allopurinol / Febuxostat ──
        Allo_Dose     [label="Allopurinol\nDose (mg/day)", fillcolor="#A5D6A7", shape=diamond]
        Allo_Plasma   [label="Allopurinol\nPlasma Conc.\n(F≈0.90)", fillcolor="#81C784"]
        Oxypurinol    [label="Oxypurinol\n(active metabolite\nt½=18-30h)", fillcolor="#66BB6A"]
        XO_Inhib_Allo [label="XO Inhibition\n(IC₅₀=0.7µM)\n→ ↓UA production", fillcolor="#2E7D32"]

        Feb_Dose      [label="Febuxostat\n40-80mg/day", fillcolor="#A5D6A7", shape=diamond]
        Feb_Plasma    [label="Febuxostat\nPlasma Conc.\n(F≈0.84)", fillcolor="#81C784"]
        XO_Inhib_Feb  [label="Non-purine XO\nInhibition\n(selective)", fillcolor="#2E7D32"]

        // ── Potassium Citrate ──
        KCit_Dose     [label="Potassium Citrate\n(mEq/day)\n30-60 mEq/day", fillcolor="#A5D6A7", shape=diamond]
        KCit_Gut      [label="Citrate GI\nAbsorption", fillcolor="#81C784"]
        KCit_Plasma   [label="Plasma Citrate\nElevation", fillcolor="#66BB6A"]
        KCit_Urine    [label="↑Urinary Citrate\n+ Urine pH ↑\n+ K⁺ excretion", fillcolor="#2E7D32"]

        // ── Tamsulosin (MET) ──
        Tamsulosin    [label="Tamsulosin\n0.4mg/day\n(MET)", fillcolor="#A5D6A7", shape=diamond]
        Alpha1_Block  [label="α₁A/D-adrenoceptor\nBlockade (Ureter)", fillcolor="#81C784"]
        Ureteral_Relax[label="Ureteral Smooth\nMuscle Relaxation\n→ ↑passage rate", fillcolor="#43A047"]

        // ── Lumasiran (siRNA for PH1) ──
        Lumasiran     [label="Lumasiran\n(siRNA – PH1)\nGalNAc conjugate", fillcolor="#A5D6A7", shape=diamond]
        Lumasiran_Liv [label="Hepatic HAGO1\nSuppression\n→ ↓Glyoxylate", fillcolor="#43A047"]

        // ── Nedosiran (HAO1 siRNA) ──
        Nedosiran     [label="Nedosiran\n(HAO1 siRNA – PH1)", fillcolor="#A5D6A7", shape=diamond]
        Nedosiran_Liv [label="↓HAO1\n→ ↓Glycolate OX\n→ ↓Oxalate", fillcolor="#43A047"]

        // ── AHA (Struvite) ──
        AHA_Dose      [label="Acetohydroxamic\nAcid (AHA)\nUrease inhibitor", fillcolor="#A5D6A7", shape=diamond]
        Urease_Inhib  [label="Urease Inhibition\n→ ↓NH₄⁺\n→ ↓Struvite SS", fillcolor="#43A047"]

        // ── Tiopronin (Cystine) ──
        Tiopronin     [label="Tiopronin\n(D-Pen alt.)\nCystine stone", fillcolor="#A5D6A7", shape=diamond]
        Cystine_Bind  [label="Cystine-Tiopronin\nDisulfide Mix.\n→ ↑Cystine solub.", fillcolor="#43A047"]

        // ── Dietary / Lifestyle Rx ──
        Fluid_Rx      [label="Hydration Rx\n(>2.5 L/day\nurine output)", fillcolor="#C8E6C9", shape=diamond]
        LowOx_Diet    [label="Low-Oxalate Diet\n(<50 mg/day)", fillcolor="#C8E6C9", shape=diamond]
        LowNa_Diet    [label="Low-Na Diet\n(<100 mEq/day)", fillcolor="#C8E6C9", shape=diamond]
        NormCa_Diet   [label="Normal Calcium\nDiet (1000 mg/day)\n(NOT low-Ca)", fillcolor="#C8E6C9", shape=diamond]
