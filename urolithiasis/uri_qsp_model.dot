    Renal_Colic -> ED_Visit [label="acute pain"]
    Renal_Colic -> Hospitaliz [label="IV meds\nneed"]
    Renal_Colic -> QoL [label="↓QoL"]
    Stone_Recurr -> Stone_Burden [label="new stones\naccumulate"]
    PriorStone -> Stone_Recurr [label="50% 5yr\nrecurrence"]
    CKD_Progr -> CKD_Stage [label="eGFR staging"]
    CKD_Stage -> ESRD_Risk [label="late stage\n→ ESRD"]
    HTN_Risk -> CVD_Risk [label="shared\nrisk"]
    Bone_Loss -> Fracture_Risk [label="BMD ↓"]

    // Imaging connections
    Obstruction -> US_Kidney [label="hydronephrosis\ndetection"]
    UA_Stone -> KUB [label="NOT seen\n(radiolucent)"]

    // 24h Urine → SS Report → Recurrence
    U24_Ca -> SS_Report
    U24_Ox -> SS_Report
    U24_UA -> SS_Report
    U24_Cit -> SS_Report
    U24_Vol -> SS_Report
    U24_pH -> SS_Report
    U24_Na -> SS_Report
    SS_Report -> Stone_Recurr [label="risk\nestimation"]
    SS_Report -> CaOx_SS_ratio

    // Procedure outcomes
    Spontaneous_P -> Stone_Free [label="natural\nresolution"]
