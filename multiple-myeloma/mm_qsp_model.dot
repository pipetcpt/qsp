digraph MultipleMyeloma_QSP {
    graph [
        label="Multiple Myeloma QSP Mechanistic Map\nBone Marrow Microenvironment · Myeloma Cell Biology · Drug PK/PD · Clinical Endpoints"
        labelloc="t"
        fontname="Helvetica"
        fontsize=20
        fontcolor="#1a1a2e"
        bgcolor="#f8f9fa"
        rankdir=LR
        splines=ortho
        nodesep=0.4
        ranksep=1.2
        compound=true
        overlap=false
    ]

    node [fontname="Helvetica" fontsize=9 style="filled,rounded" shape=box width=1.4 height=0.35]
    edge [fontname="Helvetica" fontsize=7 arrowsize=0.7]

    /* =====================================================================
       CLUSTER 1: NORMAL PLASMA CELL DIFFERENTIATION
       ===================================================================== */
    subgraph cluster_plasmacell_diff {
        label="Plasma Cell Differentiation"
        style="filled,rounded"
        fillcolor="#e8f4f8"
        color="#0077b6"
        fontcolor="#0077b6"
        fontsize=11

        HSC [label="HSC\n(Hematopoietic\nStem Cell)" fillcolor="#90cdf4" color="#2b6cb0"]
        CLP [label="CLP\n(Common Lymphoid\nProgenitor)" fillcolor="#90cdf4" color="#2b6cb0"]
        ProB [label="Pro-B Cell" fillcolor="#bee3f8" color="#2b6cb0"]
        PreB [label="Pre-B Cell" fillcolor="#bee3f8" color="#2b6cb0"]
        ImmatureB [label="Immature B Cell" fillcolor="#bee3f8" color="#2b6cb0"]
        MatureB [label="Mature Naive\nB Cell" fillcolor="#90e0ef" color="#0077b6"]
        GC_B [label="Germinal Center\nB Cell" fillcolor="#90e0ef" color="#0077b6"]
        PC [label="Normal Plasma\nCell" fillcolor="#caf0f8" color="#0077b6"]
        MemoryB [label="Memory B Cell" fillcolor="#ade8f4" color="#0077b6"]
        BM_PC [label="Long-lived BM\nPlasma Cell" fillcolor="#48cae4" color="#023e8a"]

        HSC -> CLP -> ProB -> PreB -> ImmatureB -> MatureB
        MatureB -> GC_B [label="Antigen\nstimulation"]
        GC_B -> PC [label="PC\ndifferentiation"]
        GC_B -> MemoryB
        PC -> BM_PC [label="BM homing\nCXCR4/VLA-4"]
    }

    /* =====================================================================
       CLUSTER 2: MYELOMA CELL BIOLOGY
       ===================================================================== */
    subgraph cluster_myeloma {
        label="Myeloma Cell Biology"
        style="filled,rounded"
        fillcolor="#fff0f3"
        color="#d62828"
        fontcolor="#d62828"
        fontsize=11

        MGUS [label="MGUS\n(Monoclonal\nGammopathy)" fillcolor="#ffc8dd" color="#d62828"]
        SMM [label="Smoldering MM\n(SMM)" fillcolor="#ffb3c1" color="#d62828"]
        MM_cell [label="Myeloma Cell\n(MM Cell)" fillcolor="#ff4d6d" fontcolor="white" color="#d62828"]
        PC_proliferate [label="MM Cell\nProliferation" fillcolor="#c9184a" fontcolor="white" color="#d62828"]
        PC_apoptosis [label="MM Cell\nApoptosis" fillcolor="#590d22" fontcolor="white" color="#800f2f"]
        DTC [label="Drug-tolerant\nPersister (DTC)" fillcolor="#ff758c" color="#c9184a"]
        Resistant_MM [label="Drug-Resistant\nMM Clone" fillcolor="#a4133c" fontcolor="white" color="#800f2f"]

        MGUS -> SMM [label="Progression\n~1%/yr"]
        SMM -> MM_cell [label="Progression\n~10%/yr"]
        MM_cell -> PC_proliferate [label="Autocrine\nIL-6/APRIL/BAFF"]
        PC_proliferate -> PC_apoptosis [label="Baseline\napoptosis"]
        MM_cell -> DTC [label="Stress-\ninduced"]
        DTC -> Resistant_MM [label="Genetic\nevolution"]
        Resistant_MM -> PC_proliferate [label="Clonal\nexpansion"]

        /* Oncogenic drivers */
        t_MMSET [label="t(4;14)\nMMSET/FGFR3" fillcolor="#ff8fab" color="#d62828"]
        t_CCND1 [label="t(11;14)\nCCND1" fillcolor="#ff8fab" color="#d62828"]
        t_MAF [label="t(14;16)\nc-MAF" fillcolor="#ff8fab" color="#d62828"]
        del17p [label="del(17p)\nTP53 loss" fillcolor="#ff8fab" color="#d62828"]
        RAS_mut [label="RAS/RAF\nMutation" fillcolor="#ff8fab" color="#d62828"]
        MYC_amp [label="MYC\nAmplification" fillcolor="#ff8fab" color="#d62828"]

        t_MMSET -> MM_cell [style=dashed arrowhead=odot label="drives"]
        t_CCND1 -> MM_cell [style=dashed arrowhead=odot label="drives"]
        t_MAF -> MM_cell [style=dashed arrowhead=odot label="drives"]
        del17p -> Resistant_MM [style=dashed arrowhead=odot label="high risk"]
        RAS_mut -> PC_proliferate [style=dashed arrowhead=odot label="activates"]
        MYC_amp -> PC_proliferate [style=dashed arrowhead=odot label="amplifies"]
    }

    /* =====================================================================
       CLUSTER 3: BONE MARROW MICROENVIRONMENT
       ===================================================================== */
    subgraph cluster_BMME {
        label="Bone Marrow Microenvironment (BMME)"
        style="filled,rounded"
        fillcolor="#f0fdf4"
        color="#2d6a4f"
        fontcolor="#2d6a4f"
        fontsize=11

        BMSC [label="Bone Marrow\nStromal Cell (BMSC)" fillcolor="#b7e4c7" color="#1b4332"]
        BMEC [label="BM Endothelial\nCell (BMEC)" fillcolor="#b7e4c7" color="#1b4332"]
        Osteoblast [label="Osteoblast\n(OB)" fillcolor="#d8f3dc" color="#2d6a4f"]
        Osteoclast [label="Osteoclast\n(OC)" fillcolor="#74c69d" color="#1b4332"]
        Osteocyte [label="Osteocyte" fillcolor="#d8f3dc" color="#2d6a4f"]
        MSC [label="Mesenchymal\nStem Cell (MSC)" fillcolor="#95d5b2" color="#1b4332"]
        Adipocyte_BM [label="BM Adipocyte" fillcolor="#d8f3dc" color="#2d6a4f"]

        /* Cell adhesion molecules */
        VLA4_VCAM1 [label="VLA-4/VCAM-1\nadhesion" fillcolor="#52b788" color="#1b4332"]
        LFA1_ICAM1 [label="LFA-1/ICAM-1\nadhesion" fillcolor="#52b788" color="#1b4332"]
        CXCR4_SDF1 [label="CXCR4/SDF-1α\nhoming" fillcolor="#52b788" color="#1b4332"]

        MSC -> Osteoblast [label="Differentiation\n(BMP/Wnt)"]
        MSC -> Adipocyte_BM [label="Alternative\ndifferentiation"]
        Osteoblast -> Osteocyte [label="Mineralization"]
        BMSC -> MM_cell [label="IL-6↑\nsurvival signals" style=dashed color="#d62828"]
        BMEC -> MM_cell [label="VEGF\nangiogenesis" style=dashed color="#d62828"]
        MM_cell -> BMSC [label="VLA-4/VCAM-1\ncontact" style=dashed color="#d62828"]
        MM_cell -> VLA4_VCAM1
        MM_cell -> LFA1_ICAM1
        MM_cell -> CXCR4_SDF1
        VLA4_VCAM1 -> BMSC
        CXCR4_SDF1 -> BM_niche [label="BM niche\nretention"]
    }

    BM_niche [label="BM Niche\n(protective)" fillcolor="#95d5b2" color="#1b4332" style="filled,rounded"]

    /* =====================================================================
       CLUSTER 4: CYTOKINE SIGNALING
       ===================================================================== */
    subgraph cluster_cytokines {
        label="Cytokine & Growth Factor Signaling"
        style="filled,rounded"
        fillcolor="#fffbeb"
        color="#b45309"
        fontcolor="#b45309"
        fontsize=11

        IL6 [label="IL-6\n(master MM\ncytokine)" fillcolor="#fde68a" color="#92400e"]
        IL6R [label="IL-6R/gp130\nreceptor" fillcolor="#fde68a" color="#92400e"]
        STAT3 [label="JAK1/2-STAT3\npathway" fillcolor="#fbbf24" color="#78350f"]
        APRIL [label="APRIL/BAFF\n(B cell survival)" fillcolor="#fde68a" color="#92400e"]
        BAFFR [label="TACI/BCMA/BAFFR\nreceptors" fillcolor="#fde68a" color="#92400e"]
        IGF1 [label="IGF-1\n(proliferation)" fillcolor="#fde68a" color="#92400e"]
        VEGF [label="VEGF\n(angiogenesis)" fillcolor="#fde68a" color="#92400e"]
        HGF [label="HGF/c-MET\nsignaling" fillcolor="#fde68a" color="#92400e"]
        SDF1 [label="SDF-1α/CXCL12\n(homing)" fillcolor="#fde68a" color="#92400e"]
        DKK1 [label="DKK1\n(Wnt inhibitor)" fillcolor="#fed7aa" color="#c2410c"]
        Sclerostin [label="Sclerostin/SOST\n(Wnt inhibitor)" fillcolor="#fed7aa" color="#c2410c"]
        RANKL [label="RANKL\n(OC activator)" fillcolor="#fb923c" color="#c2410c"]
        OPG [label="OPG\n(RANKL decoy)" fillcolor="#fed7aa" color="#c2410c"]
        MIP1a [label="MIP-1α/CCL3\n(OC recruiter)" fillcolor="#fed7aa" color="#c2410c"]
        TGFB [label="TGF-β\n(bone-derived)" fillcolor="#fde68a" color="#92400e"]
        TNFa [label="TNF-α\n(inflammation)" fillcolor="#fde68a" color="#92400e"]
        IL10 [label="IL-10\n(immunosuppression)" fillcolor="#fde68a" color="#92400e"]
        IL17 [label="IL-17\n(bone erosion)" fillcolor="#fde68a" color="#92400e"]

        IL6 -> IL6R -> STAT3
        APRIL -> BAFFR
        VEGF -> BMEC [style=dashed]
        DKK1 -> Osteoblast [label="inhibits" arrowhead=tee color="#d62828"]
        Sclerostin -> Osteoblast [label="inhibits" arrowhead=tee color="#d62828"]
        RANKL -> Osteoclast [label="activates" color="#d62828"]
        OPG -> RANKL [label="decoy\nreceptor" arrowhead=tee]
        MIP1a -> Osteoclast [label="recruits"]
        TGFB -> MM_cell [style=dashed label="from bone\nmatrix"]
    }

    /* =====================================================================
       CLUSTER 5: INTRACELLULAR SIGNALING IN MM CELLS
       ===================================================================== */
    subgraph cluster_intracell {
        label="Intracellular Signaling (MM Cell)"
        style="filled,rounded"
        fillcolor="#f5f3ff"
        color="#6d28d9"
        fontcolor="#6d28d9"
        fontsize=11

        PI3K_AKT [label="PI3K/AKT\npathway" fillcolor="#ddd6fe" color="#5b21b6"]
        mTORC1 [label="mTORC1\n(protein synthesis)" fillcolor="#c4b5fd" color="#5b21b6"]
        MAPK_ERK [label="RAS/RAF/MEK\n/ERK pathway" fillcolor="#ddd6fe" color="#5b21b6"]
        NF_kB [label="NF-κB\n(survival)" fillcolor="#c4b5fd" color="#5b21b6"]
        NFAT [label="NFAT\n(Ca²⁺ pathway)" fillcolor="#ddd6fe" color="#5b21b6"]
        IRF4 [label="IRF4/IKZF1-3\n(myeloma TF)" fillcolor="#c4b5fd" color="#5b21b6"]
        XBP1 [label="XBP1/UPR\n(ER stress)" fillcolor="#ddd6fe" color="#5b21b6"]
        BCL2_fam [label="BCL-2/BCL-XL\n/MCL-1\n(anti-apoptotic)" fillcolor="#7c3aed" fontcolor="white" color="#4c1d95"]
        BAX_BAK [label="BAX/BAK\n(pro-apoptotic)" fillcolor="#ddd6fe" color="#5b21b6"]
        Caspase [label="Caspase cascade\n(apoptosis exec)" fillcolor="#ddd6fe" color="#5b21b6"]
        UPS [label="Ubiquitin-Proteasome\nSystem (UPS)" fillcolor="#a78bfa" color="#5b21b6"]
        Proteasome [label="26S Proteasome\n(20S catalytic)" fillcolor="#8b5cf6" fontcolor="white" color="#4c1d95"]
        Misfolded_prot [label="Misfolded Proteins\n/ IκB / p27" fillcolor="#ddd6fe" color="#5b21b6"]
        HDAC [label="HDAC1/2/3/6\n(epigenetic)" fillcolor="#ddd6fe" color="#5b21b6"]
        Cereblon [label="Cereblon\n(CRBN, E3 ligase)" fillcolor="#ede9fe" color="#6d28d9"]
        IKZF1_3 [label="IKZF1/IKZF3\n(Ikaros/Aiolos)" fillcolor="#ddd6fe" color="#5b21b6"]
        CDK46 [label="CDK4/6\n(cell cycle)" fillcolor="#ddd6fe" color="#5b21b6"]
        p21_p27 [label="p21/p27/p53\n(tumor suppressor)" fillcolor="#ddd6fe" color="#5b21b6"]
        AURKA [label="Aurora Kinase A\n(mitotic)" fillcolor="#ddd6fe" color="#5b21b6"]

        STAT3 -> IRF4 [label="activates"]
        PI3K_AKT -> mTORC1
        PI3K_AKT -> BCL2_fam [label="MCL-1↑"]
        MAPK_ERK -> CDK46 [label="proliferation"]
        NF_kB -> BCL2_fam [label="BCL-XL↑"]
        IRF4 -> XBP1 [label="plasma cell\nprogram"]
        IRF4 -> IKZF1_3
        XBP1 -> UPS [label="ER stress\nresponse"]
        UPS -> Proteasome
        Misfolded_prot -> Proteasome [label="degradation"]
        Proteasome -> NF_kB [label="IκB degradation\n→ NF-κB free"]
        BCL2_fam -> BAX_BAK [label="inhibits" arrowhead=tee]
        BAX_BAK -> Caspase
        Caspase -> PC_apoptosis [style=dashed]
        HDAC -> IRF4 [label="deacetylates"]
        CDK46 -> p21_p27 [label="phosphorylates\np27"]
        Cereblon -> IKZF1_3 [label="E3 ligase\nubiquitination"]
    }

    /* =====================================================================
       CLUSTER 6: IMMUNE EVASION
       ===================================================================== */
    subgraph cluster_immune {
        label="Immune Evasion & Tumor Immunology"
        style="filled,rounded"
        fillcolor="#fff7ed"
        color="#9a3412"
        fontcolor="#9a3412"
        fontsize=11

        CTL [label="CD8+ T Cell\n(CTL)" fillcolor="#fed7aa" color="#9a3412"]
        Th1 [label="CD4+ Th1 Cell" fillcolor="#fed7aa" color="#9a3412"]
        Treg [label="CD4+ Treg Cell\n(immunosuppressive)" fillcolor="#fb923c" color="#c2410c"]
        NK_cell [label="NK Cell\n(CD56+)" fillcolor="#fdba74" color="#9a3412"]
        Myeloid_DC [label="Myeloid DC\n(mDC)" fillcolor="#fed7aa" color="#9a3412"]
        pDC [label="Plasmacytoid DC\n(pDC)" fillcolor="#fed7aa" color="#9a3412"]
        Macrophage [label="Tumor-associated\nMacrophage (M2)" fillcolor="#fb923c" color="#c2410c"]
        MDSC [label="MDSC\n(immunosuppressive)" fillcolor="#fb923c" color="#c2410c"]
        PD1 [label="PD-1 (T cell\nexhaustion)" fillcolor="#fed7aa" color="#9a3412"]
        PDL1 [label="PD-L1\n(on MM cell)" fillcolor="#fdba74" color="#9a3412"]
        CTLA4 [label="CTLA-4\n(T cell\ninhibition)" fillcolor="#fed7aa" color="#9a3412"]
        TIM3 [label="TIM-3/LAG-3\n(exhaustion)" fillcolor="#fed7aa" color="#9a3412"]
        HLA_loss [label="MHC-I/HLA\ndownregulation" fillcolor="#fb923c" color="#c2410c"]
        IL10_Treg [label="IL-10/TGF-β\n(Treg induction)" fillcolor="#fb923c" color="#c2410c"]
        IDO [label="IDO1\n(Trp→Kyn\ntolerance)" fillcolor="#fb923c" color="#c2410c"]
        CD38 [label="CD38\n(on MM cell)" fillcolor="#ea580c" fontcolor="white" color="#7c2d12"]
        CD138 [label="CD138/SDC1\n(syndecan-1)" fillcolor="#ea580c" fontcolor="white" color="#7c2d12"]
        BCMA [label="BCMA/TNFRSF17\n(plasma cell)" fillcolor="#ea580c" fontcolor="white" color="#7c2d12"]
        SLAMF7 [label="SLAMF7/CS1\n(elotuzumab\ntarget)" fillcolor="#fdba74" color="#9a3412"]
        CD47 [label="CD47\n('don't eat me')" fillcolor="#fb923c" color="#c2410c"]

        MM_cell -> PDL1
        PDL1 -> PD1 [label="checkpoint\ninhibition"]
        PD1 -> CTL [label="exhaustion" arrowhead=tee]
        Treg -> CTL [label="suppresses" arrowhead=tee]
        Treg -> NK_cell [label="suppresses" arrowhead=tee]
        MDSC -> CTL [label="suppresses" arrowhead=tee]
        IL10_Treg -> Treg [label="expands"]
        IDO -> Treg [label="promotes"]
        HLA_loss -> CTL [label="evades" arrowhead=tee]
        Macrophage -> IL10_Treg
        NK_cell -> MM_cell [label="ADCC\n(antibody-dep)" style=dashed color="green"]
        CD38 -> MM_cell [label="expressed on"]
        BCMA -> MM_cell [label="expressed on"]
    }

    /* =====================================================================
       CLUSTER 7: BONE DISEASE
       ===================================================================== */
    subgraph cluster_bone {
        label="Myeloma Bone Disease (MBD)"
        style="filled,rounded"
        fillcolor="#fefce8"
        color="#854d0e"
        fontcolor="#854d0e"
        fontsize=11

        Osteolytic_lesion [label="Osteolytic Lesion\n(lytic bone disease)" fillcolor="#fef08a" color="#854d0e"]
        Bone_loss [label="Cortical/Trabecular\nBone Loss" fillcolor="#fef08a" color="#854d0e"]
        Fracture [label="Pathological\nFracture" fillcolor="#eab308" color="#854d0e"]
        Hypercalcemia [label="Hypercalcemia\n(Ca²⁺ release)" fillcolor="#fde047" color="#854d0e"]
        Bone_marrow_fail [label="BM Failure\n(pancytopenia)" fillcolor="#fde047" color="#854d0e"]
        SRE [label="Skeletal-Related\nEvent (SRE)" fillcolor="#ca8a04" fontcolor="white" color="#854d0e"]
        NTX [label="N-Telopeptide\n(CTX/NTX\nbone resorption)" fillcolor="#fef08a" color="#854d0e"]
        PINP [label="PINP/OC\n(bone formation\nmarker)" fillcolor="#fef08a" color="#854d0e"]
        Wnt_inh [label="Wnt Pathway\nInhibition\n(DKK1/Sclerostin)" fillcolor="#fef08a" color="#854d0e"]

        MM_cell -> RANKL [label="induces↑"]
        MM_cell -> DKK1 [label="secretes"]
        MM_cell -> Sclerostin [label="induces"]
        MM_cell -> MIP1a [label="secretes"]
        RANKL -> Osteoclast [label="activates\nOC proliferation"]
        Osteoclast -> Osteolytic_lesion
        Osteolytic_lesion -> Bone_loss
        Bone_loss -> Fracture
        Bone_loss -> Hypercalcemia
        DKK1 -> Wnt_inh -> Osteoblast [arrowhead=tee]
        Wnt_inh -> OPG [label="decreases" arrowhead=tee]
        TGFB -> MM_cell [label="bone matrix\nreleases TGF-β\n→ vicious cycle"]
        Osteoclast -> TGFB [label="releases from\nbone matrix"]
        Osteoclast -> NTX [label="generates"]
        Osteoblast -> PINP [label="generates"]
        Fracture -> SRE
        Hypercalcemia -> SRE
        Bone_marrow_fail -> SRE
    }

    /* =====================================================================
       CLUSTER 8: M-PROTEIN / CLINICAL DISEASE BURDEN
       ===================================================================== */
    subgraph cluster_mprotein {
        label="M-Protein & Clinical Disease Markers"
        style="filled,rounded"
        fillcolor="#f0fdf4"
        color="#166534"
        fontcolor="#166534"
        fontsize=11

        M_protein [label="M-Protein\n(Monoclonal Ig)\nSerum Level" fillcolor="#bbf7d0" color="#166534"]
        sFLC [label="Serum Free Light\nChains (sFLC)\nκ or λ" fillcolor="#bbf7d0" color="#166534"]
        BJ_protein [label="Bence-Jones Protein\n(urine FLC)" fillcolor="#86efac" color="#166534"]
        Beta2M [label="β₂-Microglobulin\n(β₂M, staging)" fillcolor="#86efac" color="#166534"]
        LDH [label="LDH\n(tumor burden)" fillcolor="#86efac" color="#166534"]
        CRP [label="CRP\n(IL-6 surrogate)" fillcolor="#86efac" color="#166534"]
        Albumin [label="Albumin\n(nutritional/\nstaging)" fillcolor="#bbf7d0" color="#166534"]
        MM_bone_marrow [label="BM Plasma Cell %\n(BMPC%)" fillcolor="#4ade80" color="#14532d"]

        PC_proliferate -> M_protein [label="secreted by\nMM cells"]
        PC_proliferate -> sFLC
        sFLC -> BJ_protein [label="filtered\nby kidney"]
        MM_cell -> Beta2M [label="shed from\ncell surface"]
        MM_cell -> LDH [label="tumor burden"]
        IL6 -> CRP [label="hepatic\nsynthesis"]
        MM_cell -> MM_bone_marrow
    }

    /* =====================================================================
       CLUSTER 9: DRUG PK COMPARTMENTS
       ===================================================================== */
    subgraph cluster_PK {
        label="Drug Pharmacokinetics (PK)"
        style="filled,rounded"
        fillcolor="#faf5ff"
        color="#7e22ce"
        fontcolor="#7e22ce"
        fontsize=11

        /* Bortezomib (BTZ) */
        BTZ_central [label="Bortezomib\nCentral (Vc)" fillcolor="#e9d5ff" color="#7e22ce"]
        BTZ_periph [label="Bortezomib\nPeripheral (Vp)" fillcolor="#e9d5ff" color="#7e22ce"]
        BTZ_tissue [label="BTZ Tissue\nDistrib. (deep)" fillcolor="#e9d5ff" color="#7e22ce"]

        /* Carfilzomib (CFZ) */
        CFZ_central [label="Carfilzomib\nCentral (Vc)" fillcolor="#d8b4fe" color="#7e22ce"]
        CFZ_periph [label="Carfilzomib\nPeripheral (Vp)" fillcolor="#d8b4fe" color="#7e22ce"]

        /* Lenalidomide (LEN) */
        LEN_gut [label="Lenalidomide\nGut (Ka)" fillcolor="#c4b5fd" color="#6d28d9"]
        LEN_central [label="Lenalidomide\nCentral" fillcolor="#c4b5fd" color="#6d28d9"]

        /* Thalidomide (THAL) */
        THAL_central [label="Thalidomide\nCentral" fillcolor="#c4b5fd" color="#6d28d9"]

        /* Pomalidomide (POM) */
        POM_central [label="Pomalidomide\nCentral" fillcolor="#c4b5fd" color="#6d28d9"]

        /* Daratumumab (DARA) - anti-CD38 mAb */
        DARA_central [label="Daratumumab\nCentral (Vc)" fillcolor="#a78bfa" color="#6d28d9"]
        DARA_periph [label="Daratumumab\nPeripheral (Vp)" fillcolor="#a78bfa" color="#6d28d9"]
        DARA_CD38 [label="DARA:CD38\nBound Complex" fillcolor="#8b5cf6" fontcolor="white" color="#6d28d9"]

        /* Elotuzumab (ELO) - anti-SLAMF7 */
        ELO_central [label="Elotuzumab\nCentral (Vc)" fillcolor="#a78bfa" color="#6d28d9"]

        /* Isatuximab (ISA) - anti-CD38 */
        ISA_central [label="Isatuximab\nCentral (Vc)" fillcolor="#a78bfa" color="#6d28d9"]

        /* Venetoclax (VEN) - BCL-2 inhibitor */
        VEN_gut [label="Venetoclax\nGut (Ka)" fillcolor="#c4b5fd" color="#6d28d9"]
        VEN_central [label="Venetoclax\nCentral" fillcolor="#c4b5fd" color="#6d28d9"]

        /* Dexamethasone (DEX) */
        DEX_central [label="Dexamethasone\nCentral" fillcolor="#ddd6fe" color="#7e22ce"]

        /* Selinexor (SEL) - XPO1 inhibitor */
        SEL_central [label="Selinexor (XPO1i)\nCentral" fillcolor="#ede9fe" color="#7e22ce"]

        /* Zoledronic acid (ZOL) */
        ZOL_central [label="Zoledronic Acid\nCentral" fillcolor="#ede9fe" color="#7e22ce"]
        ZOL_bone [label="ZOL Bone\nCompartment" fillcolor="#ddd6fe" color="#7e22ce"]

        BTZ_central -> BTZ_periph [label="k12/k21" dir=both]
        BTZ_central -> BTZ_tissue [label="deep\ncompartment" dir=both]
        CFZ_central -> CFZ_periph [label="k12/k21" dir=both]
        LEN_gut -> LEN_central [label="Ka absorption"]
        VEN_gut -> VEN_central [label="Ka absorption"]
        ZOL_central -> ZOL_bone [label="bone uptake"]
        DARA_central -> DARA_periph [label="k12/k21" dir=both]
        DARA_central -> DARA_CD38 [label="target-mediated\ndisposition"]
    }

    /* =====================================================================
       CLUSTER 10: DRUG PD — PHARMACODYNAMICS
       ===================================================================== */
    subgraph cluster_PD {
        label="Drug Pharmacodynamics (PD) & Mechanisms"
        style="filled,rounded"
        fillcolor="#fff1f2"
        color="#be123c"
        fontcolor="#be123c"
        fontsize=11

        BTZ_PD [label="BTZ Proteasome\nInhibition (≥65%)\n26S/20S" fillcolor="#fda4af" color="#be123c"]
        CFZ_PD [label="CFZ Irreversible\nProteasome Block\n(β5/β1 subunits)" fillcolor="#fda4af" color="#be123c"]
        LEN_PD [label="LEN/IMiD\nCereblon-CRBN-E3\nIKZF1/3 degradation" fillcolor="#fda4af" color="#be123c"]
        DARA_PD [label="DARA Anti-CD38\nADCC/CDC/ADCP\nDirect apoptosis" fillcolor="#fda4af" color="#be123c"]
        DEX_PD [label="DEX Glucocorticoid\nGR-mediated apoptosis\nNF-κB inhibition" fillcolor="#fda4af" color="#be123c"]
        VEN_PD [label="VEN BCL-2\nBH3 mimetic\nBIM release" fillcolor="#fda4af" color="#be123c"]
        BIS_PD [label="Bisphosphonate\nOsteoclast\napoptosis" fillcolor="#fda4af" color="#be123c"]
        DKKMAB [label="Anti-DKK1 mAb\n(BHQ880 / romosozumab)\nOB stimulation" fillcolor="#fda4af" color="#be123c"]
        CAR_T [label="BCMA-CAR T Cell\nTherapy\n(ide-cel/cilta-cel)" fillcolor="#f43f5e" fontcolor="white" color="#9f1239"]
        BiTE [label="BCMA/CD3 BiTE\n(teclistamab)\nT cell redirection" fillcolor="#f43f5e" fontcolor="white" color="#9f1239"]
        ADC_drug [label="BCMA-ADC\n(belantamab\nmafodotin)" fillcolor="#fda4af" color="#be123c"]

        BTZ_PD -> Proteasome [label="inhibits" arrowhead=tee color="#be123c"]
        CFZ_PD -> Proteasome [label="irreversibly\ninhibits" arrowhead=tee color="#be123c"]
        LEN_PD -> Cereblon [label="hijacks E3\nligase → IKZF1/3↓"]
        LEN_PD -> IKZF1_3 [label="degrades" arrowhead=tee]
        DARA_PD -> CD38 [label="binds"]
        DARA_PD -> NK_cell [label="ADCC\nactivation"]
        VEN_PD -> BCL2_fam [label="BCL-2\nselective inhibit" arrowhead=tee]
        DEX_PD -> NF_kB [label="inhibits" arrowhead=tee]
        DEX_PD -> IL6 [label="decreases" arrowhead=tee]
        BIS_PD -> Osteoclast [label="apoptosis" arrowhead=tee]
        CAR_T -> BCMA [label="targets BCMA\non MM cell" color="darkgreen"]
        BiTE -> BCMA [label="targets" color="darkgreen"]
        CAR_T -> MM_cell [label="cytotoxicity" arrowhead=box color="darkgreen"]
        BiTE -> CTL [label="recruits\nT cells" color="darkgreen"]
        ADC_drug -> BCMA [label="MMAF payload\ndelivery"]
    }

    /* =====================================================================
       CLUSTER 11: CLINICAL STAGING & ENDPOINTS
       ===================================================================== */
    subgraph cluster_endpoints {
        label="Clinical Staging & Endpoints"
        style="filled,rounded"
        fillcolor="#f0f9ff"
        color="#0369a1"
        fontcolor="#0369a1"
        fontsize=11

        ISS_stage [label="ISS Stage\n(β₂M + Albumin)" fillcolor="#bae6fd" color="#0369a1"]
        RISS_stage [label="Revised ISS\n(ISS + LDH + FISH)" fillcolor="#7dd3fc" color="#0c4a6e"]
        CR [label="Complete Response\n(CR)\n(M-protein undetect.)" fillcolor="#38bdf8" fontcolor="white" color="#0c4a6e"]
        sCR [label="Stringent CR\n(sCR)\n(CR + neg FLC ratio\n+ neg BM)" fillcolor="#0284c7" fontcolor="white" color="#0c4a6e"]
        VGPR [label="VGPR (≥90%\nM-protein↓)" fillcolor="#7dd3fc" color="#0369a1"]
        PR [label="Partial Response\n(≥50% M-protein↓)" fillcolor="#bae6fd" color="#0369a1"]
        SD [label="Stable Disease\n(SD)" fillcolor="#e0f2fe" color="#0369a1"]
        PD_end [label="Progressive Disease\n(≥25% M-protein↑)" fillcolor="#fed7aa" color="#9a3412"]
        MRD [label="MRD Negativity\n(<10⁻⁵ by NGS/NGF)" fillcolor="#0ea5e9" fontcolor="white" color="#0c4a6e"]
        OS_end [label="Overall Survival\n(OS)" fillcolor="#0369a1" fontcolor="white" color="#0c4a6e"]
        PFS_end [label="Progression-Free\nSurvival (PFS)" fillcolor="#0369a1" fontcolor="white" color="#0c4a6e"]
        TTNT [label="Time-to-Next-\nTreatment (TTNT)" fillcolor="#bae6fd" color="#0369a1"]
        QoL [label="Quality of Life\n(EORTC QLQ-MY20)" fillcolor="#e0f2fe" color="#0369a1"]

        Beta2M -> ISS_stage
        Albumin -> ISS_stage
        ISS_stage -> RISS_stage
        LDH -> RISS_stage
        M_protein -> CR [label="M-protein\n<0.2 g/dL"]
        M_protein -> VGPR [label="M-protein\n≥90% reduction"]
        M_protein -> PR [label="≥50% reduction"]
        M_protein -> PD_end [label="≥25% increase"]
        CR -> sCR [label="+ negative\nFLC + BM"]
        sCR -> MRD [label="confirmed by\nNGS/flow"]
        MRD -> PFS_end [label="MRD neg →\nimproved PFS"]
        PFS_end -> OS_end
        RISS_stage -> OS_end [label="prognostic"]
    }

    /* =====================================================================
       CLUSTER 12: RENAL COMPLICATIONS
       ===================================================================== */
    subgraph cluster_renal {
        label="Renal Complications"
        style="filled,rounded"
        fillcolor="#ecfdf5"
        color="#065f46"
        fontcolor="#065f46"
        fontsize=11

        Cast_nephropathy [label="Cast Nephropathy\n(myeloma kidney)" fillcolor="#a7f3d0" color="#065f46"]
        Amyloidosis_AL [label="AL Amyloidosis\n(light chain\ndeposition)" fillcolor="#6ee7b7" color="#047857"]
        Renal_failure [label="Acute/Chronic\nRenal Failure\n(MM-induced)" fillcolor="#34d399" color="#065f46"]
        Creatinine [label="Serum Creatinine\n/ eGFR" fillcolor="#a7f3d0" color="#065f46"]
        Proteinuria [label="Proteinuria\n(Bence-Jones)" fillcolor="#a7f3d0" color="#065f46"]

        sFLC -> Cast_nephropathy [label="FLC aggregation\nin tubules"]
        sFLC -> Amyloidosis_AL [label="light chain\ndeposition"]
        Cast_nephropathy -> Renal_failure
        Amyloidosis_AL -> Renal_failure
        Hypercalcemia -> Renal_failure [label="nephrotoxic"]
        BJ_protein -> Proteinuria
        Renal_failure -> Creatinine
    }

    /* =====================================================================
       CLUSTER 13: ANEMIA & HEMATOLOGIC COMPLICATIONS
       ===================================================================== */
    subgraph cluster_heme {
        label="Hematologic Complications"
        style="filled,rounded"
        fillcolor="#fdf2f8"
        color="#86198f"
        fontcolor="#86198f"
        fontsize=11

        EPO [label="Erythropoietin\n(EPO)" fillcolor="#f0abfc" color="#86198f"]
        RBC [label="Red Blood Cells\n(RBC count)" fillcolor="#f0abfc" color="#86198f"]
        Hemoglobin [label="Hemoglobin\n(Hgb <10 g/dL)" fillcolor="#e879f9" color="#86198f"]
        Neutrophil [label="Neutrophils\n(ANC)" fillcolor="#f0abfc" color="#86198f"]
        Platelet [label="Platelets\n(PLT)" fillcolor="#f0abfc" color="#86198f"]
        Anemia [label="MM-associated\nAnemia" fillcolor="#d946ef" fontcolor="white" color="#86198f"]
        Neutropenia [label="Drug-induced\nNeutropenia" fillcolor="#a21caf" fontcolor="white" color="#86198f"]
        Thrombocytopenia [label="Drug-induced\nThrombocytopenia" fillcolor="#a21caf" fontcolor="white" color="#86198f"]

        MM_cell -> EPO [label="inhibits EPO\nproduction" arrowhead=tee]
        MM_bone_marrow -> RBC [label="crowding out\nnormal cells" arrowhead=tee]
        EPO -> RBC [label="stimulates"]
        RBC -> Hemoglobin
        Hemoglobin -> Anemia [label="<10 g/dL"]
        IL6 -> EPO [label="blunts EPO\nresponse" arrowhead=tee]
        LEN_central -> Neutropenia [label="myelosuppression"]
        LEN_central -> Thrombocytopenia [label="myelosuppression"]
    }

    /* =====================================================================
       INTER-CLUSTER CONNECTIONS
       ===================================================================== */

    /* Cytokine → MM cell survival */
    IL6 -> STAT3 [style=dashed color="#b45309" label="paracrine\nsurvival"]
    APRIL -> NF_kB [style=dashed color="#b45309" label="survival\nsignal"]
    IGF1 -> PI3K_AKT [style=dashed color="#b45309"]
    HGF -> MAPK_ERK [style=dashed color="#b45309"]
    BMSC -> IL6 [label="major\nIL-6 source"]

    /* MM cell → cytokine production */
    MM_cell -> IL6 [label="autocrine" style=dashed]
    MM_cell -> VEGF [label="angiogenic" style=dashed]
    MM_cell -> SDF1 [style=dashed]
    MM_cell -> RANKL [label="RANKL↑" style=dashed]

    /* Drug PK → PD connections */
    BTZ_central -> BTZ_PD [label="Cp → Emax"]
    CFZ_central -> CFZ_PD [label="Cp → Emax"]
    LEN_central -> LEN_PD [label="Cp → Emax"]
    DARA_central -> DARA_PD [label="Cp → target\nsaturation"]
    DEX_central -> DEX_PD [label="Cp → GR\noccupancy"]
    VEN_central -> VEN_PD [label="Cp → BCL-2\nbinding"]
    ZOL_bone -> BIS_PD [label="bone uptake\n→ OC apoptosis"]
    ISA_central -> DARA_PD [label="similar mechanism\nanti-CD38"]

    /* PD → MM cell effects */
    BTZ_PD -> PC_apoptosis [label="UPR→\napoptosis" color="#be123c"]
    CFZ_PD -> PC_apoptosis [label="ER stress\napoptosis" color="#be123c"]
    LEN_PD -> PC_apoptosis [label="IKZF1/3↓\n→ IRF4↓→apoptosis" color="#be123c"]
    DARA_PD -> PC_apoptosis [label="ADCC/CDC\napoptosis" color="#be123c"]
    DEX_PD -> PC_apoptosis [label="GC-induced\napoptosis" color="#be123c"]
    VEN_PD -> PC_apoptosis [label="BIM released\n→ apoptosis" color="#be123c"]

    /* Drug → resistance */
    BTZ_PD -> Resistant_MM [label="PSMB5 mutation\nsel. pressure" style=dashed color="#a4133c"]
    LEN_PD -> Resistant_MM [label="CRBN mutation\nsel. pressure" style=dashed color="#a4133c"]

    /* Disease progression → endpoints */
    PC_proliferate -> M_protein [label="tumor burden\n→ M-protein"]
    PC_proliferate -> Beta2M
    PC_apoptosis -> M_protein [label="reduces\nM-protein" arrowhead=tee]

    /* BM niche protects */
    BM_niche -> PC_apoptosis [label="BM-CAM-DR\nprotects" arrowhead=tee color="#2d6a4f"]
    BM_niche -> BTZ_PD [label="reduces\nefficacy" arrowhead=tee color="#2d6a4f"]

    /* RANKL/OPG balance */
    MM_cell -> OPG [label="decreases" arrowhead=tee style=dashed]

    /* Bone matrix vicious cycle */
    TGFB -> IL6 [label="induces"]

    /* Renal effect on drug PK */
    Renal_failure -> LEN_central [label="LEN requires\ndose reduction\nfor CrCl<50" style=dashed color="#065f46"]
}
