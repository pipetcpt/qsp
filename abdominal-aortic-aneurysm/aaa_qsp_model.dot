graph AAA_QSP {
    graph [
        layout=fdp
        fontname="Helvetica"
        fontsize=12
        bgcolor="#FAFAFA"
        label="Abdominal Aortic Aneurysm (AAA)\nQSP Mechanistic Map — Hemodynamics · Inflammation · MMP/ECM · Thrombosis · Drug PK/PD"
        labelloc=t
        labelfontsize=16
        labelfontname="Helvetica-Bold"
        pad=0.6
        overlap=false
        splines=true
        K=2.0
    ]
    node [fontname="Helvetica" fontsize=9 style="filled,rounded" shape=box penwidth=1.2]
    edge [fontname="Helvetica" fontsize=7 arrowsize=0 penwidth=0.9]

    // =====================================================================
    // CLUSTER 1: Risk Factors
    // =====================================================================
    subgraph cluster_risk {
        label="Risk Factors"
        style="filled,rounded"
        color="#8B4513"
        fillcolor="#FFF8DC"
        fontname="Helvetica-Bold"
        fontsize=10

        SMOKING       [label="Cigarette\nSmoking" fillcolor="#FFD700"]
        AGE           [label="Advanced\nAge (>65)" fillcolor="#FFD700"]
        MALE_SEX      [label="Male\nSex" fillcolor="#FFD700"]
        FAMILY_HIST   [label="Family\nHistory" fillcolor="#FFD700"]
        HTN_RF        [label="Hypertension" fillcolor="#FFD700"]
        DYSLIPID      [label="Dyslipidemia" fillcolor="#FFD700"]
        ATHEROSCL     [label="Atherosclerosis" fillcolor="#FFD700"]
        OBESITY_RF    [label="Obesity /\nMetabolic Synd." fillcolor="#FFD700"]
        COPD_RF       [label="COPD\n(comorbidity)" fillcolor="#FFD700"]
        PAD_RF        [label="PAD\n(comorbidity)" fillcolor="#FFD700"]
    }

    // =====================================================================
    // CLUSTER 2: Hemodynamic Stress
    // =====================================================================
    subgraph cluster_hemo {
        label="Hemodynamic Stress"
        style="filled,rounded"
        color="#4169E1"
        fillcolor="#E6F0FF"
        fontname="Helvetica-Bold"
        fontsize=10

        SBP           [label="Systolic\nBlood Pressure" fillcolor="#B0C8FF"]
        DBP           [label="Diastolic\nBlood Pressure" fillcolor="#B0C8FF"]
        PULSE_PRESS   [label="Pulse\nPressure" fillcolor="#B0C8FF"]
        CARDIAC_OUT   [label="Cardiac\nOutput" fillcolor="#B0C8FF"]
        WALL_STRESS   [label="Aortic Wall\nStress (LaPlace)" fillcolor="#87CEEB"]
        OSS           [label="Oscillatory\nShear Stress" fillcolor="#87CEEB"]
        LOW_WSS       [label="Low Wall\nShear Stress" fillcolor="#87CEEB"]
        TURBULENCE    [label="Turbulent\nBlood Flow" fillcolor="#87CEEB"]
        MECH_STRAIN   [label="Mechanical\nStrain Cycles" fillcolor="#87CEEB"]
        AORTA_STIFF   [label="Aortic\nStiffness (PWV)" fillcolor="#87CEEB"]
        PULSATILE_STR [label="Pulsatile\nStress" fillcolor="#87CEEB"]
        REFLECT_WAVE  [label="Reflected\nPressure Waves" fillcolor="#87CEEB"]
    }

    // =====================================================================
    // CLUSTER 3: Endothelial Dysfunction
    // =====================================================================
    subgraph cluster_endo {
        label="Endothelial Dysfunction"
        style="filled,rounded"
        color="#008080"
        fillcolor="#E0F5F5"
        fontname="Helvetica-Bold"
        fontsize=10

        EC_DYSFUNC    [label="Endothelial\nCell Dysfunction" fillcolor="#7FFFD4"]
        eNOS_UNCOUPLE [label="eNOS\nUncoupling" fillcolor="#AFEEEE"]
        NO_REDUC      [label="↓ Nitric Oxide\n(NO)" fillcolor="#AFEEEE"]
        ET1_UP        [label="↑ Endothelin-1\n(ET-1)" fillcolor="#AFEEEE"]
        ICAM1         [label="↑ ICAM-1" fillcolor="#98D8D8"]
        VCAM1         [label="↑ VCAM-1" fillcolor="#98D8D8"]
        E_SELECTIN    [label="↑ E-Selectin" fillcolor="#98D8D8"]
        P_SELECTIN    [label="↑ P-Selectin" fillcolor="#98D8D8"]
        MCP1          [label="↑ MCP-1\n(CCL2)" fillcolor="#98D8D8"]
        PAI1          [label="↑ PAI-1" fillcolor="#98D8D8"]
        RANTES        [label="↑ RANTES\n(CCL5)" fillcolor="#98D8D8"]
        PROSTACYCLIN  [label="↓ Prostacyclin\n(PGI2)" fillcolor="#AFEEEE"]
    }

    // =====================================================================
    // CLUSTER 4: Immune Cell Infiltration
    // =====================================================================
    subgraph cluster_immune {
        label="Inflammatory Cell Infiltration"
        style="filled,rounded"
        color="#DC143C"
        fillcolor="#FFF0F0"
        fontname="Helvetica-Bold"
        fontsize=10

        MONO_RECRUIT  [label="Monocyte\nRecruitment" fillcolor="#FFB6C1"]
        NEUTRO        [label="Neutrophil\nInfiltration" fillcolor="#FFB6C1"]
        T_CELL        [label="CD4+/CD8+\nT Cell Infiltration" fillcolor="#FFB6C1"]
        B_CELL        [label="B Cell\nActivation" fillcolor="#FFB6C1"]
        MAST_CELL     [label="Mast Cell\nDegranulation" fillcolor="#FFB6C1"]
        MAC_M1        [label="M1 Macrophage\n(Pro-inflammatory)" fillcolor="#FF8C94"]
        MAC_M2        [label="M2 Macrophage\n(Anti-inflammatory)" fillcolor="#FF8C94"]
        FOAM_CELL     [label="Foam Cell\nFormation" fillcolor="#FF8C94"]
        DENDRITE_CELL [label="Dendritic\nCell Activation" fillcolor="#FF8C94"]
        NK_CELL       [label="NK Cell\nCytotoxicity" fillcolor="#FFB6C1"]
        TREG          [label="Treg\nSuppression" fillcolor="#FFB6C1"]
        TH17          [label="Th17\nActivation" fillcolor="#FF8C94"]
    }

    // =====================================================================
    // CLUSTER 5: Cytokine / Signaling Network
    // =====================================================================
    subgraph cluster_cytokine {
        label="Cytokine & Signaling Network"
        style="filled,rounded"
        color="#FF6347"
        fillcolor="#FFF5EE"
        fontname="Helvetica-Bold"
        fontsize=10

        TNF_A         [label="TNF-α" fillcolor="#FFA07A"]
        IL1B          [label="IL-1β" fillcolor="#FFA07A"]
        IL6           [label="IL-6" fillcolor="#FFA07A"]
        IL8           [label="IL-8 (CXCL8)" fillcolor="#FFA07A"]
        IL17          [label="IL-17" fillcolor="#FFA07A"]
        IL23          [label="IL-23" fillcolor="#FFA07A"]
        IFN_G         [label="IFN-γ" fillcolor="#FFA07A"]
        TGF_B         [label="TGF-β" fillcolor="#98FB98"]
        NF_KB         [label="NF-κB\nActivation" fillcolor="#FF6347"]
        AP1           [label="AP-1\nActivation" fillcolor="#FF6347"]
        ANGII         [label="Angiotensin II\n(Ang II)" fillcolor="#FFA07A"]
        RAAS_AXIS     [label="RAAS\nActivation" fillcolor="#FFA07A"]
    }

    // =====================================================================
    // CLUSTER 6: MMP / TIMP Axis
    // =====================================================================
    subgraph cluster_mmp {
        label="MMP / TIMP Axis"
        style="filled,rounded"
        color="#FF8C00"
        fillcolor="#FFF3E0"
        fontname="Helvetica-Bold"
        fontsize=10

        MMP1          [label="MMP-1\n(Collagenase-1)" fillcolor="#FFD580"]
        MMP2_PRO      [label="Pro-MMP-2\n(Gelatinase A)" fillcolor="#FFBF47"]
        MMP2_ACT      [label="Active MMP-2\n★KEY TARGET★" fillcolor="#FF8C00" fontcolor="white"]
        MMP8          [label="MMP-8\n(Collagenase-2)" fillcolor="#FFD580"]
        MMP9_PRO      [label="Pro-MMP-9\n(Gelatinase B)" fillcolor="#FFBF47"]
        MMP9_ACT      [label="Active MMP-9\n★KEY TARGET★" fillcolor="#FF8C00" fontcolor="white"]
        MMP12         [label="MMP-12\n(Macrophage\nElastase)" fillcolor="#FFBF47"]
        MMP13         [label="MMP-13\n(Collagenase-3)" fillcolor="#FFD580"]
        TIMP1         [label="TIMP-1\n(Endogenous\nInhibitor)" fillcolor="#90EE90"]
        TIMP2         [label="TIMP-2\n(Activates\nPro-MMP-2)" fillcolor="#90EE90"]
        MT1_MMP       [label="MT1-MMP\n(Membrane-type)" fillcolor="#FFBF47"]
        PLASMIN       [label="Plasmin\n(MMP Activator)" fillcolor="#FFD580"]
    }

    // =====================================================================
    // CLUSTER 7: Oxidative Stress
    // =====================================================================
    subgraph cluster_ros {
        label="Oxidative Stress"
        style="filled,rounded"
        color="#9ACD32"
        fillcolor="#F0FFF0"
        fontname="Helvetica-Bold"
        fontsize=10

        NADPH_OX      [label="NADPH\nOxidase (NOX)" fillcolor="#ADFF2F"]
        SUPEROXIDE    [label="Superoxide\n(O₂•⁻)" fillcolor="#ADFF2F"]
        ROS           [label="Reactive Oxygen\nSpecies (ROS)" fillcolor="#7FFF00"]
        H2O2          [label="Hydrogen\nPeroxide (H₂O₂)" fillcolor="#ADFF2F"]
        PEROXY        [label="Peroxynitrite\n(ONOO⁻)" fillcolor="#ADFF2F"]
        LIP_PEROX     [label="Lipid\nPeroxidation" fillcolor="#ADFF2F"]
        OX_LDL        [label="Oxidized\nLDL (ox-LDL)" fillcolor="#ADFF2F"]
        NRF2          [label="Nrf2 Pathway\n(Antioxidant)" fillcolor="#90EE90"]
    }

    // =====================================================================
    // CLUSTER 8: VSMC Biology
    // =====================================================================
    subgraph cluster_vsmc {
        label="Vascular Smooth Muscle Cell (VSMC) Biology"
        style="filled,rounded"
        color="#228B22"
        fillcolor="#F0FFF0"
        fontname="Helvetica-Bold"
        fontsize=10

        VSMC_CONTRACT [label="VSMC\nContractile\nPhenotype" fillcolor="#90EE90"]
        VSMC_SYNTH    [label="VSMC\nSynthetic\nPhenotype" fillcolor="#90EE90"]
        VSMC_APOP     [label="VSMC\nApoptosis\n★CRITICAL★" fillcolor="#228B22" fontcolor="white"]
        VSMC_PROLIF   [label="VSMC\nProliferation" fillcolor="#90EE90"]
        VSMC_MIGRAT   [label="VSMC\nMigration" fillcolor="#90EE90"]
        ALPHA_SMA     [label="α-SMA\n(Contractile\nMarker)" fillcolor="#98FB98"]
        MYH11         [label="MYH11\n(SM-MHC)" fillcolor="#98FB98"]
        CALPONIN      [label="Calponin\n(Contractile)" fillcolor="#98FB98"]
        VSMC_COUNT    [label="VSMC\nDensity\n(↓ in AAA)" fillcolor="#228B22" fontcolor="white"]
        PDGFR         [label="PDGF\nSignaling" fillcolor="#90EE90"]
    }

    // =====================================================================
    // CLUSTER 9: ECM Remodeling
    // =====================================================================
    subgraph cluster_ecm {
        label="Extracellular Matrix Remodeling"
        style="filled,rounded"
        color="#8B6914"
        fillcolor="#FFFACD"
        fontname="Helvetica-Bold"
        fontsize=10

        ELASTIN       [label="Elastin\nContent\n(↓ in AAA)" fillcolor="#DAA520"]
        COLLAGEN_I    [label="Collagen\nType I" fillcolor="#F0E68C"]
        COLLAGEN_III  [label="Collagen\nType III" fillcolor="#F0E68C"]
        FIBRONECT     [label="Fibronectin" fillcolor="#F0E68C"]
        LAMININ       [label="Laminin" fillcolor="#F0E68C"]
        PROTEOGLY     [label="Proteoglycans\n(versican, biglycan)" fillcolor="#F0E68C"]
        ELASTIN_DEG   [label="Elastin\nDegradation\n(↑ in AAA)" fillcolor="#DAA520"]
        COLLAGEN_SYN  [label="Collagen\nSynthesis" fillcolor="#F0E68C"]
        ECM_TURNOVER  [label="ECM\nTurnover\nImbalance" fillcolor="#DAA520"]
        WALL_INTEGR   [label="Aortic Wall\nIntegrity\n(↓)" fillcolor="#B8860B"]
    }

    // =====================================================================
    // CLUSTER 10: Intraluminal Thrombus (ILT)
    // =====================================================================
    subgraph cluster_ilt {
        label="Intraluminal Thrombus (ILT)"
        style="filled,rounded"
        color="#9370DB"
        fillcolor="#F8F0FF"
        fontname="Helvetica-Bold"
        fontsize=10

        PLATELET_ACT  [label="Platelet\nActivation" fillcolor="#DDA0DD"]
        THROMBIN_GEN  [label="Thrombin\nGeneration" fillcolor="#DDA0DD"]
        FIBRIN_FORM   [label="Fibrin\nFormation" fillcolor="#DDA0DD"]
        ILT_GROWTH    [label="ILT\nGrowth/Expansion" fillcolor="#9370DB" fontcolor="white"]
        ILT_HYPOXIA   [label="ILT-Induced\nHypoxia" fillcolor="#9370DB" fontcolor="white"]
        ILT_MMP       [label="ILT-Derived\nMMP Release" fillcolor="#9370DB" fontcolor="white"]
        TPA           [label="t-PA\n(Thrombolysis)" fillcolor="#DDA0DD"]
        F13           [label="Factor XIII\n(Cross-linking)" fillcolor="#DDA0DD"]
    }

    // =====================================================================
    // CLUSTER 11: Clinical Endpoints
    // =====================================================================
    subgraph cluster_clinical {
        label="Clinical Outcomes"
        style="filled,rounded"
        color="#8B0000"
        fillcolor="#FFF0F0"
        fontname="Helvetica-Bold"
        fontsize=10

        AORTA_DIAM    [label="Aortic\nDiameter\n(Maximal)" fillcolor="#FF6347"]
        EXPAND_RATE   [label="AAA Expansion\nRate (mm/yr)" fillcolor="#FF6347"]
        RUPTURE_RISK  [label="Rupture\nRisk\n★ENDPOINT★" fillcolor="#8B0000" fontcolor="white"]
        DISSECTION    [label="Aortic\nDissection" fillcolor="#CD5C5C"]
        EMBOLISM      [label="Peripheral\nEmbolism" fillcolor="#CD5C5C"]
        AAA_PAIN      [label="AAA-Related\nPain" fillcolor="#CD5C5C"]
        ANEURYSM_VOL  [label="Aneurysm\nVolume (cm³)" fillcolor="#FF6347"]
        MORTALITY     [label="All-Cause\nMortality" fillcolor="#8B0000" fontcolor="white"]
    }

    // =====================================================================
    // CLUSTER 12: Drug PK (Multi-drug)
    // =====================================================================
    subgraph cluster_pk {
        label="Drug Pharmacokinetics"
        style="filled,rounded"
        color="#4682B4"
        fillcolor="#F0F4FF"
        fontname="Helvetica-Bold"
        fontsize=10

        DOXY_GUT      [label="Doxycycline\nGut (oral)" fillcolor="#B0C4DE"]
        DOXY_CENTRAL  [label="Doxycycline\nCentral (plasma)" fillcolor="#4682B4" fontcolor="white"]
        DOXY_PERIPH   [label="Doxycycline\nPeripheral (tissue)" fillcolor="#B0C4DE"]
        DOXY_AORTA    [label="Doxycycline\nAortic Tissue" fillcolor="#B0C4DE"]
        STATIN_GUT    [label="Statin\nGut (oral)" fillcolor="#87CEEB"]
        STATIN_LIVER  [label="Statin\nLiver (1st pass)" fillcolor="#4682B4" fontcolor="white"]
        STATIN_PLASMA [label="Statin\nPlasma (active)" fillcolor="#87CEEB"]
        BB_GUT        [label="β-Blocker\nGut (oral)" fillcolor="#ADD8E6"]
        BB_CENTRAL    [label="β-Blocker\nCentral (plasma)" fillcolor="#4682B4" fontcolor="white"]
        ACEI_GUT      [label="ACE Inhibitor\nGut (oral)" fillcolor="#ADD8E6"]
        ACEI_CENTRAL  [label="ACE Inhibitor\nCentral (plasma)" fillcolor="#4682B4" fontcolor="white"]
        ACEI_ACTIVE   [label="ACEi Active\nForm (plasma)" fillcolor="#87CEEB"]
    }

    // =====================================================================
    // CLUSTER 13: Drug PD Effects
    // =====================================================================
    subgraph cluster_pd {
        label="Drug Pharmacodynamics"
        style="filled,rounded"
        color="#6A0DAD"
        fillcolor="#F5F0FF"
        fontname="Helvetica-Bold"
        fontsize=10

        DOXY_MMP_INH  [label="Doxycycline:\nMMP Inhibition\n(MMP-2,-9,-12)" fillcolor="#DDA0DD"]
        DOXY_ANTIINF  [label="Doxycycline:\nAnti-inflammatory\n(NF-κB↓, cytokines↓)" fillcolor="#DDA0DD"]
        STATIN_HMGCR  [label="Statin:\nHMG-CoA Reductase\nInhibition" fillcolor="#DA70D6"]
        STATIN_PLEI   [label="Statin:\nPleiotropic Effects\n(anti-inflam, antioxid)" fillcolor="#DA70D6"]
        BB_HR         [label="β-Blocker:\n↓ Heart Rate\n↓ Cardiac Output" fillcolor="#9370DB"]
        BB_BP_RED     [label="β-Blocker:\n↓ Systolic BP\n↓ Wall Stress" fillcolor="#9370DB"]
        ACEI_ANGII_B  [label="ACEi:\n↓ Angiotensin II\n(ACE Inhibition)" fillcolor="#8B008B" fontcolor="white"]
        ACEI_BP_RED   [label="ACEi:\n↓ Blood Pressure\n↓ Aortic Stress" fillcolor="#8B008B" fontcolor="white"]
    }

    // =====================================================================
    // EDGES: Risk Factors → Upstream
    // =====================================================================
    SMOKING -- OSS
    SMOKING -- NADPH_OX
    SMOKING -- EC_DYSFUNC
    SMOKING -- MAC_M1
    AGE -- VSMC_APOP
    AGE -- ELASTIN_DEG
    AGE -- WALL_STRESS
    HTN_RF -- SBP
    HTN_RF -- DBP
    HTN_RF -- PULSE_PRESS
    DYSLIPID -- OX_LDL
    DYSLIPID -- FOAM_CELL
    ATHEROSCL -- EC_DYSFUNC
    ATHEROSCL -- WALL_STRESS
    MALE_SEX -- MMP9_ACT
    FAMILY_HIST -- VSMC_APOP
    OBESITY_RF -- RAAS_AXIS
    OBESITY_RF -- IL6
    COPD_RF -- NEUTRO
    PAD_RF -- EC_DYSFUNC

    // =====================================================================
    // EDGES: Hemodynamics
    // =====================================================================
    SBP -- WALL_STRESS
    DBP -- WALL_STRESS
    PULSE_PRESS -- MECH_STRAIN
    CARDIAC_OUT -- TURBULENCE
    TURBULENCE -- OSS
    OSS -- EC_DYSFUNC
    LOW_WSS -- EC_DYSFUNC
    MECH_STRAIN -- EC_DYSFUNC
    MECH_STRAIN -- VSMC_APOP
    AORTA_STIFF -- REFLECT_WAVE
    REFLECT_WAVE -- PULSATILE_STR
    PULSATILE_STR -- WALL_STRESS
    WALL_STRESS -- EC_DYSFUNC
    WALL_STRESS -- VSMC_APOP

    // =====================================================================
    // EDGES: Endothelial → Immune/Cytokine
    // =====================================================================
    EC_DYSFUNC -- eNOS_UNCOUPLE
    eNOS_UNCOUPLE -- NO_REDUC
    eNOS_UNCOUPLE -- SUPEROXIDE
    EC_DYSFUNC -- ET1_UP
    EC_DYSFUNC -- ICAM1
    EC_DYSFUNC -- VCAM1
    EC_DYSFUNC -- E_SELECTIN
    EC_DYSFUNC -- P_SELECTIN
    EC_DYSFUNC -- MCP1
    EC_DYSFUNC -- RANTES
    EC_DYSFUNC -- PAI1
    EC_DYSFUNC -- PROSTACYCLIN
    ICAM1 -- NEUTRO
    VCAM1 -- MONO_RECRUIT
    E_SELECTIN -- NEUTRO
    P_SELECTIN -- PLATELET_ACT
    MCP1 -- MONO_RECRUIT
    RANTES -- T_CELL
    PAI1 -- FIBRIN_FORM

    // =====================================================================
    // EDGES: Immune Cells → Cytokines/MMPs
    // =====================================================================
    MONO_RECRUIT -- MAC_M1
    MONO_RECRUIT -- FOAM_CELL
    MAC_M1 -- TNF_A
    MAC_M1 -- IL1B
    MAC_M1 -- IL6
    MAC_M1 -- MMP9_PRO
    MAC_M1 -- MMP12
    MAC_M1 -- ROS
    MAC_M2 -- TGF_B
    MAC_M2 -- TIMP1
    NEUTRO -- MMP8
    NEUTRO -- MMP9_PRO
    NEUTRO -- SUPEROXIDE
    T_CELL -- IFN_G
    T_CELL -- IL17
    TH17 -- IL17
    TH17 -- IL23
    B_CELL -- PLATELET_ACT
    MAST_CELL -- TNF_A
    MAST_CELL -- MMP9_PRO
    DENDRITE_CELL -- T_CELL
    NK_CELL -- VSMC_APOP
    TREG -- TNF_A
    FOAM_CELL -- OX_LDL
    FOAM_CELL -- IL1B

    // =====================================================================
    // EDGES: Cytokines → NF-κB / Downstream
    // =====================================================================
    TNF_A -- NF_KB
    IL1B -- NF_KB
    IL17 -- NF_KB
    IFN_G -- MAC_M1
    TGF_B -- COLLAGEN_SYN
    TGF_B -- VSMC_SYNTH
    NF_KB -- MMP9_PRO
    NF_KB -- MMP2_PRO
    NF_KB -- MMP12
    NF_KB -- IL8
    NF_KB -- ICAM1
    AP1 -- MMP1
    AP1 -- MMP13
    ANGII -- NF_KB
    ANGII -- NADPH_OX
    RAAS_AXIS -- ANGII
    RAAS_AXIS -- SBP
    IL8 -- NEUTRO
    IL6 -- NF_KB

    // =====================================================================
    // EDGES: MMP/TIMP Activation Cascade
    // =====================================================================
    MT1_MMP -- MMP2_PRO
    TIMP2 -- MT1_MMP
    MT1_MMP -- MMP2_ACT
    MMP2_PRO -- MMP2_ACT
    PLASMIN -- MMP9_PRO
    PLASMIN -- MMP1
    MMP9_PRO -- MMP9_ACT
    TIMP1 -- MMP9_ACT [color=green penwidth=1.5]
    TIMP1 -- MMP1 [color=green penwidth=1.5]
    TIMP2 -- MMP2_ACT [color=green penwidth=1.5]
    MMP2_ACT -- ELASTIN_DEG
    MMP2_ACT -- COLLAGEN_I
    MMP9_ACT -- ELASTIN_DEG
    MMP9_ACT -- COLLAGEN_III
    MMP12 -- ELASTIN_DEG
    MMP12 -- PLASMIN
    MMP1 -- COLLAGEN_I
    MMP8 -- COLLAGEN_I
    MMP13 -- COLLAGEN_III
    MMP13 -- COLLAGEN_I

    // =====================================================================
    // EDGES: Oxidative Stress
    // =====================================================================
    NADPH_OX -- SUPEROXIDE
    SUPEROXIDE -- ROS
    SUPEROXIDE -- PEROXY
    NO_REDUC -- PEROXY
    ROS -- H2O2
    ROS -- LIP_PEROX
    ROS -- MMP2_ACT
    ROS -- MMP9_ACT
    ROS -- EC_DYSFUNC
    ROS -- NF_KB
    ROS -- VSMC_APOP
    LIP_PEROX -- OX_LDL
    OX_LDL -- FOAM_CELL
    OX_LDL -- EC_DYSFUNC
    NRF2 -- ROS [color=green penwidth=1.5]
    H2O2 -- EC_DYSFUNC

    // =====================================================================
    // EDGES: VSMC
    // =====================================================================
    TNF_A -- VSMC_APOP
    IL1B -- VSMC_APOP
    MMP9_ACT -- VSMC_APOP
    VSMC_CONTRACT -- ALPHA_SMA
    VSMC_CONTRACT -- MYH11
    VSMC_CONTRACT -- CALPONIN
    VSMC_CONTRACT -- VSMC_SYNTH
    TGF_B -- VSMC_SYNTH
    VSMC_SYNTH -- MMP2_PRO
    VSMC_SYNTH -- COLLAGEN_SYN
    VSMC_APOP -- VSMC_COUNT
    VSMC_COUNT -- WALL_INTEGR
    PDGFR -- VSMC_PROLIF
    PDGFR -- VSMC_MIGRAT
    VSMC_PROLIF -- VSMC_COUNT

    // =====================================================================
    // EDGES: ECM Remodeling
    // =====================================================================
    ELASTIN_DEG -- WALL_INTEGR
    ELASTIN -- WALL_INTEGR
    COLLAGEN_I -- WALL_INTEGR
    COLLAGEN_III -- WALL_INTEGR
    FIBRONECT -- WALL_INTEGR
    ECM_TURNOVER -- WALL_INTEGR
    COLLAGEN_SYN -- COLLAGEN_I
    COLLAGEN_SYN -- COLLAGEN_III
    MMP2_ACT -- ECM_TURNOVER
    MMP9_ACT -- ECM_TURNOVER
    MMP12 -- ECM_TURNOVER
    TIMP1 -- ECM_TURNOVER [color=green penwidth=1.5]
    WALL_INTEGR -- AORTA_DIAM

    // =====================================================================
    // EDGES: ILT
    // =====================================================================
    TURBULENCE -- PLATELET_ACT
    PLATELET_ACT -- THROMBIN_GEN
    THROMBIN_GEN -- FIBRIN_FORM
    FIBRIN_FORM -- ILT_GROWTH
    F13 -- ILT_GROWTH
    ILT_GROWTH -- ILT_HYPOXIA
    ILT_GROWTH -- ILT_MMP
    ILT_HYPOXIA -- VSMC_APOP
    ILT_HYPOXIA -- EC_DYSFUNC
    ILT_MMP -- MMP9_ACT
    ILT_MMP -- ELASTIN_DEG
    TPA -- FIBRIN_FORM [color=green penwidth=1.5]
    PAI1 -- TPA
    ILT_GROWTH -- EMBOLISM

    // =====================================================================
    // EDGES: Clinical Endpoints
    // =====================================================================
    WALL_INTEGR -- RUPTURE_RISK
    AORTA_DIAM -- RUPTURE_RISK
    AORTA_DIAM -- ANEURYSM_VOL
    EXPAND_RATE -- AORTA_DIAM
    ELASTIN_DEG -- EXPAND_RATE
    MMP9_ACT -- EXPAND_RATE
    RUPTURE_RISK -- MORTALITY
    AORTA_DIAM -- MORTALITY
    WALL_STRESS -- RUPTURE_RISK
    EMBOLISM -- MORTALITY
