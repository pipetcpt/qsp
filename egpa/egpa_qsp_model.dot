digraph EGPA_QSP {
  graph [rankdir=LR, compound=true, fontname="Helvetica", fontsize=11,
         bgcolor="#FAFAFA", splines=true, nodesep=0.4, ranksep=0.9,
         label="EGPA (Eosinophilic Granulomatosis with Polyangiitis)\nQuantitative Systems Pharmacology Model",
         labelloc=t, fontsize=14];
  node [shape=box, style="filled,rounded", fontname="Helvetica", fontsize=8, width=1.3, height=0.4];
  edge [fontname="Helvetica", fontsize=7, arrowsize=0.6];

  /* ================================================================
     CLUSTER 1: Environmental Triggers
  ================================================================ */
  subgraph cluster_triggers {
    label="Environmental Triggers";
    style=filled; fillcolor="#FFF8F0";
    color="#8B4513"; fontcolor="#8B4513"; penwidth=2;

    Allergen        [label="Allergen\n(Fungal/Pollen/\nOccupational)",  fillcolor="#FFE4B5"];
    InfectTrigger   [label="Respiratory\nInfection",                    fillcolor="#FFE4B5"];
    DrugTrigger     [label="Drug Trigger\n(LTRA)",                      fillcolor="#FFE4B5"];
    EnvStress       [label="Environmental\nStress",                     fillcolor="#FFE4B5"];
    LTRAassoc       [label="LTRA-associated\nEGPA",                     fillcolor="#FFCCCC"];
    OccupExposure   [label="Occupational\nExposure",                    fillcolor="#FFE4B5"];
  }

  /* ================================================================
     CLUSTER 2: Innate Immune Activation
  ================================================================ */
  subgraph cluster_innate {
    label="Innate Immune Activation";
    style=filled; fillcolor="#F0FFF0";
    color="#556B2F"; fontcolor="#556B2F"; penwidth=2;

    AirwayEpi     [label="Airway Epithelial\nCells",            fillcolor="#90EE90"];
    TSLP          [label="TSLP",                                fillcolor="#90EE90"];
    IL33          [label="IL-33",                               fillcolor="#90EE90"];
    IL25          [label="IL-25 (IL-17E)",                      fillcolor="#90EE90"];
    DendCell      [label="Dendritic Cells\n(DC2/pDC)",          fillcolor="#98FB98"];
    MastCell      [label="Mast Cells",                          fillcolor="#98FB98"];
    Basophil      [label="Basophils",                           fillcolor="#98FB98"];
    ILC2          [label="ILC2 (Innate\nLymphoid Type 2)",      fillcolor="#98FB98"];
    NKcell        [label="NK Cells",                            fillcolor="#CCFFCC"];
    M2Macro       [label="M2 Macrophages",                      fillcolor="#98FB98"];
    CompSys       [label="Complement\n(C3a/C5a)",               fillcolor="#FFCCCB"];
    TLR           [label="TLR / Pattern\nRecognition",          fillcolor="#98FB98"];
    GMCSF         [label="GM-CSF",                              fillcolor="#90EE90"];
    Alarmins      [label="Alarmins\n(HMGB1/S100)",              fillcolor="#90EE90"];
  }

  /* ================================================================
     CLUSTER 3: Th2 Adaptive Immunity & B-cell Response
  ================================================================ */
  subgraph cluster_th2 {
    label="Th2 Adaptive Immunity & B-cell Response";
    style=filled; fillcolor="#F0F0FF";
    color="#00008B"; fontcolor="#00008B"; penwidth=2;

    NaiveCD4      [label="Naive CD4+\nT Cells",                 fillcolor="#ADD8E6"];
    Th2           [label="Th2 Cells",                           fillcolor="#87CEEB"];
    Th1           [label="Th1 Cells",                           fillcolor="#ADD8E6"];
    Treg          [label="Regulatory\nT Cells (Treg)",          fillcolor="#87CEEB"];
    Tfh           [label="T Follicular\nHelper (Tfh)",          fillcolor="#87CEEB"];
    IL4           [label="IL-4",                                fillcolor="#B0E0E6"];
    IL5           [label="IL-5",                                fillcolor="#B0E0E6"];
    IL13          [label="IL-13",                               fillcolor="#B0E0E6"];
    IL10          [label="IL-10",                               fillcolor="#B0E0E6"];
    IL2           [label="IL-2",                                fillcolor="#B0E0E6"];
    IL31          [label="IL-31\n(Pruritus/Itch)",              fillcolor="#B0E0E6"];
    IL9           [label="IL-9\n(Mast cell growth)",            fillcolor="#B0E0E6"];
    IFNg          [label="IFN-γ",                               fillcolor="#ADD8E6"];
    IL12DC        [label="IL-12\n(DC-derived)",                 fillcolor="#ADD8E6"];
    BCells        [label="B Cells",                             fillcolor="#ADD8E6"];
    PlasmaCell    [label="Plasma Cells",                        fillcolor="#87CEEB"];
    MemoryB       [label="Memory B Cells",                      fillcolor="#ADD8E6"];
    GermCenter    [label="Germinal Center\nReaction",           fillcolor="#ADD8E6"];
    IgE           [label="IgE\n(Total & Specific)",             fillcolor="#87CEEB"];
    IgG4          [label="IgG4",                                fillcolor="#87CEEB"];
    IgA           [label="IgA",                                 fillcolor="#87CEEB"];
    TGFB          [label="TGF-β\n(Fibrosis/Treg)",             fillcolor="#ADD8E6"];
  }

  /* ================================================================
     CLUSTER 4: Eosinophil Biology
  ================================================================ */
  subgraph cluster_eosinophil {
    label="Eosinophil Biology";
    style=filled; fillcolor="#FFF0FF";
    color="#8B008B"; fontcolor="#8B008B"; penwidth=2;

    BoneMarrow    [label="Bone Marrow\nProgenitors",            fillcolor="#DDA0DD"];
    EosProd       [label="Eosinophil\nProduction",              fillcolor="#DDA0DD"];
    BloodEos      [label="Blood\nEosinophils",                  fillcolor="#DA70D6"];
    TissueEos     [label="Tissue\nEosinophils",                 fillcolor="#DA70D6"];
    EosAct        [label="Eosinophil\nActivation",              fillcolor="#BA55D3"];
    EosDeg        [label="Eosinophil\nDegranulation",           fillcolor="#BA55D3"];
    MBP           [label="Major Basic\nProtein (MBP)",          fillcolor="#9370DB"];
    ECP           [label="Eosinophil\nCationic Protein",        fillcolor="#9370DB"];
    EPX           [label="Eosinophil\nPeroxidase (EPX)",        fillcolor="#9370DB"];
    EDN           [label="Eosinophil-Derived\nNeurotoxin",      fillcolor="#9370DB"];
    EET           [label="Eosinophil\nExtracell Traps (EET)",   fillcolor="#9370DB"];
    EosApop       [label="Eosinophil\nApoptosis",               fillcolor="#DDA0DD"];
    Eotaxin1      [label="Eotaxin-1\n(CCL11)",                  fillcolor="#DDA0DD"];
    Eotaxin2      [label="Eotaxin-2\n(CCL24)",                  fillcolor="#DDA0DD"];
    Eotaxin3      [label="Eotaxin-3\n(CCL26)",                  fillcolor="#DDA0DD"];
    CCR3          [label="CCR3\n(Eotaxin Receptor)",            fillcolor="#DDA0DD"];
    IL5Ra         [label="IL-5Rα\n(Signal Receptor)",           fillcolor="#DDA0DD"];
    SIGLEC8       [label="Siglec-8\n(Inhibitory Receptor)",     fillcolor="#DDA0DD"];
    EosSurv       [label="Eosinophil\nSurvival Signals",        fillcolor="#DDA0DD"];
    LysoPL        [label="Lysophospholipids\n(PAF/LTC4)",       fillcolor="#9370DB"];
  }

  /* ================================================================
     CLUSTER 5: ANCA Pathway & Neutrophil Activation
  ================================================================ */
  subgraph cluster_anca {
    label="ANCA Pathway & Neutrophil Activation (~40%)";
    style=filled; fillcolor="#FFF5F5";
    color="#8B0000"; fontcolor="#8B0000"; penwidth=2;

    AntiMPO       [label="Anti-MPO ANCA\n(~40%)",               fillcolor="#FFB6C1"];
    AntiPR3       [label="Anti-PR3 ANCA\n(rare)",               fillcolor="#FFB6C1"];
    Neutrophil    [label="Neutrophils",                          fillcolor="#FF6347"];
    NeutPriming   [label="Neutrophil\nPriming (TNF/IL-18)",     fillcolor="#FFA07A"];
    MPO           [label="Myeloperoxidase\n(MPO)",               fillcolor="#FF6347"];
    PR3           [label="Proteinase 3\n(PR3)",                  fillcolor="#FF6347"];
    NeutAct       [label="Neutrophil\nActivation",               fillcolor="#FF4500"];
    NeutDeg       [label="Neutrophil\nDegranulation",            fillcolor="#FF4500"];
    NETs          [label="NETs\n(Neutrophil Traps)",             fillcolor="#FF4500"];
    ROS           [label="Reactive Oxygen\nSpecies (ROS)",       fillcolor="#FF6347"];
    Elastase      [label="Elastase &\nMMP-9",                    fillcolor="#FF6347"];
    FcgRIIa       [label="FcγRIIa\n(CD32)",                     fillcolor="#FFB6C1"];
    TNFa          [label="TNF-α",                               fillcolor="#FFA07A"];
    IL1b          [label="IL-1β",                               fillcolor="#FFA07A"];
    IL6           [label="IL-6",                                 fillcolor="#FFA07A"];
    IL17          [label="IL-17",                               fillcolor="#FFA07A"];
    CXCL8         [label="CXCL8/IL-8",                          fillcolor="#FFA07A"];
    CRP           [label="C-Reactive\nProtein (CRP)",            fillcolor="#FFA07A"];
  }

  /* ================================================================
     CLUSTER 6: Granuloma Formation
  ================================================================ */
  subgraph cluster_granuloma {
    label="Granuloma Formation";
    style=filled; fillcolor="#FFFFF0";
    color="#8B6914"; fontcolor="#8B6914"; penwidth=2;

    M1Macro       [label="M1 Macrophages\n(Activated)",         fillcolor="#FFD700"];
    Epitheloid    [label="Epithelioid Cells",                   fillcolor="#FFD700"];
    GiantCell     [label="Multinucleate\nGiant Cells",          fillcolor="#FFD700"];
    GranCore      [label="Necrotizing\nGranuloma Core",         fillcolor="#FFA500"];
    GranFibr      [label="Granuloma\nFibrosis",                 fillcolor="#FFA500"];
    CD4Gran       [label="CD4+ T Cells\n(Granuloma center)",    fillcolor="#FFD700"];
    IFNg_G        [label="IFN-γ\n(Granuloma maint.)",           fillcolor="#FFD700"];
    IL18G         [label="IL-18\n(Macrophage-derived)",         fillcolor="#FFD700"];
    IL12G         [label="IL-12\n(Granuloma signal)",           fillcolor="#FFD700"];
    MMP_G         [label="MMPs\n(Tissue remodeling)",           fillcolor="#FFA500"];
    FibronectG    [label="Fibronectin &\nCollagen Deposit",     fillcolor="#FFA500"];
  }

  /* ================================================================
     CLUSTER 7: Vascular Endothelium & Vasculitis
  ================================================================ */
  subgraph cluster_vasculitis {
    label="Vasculitis & Endothelial Injury";
    style=filled; fillcolor="#F5FFFA";
    color="#006400"; fontcolor="#006400"; penwidth=2;

    VascEndo      [label="Vascular\nEndothelium",               fillcolor="#98FB98"];
    ICAM1         [label="ICAM-1",                              fillcolor="#90EE90"];
    VCAM1         [label="VCAM-1",                              fillcolor="#90EE90"];
    E_sel         [label="E-Selectin",                          fillcolor="#90EE90"];
    VascPerm      [label="↑ Vascular\nPermeability",            fillcolor="#ADFF2F"];
    Thrombosis    [label="Microthrombosis",                     fillcolor="#32CD32"];
    NecroVasc     [label="Necrotizing\nVasculitis",             fillcolor="#228B22"];
    SmVessel      [label="Small-Medium\nVessel Damage",         fillcolor="#2E8B57"];
    Ischemia      [label="Tissue\nIschemia",                    fillcolor="#006400", fontcolor="white"];
    EndoApop      [label="Endothelial\nApoptosis",              fillcolor="#008000", fontcolor="white"];
    vWF           [label="von Willebrand\nFactor (vWF)",        fillcolor="#90EE90"];
    PAI1          [label="PAI-1\n(Coagulation)",                fillcolor="#90EE90"];
    PeriVFibr     [label="Perivascular\nFibrosis",              fillcolor="#228B22", fontcolor="white"];
  }

  /* ================================================================
     CLUSTER 8: Organ Manifestations
  ================================================================ */
  subgraph cluster_organs {
    label="Organ Manifestations (Three-Phase EGPA)";
    style=filled; fillcolor="#F8F0FF";
    color="#4B0082"; fontcolor="#4B0082"; penwidth=2;

    /* Prodromal Phase - Pulmonary/ENT */
    AllerRhino    [label="Allergic\nRhinosinusitis",            fillcolor="#E6E6FA"];
    NasalPoly     [label="Nasal Polyps",                        fillcolor="#E6E6FA"];
    Asthma        [label="Bronchial Asthma\n(Prodromal)",       fillcolor="#E6E6FA"];
    FEV1          [label="FEV1 ↓",                              fillcolor="#E6E6FA"];

    /* Eosinophilic Phase */
    PulmInfilt    [label="Pulmonary\nInfiltrates",              fillcolor="#D8BFD8"];
    PleuralEff    [label="Pleural Effusion",                    fillcolor="#D8BFD8"];

    /* Cardiac */
    CardEos       [label="Cardiac\nEosinophilia",               fillcolor="#C8A2C8"];
    Cardiomyo     [label="Eosinophilic\nCardiomyopathy",        fillcolor="#C8A2C8"];
    Pericard      [label="Pericarditis/\nPericardial Eff.",     fillcolor="#C8A2C8"];
    CardFibr      [label="Cardiac\nEndomyocardial Fibr.",       fillcolor="#C8A2C8"];
    LVEF_val      [label="LVEF ↓",                              fillcolor="#C8A2C8"];

    /* Peripheral Nervous System */
    MonoNeuM      [label="Mononeuritis\nMultiplex",             fillcolor="#B0C4DE"];
    AxonDmg       [label="Axonal\nDamage",                      fillcolor="#B0C4DE"];
    PNS           [label="Peripheral\nNeuropathy",              fillcolor="#B0C4DE"];
    CNSinv        [label="CNS\nInvolvement",                    fillcolor="#B0C4DE"];

    /* Renal */
    GlomeruN      [label="Glomerulonephritis\n(ANCA+, RPGN)",   fillcolor="#87CEEB"];
    Proteinuria   [label="Proteinuria &\nRenal Insuff.",        fillcolor="#87CEEB"];

    /* GI */
    GI_Eos        [label="GI Eosinophilia\n& Necrosis",         fillcolor="#E6E6FA"];
    GI_Bleed      [label="GI Bleeding &\nPerforation",          fillcolor="#E6E6FA"];

    /* Skin */
    Purpura       [label="Palpable\nPurpura",                   fillcolor="#DDA0DD"];
    SkinNod       [label="Subcutaneous\nNodules",               fillcolor="#DDA0DD"];
    Urticaria     [label="Urticaria",                           fillcolor="#DDA0DD"];
  }

  /* ================================================================
     CLUSTER 9: Drug Pharmacokinetics
  ================================================================ */
  subgraph cluster_pk {
    label="Drug Pharmacokinetics";
    style=filled; fillcolor="#FFF0F5";
    color="#DC143C"; fontcolor="#DC143C"; penwidth=2;

    /* Mepolizumab (anti-IL-5 mAb) */
    MepoSC        [label="Mepolizumab\nSC Dose (300mg)",        fillcolor="#FFB6C1"];
    MepoC         [label="Mepolizumab\nCentral (C1)",           fillcolor="#FF69B4"];
    MepoP         [label="Mepolizumab\nPeripheral (C2)",        fillcolor="#FF69B4"];
    MepoIL5       [label="Mepo:IL-5\nComplex (TMDD)",           fillcolor="#FF1493"];

    /* Benralizumab (anti-IL-5Rα mAb) */
    BenraSC       [label="Benralizumab\nSC Dose (30mg)",        fillcolor="#FFB6C1"];
    BenraC        [label="Benralizumab\nCentral (B1)",          fillcolor="#FF69B4"];
    BenraP        [label="Benralizumab\nPeripheral (B2)",       fillcolor="#FF69B4"];

    /* Prednisolone (oral GCS) */
    PredDose      [label="Prednisolone\nOral Dose",             fillcolor="#FFD0D0"];
    PredC         [label="Prednisolone\nPlasma (P1)",           fillcolor="#FF8C69"];
    PredEff       [label="Prednisolone\nEffect Site (Ce)",      fillcolor="#FF6B6B"];

    /* Cyclophosphamide (alkylating) */
    CycloIV       [label="Cyclophosphamide\nIV Dose",           fillcolor="#FFD0D0"];
    CycloC        [label="Cyclophosphamide\nCentral (Cy1)",     fillcolor="#FF8C69"];
    CycloM        [label="4-OH-Cyclophosph.\n(Active metab.)",  fillcolor="#FF4500"];

    /* Rituximab (anti-CD20) */
    RituIV        [label="Rituximab\nIV Dose",                  fillcolor="#FFD0D0"];
    RituC         [label="Rituximab\nCentral (R1)",             fillcolor="#FF8C69"];
    RituP         [label="Rituximab\nPeripheral (R2)",          fillcolor="#FF8C69"];
    RituCD20      [label="Rituximab:CD20\nComplex",             fillcolor="#FF4500"];

    /* Azathioprine */
    AzaDose       [label="Azathioprine\nOral Dose",             fillcolor="#FFD0D0"];
    AzaC          [label="Azathioprine\nActive (6-MP/TGN)",     fillcolor="#FF8C69"];
  }

  /* ================================================================
     CLUSTER 10: Drug PD & Clinical Endpoints
  ================================================================ */
  subgraph cluster_pd {
    label="Drug PD & Clinical Endpoints";
    style=filled; fillcolor="#F0F8FF";
    color="#1E90FF"; fontcolor="#1E90FF"; penwidth=2;

    BVAS          [label="BVAS Score\n(Activity)",              fillcolor="#87CEFA"];
    VDI           [label="VDI Score\n(Damage Index)",           fillcolor="#87CEFA"];
    BloodEosN     [label="Blood Eosinophil\nCount (#/µL)",      fillcolor="#6495ED"];
    TissueEosN    [label="Tissue Eosinophil\nCount",            fillcolor="#6495ED"];
    ECP_pl        [label="Plasma ECP\n(Biomarker)",             fillcolor="#6495ED"];
    TotalIgE_E    [label="Total IgE\n(kU/L)",                   fillcolor="#4169E1"];
    FEV1_E        [label="FEV1 %\nPredicted",                   fillcolor="#4169E1"];
    LVEF_E        [label="LVEF (%)\nEndpoint",                  fillcolor="#4169E1"];
    eGFR_E        [label="eGFR\n(mL/min/1.73m²)",              fillcolor="#4169E1"];
    NDS           [label="Neuropathy\nDisability Score",         fillcolor="#87CEFA"];
    QoL           [label="QoL (SF-36\nHRQoL)",                  fillcolor="#87CEFA"];
    RelRate       [label="Relapse Rate\n(%/year)",               fillcolor="#87CEFA"];
    CSSscore      [label="CSS Score\n(Five-factor)",            fillcolor="#87CEFA"];
    OCS_spar      [label="OCS Dose\nSparing (%)",               fillcolor="#6495ED"];
    Remission     [label="Clinical Remission\n(BVAS=0)",        fillcolor="#1E90FF", fontcolor="white"];
    ANCA_stat     [label="ANCA Status\n(Pos / Neg)",             fillcolor="#87CEFA"];
    PGI2          [label="Patient Global\nImpression",           fillcolor="#87CEFA"];
    CRPL          [label="CRP & ESR\n(Inflammation)",           fillcolor="#6495ED"];
  }

  /* ================================================================
     EDGES — Trigger → Innate
  ================================================================ */
  Allergen      -> AirwayEpi   [label="activates"];
  InfectTrigger -> AirwayEpi   [label="damages"];
  DrugTrigger   -> LTRAassoc   [color="#FF0000", label="LTRA"];
  EnvStress     -> AirwayEpi;
  OccupExposure -> AirwayEpi   [label="chemical"];
  AirwayEpi     -> TSLP        [label="releases"];
  AirwayEpi     -> IL33        [label="releases"];
  AirwayEpi     -> IL25        [label="releases"];
  AirwayEpi     -> Alarmins    [label="danger\nsignals"];
  TLR           -> DendCell    [label="activates"];
  TLR           -> M2Macro     [label="activates"];
  TSLP          -> DendCell    [label="DC2 priming"];
  TSLP          -> Basophil    [label="activates"];
  TSLP          -> ILC2        [label="activates"];
  IL33          -> ILC2        [label="activates"];
  IL33          -> MastCell    [label="activates"];
  IL33          -> Basophil    [label="activates"];
  IL25          -> ILC2        [label="activates"];
  Allergen      -> MastCell    [label="IgE-mediated\n(FcεRI)"];
  Allergen      -> DendCell    [label="Ag presentation"];
  ILC2          -> IL5         [label="produces"];
  ILC2          -> IL13        [label="produces"];
  ILC2          -> IL4         [label="produces"];
  ILC2          -> GMCSF       [label="produces"];
  MastCell      -> IL5         [label="releases"];
  MastCell      -> IL4         [label="releases"];
  Basophil      -> IL4         [label="releases"];
  Basophil      -> IL13        [label="releases"];
  CompSys       -> NeutAct     [label="C5a →\nactivation"];
  CompSys       -> MastCell    [label="C3a →\ndegranulation"];
  Alarmins      -> NeutPriming [label="primes"];
  GMCSF         -> EosSurv     [label="↑ survival"];
  M2Macro       -> IL10        [label="produces"];
  M2Macro       -> TGFB        [label="produces"];

  /* ================================================================
     Innate → Adaptive (Th2 polarization)
  ================================================================ */
  DendCell      -> NaiveCD4    [label="Ag-MHC II"];
  DendCell      -> IL12DC      [label="DC1: Th1\npriming"];
  DendCell      -> Th2         [label="DC2/OX40L:\nTh2 priming"];
  NaiveCD4      -> Th2         [label="IL-4/TSLP"];
  NaiveCD4      -> Th1         [label="IL-12/IFN-γ"];
  NaiveCD4      -> Treg        [label="TGF-β/IL-2"];
  NaiveCD4      -> Tfh         [label="ICOS"];
  IL12DC        -> Th1         [label="drives"];
  Th2           -> IL4         [label="secretes"];
  Th2           -> IL5         [label="secretes"];
  Th2           -> IL13        [label="secretes"];
  Th2           -> IL9         [label="secretes"];
  Th2           -> IL10        [label="secretes"];
  Th2           -> IL31        [label="secretes"];
  Th1           -> IFNg        [label="secretes"];
  Th1           -> IL12DC      [label="amplifies", style=dashed];
  Tfh           -> GermCenter  [label="drives"];
  GermCenter    -> PlasmaCell  [label="generates"];
  GermCenter    -> MemoryB     [label="generates"];
  BCells        -> PlasmaCell  [label="diff. with\nT-cell help"];
  PlasmaCell    -> IgE         [label="secretes\n(IL-4 driven)"];
  PlasmaCell    -> IgG4        [label="secretes"];
  PlasmaCell    -> IgA         [label="secretes"];
  IL4           -> BCells      [label="class switch\n→ IgE"];
  IL4           -> IgE         [label="drives"];
  IL4           -> Th2         [label="autocrine\namp.", style=dashed];
  IgE           -> MastCell    [label="sensitizes\n(FcεRI)"];
  IgE           -> Basophil    [label="sensitizes\n(FcεRI)"];
  IL9           -> MastCell    [label="growth factor"];
  Treg          -> Th2         [label="suppresses", color="#0000FF"];
  Treg          -> IL10        [label="secretes"];
  TGFB          -> Treg        [label="induces", style=dashed, color="#0000FF"];
  IL10          -> Th2         [label="modulates", style=dashed, color="#0000FF"];
  IL10          -> NeutAct     [label="inhibits", color="#0000FF"];

  /* ================================================================
     Th2/ILC2 → Eosinophil Biology
  ================================================================ */
  IL5           -> EosProd     [label="↑ production\n& maturation"];
  IL5           -> BloodEos    [label="↑ survival\n& release"];
  IL5           -> TissueEos   [label="↑ activation"];
  BoneMarrow    -> EosProd;
  EosProd       -> BloodEos    [label="release\n(IL-5 dep.)"];
  Eotaxin1      -> CCR3        [label="binds"];
  Eotaxin2      -> CCR3        [label="binds"];
  Eotaxin3      -> CCR3        [label="binds"];
  CCR3          -> BloodEos    [label="on Eos surface"];
  CCR3          -> TissueEos   [label="chemotaxis"];
  BloodEos      -> TissueEos   [label="extravasation\n(VCAM1/ICAM1)"];
  EosSurv       -> BloodEos    [label="↑ survival"];
  IL5Ra         -> BloodEos    [label="expressed on"];
  SIGLEC8       -> EosApop     [label="promotes\n(inhibitory)", color="#0000FF"];
  TissueEos     -> EosAct      [label="tissue signals"];
  EosAct        -> EosDeg      [label="triggers"];
  EosDeg        -> MBP         [label="releases"];
  EosDeg        -> ECP         [label="releases"];
  EosDeg        -> EPX         [label="releases"];
  EosDeg        -> EDN         [label="releases"];
  EosDeg        -> LysoPL      [label="releases\n(PAF, LTC4)"];
  EosDeg        -> EET         [label="generates"];
  EosApop       -> BloodEos    [label="clearance"];
  MBP           -> MastCell    [label="degranulates"];
  LysoPL        -> Asthma      [label="bronchoconstriction"];
  LysoPL        -> VascEndo    [label="activates"];
  Eotaxin1      -> TissueEos   [label="recruits"];
  Eotaxin2      -> TissueEos   [label="recruits"];
  Eotaxin3      -> TissueEos   [label="recruits"];

  /* ================================================================
     ANCA Pathway
  ================================================================ */
  TNFa          -> NeutPriming [label="primes\nneutrophils"];
  IL1b          -> NeutPriming [label="primes"];
  IL18G         -> NeutPriming [label="primes"];
  NeutPriming   -> Neutrophil  [label="→ surface\nMPO/PR3\nexpress."];
  Neutrophil    -> MPO         [label="expresses"];
  Neutrophil    -> PR3         [label="expresses"];
  AntiMPO       -> FcgRIIa     [label="Fc region"];
  AntiPR3       -> FcgRIIa     [label="Fc region"];
  FcgRIIa       -> NeutAct     [label="signal"];
  AntiMPO       -> NeutAct     [label="binds surface\nMPO"];
  NeutAct       -> NeutDeg     [label="triggers"];
  NeutDeg       -> ROS         [label="releases"];
  NeutDeg       -> Elastase    [label="releases"];
  NeutDeg       -> NETs        [label="generates"];
  NETs          -> AntiMPO     [label="exposes MPO\n→ more ANCA", style=dashed, color="#FF0000"];
  NETs          -> CompSys     [label="activates"];
  ROS           -> NecroVasc   [label="damages"];
  Elastase      -> NecroVasc   [label="degrades\nECM"];
  PlasmaCell    -> AntiMPO     [label="secretes\nANCA"];
  PlasmaCell    -> AntiPR3     [label="secretes"];
  TNFa          -> CXCL8       [label="induces"];
  IL1b          -> CXCL8       [label="induces"];
  CXCL8         -> Neutrophil  [label="recruits"];
  IL6           -> CRP         [label="induces"];
  IL1b          -> IL6         [label="cascade"];
  TNFa          -> IL6         [label="cascade"];

  /* ================================================================
     Granuloma Formation
  ================================================================ */
  TissueEos     -> GranCore    [label="surrounds"];
  M1Macro       -> GranCore    [label="forms core"];
  CD4Gran       -> GranCore    [label="maintains"];
  IFNg          -> M1Macro     [label="Th1 → M1\nactivation"];
  IFNg_G        -> M1Macro     [label="granuloma\nIFN-γ"];
  IL18G         -> IFNg_G      [label="induces"];
  IL12G         -> CD4Gran     [label="Th1 signal"];
  M1Macro       -> Epitheloid  [label="diff →"];
  Epitheloid    -> GiantCell   [label="fusion"];
  GiantCell     -> GranCore    [label="surrounds"];
  GranCore      -> GranFibr    [label="chronic →\nfibrosis"];
  TGFB          -> GranFibr    [label="induces"];
  TGFB          -> FibronectG  [label="↑ matrix"];
  MMP_G         -> GranFibr    [label="remodels\n(paradoxical)"];
  GranFibr      -> PulmInfilt  [label="contributes"];
  GranFibr      -> PeriVFibr   [label="around\nvessels"];
  Th1           -> CD4Gran     [label="granuloma\nTh1"];

  /* ================================================================
     Vasculitis & Endothelial Injury
  ================================================================ */
  NecroVasc     -> VascEndo    [label="damages"];
  ROS           -> EndoApop    [label="induces"];
  ECP           -> VascEndo    [label="damages"];
  EPX           -> VascEndo    [label="oxidative\ndamage"];
  EET           -> NecroVasc   [label="promotes"];
  MBP           -> NecroVasc   [label="promotes"];
  VascEndo      -> ICAM1       [label="upregulates\n(TNF/IL-1)"];
  VascEndo      -> VCAM1       [label="upregulates"];
  VascEndo      -> E_sel       [label="upregulates"];
  ICAM1         -> BloodEos    [label="adhesion\n(Mac-1/LFA-1)"];
  VCAM1         -> BloodEos    [label="adhesion\n(VLA-4/α4β1)"];
  VCAM1         -> Neutrophil  [label="adhesion"];
  NecroVasc     -> VascPerm    [label="increases"];
  VascPerm      -> Thrombosis  [label="promotes"];
  Thrombosis    -> SmVessel    [label="occludes"];
  SmVessel      -> Ischemia    [label="causes"];
  EndoApop      -> NecroVasc   [label="promotes"];
  vWF           -> Thrombosis  [label="promotes"];
  PAI1          -> Thrombosis  [label="promotes"];
  PeriVFibr     -> SmVessel    [label="compounds"];

  /* ================================================================
     Organ Manifestations
  ================================================================ */
  /* ENT & Asthma */
  AllerRhino    -> NasalPoly   [label="chronic →"];
  AllerRhino    -> Asthma      [label="prodromal\nphase"];
  Asthma        -> FEV1        [label="↓"];
  Asthma        -> PulmInfilt  [label="persistent"];
  IL13          -> Asthma      [label="mucus/remod."];
  IL5           -> Asthma      [label="eos-driven"];
  LysoPL        -> Asthma      [label="LTC4 →\nbronchospasm"];

  /* Pulmonary */
  TissueEos     -> PulmInfilt  [label="infiltrates"];
  GranCore      -> PulmInfilt  [label="necrotizing\ngranulomas"];
  PulmInfilt    -> PleuralEff  [label="associated"];
  PulmInfilt    -> FEV1        [label="↓"];

  /* Cardiac */
  TissueEos     -> CardEos     [label="infiltrates\nheart"];
  ECP           -> CardEos     [label="cardiotoxic"];
  MBP           -> CardEos     [label="toxic"];
  CardEos       -> Cardiomyo   [label="→\nmyocarditis"];
  CardEos       -> Pericard    [label="→"];
  Cardiomyo     -> CardFibr    [label="chronic →"];
  CardFibr      -> LVEF_val    [label="↓ systolic"];
  Ischemia      -> Cardiomyo   [label="coronary\nischemia"];
  LysoPL        -> Cardiomyo   [label="cardiotoxic\n(PAF)"];

  /* Peripheral Nervous System */
  Ischemia      -> MonoNeuM    [label="nerve vessel\nischemia"];
  ECP           -> AxonDmg     [label="neurotoxic"];
  EDN           -> AxonDmg     [label="neurotoxic"];
  AxonDmg       -> PNS         [label="→ deficit"];
  MonoNeuM      -> AxonDmg     [label="causes"];
  TissueEos     -> MonoNeuM    [label="perineurial\ninfiltration"];
  PNS           -> CNSinv      [label="rare extension"];
  PNS           -> NDS         [label="scores"];

  /* Renal */
  AntiMPO       -> GlomeruN    [label="ANCA → RPGN"];
  Ischemia      -> GlomeruN    [label="renal\nischemia"];
  NecroVasc     -> GlomeruN    [label="GBM damage"];
  GlomeruN      -> Proteinuria [label="→ loss"];
  Proteinuria   -> eGFR_E      [label="↓ GFR"];

  /* GI */
  TissueEos     -> GI_Eos      [label="infiltrates"];
  Ischemia      -> GI_Bleed    [label="GI ischemia"];
  GI_Eos        -> GI_Bleed    [label="→ ulceration"];

  /* Skin */
  NecroVasc     -> Purpura     [label="vessel\nrupture"];
  TissueEos     -> SkinNod     [label="subcutaneous"];
  IgE           -> Urticaria   [label="IgE-mediated"];
  MastCell      -> Urticaria   [label="histamine"];

  /* ================================================================
     Drug PK Flows
  ================================================================ */
  /* Mepolizumab */
  MepoSC        -> MepoC       [label="SC abs\n(F≈80%)\nka=0.004/h"];
  MepoC         -> MepoP       [label="k12=0.01/h"];
  MepoP         -> MepoC       [label="k21=0.008/h"];
  MepoC         -> MepoIL5     [label="IL-5 binding\nkon"];
  MepoIL5       -> MepoC       [label="koff"];
  IL5           -> MepoIL5     [label="target"];

  /* Benralizumab */
  BenraSC       -> BenraC      [label="SC abs\n(F≈59%)"];
  BenraC        -> BenraP      [label="k12"];
  BenraP        -> BenraC      [label="k21"];
  BenraC        -> IL5Ra       [label="blocks IL-5Rα\n+ ADCC kill"];

  /* Prednisolone */
  PredDose      -> PredC       [label="oral F≈82%"];
  PredC         -> PredEff     [label="effect site"];

  /* Cyclophosphamide */
  CycloIV       -> CycloC      [label="IV"];
  CycloC        -> CycloM      [label="hepatic\nactivation\n(CYP2B6)"];

  /* Rituximab */
  RituIV        -> RituC       [label="IV infusion"];
  RituC         -> RituP       [label="k12"];
  RituP         -> RituC       [label="k21"];
  RituC         -> RituCD20    [label="binds CD20\n(TMDD)"];

  /* Azathioprine */
  AzaDose       -> AzaC        [label="oral →\n6-MP/TGN"];

  /* ================================================================
     Drug PD Effects
  ================================================================ */
  /* Mepolizumab */
  MepoIL5       -> BloodEos    [label="↓ IL-5 →\n↓ eos", color="#DC143C"];
  MepoIL5       -> TissueEos   [label="↓", color="#DC143C"];
  MepoIL5       -> EosProd     [label="↓ BM\nproduction", color="#DC143C"];

  /* Benralizumab */
  BenraC        -> BloodEos    [label="near-zero\ndepletion\n(ADCC)", color="#DC143C"];
  BenraC        -> TissueEos   [label="deep\ndepletion", color="#DC143C"];
  BenraC        -> EosProd     [label="↓ IL-5Rα\nblock", color="#DC143C"];

  /* Prednisolone */
  PredEff       -> Th2         [label="suppresses", color="#DC143C"];
  PredEff       -> BloodEos    [label="↓", color="#DC143C"];
  PredEff       -> IL5         [label="↓", color="#DC143C"];
  PredEff       -> TissueEos   [label="↓", color="#DC143C"];
  PredEff       -> AntiMPO     [label="↓ ANCA\nproduction", color="#DC143C"];
  PredEff       -> TNFa        [label="↓", color="#DC143C"];
  PredEff       -> NecroVasc   [label="↓ inflam.", color="#DC143C"];
  PredEff       -> OCS_spar    [label="dose sparing\nobjective"];

  /* Cyclophosphamide */
  CycloM        -> BCells      [label="alkylates\n& depletes", color="#DC143C"];
  CycloM        -> PlasmaCell  [label="depletes", color="#DC143C"];
  CycloM        -> Neutrophil  [label="↓ function", color="#DC143C"];
  CycloM        -> AntiMPO     [label="↓ ANCA", color="#DC143C"];
  CycloM        -> Th2         [label="↓", color="#DC143C"];

  /* Rituximab */
  RituCD20      -> BCells      [label="depletes\n(ADCC/CDC)", color="#DC143C"];
  RituCD20      -> PlasmaCell  [label="depletes", color="#DC143C"];
  RituCD20      -> MemoryB     [label="depletes", color="#DC143C"];
  RituCD20      -> AntiMPO     [label="↓ ANCA", color="#DC143C"];
  RituCD20      -> IgE         [label="↓", color="#DC143C"];

  /* Azathioprine */
  AzaC          -> Th2         [label="↓ prolif.", color="#DC143C"];
  AzaC          -> BCells      [label="↓ prolif.", color="#DC143C"];
  AzaC          -> NeutPriming [label="↓", color="#DC143C"];

  /* ================================================================
     Clinical Endpoints Linkage
  ================================================================ */
  BloodEos      -> BloodEosN   [label="="];
  TissueEos     -> TissueEosN  [label="="];
  ECP           -> ECP_pl      [label="plasma\nlevel"];
  IgE           -> TotalIgE_E  [label="="];
  FEV1          -> FEV1_E      [label="="];
  LVEF_val      -> LVEF_E      [label="="];
  Proteinuria   -> eGFR_E      [label="↓"];

  BloodEosN     -> BVAS        [label="eos\ncomponent"];
  NecroVasc     -> BVAS        [label="organ\nscore"];
  GlomeruN      -> BVAS        [label="renal\ncomponent"];
  MonoNeuM      -> BVAS        [label="neuro\ncomponent"];
  CardEos       -> BVAS        [label="cardiac\ncomponent"];
  GI_Bleed      -> BVAS        [label="GI\ncomponent"];
  BVAS          -> Remission   [label="BVAS=0\n→ remission"];
  BVAS          -> RelRate     [label="predicts"];
  BVAS          -> QoL         [label="inversely\nrelated"];
  VDI           -> QoL         [label="chronic\ndamage ↓ QoL"];
  PNS           -> VDI         [label="contributes"];
  CardFibr      -> VDI         [label="contributes"];
  GlomeruN      -> VDI         [label="contributes"];
  GranFibr      -> VDI         [label="contributes"];
  NDS           -> QoL         [label="↓ QoL"];
  LVEF_E        -> QoL         [label="cardiac"];

  AntiMPO       -> ANCA_stat   [label="defines\n(+/-)"];
  ANCA_stat     -> GlomeruN    [label="ANCA+ →\nhigher risk"];
  ANCA_stat     -> BVAS        [label="ANCA+ →\nhigher score"];

  CSSscore      -> BloodEosN   [label="includes"];
  CSSscore      -> Asthma      [label="includes"];
  CSSscore      -> GI_Bleed    [label="includes"];
  CSSscore      -> MonoNeuM    [label="includes"];
  CSSscore      -> CardEos     [label="includes"];
  CSSscore      -> GlomeruN    [label="includes"];

  PredEff       -> OCS_spar;
  Remission     -> PGI2        [label="improved"];
  CRP           -> CRPL        [label="="];
  IL6           -> CRPL        [label="drives"];

  /* Feedback amplification */
  BloodEos      -> Eotaxin1    [label="tissue\nrecruitment\nfeedback", style=dashed];
  /* IL5 autocrine loop handled via Th2 -> IL5 edge */
  MBP           -> IL5         [label="autocrine\namp.", style=dashed, color="#888888"];
}
