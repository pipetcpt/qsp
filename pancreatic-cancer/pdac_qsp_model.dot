digraph PDAC_QSP {
    rankdir=LR;
    bgcolor="#1a1a2e";
    graph [fontname="Helvetica" fontcolor=white pad=0.5 nodesep=0.4 ranksep=1.2 splines=line overlap=false];
    node [style=filled fontcolor=white fontname="Helvetica" fontsize=10 shape=ellipse fillcolor="#2d4a7a"];
    edge [fontcolor=white fontname="Helvetica" fontsize=8 color="#aaaaaa"];

    // =========================================================
    // SUBGRAPH 1: Normal Pancreatic Biology
    // =========================================================
    subgraph cluster_normal {
        label="Normal Pancreatic Biology & Precursor Lesions";
        fontcolor=white;
        fontsize=12;
        style=filled;
        fillcolor="#0d2137";
        color="#4a90d9";

        Acinar_Cell     [label="Acinar Cell"           fillcolor="#2d6a9f"];
        Ductal_Cell     [label="Ductal Cell"            fillcolor="#2d6a9f"];
        Islet_Cell      [label="Islet Cell"             fillcolor="#2d6a9f"];
        PSC_Quiescent   [label="PSC (Quiescent)"        fillcolor="#2d6a9f"];
        ADM             [label="Acinar-Ductal\nMetaplasia (ADM)" fillcolor="#3d7abf"];
        PanIN_1A        [label="PanIN-1A"               fillcolor="#4a8acf"];
        PanIN_1B        [label="PanIN-1B"               fillcolor="#4a8acf"];
        PanIN_2         [label="PanIN-2"                fillcolor="#5a9adf"];
        PanIN_3         [label="PanIN-3 (CIS)"          fillcolor="#6aaaef"];
        IPMN            [label="IPMN"                   fillcolor="#3d7abf"];
        MCN             [label="MCN"                    fillcolor="#3d7abf"];
    }

    // =========================================================
    // SUBGRAPH 2: Driver Mutations
    // =========================================================
    subgraph cluster_mutations {
        label="Driver Mutations & Genomic Alterations";
        fontcolor=white;
        fontsize=12;
        style=filled;
        fillcolor="#1a0d37";
        color="#9b59b6";

        KRAS_G12D   [label="KRAS G12D\n(~40%)"          fillcolor="#7d3c98"];
        KRAS_G12V   [label="KRAS G12V\n(~10%)"          fillcolor="#7d3c98"];
        TP53_Loss   [label="TP53 Loss\n(~75%)"          fillcolor="#6c3483"];
        CDKN2A_Loss [label="CDKN2A Loss\n(p16, ~95%)"  fillcolor="#6c3483"];
        SMAD4_Loss  [label="SMAD4 Loss\n(~55%)"         fillcolor="#6c3483"];
        ARID1A_Mut  [label="ARID1A Mut\n(~10%)"         fillcolor="#5b2c6f"];
        BRCA1_Mut   [label="BRCA1 Mut\n(~3%)"           fillcolor="#5b2c6f"];
        BRCA2_Mut   [label="BRCA2 Mut\n(~7%)"           fillcolor="#5b2c6f"];
        PALB2_Mut   [label="PALB2 Mut\n(~1%)"           fillcolor="#5b2c6f"];
        ATM_Mut     [label="ATM Mut\n(~4%)"             fillcolor="#5b2c6f"];
        MLH1_MSI    [label="MLH1/MSI-H\n(~1%)"          fillcolor="#5b2c6f"];
        NTRK_Fusion [label="NTRK Fusion\n(<1%)"         fillcolor="#5b2c6f"];
        HRD_Score   [label="HRD Score\n(genomic scar)"  fillcolor="#7d3c98"];
    }

    // =========================================================
    // SUBGRAPH 3: KRAS/RAS-MAPK-PI3K Signaling
    // =========================================================
    subgraph cluster_kras {
        label="KRAS / RAS-MAPK / PI3K Signaling";
        fontcolor=white;
        fontsize=12;
        style=filled;
        fillcolor="#0d1a37";
        color="#3498db";

        KRAS_GTP    [label="KRAS-GTP\n(active)"         fillcolor="#1a5276"];
        BRAF        [label="BRAF"                        fillcolor="#1f618d"];
        CRAF        [label="CRAF (RAF1)"                 fillcolor="#1f618d"];
        MEK1        [label="MEK1 (MAP2K1)"               fillcolor="#2874a6"];
        MEK2        [label="MEK2 (MAP2K2)"               fillcolor="#2874a6"];
        ERK1        [label="ERK1 (MAPK3)"                fillcolor="#2980b9"];
        ERK2        [label="ERK2 (MAPK1)"                fillcolor="#2980b9"];
        ETS_TF      [label="ETS Transcription\nFactors"  fillcolor="#3498db"];
        c_MYC_KRAS  [label="c-MYC\n(KRAS-driven)"       fillcolor="#3498db"];
        PI3K_p110a  [label="PI3K p110α\n(PIK3CA)"       fillcolor="#1a5276"];
        PIP3        [label="PIP3"                        fillcolor="#1f618d"];
        PTEN_Loss   [label="PTEN Loss"                   fillcolor="#922b21"];
        AKT_pT308   [label="AKT (pT308)"                 fillcolor="#2874a6"];
        mTORC1      [label="mTORC1"                      fillcolor="#2980b9"];
        mTORC2      [label="mTORC2"                      fillcolor="#2980b9"];
        S6K1        [label="S6K1 (RPS6KB1)"              fillcolor="#3498db"];
        EIF4E       [label="eIF4E\n(translation)"        fillcolor="#3498db"];
        RalGDS      [label="RalGDS / RalA"               fillcolor="#2874a6"];
        CDC42       [label="CDC42 / RAC1"                fillcolor="#2874a6"];
        NF_kB       [label="NF-κB"                       fillcolor="#1f618d"];
        YAP1        [label="YAP1"                        fillcolor="#2874a6"];
        TAZ         [label="TAZ (WWTR1)"                 fillcolor="#2874a6"];
        Cyclin_D1   [label="Cyclin D1\n(CCND1)"         fillcolor="#3498db"];
        CDK4        [label="CDK4/6"                      fillcolor="#3498db"];
    }

    // =========================================================
    // SUBGRAPH 4: TGF-β / SMAD / EMT
    // =========================================================
    subgraph cluster_tgfb {
        label="TGF-β / SMAD / EMT / Metastasis";
        fontcolor=white;
        fontsize=12;
        style=filled;
        fillcolor="#0d3726";
        color="#27ae60";

        TGFb1           [label="TGF-β1"                  fillcolor="#1e8449"];
        TGFbR_I         [label="TGFβR-I (ALK5)"          fillcolor="#1d6a3a"];
        TGFbR_II        [label="TGFβR-II"                fillcolor="#1d6a3a"];
        pSMAD2          [label="pSMAD2"                  fillcolor="#239b56"];
        pSMAD3          [label="pSMAD3"                  fillcolor="#239b56"];
        SMAD4_complex   [label="SMAD2/3-SMAD4\nComplex"  fillcolor="#27ae60"];
        SMAD_targets    [label="SMAD Target\nGenes"       fillcolor="#27ae60"];
        SNAIL           [label="SNAIL (SNAI1)"            fillcolor="#1e8449"];
        ZEB1            [label="ZEB1"                    fillcolor="#1e8449"];
        ZEB2            [label="ZEB2"                    fillcolor="#1e8449"];
        E_Cadherin_Loss [label="E-Cadherin\nLoss (CDH1)" fillcolor="#922b21"];
        Vimentin        [label="Vimentin\n(VIM)"          fillcolor="#239b56"];
        MMP2            [label="MMP2"                    fillcolor="#1d6a3a"];
        MMP9            [label="MMP9"                    fillcolor="#1d6a3a"];
        Invasion        [label="Local Invasion"          fillcolor="#922b21"];
        CTC             [label="CTCs"                    fillcolor="#922b21"];
        Liver_Met       [label="Liver Metastasis"        fillcolor="#7b241c"];
        Peritoneal_Met  [label="Peritoneal\nMetastasis"  fillcolor="#7b241c"];
        Wnt_bCatenin    [label="Wnt/β-Catenin"           fillcolor="#1e8449"];
        Hedgehog        [label="Hedgehog\n(SHH/GLI)"     fillcolor="#1e8449"];
        NOTCH           [label="NOTCH\nSignaling"        fillcolor="#1e8449"];
    }

    // =========================================================
    // SUBGRAPH 5: Desmoplastic Stroma
    // =========================================================
    subgraph cluster_stroma {
        label="Desmoplastic Stroma & CAFs";
        fontcolor=white;
        fontsize=12;
        style=filled;
        fillcolor="#37260d";
        color="#e67e22";

        PSC_Activated           [label="PSC (Activated)"        fillcolor="#9a6200"];
        myoCAF                  [label="myoCAF\n(α-SMA+)"       fillcolor="#a04000"];
        iCAF                    [label="iCAF\n(IL-6+)"          fillcolor="#a04000"];
        apCAF                   [label="apCAF\n(MHC-II+)"       fillcolor="#a04000"];
        Collagen_I              [label="Collagen I\n(COL1A1)"   fillcolor="#b7770d"];
        Collagen_III            [label="Collagen III"           fillcolor="#b7770d"];
        Hyaluronic_Acid         [label="Hyaluronic Acid\n(HA)"  fillcolor="#b7770d"];
        PDGF_AB                 [label="PDGF-AB"                fillcolor="#9a6200"];
        FGF2                    [label="FGF2 (bFGF)"            fillcolor="#9a6200"];
        CTGF                    [label="CTGF (CCN2)"            fillcolor="#9a6200"];
        FAP_Fibroblast          [label="FAP+ Fibroblast"        fillcolor="#a04000"];
        IFP                     [label="Interstitial Fluid\nPressure (IFP)" fillcolor="#cd6116"];
        Drug_Penetration_Reduced [label="Drug Penetration\nReduced" fillcolor="#922b21"];
        PEGPH20                 [label="PEGPH20\n(HAase)"       shape=box fillcolor="#ff6b6b" style=filled];
        Pirfenidone             [label="Pirfenidone\n(anti-fibrotic)" shape=box fillcolor="#ff6b6b" style=filled];
    }

    // =========================================================
    // SUBGRAPH 6: Immunosuppressive TME
    // =========================================================
    subgraph cluster_immune {
        label="Immunosuppressive Tumor Microenvironment";
        fontcolor=white;
        fontsize=12;
        style=filled;
        fillcolor="#1a2637";
        color="#5dade2";

        CD8_T           [label="CD8+ T Cell\n(CTL)"     fillcolor="#1a6a8a"];
        CD4_Th1         [label="CD4+ Th1 Cell"          fillcolor="#1a6a8a"];
        Treg            [label="Treg\n(FoxP3+)"         fillcolor="#922b21"];
        PMN_MDSC        [label="PMN-MDSC"               fillcolor="#7d3c10"];
        Mo_MDSC         [label="Mo-MDSC"                fillcolor="#7d3c10"];
        TAM_M1          [label="TAM (M1)\nanti-tumor"   fillcolor="#1a6a4a"];
        TAM_M2          [label="TAM (M2)\npro-tumor"    fillcolor="#7d3c10"];
        NK_Cell         [label="NK Cell"                fillcolor="#1a6a8a"];
        TLS             [label="Tertiary Lymphoid\nStructures (TLS)" fillcolor="#1a5a7a"];
        mDC             [label="mDC\n(mature DC)"       fillcolor="#1a5a7a"];
        PD1             [label="PD-1 (PDCD1)"           fillcolor="#7d3c10"];
        PDL1            [label="PD-L1 (CD274)"          fillcolor="#7d3c10"];
        CTLA4           [label="CTLA-4"                 fillcolor="#7d3c10"];
        LAG3            [label="LAG-3"                  fillcolor="#7d3c10"];
        TIM3            [label="TIM-3 (HAVCR2)"         fillcolor="#7d3c10"];
        CD47            [label="CD47\n(don't eat me)"   fillcolor="#7d3c10"];
        CXCL1           [label="CXCL1"                  fillcolor="#2e86c1"];
        CXCL5           [label="CXCL5"                  fillcolor="#2e86c1"];
        IL10            [label="IL-10"                  fillcolor="#7d3c10"];
        IFN_gamma       [label="IFN-γ"                  fillcolor="#1a6a4a"];
        Pembrolizumab_drug [label="Pembrolizumab\n(anti-PD1)" shape=box fillcolor="#ff6b6b" style=filled];
        Nivolumab_drug  [label="Nivolumab\n(anti-PD1)"  shape=box fillcolor="#ff6b6b" style=filled];
        Ipilimumab_drug [label="Ipilimumab\n(anti-CTLA4)" shape=box fillcolor="#ff6b6b" style=filled];
        Relatlimab_drug [label="Relatlimab\n(anti-LAG3)" shape=box fillcolor="#ff6b6b" style=filled];
    }

    // =========================================================
    // SUBGRAPH 7: Angiogenesis
    // =========================================================
    subgraph cluster_angio {
        label="Angiogenesis & Hypoxia";
        fontcolor=white;
        fontsize=12;
        style=filled;
        fillcolor="#260d37";
        color="#8e44ad";

        HIF1a           [label="HIF-1α"                 fillcolor="#6c3483"];
        VEGF_A          [label="VEGF-A"                  fillcolor="#7d3c98"];
        VEGFR2          [label="VEGFR2 (KDR)"           fillcolor="#7d3c98"];
        Ang1            [label="Angiopoietin-1"         fillcolor="#5b2c6f"];
        Tie2            [label="Tie2 (TEK)"             fillcolor="#5b2c6f"];
        Ang2            [label="Angiopoietin-2"         fillcolor="#6c3483"];
        PDGFR_b         [label="PDGFRβ"                 fillcolor="#5b2c6f"];
        FGFR1           [label="FGFR1"                  fillcolor="#5b2c6f"];
        Hypoxia         [label="Tumor Hypoxia\n(pO2<5 mmHg)" fillcolor="#922b21"];
        Neoangiogenesis [label="Neoangiogenesis\n(poor quality)" fillcolor="#7d3c98"];
        Bevacizumab_drug [label="Bevacizumab\n(anti-VEGF)" shape=box fillcolor="#ff6b6b" style=filled];
        Ramucirumab_drug [label="Ramucirumab\n(anti-VEGFR2)" shape=box fillcolor="#ff6b6b" style=filled];
    }

    // =========================================================
    // SUBGRAPH 8: Drug PK Compartments
    // =========================================================
    subgraph cluster_drugs {
        label="Drug PK Compartments";
        fontcolor=white;
        fontsize=12;
        style=filled;
        fillcolor="#371a0d";
        color="#e74c3c";

        GEM_C1      [label="Gemcitabine\nPlasma (C1)"       shape=box fillcolor="#ff6b6b" style=filled];
        GEM_C2      [label="Gemcitabine\nTumor (C2)"        shape=box fillcolor="#e05555" style=filled];
        dFdCTP      [label="dFdCTP\n(active metabolite)"    shape=box fillcolor="#e05555" style=filled];
        NPAC_C1     [label="nab-Paclitaxel\nPlasma (C1)"    shape=box fillcolor="#ff6b6b" style=filled];
        NPAC_C2     [label="nab-Paclitaxel\nTumor (C2)"     shape=box fillcolor="#e05555" style=filled];
        OHP_FREE    [label="Oxaliplatin\nFree (plasma)"     shape=box fillcolor="#ff6b6b" style=filled];
        OHP_DNA     [label="Oxaliplatin\nDNA Adducts"       shape=box fillcolor="#e05555" style=filled];
        CPT11_plasma [label="Irinotecan\n(CPT-11)"          shape=box fillcolor="#ff6b6b" style=filled];
        SN38        [label="SN-38\n(active)"                shape=box fillcolor="#e05555" style=filled];
        SN38G       [label="SN-38-Glucuronide\n(inactive)"  shape=box fillcolor="#c0392b" style=filled];
        FU5_plasma  [label="5-FU\n(plasma)"                 shape=box fillcolor="#ff6b6b" style=filled];
        FdUMP       [label="FdUMP\n(TS inhibitor)"          shape=box fillcolor="#e05555" style=filled];
        Erlotinib_C1 [label="Erlotinib\n(EGFR-i)"          shape=box fillcolor="#ff6b6b" style=filled];
        MRTX1133_C1 [label="MRTX1133\n(KRAS G12D-i)"       shape=box fillcolor="#ff6b6b" style=filled];
        Adagrasib_C1 [label="Adagrasib\n(KRAS G12C-i)"     shape=box fillcolor="#ff6b6b" style=filled];
        SOS1_Inh    [label="BI-3406\n(SOS1-i)"             shape=box fillcolor="#ff6b6b" style=filled];
        Olaparib_C1 [label="Olaparib\n(PARP-i)"            shape=box fillcolor="#ff6b6b" style=filled];
        NalIRI_C1   [label="Nal-IRI\n(liposomal SN-38)"    shape=box fillcolor="#ff6b6b" style=filled];
    }

    // =========================================================
    // SUBGRAPH 9: Tumor Cell Biology
    // =========================================================
    subgraph cluster_tumor {
        label="Tumor Cell Biology & Cell Cycle";
        fontcolor=white;
        fontsize=12;
        style=filled;
        fillcolor="#0d3737";
        color="#1abc9c";

        CSC_Progenitor      [label="Cancer Stem\nCell (CSC)"    fillcolor="#0e6655"];
        Proliferating_Cells [label="Proliferating\nCells"       fillcolor="#117a65"];
        Quiescent_Cells     [label="Quiescent\nCells (G0)"      fillcolor="#117a65"];
        Tumor_Volume        [label="Tumor Volume\n(TV, cm³)"    fillcolor="#148f77"];
        DNA_Damage          [label="DNA Damage\n(DSB/SSB)"      fillcolor="#922b21"];
        G1S_Arrest          [label="G1/S Cell\nCycle Arrest"    fillcolor="#7d6608"];
        Intrinsic_Apoptosis [label="Intrinsic\nApoptosis (Cyt-c)" fillcolor="#1e8449"];
        Extrinsic_Apoptosis [label="Extrinsic\nApoptosis (TRAIL)" fillcolor="#1e8449"];
        BCL2                [label="BCL-2\n(anti-apoptotic)"    fillcolor="#922b21"];
        BCL_xL              [label="BCL-xL\n(anti-apoptotic)"   fillcolor="#922b21"];
        BAX                 [label="BAX\n(pro-apoptotic)"       fillcolor="#1e8449"];
        BAK                 [label="BAK1\n(pro-apoptotic)"      fillcolor="#1e8449"];
        p53_WT              [label="p53 (WT)\ntumor suppressor" fillcolor="#148f77"];
        p53_Mut             [label="p53 (Mutant)\ngain-of-function" fillcolor="#922b21"];
        MDM2                [label="MDM2\n(p53 degrader)"       fillcolor="#922b21"];
        p21_CDKN1A          [label="p21 (CDKN1A)\nCDK inhibitor" fillcolor="#148f77"];
        pRb                 [label="pRb\n(hypophosphorylated)"  fillcolor="#148f77"];
        Autophagy           [label="Autophagy\n(survival)"      fillcolor="#7d6608"];
        Necrosis            [label="Necrosis\n(core)"           fillcolor="#7b241c"];
        ROS                 [label="Reactive Oxygen\nSpecies (ROS)" fillcolor="#7d6608"];
    }

    // =========================================================
    // SUBGRAPH 10: Clinical Endpoints
    // =========================================================
    subgraph cluster_clinical {
        label="Clinical Endpoints & Biomarkers";
        fontcolor=white;
        fontsize=12;
        style=filled;
        fillcolor="#1a370d";
        color="#58d68d";

        CA19_9              [label="CA19-9\n(U/mL)"             fillcolor="#1d6a3a"];
        CEA                 [label="CEA\n(ng/mL)"               fillcolor="#1d6a3a"];
        ctDNA               [label="ctDNA\n(total)"             fillcolor="#239b56"];
        KRAS_ctDNA_VAF      [label="KRAS ctDNA\nVAF (%)"        fillcolor="#239b56"];
        RECIST_Response     [label="RECIST Response\n(PR/SD/PD)" fillcolor="#27ae60"];
        PFS                 [label="PFS\n(months)"              fillcolor="#1e8449"];
        OS                  [label="Overall Survival\n(months)" fillcolor="#145a32"];
        ORR                 [label="ORR (%)"                    fillcolor="#1e8449"];
        R0_Resection        [label="R0 Resection\nRate (%)"     fillcolor="#27ae60"];
        Bilirubin           [label="Bilirubin\n(mg/dL)"         fillcolor="#7d6608"];
        Amylase             [label="Amylase\n(IU/L)"            fillcolor="#7d6608"];
        Lipase              [label="Lipase\n(IU/L)"             fillcolor="#7d6608"];
        HbA1c               [label="HbA1c (%)\nnew-onset DM"   fillcolor="#7d6608"];
        Pain_Score          [label="Pain Score\n(NRS 0-10)"     fillcolor="#7d6608"];
        Weight_Loss         [label="Weight Loss\n(cachexia)"    fillcolor="#922b21"];
        Grade34_Neutropenia [label="Gr3/4 Neutropenia\n(toxicity)" fillcolor="#922b21"];
        Peripheral_Neuropathy [label="Peripheral\nNeuropathy"   fillcolor="#7d6608"];
        Grade34_Diarrhea    [label="Gr3/4 Diarrhea\n(toxicity)" fillcolor="#922b21"];
    }

    // =========================================================
    // EDGES: Precursor Lesion Progression
    // =========================================================
    KRAS_G12D       -> ADM          [label="initiates" color="#e67e22"];
    ADM             -> PanIN_1A     [label="" color="#e67e22"];
    PanIN_1A        -> PanIN_1B     [color="#e67e22"];
    PanIN_1B        -> PanIN_2      [color="#e67e22"];
    PanIN_2         -> PanIN_3      [color="#e67e22"];
    PanIN_3         -> Tumor_Volume [label="PDAC\nprogression" color="#ff4444"];
    Acinar_Cell     -> ADM          [label="stress/injury" color="#aaaaaa"];
    IPMN            -> Tumor_Volume [label="malignant\ntransformation" color="#ff4444" style=dashed];

    // =========================================================
    // EDGES: Driver Mutations
    // =========================================================
    KRAS_G12D       -> KRAS_GTP     [label="constitutive\nactivation" color="#e67e22" penwidth=2];
    KRAS_G12V       -> KRAS_GTP     [color="#e67e22"];
    TP53_Loss       -> p53_WT       [style=dashed color=red arrowhead=tee label="LOF"];
    CDKN2A_Loss     -> CDK4         [style=dashed color=red arrowhead=tee label="LOF"];
    SMAD4_Loss      -> SMAD4_complex [style=dashed color=red arrowhead=tee label="LOF"];
    BRCA2_Mut       -> HRD_Score    [label="contributes\nto HRD" color="#9b59b6"];
    BRCA1_Mut       -> HRD_Score    [color="#9b59b6"];
    PALB2_Mut       -> HRD_Score    [color="#9b59b6"];
    ATM_Mut         -> HRD_Score    [color="#9b59b6"];
    HRD_Score       -> Olaparib_C1  [label="sensitivity\n(biomarker)" color="#27ae60" style=dashed];

    // =========================================================
    // EDGES: KRAS/MAPK Cascade
    // =========================================================
    KRAS_GTP        -> BRAF         [penwidth=2 color="#3498db"];
    KRAS_GTP        -> CRAF         [color="#3498db"];
    BRAF            -> MEK1         [penwidth=2 color="#3498db"];
    CRAF            -> MEK1         [color="#3498db"];
    MEK1            -> ERK1         [penwidth=2 color="#3498db"];
    MEK2            -> ERK2         [color="#3498db"];
    MEK1            -> ERK2         [color="#3498db"];
    ERK1            -> c_MYC_KRAS   [label="phospho-\nactivation" color="#3498db"];
    ERK2            -> c_MYC_KRAS   [color="#3498db"];
    ERK1            -> ETS_TF       [color="#3498db"];
    ERK1            -> Cyclin_D1    [label="upregulation" color="#3498db"];
    Cyclin_D1       -> CDK4         [label="activates" color="#3498db"];
    CDK4            -> pRb          [label="phospho-\ninactivation" color="#e67e22" style=dashed arrowhead=tee];
    c_MYC_KRAS      -> Proliferating_Cells [color="#3498db" penwidth=2];

    // =========================================================
    // EDGES: PI3K / AKT / mTOR Cascade
    // =========================================================
    KRAS_GTP        -> PI3K_p110a   [color="#2980b9"];
    PI3K_p110a      -> PIP3         [label="PIP2→PIP3" color="#2980b9"];
    PTEN_Loss       -> PIP3         [style=dashed color=red arrowhead=tee label="PTEN\ninhibits"];
    PIP3            -> AKT_pT308    [color="#2980b9"];
    mTORC2          -> AKT_pT308    [label="pS473\nfeedback" color="#2980b9"];
    AKT_pT308       -> mTORC1       [penwidth=2 color="#2980b9"];
    mTORC1          -> S6K1         [color="#2980b9"];
    mTORC1          -> EIF4E        [label="via 4E-BP1" color="#2980b9"];
    S6K1            -> mTORC2       [label="feedback" color="#aaaaaa" style=dashed];

    // =========================================================
    // EDGES: KRAS Effectors
    // =========================================================
    KRAS_GTP        -> RalGDS       [color="#2874a6"];
    KRAS_GTP        -> CDC42        [color="#2874a6"];
    KRAS_GTP        -> NF_kB        [color="#2874a6"];
    NF_kB           -> PDL1         [label="transcription" color="#e74c3c"];
    NF_kB           -> BCL2         [label="survival" color="#e74c3c"];
    NF_kB           -> CXCL1        [color="#e74c3c"];
    YAP1            -> CSC_Progenitor [label="stemness\ngene pgm" color="#3498db"];
    TAZ             -> CSC_Progenitor [color="#3498db"];
    KRAS_GTP        -> YAP1         [color="#3498db"];

    // =========================================================
    // EDGES: TGF-β / SMAD Pathway
    // =========================================================
    TGFb1           -> TGFbR_II     [color="#27ae60"];
    TGFbR_II        -> TGFbR_I      [label="complex\nformation" color="#27ae60"];
    TGFbR_I         -> pSMAD2       [color="#27ae60"];
    TGFbR_I         -> pSMAD3       [color="#27ae60"];
    pSMAD2          -> SMAD4_complex [color="#27ae60"];
    pSMAD3          -> SMAD4_complex [color="#27ae60"];
    SMAD4_complex   -> SMAD_targets  [penwidth=2 color="#27ae60"];
    SMAD4_complex   -> SNAIL        [color="#27ae60"];
    SNAIL           -> E_Cadherin_Loss [label="represses\nCDH1" style=dashed color=red arrowhead=tee];
    SNAIL           -> Vimentin     [label="induces" color="#27ae60"];
    SNAIL           -> ZEB1         [color="#27ae60"];
    ZEB1            -> E_Cadherin_Loss [style=dashed color=red arrowhead=tee];
    ZEB2            -> E_Cadherin_Loss [style=dashed color=red arrowhead=tee];
    E_Cadherin_Loss -> Invasion     [color="#e74c3c"];
    Vimentin        -> Invasion     [color="#e74c3c"];
    MMP2            -> Invasion     [color="#e74c3c"];
    MMP9            -> Invasion     [color="#e74c3c"];
    SMAD_targets    -> MMP2         [color="#27ae60"];
    SMAD_targets    -> MMP9         [color="#27ae60"];
    Invasion        -> CTC          [color="#e74c3c"];
    CTC             -> Liver_Met    [color="#e74c3c"];
    CTC             -> Peritoneal_Met [color="#e74c3c"];
    Wnt_bCatenin    -> SNAIL        [color="#27ae60"];
    Hedgehog        -> SNAIL        [color="#27ae60"];
    NOTCH           -> SNAIL        [color="#27ae60"];

    // =========================================================
    // EDGES: Stromal Activation
    // =========================================================
    PSC_Quiescent   -> PSC_Activated [label="TGFβ/PDGF\nactivation" color="#e67e22"];
    TGFb1           -> PSC_Activated [color="#e67e22"];
    PDGF_AB         -> PSC_Activated [color="#e67e22"];
    PSC_Activated   -> myoCAF       [color="#e67e22"];
    PSC_Activated   -> iCAF         [color="#e67e22"];
    PSC_Activated   -> apCAF        [color="#e67e22"];
    myoCAF          -> Collagen_I   [penwidth=2 color="#e67e22"];
    myoCAF          -> Collagen_III [color="#e67e22"];
    myoCAF          -> Hyaluronic_Acid [color="#e67e22"];
    myoCAF          -> CTGF         [color="#e67e22"];
    myoCAF          -> TGFb1        [label="positive\nfeedback" color="#e67e22"];
    myoCAF          -> IFP          [label="ECM stiffness\n↑ IFP" color="#cd6116" penwidth=2];
    Hyaluronic_Acid -> IFP          [color="#cd6116"];
    Collagen_I      -> IFP          [color="#cd6116"];
    IFP             -> Drug_Penetration_Reduced [penwidth=2 color="#e74c3c"];
    FGF2            -> PSC_Activated [color="#e67e22"];
    FAP_Fibroblast  -> Collagen_I   [color="#e67e22"];
    PDGFR_b         -> PSC_Activated [color="#e67e22"];
    iCAF            -> CXCL1        [color="#e67e22"];
    iCAF            -> CXCL5        [color="#e67e22"];
    Pirfenidone     -> PSC_Activated [style=dashed color=red arrowhead=tee label="inhibits\nactivation"];
    PEGPH20         -> Hyaluronic_Acid [style=dashed color=red arrowhead=tee label="degrades"];

    // =========================================================
    // EDGES: Immune Suppression
    // =========================================================
    PDL1            -> CD8_T        [style=dashed color=red arrowhead=tee label="exhaustion/\nanergia" penwidth=2];
    Treg            -> CD8_T        [style=dashed color=red arrowhead=tee label="suppresses" penwidth=2];
    TAM_M2          -> IL10         [color="#e74c3c"];
    IL10            -> Treg         [label="expands" color="#e74c3c"];
    IL10            -> CD8_T        [style=dashed color=red arrowhead=tee];
    CXCL1           -> PMN_MDSC     [label="recruits" color="#e74c3c"];
    CXCL5           -> Mo_MDSC      [label="recruits" color="#e74c3c"];
    PMN_MDSC        -> CD8_T        [style=dashed color=red arrowhead=tee];
    Mo_MDSC         -> CD8_T        [style=dashed color=red arrowhead=tee];
    TAM_M2          -> PDL1         [label="upregulates" color="#e74c3c"];
    IFN_gamma       -> TAM_M1       [label="polarizes" color="#27ae60"];
    IFN_gamma       -> PDL1         [label="IFN-γ\ninduces" color="#e74c3c"];
    TAM_M1          -> IFN_gamma    [label="secretes" color="#27ae60"];
    CD8_T           -> IFN_gamma    [label="produces" color="#27ae60"];
    TLS             -> CD8_T        [label="supports" color="#27ae60"];
    mDC             -> CD8_T        [label="primes" color="#27ae60"];
    NK_Cell         -> Extrinsic_Apoptosis [color="#27ae60"];
    CD8_T           -> Extrinsic_Apoptosis [label="TRAIL/\nperforin" color="#27ae60"];
    PD1             -> CD8_T        [style=dashed color=red arrowhead=tee label="inhibitory\nreceptor"];
    CTLA4           -> CD4_Th1      [style=dashed color=red arrowhead=tee];
    LAG3            -> CD8_T        [style=dashed color=red arrowhead=tee];
    TIM3            -> CD8_T        [style=dashed color=red arrowhead=tee];
    Pembrolizumab_drug -> PD1       [style=dashed color=red arrowhead=tee label="blocks"];
    Nivolumab_drug  -> PD1          [style=dashed color=red arrowhead=tee label="blocks"];
    Ipilimumab_drug -> CTLA4        [style=dashed color=red arrowhead=tee label="blocks"];
    Relatlimab_drug -> LAG3         [style=dashed color=red arrowhead=tee label="blocks"];

    // =========================================================
    // EDGES: Angiogenesis
    // =========================================================
    Hypoxia         -> HIF1a        [penwidth=2 color="#8e44ad"];
    HIF1a           -> VEGF_A       [penwidth=2 color="#8e44ad"];
    VEGF_A          -> VEGFR2       [color="#8e44ad"];
    VEGFR2          -> Neoangiogenesis [color="#8e44ad"];
    Ang1            -> Tie2         [label="vessel\nstabilization" color="#8e44ad"];
    Ang2            -> Tie2         [style=dashed color=red arrowhead=tee label="destabilizes"];
    PDGFR_b         -> Neoangiogenesis [color="#8e44ad"];
    FGFR1           -> Neoangiogenesis [color="#8e44ad"];
    Tumor_Volume    -> Hypoxia      [label="hypoxic\ncore" color="#aaaaaa"];
    Neoangiogenesis -> Tumor_Volume [label="nutrient\nsupply" color="#8e44ad"];
    Bevacizumab_drug -> VEGF_A      [style=dashed color=red arrowhead=tee label="neutralizes"];
    Ramucirumab_drug -> VEGFR2      [style=dashed color=red arrowhead=tee label="blocks"];

    // =========================================================
    // EDGES: Drug PK/PD - Gemcitabine
    // =========================================================
    Drug_Penetration_Reduced -> GEM_C1  [style=dashed color=red arrowhead=tee label="reduces\ndelivery" penwidth=2];
    GEM_C1          -> GEM_C2       [label="tumor\nuptake" color="#e74c3c"];
    GEM_C2          -> dFdCTP       [label="CDA/dCK\nactivation" color="#e74c3c"];
    dFdCTP          -> DNA_Damage   [label="DNA\nincorporation" color="#e74c3c" penwidth=2];

    // =========================================================
    // EDGES: Drug PK/PD - nab-Paclitaxel
    // =========================================================
    NPAC_C1         -> NPAC_C2      [label="albumin-\nbinding" color="#e74c3c"];
    NPAC_C2         -> DNA_Damage   [label="microtubule\nstabilization" color="#e74c3c" penwidth=2];
    NPAC_C2         -> Drug_Penetration_Reduced [style=dashed color=red arrowhead=tee label="stroma\ndepletes HA"];

    // =========================================================
    // EDGES: Drug PK/PD - FOLFIRINOX components
    // =========================================================
    OHP_FREE        -> OHP_DNA      [label="DNA\nbinding" color="#e74c3c"];
    OHP_DNA         -> DNA_Damage   [label="Pt adducts" color="#e74c3c" penwidth=2];
    CPT11_plasma    -> SN38         [label="CES2\nhydrolysis" color="#e74c3c"];
    SN38            -> DNA_Damage   [label="TOPO1\ninhibition" color="#e74c3c" penwidth=2];
    SN38            -> SN38G        [label="UGT1A1\nglucuronidation" color="#aaaaaa"];
    FU5_plasma      -> FdUMP        [label="TS\ninhibition" color="#e74c3c"];
    FdUMP           -> DNA_Damage   [penwidth=2 color="#e74c3c"];
    NalIRI_C1       -> SN38         [label="liposomal\ndelivery" color="#e74c3c"];

    // =========================================================
    // EDGES: Targeted Therapy
    // =========================================================
    MRTX1133_C1     -> KRAS_G12D    [style=dashed color=red arrowhead=tee label="covalent\ninhibitor" penwidth=2];
    Adagrasib_C1    -> KRAS_GTP     [style=dashed color=red arrowhead=tee label="G12C only"];
    SOS1_Inh        -> KRAS_GTP     [style=dashed color=red arrowhead=tee label="SOS1-i\nprevents\nGTP loading"];
    Erlotinib_C1    -> KRAS_GTP     [style=dashed color=red arrowhead=tee label="EGFR→RAS\nupstream-i"];
    Olaparib_C1     -> DNA_Damage   [label="PARP-i\ntraps SSB\n→DSB" color="#e74c3c" penwidth=2 style=dashed];

    // =========================================================
    // EDGES: DNA Damage Response & Apoptosis
    // =========================================================
    DNA_Damage      -> G1S_Arrest   [label="checkpoint\nactivation" color="#e67e22" penwidth=2];
    DNA_Damage      -> p53_WT       [label="stabilizes\np53" color="#e67e22"];
    G1S_Arrest      -> Intrinsic_Apoptosis [label="if unrepairable" color="#27ae60"];
    p53_WT          -> p21_CDKN1A   [label="transcription" color="#27ae60"];
    p21_CDKN1A      -> pRb          [style=dashed color=red arrowhead=tee label="inhibits\nCDK4/6→pRb"];
    p53_WT          -> BAX          [label="transcription" color="#27ae60"];
    p53_WT          -> MDM2         [label="auto-\nregulation" color="#aaaaaa" style=dashed];
    MDM2            -> p53_WT       [style=dashed color=red arrowhead=tee label="ubiquitin\ndegradation"];
    TP53_Loss       -> p53_Mut      [label="mutant\ngain-of-\nfunction" color="#e74c3c"];
    p53_Mut         -> MDM2         [style=dashed color=red arrowhead=tee];
    BAX             -> Intrinsic_Apoptosis [penwidth=2 color="#27ae60"];
    BAK             -> Intrinsic_Apoptosis [color="#27ae60"];
    BCL2            -> Intrinsic_Apoptosis [style=dashed color=red arrowhead=tee label="anti-\napoptotic" penwidth=2];
    BCL_xL          -> Intrinsic_Apoptosis [style=dashed color=red arrowhead=tee];
    Extrinsic_Apoptosis -> Tumor_Volume [style=dashed color=red arrowhead=tee label="cell\ndeath" penwidth=2];
    Intrinsic_Apoptosis -> Proliferating_Cells [style=dashed color=red arrowhead=tee label="depletes" penwidth=2];
    ROS             -> DNA_Damage   [color="#e67e22"];
    Hypoxia         -> ROS          [color="#e67e22"];
    Autophagy       -> Proliferating_Cells [label="nutrient\nrecycling" color="#aaaaaa"];

    // =========================================================
    // EDGES: Tumor Growth Dynamics
    // =========================================================
    CSC_Progenitor      -> Proliferating_Cells [penwidth=2 color="#27ae60" label="self-\nrenewal"];
    Proliferating_Cells -> Tumor_Volume         [penwidth=2 color="#27ae60"];
    Proliferating_Cells -> Quiescent_Cells      [label="G0 entry" color="#aaaaaa"];
    Quiescent_Cells     -> Proliferating_Cells  [label="re-entry" color="#aaaaaa"];
    Proliferating_Cells -> Necrosis             [label="nutrient\ndeprived" color="#aaaaaa"];
    pRb                 -> Proliferating_Cells  [label="G1 block\nif hypophos" style=dashed color=red arrowhead=tee];

    // =========================================================
    // EDGES: Clinical Endpoints
    // =========================================================
    Tumor_Volume    -> CA19_9       [label="secreted by\ntumor cells" color="#58d68d" penwidth=2];
    Tumor_Volume    -> CEA          [color="#58d68d"];
    Tumor_Volume    -> ctDNA        [label="shed DNA" color="#58d68d"];
    ctDNA           -> KRAS_ctDNA_VAF [label="KRAS\nmutation" color="#58d68d"];
    CA19_9          -> RECIST_Response [label="surrogate\nbiomarker" color="#58d68d" style=dashed];
    Tumor_Volume    -> RECIST_Response [penwidth=2 color="#58d68d"];
    RECIST_Response -> ORR          [color="#58d68d"];
    RECIST_Response -> PFS          [penwidth=2 color="#58d68d"];
    PFS             -> OS           [penwidth=2 color="#58d68d"];
    Tumor_Volume    -> R0_Resection [label="resectability\n(borderline)" color="#58d68d" style=dashed];
    Tumor_Volume    -> Bilirubin    [label="biliary\ncompression" color="#aaaaaa"];
    Tumor_Volume    -> Amylase      [color="#aaaaaa"];
    Tumor_Volume    -> Lipase       [color="#aaaaaa"];
    Tumor_Volume    -> Weight_Loss  [label="cancer\ncachexia" color="#e74c3c" penwidth=2];
    Islet_Cell      -> HbA1c        [label="destruction\n→DM" color="#aaaaaa"];
    Tumor_Volume    -> Pain_Score   [label="neural\ninvasion" color="#aaaaaa"];
    Grade34_Neutropenia -> OS       [label="toxicity\nlimits\ndosing" color="#e74c3c" style=dashed];
    Grade34_Diarrhea -> OS          [label="toxicity\nlimits\ndosing" color="#e74c3c" style=dashed];
    NPAC_C2         -> Peripheral_Neuropathy [label="dose-\nlimiting" color="#e74c3c" style=dashed];
    OHP_FREE        -> Peripheral_Neuropathy [color="#e74c3c" style=dashed];
    GEM_C2          -> Grade34_Neutropenia   [color="#e74c3c" style=dashed];
    SN38            -> Grade34_Diarrhea      [color="#e74c3c" style=dashed];
    Liver_Met       -> OS           [style=dashed color=red arrowhead=tee label="reduces\nsurvival"];
    Peritoneal_Met  -> OS           [style=dashed color=red arrowhead=tee label="reduces\nsurvival"];

    // =========================================================
    // EDGES: Additional cross-cluster connections
    // =========================================================
    SMAD4_Loss      -> TGFb1        [label="releases\ngrowth\ninhibition" color="#e67e22" style=dashed];
    Hedgehog        -> PSC_Activated [label="paracrine\nstroma" color="#e67e22"];
    iCAF            -> TGFb1        [label="secretes" color="#e67e22"];
    myoCAF          -> PDGF_AB      [label="autocrine" color="#e67e22"];
    Tumor_Volume    -> PDGF_AB      [label="paracrine\nstromal" color="#e67e22"];
    Tumor_Volume    -> TGFb1        [label="tumor\nsecretion" color="#e67e22"];
    HIF1a           -> CXCL1        [label="hypoxia-\ndriven" color="#e74c3c"];
    ERK1            -> HIF1a        [label="stabilizes" color="#3498db"];
    AKT_pT308       -> HIF1a        [label="via mTOR\ntranslation" color="#2980b9"];
    mTORC1          -> HIF1a        [label="translation" color="#2980b9"];
    c_MYC_KRAS      -> HIF1a        [color="#3498db"];
    c_MYC_KRAS      -> Autophagy    [label="metabolic\nreprog." color="#3498db"];
    KRAS_GTP        -> ROS          [label="metabolic\nreprog." color="#3498db"];
}
