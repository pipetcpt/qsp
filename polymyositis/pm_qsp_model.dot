digraph PolymyositisQSP {
  graph [rankdir=LR, fontname="Helvetica", fontsize=11, splines=ortho,
         label="Polymyositis (PM) — Quantitative Systems Pharmacology Map\nCD8+ T-cell Mediated Inflammatory Myopathy with Drug PK/PD",
         labelloc=t, labeljust=c, bgcolor="#FAFAFA", pad=0.5, nodesep=0.35, ranksep=0.7];
  node  [fontname="Helvetica", fontsize=9, style=filled, shape=box, margin="0.10,0.04"];
  edge  [fontsize=8, arrowsize=0.7];

  /* ─────────────────────────────────────────────
     CLUSTER 1: Environmental & Genetic Triggers
  ───────────────────────────────────────────── */
  subgraph cluster_triggers {
    label="Triggers & Genetic Risk"; style=filled; color="#FFF3E0";
    node [fillcolor="#FFE0B2"];

    viral_infect   [label="Viral Infection\n(Coxsackie, EBV,\nHIV, HTLV-1)"];
    bacterial_ag   [label="Bacterial Antigens\n(Molecular Mimicry)"];
    uv_exposure    [label="UV / Environmental\nStressors"];
    drug_triggers  [label="Drug-Induced\n(Statin, D-penicillamine,\nHydralazine)"];
    hlaDR3         [label="HLA-DR3 / DQ2\nGenetic Risk"];
    antisynthetase [label="Anti-Synthetase\nAntibodies\n(Anti-Jo-1, PL-7, PL-12)"];
    anti_SRP       [label="Anti-SRP Ab\n(Signal Recognition\nParticle)"];
    anti_MDA5      [label="Anti-MDA5 Ab\n(Melanoma Differentiation\nAssociated protein 5)"];
    anti_Mi2       [label="Anti-Mi-2 Ab\n(Dermatomyositis/PM)"];
    TLR_activation [label="TLR3 / TLR7\nActivation\n(dsRNA, ssRNA)"];
  }

  /* ─────────────────────────────────────────────
     CLUSTER 2: Innate Immunity
  ───────────────────────────────────────────── */
  subgraph cluster_innate {
    label="Innate Immune Activation"; style=filled; color="#E3F2FD";
    node [fillcolor="#BBDEFB"];

    pDC            [label="Plasmacytoid\nDendritic Cells\n(pDC)"];
    mDC            [label="Myeloid\nDendritic Cells\n(mDC)"];
    NK_cells       [label="NK Cells\n(CD56+CD16+)"];
    NKT_cells      [label="NKT Cells"];
    macro_M1       [label="M1 Macrophages\n(pro-inflammatory)"];
    macro_M2       [label="M2 Macrophages\n(anti-inflammatory)"];
    neutrophils    [label="Neutrophils\n(NET formation)"];
    mast_cells     [label="Mast Cells\n(Degranulation)"];
    IFN_alpha      [label="IFN-α/β\n(Type I Interferon)"];
    IFN_signature  [label="Interferon\nSignature\n(ISG15, IFIT1, MX1)"];
    NLRP3          [label="NLRP3\nInflammasome\nActivation"];
    complement_act [label="Complement\nActivation\n(C3a, C5a, MAC)"];
    NETs           [label="Neutrophil\nExtracellular Traps\n(NETs)"];
  }

  /* ─────────────────────────────────────────────
     CLUSTER 3: Adaptive Immunity — T cells
  ───────────────────────────────────────────── */
  subgraph cluster_Tcell {
    label="Adaptive Immunity — T Cells"; style=filled; color="#F3E5F5";
    node [fillcolor="#E1BEE7"];

    naiveCD8       [label="Naïve CD8+ T Cell"];
    activCD8       [label="Activated\nCD8+ T Cell\n(Cytotoxic)"];
    mem_CD8        [label="Memory\nCD8+ T Cell"];
    effCD8_muscle  [label="Effector CD8+\nin Muscle Tissue\n(Perforin+, Granzyme B+)"];
    naiveCD4       [label="Naïve CD4+ T Cell"];
    Th1            [label="Th1 Cell\n(IFN-γ, TNF-α, IL-2)"];
    Th17           [label="Th17 Cell\n(IL-17A, IL-22)"];
    Treg           [label="Regulatory T Cell\n(CD4+CD25+FoxP3+)"];
    Tfh            [label="Follicular Helper\nT Cell (Tfh)"];
    TCR_activation [label="TCR/MHC-I\nComplex Activation\n(CD8-peptide-MHC-I)"];
    costim_28_80   [label="Co-stimulation\nCD28 / CD80/86"];
    CTLA4_pathway  [label="CTLA-4\nInhibitory Signal"];
    PD1_PDL1       [label="PD-1/PD-L1\nCheckpoint"];
    IL2_signaling  [label="IL-2 Signaling\n(T cell proliferation)"];
    granzyme_B     [label="Granzyme B\nRelease"];
    perforin       [label="Perforin\nPore Formation"];
    FasL_pathway   [label="FasL/Fas\nApoptosis Pathway"];
  }

  /* ─────────────────────────────────────────────
     CLUSTER 4: Adaptive Immunity — B cells
  ───────────────────────────────────────────── */
  subgraph cluster_Bcell {
    label="Adaptive Immunity — B Cells & Autoantibodies"; style=filled; color="#E8F5E9";
    node [fillcolor="#C8E6C9"];

    naiveB         [label="Naïve B Cell"];
    activB         [label="Activated B Cell"];
    plasmablast    [label="Plasmablast"];
    plasma_cell    [label="Long-lived\nPlasma Cell"];
    mem_B          [label="Memory B Cell"];
    germinal_ctr   [label="Germinal Center\nReaction"];
    BAFF_APRIL     [label="BAFF / APRIL\n(B-cell Survival\nFactors)"];
    IgG_autoAb     [label="IgG\nAutoantibodies\n(Anti-Jo-1, SRP, MDA5)"];
    IgM_RF         [label="Rheumatoid Factor\n(IgM-RF)"];
    immune_complex  [label="Immune Complex\nFormation & Deposition"];
    BCR_activation [label="BCR / TLR\nDual Activation"];
  }

  /* ─────────────────────────────────────────────
     CLUSTER 5: Cytokine Network
  ───────────────────────────────────────────── */
  subgraph cluster_cytokines {
    label="Cytokine & Chemokine Network"; style=filled; color="#FFF9C4";
    node [fillcolor="#FFF176"];

    TNFalpha       [label="TNF-α"];
    IL1beta        [label="IL-1β"];
    IL6            [label="IL-6"];
    IL8_CXCL8      [label="IL-8 / CXCL8\n(Neutrophil Chemoattractant)"];
    IL12           [label="IL-12\n(Th1 Polarization)"];
    IL17A          [label="IL-17A"];
    IL18           [label="IL-18\n(IFN-γ Inducer)"];
    IL23           [label="IL-23\n(Th17 Maintenance)"];
    IFNgamma       [label="IFN-γ\n(M1 Activation,\nMHC-I Upregulation)"];
    TGFbeta        [label="TGF-β\n(Fibrosis, Treg)"];
    IL10           [label="IL-10\n(Anti-inflammatory)"];
    IL4_IL13       [label="IL-4 / IL-13\n(Th2, M2)"];
    CXCL10         [label="CXCL10 / IP-10\n(T Cell Homing)"];
    CCL2_MCP1      [label="CCL2 / MCP-1\n(Monocyte Recruitment)"];
    VEGF           [label="VEGF\n(Neovascularization)"];
    OSM            [label="Oncostatin M\n(Muscle Atrophy)"];
    MIF            [label="MIF\n(Macrophage Migration\nInhibitory Factor)"];
    JAK_STAT       [label="JAK1/2 — STAT1/3\nSignaling Hub"];
    STAT4          [label="STAT4\n(IL-12 pathway)"];
    NF_kB          [label="NF-κB\nActivation"];
  }

  /* ─────────────────────────────────────────────
     CLUSTER 6: Muscle Pathology
  ───────────────────────────────────────────── */
  subgraph cluster_muscle {
    label="Skeletal Muscle Pathology"; style=filled; color="#FFEBEE";
    node [fillcolor="#FFCDD2"];

    muscle_fiber   [label="Skeletal Muscle\nFiber (Myofiber)"];
    MHCI_express   [label="MHC-I\nUpregulation\non Myofibers"];
    sarcomere_dam  [label="Sarcomere\nDamage"];
    mitochondria_d [label="Mitochondrial\nDysfunction\n(mtDNA damage)"];
    myonuclei_loss [label="Myonuclei Loss\n(Apoptosis)"];
    necrosis_fiber [label="Myofiber\nNecrosis"];
    phagocytosis_d [label="Macrophage\nPhagocytosis of\nNecrotic Debris"];
    endomysial_inf [label="Endomysial\nInflammation\n(CD8+ T cells,\nMacrophages)"];
    perimysial_inf [label="Perimysial\nInflammation"];
    satellite_cell [label="Satellite Cell\nActivation\n(Regeneration)"];
    myogenin       [label="Myogenin / MyoD\n(Myogenesis TF)"];
    muscle_regen   [label="Muscle Fiber\nRegeneration\n(Basophilic fibers)"];
    atrophy        [label="Muscle Atrophy\n& Weakness"];
    CK_release     [label="Creatine Kinase\n(CK) Release\ninto Blood"];
    aldolase_rel   [label="Aldolase\nRelease"];
    myoglobin_rel  [label="Myoglobin\nRelease\n(Myoglobinuria)"];
    connective_fib [label="Endomysial\nFibrosis"];
    fatty_replace  [label="Fatty Replacement\nof Muscle"];
    muscle_edema   [label="Perifascicular\nEdema (MRI)"];
  }

  /* ─────────────────────────────────────────────
     CLUSTER 7: Extra-muscular Manifestations
  ───────────────────────────────────────────── */
  subgraph cluster_extramuscular {
    label="Extra-muscular & Systemic Manifestations"; style=filled; color="#E0F2F1";
    node [fillcolor="#B2DFDB"];

    ILD_lung       [label="Interstitial Lung\nDisease (ILD)\n(40% of PM)"];
    lung_fibrosis  [label="Pulmonary Fibrosis\n(UIP/NSIP pattern)"];
    FVC_decline    [label="FVC / DLCO\nDecline"];
    cardiac_myop   [label="Cardiac\nMyopathy\n(Conduction defects)"];
    arrythmia      [label="Arrhythmia\n(AV block, CHF)"];
    dysphagia_path [label="Dysphagia\n(Pharyngeal Muscle\nWeakness)"];
    aspiration_pn  [label="Aspiration\nPneumonia Risk"];
    arthralgia     [label="Polyarthralgia /\nNon-erosive Arthritis"];
    fever_sys      [label="Systemic Fever,\nFatigue, Weight Loss"];
    Raynaud_pheno  [label="Raynaud's\nPhenomenon"];
    mechanic_hands [label="Mechanic's Hands\n(Skin Fissures)"];
    calcinosis_dep [label="Calcinosis\n(Less common in PM)"];
    cancer_assoc   [label="Cancer-associated\nMyositis Risk\n↑Lung, Ovary, GI)"];
  }

  /* ─────────────────────────────────────────────
     CLUSTER 8: Corticosteroid PK/PD
  ───────────────────────────────────────────── */
  subgraph cluster_steroid_pk {
    label="Corticosteroid PK/PD (Prednisone/Prednisolone)"; style=filled; color="#E8EAF6";
    node [fillcolor="#C5CAE9"];

    pred_oral_dose [label="Oral Prednisone\nDose (mg/day)\n1–2 mg/kg/day initial"];
    pred_abs       [label="GI Absorption\n(F~80%, Tmax~1h)"];
    pred_central   [label="Prednisone\nCentral\nCompartment (C1)"];
    pred_periph    [label="Prednisone\nPeripheral\nCompartment (C2)"];
    prednis_active [label="Active\nPrednisolone\n(11β-HSD conversion)"];
    GR_receptor    [label="Glucocorticoid\nReceptor (GR)"];
    GR_complex     [label="GR-Prednisolone\nComplex\n(Cytosol→Nucleus)"];
    GRE_transact   [label="GRE\nTransactivation\n(Anti-inflamm. genes)"];
    GRE_transrep   [label="GRE\nTransrepression\n(AP-1, NF-κB block)"];
    steroid_ADR    [label="Steroid Adverse\nEffects:\nOsteoporosis, DM,\nHyperglycemia, Infect"];
    pred_elim      [label="Elimination\n(t½ ~3h pred;\n~2–3h prednis)"];
  }

  /* ─────────────────────────────────────────────
     CLUSTER 9: Immunosuppressant PK/PD
  ───────────────────────────────────────────── */
  subgraph cluster_IS_pk {
    label="Immunosuppressant PK/PD (MTX / AZA / Tacrolimus)"; style=filled; color="#FBE9E7";
    node [fillcolor="#FFCCBC"];

    MTX_dose       [label="Methotrexate\nDose (7.5–25 mg/wk)"];
    MTX_abs        [label="MTX Absorption\n(F~70%)"];
    MTX_central    [label="MTX Central\nCompartment"];
    MTX_polyglut   [label="MTX Polyglutamates\n(Long intracell t½)"];
    DHFR_inhib     [label="DHFR Inhibition\n(Folate Metabolism)"];
    AICAR_accum    [label="AICAR Accumulation\n(Adenosine Release)"];
    MTX_anti_inf   [label="MTX Anti-inflam.\nEffect (↓IL-1, TNF-α,\nT-cell proliferation)"];
    MTX_toxicity   [label="MTX Toxicity:\nHepato-, Pneumo-,\nMucositis"];

    AZA_dose       [label="Azathioprine\n(AZA) Dose\n(1.5–3 mg/kg/day)"];
    AZA_to_6MP     [label="AZA→6-MP\n(Non-enzymatic)"];
    sixMP_to_6TGN  [label="6-MP→6-TGN\n(via HPRT)"];
    TPMT_metab     [label="TPMT\nMetabolism\n(6-TGN↓ if TPMT↑)"];
    sixTGN_effect  [label="6-TGN Effect:\nPurine Synthesis\nInhibition, T/B cell ↓"];

    TAC_dose       [label="Tacrolimus\n(FK506) Dose\n(0.05–0.1 mg/kg/day)"];
    TAC_FKBP12     [label="TAC-FKBP12\nComplex"];
    calcineurin_in [label="Calcineurin\nInhibition"];
    NFAT_block     [label="NFAT Nuclear\nTranslocation Block\n(↓IL-2, T cell prolif)"];
    TAC_toxicity   [label="Tacrolimus Toxicity:\nNephrotoxicity,\nHyperglycemia, Tremor"];
  }

  /* ─────────────────────────────────────────────
     CLUSTER 10: Biologic PK/PD (Rituximab / IVIG)
  ───────────────────────────────────────────── */
  subgraph cluster_biologic_pk {
    label="Biologic Agents PK/PD (Rituximab / IVIG / JAK-i)"; style=filled; color="#F9FBE7";
    node [fillcolor="#F0F4C3"];

    RTX_infusion   [label="Rituximab IV\nInfusion\n(375 mg/m² ×4\nor 1000 mg ×2)"];
    RTX_central    [label="Rituximab\nCentral\nCompartment (C1)"];
    RTX_periph     [label="Rituximab\nPeripheral\nCompartment (C2)"];
    RTX_CD20_bind  [label="CD20 Receptor\nBinding & Saturation\n(TMDD model)"];
    B_cell_deplet  [label="B Cell Depletion\n(ADCC, CDC,\nApoptosis)"];
    RTX_repopu     [label="B Cell\nRepopulation\n(~6–9 months)"];
    IgG_decline    [label="IgG Autoantibody\nDecline"];

    IVIG_dose      [label="IVIG Dose\n(2 g/kg ×2-3 days)"];
    IVIG_FcRn      [label="FcRn-mediated\nIVIG Clearance\n(Pathogenic IgG ↓)"];
    IVIG_Fc_inhib  [label="FcγR Inhibitory\nSignaling (Fc-γRIIb)"];
    IVIG_antiinfl  [label="IVIG Anti-inflamm:\nCytokine neutralization,\nT-cell modulation"];

    JAKi_oral      [label="JAK Inhibitor\n(Baricitinib/Ruxolitinib)\nOral Dose"];
    JAKi_JAK12     [label="JAK1/2\nInhibition"];
    STAT_block     [label="STAT1/3/5\nPhosphorylation\nBlock"];
    JAKi_IFN_sup   [label="IFN Signature\nSuppression"];
    JAKi_cytok_red [label="Cytokine\nReduction\n(↓IL-6, IL-12, IFN-γ)"];
  }

  /* ─────────────────────────────────────────────
     CLUSTER 11: Clinical Endpoints & Biomarkers
  ───────────────────────────────────────────── */
  subgraph cluster_endpoints {
    label="Clinical Endpoints & Biomarkers"; style=filled; color="#F5F5F5";
    node [fillcolor="#EEEEEE"];

    CK_serum       [label="Serum CK\n(Biomarker, U/L)\nNormal <200 U/L\nPM: 1000–50000 U/L"];
    aldolase_serum [label="Serum Aldolase\n(Biomarker)"];
    LDH_serum      [label="LDH\n(Biomarker)"];
    CRP_ESR        [label="CRP / ESR\n(Inflammatory\nBiomarkers)"];
    MMT8           [label="MMT-8 Score\n(Manual Muscle\nTest, 0–80)"];
    MDAAT          [label="MDAAT\n(Myositis Disease\nActivity Assessment)"];
    HAQ_DI         [label="HAQ-DI\n(Disability Index\n0–3)"];
    CMAS           [label="Childhood Myositis\nAssessment Scale"];
    MDI            [label="Myositis Damage\nIndex (MDI)"];
    PhGA           [label="Physician Global\nActivity Score (VAS)"];
    PGA            [label="Patient Global\nActivity Score (VAS)"];
    TIS_score      [label="Total Improvement\nScore (TIS ≥20)"];
    MRI_STIR       [label="MRI STIR Signal\n(Muscle Edema/Inflam)"];
    EMG_path       [label="EMG Pattern\n(Myopathic: short,\npolyphasic units)"];
    muscle_biopsy  [label="Muscle Biopsy:\nCD8+ Infiltrate,\nMHC-I expression"];
    FVC_meas       [label="FVC (%predicted)"];
    DLCO_meas      [label="DLCO (%predicted)"];
    echo_EF        [label="Echocardiography\n(EF, Wall Motion)"];
  }

  /* ─────────────────────────────────────────────
     CLUSTER 12: Disease Progression Model
  ───────────────────────────────────────────── */
  subgraph cluster_disease_prog {
    label="Disease State & Progression Model"; style=filled; color="#EDE7F6";
    node [fillcolor="#D1C4E9"];

    DS_normal      [label="Healthy\nMuscle State\n(S0)"];
    DS_early       [label="Early Inflammation\n(S1: ↑CK, ↑cytokines)"];
    DS_active      [label="Active Disease\n(S2: Weakness,\nCK >>5× ULN)"];
    DS_severe      [label="Severe / Refractory\n(S3: Dysphagia,\nILD, Cardiac)"];
    DS_remission   [label="Remission\n(S4: CK normal,\nMMT8 >75)"];
    DS_flare       [label="Disease Flare\n(S5: post-taper)"];
    damage_accrual [label="Irreversible\nDamage Accrual\n(Fibrosis, Atrophy)"];
    mortality_risk [label="Mortality Risk\n(ILD, Cancer,\nInfection)"];
    steroid_tapering [label="Steroid Tapering\nStrategy\n(10% per 4 weeks)"];
    treat_response [label="Treatment\nResponse\nClassification\n(TIS ≥ 20, 40, 60)"];
    minimal_diseas [label="Minimal Disease\nActivity (MDA)"];
  }

  /* ═══════════════════════════════════════════════
     EDGES — Trigger → Innate Immunity
  ═══════════════════════════════════════════════ */
  viral_infect   -> TLR_activation  [color="#E65100"];
  bacterial_ag   -> TLR_activation  [color="#E65100"];
  uv_exposure    -> IFN_alpha       [color="#E65100", label="Type I IFN"];
  drug_triggers  -> NLRP3           [color="#E65100"];
  hlaDR3         -> TCR_activation  [color="#7B1FA2", label="Genetic susceptibility"];
  antisynthetase -> complement_act  [color="#E65100"];
  anti_SRP       -> macro_M1        [color="#E65100"];
  anti_MDA5      -> IFN_signature   [color="#E65100"];
  anti_Mi2       -> endomysial_inf  [color="#E65100"];
  TLR_activation -> pDC             [color="#1565C0"];
  TLR_activation -> mDC             [color="#1565C0"];
  TLR_activation -> NLRP3           [color="#1565C0"];
  TLR_activation -> NF_kB           [color="#1565C0"];

  /* Innate internal */
  pDC            -> IFN_alpha       [color="#1565C0", label="IFN-α/β prod"];
  mDC            -> IL12            [color="#1565C0"];
  mDC            -> costim_28_80    [color="#1565C0"];
  IFN_alpha      -> IFN_signature   [color="#1565C0"];
  IFN_alpha      -> JAK_STAT        [color="#1565C0"];
  NLRP3          -> IL1beta         [color="#1565C0"];
  NLRP3          -> IL18            [color="#1565C0"];
  NF_kB          -> TNFalpha        [color="#1565C0"];
  NF_kB          -> IL6             [color="#1565C0"];
  NF_kB          -> IL8_CXCL8      [color="#1565C0"];
  NK_cells       -> IFNgamma        [color="#1565C0", label="Cytotoxicity"];
  NK_cells       -> perforin        [color="#1565C0"];
  NKT_cells      -> IFNgamma        [color="#1565C0"];
  macro_M1       -> TNFalpha        [color="#1565C0"];
  macro_M1       -> IL1beta         [color="#1565C0"];
  macro_M1       -> IL6             [color="#1565C0"];
  macro_M1       -> CCL2_MCP1      [color="#1565C0"];
  macro_M1       -> MIF             [color="#1565C0"];
  macro_M1       -> phagocytosis_d  [color="#1565C0"];
  macro_M2       -> TGFbeta         [color="#1565C0"];
  macro_M2       -> IL10            [color="#1565C0"];
  macro_M2       -> VEGF            [color="#1565C0"];
  neutrophils    -> NETs            [color="#1565C0"];
  neutrophils    -> IL8_CXCL8      [color="#1565C0"];
  mast_cells     -> TNFalpha        [color="#1565C0"];
  mast_cells     -> IL4_IL13       [color="#1565C0"];
  complement_act -> MAC_muscle      [style=dashed, color="#1565C0", label="MAC→myofiber"];
  complement_act -> macro_M1       [color="#1565C0"];
  NETs           -> NLRP3           [color="#1565C0"];
  NETs           -> IFN_alpha       [color="#1565C0"];

  /* Hidden node for MAC */
  MAC_muscle [label="Membrane Attack\nComplex (MAC)\nMyofiber Insertion", fillcolor="#FFCDD2", style=filled, shape=box];

  /* Innate → Adaptive */
  pDC            -> naiveCD4        [color="#1565C0", label="Antigen Presentation"];
  mDC            -> naiveCD8        [color="#1565C0", label="Cross-presentation"];
  mDC            -> naiveB          [color="#1565C0"];
  IL12           -> Th1             [color="#FFA000", label="Th1 polarization"];
  IL23           -> Th17            [color="#FFA000"];
  IFN_alpha      -> naiveCD8        [color="#1565C0"];
  CXCL10         -> effCD8_muscle   [color="#1565C0", label="Chemotaxis"];
  CCL2_MCP1      -> macro_M1       [color="#1565C0", label="Recruitment"];

  /* T cell activation cascade */
  naiveCD8       -> TCR_activation  [color="#7B1FA2"];
  naiveCD4       -> costim_28_80    [color="#7B1FA2"];
  TCR_activation -> activCD8        [color="#7B1FA2"];
  costim_28_80   -> activCD8        [color="#7B1FA2"];
  costim_28_80   -> Th1             [color="#7B1FA2"];
  CTLA4_pathway  -> activCD8        [color="#7B1FA2", label="Inhibition", style=dashed, arrowhead=tee];
  PD1_PDL1       -> activCD8        [color="#7B1FA2", style=dashed, arrowhead=tee];
  activCD8       -> IL2_signaling   [color="#7B1FA2"];
  activCD8       -> mem_CD8         [color="#7B1FA2"];
  IL2_signaling  -> activCD8        [color="#7B1FA2", label="Autocrine loop"];
  activCD8       -> effCD8_muscle   [color="#7B1FA2", label="Homing to muscle"];
  mem_CD8        -> effCD8_muscle   [color="#7B1FA2"];
  naiveCD4       -> Th1             [color="#7B1FA2"];
  naiveCD4       -> Th17            [color="#7B1FA2"];
  naiveCD4       -> Treg            [color="#7B1FA2"];
  naiveCD4       -> Tfh             [color="#7B1FA2"];
  Th1            -> IFNgamma        [color="#7B1FA2"];
  Th1            -> TNFalpha        [color="#7B1FA2"];
  Th17           -> IL17A           [color="#7B1FA2"];
  Treg           -> IL10            [color="#7B1FA2", label="Immune suppression"];
  Treg           -> TGFbeta         [color="#7B1FA2"];
  Treg           -> activCD8        [color="#7B1FA2", style=dashed, arrowhead=tee, label="Suppression"];
  Tfh            -> germinal_ctr    [color="#7B1FA2"];

  /* Cytotoxic effector mechanisms */
  effCD8_muscle  -> granzyme_B      [color="#C62828"];
  effCD8_muscle  -> perforin        [color="#C62828"];
  effCD8_muscle  -> FasL_pathway    [color="#C62828"];
  granzyme_B     -> myonuclei_loss  [color="#C62828", label="Apoptosis"];
  perforin       -> necrosis_fiber  [color="#C62828", label="Necrosis"];
  FasL_pathway   -> myonuclei_loss  [color="#C62828"];
  effCD8_muscle  -> endomysial_inf  [color="#C62828"];

  /* B cell / autoantibody cascade */
  naiveB         -> BCR_activation  [color="#2E7D32"];
  BCR_activation -> activB          [color="#2E7D32"];
  Tfh            -> germinal_ctr    [color="#2E7D32"];
  germinal_ctr   -> plasmablast     [color="#2E7D32"];
  germinal_ctr   -> mem_B           [color="#2E7D32"];
  plasmablast    -> plasma_cell     [color="#2E7D32"];
  plasma_cell    -> IgG_autoAb      [color="#2E7D32"];
  plasma_cell    -> IgM_RF          [color="#2E7D32"];
  BAFF_APRIL     -> activB          [color="#2E7D32", label="Survival"];
  BAFF_APRIL     -> plasma_cell     [color="#2E7D32"];
  IgG_autoAb     -> immune_complex  [color="#2E7D32"];
  immune_complex -> complement_act  [color="#2E7D32"];

  /* Cytokine network internal */
  TNFalpha       -> NF_kB           [color="#F57F17"];
  TNFalpha       -> MHCI_express    [color="#F57F17"];
  IL6            -> JAK_STAT        [color="#F57F17"];
  IFNgamma       -> JAK_STAT        [color="#F57F17"];
  IFNgamma       -> MHCI_express    [color="#F57F17", label="Major driver"];
  IFNgamma       -> macro_M1       [color="#F57F17"];
  IFNgamma       -> CXCL10         [color="#F57F17"];
  JAK_STAT       -> STAT4           [color="#F57F17"];
  JAK_STAT       -> IFN_signature   [color="#F57F17"];
  IL1beta        -> NF_kB           [color="#F57F17"];
  IL1beta        -> IL6             [color="#F57F17"];
  IL18           -> IFNgamma        [color="#F57F17"];
  IL10           -> TNFalpha        [color="#F57F17", style=dashed, arrowhead=tee];
  IL10           -> IL6             [color="#F57F17", style=dashed, arrowhead=tee];
  TGFbeta        -> connective_fib  [color="#F57F17"];
  OSM            -> atrophy         [color="#F57F17"];
  MIF            -> macro_M1       [color="#F57F17"];
  VEGF           -> muscle_edema    [color="#F57F17"];
  IL17A          -> neutrophils     [color="#F57F17"];

  /* Cytokines → Muscle Pathology */
  IFNgamma       -> MHCI_express    [color="#C62828"];
  TNFalpha       -> sarcomere_dam   [color="#C62828"];
  IL1beta        -> atrophy         [color="#C62828"];
  IL6            -> atrophy         [color="#C62828"];

  /* Muscle pathology internal */
  MHCI_express   -> TCR_activation  [color="#C62828", label="Enables CD8\nRecognition"];
  MAC_muscle     -> necrosis_fiber  [color="#C62828"];
  necrosis_fiber -> CK_release      [color="#C62828"];
  necrosis_fiber -> aldolase_rel    [color="#C62828"];
  necrosis_fiber -> myoglobin_rel   [color="#C62828"];
  necrosis_fiber -> phagocytosis_d  [color="#C62828"];
  necrosis_fiber -> endomysial_inf  [color="#C62828"];
  sarcomere_dam  -> atrophy         [color="#C62828"];
  sarcomere_dam  -> CK_release      [color="#C62828"];
  mitochondria_d -> sarcomere_dam   [color="#C62828"];
  mitochondria_d -> atrophy         [color="#C62828"];
  myonuclei_loss -> muscle_fiber    [color="#C62828", style=dashed, arrowhead=tee];
  endomysial_inf -> satellite_cell  [color="#C62828", label="Triggers repair"];
  phagocytosis_d -> satellite_cell  [color="#C62828"];
  satellite_cell -> myogenin        [color="#388E3C"];
  myogenin       -> muscle_regen    [color="#388E3C"];
  muscle_regen   -> muscle_fiber    [color="#388E3C", label="Fiber regeneration"];
  TGFbeta        -> connective_fib  [color="#C62828"];
  connective_fib -> fatty_replace   [color="#C62828"];
  fatty_replace  -> damage_accrual  [color="#C62828"];
  atrophy        -> MMT8            [color="#C62828", label="Weakness→score"];
  muscle_edema   -> MRI_STIR        [color="#C62828"];
  endomysial_inf -> muscle_biopsy   [color="#C62828"];
  MHCI_express   -> muscle_biopsy   [color="#C62828"];

  /* Extra-muscular */
  TGFbeta        -> ILD_lung        [color="#00695C"];
  IFNgamma       -> ILD_lung        [color="#00695C"];
  anti_MDA5      -> ILD_lung        [color="#00695C", label="High ILD risk"];
  antisynthetase -> ILD_lung        [color="#00695C"];
  ILD_lung       -> lung_fibrosis   [color="#00695C"];
  lung_fibrosis  -> FVC_decline     [color="#00695C"];
  TNFalpha       -> cardiac_myop    [color="#00695C"];
  cardiac_myop   -> arrythmia       [color="#00695C"];
  cardiac_myop   -> echo_EF         [color="#00695C"];
  atrophy        -> dysphagia_path  [color="#00695C"];
  dysphagia_path -> aspiration_pn   [color="#00695C"];
  Raynaud_pheno  -> muscle_edema    [color="#00695C"];
  TGFbeta        -> calcinosis_dep  [color="#00695C"];
  cancer_assoc   -> DS_severe       [color="#C62828"];

  /* Biomarker links */
  CK_release     -> CK_serum        [color="#37474F"];
  aldolase_rel   -> aldolase_serum  [color="#37474F"];
  TNFalpha       -> CRP_ESR         [color="#37474F"];
  IL6            -> CRP_ESR         [color="#37474F"];
  FVC_decline    -> FVC_meas        [color="#37474F"];
  endomysial_inf -> EMG_path        [color="#37474F"];

  /* Disease State transitions */
  DS_normal      -> DS_early        [color="#6A1B9A", label="Trigger exposure"];
  DS_early       -> DS_active       [color="#6A1B9A"];
  DS_active      -> DS_severe       [color="#6A1B9A", label="Inadequate Rx"];
  DS_active      -> DS_remission    [color="#6A1B9A", label="Treatment response"];
  DS_remission   -> DS_flare        [color="#6A1B9A", label="Steroid taper"];
  DS_flare       -> DS_active       [color="#6A1B9A"];
  DS_severe      -> mortality_risk  [color="#C62828"];
  damage_accrual -> MDI             [color="#6A1B9A"];
  DS_active      -> damage_accrual  [color="#6A1B9A"];

  /* Disease → Clinical Endpoints */
  CK_serum       -> DS_active       [color="#37474F", style=dashed, label="Monitoring"];
  MMT8           -> TIS_score       [color="#37474F"];
  PhGA           -> TIS_score       [color="#37474F"];
  PGA            -> TIS_score       [color="#37474F"];
  CK_serum       -> TIS_score       [color="#37474F"];
  TIS_score      -> treat_response  [color="#37474F"];
  treat_response -> minimal_diseas  [color="#37474F"];
  minimal_diseas -> steroid_tapering [color="#37474F"];
  HAQ_DI         -> MDI             [color="#37474F"];
  FVC_meas       -> MDI             [color="#37474F"];

  /* ═══════════════════════════════════════════
     CORTICOSTEROID PHARMACOLOGY EDGES
  ═══════════════════════════════════════════ */
  pred_oral_dose -> pred_abs        [color="#283593", label="Oral → Absorbed"];
  pred_abs       -> pred_central    [color="#283593"];
  pred_central   -> pred_periph     [color="#283593", label="Distribution"];
  pred_periph    -> pred_central    [color="#283593"];
  pred_central   -> prednis_active  [color="#283593", label="Hepatic activation"];
  prednis_active -> GR_receptor     [color="#283593"];
  GR_receptor    -> GR_complex      [color="#283593"];
  GR_complex     -> GRE_transact    [color="#283593"];
  GR_complex     -> GRE_transrep    [color="#283593"];
  GRE_transact   -> IL10            [color="#283593", label="↑Anti-inflamm"];
  GRE_transrep   -> NF_kB           [color="#283593", style=dashed, arrowhead=tee, label="Block"];
  GRE_transrep   -> TNFalpha        [color="#283593", style=dashed, arrowhead=tee];
  GRE_transrep   -> IL6             [color="#283593", style=dashed, arrowhead=tee];
  GRE_transrep   -> IL1beta         [color="#283593", style=dashed, arrowhead=tee];
  GRE_transrep   -> IL12            [color="#283593", style=dashed, arrowhead=tee];
  GRE_transrep   -> IFNgamma        [color="#283593", style=dashed, arrowhead=tee];
  GRE_transrep   -> Th1             [color="#283593", style=dashed, arrowhead=tee];
  GRE_transrep   -> activCD8        [color="#283593", style=dashed, arrowhead=tee];
  GRE_transact   -> steroid_ADR     [color="#283593"];
  pred_central   -> pred_elim       [color="#283593"];
  pred_elim      -> pred_central    [color="#283593", style=dashed, arrowhead=tee];

  /* MTX Pharmacology */
  MTX_dose       -> MTX_abs         [color="#BF360C"];
  MTX_abs        -> MTX_central     [color="#BF360C"];
  MTX_central    -> MTX_polyglut    [color="#BF360C", label="Intracell\npolyglutamation"];
  MTX_polyglut   -> DHFR_inhib      [color="#BF360C"];
  MTX_polyglut   -> AICAR_accum     [color="#BF360C"];
  DHFR_inhib     -> IL2_signaling   [color="#BF360C", style=dashed, arrowhead=tee, label="↓T cell prolif"];
  AICAR_accum    -> TNFalpha        [color="#BF360C", style=dashed, arrowhead=tee];
  AICAR_accum    -> IL1beta         [color="#BF360C", style=dashed, arrowhead=tee];
  MTX_polyglut   -> MTX_anti_inf    [color="#BF360C"];
  MTX_anti_inf   -> activCD8        [color="#BF360C", style=dashed, arrowhead=tee];
  MTX_anti_inf   -> IFNgamma        [color="#BF360C", style=dashed, arrowhead=tee];
  MTX_central    -> MTX_toxicity    [color="#BF360C"];

  /* AZA Pharmacology */
  AZA_dose       -> AZA_to_6MP      [color="#E65100"];
  AZA_to_6MP     -> sixMP_to_6TGN  [color="#E65100"];
  sixMP_to_6TGN  -> TPMT_metab      [color="#E65100"];
  TPMT_metab     -> sixTGN_effect   [color="#E65100", style=dashed, arrowhead=tee];
  sixMP_to_6TGN  -> sixTGN_effect   [color="#E65100"];
  sixTGN_effect  -> naiveCD8        [color="#E65100", style=dashed, arrowhead=tee, label="↓Proliferation"];
  sixTGN_effect  -> naiveB          [color="#E65100", style=dashed, arrowhead=tee];
  sixTGN_effect  -> activB          [color="#E65100", style=dashed, arrowhead=tee];

  /* Tacrolimus Pharmacology */
  TAC_dose       -> TAC_FKBP12      [color="#4A148C"];
  TAC_FKBP12     -> calcineurin_in  [color="#4A148C"];
  calcineurin_in -> NFAT_block      [color="#4A148C"];
  NFAT_block     -> IL2_signaling   [color="#4A148C", style=dashed, arrowhead=tee, label="↓IL-2"];
  NFAT_block     -> activCD8        [color="#4A148C", style=dashed, arrowhead=tee];
  TAC_FKBP12     -> TAC_toxicity    [color="#4A148C"];

  /* Rituximab Pharmacology */
  RTX_infusion   -> RTX_central     [color="#1B5E20", label="IV infusion"];
  RTX_central    -> RTX_periph      [color="#1B5E20"];
  RTX_periph     -> RTX_central     [color="#1B5E20"];
  RTX_central    -> RTX_CD20_bind   [color="#1B5E20", label="TMDD"];
  RTX_CD20_bind  -> B_cell_deplet   [color="#1B5E20", label="ADCC/CDC"];
  B_cell_deplet  -> naiveB          [color="#1B5E20", style=dashed, arrowhead=tee];
  B_cell_deplet  -> activB          [color="#1B5E20", style=dashed, arrowhead=tee];
  B_cell_deplet  -> plasma_cell     [color="#1B5E20", style=dashed, arrowhead=tee];
  B_cell_deplet  -> RTX_repopu      [color="#1B5E20", label="~6 months"];
  RTX_repopu     -> naiveB          [color="#1B5E20"];
  B_cell_deplet  -> IgG_decline     [color="#1B5E20"];
  IgG_decline    -> IgG_autoAb      [color="#1B5E20", style=dashed, arrowhead=tee];
  IgG_decline    -> immune_complex  [color="#1B5E20", style=dashed, arrowhead=tee];

  /* IVIG Pharmacology */
  IVIG_dose      -> IVIG_FcRn       [color="#006064"];
  IVIG_FcRn      -> IgG_autoAb      [color="#006064", style=dashed, arrowhead=tee, label="Compete FcRn"];
  IVIG_dose      -> IVIG_Fc_inhib   [color="#006064"];
  IVIG_Fc_inhib  -> macro_M1       [color="#006064", style=dashed, arrowhead=tee];
  IVIG_dose      -> IVIG_antiinfl   [color="#006064"];
  IVIG_antiinfl  -> TNFalpha        [color="#006064", style=dashed, arrowhead=tee];
  IVIG_antiinfl  -> IL6             [color="#006064", style=dashed, arrowhead=tee];
  IVIG_antiinfl  -> activCD8        [color="#006064", style=dashed, arrowhead=tee];

  /* JAK inhibitor Pharmacology */
  JAKi_oral      -> JAKi_JAK12      [color="#33691E"];
  JAKi_JAK12     -> STAT_block      [color="#33691E"];
  STAT_block     -> JAK_STAT        [color="#33691E", style=dashed, arrowhead=tee];
  STAT_block     -> IFN_signature   [color="#33691E", style=dashed, arrowhead=tee];
  STAT_block     -> JAKi_IFN_sup   [color="#33691E"];
  JAKi_IFN_sup  -> IFNgamma        [color="#33691E", style=dashed, arrowhead=tee];
  JAKi_JAK12     -> JAKi_cytok_red  [color="#33691E"];
  JAKi_cytok_red -> IL6             [color="#33691E", style=dashed, arrowhead=tee];
  JAKi_cytok_red -> IL12            [color="#33691E", style=dashed, arrowhead=tee];
  JAKi_cytok_red -> Th1             [color="#33691E", style=dashed, arrowhead=tee];

  /* PD → Disease state transition via biomarkers */
  GRE_transrep   -> CK_serum        [color="#283593", style=dashed, label="↓CK (indirect)"];
  MTX_anti_inf   -> CK_serum        [color="#BF360C", style=dashed];
  B_cell_deplet  -> CK_serum        [color="#1B5E20", style=dashed];
  IVIG_antiinfl  -> MMT8            [color="#006064", style=dashed, label="↑Strength"];
  JAKi_cytok_red -> MMT8            [color="#33691E", style=dashed];
  treat_response -> DS_remission    [color="#37474F"];
  steroid_tapering -> DS_flare      [color="#37474F", style=dashed];
}
