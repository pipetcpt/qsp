digraph BTH_QSP {
  rankdir = LR;
  graph [fontname="Helvetica", fontsize=10, compound=true, splines=ortho, nodesep=0.4, ranksep=0.8];
  node  [fontname="Helvetica", fontsize=8, shape=box, style="filled,rounded", margin="0.12,0.06"];
  edge  [fontname="Helvetica", fontsize=7, arrowsize=0.7];

  // ============================================================
  // CLUSTER 1: Genetic Basis
  // ============================================================
  subgraph cluster_genetics {
    label="① Genetic Basis"; style=filled; fillcolor="#FFF0F0";
    color="#8B0000"; fontcolor="#8B0000"; fontsize=11;

    HBB_MUT    [label="HBB Gene\nMutation\n(β0 / β+)", fillcolor="#FF6B6B", fontcolor=white];
    BETA_DEF   [label="β-Globin Chain\nDeficiency / Absence", fillcolor="#FF4444", fontcolor=white];
    ALPHA_NORM [label="α-Globin Chain\n(Normal output)", fillcolor="#FFB3B3"];
    ALPHA_EXC  [label="Excess Free\nα-Chains (unpaired)", fillcolor="#CC0000", fontcolor=white];
    ALPHA_PREC [label="α-Chain Aggregates\n(Heinz bodies)", fillcolor="#990000", fontcolor=white];
    HBF        [label="HbF (Fetal Hb)\nγ-Globin Chains", fillcolor="#FFAAAA"];
    BCL11A     [label="BCL11A\n(γ-globin repressor)", fillcolor="#FF9999"];
    KLF1       [label="KLF1 TF\n(erythroid master)", fillcolor="#FFB3B3"];
    SOX6       [label="SOX6\n(γ-globin repressor)", fillcolor="#FFB3B3"];
    GLOBIN_RATIO [label="α/β Globin\nChain Ratio\n(↑↑↑ in BTH)", fillcolor="#FF7777", fontcolor=white];
    HBE        [label="HbE Variant\n(β26 Glu→Lys)", fillcolor="#FFCCCC"];
  }

  // ============================================================
  // CLUSTER 2: Bone Marrow Erythropoiesis
  // ============================================================
  subgraph cluster_bm_eryth {
    label="② Bone Marrow Erythropoiesis"; style=filled; fillcolor="#E8EAF6";
    color="#1A237E"; fontcolor="#1A237E"; fontsize=11;

    HSC      [label="Hematopoietic\nStem Cells (HSC)", fillcolor="#9FA8DA"];
    MEP      [label="Megakaryocyte-\nErythroid Progenitor\n(MEP)", fillcolor="#9FA8DA"];
    BFU_E    [label="BFU-E\n(Burst-Forming Unit)", fillcolor="#7986CB"];
    CFU_E    [label="CFU-E\n(Colony-Forming Unit)", fillcolor="#7986CB"];
    PRO_E    [label="Proerythroblast\n(Pro-EB)", fillcolor="#5C6BC0"];
    BASO_E   [label="Basophilic\nErythroblast (Baso-EB)", fillcolor="#3F51B5"];
    POLY_E   [label="Polychromatic\nErythroblast (Poly-EB)", fillcolor="#3949AB"];
    ORTHO_E  [label="Orthochromatic\nErythroblast (Ortho-EB)", fillcolor="#303F9F", fontcolor=white];
    ENUCL    [label="Enucleation\n(Pyrenocyte + Retic)", fillcolor="#283593", fontcolor=white];
    RETIC_BM [label="Reticulocyte\n(BM, immature)", fillcolor="#1A237E", fontcolor=white];
    BM_EXPAN [label="BM Erythroid\nHyperplasia\n(5-30× normal)", fillcolor="#E8EAF6", shape=diamond];
    ISLETS   [label="Erythroblastic\nIslands (macrophage\ncentral)", fillcolor="#C5CAE9"];
    ERYTHROBLAST_POOL [label="Total Erythroblast\nPool (×5-30)", fillcolor="#7986CB"];
  }

  // ============================================================
  // CLUSTER 3: Ineffective Erythropoiesis
  // ============================================================
  subgraph cluster_ineff {
    label="③ Ineffective Erythropoiesis"; style=filled; fillcolor="#FBE9E7";
    color="#BF360C"; fontcolor="#BF360C"; fontsize=11;

    INEFF_EP [label="Ineffective\nErythropoiesis\n(IE: 60–90% die)", fillcolor="#FF5722", fontcolor=white];
    ROS_EB   [label="ROS in Erythroblasts\n(Fe2+/Fenton)", fillcolor="#E64A19", fontcolor=white];
    MEMBRANE [label="RBC Membrane\nDamage & Rigidity", fillcolor="#D84315", fontcolor=white];
    APOPTOSIS[label="Erythroblast\nApoptosis (Fas, Cyt-c)", fillcolor="#BF360C", fontcolor=white];
    HEMOLYSIS[label="Peripheral Hemolysis\n(↑ LDH, bilirubin)", fillcolor="#FF7043"];
    PHAGO    [label="Macrophage\nPhagocytosis (RE system)", fillcolor="#FF8A65"];
    EXTRAMEDULLAR [label="Extramedullary\nHematopoiesis\n(liver, spleen)", fillcolor="#FFAB91"];
    SPLENOMEG[label="Splenomegaly\n(→ hypersplenism)", fillcolor="#FFCCBC"];
    HEPAMEGALY[label="Hepatomegaly", fillcolor="#FFCCBC"];
    BONE_DEFORM[label="Bone Deformities\n(thalassemia facies,\nfragility fractures)", fillcolor="#FF8A65"];
  }

  // ============================================================
  // CLUSTER 4: EPO Axis & Oxygen Sensing
  // ============================================================
  subgraph cluster_epo {
    label="④ EPO Axis & Hypoxia Sensing"; style=filled; fillcolor="#E1F5FE";
    color="#01579B"; fontcolor="#01579B"; fontsize=11;

    HIF1A  [label="HIF-1α\n(Hypoxia Inducible)", fillcolor="#81D4FA"];
    HIF2A  [label="HIF-2α\n(Primary EPO driver)", fillcolor="#4FC3F7"];
    VHL    [label="VHL E3 Ligase\n(HIF degrader, PHD)", fillcolor="#29B6F6"];
    KIDNEY [label="Peritubular Fibroblasts\n(Kidney EPO source)", fillcolor="#03A9F4"];
    LIVER_EPO[label="Liver\n(EPO — fetal, backup)", fillcolor="#039BE5"];
    EPO    [label="Erythropoietin\n(IU/L)\n[BTH: 100-10,000]", fillcolor="#0288D1", fontcolor=white];
    EPOR   [label="EPO Receptor\n(EPOR)", fillcolor="#0277BD", fontcolor=white];
    JAK2   [label="JAK2\nKinase", fillcolor="#01579B", fontcolor=white];
    STAT5  [label="STAT5\nActivation", fillcolor="#01579B", fontcolor=white];
    PI3K   [label="PI3K / AKT\nSurvival", fillcolor="#0277BD", fontcolor=white];
    RASERK [label="RAS / ERK\nProliferation", fillcolor="#01579B", fontcolor=white];
    BCL_XL [label="BCL-XL ↑\n(anti-apoptosis)", fillcolor="#81D4FA"];
    ANEMIA_SENS[label="Tissue Hypoxia\n(Anemia sensor)", fillcolor="#B3E5FC", shape=diamond];
  }

  // ============================================================
  // CLUSTER 5: Iron Metabolism
  // ============================================================
  subgraph cluster_iron {
    label="⑤ Iron Metabolism & Overload"; style=filled; fillcolor="#FFF3E0";
    color="#E65100"; fontcolor="#E65100"; fontsize=11;

    FE_DIET   [label="Dietary Iron\n(2–10 mg/day)", fillcolor="#FFE0B2"];
    DMT1      [label="DMT1 (SLC11A2)\nDuodenal Fe2+ importer", fillcolor="#FFCC80"];
    DCYTB     [label="Dcytb\nFerric reductase", fillcolor="#FFB74D"];
    FE_ENTERO [label="Enterocyte\nIron pool", fillcolor="#FFA726"];
    FERROPORTIN[label="Ferroportin (FPN1)\nBasolateral exporter", fillcolor="#FF9800"];
    HEPH      [label="Hephaestin\n(Cu oxidase, Fe2+→Fe3+)", fillcolor="#FB8C00"];
    FE_PLASMA [label="Plasma Iron\nTransferrin-bound\n(μmol/L)", fillcolor="#F57C00", fontcolor=white];
    TF        [label="Transferrin\n(Fe3+ carrier)", fillcolor="#EF6C00", fontcolor=white];
    TFR1      [label="TfR1 (CD71)\nErythroid Fe uptake", fillcolor="#E65100", fontcolor=white];
    TFR2      [label="TfR2\nHepatic Fe sensor", fillcolor="#E65100", fontcolor=white];
    FE_LIVER  [label="Liver Iron\nContent (LIC)\n[Normal <2 mg/g]", fillcolor="#FF8C00", fontcolor=white];
    FE_HEART  [label="Cardiac Iron\n(T2* ↓ = overload)", fillcolor="#F44336", fontcolor=white];
    FE_ENDO   [label="Endocrine Organ\nIron\n(pancreas, pituitary)", fillcolor="#E53935", fontcolor=white];
    FERRITIN  [label="Serum Ferritin\n(μg/L)\n[BTH: 2000–8000]", fillcolor="#FF6D00", fontcolor=white];
    NTBI      [label="Non-Transferrin-\nBound Iron (NTBI)\n(toxic species)", fillcolor="#D84315", fontcolor=white];
    LABILE_FE [label="Labile Iron Pool\n(cytoplasmic, reactive)", fillcolor="#BF360C", fontcolor=white];
    HEMOSIDER [label="Hemosiderin\n(insoluble Fe deposits)", fillcolor="#E64A19", fontcolor=white];
    RBC_FE    [label="RBC Iron\n(Hb synthesis, 2 mg/g Hb)", fillcolor="#FF8A65"];
  }

  // ============================================================
  // CLUSTER 6: Hepcidin / BMP-SMAD Regulation
  // ============================================================
  subgraph cluster_hepcidin {
    label="⑥ Hepcidin / BMP-SMAD Regulatory Axis"; style=filled; fillcolor="#F3E5F5";
    color="#4A148C"; fontcolor="#4A148C"; fontsize=11;

    BMP6      [label="BMP6\n(Hepatic iron sensor)", fillcolor="#CE93D8"];
    BMP2      [label="BMP2\n(Vascular-liver)", fillcolor="#BA68C8"];
    HJV       [label="Hemojuvelin (HJV)\nBMP co-receptor", fillcolor="#AB47BC"];
    BMPR1     [label="BMPR1/BMPR2\nHepatic receptor", fillcolor="#9C27B0", fontcolor=white];
    SMAD1_5_8 [label="pSMAD1/5/8\nPhosphorylation ↑", fillcolor="#7B1FA2", fontcolor=white];
    SMAD4     [label="SMAD4\nCo-SMAD complex", fillcolor="#6A1B9A", fontcolor=white];
    HEPCIDIN  [label="HEPCIDIN (HAMP)\n[BTH: Very Low ↓↓]\n(nM)", fillcolor="#4A148C", fontcolor=white];
    ERFE      [label="Erythroferrone (ERFE)\n(FAM132B)\n[BTH: Massively ↑↑↑]", fillcolor="#E91E63", fontcolor=white];
    GDF11     [label="GDF11\n(TGF-β superfamily\nligand)", fillcolor="#F48FB1"];
    ACTIVIN_B [label="Activin B\n(INHBB)", fillcolor="#F48FB1"];
    GDF15     [label="GDF15\n(stress erythropoiesis)", fillcolor="#F06292"];
    TWSG1     [label="TWSG1\n(Twisted gastrulation 1)", fillcolor="#EC407A"];
    MATRIPT2  [label="Matriptase-2\n(TMPRSS6)\nHJV cleavage/inhibition", fillcolor="#E91E63", fontcolor=white];
    IL6       [label="IL-6\n(Inflammation→HAMP)", fillcolor="#CE93D8"];
    STAT3_HAMP[label="STAT3 → HAMP\n(IL-6 driven)", fillcolor="#BA68C8"];
  }

  // ============================================================
  // CLUSTER 7: End-Organ Damage
  // ============================================================
  subgraph cluster_organ_damage {
    label="⑦ End-Organ Damage (Iron Overload)"; style=filled; fillcolor="#E8F5E9";
    color="#1B5E20"; fontcolor="#1B5E20"; fontsize=11;

    LIVER_FAIL  [label="Hepatic Fibrosis /\nCirrhosis (ALT ↑)", fillcolor="#A5D6A7"];
    CARDIAC_IO  [label="Cardiac Iron\nDeposition", fillcolor="#66BB6A"];
    CARDIO_FAIL [label="Cardiomyopathy\n(Systolic failure,\nArrhythmia)", fillcolor="#388E3C", fontcolor=white];
    DM_ENDO     [label="Diabetes Mellitus\n(β-cell Fe toxicity)", fillcolor="#2E7D32", fontcolor=white];
    HYPOGONAD   [label="Hypogonadism\n(pituitary Fe)", fillcolor="#1B5E20", fontcolor=white];
    HYPOTHYROID [label="Hypothyroidism\n(thyroid Fe)", fillcolor="#33691E", fontcolor=white];
    ADRENAL_INS [label="Adrenal\nInsufficiency", fillcolor="#558B2F", fontcolor=white];
    BMD_LOSS    [label="Osteoporosis /\nOsteopenia (BMD ↓)", fillcolor="#8BC34A"];
    PULM_HTN    [label="Pulmonary\nHypertension\n(RBC/NO axis)", fillcolor="#7CB342"];
    GROWTH_FAIL [label="Growth Failure /\nPubertal Delay", fillcolor="#9CCC65"];
    NEURO_DEFECT[label="Neurocognitive\nDeficits (chronic anemia)", fillcolor="#AED581"];
  }

  // ============================================================
  // CLUSTER 8: Clinical Endpoints & Biomarkers
  // ============================================================
  subgraph cluster_clinical {
    label="⑧ Clinical Endpoints & Biomarkers"; style=filled; fillcolor="#ECEFF1";
    color="#37474F"; fontcolor="#37474F"; fontsize=11;

    HGB_LAB  [label="Hemoglobin\n(g/dL)\n[BTH-TDT: 6–8]", fillcolor="#90A4AE"];
    MCV_LAB  [label="MCV (fL)\n[BTH: 50–70 fL]", fillcolor="#78909C"];
    MCH_LAB  [label="MCH (pg)\n[BTH: 12–20 pg]", fillcolor="#607D8B", fontcolor=white];
    RETIC_LAB[label="Reticulocytes\n(% or 10^9/L)\n[↑ in hemolysis]", fillcolor="#546E7A", fontcolor=white];
    NRBC_LAB [label="Nucleated RBCs\n(NRBC/100 WBC)\n[↑ in BTH]", fillcolor="#455A64", fontcolor=white];
    LDH_LAB  [label="LDH (U/L)\n↑ in hemolysis", fillcolor="#78909C"];
    BILI_LAB [label="Total Bilirubin\n(μmol/L) ↑", fillcolor="#90A4AE"];
    FERRITIN_LAB[label="Serum Ferritin\n(μg/L)", fillcolor="#607D8B", fontcolor=white];
    LIC_LAB  [label="LIC (MRI/biopsy)\n(mg Fe/g dw)\nTarget: <7", fillcolor="#546E7A", fontcolor=white];
    T2STAR   [label="Cardiac T2*\n(MRI, ms)\n>20 ms = safe", fillcolor="#455A64", fontcolor=white];
    TI_ENDPT [label="Transfusion\nIndependence (TI)\n(Hb ≥9, >12 wk)", fillcolor="#B0BEC5"];
    TBU_ENDPT[label="Transfusion\nBurden\n(units/year)", fillcolor="#90A4AE"];
    SCA_SCORE[label="Splenic Volume\n(mL, MRI)", fillcolor="#78909C"];
  }

  // ============================================================
  // CLUSTER 9: Drug PK — Luspatercept
  // ============================================================
  subgraph cluster_luspat {
    label="⑨ Luspatercept (ACE-536) PK/PD"; style=filled; fillcolor="#FBE9E7";
    color="#B71C1C"; fontcolor="#B71C1C"; fontsize=11;

    LUSPAT_DOSE[label="Luspatercept\n1.0–1.25 mg/kg SC\nq21 days", fillcolor="#FFCDD2"];
    LUSPAT_SC  [label="SC Depot\n(absorption site)", fillcolor="#EF9A9A"];
    LUSPAT_C1  [label="Central Cpt.\n(Vd ~8 L, t½=~11d)", fillcolor="#EF5350"];
    LUSPAT_C2  [label="Peripheral Cpt.\n(slow distribution)", fillcolor="#E53935"];
    ACVR2B     [label="ACVR2B Receptor\n(target binding)", fillcolor="#C62828", fontcolor=white];
    GDF11_TRAP [label="GDF11 Neutralized\n(ligand-trap)", fillcolor="#B71C1C", fontcolor=white];
    ACTB_TRAP  [label="Activin B Trapped\n(INHBB neutralized)", fillcolor="#B71C1C", fontcolor=white];
    SMAD23_INH [label="SMAD2/3 Block\n(late eryth. improved)", fillcolor="#D32F2F", fontcolor=white];
    LATE_ERYTH [label="Late-Stage\nErythropoiesis ↑\n(Poly-EB → Ortho-EB)", fillcolor="#FF5722", fontcolor=white];
    ERYTHROID_EFF[label="Erythroid\nMaturation\nEfficiency ↑", fillcolor="#FF7043"];
  }

  // ============================================================
  // CLUSTER 10: Drug PK — Iron Chelation
  // ============================================================
  subgraph cluster_chelation {
    label="⑩ Iron Chelation Therapy"; style=filled; fillcolor="#E0F7FA";
    color="#006064"; fontcolor="#006064"; fontsize=11;

    DFX_DOSE [label="Deferasirox (DFX)\n20–40 mg/kg/day PO\n(Exjade, Jadenu)", fillcolor="#B2EBF2"];
    DFX_GUT  [label="DFX Gut\n(F=70%, Tmax 3.5h)", fillcolor="#80DEEA"];
    DFX_CENT [label="DFX Plasma\n(99% protein bound)\nCL=1.5 mL/h/kg", fillcolor="#26C6DA", fontcolor=white];
    DFX_FE   [label="DFX-Fe Complex\n(fecal + urinary)", fillcolor="#00BCD4", fontcolor=white];
    DFO_DOSE [label="Deferoxamine (DFO)\n40–60 mg/kg\nSC/IV 8–12h/day", fillcolor="#B2EBF2"];
    DFO_CENT [label="DFO Plasma\n(t½ ~1h IV)", fillcolor="#80DEEA"];
    DFO_FE   [label="DFO-Fe Ferrioxamine\n(urinary, 70%)", fillcolor="#26C6DA", fontcolor=white];
    DFP_DOSE [label="Deferiprone (DFP)\n75–99 mg/kg/day\nPO tid", fillcolor="#B2EBF2"];
    DFP_CENT [label="DFP Plasma\n(t½ ~3h)", fillcolor="#80DEEA"];
    DFP_FE   [label="DFP-Fe Complex\n(urine, cardiac iron\nremoval +++)", fillcolor="#00ACC1", fontcolor=white];
    COMBO_CHEL[label="Combination\nChelation\n(DFO+DFP)", fillcolor="#00838F", fontcolor=white];
  }

  // ============================================================
  // CLUSTER 11: Other Pharmacotherapies
  // ============================================================
  subgraph cluster_other_rx {
    label="⑪ Other Pharmacotherapies & Curative Approaches"; style=filled; fillcolor="#EFEBE9";
    color="#4E342E"; fontcolor="#4E342E"; fontsize=11;

    TRANSFUSE   [label="Blood Transfusion\n(RBC, every 3–4 wk)\nTarget: pre-Hb ≥9.5", fillcolor="#D7CCC8"];
    TX_RBC      [label="Transfused RBC Pool\n(allogeneic)", fillcolor="#BCAAA4"];
    TX_FE_LOAD  [label="Transfusion Iron\nLoading\n(0.2 mg Fe/mL RBC)", fillcolor="#A1887F", fontcolor=white];
    HU_DOSE     [label="Hydroxyurea\n15–35 mg/kg/day\n(HbF inducer)", fillcolor="#D7CCC8"];
    HU_GUT      [label="HU Gut\n(Tmax 1h, F=80%)", fillcolor="#BCAAA4"];
    HU_CENT     [label="HU Plasma\n(t½ ~4h, Vd ~0.6 L/kg)", fillcolor="#A1887F", fontcolor=white];
    HU_RNR      [label="Ribonucleotide\nReductase Inhibition", fillcolor="#8D6E63", fontcolor=white];
    GAMMA_INDUCT[label="γ-Globin Induction\n→ HbF ↑", fillcolor="#795548", fontcolor=white];
    GENE_THERAPY[label="Gene Therapy\n(betibeglogene autotemcel\nbeti-cel, LentiGlobin)", fillcolor="#5D4037", fontcolor=white];
    CRISPR_EDIT [label="CRISPR/Cas9\n(BCL11A enhancer KO\nor HBB correction)", fillcolor="#4E342E", fontcolor=white];
    CORRECTED_HSC[label="Engrafted\nCorrected HSCs\n(functional β-globin+)", fillcolor="#3E2723", fontcolor=white];
    SCT         [label="Allogeneic\nStem Cell Transplant\n(HLA-matched donor)", fillcolor="#6D4C41", fontcolor=white];
    LUSPA_COMBO [label="Luspatercept +\nTransfusion Reduction\n(BEYOND trial)", fillcolor="#8D6E63", fontcolor=white];
  }

  // ============================================================
  // CLUSTER 12: Coagulation & Vascular Complications
  // ============================================================
  subgraph cluster_coag {
    label="⑫ Coagulation & Vascular Complications"; style=filled; fillcolor="#FCE4EC";
    color="#880E4F"; fontcolor="#880E4F"; fontsize=11;

    PS_EXPO  [label="Phosphatidylserine\nExposure (RBC outer\nleaflet)", fillcolor="#F48FB1"];
    MICRO_PART[label="Microparticles\n(procoagulant MPs)", fillcolor="#F06292"];
    PLT_ACT  [label="Platelet\nActivation ↑", fillcolor="#EC407A"];
    THROMBIN [label="Thrombin\nGeneration ↑", fillcolor="#E91E63", fontcolor=white];
    HYPERCOAG[label="Hypercoagulable\nState", fillcolor="#C2185B", fontcolor=white];
    FREE_HGB [label="Free Plasma Hb\n(NO scavenger)", fillcolor="#AD1457", fontcolor=white];
    NO_DEFI  [label="NO Deficiency\n(eNOS ↓)", fillcolor="#880E4F", fontcolor=white];
    ENDO_DYSF[label="Endothelial\nDysfunction", fillcolor="#6A1B9A", fontcolor=white];
    STROKE_VTE[label="Stroke / VTE\nRisk ↑", fillcolor="#880E4F", fontcolor=white];
    SPLENO_COAG[label="Post-Splenectomy\nThrombosis Risk", fillcolor="#AD1457", fontcolor=white];
  }

  // ============================================================
  // EDGES
  // ============================================================

  // --- Genetic basis ---
  HBB_MUT    -> BETA_DEF   [label="β0/β+ alleles"];
  ALPHA_NORM -> ALPHA_EXC  [label="excess vs β-def"];
  BETA_DEF   -> GLOBIN_RATIO[label="↑ ratio"];
  ALPHA_NORM -> GLOBIN_RATIO;
  GLOBIN_RATIO -> ALPHA_EXC;
  ALPHA_EXC  -> ALPHA_PREC [label="precipitation\n& aggregation"];
  HBF        -> ALPHA_EXC  [label="compensates\n(partial)", color=green4, style=dashed];
  BCL11A     -> HBF        [label="represses", color=red];
  SOX6       -> HBF        [label="represses", color=red];
  KLF1       -> BCL11A     [label="transcribes"];
  KLF1       -> SOX6       [label="transcribes"];
  HBE        -> BETA_DEF   [label="unstable mRNA\n(HbE/β form)"];

  // --- Erythropoiesis cascade ---
  HSC  -> MEP;
  MEP  -> BFU_E   [label="committed"];
  BFU_E-> CFU_E   [label="proliferation\n(EPO-dependent)"];
  CFU_E-> PRO_E   [label="differentiation"];
  PRO_E-> BASO_E;
  BASO_E->POLY_E;
  POLY_E->ORTHO_E;
  ORTHO_E->ENUCL;
  ENUCL->RETIC_BM [label="reticulocyte\nreleased"];
  RETIC_BM->HGB_LAB[label="→ peripheral\nblood Hb"];
  ERYTHROBLAST_POOL->INEFF_EP[label="massive pool\nbut most die"];
  ISLETS->PRO_E   [label="support\nmaturation"];
  BM_EXPAN->BFU_E [label="↑ progenitor\noutput"];
  BM_EXPAN->ERYTHROBLAST_POOL;

  // --- Alpha-chain toxicity / IE ---
  ALPHA_PREC -> ROS_EB     [label="Fenton\nreaction"];
  ALPHA_PREC -> APOPTOSIS  [label="mitochondrial\npathway"];
  ALPHA_PREC -> MEMBRANE;
  ROS_EB     -> APOPTOSIS;
  BASO_E     -> INEFF_EP   [label="α-chain kills"];
  POLY_E     -> INEFF_EP   [label="α-chain kills"];
  ORTHO_E    -> INEFF_EP   [label="α-chain kills"];
  INEFF_EP   -> APOPTOSIS;
  APOPTOSIS  -> INEFF_EP   [dir=none];
  MEMBRANE   -> HEMOLYSIS;
  INEFF_EP   -> HEMOLYSIS;
  HEMOLYSIS  -> PHAGO;
  PHAGO      -> EXTRAMEDULLAR[label="extramedullary\nEM hematopoiesis"];
  EXTRAMEDULLAR->SPLENOMEG;
  EXTRAMEDULLAR->HEPAMEGALY;
  INEFF_EP   -> BM_EXPAN   [label="EPO drives\ncompensation"];
  BM_EXPAN   -> BONE_DEFORM[label="cortical\nexpansion"];

  // --- EPO Axis ---
  ANEMIA_SENS-> HIF1A      [label="O2 tension ↓"];
  HIF1A      -> HIF2A;
  VHL        -> HIF1A      [label="normally\ndegrades", color=red];
  VHL        -> HIF2A      [label="normally\ndegrades", color=red];
  HIF2A      -> KIDNEY     [label="stimulates\nEPO gene"];
  HIF1A      -> LIVER_EPO;
  KIDNEY     -> EPO        [label="secretes"];
  LIVER_EPO  -> EPO;
  EPO        -> EPOR       [label="binds JAK2\nassociated"];
  EPOR       -> JAK2       [label="dimerization\n& activation"];
  JAK2       -> STAT5;
  JAK2       -> PI3K;
  JAK2       -> RASERK;
  STAT5      -> BFU_E      [label="↑ survival &\nproliferation"];
  STAT5      -> CFU_E;
  STAT5      -> BCL_XL;
  BCL_XL     -> APOPTOSIS  [label="suppresses", color=green4];
  PI3K       -> BCL_XL;
  RASERK     -> BFU_E;
  INEFF_EP   -> ANEMIA_SENS[label="severe anemia\ntriggered"];
  HGB_LAB    -> ANEMIA_SENS[label="low Hb\n→ hypoxia"];

  // --- ERFE / Hepcidin ---
  RETIC_BM   -> ERFE       [label="produces (stress)"];
  PRO_E      -> ERFE       [label="high ERFE"];
  BASO_E     -> ERFE       [label="high ERFE"];
  INEFF_EP   -> ERFE       [label="↑ with IE"];
  ERFE       -> SMAD1_5_8  [label="inhibits BMP\nsignaling", color=red, penwidth=2];
  ERFE       -> HJV        [label="reduces BMP\nco-receptor", color=red];
  GDF11      -> SMAD23_INH [label="normally signals", style=dashed];
  ACTIVIN_B  -> SMAD23_INH [label="normally signals", style=dashed];
  GDF15      -> SMAD1_5_8  [label="inhibits", color=red];
  TWSG1      -> SMAD1_5_8  [label="inhibits", color=red];
  BMP6       -> HJV        [label="activates"];
  BMP2       -> HJV;
  HJV        -> BMPR1;
  BMPR1      -> SMAD1_5_8;
  SMAD1_5_8  -> SMAD4;
  SMAD4      -> HEPCIDIN   [label="→ HAMP\ntranscription ↑"];
  MATRIPT2   -> HJV        [label="cleaves\n(↓ BMP signal)", color=red];
  IL6        -> STAT3_HAMP;
  STAT3_HAMP -> HEPCIDIN   [label="inflammation\ndriven"];
  TFR2       -> SMAD1_5_8  [label="Fe-Tf sensing\n→ BMP ↑"];
  HEPCIDIN   -> FERROPORTIN[label="binds → degrades\n(↓ Fe export)", color=red, penwidth=2];

  // --- Iron flow ---
  FE_DIET    -> DCYTB      [label="Fe3+ in gut"];
  DCYTB      -> DMT1       [label="Fe3+ → Fe2+"];
  DMT1       -> FE_ENTERO;
  FE_ENTERO  -> FERROPORTIN[label="export to blood"];
  FERROPORTIN-> HEPH       [label="oxidizes\nFe2+→Fe3+"];
  HEPH       -> FE_PLASMA  [label="→ Tf-bound Fe"];
  FE_PLASMA  -> TF;
  TF         -> TFR1       [label="delivers Fe\nto erythroblasts"];
  TFR1       -> FE_ENTERO  [label="BM: Fe\nuptake for Hb"];
  TFR1       -> RBC_FE     [label="erythroid\nFe uptake"];
  TFR2       -> FE_PLASMA  [label="senses Fe"];
  FE_PLASMA  -> FE_LIVER   [label="hepatic\nuptake &\nstorage"];
  FE_LIVER   -> FERRITIN   [label="ferritin forms\nfrom stored Fe"];
  FE_LIVER   -> HEMOSIDER  [label="overflow\ndeposition"];
  FERRITIN   -> NTBI        [label="overflow\n(Fe3+ complex)", style=dashed];
  NTBI       -> LABILE_FE  [label="cellular\nuptake"];
  LABILE_FE  -> FE_HEART   [label="myocyte iron\naccumulation"];
  LABILE_FE  -> FE_ENDO    [label="endocrine\niron toxicity"];
  RBC_FE     -> HGB_LAB    [label="Hb synthesis\n(0.34 mg Fe/g Hb)"];
  HEPCIDIN   -> FERROPORTIN[label="", style=invis];

  // --- Organ damage ---
  FE_LIVER   -> LIVER_FAIL [label="ROS/fibrosis"];
  FE_HEART   -> CARDIAC_IO;
  CARDIAC_IO -> CARDIO_FAIL;
  FE_ENDO    -> DM_ENDO;
  FE_ENDO    -> HYPOGONAD;
  FE_ENDO    -> HYPOTHYROID;
  FE_ENDO    -> ADRENAL_INS;
  BM_EXPAN   -> BMD_LOSS   [label="cortex\nthinning"];
  HEMOLYSIS  -> PULM_HTN   [label="NO scavenging\n+ vasoconstr."];
  HEMOLYSIS  -> GROWTH_FAIL;
  ANEMIA_SENS-> NEURO_DEFECT[label="chronic\nhypoxia"];

  // --- Clinical biomarkers ---
  RETIC_BM   -> RETIC_LAB;
  HGB_LAB    -> MCV_LAB;
  HGB_LAB    -> MCH_LAB;
  PRO_E      -> NRBC_LAB;
  HEMOLYSIS  -> LDH_LAB;
  HEMOLYSIS  -> BILI_LAB;
  FERRITIN   -> FERRITIN_LAB;
  FE_LIVER   -> LIC_LAB;
  FE_HEART   -> T2STAR;
  HGB_LAB    -> TI_ENDPT  [label="TI if Hb≥9\n>12wk, no Tx"];
  TRANSFUSE  -> TBU_ENDPT [label="count units"];
  SPLENOMEG  -> SCA_SCORE;

  // --- Luspatercept PK/PD ---
  LUSPAT_DOSE-> LUSPAT_SC;
  LUSPAT_SC  -> LUSPAT_C1  [label="Ka=0.27/day\nF=60%"];
  LUSPAT_C1  -> LUSPAT_C2  [label="distribution\nQ/Vp"];
  LUSPAT_C1  -> ACVR2B     [label="binds"];
  ACVR2B     -> GDF11_TRAP [label="sequesters\nGDF11"];
  ACVR2B     -> ACTB_TRAP  [label="sequesters\nActB"];
  GDF11_TRAP -> SMAD23_INH [label="blocks", color=red, penwidth=2];
  ACTB_TRAP  -> SMAD23_INH [label="blocks", color=red, penwidth=2];
  SMAD23_INH -> LATE_ERYTH [label="when inhibited\n→ maturation ↑", color=green4, penwidth=2];
  LATE_ERYTH -> ERYTHROID_EFF[label="↑ efficiency"];
  ERYTHROID_EFF->ORTHO_E  [label="↑ ortho-EB\nmaturation"];
  ERYTHROID_EFF->RETIC_BM  [label="↑ retic\noutput"];
  RETIC_BM   -> HGB_LAB   [label="↑ Hb\n(+1–2 g/dL)"];
  ERFE       -> GDF11      [label="related\nligands", style=dashed, color=gray];
  LATE_ERYTH -> INEFF_EP   [label="↓ IE rate", color=green4, style=dashed];

  // --- Chelation therapy ---
  DFX_DOSE   -> DFX_GUT;
  DFX_GUT    -> DFX_CENT   [label="Ka=0.64/h\nF=70%"];
  DFX_CENT   -> DFX_FE     [label="Fe3+ chelation\nKi~10nM"];
  DFX_FE     -> FE_LIVER   [label="removes iron\nfecal/renal", color=green4, penwidth=2];
  DFX_FE     -> FERRITIN   [label="↓ stores", color=green4];
  DFO_DOSE   -> DFO_CENT;
  DFO_CENT   -> DFO_FE     [label="Fe3+ chelation"];
  DFO_FE     -> FE_LIVER   [label="removes iron", color=green4];
  DFO_FE     -> FE_ENDO    [label="removes\nendocrine Fe", color=green4];
  DFP_DOSE   -> DFP_CENT;
  DFP_CENT   -> DFP_FE     [label="Fe2+/Fe3+ chelation"];
  DFP_FE     -> FE_HEART   [label="removes\ncardiac iron +++", color=green4, penwidth=2];
  DFP_FE     -> FE_LIVER   [label="removes iron", color=green4];
  DFP_CENT   -> DFO_CENT   [label="shuttle effect\n(DFP+DFO combo)"];
  DFP_CENT   -> DFX_CENT   [label="", style=invis];
  COMBO_CHEL -> DFP_DOSE   [label="includes"];
  COMBO_CHEL -> DFO_DOSE   [label="includes"];

  // --- Other therapies ---
  TRANSFUSE  -> TX_RBC     [label="q3–4wk\n2–4 units"];
  TX_RBC     -> HGB_LAB    [label="immediate\nHb ↑"];
  TX_RBC     -> INEFF_EP   [label="suppresses\n(EPO↓)", color=green4, style=dashed];
  TRANSFUSE  -> TX_FE_LOAD;
  TX_FE_LOAD -> FE_PLASMA  [label="adds to\niron pool"];
  HU_DOSE    -> HU_GUT;
  HU_GUT     -> HU_CENT    [label="F=80%\nTmax 1h"];
  HU_CENT    -> HU_RNR     [label="RNR inhibition"];
  HU_RNR     -> GAMMA_INDUCT[label="stress eryth.\nHbF gene"];
  GAMMA_INDUCT->HBF        [label="γ-globin ↑"];
  HBF        -> HGB_LAB    [label="HbF contributes\nto total Hb"];
  GENE_THERAPY->CORRECTED_HSC[label="lentiviral\nvector"];
  CRISPR_EDIT->CORRECTED_HSC[label="gene\nediting"];
  CRISPR_EDIT->BCL11A      [label="BCL11A KO\n→ HbF ↑", color=green4];
  CORRECTED_HSC->HSC       [label="engraftment\n(BM reconstitution)"];
  CORRECTED_HSC->BETA_DEF  [label="corrects", color=green4, penwidth=2];
  SCT        -> HSC         [label="donor HSC\nengraft", color=green4, penwidth=2];
  LUSPA_COMBO->LUSPAT_DOSE  [label="with planned\nTx reduction"];
  LUSPA_COMBO->TRANSFUSE    [label="Tx interval ↑"];

  // --- Coagulation ---
  MEMBRANE   -> PS_EXPO;
  HEMOLYSIS  -> FREE_HGB;
  FREE_HGB   -> NO_DEFI    [label="NO scavenging"];
  NO_DEFI    -> ENDO_DYSF;
  ENDO_DYSF  -> PULM_HTN;
  PS_EXPO    -> MICRO_PART;
  MICRO_PART -> PLT_ACT;
  PLT_ACT    -> THROMBIN;
  THROMBIN   -> HYPERCOAG;
  HYPERCOAG  -> STROKE_VTE;
  SPLENOMEG  -> SPLENO_COAG[label="post-splenect.\nif done"];
  SPLENO_COAG-> HYPERCOAG;
  ENDO_DYSF  -> HYPERCOAG;
}
