digraph RaynaudQSP {
  graph [
    rankdir=LR
    fontname="Helvetica"
    fontsize=11
    bgcolor="#FAFAFA"
    splines=ortho
    nodesep=0.35
    ranksep=0.65
    label="레이노 현상 (Raynaud's Phenomenon) — QSP Mechanistic Map\nα2-AR · ET-1 · NO · RhoA/ROCK · Platelet · Neuropeptide Pathways"
    labelloc=t
    labeljust=c
    fontsize=14
  ]
  node [shape=box style="rounded,filled" fontname="Helvetica" fontsize=9 margin="0.12,0.06"]
  edge [fontname="Helvetica" fontsize=8 arrowsize=0.7]

  /* ─────────────────────────────────────────────────────
     CLUSTER 1: Environmental Triggers
  ───────────────────────────────────────────────────── */
  subgraph cluster_trigger {
    label="Triggers" style=filled fillcolor="#E8F4F8" color="#2196F3" fontsize=10
    node [fillcolor="#BBDEFB"]
    Cold          [label="Cold\nExposure" shape=ellipse fillcolor="#90CAF9"]
    Emotional     [label="Emotional\nStress"]
    Vibration     [label="Vibration /\nTrauma"]
    Sympathetic   [label="Sympathetic\nActivation" fillcolor="#64B5F6"]
    Cold -> Sympathetic
    Emotional -> Sympathetic
    Vibration -> Sympathetic
  }

  /* ─────────────────────────────────────────────────────
     CLUSTER 2: Sympathetic Nervous System / Adrenergic
  ───────────────────────────────────────────────────── */
  subgraph cluster_sns {
    label="Sympathetic / Adrenergic" style=filled fillcolor="#FFF3E0" color="#FF9800" fontsize=10
    node [fillcolor="#FFE0B2"]
    NE_release    [label="Norepinephrine\n(NE) Release"]
    alpha2AR      [label="α2C-AR\n(upregulated by cold)" fillcolor="#FFCC80"]
    alpha1AR      [label="α1-AR\n(vasoconstriction)"]
    beta2AR       [label="β2-AR\n(vasodilation)"]
    Gq_alpha2     [label="Gq protein\ncoupling (α2)"]
    PLC_alpha2    [label="PLC-β\nActivation"]
    IP3_alpha2    [label="IP3 /\nDAG Release"]
    Rho_activation [label="RhoA\nActivation" fillcolor="#FFB74D"]
    NPY_release   [label="Neuropeptide Y\n(NPY) Co-release"]
    Y1R           [label="NPY Y1/Y2R\nVSMC" fillcolor="#FFCC80"]
    NE_release -> alpha2AR
    NE_release -> alpha1AR
    NE_release -> beta2AR
    NE_release -> NPY_release
    alpha2AR -> Gq_alpha2
    Gq_alpha2 -> PLC_alpha2
    PLC_alpha2 -> IP3_alpha2
    alpha2AR -> Rho_activation [label="RhoGEF"]
    NPY_release -> Y1R
  }

  /* ─────────────────────────────────────────────────────
     CLUSTER 3: Calcium Signaling in VSMC
  ───────────────────────────────────────────────────── */
  subgraph cluster_calcium {
    label="Vascular Smooth Muscle Ca²⁺ Signaling" style=filled fillcolor="#F3E5F5" color="#9C27B0" fontsize=10
    node [fillcolor="#E1BEE7"]
    Ltype_VGCC    [label="L-type VGCC\n(Cav1.2)" fillcolor="#CE93D8"]
    SOCE          [label="Store-Operated\nCa²⁺ Entry (SOCE)"]
    SR_release    [label="Sarcoplasmic\nReticulum Ca²⁺"]
    Cai           [label="[Ca²⁺]i\nElevation" fillcolor="#CE93D8" shape=ellipse]
    CaM           [label="Calmodulin (CaM)\nActivation"]
    MLCK          [label="MLCK\nActivation"]
    MLC_p         [label="MLC\nPhosphorylation"]
    VSMC_contract [label="VSMC\nContraction" fillcolor="#AB47BC" shape=ellipse]
    IP3_alpha2 -> SR_release [label="IP3R"]
    SR_release -> Cai
    Ltype_VGCC -> Cai
    SOCE -> Cai
    Cai -> CaM
    CaM -> MLCK
    MLCK -> MLC_p
    MLC_p -> VSMC_contract
  }

  /* ─────────────────────────────────────────────────────
     CLUSTER 4: RhoA / ROCK Pathway (Ca2+ Sensitization)
  ───────────────────────────────────────────────────── */
  subgraph cluster_rho {
    label="RhoA / ROCK Pathway" style=filled fillcolor="#FFEBEE" color="#F44336" fontsize=10
    node [fillcolor="#FFCDD2"]
    ROCK          [label="ROCK1/2\n(Rho-kinase)" fillcolor="#EF9A9A"]
    MYPT1_p       [label="MYPT1\nPhosphorylation"]
    MLC_p2        [label="MLC\nPhosphorylation\n(Ca²⁺-independent)"]
    PDE_inhib     [label="PDE1 Inhibition\n↑ cGMP? (cross)"]
    ROCK -> MYPT1_p [label="MYPT1-Thr696"]
    MYPT1_p -> MLC_p2 [label="↓ MLCP activity"]
    MLC_p2 -> VSMC_contract
    ROCK -> PDE_inhib
    Rho_activation -> ROCK
  }

  /* ─────────────────────────────────────────────────────
     CLUSTER 5: Endothelial Function
  ───────────────────────────────────────────────────── */
  subgraph cluster_endo {
    label="Endothelial Cell" style=filled fillcolor="#E8F5E9" color="#4CAF50" fontsize=10
    node [fillcolor="#C8E6C9"]
    eNOS          [label="eNOS\n(↓ in Raynaud)" fillcolor="#A5D6A7"]
    NO            [label="Nitric Oxide\n(NO↓)" fillcolor="#81C784"]
    sGC           [label="sGC\nActivation"]
    cGMP          [label="cGMP\n↑"]
    PKG           [label="PKG\nActivation"]
    MLCP_act      [label="MLCP\nActivation"]
    ET1_synth     [label="ET-1\nSynthesis\n(↑ in Raynaud)" fillcolor="#FFCDD2"]
    ECE1          [label="ECE-1\n(ET-converting\nenzyme)"]
    bigET1        [label="Big ET-1\n(precursor)"]
    ETA_R         [label="ETA Receptor\n(VSMC constrict)" fillcolor="#EF9A9A"]
    ETB_R_endo    [label="ETB Receptor\n(endothelium—NO/PGI2)" fillcolor="#A5D6A7"]
    PGI2_synth    [label="PGI2\nSynthesis\n(↓ in Raynaud)"]
    TXA2_endo     [label="TXA2/TXB2\n(↑ in Raynaud)" fillcolor="#FFCDD2"]
    COX2_endo     [label="COX-2\n(endothelial)"]
    eNOS -> NO
    bigET1 -> ET1_synth [label="ECE-1"]
    ET1_synth -> ETA_R
    ET1_synth -> ETB_R_endo
    ETB_R_endo -> eNOS [label="↑ eNOS"]
    ETB_R_endo -> PGI2_synth
    COX2_endo -> TXA2_endo
    COX2_endo -> PGI2_synth
    NO -> sGC
    sGC -> cGMP
    cGMP -> PKG
    PKG -> MLCP_act
    MLCP_act -> MLC_p [label="↓ pMLC" color="#4CAF50" style=dashed]
    MLCP_act -> MLC_p2 [label="↓ pMLC" color="#4CAF50" style=dashed]
  }

  /* ─────────────────────────────────────────────────────
     CLUSTER 6: PGI2 / cAMP Pathway
  ───────────────────────────────────────────────────── */
  subgraph cluster_pgi2 {
    label="PGI2/cAMP Vasodilator Pathway" style=filled fillcolor="#E0F7FA" color="#00BCD4" fontsize=10
    node [fillcolor="#B2EBF2"]
    IP_receptor   [label="IP Receptor\n(PGI2/Iloprost)" fillcolor="#80DEEA"]
    Gs_AC         [label="Gs-Adenylyl\nCyclase"]
    cAMP          [label="cAMP ↑" fillcolor="#80DEEA"]
    PKA           [label="PKA\nActivation"]
    MLCP_cAMP     [label="MLCP via PKA\n(vasodilation)"]
    BKCa          [label="BKCa Channel\nOpening (PKA)"]
    PGI2_synth -> IP_receptor
    IP_receptor -> Gs_AC
    Gs_AC -> cAMP
    cAMP -> PKA
    PKA -> MLCP_cAMP
    PKA -> BKCa
    MLCP_cAMP -> VSMC_contract [label="relaxation" style=dashed color="#00BCD4"]
    BKCa -> Cai [label="↓ Cai" style=dashed color="#00BCD4"]
  }

  /* ─────────────────────────────────────────────────────
     CLUSTER 7: Platelet Activation
  ───────────────────────────────────────────────────── */
  subgraph cluster_platelet {
    label="Platelet Activation" style=filled fillcolor="#FFF8E1" color="#FFC107" fontsize=10
    node [fillcolor="#FFECB3"]
    Plat_SHT      [label="5-HT\n(Serotonin)\nRelease" fillcolor="#FFD54F"]
    Plat_TXA2     [label="TXA2\nRelease" fillcolor="#FFCC02"]
    Plat_ADP      [label="ADP\nRelease"]
    GP2b3a        [label="GP IIb/IIIa\nActivation"]
    Plat_agg      [label="Platelet\nAggregation" fillcolor="#FFB300" shape=ellipse]
    Thrombus      [label="Microvascular\nThrombus"]
    HTR2A_VSMC     [label="5-HT2A\nVSMC\n(vasoconstriction)" fillcolor="#FFCDD2"]
    TXR_VSMC      [label="TP Receptor\nVSMC constrict" fillcolor="#FFCDD2"]
    Plat_SHT -> HTR2A_VSMC
    Plat_TXA2 -> TXR_VSMC
    Plat_ADP -> GP2b3a
    GP2b3a -> Plat_agg
    Plat_agg -> Thrombus
    TXA2_endo -> Plat_TXA2 [label="amplifies"]
    HTR2A_VSMC -> VSMC_contract
    TXR_VSMC -> VSMC_contract
    TXR_VSMC -> Rho_activation
  }

  /* ─────────────────────────────────────────────────────
     CLUSTER 8: Sensory Neuropeptides (CGRP / Substance P)
  ───────────────────────────────────────────────────── */
  subgraph cluster_neuro {
    label="Sensory Neuropeptides" style=filled fillcolor="#F9FBE7" color="#8BC34A" fontsize=10
    node [fillcolor="#DCEDC8"]
    CGRP          [label="CGRP\n(calcitonin gene-\nrelated peptide)" fillcolor="#C5E1A5"]
    CLR_RAMP1     [label="CLR/RAMP1\nReceptor"]
    SubP          [label="Substance P"]
    NK1R          [label="NK1 Receptor\nVSMC/Endo"]
    TRPV1_nerve   [label="TRPV1\nCold Sensor\n(sensitized)"]
    SNS_sensitize  [label="SNS\nSensitization\n(cold stress)"]
    CGRP_cAMP     [label="VSMC cAMP ↑\n(vasodilation)"]
    CGRP -> CLR_RAMP1
    CLR_RAMP1 -> CGRP_cAMP [label="Gs"]
    SubP -> NK1R
    NK1R -> eNOS [label="↑ NO"]
    TRPV1_nerve -> CGRP [label="release"]
    TRPV1_nerve -> SubP [label="release"]
    Cold -> TRPV1_nerve [label="cold block"]
    Cold -> SNS_sensitize
    CGRP_cAMP -> VSMC_contract [label="relax" style=dashed color="#8BC34A"]
    Y1R -> CGRP [label="NPY suppresses" style=dashed color="#FF5722"]
  }

  /* ─────────────────────────────────────────────────────
     CLUSTER 9: Oxidative Stress & Inflammation
  ───────────────────────────────────────────────────── */
  subgraph cluster_ros {
    label="Oxidative Stress & Inflammation" style=filled fillcolor="#FCE4EC" color="#E91E63" fontsize=10
    node [fillcolor="#F8BBD9"]
    ROS           [label="ROS\n(O2•−, H2O2)" fillcolor="#F48FB1"]
    NOX2          [label="NADPH Oxidase\n(NOX2)"]
    XO            [label="Xanthine\nOxidase"]
    BH4_oxidize   [label="BH4\nOxidation\n(eNOS uncoupling)" fillcolor="#F06292"]
    eNOS_uncouple [label="eNOS\nUncoupling\n→ O2•−"]
    ONOO          [label="Peroxynitrite\n(ONOO−)"]
    NF_kB         [label="NF-κB\nActivation"]
    IL6_endo      [label="IL-6\nEndothelial"]
    TNFa_endo     [label="TNF-α\nLocal"]
    VCAM1         [label="VCAM-1\nICAM-1"]
    Monocyte_inf  [label="Monocyte\nInfiltration"]
    ROS -> ONOO [label="+ NO"]
    ROS -> BH4_oxidize
    BH4_oxidize -> eNOS_uncouple
    eNOS_uncouple -> ROS [label="feed-forward"]
    NOX2 -> ROS
    XO -> ROS
    ONOO -> NF_kB
    NF_kB -> IL6_endo
    NF_kB -> TNFa_endo
    NF_kB -> VCAM1
    VCAM1 -> Monocyte_inf
    TNFa_endo -> ET1_synth [label="↑"]
    IL6_endo -> ET1_synth [label="↑"]
    TNFa_endo -> eNOS [label="↓" color="red"]
    Ischemia_reox  [label="Ischemia-\nReperfusion"]
    Ischemia_reox -> NOX2
    Ischemia_reox -> XO
  }

  /* ─────────────────────────────────────────────────────
     CLUSTER 10: Drug PK (Pharmacokinetics)
  ───────────────────────────────────────────────────── */
  subgraph cluster_pk {
    label="Drug PK Compartments" style=filled fillcolor="#ECEFF1" color="#607D8B" fontsize=10
    node [fillcolor="#CFD8DC"]
    // CCB (Nifedipine)
    NIF_gut       [label="Nifedipine\nGut (mg)"]
    NIF_plasma    [label="Nifedipine\nPlasma (ng/mL)"]
    NIF_tissue    [label="Nifedipine\nTissue"]
    // PDE5i (Sildenafil)
    SIL_gut       [label="Sildenafil\nGut (mg)"]
    SIL_plasma    [label="Sildenafil\nPlasma (ng/mL)"]
    // ERA (Bosentan)
    BOS_gut       [label="Bosentan\nGut (mg)"]
    BOS_plasma    [label="Bosentan\nPlasma (ng/mL)"]
    // Prostacyclin (Iloprost IV/inhaled)
    ILO_IV        [label="Iloprost\nIV (ng/mL)"]
    ILO_tissue    [label="Iloprost\nTissue"]
    // Prazosin
    PRA_gut       [label="Prazosin\nGut (mg)"]
    PRA_plasma    [label="Prazosin\nPlasma (ng/mL)"]
    NIF_gut -> NIF_plasma [label="ka·F"]
    NIF_plasma -> NIF_tissue [label="kd"]
    NIF_tissue -> NIF_plasma [label="kr"]
    NIF_plasma -> NIF_plasma [label="CL/V" style=dashed]
    SIL_gut -> SIL_plasma [label="ka·F"]
    BOS_gut -> BOS_plasma [label="ka·F"]
    ILO_IV -> ILO_tissue [label="kd"]
    PRA_gut -> PRA_plasma [label="ka·F"]
  }

  /* ─────────────────────────────────────────────────────
     CLUSTER 11: Drug PD (Pharmacodynamics — Mechanisms)
  ───────────────────────────────────────────────────── */
  subgraph cluster_pd_drugs {
    label="Drug PD Mechanisms" style=filled fillcolor="#EDE7F6" color="#673AB7" fontsize=10
    node [fillcolor="#D1C4E9"]
    CCB_effect    [label="CCB Effect\n(L-VGCC block)" fillcolor="#B39DDB"]
    PDE5i_effect  [label="PDE5i Effect\n(↑ cGMP)" fillcolor="#B39DDB"]
    ERA_effect    [label="ERA Effect\n(ETA/B block)" fillcolor="#B39DDB"]
    PGI2a_effect  [label="PGI2 Analog\n(IP-R agonist)" fillcolor="#B39DDB"]
    Prazosin_eff  [label="α1-blocker\n(Prazosin)" fillcolor="#B39DDB"]
    ROCK_inhib    [label="ROCK Inhibitor\n(Fasudil)" fillcolor="#B39DDB"]
    NIF_plasma -> CCB_effect [label="Emax" color="#673AB7"]
    SIL_plasma -> PDE5i_effect [label="Emax"]
    BOS_plasma -> ERA_effect [label="Emax"]
    ILO_IV -> PGI2a_effect [label="Emax"]
    PRA_plasma -> Prazosin_eff [label="Emax"]
    CCB_effect -> Ltype_VGCC [label="block" color="red"]
    PDE5i_effect -> cGMP [label="↑" color="#4CAF50"]
    ERA_effect -> ETA_R [label="block" color="red"]
    ERA_effect -> ETB_R_endo [label="block" color="red"]
    PGI2a_effect -> IP_receptor [label="agonist" color="#4CAF50"]
    Prazosin_eff -> alpha1AR [label="block" color="red"]
    ROCK_inhib -> ROCK [label="inhibit" color="red"]
  }

  /* ─────────────────────────────────────────────────────
     CLUSTER 12: Clinical Endpoints / Outputs
  ───────────────────────────────────────────────────── */
  subgraph cluster_clinical {
    label="Clinical Endpoints & Outcomes" style=filled fillcolor="#F1F8E9" color="#558B2F" fontsize=10
    node [fillcolor="#DCEDC8"]
    DigBloodFlow  [label="Digital\nBlood Flow\n(mL/min)" fillcolor="#AED581" shape=ellipse]
    VasospEp      [label="Vasospasm\nEpisode\nFrequency/wk" fillcolor="#AED581" shape=ellipse]
    AttackDur     [label="Attack\nDuration\n(min)" fillcolor="#AED581" shape=ellipse]
    VAS_Raynaud   [label="Pain VAS\n(0-10)" fillcolor="#AED581" shape=ellipse]
    RCS           [label="Raynaud\nCondition Score\n(RCS)" fillcolor="#8BC34A" shape=ellipse]
    DU_healing    [label="Digital Ulcer\nHealing Rate" fillcolor="#FFAB91" shape=ellipse]
    DigNecrosis   [label="Digital\nNecrosis Risk" fillcolor="#EF9A9A" shape=ellipse]
    TempThreshold [label="Temperature\nThreshold (°C)"]
    NailFoldCap   [label="Nailfold\nCapillaroscopy\nScore"]
    IRT_asymm     [label="IRT\nAsymmetry\n(ΔT)"]
    VSMC_contract -> DigBloodFlow [label="↓ flow" color="red"]
    Thrombus -> DigBloodFlow [label="↓ flow" color="red"]
    Ischemia_reox -> DigBloodFlow [label="reperf"]
    VSMC_contract -> VasospEp [label="drives" color="red"]
    DigBloodFlow -> AttackDur [label="inverse"]
    VasospEp -> VAS_Raynaud
    AttackDur -> VAS_Raynaud
    VasospEp -> RCS
    AttackDur -> RCS
    VAS_Raynaud -> RCS
    DigBloodFlow -> DU_healing [label="ischemia\n→ ulcer" color="orange"]
    DU_healing -> DigNecrosis
    DigBloodFlow -> TempThreshold
    NailFoldCap -> RCS
    IRT_asymm -> RCS
  }

  /* ─────────────────────────────────────────────────────
     CLUSTER 13: Secondary Causes / Connective Tissue
  ───────────────────────────────────────────────────── */
  subgraph cluster_secondary {
    label="Secondary Raynaud / CTD" style=filled fillcolor="#FBE9E7" color="#FF5722" fontsize=10
    node [fillcolor="#FFCCBC"]
    Scleroderma   [label="Systemic\nSclerosis (SSc)" fillcolor="#FFAB91"]
    SLE_RAY       [label="SLE-\nassociated"]
    Mixed_CTD     [label="MCTD"]
    AntiCentro    [label="Anti-centromere\nAb (↑ severity)"]
    AntiTopI      [label="Anti-Scl70\n(SSc diffuse)"]
    Vessel_remodel [label="Vascular\nRemodeling\n(intimal fibrosis)"]
    Cap_loss      [label="Capillary\nLoss (capillaroscopy)" fillcolor="#EF9A9A"]
    Scleroderma -> Vessel_remodel
    Scleroderma -> ET1_synth [label="↑ ET-1"]
    Scleroderma -> eNOS [label="↓ eNOS"]
    AntiCentro -> Vessel_remodel
    AntiTopI -> Vessel_remodel
    SLE_RAY -> alpha2AR [label="↑ expression"]
    Mixed_CTD -> ET1_synth
    Vessel_remodel -> Cap_loss
    Cap_loss -> DigBloodFlow [label="structural ↓"]
  }

  /* ─────────────────────────────────────────────────────
     CROSS-CLUSTER EDGES (Key Connections)
  ───────────────────────────────────────────────────── */
  Sympathetic -> NE_release
  Rho_activation -> ROCK
  ETA_R -> Rho_activation [label="Gα12/13"]
  ETA_R -> IP3_alpha2 [label="Gq"]
  alpha1AR -> Ltype_VGCC [label="↑ open"]
  eNOS -> NO
  NO -> Ltype_VGCC [label="PKG\ninhibits" color="#4CAF50" style=dashed]
  PGI2_synth -> IP_receptor
  VSMC_contract -> Ischemia_reox [label="ischemia"]
  alpha2AR -> NOX2 [label="↑ ROS"]
  ET1_synth -> ETA_R
  TXA2_endo -> TXR_VSMC
  Y1R -> Ltype_VGCC [label="↑"]
  Monocyte_inf -> ET1_synth [label="paracrine"]
  Monocyte_inf -> NOX2 [label="↑ O2•−"]
  SNS_sensitize -> alpha2AR [label="upregulate"]
}
