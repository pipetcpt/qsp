// ============================================================
// Endometriosis QSP Mechanistic Map
// Quantitative Systems Pharmacology Model
// Version: 1.0  Date: 2026-06-20
// Coverage: HPO Axis · Ectopic Lesion Biology · Peritoneal Inflammation
//           Angiogenesis · Pain Signaling · Immune Dysregulation
//           Oxidative Stress · Drug PK/PD · Clinical Endpoints
// ============================================================

digraph EndometriosisQSP {

    graph [
        rankdir = TB
        fontname = "Helvetica"
        fontsize = 11
        label = "Endometriosis QSP Mechanistic Map\nv1.0 · 2026-06-20"
        labelloc = t
        splines = ortho
        overlap = false
        nodesep = 0.35
        ranksep = 0.6
        bgcolor = "#FAFAFA"
    ]

    node [
        fontname = "Helvetica"
        fontsize = 9
        style = "filled,rounded"
        penwidth = 1.2
    ]

    edge [
        fontname = "Helvetica"
        fontsize = 8
        penwidth = 1.0
    ]

    // ==========================================================
    // cluster_hpo: Hypothalamic-Pituitary-Ovarian Axis
    // ==========================================================
    subgraph cluster_hpo {
        label = "HPO Axis (Hypothalamic-Pituitary-Ovarian)"
        style = "filled,rounded"
        color = "#3A7BD5"
        fillcolor = "#EBF1FB"
        fontsize = 11
        fontcolor = "#1A3A6B"

        // Hypothalamus
        Kisspeptin [label="Kisspeptin\n(KNDy neurons)" shape=ellipse fillcolor="#BDD7EE"]
        GnRH_neuron [label="GnRH Neuron\n(Hypothalamus)" shape=ellipse fillcolor="#9DC3E6" fontcolor="#1A3A6B"]
        GnRH_pulse [label="GnRH Pulse\nFrequency/Amplitude" shape=diamond fillcolor="#2E75B6" fontcolor=white]
        GnRH_portal [label="GnRH in\nPortal Blood" shape=ellipse fillcolor="#BDD7EE"]

        // Pituitary
        GnRH_receptor [label="GnRH-R\n(Pituitary)" shape=rectangle fillcolor="#9DC3E6"]
        GnRH_receptor_downreg [label="GnRH-R\nDown-regulation" shape=diamond fillcolor="#2E75B6" fontcolor=white]
        FSH [label="FSH\n(IU/L)" shape=ellipse fillcolor="#BDD7EE"]
        LH [label="LH\n(IU/L)" shape=ellipse fillcolor="#BDD7EE"]
        FSH_surge [label="FSH Surge\n(mid-cycle)" shape=diamond fillcolor="#2E75B6" fontcolor=white]
        LH_surge [label="LH Surge\n(ovulatory)" shape=diamond fillcolor="#2E75B6" fontcolor=white]

        // Ovary
        Follicle_growth [label="Follicle Growth\n(AFC)" shape=ellipse fillcolor="#BDD7EE"]
        Granulosa_cell [label="Granulosa Cell\nAromatase" shape=rectangle fillcolor="#9DC3E6"]
        Theca_cell [label="Theca Cell\nAndrogen prod." shape=rectangle fillcolor="#9DC3E6"]
        Ovulation [label="Ovulation" shape=diamond fillcolor="#FF8C00" fontcolor=white]
        Corpus_luteum [label="Corpus Luteum\nformation" shape=ellipse fillcolor="#BDD7EE"]
        E2_ovarian [label="E2 (Ovarian)\npg/mL" shape=ellipse fillcolor="#FF6B9D" fontcolor=white fontname="Helvetica-Bold"]
        P4_luteal [label="P4 (Progesterone)\nng/mL" shape=ellipse fillcolor="#C7A0DC"]
        AMH [label="AMH\n(ng/mL)" shape=ellipse fillcolor="#BDD7EE"]
        Inhibin_B [label="Inhibin B\n(pg/mL)" shape=ellipse fillcolor="#BDD7EE"]
        Inhibin_A [label="Inhibin A\n(pg/mL)" shape=ellipse fillcolor="#BDD7EE"]
        Androgens_ovarian [label="Androgens\n(T, DHEA-S)" shape=ellipse fillcolor="#BDD7EE"]

        // Endometrium cycle
        Endometrium_proliferative [label="Endometrium\n(Proliferative)" shape=ellipse fillcolor="#BDD7EE"]
        Endometrium_secretory [label="Endometrium\n(Secretory)" shape=ellipse fillcolor="#BDD7EE"]
        Menstruation [label="Menstruation\n(retrograde)" shape=diamond fillcolor="#E74C3C" fontcolor=white]

        // Feedback nodes
        E2_neg_feedback [label="E2 Negative\nFeedback → Pit." shape=diamond fillcolor="#E74C3C" fontcolor=white]
        E2_pos_feedback [label="E2 Positive\nFeedback → LH surge" shape=diamond fillcolor="#27AE60" fontcolor=white]
        P4_neg_feedback [label="P4 Negative\nFeedback → GnRH/LH" shape=diamond fillcolor="#E74C3C" fontcolor=white]
    }

    // ==========================================================
    // cluster_ectopic: Ectopic Endometrium Lesion Biology
    // ==========================================================
    subgraph cluster_ectopic {
        label = "Ectopic Endometrium Lesion Biology"
        style = "filled,rounded"
        color = "#C0392B"
        fillcolor = "#FDEDEC"
        fontsize = 11
        fontcolor = "#6B1A1A"

        Retrograde_menses [label="Retrograde\nMenstruation" shape=diamond fillcolor="#E74C3C" fontcolor=white]
        Endometrial_cells_shed [label="Endometrial Cells\n(peritoneal)" shape=ellipse fillcolor="#F1948A"]
        Peritoneal_attachment [label="Peritoneal\nAttachment" shape=rectangle fillcolor="#E74C3C" fontcolor=white]
        Implant_formation [label="Lesion Implant\nformation" shape=rectangle fillcolor="#C0392B" fontcolor=white]
        Lesion_volume [label="Lesion Volume\n(cm³)" shape=ellipse fillcolor="#F1948A" fontname="Helvetica-Bold"]
        Lesion_proliferation [label="Lesion\nProliferation" shape=diamond fillcolor="#E74C3C" fontcolor=white]
        Lesion_apoptosis [label="Lesion\nApoptosis" shape=diamond fillcolor="#27AE60" fontcolor=white]
        Lesion_invasion [label="Lesion Invasion\n(deep endometriosis)" shape=rectangle fillcolor="#C0392B" fontcolor=white]

        // Receptors and transcription factors
        ERalpha [label="ERα\n(ESR1)" shape=rectangle fillcolor="#F5CBA7"]
        ERbeta [label="ERβ\n(ESR2 ↑ in endo)" shape=rectangle fillcolor="#F5CBA7"]
        PR_A [label="PR-A\n(progesterone R-A)" shape=rectangle fillcolor="#C7A0DC"]
        PR_B [label="PR-B\n(progesterone R-B)" shape=rectangle fillcolor="#C7A0DC"]
        Progesterone_resistance [label="Progesterone\nResistance" shape=diamond fillcolor="#8E44AD" fontcolor=white]
        HOXA10 [label="HOXA10\n(↓ in ectopic)" shape=rectangle fillcolor="#F5CBA7"]
        SF1 [label="SF-1 (NR5A1)\n(↑ in ectopic)" shape=rectangle fillcolor="#F5CBA7"]
        CYP19A1 [label="Aromatase\n(CYP19A1)" shape=rectangle fillcolor="#E74C3C" fontcolor=white fontname="Helvetica-Bold"]
        E2_local [label="E2 Local\n(pmol/L at lesion)" shape=ellipse fillcolor="#FF6B9D" fontcolor=white fontname="Helvetica-Bold"]
        E2_local_amplification [label="E2 Local\nAmplification loop" shape=diamond fillcolor="#FF1493" fontcolor=white]

        // Stromal biology
        Stromal_cells [label="Ectopic Stromal\nCells" shape=ellipse fillcolor="#F1948A"]
        Epithelial_cells_ecto [label="Ectopic Epithelial\nCells" shape=ellipse fillcolor="#F1948A"]
        EMT [label="EMT\n(Epithelial-Mesenchymal\nTransition)" shape=diamond fillcolor="#E74C3C" fontcolor=white]
        BCL2 [label="BCL-2\n(anti-apoptosis ↑)" shape=rectangle fillcolor="#F5CBA7"]
        Survivin [label="Survivin\n(BIRC5)" shape=rectangle fillcolor="#F5CBA7"]
        MMP_ectopic [label="MMP-2/9\n(invasion)" shape=rectangle fillcolor="#F5CBA7"]
    }

    // ==========================================================
    // cluster_inflammation: Peritoneal Inflammation
    // ==========================================================
    subgraph cluster_inflammation {
        label = "Peritoneal Inflammation"
        style = "filled,rounded"
        color = "#E67E22"
        fillcolor = "#FEF9E7"
        fontsize = 11
        fontcolor = "#6B3A1A"

        Peritoneal_macrophages [label="Peritoneal\nMacrophages (M1/M2)" shape=ellipse fillcolor="#FAD7A0" fontname="Helvetica-Bold"]
        Macrophage_activation [label="Macrophage\nActivation" shape=diamond fillcolor="#E67E22" fontcolor=white]
        IL1beta [label="IL-1β\n(pg/mL)" shape=ellipse fillcolor="#FAD7A0"]
        IL6 [label="IL-6\n(pg/mL)" shape=ellipse fillcolor="#FAD7A0" fontname="Helvetica-Bold"]
        IL8 [label="IL-8/CXCL8\n(pg/mL)" shape=ellipse fillcolor="#FAD7A0"]
        TNFalpha [label="TNF-α\n(pg/mL)" shape=ellipse fillcolor="#FAD7A0"]
        MCP1 [label="MCP-1/CCL2\n(pg/mL)" shape=ellipse fillcolor="#FAD7A0"]
        RANTES [label="RANTES/CCL5\n(pg/mL)" shape=ellipse fillcolor="#FAD7A0"]

        // Eicosanoid pathway
        AA_pathway [label="Arachidonic Acid\npathway" shape=ellipse fillcolor="#FAD7A0"]
        COX1 [label="COX-1\n(constitutive)" shape=rectangle fillcolor="#FAD7A0"]
        COX2 [label="COX-2\n(↑ in endo)" shape=rectangle fillcolor="#E67E22" fontcolor=white fontname="Helvetica-Bold"]
        PGE2 [label="PGE2\n(pg/mL)" shape=ellipse fillcolor="#E67E22" fontcolor=white fontname="Helvetica-Bold"]
        PGE2_receptor [label="EP2/EP4\nreceptors" shape=rectangle fillcolor="#FAD7A0"]
        cAMP [label="cAMP\n(↑ via EP2/4)" shape=ellipse fillcolor="#FAD7A0"]

        // NF-kB pathway
        NFkB [label="NF-κB\n(p65/p50)" shape=diamond fillcolor="#E67E22" fontcolor=white fontname="Helvetica-Bold"]
        IkB [label="IκB\n(inhibitor)" shape=rectangle fillcolor="#FAD7A0"]
        NFkB_activation [label="NF-κB\nActivation" shape=diamond fillcolor="#E67E22" fontcolor=white]

        // MMPs
        MMP1 [label="MMP-1\n(collagenase)" shape=rectangle fillcolor="#FAD7A0"]
        MMP2 [label="MMP-2\n(gelatinase A)" shape=rectangle fillcolor="#FAD7A0"]
        MMP9 [label="MMP-9\n(gelatinase B)" shape=rectangle fillcolor="#FAD7A0"]
        TIMP1 [label="TIMP-1\n(inhibitor)" shape=rectangle fillcolor="#FAD7A0"]

        // PGE2→Aromatase feedback
        PGE2_arom_loop [label="PGE2→Aromatase\nPositive Feedback" shape=diamond fillcolor="#FF4500" fontcolor=white fontname="Helvetica-Bold"]
    }

    // ==========================================================
    // cluster_angiogenesis: Growth Factors & Angiogenesis
    // ==========================================================
    subgraph cluster_angiogenesis {
        label = "Growth Factors & Angiogenesis"
        style = "filled,rounded"
        color = "#1ABC9C"
        fillcolor = "#E8F8F5"
        fontsize = 11
        fontcolor = "#0E6655"

        HIF1alpha [label="HIF-1α\n(hypoxia sensor)" shape=diamond fillcolor="#1ABC9C" fontcolor=white fontname="Helvetica-Bold"]
        VEGF_A [label="VEGF-A\n(pg/mL)" shape=ellipse fillcolor="#A9DFBF" fontname="Helvetica-Bold"]
        VEGFR1 [label="VEGFR1\n(Flt-1)" shape=rectangle fillcolor="#A9DFBF"]
        VEGFR2 [label="VEGFR2\n(KDR/Flk-1)" shape=rectangle fillcolor="#A9DFBF"]
        Angiopoietin1 [label="Angiopoietin-1\n(stabilization)" shape=ellipse fillcolor="#A9DFBF"]
        Angiopoietin2 [label="Angiopoietin-2\n(destabilization)" shape=ellipse fillcolor="#A9DFBF"]
        bFGF [label="bFGF/FGF2\n(pg/mL)" shape=ellipse fillcolor="#A9DFBF"]
        FGFR1 [label="FGFR1\n(receptor)" shape=rectangle fillcolor="#A9DFBF"]
        EGF [label="EGF\n(ng/mL)" shape=ellipse fillcolor="#A9DFBF"]
        EGFR [label="EGFR\n(receptor)" shape=rectangle fillcolor="#A9DFBF"]
        IGF1 [label="IGF-1\n(ng/mL)" shape=ellipse fillcolor="#A9DFBF"]
        IGF1R [label="IGF-1R\n(receptor)" shape=rectangle fillcolor="#A9DFBF"]
        Neovascularization [label="Neovascularization\n(new vessel density)" shape=diamond fillcolor="#1ABC9C" fontcolor=white fontname="Helvetica-Bold"]
        Vessel_permeability [label="Vessel\nPermeability ↑" shape=ellipse fillcolor="#A9DFBF"]
        PI3K_AKT [label="PI3K/AKT/mTOR\npathway" shape=rectangle fillcolor="#A9DFBF"]
        RAS_ERK [label="RAS/ERK/MAPK\npathway" shape=rectangle fillcolor="#A9DFBF"]
    }

    // ==========================================================
    // cluster_pain: Pain Signaling
    // ==========================================================
    subgraph cluster_pain {
        label = "Pain Signaling"
        style = "filled,rounded"
        color = "#8E44AD"
        fillcolor = "#F5EEF8"
        fontsize = 11
        fontcolor = "#4A235A"

        Nociceptors [label="Nociceptors\n(C/Aδ fibers)" shape=ellipse fillcolor="#D7BDE2" fontname="Helvetica-Bold"]
        NGF [label="NGF\n(nerve growth factor)" shape=ellipse fillcolor="#D7BDE2" fontname="Helvetica-Bold"]
        TrkA [label="TrkA receptor\n(NGF receptor)" shape=rectangle fillcolor="#C39BD3"]
        p75NTR [label="p75NTR\n(low-affinity NGF-R)" shape=rectangle fillcolor="#C39BD3"]
        TRPV1 [label="TRPV1\n(heat/capsaicin R)" shape=rectangle fillcolor="#C39BD3"]
        Substance_P [label="Substance P\n(neuropeptide)" shape=ellipse fillcolor="#D7BDE2"]
        CGRP [label="CGRP\n(vasodilator)" shape=ellipse fillcolor="#D7BDE2"]
        Bradykinin [label="Bradykinin\n(sensitizer)" shape=ellipse fillcolor="#D7BDE2"]
        Bradykinin_R [label="B1/B2 receptor\n(bradykinin)" shape=rectangle fillcolor="#C39BD3"]
        Spinal_dorsal_horn [label="Spinal Dorsal\nHorn (DH)" shape=ellipse fillcolor="#C39BD3"]
        NMDA_R [label="NMDA-R\n(glutamate)" shape=rectangle fillcolor="#C39BD3"]
        AMPA_R [label="AMPA-R\n(glutamate)" shape=rectangle fillcolor="#C39BD3"]
        Wind_up [label="Wind-up\n(WDR neurons)" shape=diamond fillcolor="#8E44AD" fontcolor=white]
        Central_sensitization [label="Central\nSensitization" shape=diamond fillcolor="#8E44AD" fontcolor=white fontname="Helvetica-Bold"]
        Sympathetic_nerves [label="Sympathetic Nerves\n(adrenergic)" shape=ellipse fillcolor="#D7BDE2"]
        Pain_perception [label="Pain Perception\n(cortical)" shape=ellipse fillcolor="#8E44AD" fontcolor=white fontname="Helvetica-Bold"]
        Dysmenorrhea [label="Dysmenorrhea\n(NRS)" shape=ellipse fillcolor="#D7BDE2" fontname="Helvetica-Bold"]
        Dyspareunia [label="Dyspareunia\n(NRS)" shape=ellipse fillcolor="#D7BDE2" fontname="Helvetica-Bold"]
        CPP [label="Chronic Pelvic Pain\n(NRS)" shape=ellipse fillcolor="#D7BDE2" fontname="Helvetica-Bold"]
        Peripheral_sensitization [label="Peripheral\nSensitization" shape=diamond fillcolor="#8E44AD" fontcolor=white]
        Neurogenesis_endo [label="Neurogenesis\n(ectopic innervation)" shape=ellipse fillcolor="#D7BDE2"]
    }

    // ==========================================================
    // cluster_immune: Immune Dysregulation
    // ==========================================================
    subgraph cluster_immune {
        label = "Immune Dysregulation"
        style = "filled,rounded"
        color = "#2980B9"
        fillcolor = "#EBF5FB"
        fontsize = 11
        fontcolor = "#1A3A6B"

        NK_cells [label="NK Cells\n(↓ cytotoxicity)" shape=ellipse fillcolor="#AED6F1" fontname="Helvetica-Bold"]
        NK_cytotoxicity [label="NK Cytotoxicity\n(↓ in endo)" shape=diamond fillcolor="#E74C3C" fontcolor=white]
        Tregs [label="Tregs\n(CD4+CD25+FoxP3+)" shape=ellipse fillcolor="#AED6F1"]
        Th17 [label="Th17 cells\n(IL-17 producers)" shape=ellipse fillcolor="#AED6F1"]
        Th1 [label="Th1 cells\n(IFN-γ, IL-2)" shape=ellipse fillcolor="#AED6F1"]
        Th2 [label="Th2 cells\n(IL-4, IL-5, IL-13)" shape=ellipse fillcolor="#AED6F1"]
        IL17 [label="IL-17A\n(pg/mL)" shape=ellipse fillcolor="#AED6F1"]
        IFN_gamma [label="IFN-γ\n(pg/mL)" shape=ellipse fillcolor="#AED6F1"]
        IL10 [label="IL-10\n(pg/mL, anti-inflam)" shape=ellipse fillcolor="#AED6F1"]
        TGF_beta [label="TGF-β\n(fibrosis, Treg)" shape=ellipse fillcolor="#AED6F1" fontname="Helvetica-Bold"]
        Complement [label="Complement\n(C3, C4)" shape=ellipse fillcolor="#AED6F1"]
        B_cells [label="B Cells\n(autoantibodies)" shape=ellipse fillcolor="#AED6F1"]
        Autoantibodies [label="Anti-endometrial\nAntibodies" shape=ellipse fillcolor="#AED6F1"]
        Mast_cells [label="Mast Cells\n(histamine, proteases)" shape=ellipse fillcolor="#AED6F1"]
        Dendritic_cells [label="Dendritic Cells\n(APC)" shape=ellipse fillcolor="#AED6F1"]
    }

    // ==========================================================
    // cluster_oxidative: Oxidative Stress
    // ==========================================================
    subgraph cluster_oxidative {
        label = "Oxidative Stress"
        style = "filled,rounded"
        color = "#F39C12"
        fillcolor = "#FDFEFE"
        fontsize = 11
        fontcolor = "#784212"

        ROS [label="ROS\n(reactive O2 species)" shape=ellipse fillcolor="#FAD7A0" fontname="Helvetica-Bold"]
        Iron_overload [label="Iron Overload\n(peritoneal fluid)" shape=ellipse fillcolor="#FAD7A0"]
        Fenton_reaction [label="Fenton Reaction\n(Fe²⁺ + H₂O₂)" shape=diamond fillcolor="#F39C12" fontcolor=white]
        OH_radical [label="·OH Radical\n(hydroxyl)" shape=ellipse fillcolor="#FAD7A0"]
        SOD [label="SOD\n(superoxide dismutase)" shape=rectangle fillcolor="#FDEBD0"]
        Catalase [label="Catalase\n(H₂O₂ → H₂O)" shape=rectangle fillcolor="#FDEBD0"]
        GPx [label="Glutathione\nPeroxidase (GPx)" shape=rectangle fillcolor="#FDEBD0"]
        Lipid_peroxidation [label="Lipid\nPeroxidation" shape=ellipse fillcolor="#FAD7A0"]
        MDA [label="MDA/4-HNE\n(lipid perox. products)" shape=ellipse fillcolor="#FAD7A0"]
        DNA_damage [label="DNA Damage\n(8-OHdG)" shape=ellipse fillcolor="#FAD7A0"]
        Nrf2 [label="Nrf2\n(antioxidant TF)" shape=rectangle fillcolor="#FDEBD0"]
        Mitochondrial_dysfunction [label="Mitochondrial\nDysfunction" shape=ellipse fillcolor="#FAD7A0"]
        Oxidative_stress_index [label="Oxidative Stress\nIndex (OSI)" shape=diamond fillcolor="#F39C12" fontcolor=white]
    }

    // ==========================================================
    // cluster_drugs: Drug PK/PD
    // ==========================================================
    subgraph cluster_drugs {
        label = "Drug PK/PD Compartments"
        style = "filled,rounded"
        color = "#2C3E50"
        fillcolor = "#ECF0F1"
        fontsize = 11
        fontcolor = "#1A252F"

        // GnRH agonist
        Leuprolide_depot [label="Leuprolide Depot\n3.75mg SC q28d" shape=rectangle fillcolor="#85C1E9" fontname="Helvetica-Bold"]
        Leuprolide_PK [label="Leuprolide PK\n(ka=0.005/h depot)" shape=ellipse fillcolor="#85C1E9"]
        GnRH_agonist_flare [label="GnRH Agonist Flare\n(week 1 E2↑)" shape=diamond fillcolor="#E74C3C" fontcolor=white]
        GnRH_desensitization [label="GnRH-R\nDesensitization" shape=diamond fillcolor="#2C3E50" fontcolor=white fontname="Helvetica-Bold"]

        // GnRH antagonists
        Elagolix_150 [label="Elagolix 150mg/d\n(GnRH antagonist)" shape=rectangle fillcolor="#85C1E9" fontname="Helvetica-Bold"]
        Elagolix_200BID [label="Elagolix 200mg BID\n(high dose)" shape=rectangle fillcolor="#5DADE2" fontname="Helvetica-Bold"]
        Elagolix_PK [label="Elagolix PK\n(ka=1.2/h, Vd=90L)" shape=ellipse fillcolor="#85C1E9"]
        Cetrorelix [label="Cetrorelix\n(GnRH antagonist)" shape=rectangle fillcolor="#85C1E9"]
        Relugolix [label="Relugolix\n(oral GnRH antag.)" shape=rectangle fillcolor="#85C1E9"]
        GnRH_R_occupancy [label="GnRH-R\nOccupancy (%)" shape=diamond fillcolor="#2C3E50" fontcolor=white]

        // Progestins
        Dienogest [label="Dienogest 2mg/d\n(4th gen progestin)" shape=rectangle fillcolor="#C39BD3" fontname="Helvetica-Bold"]
        Dienogest_PK [label="Dienogest PK\n(ka=1.5/h, Vd=47L)" shape=ellipse fillcolor="#C39BD3"]
        MPA [label="Medroxyprogesterone\nAcetate (MPA)" shape=rectangle fillcolor="#C39BD3"]
        Norethindrone_acetate [label="Norethindrone\nAcetate 5mg/d" shape=rectangle fillcolor="#C39BD3"]
        LNG_IUD [label="Levonorgestrel-IUD\n(Mirena)" shape=rectangle fillcolor="#C39BD3"]
        Combined_OCP [label="Combined OCP\n(EE30mcg+DNG2mg)" shape=rectangle fillcolor="#C39BD3" fontname="Helvetica-Bold"]

        // Aromatase inhibitors
        Letrozole [label="Letrozole 2.5mg/d\n(AI, non-steroidal)" shape=rectangle fillcolor="#A9DFBF" fontname="Helvetica-Bold"]
        Letrozole_PK [label="Letrozole PK\n(ka=1.8/h, Vd=103L)" shape=ellipse fillcolor="#A9DFBF"]
        Anastrozole [label="Anastrozole 1mg/d\n(AI, non-steroidal)" shape=rectangle fillcolor="#A9DFBF"]
        AI_E2_suppression [label="AI→E2\nSuppression" shape=diamond fillcolor="#1ABC9C" fontcolor=white]

        // NSAIDs
        Ibuprofen [label="Ibuprofen\n(COX-1/2 inhib)" shape=rectangle fillcolor="#FAD7A0"]
        Celecoxib [label="Celecoxib\n(COX-2 selective)" shape=rectangle fillcolor="#FAD7A0"]
        NSAID_PGE2_inhib [label="NSAID→PGE2\nInhibition" shape=diamond fillcolor="#E67E22" fontcolor=white]
    }

    // ==========================================================
    // cluster_clinical: Clinical Endpoints & Biomarkers
    // ==========================================================
    subgraph cluster_clinical {
        label = "Clinical Endpoints & Biomarkers"
        style = "filled,rounded"
        color = "#17202A"
        fillcolor = "#EAECEE"
        fontsize = 11
        fontcolor = "#17202A"

        BMD_lumbar [label="BMD Lumbar\n(g/cm² DXA)" shape=ellipse fillcolor="#BFC9CA" fontname="Helvetica-Bold"]
        BMD_hip [label="BMD Hip\n(g/cm² DXA)" shape=ellipse fillcolor="#BFC9CA" fontname="Helvetica-Bold"]
        Hot_flushes [label="Hot Flushes\n(VMS freq/d)" shape=ellipse fillcolor="#BFC9CA"]
        Endometrioma_size [label="Endometrioma Size\n(cm, ultrasound)" shape=ellipse fillcolor="#BFC9CA" fontname="Helvetica-Bold"]
        rAFS_score [label="rAFS Score\n(revised AFS)" shape=ellipse fillcolor="#BFC9CA" fontname="Helvetica-Bold"]
        CA125 [label="CA-125\n(U/mL)" shape=ellipse fillcolor="#BFC9CA"]
        Fertility_outcome [label="Fertility Outcome\n(clinical pregnancy)" shape=ellipse fillcolor="#BFC9CA" fontname="Helvetica-Bold"]
        Fecundability [label="Fecundability\n(monthly PR)" shape=ellipse fillcolor="#BFC9CA"]
        Recurrence_rate [label="Recurrence Rate\n(%/year post-surgery)" shape=ellipse fillcolor="#BFC9CA"]
        Serum_E2_clinical [label="Serum E2\n(pg/mL, clinical)" shape=ellipse fillcolor="#FF6B9D" fontcolor=white]
        Serum_FSH_clinical [label="Serum FSH\n(IU/L, clinical)" shape=ellipse fillcolor="#BFC9CA"]
        Serum_P4_clinical [label="Serum P4\n(ng/mL, clinical)" shape=ellipse fillcolor="#BFC9CA"]
        PBAC_score [label="PBAC Score\n(menstrual blood loss)" shape=ellipse fillcolor="#BFC9CA"]
        Quality_of_life [label="Quality of Life\n(EHP-30 score)" shape=ellipse fillcolor="#BFC9CA" fontname="Helvetica-Bold"]
        Serum_AMH_clinical [label="Serum AMH\n(ng/mL, ovarian reserve)" shape=ellipse fillcolor="#BFC9CA"]
    }

    // ==========================================================
    // INTRA-CLUSTER EDGES — HPO Axis
    // ==========================================================
    // Hypothalamus → Pituitary
    Kisspeptin -> GnRH_neuron [color="#2196F3" label="stimulates"]
    GnRH_neuron -> GnRH_pulse [color="#2196F3" label="generates"]
    GnRH_pulse -> GnRH_portal [color="#2196F3"]
    GnRH_portal -> GnRH_receptor [color="#2196F3"]
    GnRH_receptor -> FSH [color="#2196F3" label="→ FSH prod"]
    GnRH_receptor -> LH [color="#2196F3" label="→ LH prod"]

    // FSH/LH surges
    FSH -> FSH_surge [color="#2196F3" style=dashed]
    LH -> LH_surge [color="#2196F3" style=dashed]
    LH_surge -> Ovulation [color="#FF8C00" label="triggers" penwidth=2]

    // Ovary
    FSH -> Follicle_growth [color="#2196F3"]
    FSH -> Granulosa_cell [color="#2196F3"]
    LH -> Theca_cell [color="#2196F3"]
    Follicle_growth -> E2_ovarian [color="#2196F3"]
    Granulosa_cell -> E2_ovarian [color="#2196F3" label="aromatase"]
    Theca_cell -> Androgens_ovarian [color="#2196F3"]
    Androgens_ovarian -> Granulosa_cell [color="#2196F3" label="substrate"]
    Ovulation -> Corpus_luteum [color="#FF8C00"]
    Corpus_luteum -> P4_luteal [color="#9B59B6" penwidth=2]
    Corpus_luteum -> E2_ovarian [color="#FF6B9D" style=dashed]
    Granulosa_cell -> Inhibin_B [color="#2196F3"]
    Corpus_luteum -> Inhibin_A [color="#9B59B6"]
    Follicle_growth -> AMH [color="#2196F3"]

    // Feedback
    E2_ovarian -> E2_neg_feedback [color="#E74C3C"]
    E2_neg_feedback -> FSH [color="#E74C3C" label="inhibits" style=dashed]
    E2_neg_feedback -> LH [color="#E74C3C" style=dashed]
    E2_ovarian -> E2_pos_feedback [color="#27AE60" style=dashed label="mid-cycle"]
    E2_pos_feedback -> LH_surge [color="#27AE60" penwidth=2]
    P4_luteal -> P4_neg_feedback [color="#9B59B6"]
    P4_neg_feedback -> GnRH_pulse [color="#E74C3C" label="↓ frequency" style=dashed]
    Inhibin_B -> FSH [color="#E74C3C" label="inhibits" style=dashed]
    Inhibin_A -> FSH [color="#E74C3C" style=dashed]

    // Endometrium cycle
    E2_ovarian -> Endometrium_proliferative [color="#FF6B9D"]
    P4_luteal -> Endometrium_secretory [color="#9B59B6"]
    Endometrium_secretory -> Menstruation [color="#E74C3C" label="P4 withdrawal"]
    Endometrium_proliferative -> Menstruation [color="#E74C3C" style=dashed]
    GnRH_receptor -> GnRH_receptor_downreg [color="#E74C3C" style=dashed label="prolonged stim"]
    GnRH_receptor_downreg -> FSH [color="#E74C3C" style=dashed]
    GnRH_receptor_downreg -> LH [color="#E74C3C" style=dashed]

    // ==========================================================
    // INTRA-CLUSTER EDGES — Ectopic Lesion
    // ==========================================================
    Retrograde_menses -> Endometrial_cells_shed [color="#E74C3C"]
    Endometrial_cells_shed -> Peritoneal_attachment [color="#E74C3C"]
    Peritoneal_attachment -> Implant_formation [color="#E74C3C"]
    Implant_formation -> Lesion_volume [color="#E74C3C"]
    Lesion_proliferation -> Lesion_volume [color="#E74C3C" label="+ growth"]
    Lesion_apoptosis -> Lesion_volume [color="#27AE60" label="- regression"]
    Lesion_invasion -> Lesion_volume [color="#E74C3C" style=dashed label="deep endo"]

    // Receptor / TF cascade at lesion
    E2_local -> ERalpha [color="#FF6B9D"]
    E2_local -> ERbeta [color="#FF6B9D"]
    ERalpha -> Lesion_proliferation [color="#E74C3C" penwidth=2]
    ERalpha -> BCL2 [color="#E74C3C"]
    ERalpha -> Survivin [color="#E74C3C"]
    BCL2 -> Lesion_apoptosis [color="#E74C3C" label="inhibits" style=dashed]
    Survivin -> Lesion_apoptosis [color="#E74C3C" style=dashed]
    SF1 -> CYP19A1 [color="#E74C3C" penwidth=2]
    CYP19A1 -> E2_local [color="#FF6B9D" penwidth=2 label="converts\nandrogen→E2"]
    E2_local -> E2_local_amplification [color="#FF1493" penwidth=2]
    E2_local_amplification -> CYP19A1 [color="#FF1493" penwidth=2 label="PGE2 loop"]
    PR_A -> Progesterone_resistance [color="#8E44AD"]
    PR_B -> Progesterone_resistance [color="#8E44AD" style=dashed]
    Progesterone_resistance -> Lesion_proliferation [color="#E74C3C" style=dashed]
    HOXA10 -> Lesion_proliferation [color="#27AE60" label="suppresses" style=dashed]
    ERbeta -> HOXA10 [color="#E74C3C" label="↓ HOXA10" style=dashed]
    Stromal_cells -> MMP_ectopic [color="#E74C3C"]
    MMP_ectopic -> Lesion_invasion [color="#E74C3C"]
    Endometrial_cells_shed -> EMT [color="#E74C3C" style=dashed]
    EMT -> Stromal_cells [color="#E74C3C"]
    Epithelial_cells_ecto -> Lesion_volume [color="#E74C3C" style=dashed]

    // ==========================================================
    // INTRA-CLUSTER EDGES — Inflammation
    // ==========================================================
    Peritoneal_macrophages -> Macrophage_activation [color="#E67E22"]
    Macrophage_activation -> IL1beta [color="#E67E22"]
    Macrophage_activation -> IL6 [color="#E67E22"]
    Macrophage_activation -> IL8 [color="#E67E22"]
    Macrophage_activation -> TNFalpha [color="#E67E22"]
    Macrophage_activation -> MCP1 [color="#E67E22"]
    Macrophage_activation -> RANTES [color="#E67E22"]
    IL1beta -> NFkB_activation [color="#E67E22"]
    TNFalpha -> NFkB_activation [color="#E67E22"]
    NFkB_activation -> IkB [color="#E74C3C" label="degrades IκB" style=dashed]
    IkB -> NFkB [color="#E74C3C" label="inhibits" style=dashed]
    NFkB_activation -> NFkB [color="#E67E22" penwidth=2]
    NFkB -> COX2 [color="#E67E22" penwidth=2]
    NFkB -> IL6 [color="#E67E22"]
    NFkB -> IL8 [color="#E67E22"]
    NFkB -> MMP1 [color="#E67E22"]
    NFkB -> MMP9 [color="#E67E22"]
    AA_pathway -> COX1 [color="#E67E22"]
    AA_pathway -> COX2 [color="#E67E22"]
    COX1 -> PGE2 [color="#E67E22"]
    COX2 -> PGE2 [color="#E67E22" penwidth=2]
    PGE2 -> PGE2_receptor [color="#E67E22"]
    PGE2_receptor -> cAMP [color="#E67E22" label="EP2/4→Gs→AC"]
    cAMP -> SF1 [color="#E67E22" label="PKA activates SF-1" penwidth=2]
    PGE2 -> PGE2_arom_loop [color="#FF4500" penwidth=2]
    PGE2_arom_loop -> CYP19A1 [color="#FF4500" penwidth=2 label="↑ aromatase"]
    MMP1 -> TIMP1 [color="#27AE60" label="balanced by" style=dashed]
    MMP2 -> TIMP1 [color="#27AE60" style=dashed]
    MMP9 -> TIMP1 [color="#27AE60" style=dashed]

    // ==========================================================
    // INTRA-CLUSTER EDGES — Angiogenesis
    // ==========================================================
    HIF1alpha -> VEGF_A [color="#1ABC9C" penwidth=2]
    HIF1alpha -> bFGF [color="#1ABC9C"]
    VEGF_A -> VEGFR1 [color="#1ABC9C"]
    VEGF_A -> VEGFR2 [color="#1ABC9C" penwidth=2]
    VEGFR2 -> Neovascularization [color="#1ABC9C" penwidth=2]
    VEGFR2 -> Vessel_permeability [color="#1ABC9C"]
    VEGFR1 -> Neovascularization [color="#1ABC9C" style=dashed label="weaker signal"]
    Angiopoietin1 -> Neovascularization [color="#1ABC9C" label="stabilize"]
    Angiopoietin2 -> Neovascularization [color="#E74C3C" label="destabilize" style=dashed]
    bFGF -> FGFR1 [color="#1ABC9C"]
    FGFR1 -> Neovascularization [color="#1ABC9C"]
    EGF -> EGFR [color="#1ABC9C"]
    EGFR -> PI3K_AKT [color="#1ABC9C"]
    EGFR -> RAS_ERK [color="#1ABC9C"]
    IGF1 -> IGF1R [color="#1ABC9C"]
    IGF1R -> PI3K_AKT [color="#1ABC9C"]
    PI3K_AKT -> Lesion_proliferation [color="#1ABC9C" penwidth=2]
    RAS_ERK -> Lesion_proliferation [color="#1ABC9C"]
    PI3K_AKT -> HIF1alpha [color="#1ABC9C" style=dashed]
    Neovascularization -> Lesion_volume [color="#1ABC9C" penwidth=2 label="nutrient supply"]

    // ==========================================================
    // INTRA-CLUSTER EDGES — Pain
    // ==========================================================
    Nociceptors -> TrkA [color="#8E44AD"]
    NGF -> TrkA [color="#8E44AD" penwidth=2]
    NGF -> p75NTR [color="#8E44AD"]
    TrkA -> Peripheral_sensitization [color="#8E44AD" penwidth=2]
    TrkA -> Neurogenesis_endo [color="#8E44AD"]
    Peripheral_sensitization -> TRPV1 [color="#8E44AD"]
    TRPV1 -> Substance_P [color="#8E44AD"]
    TRPV1 -> CGRP [color="#8E44AD"]
    Bradykinin -> Bradykinin_R [color="#8E44AD"]
    Bradykinin_R -> Peripheral_sensitization [color="#8E44AD"]
    Substance_P -> Spinal_dorsal_horn [color="#8E44AD"]
    CGRP -> Spinal_dorsal_horn [color="#8E44AD"]
    Spinal_dorsal_horn -> NMDA_R [color="#8E44AD"]
    Spinal_dorsal_horn -> AMPA_R [color="#8E44AD"]
    NMDA_R -> Wind_up [color="#8E44AD" penwidth=2]
    AMPA_R -> Wind_up [color="#8E44AD"]
    Wind_up -> Central_sensitization [color="#8E44AD" penwidth=2]
    Central_sensitization -> Pain_perception [color="#8E44AD" penwidth=2]
    Sympathetic_nerves -> Nociceptors [color="#8E44AD" label="adrenergic sensitiz."]
    Neurogenesis_endo -> Nociceptors [color="#8E44AD" style=dashed]
    Pain_perception -> Dysmenorrhea [color="#8E44AD"]
    Pain_perception -> Dyspareunia [color="#8E44AD"]
    Pain_perception -> CPP [color="#8E44AD"]

    // ==========================================================
    // INTRA-CLUSTER EDGES — Immune
    // ==========================================================
    NK_cells -> NK_cytotoxicity [color="#2980B9"]
    NK_cytotoxicity -> Endometrial_cells_shed [color="#27AE60" label="should kill" style=dashed]
    Tregs -> IL10 [color="#2980B9"]
    Tregs -> TGF_beta [color="#2980B9"]
    IL10 -> Macrophage_activation [color="#27AE60" label="suppresses" style=dashed]
    TGF_beta -> Tregs [color="#2980B9" label="expand Tregs"]
    TGF_beta -> Th17 [color="#2980B9" style=dashed label="±"]
    Th17 -> IL17 [color="#2980B9"]
    Th1 -> IFN_gamma [color="#2980B9"]
    IFN_gamma -> NK_cells [color="#27AE60" label="activates" style=dashed]
    IL17 -> NFkB_activation [color="#2980B9"]
    Dendritic_cells -> Th1 [color="#2980B9" style=dashed]
    Dendritic_cells -> Th17 [color="#2980B9" style=dashed]
    Dendritic_cells -> Tregs [color="#2980B9" style=dashed]
    Mast_cells -> Bradykinin [color="#2980B9" style=dashed label="histamine/proteases"]
    B_cells -> Autoantibodies [color="#2980B9"]
    Complement -> Macrophage_activation [color="#2980B9" style=dashed]

    // ==========================================================
    // INTRA-CLUSTER EDGES — Oxidative Stress
    // ==========================================================
    Iron_overload -> Fenton_reaction [color="#F39C12"]
    Fenton_reaction -> OH_radical [color="#F39C12"]
    OH_radical -> ROS [color="#F39C12"]
    ROS -> Lipid_peroxidation [color="#F39C12"]
    Lipid_peroxidation -> MDA [color="#F39C12"]
    ROS -> DNA_damage [color="#F39C12"]
    ROS -> Mitochondrial_dysfunction [color="#F39C12"]
    SOD -> ROS [color="#27AE60" label="dismutase" style=dashed]
    Catalase -> ROS [color="#27AE60" style=dashed]
    GPx -> Lipid_peroxidation [color="#27AE60" style=dashed]
    Nrf2 -> SOD [color="#27AE60"]
    Nrf2 -> Catalase [color="#27AE60"]
    Nrf2 -> GPx [color="#27AE60"]
    ROS -> Nrf2 [color="#27AE60" label="activates" style=dashed]
    Oxidative_stress_index -> DNA_damage [color="#F39C12"]
    ROS -> Oxidative_stress_index [color="#F39C12"]

    // ==========================================================
    // INTRA-CLUSTER EDGES — Drugs
    // ==========================================================
    // GnRH agonist
    Leuprolide_depot -> Leuprolide_PK [color="#2C3E50"]
    Leuprolide_PK -> GnRH_agonist_flare [color="#E74C3C" label="week 1 flare"]
    Leuprolide_PK -> GnRH_desensitization [color="#2C3E50" label="weeks 3-4+"]
    GnRH_agonist_flare -> E2_ovarian [color="#E74C3C" penwidth=2 label="transient ↑E2"]

    // GnRH antagonists
    Elagolix_150 -> Elagolix_PK [color="#2C3E50"]
    Elagolix_200BID -> Elagolix_PK [color="#2C3E50"]
    Elagolix_PK -> GnRH_R_occupancy [color="#2C3E50"]
    Cetrorelix -> GnRH_R_occupancy [color="#2C3E50"]
    Relugolix -> GnRH_R_occupancy [color="#2C3E50"]

    // Progestins
    Dienogest -> Dienogest_PK [color="#8E44AD"]
    Dienogest_PK -> PR_A [color="#9B59B6"]
    Dienogest_PK -> PR_B [color="#9B59B6"]
    Dienogest_PK -> COX2 [color="#E74C3C" style=dashed label="↓ COX-2"]
    Dienogest_PK -> Lesion_proliferation [color="#E74C3C" style=dashed label="antiproliferative"]

    // Aromatase inhibitors
    Letrozole -> Letrozole_PK [color="#1ABC9C"]
    Letrozole_PK -> AI_E2_suppression [color="#1ABC9C"]
    Anastrozole -> AI_E2_suppression [color="#1ABC9C"]

    // NSAIDs
    Ibuprofen -> NSAID_PGE2_inhib [color="#E67E22"]
    Celecoxib -> NSAID_PGE2_inhib [color="#E67E22"]

    // ==========================================================
    // CROSS-CLUSTER EDGES (key mechanistic connections)
    // ==========================================================

    // HPO → Ectopic lesion
    Menstruation -> Retrograde_menses [color="#E74C3C" penwidth=2 label="retrograde\nflow" constraint=false]
    E2_ovarian -> E2_local [color="#FF6B9D" penwidth=2 label="E2 systemic\n→ local" constraint=false]

    // PGE2 → Aromatase (positive feedback loop — KEY)
    PGE2 -> CYP19A1 [color="#FF4500" penwidth=3 label="PGE2→Aromatase\nkey loop" constraint=false]
    CYP19A1 -> E2_local [color="#FF6B9D" penwidth=2 constraint=false]
    E2_local -> COX2 [color="#FF4500" penwidth=2 label="E2→COX-2\nloop" constraint=false]
    COX2 -> PGE2 [color="#E67E22" penwidth=2 constraint=false]

    // Inflammation → Pain
    IL1beta -> NGF [color="#8E44AD" penwidth=2 label="IL-1β→NGF" constraint=false]
    IL6 -> NGF [color="#8E44AD" constraint=false]
    TNFalpha -> Nociceptors [color="#8E44AD" label="TNF-α sensitize" constraint=false]
    PGE2 -> Peripheral_sensitization [color="#8E44AD" penwidth=2 label="PGE2→sensitize" constraint=false]
    IL1beta -> Bradykinin [color="#8E44AD" style=dashed constraint=false]

    // Inflammation → Lesion
    IL6 -> Lesion_proliferation [color="#E74C3C" penwidth=2 constraint=false]
    IL1beta -> Lesion_proliferation [color="#E74C3C" constraint=false]
    TNFalpha -> NFkB [color="#E67E22" penwidth=2 constraint=false]
    NFkB -> Lesion_proliferation [color="#E74C3C" penwidth=2 constraint=false]
    MMP1 -> Lesion_invasion [color="#E74C3C" constraint=false]
    MMP9 -> Lesion_invasion [color="#E74C3C" constraint=false]

    // Lesion → Inflammation
    Lesion_volume -> Peritoneal_macrophages [color="#E67E22" label="lesion activates\nmacrophages" constraint=false]
    Epithelial_cells_ecto -> IL6 [color="#E67E22" style=dashed constraint=false]
    Stromal_cells -> IL8 [color="#E67E22" style=dashed constraint=false]

    // HIF-1α → VEGF → neovascularization → lesion growth
    Lesion_volume -> HIF1alpha [color="#1ABC9C" label="hypoxia in lesion" constraint=false]
    HIF1alpha -> VEGF_A [color="#1ABC9C" penwidth=2 constraint=false]
    VEGF_A -> Neovascularization [color="#1ABC9C" penwidth=2 constraint=false]
    Neovascularization -> Lesion_volume [color="#1ABC9C" penwidth=2 label="vessel\nsupply" constraint=false]

    // NK cell dysfunction → lesion survival
    NK_cells -> Lesion_apoptosis [color="#27AE60" label="NK kills\n(dysfunctional↓)" constraint=false]
    TGF_beta -> NK_cytotoxicity [color="#E74C3C" label="TGF-β↓NK" style=dashed constraint=false]
    IL10 -> NK_cytotoxicity [color="#E74C3C" style=dashed constraint=false]

    // Drug → HPO axis suppression
    GnRH_desensitization -> GnRH_receptor [color="#E74C3C" penwidth=2 label="agonist\ndown-reg" constraint=false]
    GnRH_desensitization -> FSH [color="#E74C3C" label="↓ FSH" style=dashed constraint=false]
    GnRH_desensitization -> LH [color="#E74C3C" label="↓ LH" style=dashed constraint=false]
    GnRH_R_occupancy -> GnRH_receptor [color="#E74C3C" penwidth=2 label="antagonist\nblocks" constraint=false]
    GnRH_R_occupancy -> FSH [color="#E74C3C" style=dashed constraint=false]
    GnRH_R_occupancy -> LH [color="#E74C3C" style=dashed constraint=false]
    GnRH_R_occupancy -> E2_ovarian [color="#E74C3C" penwidth=2 label="↓ E2" constraint=false]
    AI_E2_suppression -> CYP19A1 [color="#E74C3C" penwidth=2 label="AI blocks\naromatase" constraint=false]
    AI_E2_suppression -> E2_local [color="#E74C3C" penwidth=2 constraint=false]
    NSAID_PGE2_inhib -> COX2 [color="#E74C3C" label="NSAID→↓COX2" constraint=false]
    NSAID_PGE2_inhib -> PGE2 [color="#E74C3C" penwidth=2 label="↓ PGE2" constraint=false]
    NSAID_PGE2_inhib -> Pain_perception [color="#E74C3C" label="pain relief" style=dashed constraint=false]
    Combined_OCP -> E2_ovarian [color="#E74C3C" label="OCP→ ovarian\nsuppression" style=dashed constraint=false]
    Combined_OCP -> LH [color="#E74C3C" style=dashed constraint=false]
    LNG_IUD -> Lesion_proliferation [color="#E74C3C" style=dashed label="local progestin" constraint=false]
    MPA -> PR_A [color="#9B59B6" style=dashed constraint=false]
    Norethindrone_acetate -> PR_A [color="#9B59B6" style=dashed constraint=false]

    // E2 deficiency → BMD loss
    E2_ovarian -> BMD_lumbar [color="#27AE60" label="E2 protects bone" constraint=false]
    E2_ovarian -> BMD_hip [color="#27AE60" constraint=false]
    GnRH_desensitization -> BMD_lumbar [color="#E74C3C" label="E2↓→BMD↓" style=dashed constraint=false]
    GnRH_R_occupancy -> BMD_lumbar [color="#E74C3C" style=dashed constraint=false]

    // Oxidative stress → inflammation loop
    ROS -> NFkB_activation [color="#E67E22" label="ROS→NF-κB" constraint=false]
    ROS -> IL1beta [color="#E67E22" style=dashed constraint=false]
    ROS -> Lesion_proliferation [color="#E74C3C" style=dashed label="ROS→growth" constraint=false]
    Iron_overload -> Peritoneal_macrophages [color="#F39C12" style=dashed constraint=false]
    Menstruation -> Iron_overload [color="#F39C12" label="shed blood\n→iron" constraint=false]

    // Clinical endpoints
    E2_ovarian -> Serum_E2_clinical [color="#FF6B9D" constraint=false]
    E2_ovarian -> Hot_flushes [color="#E74C3C" label="E2↓→VMS" style=dashed constraint=false]
    FSH -> Serum_FSH_clinical [color="#2196F3" constraint=false]
    P4_luteal -> Serum_P4_clinical [color="#9B59B6" constraint=false]
    Lesion_volume -> Endometrioma_size [color="#E74C3C" constraint=false]
    Lesion_volume -> rAFS_score [color="#E74C3C" constraint=false]
    IL6 -> CA125 [color="#E67E22" label="↑CA-125" constraint=false]
    Lesion_volume -> CA125 [color="#E74C3C" style=dashed constraint=false]
    Ovulation -> Fertility_outcome [color="#27AE60" constraint=false]
    Lesion_volume -> Fertility_outcome [color="#E74C3C" label="endo→infertility" style=dashed constraint=false]
    Ovulation -> Fecundability [color="#27AE60" constraint=false]
    Lesion_volume -> Recurrence_rate [color="#E74C3C" constraint=false]
    BMD_lumbar -> Quality_of_life [color="#2C3E50" style=dashed constraint=false]
    CPP -> Quality_of_life [color="#8E44AD" penwidth=2 constraint=false]
    Dysmenorrhea -> Quality_of_life [color="#8E44AD" constraint=false]
    AMH -> Serum_AMH_clinical [color="#2196F3" constraint=false]
    Menstruation -> PBAC_score [color="#2C3E50" constraint=false]
    LNG_IUD -> PBAC_score [color="#27AE60" label="↓ bleeding" style=dashed constraint=false]

    // Immune → lesion
    Th2 -> Mast_cells [color="#2980B9" style=dashed constraint=false]
    IL17 -> Lesion_proliferation [color="#E74C3C" style=dashed constraint=false]
    TGF_beta -> Lesion_invasion [color="#E74C3C" label="TGF-β→invasion" style=dashed constraint=false]
    Tregs -> Lesion_apoptosis [color="#E74C3C" label="Tregs suppress\nimmuno clearance" style=dashed constraint=false]

    // Aromatase feedback detail
    E2_local -> SF1 [color="#FF4500" penwidth=2 label="E2 activates\nSF-1" constraint=false]
    SF1 -> CYP19A1 [color="#FF4500" penwidth=2 constraint=false]

}
