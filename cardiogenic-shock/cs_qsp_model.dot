digraph CardiogenicShock_QSP {
    // ===========================================================
    // Cardiogenic Shock (CS) — Comprehensive QSP Mechanistic Map
    // ===========================================================
    // Hemodynamics, neurohormones, inflammation, microcirculation,
    // multi-organ failure, drug PK/PD (inotropes/vasopressors/MCS),
    // and clinical endpoints (SCAI A→E staging, 30-day mortality).
    // 120+ nodes / 12 subgraph clusters
    // ===========================================================

    graph [rankdir=LR, splines=true, overlap=false, fontname="Helvetica",
           label="Cardiogenic Shock — QSP Mechanistic Map",
           labelloc="t", fontsize=22, bgcolor="#FAFAFA", pad=0.4, nodesep=0.35, ranksep=0.55];
    node  [shape=box, style="rounded,filled", fontname="Helvetica", fontsize=10, margin="0.10,0.06"];
    edge  [fontname="Helvetica", fontsize=8, color="#555555", arrowsize=0.65];

    // ---------- 1. Etiology / Trigger ----------
    subgraph cluster_etiology {
        label="① 원인 / 트리거 (Etiology — SHOCK trial: AMI 80%)";
        style="rounded,filled"; color="#B71C1C"; fillcolor="#FFEBEE"; fontsize=14;
        AMI       [label="급성 심근경색\n(STEMI 70-80%)", fillcolor="#FFCDD2"];
        LMCA      [label="좌주관상동맥 폐색\n(LMCA · LAD prox)", fillcolor="#FFCDD2"];
        MR_papl   [label="유두근 파열\n→ 급성 MR", fillcolor="#FFCDD2"];
        VSR       [label="심실중격 파열\n(VSR, 2-3 days)", fillcolor="#FFCDD2"];
        FreeWallR [label="유리벽 파열\n→ 심장압전", fillcolor="#FFCDD2"];
        Myocarditis [label="전격성 심근염\n(바이러스/거대세포)", fillcolor="#FFCDD2"];
        Takotsubo [label="Takotsubo\n심근병증", fillcolor="#FFCDD2"];
        DCMP_decomp [label="DCM 급성 악화\n(EF<20%)", fillcolor="#FFCDD2"];
        Arrhythmia [label="치명적 부정맥\n(VT/VF · 서맥)", fillcolor="#FFCDD2"];
        ValveAcute [label="급성 판막 부전\n(인공판막 혈전)", fillcolor="#FFCDD2"];
        PostCardiotomy [label="개심술 후 심장기능 부전\n(post-cardiotomy)", fillcolor="#FFCDD2"];
    }

    // ---------- 2. LV Failure / Hemodynamic core ----------
    subgraph cluster_lv {
        label="② 좌심실 부전 (LV Failure — SCAI 'C' onwards)";
        style="rounded,filled"; color="#0D47A1"; fillcolor="#E3F2FD"; fontsize=14;
        Necrosis [label="심근 괴사·기절\n(stunning/hibernation)", fillcolor="#BBDEFB"];
        LV_Contract [label="좌심실 수축력↓\n(LVEF<30%, dP/dt↓)", fillcolor="#90CAF9"];
        SV_drop [label="일회박출량↓\n(SV<35mL)", fillcolor="#90CAF9"];
        CO_drop [label="심박출량↓\n(CO<2.2 L/min/m²·CI)", fillcolor="#90CAF9"];
        LVEDP_up [label="LVEDP↑·PCWP↑\n(>18 mmHg)", fillcolor="#BBDEFB"];
        LVdilatation [label="LV 확장·구형화\n(LVEDV↑, sphericity)", fillcolor="#BBDEFB"];
        WallStress [label="LV 벽응력↑\n(Laplace)", fillcolor="#BBDEFB"];
        MyoO2Demand [label="심근 산소요구↑\n(MVO2)", fillcolor="#BBDEFB"];
        SubendoIsch [label="심내막하 허혈\n(supply/demand mismatch)", fillcolor="#BBDEFB"];
    }

    // ---------- 3. RV Failure ----------
    subgraph cluster_rv {
        label="③ 우심실 부전 (RV — 비AMI, 폐색전, RV infarct ~25%)";
        style="rounded,filled"; color="#1B5E20"; fillcolor="#E8F5E9"; fontsize=14;
        RVI [label="RV 심근경색\n(하벽 STEMI 30-50%)", fillcolor="#C8E6C9"];
        RV_Contract [label="RV 수축력↓\n(TAPSE<14mm)", fillcolor="#A5D6A7"];
        RV_dilation [label="RV 확장·교호운동\n(septal bowing)", fillcolor="#A5D6A7"];
        PAH_acute [label="급성 PVR↑\n(저산소·산증·미세혈전)", fillcolor="#C8E6C9"];
        VentInter [label="심실 상호의존성\n(septum shift L→R)", fillcolor="#A5D6A7"];
        Pre_load_LV [label="LV 전부하↓\n(under-filling)", fillcolor="#A5D6A7"];
    }

    // ---------- 4. Systemic Hemodynamics ----------
    subgraph cluster_sys {
        label="④ 전신 혈역학 (Systemic Hemodynamics — SCAI Stage)";
        style="rounded,filled"; color="#4527A0"; fillcolor="#EDE7F6"; fontsize=14;
        MAP_drop [label="평균동맥압↓\n(MAP<65 mmHg)", fillcolor="#D1C4E9"];
        SBP_drop [label="수축기 혈압↓\n(SBP<90 mmHg ≥30분)", fillcolor="#D1C4E9"];
        SVR_init [label="초기 SVR↑\n(보상)", fillcolor="#D1C4E9"];
        SVR_late [label="후기 SVR↓\n(혼합형 쇼크 30-40%)", fillcolor="#D1C4E9"];
        TissuePerf [label="조직 관류↓\n(skin mottling, cap refill>3s)", fillcolor="#D1C4E9"];
        Lactate_up [label="젖산 상승\n(>2 또는 >4 mmol/L)", fillcolor="#D1C4E9"];
        SvO2 [label="혼합정맥혈 SaO2↓\n(<60%)", fillcolor="#D1C4E9"];
        UrineOut [label="요량↓\n(<0.5 mL/kg/h)", fillcolor="#D1C4E9"];
    }

    // ---------- 5. Neurohormonal Activation ----------
    subgraph cluster_neuro {
        label="⑤ 신경호르몬 활성화 (Neurohormonal)";
        style="rounded,filled"; color="#E65100"; fillcolor="#FFF3E0"; fontsize=14;
        SNS [label="교감신경 항진\n(NE 10-20× 정상)", fillcolor="#FFE0B2"];
        Epi [label="부신 에피네프린↑\n(0.5-2 nmol/L)", fillcolor="#FFE0B2"];
        RAAS [label="RAAS 활성화\n(렌+AngII↑)", fillcolor="#FFE0B2"];
        AVP [label="ADH(바소프레신)↓\n→ 후기 결핍", fillcolor="#FFE0B2"];
        BNP_NT [label="BNP·NT-proBNP↑↑\n(>5000 pg/mL)", fillcolor="#FFE0B2"];
        Cortisol [label="코르티솔↑\n(CIRCI 가능)", fillcolor="#FFE0B2"];
        Beta1_down [label="β1 수용체 하향조절\n(GRK2)", fillcolor="#FFE0B2"];
        cAMP_loss [label="심근 cAMP 반응↓", fillcolor="#FFE0B2"];
    }

    // ---------- 6. Inflammation / SIRS ----------
    subgraph cluster_inflam {
        label="⑥ 전신 염증 (SIRS in CS — Hochman 2003)";
        style="rounded,filled"; color="#880E4F"; fillcolor="#FCE4EC"; fontsize=14;
        DAMP [label="DAMPs 방출\n(HMGB1·HSP·미토 DNA)", fillcolor="#F8BBD0"];
        iNOS [label="iNOS 유도\n(혈관·심근)", fillcolor="#F8BBD0"];
        NO_excess [label="NO 과잉\n(혈관확장·심억제)", fillcolor="#F8BBD0"];
        TNFa [label="TNF-α↑\n(>20 pg/mL)", fillcolor="#F8BBD0"];
        IL6 [label="IL-6↑\n(>200 pg/mL)", fillcolor="#F8BBD0"];
        IL10 [label="IL-10↑\n(보상성 면역억제)", fillcolor="#F8BBD0"];
        Complement [label="보체 활성화\n(C3a·C5a)", fillcolor="#F8BBD0"];
        Endothel [label="내피 활성화\n(ICAM-1·VCAM-1)", fillcolor="#F8BBD0"];
        Glycocalyx [label="당질외피 분해\n(syndecan-1↑)", fillcolor="#F8BBD0"];
        CapLeak [label="모세혈관 누출↑\n(부종)", fillcolor="#F8BBD0"];
    }

    // ---------- 7. Microcirculation ----------
    subgraph cluster_micro {
        label="⑦ 미세순환 (Microcirculation)";
        style="rounded,filled"; color="#006064"; fillcolor="#E0F7FA"; fontsize=14;
        MicroFlow [label="미세관류 이질성\n(De Backer DBI)", fillcolor="#B2EBF2"];
        Shunt [label="기능적 단락(shunt)", fillcolor="#B2EBF2"];
        TissueO2 [label="조직 산소공급↓\n(StO2)", fillcolor="#B2EBF2"];
        MitoDys [label="미토콘드리아 기능부전\n(전자전달계)", fillcolor="#B2EBF2"];
        ROS [label="ROS↑·산화 스트레스", fillcolor="#B2EBF2"];
        AnaerobicGly [label="혐기성 해당↑\n→ 젖산생성", fillcolor="#B2EBF2"];
        H_acid [label="대사성 산증\n(pH<7.30, BE<-6)", fillcolor="#B2EBF2"];
    }

    // ---------- 8. Multi-Organ Failure ----------
    subgraph cluster_mof {
        label="⑧ 다발성 장기부전 (MOF — SCAI 'E')";
        style="rounded,filled"; color="#4A148C"; fillcolor="#F3E5F5"; fontsize=14;
        AKI [label="급성 신손상\n(KDIGO 2-3)", fillcolor="#E1BEE7"];
        LiverShock [label="쇼크 간\n(AST/ALT >20× 정상)", fillcolor="#E1BEE7"];
        IschColitis [label="허혈성 장염·박테리아 전이", fillcolor="#E1BEE7"];
        ARDS [label="ARDS / 폐부종\n(P/F<200)", fillcolor="#E1BEE7"];
        DIC [label="DIC·혈전성 미세혈관병", fillcolor="#E1BEE7"];
        EncephCNS [label="허혈성 뇌증\n(GCS↓)", fillcolor="#E1BEE7"];
        AdrInsuf [label="상대적 부신부전\n(CIRCI)", fillcolor="#E1BEE7"];
    }

    // ---------- 9. Coagulation / Endothelium ----------
    subgraph cluster_coag {
        label="⑨ 응고·내피";
        style="rounded,filled"; color="#37474F"; fillcolor="#ECEFF1"; fontsize=14;
        TF [label="조직인자 노출\n→ 외인성 응고", fillcolor="#CFD8DC"];
        Platelets [label="혈소판 활성·소모", fillcolor="#CFD8DC"];
        Fibrinogen [label="피브리노겐 소모", fillcolor="#CFD8DC"];
        VWF [label="vWF·ADAMTS13 균형 붕괴", fillcolor="#CFD8DC"];
        FibrosisM [label="심근·폐 미세혈전", fillcolor="#CFD8DC"];
    }

    // ---------- 10. Pharmacology PK/PD ----------
    subgraph cluster_drugs {
        label="⑩ 약물 PK / PD (Inotropes · Vasopressors · MCS)";
        style="rounded,filled"; color="#212121"; fillcolor="#F5F5F5"; fontsize=14;
        NE_drug [label="노르에피네프린\n(α1·β1, 1차 vasopressor)\nKd_α1≈8 nM", fillcolor="#FFCC80"];
        Epi_drug [label="에피네프린\n(α·β1·β2)\n2차 또는 anaphylaxis", fillcolor="#FFCC80"];
        DA_drug [label="도파민\n(저용량 D1, 고용량 α)\nSOAP-II 불량", fillcolor="#FFCC80"];
        Dobu [label="도부타민\n(β1>β2 작용제)\n2.5-20 µg/kg/min", fillcolor="#FFCC80"];
        Mil [label="밀리논(Milrinone)\nPDE3 억제 → cAMP↑", fillcolor="#FFCC80"];
        Levo [label="레보시멘단(Levosimendan)\nTnC 칼슘 감수성↑\n+ K-ATP 개방", fillcolor="#FFCC80"];
        AVP_drug [label="바소프레신\n(V1aR, 0.03 U/min)", fillcolor="#FFCC80"];
        DigOmec [label="오메캄티브 메카르빌\n심근 미오신 활성제", fillcolor="#FFCC80"];
        IABP [label="대동맥 내 풍선펌프\n(IABP-SHOCK II: ns)", fillcolor="#A5D6A7"];
        Impella [label="Impella CP/5.0\n경피적 LV 보조\n(DanGer Shock 2024 +↓사망)", fillcolor="#A5D6A7"];
        ECMO [label="VA-ECMO\n(ECLS-SHOCK 2023: ns)", fillcolor="#A5D6A7"];
        LVAD [label="장기 LVAD/심장이식", fillcolor="#A5D6A7"];
        Furosemide [label="푸로세마이드\n(부종·울혈)", fillcolor="#FFCC80"];
        Bicarb [label="중탄산나트륨\n(중증 산증)", fillcolor="#FFCC80"];
        TLowering [label="목표체온 조절(33-36°C)\n(out-of-hospital arrest)", fillcolor="#A5D6A7"];
        Revasc [label="긴급 재관류\n(PCI · CABG)\nSHOCK trial 30% RRR 6yr", fillcolor="#A5D6A7"];
    }

    // ---------- 11. Drug Concentrations / Receptors ----------
    subgraph cluster_targets {
        label="⑪ 분자 표적 및 신호경로 (Targets)";
        style="rounded,filled"; color="#0277BD"; fillcolor="#E1F5FE"; fontsize=14;
        Alpha1R [label="α1-아드레날린 수용체\n(혈관 평활근)", fillcolor="#B3E5FC"];
        Beta1R [label="β1-아드레날린 수용체\n(심근)", fillcolor="#B3E5FC"];
        Beta2R [label="β2-아드레날린 수용체\n(혈관 확장)", fillcolor="#B3E5FC"];
        V1aR [label="V1a 수용체\n(혈관)", fillcolor="#B3E5FC"];
        D1R [label="D1 수용체\n(신장·내장 혈관)", fillcolor="#B3E5FC"];
        PDE3 [label="PDE3 인산다이에스터라제\n→ cAMP 분해", fillcolor="#B3E5FC"];
        TnC [label="트로포닌 C\n(Ca²⁺ 감수성)", fillcolor="#B3E5FC"];
        K_ATP [label="ATP-감수성 K 채널\n(혈관 확장)", fillcolor="#B3E5FC"];
        Gs [label="Gs · 아데닐릴 시클라제 → cAMP", fillcolor="#B3E5FC"];
        Gq [label="Gq · PLC · IP3 → Ca²⁺", fillcolor="#B3E5FC"];
        cAMP_card [label="심근 cAMP", fillcolor="#B3E5FC"];
        Ca_handling [label="Ca²⁺ 항상성·SR·RyR·SERCA2a", fillcolor="#B3E5FC"];
        ROCK [label="Rho/ROCK\n혈관 수축 신호", fillcolor="#B3E5FC"];
        eNOS [label="내피 NO 합성효소(eNOS)", fillcolor="#B3E5FC"];
    }

    // ---------- 12. Clinical Endpoints / Scores ----------
    subgraph cluster_clin {
        label="⑫ 임상 지표 / 예후 (Clinical Endpoints)";
        style="rounded,filled"; color="#3E2723"; fillcolor="#EFEBE9"; fontsize=14;
        SCAI [label="SCAI Stage A → E\n(2022 update)", fillcolor="#D7CCC8"];
        Mort30 [label="30일 사망률\n(SCAI E 67%, B 5%)", fillcolor="#D7CCC8"];
        IHM [label="원내 사망률\n(전체 ≈ 40-50%)", fillcolor="#D7CCC8"];
        CSWS [label="CardShock Risk Score\n(7 var, AUC 0.81)", fillcolor="#D7CCC8"];
        IABPSHOCKII [label="IABP-SHOCK II 점수\n(6 var)", fillcolor="#D7CCC8"];
        LV_RecovEF [label="LVEF 회복(%)\n(stunning reversibility)", fillcolor="#D7CCC8"];
        QoL [label="삶의 질 / NYHA\n(생존자)", fillcolor="#D7CCC8"];
        Days_VPress [label="혈관수축제 무사용일\n(vasoactive-free days)", fillcolor="#D7CCC8"];
        ICU_Mort [label="ICU 체류·재원기간", fillcolor="#D7CCC8"];
    }

    // ============= EDGES =============

    // 1) Etiology → LV/RV
    AMI -> Necrosis [label="ischemia"];
    LMCA -> Necrosis;
    MR_papl -> LV_Contract [label="acute volume overload"];
    VSR -> LV_Contract;
    FreeWallR -> LV_Contract;
    Myocarditis -> Necrosis;
    Takotsubo -> LV_Contract;
    DCMP_decomp -> LV_Contract;
    Arrhythmia -> CO_drop;
    ValveAcute -> LV_Contract;
    PostCardiotomy -> LV_Contract;
    AMI -> RVI [label="inf STEMI"];
    RVI -> RV_Contract;

    // 2) LV cascade
    Necrosis -> LV_Contract;
    LV_Contract -> SV_drop;
    SV_drop -> CO_drop;
    CO_drop -> MAP_drop;
    LV_Contract -> LVEDP_up;
    LVEDP_up -> LVdilatation;
    LVdilatation -> WallStress;
    WallStress -> MyoO2Demand;
    MyoO2Demand -> SubendoIsch;
    SubendoIsch -> Necrosis [style=dashed, color="#B71C1C", label="vicious cycle"];
    LVEDP_up -> ARDS [label="pulmonary edema"];

    // 3) RV cascade
    RV_Contract -> RV_dilation;
    RV_dilation -> VentInter;
    VentInter -> Pre_load_LV;
    Pre_load_LV -> SV_drop;
    PAH_acute -> RV_Contract [label="afterload"];

    // 4) Systemic hemodynamics
    MAP_drop -> TissuePerf;
    TissuePerf -> Lactate_up;
    CO_drop -> SvO2 [label="venous extraction"];
    MAP_drop -> UrineOut;
    SVR_init -> MAP_drop [label="initial compensation"];
    SVR_late -> MAP_drop [style=dashed, label="vasoplegia"];
    NO_excess -> SVR_late;

    // 5) Neurohormonal
    MAP_drop -> SNS [label="baroreflex"];
    SNS -> Epi;
    SNS -> RAAS;
    SNS -> NE_drug [style=invis];   // anchor
    RAAS -> SVR_init;
    SNS -> Beta1_down;
    Beta1_down -> cAMP_loss;
    LVEDP_up -> BNP_NT;
    SNS -> Cortisol;
    AVP -> SVR_late [style=dashed];

    // 6) Inflammation
    Necrosis -> DAMP;
    DAMP -> TNFa;
    DAMP -> IL6;
    DAMP -> Complement;
    TNFa -> iNOS;
    iNOS -> NO_excess;
    NO_excess -> LV_Contract [style=dashed, label="myocardial depression"];
    IL6 -> Endothel;
    Endothel -> Glycocalyx;
    Glycocalyx -> CapLeak;
    CapLeak -> TissuePerf;
    Complement -> Endothel;
    IL10 -> Endothel [style=dashed, label="immunosuppression"];

    // 7) Microcirculation
    TissuePerf -> MicroFlow;
    MicroFlow -> Shunt;
    Shunt -> TissueO2;
    TissueO2 -> MitoDys;
    MitoDys -> ROS;
    ROS -> MitoDys [style=dashed];
    MitoDys -> AnaerobicGly;
    AnaerobicGly -> Lactate_up;
    Lactate_up -> H_acid;
    H_acid -> LV_Contract [style=dashed, label="acidosis depresses contractility"];

    // 8) Multi-Organ Failure
    TissuePerf -> AKI;
    TissuePerf -> LiverShock;
    TissuePerf -> IschColitis;
    TissuePerf -> EncephCNS;
    ARDS -> TissueO2 [label="hypoxemia"];
    IschColitis -> DAMP [label="gut→bacterial translocation"];
    AdrInsuf -> SVR_late;

    // 9) Coagulation
    DAMP -> TF;
    Endothel -> TF;
    TF -> Platelets;
    Platelets -> DIC;
    Fibrinogen -> DIC;
    VWF -> FibrosisM;

    // 10) Drug pharmacology
    NE_drug -> Alpha1R [label="agonist"];
    Alpha1R -> Gq;
    Gq -> SVR_init;
    NE_drug -> Beta1R [label="weak β1"];
    Beta1R -> Gs;
    Gs -> cAMP_card;
    cAMP_card -> Ca_handling [label="PKA"];
    Ca_handling -> LV_Contract [label="inotropy↑"];
    Epi_drug -> Beta1R;
    Epi_drug -> Beta2R [label="β2"];
    Beta2R -> Gs;
    Beta2R -> SVR_init [style=dashed, label="vasodilation"];
    Dobu -> Beta1R;
    Dobu -> Beta2R [label="β2 minor"];
    DA_drug -> D1R [label="low dose"];
    DA_drug -> Alpha1R [label="high dose"];
    D1R -> SVR_init [style=dashed, label="renal vasodil"];
    Mil -> PDE3 [label="IC50≈0.3µM"];
    PDE3 -> cAMP_card [style=dashed, label="degrades"];
    Mil -> cAMP_card [label="cAMP↑"];
    Levo -> TnC [label="Ca-sensitization"];
    TnC -> LV_Contract;
    Levo -> K_ATP [label="opens"];
    K_ATP -> SVR_init [style=dashed, label="vasodilate"];
    AVP_drug -> V1aR [label="agonist"];
    V1aR -> SVR_init;
    DigOmec -> LV_Contract [label="cardiac myosin"];
    eNOS -> NO_excess [style=dashed, color="#555"];

    // MCS
    IABP -> CO_drop [style=dashed, label="diastolic augment 10-15%"];
    Impella -> CO_drop [label="2.5-5.5 L/min unload"];
    Impella -> LVEDP_up [style=dashed, label="LV unloading"];
    ECMO -> CO_drop [label="3-7 L/min support"];
    ECMO -> LVEDP_up [style=dashed, label="LV distension risk"];
    LVAD -> LV_Contract [label="long-term support"];
    Revasc -> Necrosis [style=dashed, label="myocardial salvage"];

    // Adjuncts
    Furosemide -> LVEDP_up [style=dashed, label="preload reduction"];
    Bicarb -> H_acid [style=dashed];
    TLowering -> MyoO2Demand [style=dashed, label="↓demand"];

    // 11) Clinical endpoints
    SV_drop -> SCAI;
    Lactate_up -> SCAI;
    MOFnode [shape=point, style=invis];   // junction
    AKI -> SCAI;
    EncephCNS -> SCAI;
    SCAI -> Mort30 [label="strong predictor"];
    SCAI -> IHM;
    CSWS -> Mort30;
    IABPSHOCKII -> Mort30;
    Revasc -> LV_RecovEF [label="early reperfusion"];
    Impella -> Mort30 [style=dashed, label="DanGer 2024 ↓26→18% (HR 0.74)"];
    ECMO -> Mort30 [style=dashed, label="ECLS-SHOCK ns"];
    NE_drug -> Mort30 [style=dashed, label="standard 1st-line"];
    LV_RecovEF -> QoL;
    Days_VPress -> ICU_Mort;

    // Cross-links (vicious cycles)
