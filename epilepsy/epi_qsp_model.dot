digraph epilepsy_qsp {
    rankdir=TB;
    compound=true;
    splines=curved;
    graph [
        label="Epilepsy (뇌전증) QSP Mechanistic Map\nIon Channel Biology · Seizure Network Dynamics · AED PK/PD · Drug Resistance · Clinical Outcomes",
        labelloc=t,
        fontname="Helvetica-Bold",
        fontsize=20,
        bgcolor="#F8F9FA",
        pad=1.0,
        nodesep=0.35,
        ranksep=0.65,
        overlap=false,
        size="28,20"
    ];
    node [fontname="Helvetica", fontsize=9, style="filled,rounded", shape=box, margin="0.12,0.06", penwidth=1.2];
    edge [fontname="Helvetica", fontsize=7, arrowsize=0.6, penwidth=0.9];

    // ============================
    // CLUSTER 1: GENETIC ETIOLOGY
    // ============================
    subgraph cluster_genetics {
        label="Genetic Epilepsy Etiology\n(Monogenic & Polygenic)";
        style=filled;
        color="#CC2244";
        fillcolor="#FFF0F3";
        fontname="Helvetica-Bold";
        fontsize=12;
        fontcolor="#CC2244";

        SCN1A [label="SCN1A\n(Nav1.1 gene — Dravet)", fillcolor="#FFCCD6"];
        SCN2A [label="SCN2A\n(Nav1.2 gene — BFNE/EE)", fillcolor="#FFCCD6"];
        SCN8A [label="SCN8A\n(Nav1.6 gene — EIEE13)", fillcolor="#FFCCD6"];
        KCNQ2 [label="KCNQ2\n(Kv7.2 gene — BFNE)", fillcolor="#FFD0D8"];
        KCNQ3 [label="KCNQ3\n(Kv7.3 gene — BFNE)", fillcolor="#FFD0D8"];
        KCNT1 [label="KCNT1\n(Slack K+ — ADSHE)", fillcolor="#FFD0D8"];
        GABRG2 [label="GABRG2\n(GABA-A γ2 — GEFS+)", fillcolor="#FFCCDD"];
        GABRA1 [label="GABRA1\n(GABA-A α1 — JME)", fillcolor="#FFCCDD"];
        GABRB3 [label="GABRB3\n(GABA-A β3 — Lennox-Gastaut)", fillcolor="#FFCCDD"];
        DEPDC5 [label="DEPDC5\n(GATOR1 — mTORC1 regulator)", fillcolor="#FFD8E0"];
        TSC1 [label="TSC1\n(Hamartin — TSC)", fillcolor="#FFD8E0"];
        TSC2 [label="TSC2\n(Tuberin — TSC)", fillcolor="#FFD8E0"];
        CDKL5 [label="CDKL5\n(CDD — early infantile)", fillcolor="#FFE0E6"];
        STXBP1 [label="STXBP1\n(Munc18-1 — EIEE4)", fillcolor="#FFE0E6"];
        PCDH19 [label="PCDH19\n(Protocadherin — female epilepsy)", fillcolor="#FFE0E6"];
    }

    // ============================
    // CLUSTER 2: ACQUIRED CAUSES
    // ============================
    subgraph cluster_acquired {
        label="Acquired Epilepsy Causes\n(Structural/Infectious/Immune)";
        style=filled;
        color="#994400";
        fillcolor="#FFF5EE";
        fontname="Helvetica-Bold";
        fontsize=12;
        fontcolor="#994400";

        MTS [label="Mesial Temporal\nSclerosis (MTS)", fillcolor="#FFE5CC"];
        TBI [label="Traumatic Brain\nInjury (TBI)", fillcolor="#FFE5CC"];
        StrokeAcq [label="Stroke /\nCerebral Ischemia", fillcolor="#FFE5CC"];
        FCD [label="Focal Cortical\nDysplasia (FCD)", fillcolor="#FFDEC0"];
        AE_cause [label="Autoimmune\nEncephalitis (NMDAR-Ab)", fillcolor="#FFDEC0"];
        Febrile [label="Prolonged Febrile\nSeizures (>30 min)", fillcolor="#FFDEC0"];
        Perinatal [label="Perinatal Hypoxia-\nIschemia (HIE)", fillcolor="#FFD8B8"];
        BrainTumor [label="Primary Brain\nTumor (LGG/GBM)", fillcolor="#FFD8B8"];
        CNS_Infect [label="CNS Infection\n(Bacterial/Viral/Parasitic)", fillcolor="#FFD8B8"];
    }

    // ================================
    // CLUSTER 3: ION CHANNEL BIOLOGY
    // ================================
    subgraph cluster_ionchannel {
        label="Voltage-Gated Ion Channel Pathophysiology";
        style=filled;
        color="#1144BB";
        fillcolor="#EEF4FF";
        fontname="Helvetica-Bold";
        fontsize=12;
        fontcolor="#1144BB";

        Nav11 [label="Nav1.1 (SCN1A)\nInterneuron-specific Nav", fillcolor="#C8DEFF"];
        Nav12 [label="Nav1.2 (SCN2A)\nAxon initial segment Nav", fillcolor="#C8DEFF"];
        Nav16 [label="Nav1.6 (SCN8A)\nNodes of Ranvier Nav", fillcolor="#C8DEFF"];
        NavFastInact [label="Nav Fast Inactivation\n(ms timescale, refractory)", fillcolor="#D8E8FF"];
        NavSlowInact [label="Nav Slow Inactivation\n(seconds timescale)", fillcolor="#D8E8FF"];
        NavPersist [label="Persistent I_NaP\n(Sub-threshold depolarizing tone)", fillcolor="#D4E0FF", penwidth=1.8];
        Kv72 [label="Kv7.2 (KCNQ2)\nM-current subunit", fillcolor="#C8DCFF"];
        Kv73 [label="Kv7.3 (KCNQ3)\nM-current subunit", fillcolor="#C8DCFF"];
        Mcurrent [label="IM (M-current)\nSub-threshold K+ repolarization", fillcolor="#CCE0FF", penwidth=1.8];
        HCN1 [label="HCN1\n(Hyperpolarization-activated)", fillcolor="#D4E6FF"];
        HCN2 [label="HCN2 / Ih current\n(Thalamic pacemaker)", fillcolor="#D4E6FF"];
        CaT [label="T-type Cav3.1\n(Thalamic burst firing — absence)", fillcolor="#D8E8FF"];
        CaN [label="N-type Cav2.2\n(Presynaptic Ca2+ entry)", fillcolor="#D8E8FF"];
        BKchan [label="BK Channels (KCa1.1)\n(Ca2+-activated K+ outward)", fillcolor="#DCE8FF"];
        SK2chan [label="SK2 Channels (KCa2.2)\n(After-hyperpolarization)", fillcolor="#DCE8FF"];
    }

    // ===========================
    // CLUSTER 4: GABAergic SYSTEM
    // ===========================
    subgraph cluster_gaba {
        label="GABAergic Inhibitory System\n(Chloride & K+ Signaling)";
        style=filled;
        color="#116611";
        fillcolor="#F0FFF0";
        fontname="Helvetica-Bold";
        fontsize=12;
        fontcolor="#116611";

        GAD65 [label="GAD65 (GAD2)\n(GABA synthesis enzyme, synaptic)", fillcolor="#CCFFCC"];
        GAD67 [label="GAD67 (GAD1)\n(GABA synthesis, constitutive)", fillcolor="#CCFFCC"];
        VGAT [label="VGAT (SLC32A1)\n(Vesicular GABA transporter)", fillcolor="#D0FFC8"];
        GABA_A [label="GABA-A Receptor\n(Ionotropic Cl- channel, αβγ)", fillcolor="#AAFFAA", penwidth=2.0];
        GABA_A_a1 [label="GABA-A α1 subunit\n(Sedation, anticonvulsant)", fillcolor="#BBFFBB"];
        GABA_A_a2 [label="GABA-A α2 subunit\n(Anxiolysis, spinal antinociception)", fillcolor="#BBFFBB"];
        GABA_A_g2 [label="GABA-A γ2 subunit\n(BZD binding site — GABRG2)", fillcolor="#BBFFBB"];
        Cl_influx [label="Cl- Influx → Hyperpolarization\n(IPSP, anti-seizure effect)", fillcolor="#C0FFC0", penwidth=2.0];
        GABA_B [label="GABA-B Receptor\n(Metabotropic GPCR, Gi-coupled)", fillcolor="#C4FFC4"];
        GIRK [label="GIRK Channel (Kir3)\n(K+ efflux via GABA-B, IPSP)", fillcolor="#C8FFC8"];
        GAT1 [label="GAT-1 (SLC6A1)\n(Presynaptic GABA reuptake)", fillcolor="#CCFFCC"];
        GAT3 [label="GAT-3 (SLC6A11)\n(Astrocyte GABA reuptake)", fillcolor="#CCFFCC"];
        PV_INT [label="Parvalbumin (PV+)\nInterneurons (fast perisomatic)", fillcolor="#D0FFD0"];
        SST_INT [label="Somatostatin (SST+)\nInterneurons (dendritic inhibition)", fillcolor="#D0FFD0"];
        Neurosteroid [label="Endogenous Neurosteroids\n(THDOC, allopregnanolone — δ subunit)", fillcolor="#D4FFD4"];
        BZD_site [label="Benzodiazepine Binding Site\n(GABA-A γ2 — frequency↑)", fillcolor="#D8FFD8"];
    }

    // ==============================
    // CLUSTER 5: GLUTAMATERGIC SYSTEM
    // ==============================
    subgraph cluster_glutamate {
        label="Glutamatergic Excitatory System\n(Ionotropic & Metabotropic)";
        style=filled;
        color="#BB5500";
        fillcolor="#FFF8F0";
        fontname="Helvetica-Bold";
        fontsize=12;
        fontcolor="#BB5500";

        Gln_Glu [label="Glutamine → Glutamate\n(Glutaminase, GLS1/GLS2)", fillcolor="#FFE8CC"];
        VGLUT1 [label="VGLUT1 (SLC17A7)\n(Cortical Glu vesicle loading)", fillcolor="#FFE4C0"];
        VGLUT2 [label="VGLUT2 (SLC17A6)\n(Thalamic Glu vesicle loading)", fillcolor="#FFE4C0"];
        NMDA_R [label="NMDA Receptor\n(GluN1/GluN2A/GluN2B, Ca2+ permeable)", fillcolor="#FFCC88", penwidth=2.0];
        Mg_block [label="Mg2+ Block (NMDA)\n(Voltage-dependent relief at depol)", fillcolor="#FFD090"];
        AMPA_R [label="AMPA Receptor\n(GluA1/GluA2, fast EPSP)", fillcolor="#FFCC88", penwidth=2.0];
        Kainate_R [label="Kainate Receptor\n(GluK1/GluK2, seizure induction)", fillcolor="#FFD4A0"];
        mGluR1 [label="mGluR1/5 (Group I)\n(Gq/PLC/IP3, excitatory modulation)", fillcolor="#FFD8A8"];
        mGluR2 [label="mGluR2/3 (Group II)\n(Gi/cAMP↓, presynaptic auto-receptor)", fillcolor="#FFD8A8"];
        EAAT1 [label="EAAT1/GLAST (SLC1A3)\n(Astrocyte Glu reuptake)", fillcolor="#FFDCB0"];
        EAAT2 [label="EAAT2/GLT-1 (SLC1A2)\n(Major Glu reuptake ~95%)", fillcolor="#FFDCB0"];
        Ca_NMDA [label="Ca2+ Influx (NMDA)\n(Excitotoxicity trigger → CaMKII)", fillcolor="#FFC880", penwidth=2.0];
        AMPA_traffic [label="AMPA Receptor Trafficking\n(LTP → synaptic upscaling)", fillcolor="#FFE0B8"];
    }

    // =================================
    // CLUSTER 6: SEIZURE NETWORK DYNAMICS
    // =================================
    subgraph cluster_network {
        label="Seizure Network Dynamics\n(Hippocampal·Thalamo-Cortical·Status Epilepticus)";
        style=filled;
        color="#666600";
        fillcolor="#FFFFF0";
        fontname="Helvetica-Bold";
        fontsize=12;
        fontcolor="#666600";

        CA3 [label="CA3 Pyramidal Neurons\n(Burst firing, recurrent collaterals)", fillcolor="#FFFFC0"];
        CA1 [label="CA1 Pyramidal Neurons\n(Output, Schaffer → entorhinal)", fillcolor="#FFFFC0"];
        DG [label="Dentate Gyrus\n(Gating — inhibitory 'dentate brake')", fillcolor="#FFFFC0"];
        MossyFiber [label="Mossy Fiber Sprouting\n(Aberrant recurrent circuits → epileptogenesis)", fillcolor="#FFFF88"];
        ThalamusRelay [label="Thalamic Relay Neurons\n(TC oscillation — absence/generalized)", fillcolor="#FFFF88"];
        ThalamusReticular [label="Thalamic Reticular\nNucleus (GABAergic pacemaker)", fillcolor="#FFFF88"];
        CortexL5 [label="Layer V Cortical\nPyramidal Neurons (output)", fillcolor="#FFFFAA"];
        Synchrony [label="Network Synchrony Index\n(E/I imbalance measure)", fillcolor="#FFFF00", shape=ellipse, penwidth=1.8];
        SeizThresh [label="Seizure Threshold (Θ)\n[Θ_baseline − ΔGABA + ΔNav block]", fillcolor="#FFEE00", shape=ellipse, penwidth=2.5];
        Interictal [label="Interictal Epileptiform\nDischarge (IED, <5 sec)", fillcolor="#FFFFC0"];
        Ictal [label="Ictal Discharge\n(Clinical Seizure ≥5 sec)", fillcolor="#FFD700", shape=ellipse, penwidth=2.5];
        Postictal [label="Postictal Suppression\n(GABA surge, ATP depletion, postictal state)", fillcolor="#FFFFC0"];
        SE_early [label="Early SE\n(<5 min — still BZD-responsive)", fillcolor="#FFE060", penwidth=2.0];
        SE_estab [label="Established SE\n(5–30 min — BZD tolerance begins)", fillcolor="#FFD040", penwidth=2.0];
        SE_refrac [label="Refractory SE\n(>30–60 min — GABA-A internalization)", fillcolor="#FFBA00", penwidth=2.5];
    }

    // ===========================
    // CLUSTER 7: AED PK
    // ===========================
    subgraph cluster_pk {
        label="Antiepileptic Drug Pharmacokinetics (PK)\n(VPA · LEV · CBZ · LTG · PHT/GBP/PER/LCS)";
        style=filled;
        color="#551199";
        fillcolor="#F8F0FF";
        fontname="Helvetica-Bold";
        fontsize=12;
        fontcolor="#551199";

        VPA_gut [label="VPA Gut Absorption\n(ka=1.2/h, F=90%)", fillcolor="#ECC8FF"];
        VPA_C [label="VPA Central Compartment\n(Vc=9.1 L, 90% protein bound)", fillcolor="#E0AAFF", penwidth=2.0];
        VPA_P [label="VPA Peripheral\n(Vp=12 L)", fillcolor="#ECC8FF"];
        VPA_met [label="VPA Elimination\n(UGT + CYP2C9 + β-oxidation)", fillcolor="#F0D0FF"];
        LEV_gut [label="LEV Gut Absorption\n(ka=1.5/h, F≈100%)", fillcolor="#E8CCFF"];
        LEV_C [label="LEV Central\n(Vc=42 L, renal CL=3.8 L/h)", fillcolor="#DDB0FF", penwidth=2.0];
        LEV_met [label="LEV Hydrolysis\n(non-CYP, ucb L057 active)", fillcolor="#ECD4FF"];
        CBZ_gut [label="CBZ Gut Absorption\n(ka=0.5/h, F=75%, slow)", fillcolor="#E4C8FF"];
        CBZ_C [label="CBZ Central\n(Vc=51 L, autoinduction 2–4 wk)", fillcolor="#D8A8FF", penwidth=2.0];
        CBZ_E [label="CBZ-10,11-Epoxide\n(Active metabolite, ~50% CBZ activity)", fillcolor="#E8D0FF"];
        CBZ_auto [label="CYP3A4 Auto-Induction\n(CBZ induces own metabolism)", fillcolor="#EEDCFF"];
        LTG_gut [label="LTG Gut Absorption\n(ka=0.8/h, F≈98%)", fillcolor="#E6CCFF"];
        LTG_C [label="LTG Central\n(Vc=77 L, UGT1A4 glucuronidation)", fillcolor="#DAB0FF", penwidth=2.0];
        LTG_UGT [label="UGT1A4 Glucuronidation\n(LTG-N2-glucuronide, major)", fillcolor="#ECD8FF"];
        DDI_VPA_LTG [label="DDI: VPA inhibits UGT1A4\n(LTG t½ doubles: 24→48h)", fillcolor="#FFC8FF", shape=diamond, penwidth=1.8];
        DDI_CBZ_LTG [label="DDI: CBZ induces CYP3A4\n(LTG CL ↑2×; t½ halved)", fillcolor="#FFC8FF", shape=diamond, penwidth=1.8];
    }

    // ===========================
    // CLUSTER 8: AED PD MECHANISMS
    // ===========================
    subgraph cluster_pd {
        label="AED Pharmacodynamics (PD)\n(Mechanism-Based Seizure Threshold Elevation)";
        style=filled;
        color="#224488";
        fillcolor="#EEF2FF";
        fontname="Helvetica-Bold";
        fontsize=12;
        fontcolor="#224488";

        VPA_GABAT [label="VPA → GABA-T Inhibition\n(Succinic semialdehyde pathway, GABA↑)", fillcolor="#C8D8FF"];
        VPA_HDAC [label="VPA → HDAC Inhibition\n(Epigenetic: SCN1A mRNA↑)", fillcolor="#C8D8FF"];
        VPA_NavPD [label="VPA → Nav Partial Block\n(State-dependent, weak)", fillcolor="#D0DCFF"];
        LEV_SV2A [label="LEV → SV2A Binding\n(Synaptic vesicle protein 2A)", fillcolor="#C4D4FF", penwidth=2.0];
        LEV_vesicle [label="LEV → Vesicle\nRelease Kinetics Altered", fillcolor="#C4D4FF"];
        CBZ_Nav [label="CBZ → Nav Slow Inactivation\n(Use-dependent, high-freq block)", fillcolor="#BCCAFF", penwidth=2.0];
        LTG_Nav [label="LTG → Nav State-Dep Block\n(Slow inact + persistent I_NaP↓)", fillcolor="#C0CEFF", penwidth=2.0];
        PHT_Nav [label="PHT → Nav Inactivation\n(Frequency-dependent stabilization)", fillcolor="#C4D0FF"];
        BZD_GABAA [label="BZD → GABA-A Cl- Open\nFrequency↑ (γ2 site, allosteric)", fillcolor="#B8C8FF", penwidth=2.0];
        GBP_Cav [label="GBP/PGB → Cav2.2 α2δ-1\n(Presynaptic Ca2+ entry↓, Glu release↓)", fillcolor="#C8D4FF"];
        PER_AMPA [label="Perampanel → AMPA R\n(Non-competitive antagonist, AMPA block)", fillcolor="#CCDDFF"];
        LCS_Nav [label="Lacosamide → Nav\n(Enhanced slow inactivation + CRMP-2)", fillcolor="#D0E0FF"];
        ETX_CaT [label="Ethosuximide → T-type Cav3.1\n(Absence epilepsy: thalamic burst↓)", fillcolor="#D4E4FF"];
        Everolimus_mTOR [label="Everolimus → mTORC1↓\n(TSC/FCD: proliferation↓, seizure↓)", fillcolor="#D8E8FF"];
        Fen_5HT2C [label="Fenfluramine → 5-HT2C + σ1R\n(Dravet syndrome: seizure↓)", fillcolor="#DCE8FF"];
    }

    // ==============================
    // CLUSTER 9: DRUG RESISTANCE
    // ==============================
    subgraph cluster_resistance {
        label="AED Drug Resistance Mechanisms\n(Pharmacokinetic & Target Hypothesis)";
        style=filled;
        color="#AA1100";
        fillcolor="#FFF2F0";
        fontname="Helvetica-Bold";
        fontsize=12;
        fontcolor="#AA1100";

        Pgp [label="P-gp (ABCB1/MDR1)\n(BBB efflux pump — major AED transporter)", fillcolor="#FFCCCC", penwidth=2.0];
        MRP2 [label="MRP2 (ABCC2)\n(BBB & hepatic AED efflux)", fillcolor="#FFCCCC"];
        BCRP [label="BCRP (ABCG2)\n(Breast cancer resistance protein)", fillcolor="#FFCCCC"];
        BBB_efflux [label="BBB AED Efflux ↑\n(↓ CNS drug exposure fraction)", fillcolor="#FFB8B8", penwidth=2.0];
        Nav_resist [label="Nav1.1/Nav1.2\nPharmacoresistant Variants", fillcolor="#FFCCCC"];
        GABAA_resist [label="GABA-A Subunit\nPharmacoresistant Variants (γ2 loss)", fillcolor="#FFCCCC"];
        NFKB_MDR [label="NF-κB → MDR1/ABCB1 Transcription↑\n(Seizure-driven transporter upregulation)", fillcolor="#FFD0D0"];
        Refrac_def [label="Drug-Resistant Epilepsy (DRE)\nFail ≥2 adequate AED trials", fillcolor="#FF9999", shape=ellipse, penwidth=2.5];
        PK_hypo [label="Pharmacokinetic Hypothesis\n(AED distribution to brain↓)", fillcolor="#FFD8D8"];
        Target_hypo [label="Target Hypothesis\n(AED binding site altered)", fillcolor="#FFD8D8"];
    }

    // ================================
    // CLUSTER 10: CLINICAL OUTCOMES
    // ================================
    subgraph cluster_clinical {
        label="Clinical Endpoints & Outcomes\n(Efficacy · Safety · Quality of Life)";
        style=filled;
        color="#886600";
        fillcolor="#FFFCE8";
        fontname="Helvetica-Bold";
        fontsize=12;
        fontcolor="#886600";

        SeizFreq [label="Seizure Frequency\n(episodes/28 days, primary endpoint)", fillcolor="#FFEE88", shape=ellipse, penwidth=2.5];
        ILAE_outcome [label="ILAE Outcome Classification\n(Class 1: SF; Class 2–6: freq↓)", fillcolor="#FFDD66"];
        Responder50 [label="≥50% Seizure Reduction\n(Responder — regulatory standard)", fillcolor="#FFDD66"];
        SeizFreedom [label="Seizure Freedom (SF)\n(12-month SF rate — gold standard)", fillcolor="#FFDD66", penwidth=2.0];
        SUDEP [label="SUDEP Risk\n(Sudden Unexpected Death — GTCS↑↑)", fillcolor="#FFB800", penwidth=2.5];
        Cognitive [label="Cognitive Impairment\n(TICS-M, IQ, VPA-induced)", fillcolor="#FFE888"];
        DeprAnx [label="Depression/Anxiety\n(PHQ-9, GAD-7 — comorbidity 30–50%)", fillcolor="#FFE888"];
        VPA_Terato [label="VPA Teratogenicity\n(NTD 2–3%, ASD risk, folic acid)", fillcolor="#FFCC44", penwidth=1.8];
        AED_bone [label="AED-Bone Effects\n(CYP450 VitD catabolism → BMD↓)", fillcolor="#FFEE88"];
        QOLIE89 [label="QoL: QOLIE-89\n(89-item validated scale)", fillcolor="#FFF088"];
        Driving [label="Driving Eligibility\n(6–12 mo seizure-free requirement)", fillcolor="#FFF088"];
        SE_mortality [label="Status Epilepticus\nMortality (10–20%, SRSE >40%)", fillcolor="#FFBB00", penwidth=2.5];
    }

    // =========================================
    // INTER-CLUSTER EDGES
    // =========================================

    // Genetics → Ion Channels
    SCN1A -> Nav11 [label="LOF encodes\n→ interneuron↓", color="#CC2244", style=dashed];
    SCN2A -> Nav12 [label="GOF encodes\n→ axon excit↑", color="#CC2244", style=dashed];
    SCN8A -> Nav16 [label="GOF encodes\n→ AP firing↑", color="#CC2244", style=dashed];
    KCNQ2 -> Kv72 [label="LOF encodes\n→ M-current↓", color="#CC2244", style=dashed];
    KCNQ3 -> Kv73 [label="encodes", color="#CC2244", style=dashed];
    GABRG2 -> GABA_A_g2 [label="LOF encodes\n→ BZD response↓", color="#CC2244", style=dashed];
    GABRA1 -> GABA_A_a1 [label="LOF encodes\n→ IPSP↓", color="#CC2244", style=dashed];
    GABRB3 -> GABA_A [label="LOF encodes\n→ Cl- gating↓", color="#CC2244", style=dashed];
    DEPDC5 -> SeizThresh [label="LOF: mTORC1↑\n→ cortical dysplasia→Θ↓", color="#CC2244"];
    TSC1 -> Everolimus_mTOR [label="TSC pathway\n(tuberin-hamartin complex)", color="#CC2244", style=dotted];
    TSC2 -> Everolimus_mTOR [label="TSC pathway", color="#CC2244", style=dotted];
    CDKL5 -> GABA_A [label="CDKL5 phosphorylates\nGABA-A subunit", color="#CC2244", style=dashed];
    STXBP1 -> VGAT [label="Munc18-1 LOF\n→ vesicle fusion↓", color="#CC2244", style=dashed];

    // Genetics → Network
    SCN1A -> PV_INT [label="Nav1.1 LOF\n→ PV+ interneuron↓", color="#880000", penwidth=1.8];
    SCN2A -> CA1 [label="Nav1.2 GOF\n→ pyramidal excitability↑", color="#880000"];

    // Acquired → Network
    MTS -> MossyFiber [label="hippocampal\nCA1/CA3 scar→sprouting", color="#994400"];
    MTS -> DG [label="granule cell\ndispersion", color="#994400"];
    TBI -> SeizThresh [label="BBB disruption\n→ K+ dysreg→Θ↓", color="#994400", style=dashed];
    FCD -> Ictal [label="dysplastic neurons\n→ focal onset", color="#994400"];
    AE_cause -> NMDA_R [label="Anti-NMDAR Ab\n→ receptor internalization", color="#994400"];
    Febrile -> MTS [label="prolonged febrile→MTS\n(if >30 min)", color="#994400", style=dashed];
    StrokeAcq -> CA1 [label="ischemia →\nCA1 hyperexcitability", color="#994400", style=dashed];
    CNS_Infect -> SeizThresh [label="BBB disruption\n+ neuroinflammation", color="#994400", style=dashed];

    // Ion Channels → GABAergic
    Nav11 -> PV_INT [label="Nav1.1 drives\nPV+ AP firing", color="#1144BB"];
    Nav11 -> GAD65 [label="interneuron drive\n→ GABA synthesis", color="#1144BB", style=dashed];
    Kv72 -> Mcurrent [label="heterotet\nsubunit", color="#1144BB"];
    Kv73 -> Mcurrent [label="heterotet\nsubunit", color="#1144BB"];
    BKchan -> Postictal [label="Ca2+→BK→K+ efflux\n→ repolarization", color="#1144BB", style=dashed];
    SK2chan -> Postictal [label="AHP → burst\ntermination", color="#1144BB", style=dashed];

    // Ion Channels → Network
    Nav12 -> CA1 [label="Nav1.2 axon initial\nsegment excitability", color="#1144BB"];
    Nav16 -> Ictal [label="Nav1.6 node of Ranvier\nAP propagation speed", color="#1144BB"];
    NavPersist -> SeizThresh [label="persistent I_NaP\n→ depolarizing tone→Θ↓", color="#AA0000", penwidth=1.8];
    Mcurrent -> SeizThresh [label="M-current\n→ sub-threshold repolarization↑Θ", color="#116611", penwidth=1.8];
    HCN1 -> ThalamusRelay [label="Ih pacemaker\ncurrent in TC loop", color="#1144BB"];
    HCN2 -> ThalamusRelay [label="Ih thalamic\nburst firing", color="#1144BB"];
    CaT -> ThalamusRelay [label="T-type Ca2+\nburst firing (absence)", color="#1144BB", penwidth=1.8];
    CaN -> VGLUT1 [label="triggers\nGlu vesicle release", color="#1144BB"];

    // GABAergic → Network
    GAD65 -> GABA_A [label="GABA synthesis→\nvesicle fill", color="#116611"];
    GAD67 -> GABA_A [label="GABA synthesis\n(constitutive tone)", color="#116611"];
    VGAT -> GABA_A [label="vesicle\nloading", color="#116611"];
    GABA_A -> Cl_influx [label="receptor opening\n→ Cl- flux", color="#116611", penwidth=2.0];
    GABA_A_a1 -> GABA_A [label="α1 subunit\n(sedative AE)", color="#116611", style=dashed];
    GABA_A_a2 -> GABA_A [label="α2 subunit\n(anxiolytic AE)", color="#116611", style=dashed];
    GABA_A_g2 -> BZD_site [label="γ2 harbors\nBZD binding site", color="#116611", style=dashed];
    BZD_site -> GABA_A [label="allosteric↑\nCl- open frequency", color="#116611", penwidth=1.8];
    GABA_B -> GIRK [label="Gi→βγ→\nGIRK activation", color="#116611"];
    GAT1 -> Cl_influx [label="reuptake terminates\nGABA signal", color="#116611", dir=back, style=dashed];
    Cl_influx -> SeizThresh [label="IPSP\nhyperpolarization↑Θ", color="#116611", penwidth=2.5];
    GIRK -> SeizThresh [label="K+ efflux\nhyperpolarization↑Θ", color="#116611"];
    PV_INT -> GABA_A [label="fast perisomatic\ninhibition (basket/axo-ax)", color="#116611", penwidth=1.8];
    SST_INT -> GABA_B [label="dendritic\nshunting inhibition", color="#116611"];
    Neurosteroid -> GABA_A [label="δ-subunit extrasynaptic\npotentiation", color="#116611"];

    // Glutamatergic → Network
    Gln_Glu -> VGLUT1 [label="Glu substrate\nfor vesicle load", color="#BB5500"];
    VGLUT1 -> NMDA_R [label="Glu vesicle\nrelease (cortex)", color="#BB5500"];
    VGLUT2 -> ThalamusRelay [label="thalamic Glu\nrelease", color="#BB5500"];
    NMDA_R -> Ca_NMDA [label="Ca2+ influx\n(V>-55 mV)", color="#BB5500", penwidth=2.0];
    Mg_block -> NMDA_R [label="voltage-dep Mg2+\nblock at rest", color="#BB5500", dir=none, style=dashed];
    AMPA_R -> Ictal [label="fast EPSP→\nburst initiation", color="#BB5500", penwidth=2.0];
    Ca_NMDA -> SeizThresh [label="excitotoxicity\n+ LTP→Θ↓", color="#BB5500", penwidth=1.8];
    Ca_NMDA -> MTS [label="neuronal loss\n→ MTS formation", color="#BB5500", style=dashed];
    EAAT1 -> NMDA_R [label="Glu reuptake\nlimits activation", color="#BB5500", dir=back];
    EAAT2 -> NMDA_R [label="Glu reuptake\n(~95%)", color="#BB5500", dir=back];
    mGluR1 -> Ca_NMDA [label="IP3→Ca2+\nrelease ER", color="#BB5500"];
    mGluR2 -> VGLUT1 [label="presynaptic\nGlu release↓", color="#BB5500", dir=back];
    Kainate_R -> CA3 [label="CA3 burst\nfacilitation", color="#BB5500"];
    AMPA_traffic -> AMPA_R [label="LTP insertion\nof GluA1", color="#BB5500", style=dashed];

    // Network Dynamics internal
    CA3 -> CA1 [label="Schaffer\ncollaterals", color="#666600", penwidth=1.5];
    CA3 -> CA3 [label="recurrent collaterals\n→ burst amplification", color="#666600", style=dashed];
    DG -> CA3 [label="mossy fibers\n(dentate gating role)", color="#666600"];
    MossyFiber -> CA3 [label="aberrant recurrent\ncircuits (epileptogenic)", color="#666600", penwidth=1.8];
    ThalamusRelay -> CortexL5 [label="TC oscillation\n(3 Hz spike-wave — absence)", color="#666600", penwidth=1.5];
    ThalamusReticular -> ThalamusRelay [label="GABA phasic\ninhibition (burst modulation)", color="#666600"];
    CA1 -> Ictal [label="hippocampal output\n→ seizure propagation", color="#666600", penwidth=1.8];
    Interictal -> Ictal [label="IED → ictal\ntransition (synchrony↑)", color="#996600", style=dashed, penwidth=1.5];
    Ictal -> Synchrony [label="E/I imbalance\ndrives synchrony", color="#880000", penwidth=2.0];
    Synchrony -> SeizThresh [label="positive feedback\nlowers Θ", color="#880000", penwidth=1.8];
    Ictal -> Postictal [label="post-seizure\nGABA surge + ATP↓", color="#666600"];
    Ictal -> SE_early [label="if continuous\n>5 min", color="#990000", penwidth=2.0];
    SE_early -> SE_estab [label="if >30 min\n(BZD tolerance starts)", color="#990000", penwidth=2.0];
    SE_estab -> SE_refrac [label="if >60 min\n(GABA-A internalized)", color="#990000", penwidth=2.5];

    // Drug PK internal
    VPA_gut -> VPA_C [label="ka=1.2/h", color="#551199"];
    VPA_C -> VPA_P [label="Q=0.23 L/h", color="#551199"];
    VPA_P -> VPA_C [label="redistribution", color="#551199", style=dashed];
    VPA_C -> VPA_met [label="CL=0.47 L/h", color="#551199"];
    LEV_gut -> LEV_C [label="ka=1.5/h", color="#551199"];
    LEV_C -> LEV_met [label="CL_renal=3.8 L/h", color="#551199"];
    CBZ_gut -> CBZ_C [label="ka=0.5/h", color="#551199"];
    CBZ_C -> CBZ_E [label="CYP3A4→CBZ-E\n(fm~40%)", color="#551199"];
    CBZ_C -> CBZ_auto [label="self-induces\nCYP3A4", color="#551199"];
    CBZ_auto -> CBZ_C [label="CL↑2× over 2–4 wk\n(autoinduction)", color="#551199", style=dashed];
    LTG_gut -> LTG_C [label="ka=0.8/h", color="#551199"];
    LTG_C -> LTG_UGT [label="CL via\nUGT1A4", color="#551199"];
    DDI_VPA_LTG -> LTG_UGT [label="VPA inhibits\nUGT1A4", color="#AA00AA", penwidth=1.8];
    DDI_CBZ_LTG -> LTG_UGT [label="CBZ induces CYP3A4\n→ LTG CL↑2×", color="#AA00AA", penwidth=1.8];

    // PK → PD
    VPA_C -> VPA_GABAT [label="CNS VPA\n(fu=0.10)", color="#224488", penwidth=1.8];
    VPA_C -> VPA_HDAC [label="epigenetic\neffect", color="#224488"];
    VPA_C -> VPA_NavPD [label="partial Nav\nblock", color="#224488"];
    LEV_C -> LEV_SV2A [label="SV2A\noccupancy", color="#224488", penwidth=1.8];
    LEV_SV2A -> LEV_vesicle [label="slows vesicle\nrefilling kinetics", color="#224488"];
    CBZ_C -> CBZ_Nav [label="use-dependent\nblock", color="#224488", penwidth=2.0];
    CBZ_E -> CBZ_Nav [label="active metabolite\ncontributes", color="#224488", style=dashed];
    LTG_C -> LTG_Nav [label="state-dep block\n+ persistent I_NaP↓", color="#224488", penwidth=2.0];

    // PD → Ion Channels / GABA / Glutamate
    VPA_GABAT -> GAD65 [label="GABA-T↓ → GABA↑\n(increased inhibitory tone)", color="#224488", style=dashed, penwidth=1.8];
    VPA_HDAC -> SCN1A [label="↑Nav1.1 mRNA\n(interneuron rescue)", color="#224488", style=dashed];
    CBZ_Nav -> NavSlowInact [label="enhances slow\ninactivated state", color="#224488", penwidth=1.8];
    LTG_Nav -> NavPersist [label="I_NaP↓\n(sub-threshold stabilization)", color="#224488", penwidth=1.8];
    PHT_Nav -> NavFastInact [label="stabilizes\nfast-inactivated state", color="#224488"];
    LEV_vesicle -> VGLUT1 [label="Glu release↓\n(synaptic vesicle cycling)", color="#224488", style=dashed];
    LEV_vesicle -> VGAT [label="GABA release\nkinetics modulated", color="#224488", style=dashed];
    BZD_GABAA -> BZD_site [label="allosteric\nγ2 binding", color="#224488", penwidth=2.0];
    GBP_Cav -> CaN [label="α2δ-1 subunit\nbinding→Cav2.2↓", color="#224488", penwidth=1.8];
    PER_AMPA -> AMPA_R [label="non-competitive\nAMPA block", color="#224488", penwidth=1.8];
    ETX_CaT -> CaT [label="T-type Ca2+\nblock→TC burst↓", color="#224488", penwidth=1.8];
    Everolimus_mTOR -> DEPDC5 [label="mTORC1 pathway\ndownstream target", color="#224488", style=dotted];
    Fen_5HT2C -> SeizThresh [label="5-HT2C/σ1R\n→Θ↑ (Dravet)", color="#224488", style=dashed];

    // PD → Seizure Threshold
    VPA_GABAT -> SeizThresh [label="GABA↑→Θ↑\n(indirect response)", color="#116611", penwidth=2.5];
    CBZ_Nav -> SeizThresh [label="Nav block→\nmembrane stability↑Θ", color="#1144BB", penwidth=2.5];
    LTG_Nav -> SeizThresh [label="I_NaP↓ + Nav\n→ Θ↑", color="#1144BB", penwidth=2.0];
    BZD_GABAA -> SE_early [label="IV BZD aborts\nearly SE (first-line)", color="#1144BB", penwidth=2.5];
    LEV_vesicle -> Synchrony [label="synchrony↓\n(SV2A mechanism)", color="#1144BB"];
    PER_AMPA -> Ictal [label="AMPA block→\nictal duration↓", color="#1144BB"];

    // Resistance → PK
    Pgp -> BBB_efflux [label="major driver\nof efflux", color="#AA1100", penwidth=2.0];
    MRP2 -> BBB_efflux [label="contributes\n(VPA, CBZ)", color="#AA1100"];
    BCRP -> BBB_efflux [label="contributes\n(LTG, CBZ)", color="#AA1100"];
    BBB_efflux -> VPA_C [label="CNS VPA fraction↓\n(P-gp substrate)", color="#AA1100", style=dashed, penwidth=1.8];
    BBB_efflux -> LEV_C [label="CNS LEV fraction↓", color="#AA1100", style=dashed];
    BBB_efflux -> CBZ_C [label="CNS CBZ↓\n(strong P-gp substrate)", color="#AA1100", style=dashed, penwidth=1.8];
    Nav_resist -> CBZ_Nav [label="altered binding site\n→ CBZ affinity↓", color="#AA1100", style=dashed];
    GABAA_resist -> BZD_GABAA [label="γ2 variant→\nBZD potentiation↓", color="#AA1100", style=dashed];
    NFKB_MDR -> Pgp [label="transcriptional\nupregulation", color="#AA1100", penwidth=1.8];
    Ictal -> NFKB_MDR [label="seizure-driven\nNF-κB activation", color="#AA1100", style=dashed];
    BBB_efflux -> Refrac_def [label="pharmacokinetic\nhypothesis→DRE", color="#AA1100", penwidth=2.0];
    Target_hypo -> Refrac_def [label="target altered\nhypothesis", color="#AA1100", penwidth=1.5];
    PK_hypo -> Refrac_def [label="PK distribution\nhypothesis", color="#AA1100", penwidth=1.5];

    // Network → Clinical
    SeizThresh -> SeizFreq [label="Θ↓ → seizure\nfrequency↑", color="#886600", penwidth=2.5];
    Ictal -> SeizFreq [label="each ictal event\n= +1 episode", color="#886600", penwidth=2.0];
    SeizFreq -> ILAE_outcome [label="ILAE\nclassification", color="#886600", penwidth=1.5];
    SeizFreq -> Responder50 [label="≥50% freq\nreduction", color="#886600", penwidth=1.5];
    Responder50 -> SeizFreedom [label="complete\nsuppression", color="#886600"];
    Refrac_def -> SeizFreedom [label="DRE impairs\nSF rate", color="#AA1100", penwidth=2.0];
    Ictal -> SUDEP [label="nocturnal GTCS\n→ SUDEP risk↑↑", color="#880000", penwidth=2.5];
    SeizFreq -> SUDEP [label="frequency\n∝ SUDEP risk", color="#880000", penwidth=1.8];
    SE_refrac -> SE_mortality [label="super-refractory SE\n→ mortality 10–20%", color="#880000", penwidth=2.5];
    VPA_C -> VPA_Terato [label="1st trimester\nexposure", color="#886600", penwidth=1.8];
    VPA_C -> AED_bone [label="CYP2C9 induces\nVitD catabolism", color="#886600", style=dashed];
    CBZ_C -> AED_bone [label="CYP3A4 induces\nVitD catabolism", color="#886600", style=dashed];
    Cognitive -> QOLIE89 [label="cognitive\ndomain score", color="#886600", style=dashed];
    DeprAnx -> QOLIE89 [label="psychiatric\ndomain score", color="#886600", style=dashed];
    SeizFreedom -> Driving [label="6–12 mo SF\n→ driving eligible", color="#886600", penwidth=1.5];
    SeizFreedom -> QOLIE89 [label="major\ndeterminant↑QoL", color="#886600", penwidth=1.8];
    VPA_C -> Cognitive [label="cognitive side effects\n(attention, IQ, VPA)", color="#886600", style=dashed];
    Refrac_def -> SUDEP [label="DRE→ persistent\nGTCS→SUDEP↑", color="#AA1100", penwidth=1.8];
}
