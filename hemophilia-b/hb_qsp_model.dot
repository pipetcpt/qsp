digraph HemophiliaB_QSP {

graph [rankdir=LR, bgcolor="#1a1a2e", fontcolor=white, fontsize=14, labelloc=t,
       label="Hemophilia B — Comprehensive QSP Mechanistic Map\n(FIX Deficiency · Coagulation Cascade · FIX Replacement · Concizumab/Fitusiran/Marstacimab · AAV Gene Therapy · Inhibitors · Arthropathy · Clinical Endpoints)",
       fontname="Helvetica-Bold", pad=0.5, nodesep=0.3, ranksep=0.8]
node [shape=box, style="filled,rounded", fontname="Helvetica", fontsize=9, margin="0.1,0.05"]
edge [fontname="Helvetica", fontsize=8, color="#aaaaaa"]

// ─── CLUSTER 0: F9 Gene, Hepatic Synthesis & Vitamin K Cycle ───────────────
