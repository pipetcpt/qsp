    Gla_Domain_Carboxyl    [label="Gla Domain\nγ-Carboxylation", fillcolor="#023e8a", fontcolor=white]
    VKORC1_Enzyme          [label="VKORC1\n(Vit K Epoxide Reductase)", fillcolor="#023e8a", fontcolor=white]
    Vitamin_K_Cycle        [label="Vitamin K Cycle", fillcolor="#6a0572", fontcolor=white]
