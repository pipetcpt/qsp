    FIX_Secretion_Plasma   [label="Mature FIX Secretion\ninto Plasma", fillcolor="#6a0572", fontcolor=white]
    FIX_Padua_Variant      [label="FIX-Padua (R338L)\nHyperfunctional Variant", fillcolor="#2b9348", fontcolor=white]
    FIX_Plasma_Level       [label="Plasma FIX:Ag / FIX:C\nLevel (IU/dL)", fillcolor="#e63946", fontcolor=white]
    Severity_Classification [label="Severity: Severe(<1)/\nModerate(1-5)/Mild(>5 IU/dL)", fillcolor="#e63946", fontcolor=white]

    F9_gene_Xq27          -> F9_Missense_Mut
    F9_gene_Xq27          -> F9_Nonsense_Mut
    F9_gene_Xq27          -> F9_Leiden_Variant
    F9_gene_Xq27          -> F9_LargeDeletion
    F9_gene_Xq27          -> Hepatocyte_Synthesis
