    F9_LargeDeletion       [label="Large Deletion/Inversion", fillcolor="#023e8a", fontcolor=white]
    Hepatocyte_Synthesis   [label="Hepatocyte FIX\nSynthesis", fillcolor="#6a0572", fontcolor=white]
