    Carrier_Female_Phenotype -> FIX_Plasma_Level
}

// ─── CLUSTER 11: Long-Term Comorbidity & Historical Legacy Risk ───────────
subgraph cluster_11 {
    label="Long-Term Comorbidity & Historical Legacy Risk"
    color=slateblue
    fontcolor=slateblue
    fontsize=12
    style=rounded

    Chronic_Pain_Opioid      [label="Chronic Pain /\nOpioid Dependence", fillcolor="#023e8a", fontcolor=white]
    Orthopedic_Surgery       [label="Synovectomy /\nJoint Replacement Surgery", fillcolor="#6a0572", fontcolor=white]
    Legacy_Transfusion_Risk  [label="Historical pdFIX\nTransfusion (HIV/HCV Legacy)", fillcolor="#d90429", fontcolor=white]
    Mortality_LifeExpectancy [label="Life Expectancy /\nAge-Adjusted Mortality", fillcolor="#e63946", fontcolor=white]
    Disability_Adjusted_Life [label="Disability-Adjusted\nLife Years (DALY)", fillcolor="#023e8a", fontcolor=white]

    Hemophilic_Arthropathy   -> Chronic_Pain_Opioid
    Hemophilic_Arthropathy   -> Orthopedic_Surgery
    Legacy_Transfusion_Risk  -> Mortality_LifeExpectancy
    Chronic_Pain_Opioid      -> Disability_Adjusted_Life
    HaemAQoL                 -> Mortality_LifeExpectancy [style=dashed]
    Intracranial_Hemorrhage  -> Mortality_LifeExpectancy
}

// ─── CLUSTER 12: Adjunctive & Local Hemostatic Measures ───────────────────
subgraph cluster_12 {
    label="Adjunctive & Local Hemostatic Measures"
    color=lightseagreen
    fontcolor=lightseagreen
    fontsize=12
    style=rounded

    Tranexamic_Acid_Adjunct [label="Tranexamic Acid\n(Antifibrinolytic Adjunct)", fillcolor="#2b9348", fontcolor=white]
    DDAVP_Ineffective       [label="Desmopressin\n(Ineffective in FIX Deficiency)", fillcolor="#6c757d", fontcolor=white]
    RICE_Local_Measures     [label="RICE / Local\nCompression Measures", fillcolor="#2b9348", fontcolor=white]
    Physiotherapy_Rehab     [label="Physiotherapy &\nJoint Rehabilitation", fillcolor="#2b9348", fontcolor=white]

    Tranexamic_Acid_Adjunct  -> Plasmin_Fibrinolysis [style=dashed, label="inhibits"]
    RICE_Local_Measures      -> Spontaneous_Hemarthrosis [style=dashed, label="mitigates"]
    Physiotherapy_Rehab      -> Physical_Activity_Score
    DDAVP_Ineffective        -> FIX_Plasma_Level [style=dashed, label="no effect"]
}

}
