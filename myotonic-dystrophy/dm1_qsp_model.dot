digraph DM1_QSP {
  graph [
    rankdir=LR,
    fontname="Helvetica",
    fontsize=12,
    bgcolor="#F8F9FA",
    splines=curved,
    nodesep=0.25,
    ranksep=0.55,
    label="Myotonic Dystrophy Type 1 (DM1) — Quantitative Systems Pharmacology Map\nCTG Repeat Expansion · MBNL/CUGBP1 Imbalance · Multi-Organ Pathology · Drug PK/PD\n(근긴장성 이영양증 제1형 QSP 기계론적 지도)",
    labelloc=t,
    labeljust=c,
    fontsize=17
  ]
  node [fontname="Helvetica", fontsize=8, style="filled,rounded", shape=box, margin="0.08,0.04"]
  edge [fontname="Helvetica", fontsize=7, arrowsize=0.65]

  // ============================================================
  // CLUSTER 1: GENETIC & MOLECULAR BIOLOGY
  // ============================================================
  subgraph cluster_genetic {
    style=filled; color="#E3F2FD"; label="① 유전·분자 생물학\n(Genetic & Molecular Biology)";
    fontsize=10; fontcolor="#0D47A1"; penwidth=2;

    DMPK_gene       [label="DMPK Gene\n(Chr 19q13.32)", fillcolor="#BBDEFB", color="#1565C0"]
    CTG_normal      [label="Normal CTG Repeat\n(5–37 repeats)", fillcolor="#C8E6C9", color="#2E7D32"]
    CTG_premut      [label="Premutation\n(38–49 repeats)", fillcolor="#FFF9C4", color="#F9A825"]
    CTG_expansion   [label="Pathological CTG\nExpansion (>50→10 000+)", fillcolor="#FFCDD2", color="#B71C1C", shape=diamond]
    Somatic_inst    [label="Somatic Repeat\nInstability\n(tissue-specific)", fillcolor="#FFCDD2", color="#C62828"]
    Anticipation    [label="Genetic Anticipation\n(Intergenerational\nRepeat Expansion)", fillcolor="#EF9A9A", color="#B71C1C"]
    DMPK_mRNA_norm  [label="Normal DMPK mRNA\n(Exported to Cytoplasm)", fillcolor="#C8E6C9", color="#2E7D32"]
    DMPK_mRNA_mut   [label="Mutant DMPK mRNA\n(CUGn Expansion — Nuclear\nRetention)", fillcolor="#EF9A9A", color="#C62828"]
    CUG_hairpin     [label="CUGn RNA Hairpin\nSecondary Structure\n(dsRNA-like)", fillcolor="#EF9A9A", color="#B71C1C"]
    Nuclear_foci    [label="Nuclear RNA Foci\n(Pathological Inclusions\nin Myonuclei)", fillcolor="#EF9A9A", color="#C62828", shape=ellipse]
    DMPK_protein    [label="DMPK Serine-Threonine\nKinase Protein\n(Haploinsufficiency)", fillcolor="#FFF9C4", color="#F9A825"]
    SIX5_expr       [label="SIX5 Gene\n(Reduced Expression)", fillcolor="#FFF9C4", color="#F9A825"]
    CNBP_expr       [label="CNBP/ZNF9\n(Reduced Expression)", fillcolor="#FFF9C4", color="#F9A825"]
  }

  // ============================================================
  // CLUSTER 2: RNA BINDING PROTEINS
  // ============================================================
  subgraph cluster_RBP {
    style=filled; color="#FFF8E1"; label="② RNA 결합 단백질\n(RNA-Binding Proteins)";
    fontsize=10; fontcolor="#E65100"; penwidth=2;

    MBNL1_free      [label="MBNL1 (Free)\nActive Splicing Regulator", fillcolor="#A5D6A7", color="#2E7D32", shape=ellipse]
    MBNL1_seq       [label="MBNL1 Sequestered\n(Trapped in CUG Foci)", fillcolor="#EF9A9A", color="#B71C1C", shape=ellipse]
    MBNL2_free      [label="MBNL2 (Free)\nCNS Splicing Regulator", fillcolor="#A5D6A7", color="#2E7D32", shape=ellipse]
    MBNL2_seq       [label="MBNL2 Sequestered\n(CNS/Eye Foci)", fillcolor="#EF9A9A", color="#B71C1C", shape=ellipse]
    MBNL3_muscle    [label="MBNL3\nMuscle Development", fillcolor="#FFE0B2", color="#E65100", shape=ellipse]
    CUGBP1_basal    [label="CUGBP1/CELF1\n(Basal Level)", fillcolor="#B3E5FC", color="#0277BD", shape=ellipse]
    CUGBP1_hyper    [label="CUGBP1/CELF1\nHyperactivated", fillcolor="#EF9A9A", color="#C62828", shape=ellipse]
    PKC_betaII      [label="PKCβII\n(Activated by CUG RNA)", fillcolor="#FFCDD2", color="#B71C1C"]
    CUGBP1_phospho  [label="CUGBP1 Ser302\nPhosphorylation\n(Stabilized)", fillcolor="#EF9A9A", color="#B71C1C"]
    hnRNP_H1        [label="hnRNP H1\nSplicing Regulator", fillcolor="#FFE0B2", color="#E65100", shape=ellipse]
    RBFOX1          [label="RBFOX1\n(Muscle Splicing)", fillcolor="#FFE0B2", color="#E65100", shape=ellipse]
    STAU1           [label="STAUFEN1\nmRNA Stability\n(DM1-upregulated)", fillcolor="#FFCDD2", color="#B71C1C"]
    DDX6_G3BP1      [label="DDX6 / G3BP1\nStress Granule\nAssembly", fillcolor="#FFE0B2", color="#E65100"]
    UPF1_NMD        [label="UPF1 / NMD Pathway\n(Nonsense-Mediated\nDecay)", fillcolor="#FFE0B2", color="#E65100"]
  }

  // ============================================================
  // CLUSTER 3: ALTERNATIVE SPLICING MISREGULATION
  // ============================================================
  subgraph cluster_splicing {
    style=filled; color="#F3E5F5"; label="③ 이상 선택적 스플라이싱\n(Misregulated Alternative Splicing)";
    fontsize=10; fontcolor="#6A1B9A"; penwidth=2;

    CLCN1_pre       [label="CLCN1 pre-mRNA\n(Chloride Channel)", fillcolor="#CE93D8", color="#6A1B9A"]
    CLCN1_adult     [label="CLCN1 Adult Isoform\n(Functional)", fillcolor="#C8E6C9", color="#2E7D32"]
    CLCN1_fetal     [label="CLCN1 Fetal Isoform\n(Exon 7a Inclusion\n→ PTC / NMD)", fillcolor="#EF9A9A", color="#B71C1C"]
    SERCA1_pre      [label="ATP2A1/SERCA1\npre-mRNA", fillcolor="#CE93D8", color="#6A1B9A"]
    SERCA1_adult    [label="SERCA1a Adult\n(Full Ca²⁺ Pump)", fillcolor="#C8E6C9", color="#2E7D32"]
    SERCA1_fetal    [label="SERCA1b Fetal\n(Reduced Pump\nExon 22 Excl.)", fillcolor="#EF9A9A", color="#B71C1C"]
    INSR_pre        [label="INSR pre-mRNA\n(Insulin Receptor)", fillcolor="#CE93D8", color="#6A1B9A"]
    INSR_adult      [label="INSR-B Adult\n(Full Signaling\nExon 11 +)", fillcolor="#C8E6C9", color="#2E7D32"]
    INSR_fetal      [label="INSR-A Fetal\n(Reduced Signaling\nExon 11 −)", fillcolor="#EF9A9A", color="#B71C1C"]
    TNNT2_pre       [label="TNNT2 pre-mRNA\n(Cardiac Troponin T)", fillcolor="#CE93D8", color="#6A1B9A"]
    TNNT2_fetal     [label="TNNT2 Fetal Isoform\n(Exon 5 Inclusion\nContractile Defect)", fillcolor="#EF9A9A", color="#B71C1C"]
    BIN1_pre        [label="BIN1 pre-mRNA\n(Bridging Integrator 1)", fillcolor="#CE93D8", color="#6A1B9A"]
    BIN1_fetal      [label="BIN1 Fetal Isoform\n(T-Tubule Defect)", fillcolor="#EF9A9A", color="#B71C1C"]
    MAPT_pre        [label="MAPT/Tau pre-mRNA\n(Microtubule-assoc.)", fillcolor="#CE93D8", color="#6A1B9A"]
    MAPT_4R_excess  [label="Tau 4R/3R\nRatio Imbalance\n(Neurofibrillary)", fillcolor="#EF9A9A", color="#B71C1C"]
    APP_pre         [label="APP pre-mRNA\n(Amyloid Precursor)", fillcolor="#CE93D8", color="#6A1B9A"]
    APP_amyloid     [label="APP Amyloidogenic\nProcessing (↑)", fillcolor="#EF9A9A", color="#B71C1C"]
    CAMK2D_pre      [label="CaMKIIδ Exon 16\nAbnormal Inclusion\n(Cardiac)", fillcolor="#CE93D8", color="#6A1B9A"]
    KCNQ1_pre       [label="KCNQ1 Exon 6\nAbnormal Inclusion\n(Cardiac IKs)", fillcolor="#CE93D8", color="#6A1B9A"]
    NF1_pre         [label="NF1 Exon 23a\nAbnormal Inclusion\n(Ras-GAP)", fillcolor="#CE93D8", color="#6A1B9A"]
    DMD_pre         [label="DMD Exon 78\nAbnormal Exclusion\n(Dystrophin)", fillcolor="#CE93D8", color="#6A1B9A"]
  }

  // ============================================================
  // CLUSTER 4: SKELETAL MUSCLE PATHOPHYSIOLOGY
  // ============================================================
  subgraph cluster_muscle {
    style=filled; color="#E8F5E9"; label="④ 골격근 병태생리\n(Skeletal Muscle Pathophysiology)";
    fontsize=10; fontcolor="#1B5E20"; penwidth=2;

    ClC1_protein    [label="ClC-1 Chloride\nChannel Protein\n(Reduced 95%+)", fillcolor="#FFCDD2", color="#C62828"]
    Cl_conductance  [label="Sarcolemmal Cl⁻\nConductance ↓↓", fillcolor="#EF9A9A", color="#B71C1C"]
    Nav1_4          [label="Nav1.4 Sodium\nChannel\n(Persistent Current)", fillcolor="#FFE0B2", color="#E65100"]
    Nav1_4_inactive [label="Nav1.4 Slow\nInactivation Impaired\n(DM1-mutant)", fillcolor="#FFCDD2", color="#B71C1C"]
    Mem_hyperexcit  [label="Sarcolemmal\nMembrane\nHyperexcitability", fillcolor="#EF9A9A", color="#C62828"]
    Myot_discharge  [label="Repetitive AP\nDischarge (EMG)\nMyotonic Run", fillcolor="#EF9A9A", color="#C62828", shape=ellipse]
    Myotonia_clin   [label="Clinical Myotonia\n(Grip Relaxation\nDelay)", fillcolor="#EF9A9A", color="#C62828", shape=diamond]
    Grip_strength   [label="Hand Grip\nStrength (kg)", fillcolor="#FFE0B2", color="#E65100"]
    SERCA_pump      [label="SERCA1 Ca²⁺-ATPase\nPump Activity ↓", fillcolor="#FFCDD2", color="#B71C1C"]
    Ca_dysreg       [label="Intracellular Ca²⁺\nDysregulation\n([Ca²⁺]i ↑)", fillcolor="#EF9A9A", color="#B71C1C"]
    Mito_dysfunc    [label="Mitochondrial\nDysfunction\n(ΔΨm ↓)", fillcolor="#EF9A9A", color="#B71C1C"]
    ROS_muscle      [label="Reactive Oxygen\nSpecies (ROS) ↑", fillcolor="#EF9A9A", color="#B71C1C"]
    Muscle_apoptosis[label="Muscle Cell\nApoptosis/Necrosis", fillcolor="#EF9A9A", color="#C62828"]
    Muscle_atrophy  [label="Progressive Muscle\nAtrophy & Wasting", fillcolor="#FFCDD2", color="#C62828", shape=diamond]
    Satellite_cells [label="Satellite Cell\nDysfunction\n(Regeneration ↓)", fillcolor="#FFCDD2", color="#B71C1C"]
    FoxO3a          [label="FoxO3a\nActivation\n(Atrogene ↑)", fillcolor="#FFCDD2", color="#B71C1C"]
    MuRF1_atrogin   [label="MuRF1 / Atrogin-1\n(E3 Ubiquitin\nLigases)", fillcolor="#FFCDD2", color="#B71C1C"]
    UPS_muscle      [label="Ubiquitin-Proteasome\nSystem Upregulation", fillcolor="#FFCDD2", color="#B71C1C"]
    Autophagy_DM1   [label="Autophagy\nDysregulation\n(LC3-II ↑)", fillcolor="#EF9A9A", color="#B71C1C"]
    PI3K_AKT        [label="PI3K/AKT\nSignaling Impaired", fillcolor="#FFCDD2", color="#B71C1C"]
    mTOR_muscle     [label="mTORC1\nSignaling ↓", fillcolor="#FFCDD2", color="#B71C1C"]
    T_tubule_defect [label="T-Tubule Structure\nDefect (BIN1/DNM2)", fillcolor="#EF9A9A", color="#B71C1C"]
    MIRS_score      [label="MIRS Score\n(1–5 Scale)", fillcolor="#FFAB91", color="#BF360C", shape=diamond]
    Six_MWT         [label="6-Min Walk Test\n(meters)", fillcolor="#FFAB91", color="#BF360C", shape=diamond]
  }

  // ============================================================
  // CLUSTER 5: CARDIAC PATHOPHYSIOLOGY
  // ============================================================
  subgraph cluster_cardiac {
    style=filled; color="#FCE4EC"; label="⑤ 심장 병태생리\n(Cardiac Pathophysiology)";
    fontsize=10; fontcolor="#880E4F"; penwidth=2;

    SCN5A_splice    [label="SCN5A (Nav1.5)\nFetal Isoform\n(Reduced INa)", fillcolor="#F48FB1", color="#880E4F"]
    CAMK2D_card     [label="CaMKIIδ Exon 16+\nHyperactivity\n(SR Ca²⁺ Leak)", fillcolor="#EF9A9A", color="#B71C1C"]
    KCNQ1_splice    [label="KCNQ1 Exon 6+\nIKs Reduction\n(QTc ↑)", fillcolor="#F48FB1", color="#880E4F"]
    TnT_fetal       [label="Cardiac TnT\nFetal Isoform\n(Contractile ↓)", fillcolor="#EF9A9A", color="#B71C1C"]
    AV_conduction   [label="AV Node\nConduction Defect\n(PR ↑)", fillcolor="#FFCDD2", color="#C62828"]
    HisPurkinje     [label="His-Purkinje\nSystem Disease\n(QRS ↑)", fillcolor="#FFCDD2", color="#C62828"]
    PR_interval     [label="PR Interval\n> 200 ms", fillcolor="#EF9A9A", color="#C62828", shape=diamond]
    QRS_duration    [label="QRS Duration\n> 120 ms", fillcolor="#EF9A9A", color="#C62828", shape=diamond]
    QTc_interval    [label="QTc Interval\nProlongation", fillcolor="#EF9A9A", color="#C62828", shape=diamond]
    HV_interval     [label="HV Interval\n> 70 ms\n(High-Risk Marker)", fillcolor="#EF9A9A", color="#C62828", shape=diamond]
    CHB             [label="Complete Heart\nBlock (3rd AV)", fillcolor="#B71C1C", fontcolor="white", shape=diamond]
    VT_VF           [label="Ventricular\nTachycardia/\nFibrillation", fillcolor="#B71C1C", fontcolor="white", shape=diamond]
    AF_DM1          [label="Atrial Fibrillation\n(AF/Flutter 25%)", fillcolor="#F48FB1", color="#880E4F", shape=diamond]
    Sudden_death    [label="Sudden Cardiac\nDeath (30% deaths)", fillcolor="#B71C1C", fontcolor="white", shape=octagon]
    Cardiac_fibrosis[label="Myocardial Fibrosis\n& Fat Infiltration", fillcolor="#EF9A9A", color="#B71C1C"]
    LV_dysfunc      [label="LV Systolic\nDysfunction\n(EF < 50%)", fillcolor="#EF9A9A", color="#C62828", shape=diamond]
    ICD_PM          [label="ICD / Pacemaker\nImplantation", fillcolor="#F48FB1", color="#880E4F", shape=diamond]
    ECG_endpoint    [label="ECG Monitoring\n(Annual / 2-yr)", fillcolor="#FFAB91", color="#BF360C", shape=octagon]
  }

  // ============================================================
  // CLUSTER 6: CNS & COGNITIVE PATHOPHYSIOLOGY
  // ============================================================
  subgraph cluster_cns {
    style=filled; color="#E8EAF6"; label="⑥ 중추신경·인지 병태생리\n(CNS & Cognitive Pathophysiology)";
    fontsize=10; fontcolor="#283593"; penwidth=2;

    MBNL2_CNS       [label="MBNL2 Sequestration\nin CNS Neurons\n(Foci)", fillcolor="#9FA8DA", color="#283593"]
    Tau_4R          [label="4R/3R Tau\nImbalance\n(Neurofibrillary)", fillcolor="#7986CB", color="#283593"]
    APP_process     [label="Amyloidogenic APP\nProcessing\n(Aβ Accumulation)", fillcolor="#7986CB", color="#283593"]
    NMDA_splice     [label="NMDA Receptor\nGluN1 Exon 5\nSplicing Abnormal", fillcolor="#9FA8DA", color="#283593"]
    GABAa_splice    [label="GABAa Receptor\nα1 Subunit Splicing\n(Abnormal)", fillcolor="#9FA8DA", color="#283593"]
    White_matter    [label="White Matter\nLesions\n(MRI Hyperintensity)", fillcolor="#7986CB", color="#283593"]
    Cortical_atrophy[label="Cortical Atrophy\n(Temporal/Frontal\nLobes)", fillcolor="#7986CB", color="#283593"]
    Executive_defic [label="Executive Function\nImpairment", fillcolor="#FFCDD2", color="#C62828", shape=diamond]
    Memory_defic    [label="Memory / Learning\nDeficits", fillcolor="#FFCDD2", color="#C62828", shape=diamond]
    INI_brief       [label="INI-Brief / Cognitive\nScore", fillcolor="#FFAB91", color="#BF360C", shape=octagon]
    Hypersomnia_DM1 [label="Excessive Daytime\nSleepiness (EDS)\nEpworth ≥ 10", fillcolor="#EF9A9A", color="#C62828", shape=diamond]
    Orexin_low      [label="Orexin/Hypocretin\nReduction\n(Hypothalamic)", fillcolor="#9FA8DA", color="#283593"]
    Sleep_apnea_CNS [label="Central Sleep\nApnea Component", fillcolor="#EF9A9A", color="#B71C1C"]
    Depression_DM1  [label="Depression &\nAnxiety\n(~70% prevalence)", fillcolor="#EF9A9A", color="#B71C1C", shape=diamond]
    Personality_DM1 [label="Personality Changes\n(Avoidant / Obsessive)", fillcolor="#EF9A9A", color="#B71C1C"]
    APOE4_mod       [label="APOE4 Genotype\n(Cognitive Risk\nModifier)", fillcolor="#C5CAE9", color="#283593"]
    Cerebral_hypoper[label="Cerebral\nHypoperfusion\n(SPECT/PET)", fillcolor="#7986CB", color="#283593"]
  }

  // ============================================================
  // CLUSTER 7: ENDOCRINE & METABOLIC
  // ============================================================
  subgraph cluster_endocrine {
    style=filled; color="#FFF3E0"; label="⑦ 내분비·대사 및 기타 전신\n(Endocrine, Metabolic & Systemic)";
    fontsize=10; fontcolor="#E65100"; penwidth=2;

    INSR_signal     [label="Insulin Receptor\nSignaling Impaired\n(INSR-A dominant)", fillcolor="#EF9A9A", color="#B71C1C"]
    IRS1_serine     [label="IRS-1 Serine\nPhosphorylation\n(Inhibitory)", fillcolor="#FFCDD2", color="#B71C1C"]
    GLUT4_DM1       [label="GLUT4 Translocation\nImpaired", fillcolor="#EF9A9A", color="#B71C1C"]
    Glucose_uptake  [label="Skeletal Muscle\nGlucose Uptake ↓", fillcolor="#EF9A9A", color="#B71C1C"]
    Insulin_resist  [label="Peripheral Insulin\nResistance (HOMA-IR ↑)", fillcolor="#EF9A9A", color="#C62828", shape=diamond]
    Hyperinsulin    [label="Compensatory\nHyperinsulinemia", fillcolor="#FFCDD2", color="#B71C1C"]
    T2DM_risk       [label="Type 2 Diabetes\n(Risk ×3 vs General)", fillcolor="#EF9A9A", color="#C62828", shape=diamond]
    HbA1c_DM1       [label="HbA1c Level\n(Metabolic Endpoint)", fillcolor="#FFAB91", color="#BF360C", shape=octagon]
    Testicular_atr  [label="Testicular Atrophy\n(Hypogonadism)", fillcolor="#FFCDD2", color="#B71C1C"]
    Testosterone_low[label="Testosterone ↓\n(Primary / Mixed)", fillcolor="#FFCDD2", color="#B71C1C"]
    FSH_elevated    [label="FSH / LH ↑\n(HPG Axis Disrupted)", fillcolor="#FFCDD2", color="#B71C1C"]
    Thyroid_DM1     [label="Hypothyroid\nTendency (TSH ↑)", fillcolor="#FFE0B2", color="#E65100"]
    GI_dysmotil     [label="GI Dysmotility\n(Pseudo-obstruction\nConstipation)", fillcolor="#FFCDD2", color="#B71C1C"]
    Dysphagia_DM1   [label="Dysphagia\n(Pharyngeal ↓)", fillcolor="#FFCDD2", color="#B71C1C", shape=diamond]
    Cataracts_DM1   [label="Posterior Subcapsular\nCataracts\n(MBNL1/2 ↓)", fillcolor="#FFCDD2", color="#B71C1C", shape=diamond]
    Resp_muscle_wk  [label="Respiratory Muscle\nWeakness\n(Diaphragm/IC)", fillcolor="#EF9A9A", color="#B71C1C"]
    Alv_hypoventi   [label="Alveolar\nHypoventilation\n(PCO₂ ↑)", fillcolor="#EF9A9A", color="#C62828"]
    Resp_failure    [label="Respiratory Failure\n(FVC < 50%\n→ Ventilator)", fillcolor="#B71C1C", fontcolor="white", shape=diamond]
    Maternal_congDM1[label="Congenital DM1\n(Maternal Trans-\nmission Risk)", fillcolor="#FFCDD2", color="#C62828"]
  }

  // ============================================================
  // CLUSTER 8: DRUG PHARMACOKINETICS
  // ============================================================
  subgraph cluster_pk {
    style=filled; color="#E0F7FA"; label="⑧ 약물 약동학\n(Drug Pharmacokinetics)";
    fontsize=10; fontcolor="#006064"; penwidth=2;

    Mex_dose        [label="Mexiletine\nOral Dose (mg TID)", fillcolor="#80DEEA", color="#006064", shape=component]
    Mex_gut         [label="Mexiletine\nGut Compartment\n(Ka = 1.2 h⁻¹)", fillcolor="#80DEEA", color="#006064"]
    Mex_central     [label="Mexiletine\nCentral (Plasma)\nVc = 65 L", fillcolor="#4DD0E1", color="#006064"]
    Mex_periph      [label="Mexiletine\nPeripheral (Tissue)\nVp = 195 L", fillcolor="#00BCD4", color="#006064"]
    Mex_CYP2D6      [label="CYP2D6 Hepatic\nMetabolism (PM → 3×\nExposure ↑)", fillcolor="#B2EBF2", color="#006064"]
    Mex_CYP1A2      [label="CYP1A2 Metabolism\n(Inducible by\nOmeprazole etc.)", fillcolor="#B2EBF2", color="#006064"]
    Mex_renal       [label="Renal Elimination\n(~9% Unchanged)", fillcolor="#B2EBF2", color="#006064"]
    Mex_Cp          [label="Mexiletine Cp\n(Free Plasma, μM)\ntarget 3–10 μM", fillcolor="#00BCD4", color="#006064"]

    ASO_dose_sc     [label="ASO / DYNE-101\nSubQ Dose (mg)", fillcolor="#80CBC4", color="#00695C", shape=component]
    ASO_plasma      [label="ASO Plasma\nConc. (μg/mL)", fillcolor="#80CBC4", color="#00695C"]
    ASO_muscle_tiss [label="ASO Muscle\nTissue Conc.\n(t½ ~2–4 wk)", fillcolor="#26A69A", color="#00695C"]
    ASO_nucleus     [label="ASO Nuclear\nConc. (Active)", fillcolor="#00897B", color="#00695C", fontcolor="white"]

    AOC1001_dose    [label="AOC 1001\n(Ab-Oligo Conjugate\nIV Dose)", fillcolor="#80CBC4", color="#00695C", shape=component]
    DMPK2_dose      [label="Ionis-DMPK-2.5Rx\n(ISIS 598769\nSC Dose)", fillcolor="#80CBC4", color="#00695C", shape=component]
    AAV_MBNL1       [label="AAV-MBNL1\nGene Therapy\n(Intramuscular)", fillcolor="#A5D6A7", color="#1B5E20", shape=component]
    mRNA_LNP        [label="MBNL1 mRNA-LNP\nTherapy (Emerging)", fillcolor="#A5D6A7", color="#1B5E20", shape=component]
  }

  // ============================================================
  // CLUSTER 9: DRUG PHARMACODYNAMICS / TARGETS
  // ============================================================
  subgraph cluster_pd {
    style=filled; color="#F1F8E9"; label="⑨ 약물 약력학·표적\n(Drug Pharmacodynamics & Targets)";
    fontsize=10; fontcolor="#33691E"; penwidth=2;

    Nav1_4_block    [label="Nav1.4 Blockade\nby Mexiletine\nIC₅₀ ~3 μM (muscle)", fillcolor="#DCEDC8", color="#33691E"]
    Nav1_5_block    [label="Nav1.5 (Cardiac)\nBlockade — Side Effect\n(Monitor QRS/QTc)", fillcolor="#FFCDD2", color="#B71C1C"]
    Myot_reduction  [label="Myotonia Reduction\n(VAS −2.6 pt\nMELT 2018)", fillcolor="#C8E6C9", color="#2E7D32"]
    QTc_mex         [label="QTc Shortening\nClass Ib Antiarrhythmic\n(−10 to −20 ms)", fillcolor="#C8E6C9", color="#2E7D32"]
    CUG_degradation [label="CUG RNA Foci\nDegradation (RNase H)\nby DMPK ASO", fillcolor="#DCEDC8", color="#33691E"]
    MBNL1_release   [label="MBNL1 Liberation\nfrom Foci\n(ASO-mediated)", fillcolor="#A5D6A7", color="#2E7D32"]
    Splicing_rescue [label="Splicing Rescue\nCLCN1 / INSR /\nSERCA1 / MAPT", fillcolor="#C8E6C9", color="#2E7D32"]
    PKC_inhibit     [label="PKCβII Inhibition\n→ CUGBP1\nDephosphorylation", fillcolor="#DCEDC8", color="#33691E"]
    CUGBP1_norm     [label="CUGBP1 Level\nNormalization", fillcolor="#C8E6C9", color="#2E7D32"]
    MBNL1_restore   [label="MBNL1 Protein\nRestoration\n(Gene Therapy)", fillcolor="#A5D6A7", color="#2E7D32"]
