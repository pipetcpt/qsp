digraph VEXAS_QSP {
  graph [rankdir=LR, splines=spline, overlap=false, fontname="Helvetica",
         label="VEXAS Syndrome QSP Map — UBA1 somatic mutation · myeloid-restricted autoinflammation · cytopenias",
         labelloc="t", fontsize=22, nodesep=0.45, ranksep=0.8, bgcolor="white"];
  node  [shape=box, style="rounded,filled", fontname="Helvetica", fontsize=11, color="#333333"];
  edge  [fontname="Helvetica", fontsize=9, color="#666666"];

  // ============ 1) Germline & Somatic Genetics ============
  subgraph cluster_genetics {
    label="1) Genetics & HSC Mosaicism"; style="rounded,filled"; fillcolor="#FFF2CC"; color="#7F6000";
    UBA1_WT       [label="UBA1 (Xp11.23)\nE1 ubiquitin-activating enzyme", fillcolor="#FFF8E1"];
    UBA1a_iso     [label="UBA1a (nuclear)\nNLS+ · 117 kDa", fillcolor="#FFFDE7"];
    UBA1b_iso     [label="UBA1b (cytosolic)\nMet41 start · 110 kDa", fillcolor="#FFFDE7"];
    Met41_codon   [label="Codon 41 (Met)\nalternative start site", fillcolor="#FFFDE7"];
    M41T          [label="p.Met41Thr\n(~50% cases)", fillcolor="#FFE0B2"];
    M41V          [label="p.Met41Val\n(severe phenotype)", fillcolor="#FFE0B2"];
    M41L          [label="p.Met41Leu", fillcolor="#FFE0B2"];
    splice_var    [label="Splice/non-Met41\nUBA1 variants", fillcolor="#FFE0B2"];
    HSC_clone     [label="HSC somatic mosaicism\n(myeloid-restricted)", fillcolor="#FFD180"];
    XLR_male      [label="X-linked recessive\n>95% male", fillcolor="#FFD180"];
    VAF           [label="Variant allele fraction\n(VAF 30–90% in monocytes)", fillcolor="#FFD180"];
    age_onset     [label="Onset >50 yr\nclonal expansion", fillcolor="#FFD180"];

    UBA1_WT -> UBA1a_iso [label="exon 3 ATG"];
    UBA1_WT -> Met41_codon -> UBA1b_iso [label="cytosolic isoform"];
    M41T -> UBA1b_iso [label="loss"]; M41V -> UBA1b_iso [label="loss"]; M41L -> UBA1b_iso [label="loss"];
    splice_var -> UBA1b_iso [label="loss"];
    HSC_clone -> M41T; HSC_clone -> M41V; HSC_clone -> M41L; HSC_clone -> splice_var;
    XLR_male -> HSC_clone; VAF -> HSC_clone; age_onset -> HSC_clone;
  }

  // ============ 2) Ubiquitin Proteostasis ============
  subgraph cluster_ubq {
    label="2) Ubiquitin-Proteasome Dysfunction"; style="rounded,filled"; fillcolor="#E1F5FE"; color="#01579B";
    Ub_pool      [label="Free ubiquitin pool", fillcolor="#E1F5FE"];
    Ub_activated [label="Ub-AMP / Ub~UBA1\n(activated ubiquitin)", fillcolor="#E1F5FE"];
    E2_charged   [label="E2 conjugating enzymes\nUbcH7, UbcH5", fillcolor="#E1F5FE"];
    E3_ligases   [label="E3 ligases\n(SCF, RING, HECT)", fillcolor="#E1F5FE"];
    polyUb       [label="K48/K63 polyubiquitin chains", fillcolor="#E1F5FE"];
    proteasome   [label="26S proteasome", fillcolor="#E1F5FE"];
    autophagy    [label="Selective autophagy\n(p62/NBR1)", fillcolor="#E1F5FE"];
    misfold      [label="Misfolded protein\naccumulation", fillcolor="#B3E5FC"];
    aggresome    [label="Aggresomes /\nintracytoplasmic inclusions", fillcolor="#B3E5FC"];

    UBA1b_iso -> Ub_activated [label="ATP-dep activation"];
    Ub_activated -> E2_charged -> E3_ligases -> polyUb -> proteasome;
    polyUb -> autophagy;
    Ub_pool -> Ub_activated;
    proteasome -> misfold [label="↓ clearance", style=dashed, color="#D32F2F"];
    misfold -> aggresome;
  }

  // ============ 3) ER Stress / UPR ============
  subgraph cluster_upr {
    label="3) ER Stress & UPR"; style="rounded,filled"; fillcolor="#FFEBEE"; color="#B71C1C";
    BiP_GRP78    [label="BiP/GRP78", fillcolor="#FFCDD2"];
    PERK         [label="PERK", fillcolor="#FFCDD2"];
    IRE1a        [label="IRE1α", fillcolor="#FFCDD2"];
    ATF6         [label="ATF6", fillcolor="#FFCDD2"];
    eIF2a_P      [label="phospho-eIF2α\n(global translation ↓)", fillcolor="#FFCDD2"];
    ATF4         [label="ATF4", fillcolor="#FFCDD2"];
    CHOP         [label="CHOP / GADD153\n(apoptotic)", fillcolor="#FFCDD2"];
    XBP1s        [label="XBP1s\n(ER expansion, ERAD)", fillcolor="#FFCDD2"];
    JNK_p38      [label="JNK / p38 MAPK", fillcolor="#FFCDD2"];

    misfold -> BiP_GRP78 -> PERK; BiP_GRP78 -> IRE1a; BiP_GRP78 -> ATF6;
    PERK -> eIF2a_P -> ATF4 -> CHOP;
    IRE1a -> XBP1s; IRE1a -> JNK_p38;
    ATF6 -> XBP1s;
  }

  // ============ 4) Mitochondrial Dysfunction & ROS ============
  subgraph cluster_mito {
    label="4) Mitochondrial Stress & ROS"; style="rounded,filled"; fillcolor="#FFF3E0"; color="#E65100";
    mito_dysfn   [label="Mitochondrial dysfunction\n(ΔΨm collapse)", fillcolor="#FFE0B2"];
    ROS          [label="Reactive oxygen species\n(mtROS, NOX-ROS)", fillcolor="#FFE0B2"];
    mtDNA_leak   [label="mtDNA cytosolic leak", fillcolor="#FFE0B2"];
    cGAS_STING   [label="cGAS–STING axis", fillcolor="#FFE0B2"];
    cardiolipin  [label="Oxidized cardiolipin\n(NLRP3 trigger)", fillcolor="#FFE0B2"];
    mitophagy    [label="Defective mitophagy", fillcolor="#FFE0B2"];

    misfold -> mito_dysfn -> ROS; mito_dysfn -> mtDNA_leak -> cGAS_STING;
    mito_dysfn -> cardiolipin; misfold -> mitophagy;
  }

  // ============ 5) Innate Immune Activation ============
  subgraph cluster_innate {
    label="5) Innate Inflammation"; style="rounded,filled"; fillcolor="#E8F5E9"; color="#1B5E20";
    NFkB         [label="NF-κB (p65 / p50)", fillcolor="#C8E6C9"];
    NLRP3        [label="NLRP3 inflammasome", fillcolor="#C8E6C9"];
    AIM2         [label="AIM2 inflammasome", fillcolor="#C8E6C9"];
    Casp1        [label="Caspase-1", fillcolor="#C8E6C9"];
    GSDMD        [label="Gasdermin D pores\n(pyroptosis)", fillcolor="#C8E6C9"];
    IL1b         [label="IL-1β", fillcolor="#A5D6A7"];
    IL18         [label="IL-18", fillcolor="#A5D6A7"];
    IL6          [label="IL-6", fillcolor="#A5D6A7"];
    IL8_CXCL8    [label="IL-8 / CXCL8", fillcolor="#A5D6A7"];
    TNFa         [label="TNF-α", fillcolor="#A5D6A7"];
    IFN_I        [label="Type I IFN\n(IFN-α/β)", fillcolor="#A5D6A7"];
    IFN_sig      [label="Interferon signature\n(IFI27, IFIT3, SIGLEC1)", fillcolor="#A5D6A7"];
    JAK_STAT     [label="JAK1/2 – STAT1/3", fillcolor="#A5D6A7"];
    CCL2_MCP1    [label="CCL2 / MCP-1", fillcolor="#A5D6A7"];
    CRP          [label="CRP / SAA\n(acute-phase)", fillcolor="#81C784"];
    ferritin     [label="Hyperferritinemia\n(>500–10,000 ng/mL)", fillcolor="#81C784"];

    XBP1s -> NFkB; JNK_p38 -> NFkB; ROS -> NLRP3; cardiolipin -> NLRP3;
    cGAS_STING -> IFN_I; mtDNA_leak -> AIM2;
    NLRP3 -> Casp1 -> GSDMD;
    Casp1 -> IL1b; Casp1 -> IL18;
    NFkB -> IL6; NFkB -> TNFa; NFkB -> IL8_CXCL8; NFkB -> CCL2_MCP1;
    IFN_I -> JAK_STAT -> IFN_sig;
    IL6 -> CRP; IL6 -> ferritin; IL1b -> CRP;
  }

  // ============ 6) Hematopoiesis & Vacuolation ============
  subgraph cluster_heme {
    label="6) Bone Marrow & Cytopenias"; style="rounded,filled"; fillcolor="#F3E5F5"; color="#4A148C";
    BM_HSC       [label="Bone marrow HSC", fillcolor="#E1BEE7"];
    myeloid_lin  [label="Myeloid lineage\n(CMP→GMP→neutrophil/mono)", fillcolor="#E1BEE7"];
    erythroid    [label="Erythroid lineage", fillcolor="#E1BEE7"];
    megakaryo    [label="Megakaryocyte", fillcolor="#E1BEE7"];
    vacuoles     [label="Cytoplasmic vacuoles\n(myeloid/erythroid precursors)", fillcolor="#CE93D8"];
    dyserythro   [label="Dyserythropoiesis\nineffective erythropoiesis", fillcolor="#CE93D8"];
    macrocytic   [label="Macrocytic anemia\nHb < 10 g/dL, MCV >100 fL", fillcolor="#BA68C8"];
    thrombocyto  [label="Thrombocytopenia\nPLT < 100×10⁹/L", fillcolor="#BA68C8"];
    neutroph     [label="Neutropenia or\nactivated neutrophilia", fillcolor="#BA68C8"];
    lymphocyto   [label="Lymphopenia", fillcolor="#BA68C8"];
    MDS_overlap  [label="MDS overlap\n(SF3B1 co-mutation 14–53%)", fillcolor="#9C27B0", fontcolor="white"];
    AML_risk     [label="Risk of AML/MDS progression", fillcolor="#9C27B0", fontcolor="white"];
    PNH_overlap  [label="PNH clone overlap\n(rare)", fillcolor="#CE93D8"];

    HSC_clone -> BM_HSC -> myeloid_lin; BM_HSC -> erythroid; BM_HSC -> megakaryo;
    misfold -> vacuoles; ROS -> vacuoles;
    erythroid -> dyserythro -> macrocytic;
    megakaryo -> thrombocyto; myeloid_lin -> neutroph; myeloid_lin -> lymphocyto;
    BM_HSC -> MDS_overlap -> AML_risk;
    BM_HSC -> PNH_overlap;
  }

  // ============ 7) Clinical Manifestations ============
  subgraph cluster_clinical {
    label="7) Multisystem Clinical Phenotype"; style="rounded,filled"; fillcolor="#FCE4EC"; color="#880E4F";
    fever        [label="Recurrent fevers\n>38.5°C", fillcolor="#F8BBD0"];
    fatigue      [label="Profound fatigue", fillcolor="#F8BBD0"];
    skin_neut    [label="Neutrophilic dermatosis\nSweet/PG-like", fillcolor="#F48FB1"];
    chondritis   [label="Auricular/nasal chondritis\n(RP-like)", fillcolor="#F48FB1"];
    polychond    [label="Relapsing polychondritis phenocopy", fillcolor="#F48FB1"];
    lung_infilt  [label="Pulmonary infiltrates /\norganizing pneumonia", fillcolor="#F48FB1"];
    pleuritis    [label="Pleuritis / pericarditis", fillcolor="#F48FB1"];
    arthritis    [label="Inflammatory arthritis\noligo- or polyarticular", fillcolor="#F48FB1"];
    vasculitis   [label="Cutaneous / medium-vessel\nvasculitis", fillcolor="#F48FB1"];
    PAN_like     [label="PAN-like vasculitis", fillcolor="#F48FB1"];
    orbital      [label="Orbital inflammation /\nepiscleritis", fillcolor="#F48FB1"];
    VTE          [label="Venous thromboembolism\n(DVT/PE)", fillcolor="#EC407A", fontcolor="white"];
    HLH_like     [label="HLH-like\nhyperinflammatory crisis", fillcolor="#EC407A", fontcolor="white"];
    GI           [label="GI manifestations\nileitis/colitis", fillcolor="#F48FB1"];
    weight_loss  [label="Weight loss", fillcolor="#F8BBD0"];

    IL6 -> fever; IL1b -> fever; TNFa -> fever; IL6 -> fatigue;
    IL8_CXCL8 -> skin_neut; IL1b -> skin_neut;
    NFkB -> chondritis; chondritis -> polychond;
    CCL2_MCP1 -> lung_infilt; IL6 -> lung_infilt;
    IL1b -> arthritis;
    NFkB -> vasculitis -> PAN_like;
    IL6 -> orbital;
    IL6 -> VTE [label="endothelial inflammation"];
    ferritin -> HLH_like;
    NFkB -> GI;
    TNFa -> weight_loss;
  }

  // ============ 8) Diagnostic Workup & Scores ============
  subgraph cluster_dx {
    label="8) Diagnostics & Severity"; style="rounded,filled"; fillcolor="#E0F2F1"; color="#004D40";
    BM_bx        [label="Bone marrow biopsy\nvacuoles in precursors", fillcolor="#B2DFDB"];
    UBA1_seq     [label="UBA1 gene sequencing\n(NGS/ddPCR)", fillcolor="#B2DFDB"];
    flow_cyto    [label="Flow cytometry\n(monocyte clonality)", fillcolor="#B2DFDB"];
    ESR_CRP      [label="ESR, CRP markedly ↑", fillcolor="#B2DFDB"];
    cytokine_p   [label="Cytokine panel\nIL-6, IL-1β, TNF-α, IFN-γ", fillcolor="#B2DFDB"];
    IFN_score    [label="Interferon score", fillcolor="#B2DFDB"];
    VEXAS_score  [label="VEXAS severity score\n(2024 consortium)", fillcolor="#B2DFDB"];
    HCT_CI       [label="HCT-CI index", fillcolor="#B2DFDB"];

    BM_HSC -> BM_bx; UBA1_WT -> UBA1_seq; myeloid_lin -> flow_cyto;
    CRP -> ESR_CRP; IL6 -> cytokine_p; IFN_sig -> IFN_score;
    VEXAS_score -> HCT_CI;
  }

  // ============ 9) Pharmacology – Drug PK/PD ============
  subgraph cluster_drugs {
    label="9) Pharmacology — PK/PD"; style="rounded,filled"; fillcolor="#EDE7F6"; color="#311B92";
    GC_drug      [label="Glucocorticoids\n(prednisone)", fillcolor="#D1C4E9"];
    GR           [label="Glucocorticoid receptor\n(transrepression of NFκB)", fillcolor="#D1C4E9"];
    Toci         [label="Tocilizumab\nanti-IL-6R mAb", fillcolor="#D1C4E9"];
    Sariluma     [label="Sarilumab\nanti-IL-6R", fillcolor="#D1C4E9"];
    Anakinra     [label="Anakinra\nIL-1Ra (rhIL-1RA)", fillcolor="#D1C4E9"];
    Canakin      [label="Canakinumab\nanti-IL-1β mAb", fillcolor="#D1C4E9"];
    Rilonacept   [label="Rilonacept\nIL-1 trap", fillcolor="#D1C4E9"];
    Ruxo         [label="Ruxolitinib\nJAK1/2 inhibitor", fillcolor="#D1C4E9"];
    Tofa         [label="Tofacitinib / upadacitinib\nJAK1(/3) inhibitor", fillcolor="#D1C4E9"];
    Aza          [label="Azacitidine\nhypomethylating agent", fillcolor="#D1C4E9"];
    HSCT         [label="Allogeneic HSCT\n(curative)", fillcolor="#9575CD", fontcolor="white"];
    TNFi         [label="TNF inhibitors\n(less effective)", fillcolor="#D1C4E9"];
    Coloch       [label="Colchicine\ntubulin/NLRP3 modulator", fillcolor="#D1C4E9"];
    IVIG_d       [label="IVIG (anecdotal)", fillcolor="#D1C4E9"];
    Rituximab    [label="Rituximab (anti-CD20)\nadjunct for B-cell driven sx", fillcolor="#D1C4E9"];
    Anticoag     [label="Anticoagulation\nDOAC/LMWH for VTE", fillcolor="#D1C4E9"];

    GC_drug -> GR -> NFkB [label="⊣"];
    Toci -> IL6 [label="⊣ (IL-6R block)"];
    Sariluma -> IL6 [label="⊣"];
    Anakinra -> IL1b [label="⊣ IL-1R1"];
    Canakin -> IL1b [label="⊣"];
    Rilonacept -> IL1b [label="⊣"];
    Ruxo -> JAK_STAT [label="⊣"];
    Tofa -> JAK_STAT [label="⊣"];
    Aza -> BM_HSC [label="⊣ clone fitness"];
    HSCT -> HSC_clone [label="replace"];
    TNFi -> TNFa [label="⊣ partial"];
    Coloch -> NLRP3 [label="⊣"];
    Rituximab -> NFkB [label="indirect"];
    Anticoag -> VTE [label="⊣"];
  }

  // ============ 10) Steroid Toxicity / Comorbidity ============
  subgraph cluster_tox {
    label="10) Toxicity & Comorbidities"; style="rounded,filled"; fillcolor="#FFEBE6"; color="#BF360C";
    GIO          [label="Glucocorticoid-induced\nosteoporosis", fillcolor="#FFCCBC"];
    GI_bleed     [label="GI bleeding /\npeptic ulcer", fillcolor="#FFCCBC"];
    DM_steroid   [label="Steroid-induced DM", fillcolor="#FFCCBC"];
    HTN          [label="Hypertension", fillcolor="#FFCCBC"];
    infection    [label="Opportunistic infection\n(PJP, HSV, CMV)", fillcolor="#FFCCBC"];
    diverticul   [label="Diverticulitis\n(IL-6 blockade risk)", fillcolor="#FFCCBC"];
    hep_tox      [label="Hepatotoxicity\n(tocilizumab/JAKi)", fillcolor="#FFCCBC"];
    transf       [label="Chronic transfusion need\n(iron overload)", fillcolor="#FFCCBC"];
    cardio_event [label="Cardiovascular events", fillcolor="#FFCCBC"];

    GC_drug -> GIO; GC_drug -> GI_bleed; GC_drug -> DM_steroid; GC_drug -> HTN; GC_drug -> infection;
    Toci -> diverticul; Toci -> hep_tox; Ruxo -> infection;
    macrocytic -> transf;
    NFkB -> cardio_event; VTE -> cardio_event;
  }

  // ============ 11) Clinical Endpoints / Outcomes ============
  subgraph cluster_endpoints {
    label="11) Outcomes & Endpoints"; style="rounded,filled"; fillcolor="#E3F2FD"; color="#0D47A1";
    pred_dose    [label="Daily prednisone-eq dose\n(mg/d) [primary efficacy]", fillcolor="#BBDEFB"];
    HBeq         [label="Hb (g/dL)", fillcolor="#BBDEFB"];
    PLT_count    [label="Platelet count (×10⁹/L)", fillcolor="#BBDEFB"];
    CRP_end      [label="Serum CRP (mg/L)", fillcolor="#BBDEFB"];
    VAS_global   [label="Patient global VAS", fillcolor="#BBDEFB"];
    days_fever   [label="Days with fever / month", fillcolor="#BBDEFB"];
    OS_5yr       [label="5-yr overall survival\n(~50–60%)", fillcolor="#BBDEFB"];
    flare_free   [label="Flare-free survival", fillcolor="#BBDEFB"];
    QoL_SF36     [label="SF-36 / EQ-5D QoL", fillcolor="#BBDEFB"];
    VAF_decline  [label="UBA1 VAF dynamics", fillcolor="#BBDEFB"];
    transf_indep [label="Transfusion independence", fillcolor="#BBDEFB"];

    pred_dose -> OS_5yr [label="↓ at high dose"];
    CRP_end -> flare_free;
    HBeq -> transf_indep;
    VAF_decline -> OS_5yr;
    VAS_global -> QoL_SF36;
  }

  // ============ Cross-cluster integration ============
  ferritin -> HLH_like; macrocytic -> fatigue; thrombocyto -> VTE [style=dotted, label="paradoxical"];
  IL6 -> JAK_STAT [label="trans-signaling"];
  VAF -> VAF_decline; HSCT -> VAF_decline;
  Aza -> VAF_decline;
  Ruxo -> IFN_sig [label="⊣"];
  vacuoles -> BM_bx [label="dx feature"];
}
