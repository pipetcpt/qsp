digraph T1DM_QSP {
  graph [
    label="Type 1 Diabetes Mellitus — Comprehensive QSP Mechanistic Map\nAutoimmune Beta-Cell Destruction · Glucose Homeostasis · Insulin PK/PD · Closed-Loop Therapy · Immunotherapy"
    labelloc=t fontsize=22 fontname="Helvetica-Bold"
    bgcolor="#f8f9fa" rankdir=TB splines=ortho
    nodesep=0.4 ranksep=0.6
  ]
  node [fontname="Helvetica" fontsize=10 style="filled,rounded" shape=box]
  edge [fontname="Helvetica" fontsize=9 arrowsize=0.7]

  /* ═══════════════════════════════════════════════════════════════
     CLUSTER 1: GENETIC & ENVIRONMENTAL SUSCEPTIBILITY
     ═══════════════════════════════════════════════════════════════ */
  subgraph cluster_genetics {
    label="Genetic & Environmental Susceptibility"
    style="filled,rounded" bgcolor="#E8F4FD" color="#2196F3" penwidth=2
    fontname="Helvetica-Bold" fontsize=13

    HLA_DR3  [label="HLA-DR3\n(DQ2)" fillcolor="#AED6F1" shape=ellipse]
    HLA_DR4  [label="HLA-DR4\n(DQ8)" fillcolor="#AED6F1" shape=ellipse]
    PTPN22   [label="PTPN22\nR620W" fillcolor="#AED6F1" shape=ellipse]
    CTLA4    [label="CTLA-4\n+49A/G" fillcolor="#AED6F1" shape=ellipse]
    IL2RA    [label="IL-2Rα\n(CD25)" fillcolor="#AED6F1" shape=ellipse]
    INS_gene [label="INS VNTR\n(Class I/III)" fillcolor="#AED6F1" shape=ellipse]
    IFIH1    [label="IFIH1/MDA5\nrs1990760" fillcolor="#AED6F1" shape=ellipse]
    viral    [label="Viral Trigger\n(Enterovirus/CVB)" fillcolor="#FDEBD0" shape=diamond]
    gut_micro[label="Gut Microbiome\nDysbiosis" fillcolor="#FDEBD0" shape=diamond]
    early_nu [label="Early Nutrition\n(Cow milk/Gluten)" fillcolor="#FDEBD0" shape=diamond]
    vitamin_d[label="Vitamin D\nDeficiency" fillcolor="#FDEBD0" shape=diamond]
    stress   [label="Psychological\nStress" fillcolor="#FDEBD0" shape=diamond]
  }

  /* ═══════════════════════════════════════════════════════════════
     CLUSTER 2: INNATE IMMUNITY
     ═══════════════════════════════════════════════════════════════ */
  subgraph cluster_innate {
    label="Innate Immunity"
    style="filled,rounded" bgcolor="#FEF9E7" color="#F39C12" penwidth=2
    fontname="Helvetica-Bold" fontsize=13

    pDC      [label="Plasmacytoid\nDendritic Cell (pDC)" fillcolor="#FAD7A0"]
    mDC      [label="Myeloid DC\n(mDC)" fillcolor="#FAD7A0"]
    macro    [label="Macrophage\n(M1-polarized)" fillcolor="#FAD7A0"]
    NK       [label="NK Cell" fillcolor="#FAD7A0"]
    neutro   [label="Neutrophil\n/ NETs" fillcolor="#FAD7A0"]
    IFNa     [label="IFN-α/β\n(Type I IFN)" fillcolor="#FFDAB9" shape=ellipse]
    IL1b_inn [label="IL-1β\n(Inflammasome)" fillcolor="#FFDAB9" shape=ellipse]
    IL12     [label="IL-12/IL-18\nNK activation" fillcolor="#FFDAB9" shape=ellipse]
    CXCL10   [label="CXCL10/CXCL9\nChemokines" fillcolor="#FFDAB9" shape=ellipse]
    TLR3_7   [label="TLR3/TLR7\n(dsRNA sensing)" fillcolor="#FAD7A0"]
    NLRP3    [label="NLRP3\nInflammasome" fillcolor="#FAD7A0"]
    RIG_I    [label="RIG-I/MDA5\ncGAS-STING" fillcolor="#FAD7A0"]
  }

  /* ═══════════════════════════════════════════════════════════════
     CLUSTER 3: ADAPTIVE IMMUNITY — T CELLS
     ═══════════════════════════════════════════════════════════════ */
  subgraph cluster_tcell {
    label="Adaptive Immunity — T Cells"
    style="filled,rounded" bgcolor="#FDEDEC" color="#E74C3C" penwidth=2
    fontname="Helvetica-Bold" fontsize=13

    CD4_naive  [label="Naive CD4+\nT Cell" fillcolor="#F1948A"]
    Th1        [label="Th1 Cell\n(IFN-γ↑/TNF-α↑)" fillcolor="#E74C3C" fontcolor=white]
    Tfh        [label="Tfh Cell\n(IL-21↑/CXCR5+)" fillcolor="#F1948A"]
    Treg       [label="Regulatory T Cell\n(FoxP3+/CD25+)" fillcolor="#A9DFBF" shape=ellipse]
    CD8_naive  [label="Naive CD8+\nT Cell" fillcolor="#F1948A"]
    CD8_eff    [label="CD8+ Effector\nCTL (β-cell killer)" fillcolor="#E74C3C" fontcolor=white]
    CD8_mem    [label="CD8+ Memory\n(long-lived)" fillcolor="#F1948A"]
    TCR_activ  [label="TCR Activation\n(pMHC-I/II)" fillcolor="#E74C3C" fontcolor=white shape=diamond]
    IFNg       [label="IFN-γ\n(Th1/CTL)" fillcolor="#FADBD8" shape=ellipse]
    TNFa       [label="TNF-α\n(macrophage)" fillcolor="#FADBD8" shape=ellipse]
    IL2        [label="IL-2\n(T cell growth)" fillcolor="#FADBD8" shape=ellipse]
    perforin   [label="Perforin/\nGranzyme B" fillcolor="#E74C3C" fontcolor=white shape=ellipse]
    FasL       [label="FasL/TRAIL\nApoptosis" fillcolor="#E74C3C" fontcolor=white shape=ellipse]
    CTLA4_sig  [label="CTLA-4\n(coinhibition)" fillcolor="#A9DFBF" shape=ellipse]
    PD1_PDL1   [label="PD-1/PD-L1\n(exhaustion)" fillcolor="#A9DFBF" shape=ellipse]
  }

  /* ═══════════════════════════════════════════════════════════════
     CLUSTER 4: B CELLS & AUTOANTIBODIES
     ═══════════════════════════════════════════════════════════════ */
  subgraph cluster_bcell {
    label="B Cells & Autoantibodies"
    style="filled,rounded" bgcolor="#F9EBEA" color="#C0392B" penwidth=2
    fontname="Helvetica-Bold" fontsize=13

    Bnaive   [label="Naive B Cell" fillcolor="#F5CBA7"]
    Bact     [label="Activated B Cell\n(GC reaction)" fillcolor="#E59866"]
    plasma   [label="Plasma Cell\n(IgG secreting)" fillcolor="#E59866"]
    BAFF_sig [label="BAFF/APRIL\n(B cell survival)" fillcolor="#FDEBD0" shape=ellipse]
    IAA      [label="Insulin Autoantibody\n(IAA) — 1st Ab" fillcolor="#F1948A" shape=ellipse]
    GADA     [label="Anti-GAD65\n(GADA)" fillcolor="#F1948A" shape=ellipse]
    IA2A     [label="Anti-IA-2\n(IA-2A/IA-2βA)" fillcolor="#F1948A" shape=ellipse]
    ZnT8A    [label="Anti-ZnT8\n(ZnT8A)" fillcolor="#F1948A" shape=ellipse]
    multi_Ab [label="Multiple Ab Positivity\n(Risk staging: Stage 1-3)" fillcolor="#C0392B" fontcolor=white shape=diamond]
  }

  /* ═══════════════════════════════════════════════════════════════
     CLUSTER 5: BETA CELL DESTRUCTION & INSULITIS
     ═══════════════════════════════════════════════════════════════ */
  subgraph cluster_betacell_dest {
    label="Beta Cell Insulitis & Destruction"
    style="filled,rounded" bgcolor="#F2F3F4" color="#7F8C8D" penwidth=2
    fontname="Helvetica-Bold" fontsize=13

    islet_inf   [label="Islet Infiltration\n(Insulitis)" fillcolor="#BDC3C7" shape=diamond]
    MHC1_up     [label="MHC-I Upregulation\n(IFN-γ/IFN-α driven)" fillcolor="#BDC3C7"]
    ER_stress   [label="ER Stress\n(UPR: BiP/IRE1α/PERK)" fillcolor="#BDC3C7"]
    ROS_bc      [label="Oxidative Stress\nROS/RNS in β-cells" fillcolor="#BDC3C7"]
    mitophagy   [label="Mitochondrial\nDysfunction" fillcolor="#BDC3C7"]
    beta_apop   [label="Beta Cell Apoptosis\n(Caspase-3↑)" fillcolor="#7F8C8D" fontcolor=white shape=diamond]
    beta_mass   [label="Beta Cell Mass\n(Bm → decline)" fillcolor="#7F8C8D" fontcolor=white shape=box3d]
    cpep        [label="C-Peptide\n(β-cell function marker)" fillcolor="#BDC3C7" shape=ellipse]
    stage1      [label="Stage 1 T1DM\n(≥2 Ab, normoglycemia)" fillcolor="#EAEDED"]
    stage2      [label="Stage 2 T1DM\n(≥2 Ab, dysglycemia)" fillcolor="#D5D8DC"]
    stage3      [label="Stage 3 T1DM\n(Clinical onset)" fillcolor="#7F8C8D" fontcolor=white]
    DKA         [label="Diabetic Ketoacidosis\n(DKA)" fillcolor="#E74C3C" fontcolor=white shape=diamond]
  }

  /* ═══════════════════════════════════════════════════════════════
     CLUSTER 6: BETA CELL BIOLOGY & INSULIN SECRETION
     ═══════════════════════════════════════════════════════════════ */
  subgraph cluster_betacell_bio {
    label="Beta Cell Biology & Insulin Secretion"
    style="filled,rounded" bgcolor="#EBF5FB" color="#2980B9" penwidth=2
    fontname="Helvetica-Bold" fontsize=13

    GLUT2    [label="GLUT2/GLUT1\nGlucose Transporter" fillcolor="#85C1E9"]
    glucokin [label="Glucokinase\n(GCK — glucose sensor)" fillcolor="#85C1E9"]
    ATP_ADP  [label="ATP/ADP Ratio\n↑ with glucose" fillcolor="#85C1E9" shape=ellipse]
    KATP     [label="ATP-K+ Channel\n(KATP closure)" fillcolor="#85C1E9"]
    depol    [label="Beta Cell\nDepolarization" fillcolor="#3498DB" fontcolor=white shape=diamond]
    VGCC     [label="VGCC\n(Ca²⁺ influx)" fillcolor="#85C1E9"]
    calcium  [label="Intracellular Ca²⁺↑\n(Triggering Signal)" fillcolor="#3498DB" fontcolor=white shape=ellipse]
    exocyt   [label="Insulin Granule\nExocytosis" fillcolor="#3498DB" fontcolor=white shape=diamond]
    proinsu  [label="Proinsulin\nBiosynthesis" fillcolor="#85C1E9"]
    cpep2    [label="C-Peptide\n(equimolar secretion)" fillcolor="#AED6F1" shape=ellipse]
    GLP1_rec [label="GLP-1R\n(Incretin Effect)" fillcolor="#85C1E9"]
    GIP_rec  [label="GIP-R\n(Incretin Effect)" fillcolor="#85C1E9"]
    cAMP_bc  [label="cAMP/PKA\n(Amplifying pathway)" fillcolor="#AED6F1" shape=ellipse]
    GSIS     [label="Glucose-Stimulated\nInsulin Secretion (GSIS)" fillcolor="#2980B9" fontcolor=white shape=diamond]
  }

  /* ═══════════════════════════════════════════════════════════════
     CLUSTER 7: GLUCOSE HOMEOSTASIS
     ═══════════════════════════════════════════════════════════════ */
  subgraph cluster_glucose {
    label="Glucose Homeostasis"
    style="filled,rounded" bgcolor="#E9F7EF" color="#27AE60" penwidth=2
    fontname="Helvetica-Bold" fontsize=13

    gut_glu   [label="Gut Glucose\nAbsorption (Ra)" fillcolor="#A9DFBF"]
    plasma_G  [label="Plasma Glucose\n[G] (central compartment)" fillcolor="#27AE60" fontcolor=white shape=box3d]
    liver_EGP [label="Hepatic EGP\n(Glucose Production)" fillcolor="#A9DFBF"]
    liver_GU  [label="Hepatic Glucose\nUptake (HGU)" fillcolor="#A9DFBF"]
    muscle_GU [label="Muscle Glucose\nUptake (GU)" fillcolor="#A9DFBF"]
    adipose_GU[label="Adipose Glucose\nUptake" fillcolor="#A9DFBF"]
    brain_GU  [label="Brain Glucose\nUptake (insulin-independent)" fillcolor="#A9DFBF"]
    renal_GU  [label="Renal Glucose\nFiltration/SGLT2" fillcolor="#A9DFBF"]
    glucagon  [label="Glucagon\n(α-cell, EGP↑)" fillcolor="#FDEBD0" shape=ellipse]
    glycogen  [label="Glycogen\nSynthesis/Glycogenolysis" fillcolor="#A9DFBF"]
    gluconeo  [label="Gluconeogenesis\n(PEPCK/G6Pase)" fillcolor="#A9DFBF"]
    GLUT4     [label="GLUT4 Translocation\n(Insulin-sensitive)" fillcolor="#A9DFBF"]
    IR_sig    [label="Insulin Receptor\nSignaling (IRS1/PI3K/Akt)" fillcolor="#76D7C4"]
    HbA1c     [label="HbA1c\n(≥6.5% = diagnostic)" fillcolor="#27AE60" fontcolor=white shape=ellipse]
    AGE_form  [label="Advanced Glycation\nEnd-products (AGEs)" fillcolor="#E74C3C" fontcolor=white shape=ellipse]
  }

  /* ═══════════════════════════════════════════════════════════════
     CLUSTER 8: INSULIN PK — THERAPEUTIC
     ═══════════════════════════════════════════════════════════════ */
  subgraph cluster_insulin_pk {
    label="Insulin PK — Therapeutic Administration"
    style="filled,rounded" bgcolor="#F5EEF8" color="#8E44AD" penwidth=2
    fontname="Helvetica-Bold" fontsize=13

    SC_depot  [label="SC Depot\n(Insulin hexamer)" fillcolor="#D7BDE2" shape=box3d]
    SC_depot2 [label="SC Depot\n(Dimer/Monomer)" fillcolor="#D7BDE2" shape=box3d]
    C_ins     [label="Central Plasma\nInsulin [I]" fillcolor="#8E44AD" fontcolor=white shape=box3d]
    P_ins     [label="Peripheral\nTissue Insulin" fillcolor="#D7BDE2" shape=box3d]
    liver_ins [label="Hepatic Insulin\nClearance (50%)" fillcolor="#D7BDE2"]
    renal_ins [label="Renal Insulin\nClearance" fillcolor="#D7BDE2"]
    ka_ins    [label="Absorption Rate (ka)\nUltra-rapid: 0.08 min⁻¹\nRapid: 0.05 min⁻¹\nNPH: 0.02 min⁻¹" fillcolor="#D7BDE2" shape=note]
    basal_ins [label="Basal Insulin\n(Glargine/Degludec)" fillcolor="#A569BD"]
    bolus_ins [label="Bolus Insulin\n(Aspart/Lispro/Glulisine)" fillcolor="#A569BD"]
    CSII      [label="CSII Pump\n(Continuous SC infusion)" fillcolor="#8E44AD" fontcolor=white]
    CGM       [label="CGM Sensor\n(Dexcom G7/Libre 3)" fillcolor="#8E44AD" fontcolor=white shape=diamond]
    APC       [label="Automated Insulin\nDelivery (APC/HCL)" fillcolor="#6C3483" fontcolor=white shape=diamond]
  }

  /* ═══════════════════════════════════════════════════════════════
     CLUSTER 9: IMMUNOTHERAPY
     ═══════════════════════════════════════════════════════════════ */
  subgraph cluster_immunotherapy {
    label="Disease-Modifying Immunotherapy"
    style="filled,rounded" bgcolor="#E8DAEF" color="#7D3C98" penwidth=2
    fontname="Helvetica-Bold" fontsize=13

    teplizumab [label="Teplizumab\n(Anti-CD3 mAb\nFDA-approved 2022)" fillcolor="#9B59B6" fontcolor=white]
    tepliz_moa [label="CD3ε binding →\nTCR internalization\n+ Treg induction" fillcolor="#D7BDE2" shape=note]
    delay_3y   [label="T1DM Onset Delay\n~3 years (TN-10 trial)" fillcolor="#76448A" fontcolor=white shape=ellipse]
    abatacept  [label="Abatacept\n(CTLA4-Ig Anti-CD28)" fillcolor="#9B59B6" fontcolor=white]
    abata_moa  [label="CD80/86 blockade\n→ T cell anergy" fillcolor="#D7BDE2" shape=note]
    rituximab  [label="Rituximab\n(Anti-CD20)" fillcolor="#9B59B6" fontcolor=white]
    ritu_moa   [label="B cell depletion\n→ Autoab↓" fillcolor="#D7BDE2" shape=note]
    ATG        [label="Anti-Thymocyte\nGlobulin (ATG)" fillcolor="#9B59B6" fontcolor=white]
    GCSF       [label="ATG+GCSF\n(TrialNet)" fillcolor="#D7BDE2" shape=note]
    baricit    [label="Baricitinib\n(JAK1/2i, BANDIT)" fillcolor="#9B59B6" fontcolor=white]
    verapamil  [label="Verapamil\n(CREB/Thioredoxin)" fillcolor="#9B59B6" fontcolor=white]
    IFNb_rx    [label="IFN-β\n(Antiviral)" fillcolor="#9B59B6" fontcolor=white]
    IL2_low    [label="Low-dose IL-2\n(Treg expansion)" fillcolor="#9B59B6" fontcolor=white]
    IL2_moa    [label="Treg: CD4+CD25+\nFoxP3+ expansion" fillcolor="#D7BDE2" shape=note]
    CAR_Treg   [label="CAR-Treg\n(proinsulin-specific)" fillcolor="#6C3483" fontcolor=white]
    islet_tx   [label="Islet Transplant\n(Edmonton protocol)" fillcolor="#6C3483" fontcolor=white]
    stem_cell  [label="Stem Cell-Derived\nIslets (VX-880/VX-264)" fillcolor="#6C3483" fontcolor=white]
  }

  /* ═══════════════════════════════════════════════════════════════
     CLUSTER 10: ADJUNCTIVE PHARMACOTHERAPY
     ═══════════════════════════════════════════════════════════════ */
  subgraph cluster_adj {
    label="Adjunctive Pharmacotherapy"
    style="filled,rounded" bgcolor="#EAFAF1" color="#1E8449" penwidth=2
    fontname="Helvetica-Bold" fontsize=13

    SGLT2i    [label="SGLT2 Inhibitors\n(Sotagliflozin/Empagliflozin)" fillcolor="#58D68D"]
    sglt2_moa [label="Renal glucose excretion\n↑ UGE (~70g/d)\n+ Glucosuria" fillcolor="#A9DFBF" shape=note]
    glp1ra    [label="GLP-1RA\n(Semaglutide/Liraglutide)" fillcolor="#58D68D"]
    glp1_moa  [label="GLP-1R → cAMP → GSIS↑\n+ EGP↓ + Satiety" fillcolor="#A9DFBF" shape=note]
    pramlint  [label="Pramlintide\n(Amylin analog)" fillcolor="#58D68D"]
    pram_moa  [label="Glucagon↓ + Gastric\nemptying ↓" fillcolor="#A9DFBF" shape=note]
    metform   [label="Metformin\n(Insulin sparing)" fillcolor="#58D68D"]
    aspirin   [label="Aspirin\n(CV protection)" fillcolor="#58D68D"]
    ACEi      [label="ACE Inhibitor\n(Nephroprotection)" fillcolor="#58D68D"]
    statin    [label="Statin\n(CV risk)" fillcolor="#58D68D"]
  }

  /* ═══════════════════════════════════════════════════════════════
     CLUSTER 11: CHRONIC COMPLICATIONS
     ═══════════════════════════════════════════════════════════════ */
  subgraph cluster_complication {
    label="Chronic Complications (AGE/RAGE/Oxidative Stress)"
    style="filled,rounded" bgcolor="#FDEDEC" color="#922B21" penwidth=2
    fontname="Helvetica-Bold" fontsize=13

    RAGE       [label="RAGE Activation\n(AGE receptor)" fillcolor="#F1948A"]
    polyol     [label="Polyol Pathway\n(Aldose Reductase↑)" fillcolor="#F1948A"]
    PKC_act    [label="PKC Activation\n(DAG↑)" fillcolor="#F1948A"]
    hexosamine [label="Hexosamine Pathway\n(O-GlcNAc↑)" fillcolor="#F1948A"]
    ox_stress  [label="Oxidative Stress\nmitochondrial ROS" fillcolor="#E74C3C" fontcolor=white shape=diamond]

    neph       [label="Diabetic Nephropathy\n(Glomerulosclerosis\neGFR↓, Albuminuria↑)" fillcolor="#922B21" fontcolor=white]
    TGFb_neph  [label="TGF-β1/SMAD\nFibrosis (mesangium)" fillcolor="#F1948A" shape=ellipse]
    retino     [label="Diabetic Retinopathy\n(VEGF↑, neovascularization)" fillcolor="#922B21" fontcolor=white]
    VEGF_ret   [label="VEGF-A\nPericyte loss" fillcolor="#F1948A" shape=ellipse]
    neuro      [label="Diabetic Neuropathy\n(Axonal degeneration\nNCV↓)" fillcolor="#922B21" fontcolor=white]
    CVD        [label="Cardiovascular Disease\n(Atherosclerosis, CAD\nHF, Stroke)" fillcolor="#922B21" fontcolor=white]
    DFU        [label="Diabetic Foot Ulcer\n(PAD + Neuropathy)" fillcolor="#F1948A"]
    hypo_unawr [label="Hypoglycemia\nUnawareness" fillcolor="#E74C3C" fontcolor=white shape=ellipse]
  }

  /* ═══════════════════════════════════════════════════════════════
     CLUSTER 12: CLINICAL ENDPOINTS & BIOMARKERS
     ═══════════════════════════════════════════════════════════════ */
  subgraph cluster_endpoints {
    label="Clinical Endpoints & Biomarkers"
    style="filled,rounded" bgcolor="#EBF5FB" color="#1F618D" penwidth=2
    fontname="Helvetica-Bold" fontsize=13

    HbA1c_ep  [label="HbA1c\n(<7.0% target)" fillcolor="#2E86C1" fontcolor=white shape=ellipse]
    TIR       [label="Time-in-Range\n(70–180 mg/dL, >70%)" fillcolor="#2E86C1" fontcolor=white shape=ellipse]
    TBR       [label="Time-Below-Range\n(<70 mg/dL, <4%)" fillcolor="#E74C3C" fontcolor=white shape=ellipse]
    TAR       [label="Time-Above-Range\n(>180 mg/dL, <25%)" fillcolor="#F39C12" fontcolor=white shape=ellipse]
    cpep_ep   [label="C-Peptide AUC\n(MMTT — β-cell reserve)" fillcolor="#2E86C1" fontcolor=white shape=ellipse]
    insulin_dose [label="Total Daily Insulin\nDose (TDD)" fillcolor="#A9CCE3" shape=ellipse]
    BMI_ep    [label="BMI\n(kg/m²)" fillcolor="#A9CCE3" shape=ellipse]
    eGFR_ep   [label="eGFR\n(CKD staging)" fillcolor="#A9CCE3" shape=ellipse]
    UACR      [label="UACR\n(Albuminuria)" fillcolor="#A9CCE3" shape=ellipse]
    LDL_ep    [label="LDL-C\n(<70 mg/dL target)" fillcolor="#A9CCE3" shape=ellipse]
    DQOL      [label="Diabetes QoL\n(DQOL/PAID score)" fillcolor="#A9CCE3" shape=ellipse]
  }

  /* ═══════════════════════════════════════════════════════════════
     INTER-CLUSTER EDGES
     ═══════════════════════════════════════════════════════════════ */

  /* Genetic → Innate */
  HLA_DR3 -> TCR_activ [label="peptide presentation" color="#2196F3"]
  HLA_DR4 -> TCR_activ [color="#2196F3"]
  PTPN22 -> Treg [label="Treg dysfunction" color="#E74C3C" style=dashed]
  CTLA4 -> CTLA4_sig [label="coinhibition↓" color="#27AE60" style=dashed]
  viral -> TLR3_7 [label="dsRNA" color="#E74C3C"]
  viral -> RIG_I [color="#E74C3C"]
  gut_micro -> NLRP3 [label="dysbiosis" color="#F39C12"]
  early_nu -> macro [label="antigen sensitization" color="#F39C12" style=dashed]
  IFIH1 -> RIG_I [label="viral sensing gene" color="#2196F3"]
  INS_gene -> proinsu [label="central tolerance" color="#2196F3" style=dashed]

  /* Innate → Adaptive */
  TLR3_7 -> IFNa [color="#F39C12"]
  RIG_I -> IFNa [color="#F39C12"]
  IFNa -> mDC [label="DC maturation" color="#E74C3C"]
  pDC -> IFNa [color="#E74C3C"]
  mDC -> CD4_naive [label="Ag presentation\n(MHC-II)" color="#E74C3C"]
  mDC -> CD8_naive [label="Ag presentation\n(MHC-I/cross)" color="#E74C3C"]
  NLRP3 -> IL1b_inn [label="caspase-1" color="#E74C3C"]
  IL1b_inn -> macro [color="#F39C12"]
  macro -> IL12 [color="#F39C12"]
  IL12 -> CD4_naive [label="Th1 polarization" color="#E74C3C"]
  NK -> IL12 [color="#F39C12" dir=both]
  CXCL10 -> CD8_naive [label="recruitment" color="#F39C12"]

  /* T cell activation */
  CD4_naive -> Th1 [label="IL-12/IFN-γ" color="#E74C3C"]
  CD4_naive -> Tfh [label="IL-21/CXCL13" color="#E74C3C"]
  CD8_naive -> CD8_eff [label="TCR + MHC-I" color="#E74C3C"]
  CD8_eff -> CD8_mem [color="#E74C3C" style=dashed]
  TCR_activ -> CD8_eff [color="#E74C3C"]
  TCR_activ -> Th1 [color="#E74C3C"]
  Th1 -> IFNg [color="#E74C3C"]
  Th1 -> TNFa [color="#E74C3C"]
  IFNg -> macro [label="M1 polarization" color="#F39C12"]
  CTLA4_sig -> Th1 [label="inhibits" color="#27AE60" arrowhead=tee]
  PD1_PDL1 -> CD8_eff [label="inhibits" color="#27AE60" arrowhead=tee]
  IL2 -> Th1 [label="autocrine" color="#E74C3C"]
  IL2 -> CD8_eff [color="#E74C3C"]
  IL2 -> Treg [label="Treg survival" color="#27AE60"]
