digraph MPA_QSP {
    graph [
        label="Microscopic Polyangiitis (MPA)\nQuantitative Systems Pharmacology Model",
        fontname="Helvetica", fontsize=22, labelloc="t",
        rankdir=TB, bgcolor="#F0F4F8",
        nodesep=0.45, ranksep=0.7,
        splines=true, overlap=false,
        compound=true
    ]
    node [fontname="Helvetica", fontsize=9, style="filled,rounded",
          shape=box, margin="0.08,0.04", penwidth=1.4]
    edge [fontname="Helvetica", fontsize=7, arrowsize=0.55, penwidth=1.1]

    // ================================================================
    // CLUSTER 1: Genetic & Environmental Risk
    // ================================================================
    subgraph cluster_risk {
        label="Genetic & Environmental Risk"
        style=filled; bgcolor="#FFF0F0"; color="#CC0000"; fontcolor="#CC0000"; fontsize=13; penwidth=2

        HLA_DQ     [label="HLA-DQ\nVariant",          fillcolor="#FFCCCC"]
        HLA_DR4    [label="HLA-DR4",                   fillcolor="#FFCCCC"]
        PTPN22     [label="PTPN22\nPolymorphism",      fillcolor="#FFCCCC"]
        SERPINA1   [label="SERPINA1\n(α₁-Antitrypsin)",fillcolor="#FFCCCC"]
        MPO_gene   [label="MPO Gene\nVariant",         fillcolor="#FFCCCC"]
        PRTN3_gene [label="PRTN3 Gene\nVariant",       fillcolor="#FFCCCC"]
        Silica_exp [label="Silica\nExposure",          fillcolor="#FFE5CC"]
        Drug_trig  [label="Drug Triggers\n(PTU/Hydralazine)", fillcolor="#FFE5CC"]
        Infect_trig[label="Infection\n(S. aureus/viral)", fillcolor="#FFE5CC"]
        Microbiome [label="Gut Microbiome\nDysbiosis", fillcolor="#FFE5CC"]
        UV_exp     [label="UV / Chemical\nExposure",   fillcolor="#FFE5CC"]
        GEN_RISK   [label="GENETIC\nRISK SCORE",       shape=diamond, fillcolor="#FF9999", penwidth=2.5]

        HLA_DQ     -> GEN_RISK
        HLA_DR4    -> GEN_RISK
        PTPN22     -> GEN_RISK
        SERPINA1   -> GEN_RISK
        MPO_gene   -> GEN_RISK
        PRTN3_gene -> GEN_RISK
        Silica_exp -> GEN_RISK [label="epigenetic\ntrigger"]
        Drug_trig  -> GEN_RISK [label="drug-induced\nANCA"]
        Infect_trig-> GEN_RISK [label="molecular\nmimicry"]
        Microbiome -> GEN_RISK [label="immune\ndysregulation"]
        UV_exp     -> GEN_RISK [label="oxidative\nstress"]
    }

    // ================================================================
    // CLUSTER 2: Innate Immunity
    // ================================================================
    subgraph cluster_innate {
        label="Innate Immune Activation"
        style=filled; bgcolor="#FFF8E0"; color="#CC8800"; fontcolor="#CC8800"; fontsize=13; penwidth=2

        Mono_circ  [label="Circulating\nMonocyte",        fillcolor="#FFE080"]
        Mac_M1     [label="M1 Macrophage\n(Pro-inflam)",  fillcolor="#FFD040"]
        Mac_M2     [label="M2 Macrophage\n(Anti-inflam)", fillcolor="#FFE080"]
        DC_myeloid [label="Myeloid Dendritic\nCell (mDC)",fillcolor="#FFE080"]
        DC_plasma  [label="Plasmacytoid DC\n(pDC)",       fillcolor="#FFE080"]
        NK_cell    [label="NK Cell\n(ADCC)",               fillcolor="#FFE080"]
        Comp_C3    [label="Complement C3",                 fillcolor="#FFD54F"]
        Comp_C5    [label="Complement C5",                 fillcolor="#FFD54F"]
        C5a        [label="C5a\nAnaphylatoxin",            fillcolor="#FFB300", penwidth=2]
        C5aR1      [label="C5aR1\nReceptor",               fillcolor="#FFB300"]
        MAC_node   [label="Membrane Attack\nComplex (MAC)",fillcolor="#FFD54F"]
        Alt_path   [label="Alternative\nPathway",          fillcolor="#FFD54F"]
        Factor_B   [label="Factor B",                      fillcolor="#FFD54F"]
        Properdin  [label="Properdin",                     fillcolor="#FFD54F"]
        NLRP3      [label="NLRP3\nInflammasome",           fillcolor="#FFE080"]

        Comp_C3 -> Alt_path
        Alt_path -> Factor_B
        Factor_B -> Properdin
        Properdin -> Comp_C5 [label="C3 convertase\namplification"]
        Comp_C5 -> C5a       [label="C5 cleavage\n(C5 convertase)"]
        Comp_C5 -> MAC_node  [label="C5b → MAC\n(C5b-9)"]
        C5a     -> C5aR1     [label="binding\n(Kd ~1 nM)"]
        NLRP3   -> Mac_M1    [label="IL-1β/IL-18\nrelease"]
    }

    // ================================================================
    // CLUSTER 3: T Cell Immunity
    // ================================================================
    subgraph cluster_tcells {
        label="T Cell Responses"
        style=filled; bgcolor="#F5E6FF"; color="#7B2FBE"; fontcolor="#7B2FBE"; fontsize=13; penwidth=2

        Naive_T    [label="Naive T Cell\n(CD4+/CD8+)",     fillcolor="#D4AAFF"]
        Th1        [label="Th1 Cell\n(IFN-γ dominant)",    fillcolor="#C084FF"]
        Th17       [label="Th17 Cell\n(IL-17A dominant)",  fillcolor="#C084FF"]
        Treg       [label="Regulatory T\n(FOXP3+, CD25+)", fillcolor="#B8F0B8"]
        Tfh        [label="T Follicular\nHelper (Tfh)",     fillcolor="#C084FF"]
        CD8_T      [label="CD8+ Cytotoxic\nT Cell",         fillcolor="#C084FF"]
        CD40L      [label="CD40L\n(CD154)",                 fillcolor="#D4AAFF", shape=ellipse]
        IL21_Tfh   [label="IL-21\n(Tfh effector)",          fillcolor="#D4AAFF", shape=ellipse]
        PD1_CTLA4  [label="PD-1/CTLA-4\n(Checkpoints)",    fillcolor="#B8D4FF"]
        T_exh      [label="T Cell\nExhaustion",             fillcolor="#B8D4FF"]
        ICOS_L     [label="ICOS-ICOSL\nCo-stimulation",     fillcolor="#D4AAFF"]
        OX40       [label="OX40-OX40L\nSignal",             fillcolor="#D4AAFF"]
        FOXP3      [label="FOXP3\nExpression",               fillcolor="#B8F0B8"]
        T_B_cross  [label="T-B Cross-talk\n(GC reaction)",  fillcolor="#E0CCFF", shape=diamond]

        Naive_T -> Th1       [label="IL-12/IFN-γ"]
        Naive_T -> Th17      [label="IL-6/TGF-β/IL-23"]
        Naive_T -> Treg      [label="TGF-β/IL-2\nFOXP3↑"]
        Naive_T -> Tfh       [label="ICOS-L/CXCR5"]
        Naive_T -> CD8_T     [label="IL-2/MHC-I"]
        Tfh     -> CD40L
        Tfh     -> IL21_Tfh
        Tfh     -> T_B_cross [label="GC\nsupport"]
        ICOS_L  -> Tfh       [label="Tfh\nmaturation"]
        OX40    -> Th1       [label="Th1 survival"]
        FOXP3   -> Treg      [label="defines Treg"]
        PD1_CTLA4 -> T_exh  [label="checkpoint\nexhaustion"]
    }

    // ================================================================
    // CLUSTER 4: B Cells & ANCA Production
    // ================================================================
    subgraph cluster_bcells {
        label="B Cells & ANCA Production"
        style=filled; bgcolor="#E6E6FF"; color="#000088"; fontcolor="#000088"; fontsize=13; penwidth=2

        Naive_B    [label="Naive B Cell\n(CD20+, IgM+)",   fillcolor="#AAAAFF"]
        GC_B       [label="Germinal Center\nB Cell",         fillcolor="#8888FF"]
        Mem_B      [label="Memory B Cell\n(CD27+)",          fillcolor="#AAAAFF"]
        Plasmablast[label="Plasmablast\n(CD38+ CD20−)",      fillcolor="#6666FF"]
        Plasma_cell[label="Long-lived\nPlasma Cell",         fillcolor="#4444FF", fontcolor="white", penwidth=2.5]
        CD20_Ag    [label="CD20 Antigen\n(RTX target)",      fillcolor="#CCCCFF", shape=ellipse]
        BAFF       [label="BAFF/BLyS\n(Survival factor)",   fillcolor="#AAAAFF", shape=ellipse]
        APRIL      [label="APRIL\n(TACI ligand)",            fillcolor="#AAAAFF", shape=ellipse]
        BCR_signal [label="BCR Signaling\n(PI3K/Btk)",       fillcolor="#CCCCFF"]
        MPO_Ag     [label="MPO Antigen\n(Self-antigen)",      fillcolor="#FF8888", shape=ellipse, penwidth=2]
        MPO_ANCA   [label="Anti-MPO IgG\n(pANCA)",           fillcolor="#FF4444", shape=ellipse, penwidth=3]
        ANCA_titer [label="ANCA Serum\nTiter",                fillcolor="#FF6666", penwidth=2]
        Epitope_spr[label="Epitope\nSpreading",               fillcolor="#FFAAAA"]

        Naive_B    -> BCR_signal [label="MPO antigen\ndriven"]
        BCR_signal -> GC_B      [label="GC entry"]
        GC_B       -> Mem_B     [label="memory\ndifferentiation"]
        GC_B       -> Plasmablast[label="effector\ndifferentiation"]
        Plasmablast-> Plasma_cell[label="bone marrow\nhoming"]
        Plasma_cell-> MPO_ANCA  [label="IgG secretion\n(μg/mL/day)"]
        BAFF       -> Plasma_cell[label="survival\nsignals"]
        APRIL      -> Plasma_cell[label="IgA/IgG\nclass switch"]
        MPO_Ag     -> BCR_signal [label="cognate\nantigen"]
        MPO_ANCA   -> ANCA_titer
        Epitope_spr-> MPO_ANCA  [label="broadens\nspecificity"]
        CD20_Ag    -> Naive_B   [label="surface\nexpression"]
    }

    // ================================================================
    // CLUSTER 5: Neutrophil-Mediated Vasculitis
    // ================================================================
    subgraph cluster_neutrophil {
        label="Neutrophil-Mediated ANCA Vasculitis"
        style=filled; bgcolor="#FFE8E8"; color="#AA0000"; fontcolor="#AA0000"; fontsize=13; penwidth=2

        Neut_BM    [label="Bone Marrow\nNeutrophil (PMN)",  fillcolor="#FFB0B0"]
        Neut_circ  [label="Circulating\nNeutrophil",         fillcolor="#FFB0B0"]
        Neut_prime [label="PRIMED\nNeutrophil",              fillcolor="#FF8080", penwidth=2.5]
        MPO_surf   [label="MPO on PMN\nSurface",             fillcolor="#FF6060", shape=ellipse]
        PR3_surf   [label="PR3 on PMN\nSurface (minor)",     fillcolor="#FF9090", shape=ellipse]
        ANCA_bind  [label="ANCA-PMN\nBinding",               fillcolor="#FF4040", shape=diamond, penwidth=3]
        FcgRII     [label="FcγRIIa\nActivation",             fillcolor="#FF6060"]
        FcgRIII    [label="FcγRIIIb\nActivation",            fillcolor="#FF6060"]
        Ca2p_flux  [label="Intracellular\nCa²⁺ Flux",        fillcolor="#FF8080"]
        NADPH_ox   [label="NADPH Oxidase\n(NOX2)",           fillcolor="#FF4040"]
        ROS_PMN    [label="ROS / Superoxide\nBurst",         fillcolor="#FF2020", penwidth=2]
        Degranul   [label="Azurophil\nDegranulation",        fillcolor="#FF4040", penwidth=2]
        Elastase   [label="Neutrophil\nElastase (NE)",       fillcolor="#FF6060"]
        Cathepsin  [label="Cathepsin G &\nProteinase 3",     fillcolor="#FF6060"]
        MPO_rel    [label="MPO Release\ninto Vessel Wall",   fillcolor="#FF4040"]
        NETosis    [label="NETosis\n(Suicidal NET)",         fillcolor="#CC0000", penwidth=2.5]
        NETs       [label="Neutrophil\nExtracellular Traps", fillcolor="#CC0000", fontcolor="white", penwidth=2]
        NET_Cit    [label="Citrullinated\nHistones on NETs", fillcolor="#FF6060"]
        NET_MPO    [label="NET-bound\nMPO / Autoantigen",    fillcolor="#FF4040"]
        PAD4       [label="PAD4\n(Citrullination enz.)",   fillcolor="#FF8080"]

        Neut_BM   -> Neut_circ  [label="G-CSF\nmobilization"]
        Neut_circ -> Neut_prime  [label="priming by\nTNF-α/IL-8/C5a"]
        Neut_prime-> MPO_surf   [label="surface\ntranslocation"]
        Neut_prime-> PR3_surf   [label="surface\ntranslocation"]
        MPO_surf  -> ANCA_bind  [label="ANCA\nrecognition"]
        ANCA_bind -> FcgRII     [label="Fc-region\nengagement"]
        ANCA_bind -> FcgRIII    [label="Fc-region\nengagement"]
        FcgRII    -> Ca2p_flux  [label="PLCγ/IP3\nactivation"]
        FcgRII    -> NADPH_ox   [label="p47phox\nassembly"]
        FcgRIII   -> NADPH_ox   [label="assembly"]
        Ca2p_flux -> Degranul   [label="exocytosis\ntrigger"]
        Ca2p_flux -> NETosis    [label="chromatin\nexplosion"]
        NADPH_ox  -> ROS_PMN    [label="O₂•⁻ → H₂O₂"]
        ROS_PMN   -> Degranul   [label="amplify"]
        ROS_PMN   -> NETosis    [label="mitochondrial\nROS trigger"]
        Degranul  -> Elastase
        Degranul  -> Cathepsin
        Degranul  -> MPO_rel
        NETosis   -> NETs
        NETs      -> NET_Cit
        NETs      -> NET_MPO
        PAD4      -> NET_Cit    [label="histone\ncitrullination"]
    }

    // ================================================================
    // CLUSTER 6: Vascular / Endothelial Injury
    // ================================================================
    subgraph cluster_vascular {
        label="Small Vessel / Endothelial Injury"
        style=filled; bgcolor="#FFE0D0"; color="#8B2000"; fontcolor="#8B2000"; fontsize=13; penwidth=2

        Endothel   [label="Endothelial\nCell (EC)",          fillcolor="#FFCCAA"]
        Endothel_act[label="Activated\nEndothelium",         fillcolor="#FFAA80", penwidth=2]
        ICAM1      [label="ICAM-1\n(CD54)",                  fillcolor="#FFAA80"]
        VCAM1      [label="VCAM-1\n(CD106)",                 fillcolor="#FFAA80"]
        P_selec    [label="P-selectin\n(CD62P)",             fillcolor="#FFAA80"]
        E_selec    [label="E-selectin\n(CD62E)",             fillcolor="#FFAA80"]
        vWF        [label="von Willebrand\nFactor (vWF)",    fillcolor="#FFCCAA"]
        Tissue_fac [label="Tissue Factor\n(TF/CD142)",       fillcolor="#FFAA80"]
        Fibrinoid  [label="Fibrinoid\nNecrosis",             fillcolor="#CC4400", penwidth=2.5]
        Pauci_imm  [label="Pauci-immune\nVasculitis",        fillcolor="#AA2200", fontcolor="white", penwidth=3]

        Endothel   -> Endothel_act  [label="ROS/ANCA/\ncytokine stimulation"]
        Endothel_act -> ICAM1
        Endothel_act -> VCAM1
        Endothel_act -> P_selec
        Endothel_act -> E_selec
        Endothel_act -> vWF         [label="Weibel-Palade\nbody release"]
        Endothel_act -> Tissue_fac  [label="procoagulant\nswitch"]
        Fibrinoid   -> Pauci_imm
        Tissue_fac  -> Fibrinoid    [label="fibrin\ndeposition"]
    }

    // ================================================================
    // CLUSTER 7: Renal Pathology
    // ================================================================
    subgraph cluster_renal {
        label="Renal Pathology (Pauci-immune GN)"
        style=filled; bgcolor="#E0F0FF"; color="#004488"; fontcolor="#004488"; fontsize=13; penwidth=2

        Glom_cap   [label="Glomerular\nCapillary",           fillcolor="#AADDFF"]
        Podocyte   [label="Podocyte\n(Foot Processes)",      fillcolor="#AADDFF"]
        GBM_node   [label="Glomerular\nBasement Membrane",   fillcolor="#AADDFF"]
        Mesangium  [label="Mesangial\nCell",                  fillcolor="#AADDFF"]
        Parietal_ep[label="Parietal Epithelial\nCell (PEC)", fillcolor="#AADDFF"]
        RPGN       [label="RPGN\n(Crescent GN)",             fillcolor="#4488CC", fontcolor="white", penwidth=2.5]
        Crescent   [label="Cellular→Fibrous\nCrescent",      fillcolor="#2266AA", fontcolor="white", penwidth=2]
        Tubular_inj[label="Tubular\nInjury",                  fillcolor="#88BBDD"]
        Interst_neph[label="Interstitial\nNephritis",         fillcolor="#88BBDD"]
        Renal_fibr [label="Renal Fibrosis\n(TGF-β driven)",  fillcolor="#6699CC", fontcolor="white"]
        GFR_node   [label="GFR\n(mL/min/1.73m²)",           fillcolor="#003377", fontcolor="white", penwidth=3]
        Creatinine [label="Serum\nCreatinine (↑)",           fillcolor="#88BBDD"]
        Proteinuria[label="Proteinuria\n(g/day)",             fillcolor="#88BBDD"]
        Hematuria  [label="Microscopic\nHematuria",           fillcolor="#88BBDD"]

        Glom_cap   -> RPGN      [label="capillaritis\n→ fibrinoid Δ"]
        RPGN       -> Crescent  [label="PEC\nproliferation"]
        Crescent   -> GFR_node  [label="nephron\nloss → GFR↓"]
        Crescent   -> Proteinuria [label="glomerular\nfiltration↑"]
        Crescent   -> Hematuria  [label="RBC\ncasting"]
        Podocyte   -> Proteinuria [label="slit\ndiaphragm loss"]
        GBM_node   -> RPGN     [label="GBM\ndestruction"]
        Tubular_inj-> Creatinine [label="tubular\nsecretion↓"]
        GFR_node   -> Creatinine [label="inversely\ncorrelated"]
        Interst_neph -> Renal_fibr [label="fibroblast\nactivation"]
        Renal_fibr -> GFR_node  [label="permanent\nnephron loss"]
        Parietal_ep-> Crescent  [label="PEC activation\n→ crescent"]
        Mesangium  -> Glom_cap  [label="support\nstructure"]
    }

    // ================================================================
    // CLUSTER 8: Pulmonary Pathology
    // ================================================================
    subgraph cluster_pulmonary {
        label="Pulmonary Pathology (DAH)"
        style=filled; bgcolor="#E0FFE8"; color="#005522"; fontcolor="#005522"; fontsize=13; penwidth=2

        Pulm_cap   [label="Pulmonary\nCapillary",             fillcolor="#AAFFCC"]
        Alv_mac    [label="Alveolar\nMacrophage",             fillcolor="#AAFFCC"]
        Alv_ep_I   [label="Alveolar Epithelial\nCell Type I", fillcolor="#AAFFCC"]
        Alv_ep_II  [label="Alveolar Epithelial\nCell Type II",fillcolor="#AAFFCC"]
        Pulm_cap_it[label="Pulmonary\nCapillaritis",          fillcolor="#44CC88", penwidth=2]
        DAH        [label="Diffuse Alveolar\nHemorrhage (DAH)",fillcolor="#008844", fontcolor="white", penwidth=3]
        Hemoptysis [label="Hemoptysis",                        fillcolor="#66CC00"]
        DLCO_node  [label="DLCO\n(% predicted)",               fillcolor="#004422", fontcolor="white", penwidth=2]
        Pulm_fibr  [label="Pulmonary\nFibrosis (late)",        fillcolor="#66AA44"]
        Resp_fail  [label="Respiratory\nFailure",               fillcolor="#CC4400", fontcolor="white", penwidth=2.5]

        Pulm_cap   -> Pulm_cap_it [label="PMN infiltration\nANCA-mediated"]
        Pulm_cap_it-> DAH         [label="capillary\nrupture"]
        DAH        -> Hemoptysis  [label="airway\nbleeding"]
        DAH        -> DLCO_node   [label="DLCO↓\nhemosiderin"]
        DAH        -> Resp_fail   [label="massive\nhemorrhage"]
        Alv_mac    -> Pulm_cap_it [label="cytokine\namplification"]
        Alv_ep_I   -> DAH         [label="barrier\nbreach"]
        Alv_ep_II  -> Pulm_fibr   [label="repair →\nfibrosis"]
        Pulm_fibr  -> DLCO_node   [label="DLCO↓↓"]
        Pulm_fibr  -> Resp_fail   [label="progressive\nhypoxemia"]
    }

    // ================================================================
    // CLUSTER 9: Systemic Cytokines & Mediators
    // ================================================================
    subgraph cluster_cytokines {
        label="Systemic Cytokines & Inflammatory Mediators"
        style=filled; bgcolor="#F0FFE0"; color="#336600"; fontcolor="#336600"; fontsize=13; penwidth=2

        TNFa   [label="TNF-α",              fillcolor="#AAFFAA"]
        IL1b   [label="IL-1β",              fillcolor="#AAFFAA"]
        IL6    [label="IL-6",               fillcolor="#AAFFAA"]
        IL8    [label="IL-8 / CXCL8\n(PMN chemoattractant)", fillcolor="#CCFF88"]
        IL17   [label="IL-17A",             fillcolor="#AAFFAA"]
        IL18   [label="IL-18",              fillcolor="#AAFFAA"]
        IL33   [label="IL-33\n(alarmin)",   fillcolor="#AAFFAA"]
        IFNg   [label="IFN-γ",              fillcolor="#AAFFAA"]
        TGFb1  [label="TGF-β1\n(fibrogenic)", fillcolor="#AAFFAA"]
        MCP1   [label="MCP-1/CCL2\n(monocyte recruit.)", fillcolor="#CCFF88"]
        RANTES [label="RANTES/CCL5",        fillcolor="#CCFF88"]
        CXCL10 [label="CXCL10/IP-10\n(T cell chemoattr.)", fillcolor="#CCFF88"]
        CRP_ESR[label="CRP / ESR\n(Acute Phase Response)", fillcolor="#88FF44", shape=ellipse, penwidth=2]
        GC_CSF [label="GM-CSF\n(PMN priming)", fillcolor="#AAFFAA"]
        LPS_PAMP[label="LPS / PAMPs\n(TLR triggers)", fillcolor="#FFEE88", shape=ellipse]

        IL6    -> CRP_ESR     [label="hepatic\nAPR"]
        IL18   -> IFNg        [label="IFN-γ\nproduction"]
    }

    // ================================================================
    // CLUSTER 10: Drug Pharmacokinetics
    // ================================================================
    subgraph cluster_drug_pk {
        label="Drug Pharmacokinetics"
        style=filled; bgcolor="#FFF0F8"; color="#880044"; fontcolor="#880044"; fontsize=13; penwidth=2

        CY_oral    [label="Cyclophosphamide\nOral (2mg/kg/d)",     fillcolor="#FFB0D0"]
        CY_IV      [label="Cyclophosphamide\nIV Pulse (15mg/kg)", fillcolor="#FFB0D0"]
        CY_C       [label="CY: Central\nCompartment (Cp)",         fillcolor="#FF88BB"]
        CY_P       [label="CY: Peripheral\nCompartment",           fillcolor="#FF88BB"]
        OH_CY      [label="4-OH-CY\nActive Metabolite",           fillcolor="#FF4488", penwidth=2.5]
        RTX_inf    [label="Rituximab IV\n(375mg/m²×4 or\n1000mg×2)", fillcolor="#D0B0FF"]
        RTX_C      [label="RTX: Central\nCompartment",             fillcolor="#BB88FF"]
        RTX_P      [label="RTX: Peripheral\nCompartment",          fillcolor="#BB88FF"]
        PRED_oral  [label="Prednisolone\nOral (1mg/kg→taper)",     fillcolor="#FFDDAA"]
        PRED_C     [label="PRED: Central\nCompartment",            fillcolor="#FFCCAA"]
        MPPRED     [label="Methylprednisolone\nIV Pulse (1g×3)",   fillcolor="#FFDDAA"]
        AZA_oral   [label="Azathioprine\n(AZA, 2mg/kg/d)\n[Maintenance]", fillcolor="#AAFFCC"]
        MMF_oral   [label="Mycophenolate\n(MMF, 3g/d)\n[Maintenance]", fillcolor="#AAFFCC"]
        PLEX_treat [label="Plasma Exchange\n(PLEX, 7×/2wk)",       fillcolor="#FFFF99"]
        Avacopan   [label="Avacopan\n(C5aR1 inhibitor\n30mg BID)", fillcolor="#FFD0A0"]

        CY_oral -> CY_C    [label="ka=1.2/h\nF=0.75"]
        CY_IV   -> CY_C    [label="IV infusion\n(1h)"]
        CY_C    -> CY_P    [label="Qcp=18 L/h\nVp=38 L"]
        CY_P    -> CY_C    [label="redistribution"]
        CY_C    -> OH_CY   [label="CYP2B6\nCYP3A4\n(liver)"]

        RTX_inf -> RTX_C   [label="IV infusion\n(3-6h)"]
        RTX_C   -> RTX_P   [label="distribution\nk12"]
        RTX_P   -> RTX_C   [label="redistribution\nk21"]

        PRED_oral -> PRED_C [label="ka=3.6/h\nF=0.85"]
        MPPRED    -> PRED_C [label="IV→PRED\n(equiv.)"]
    }

    // ================================================================
    // CLUSTER 11: PD & Clinical Endpoints
    // ================================================================
    subgraph cluster_endpoints {
        label="Pharmacodynamics & Clinical Endpoints"
        style=filled; bgcolor="#F0F0FF"; color="#220088"; fontcolor="#220088"; fontsize=13; penwidth=2

        CD20_depl  [label="B Cell Depletion\n(CD20+ <5/μL)",      fillcolor="#DDAAFF"]
        B_repop    [label="B Cell\nRepopulation\n(6-12 months)",   fillcolor="#CCBBFF"]
        ANCA_suppr [label="ANCA Titer\nSuppression",               fillcolor="#BB88FF", penwidth=2]
        GC_suppr   [label="GC-Mediated\nImmunosuppression",        fillcolor="#FFDDAA"]
        CY_tox     [label="CY Toxicity\n(Infertility/Bladder)",    fillcolor="#FFAAAA"]
        BVAS_score [label="BVAS Score\n(Disease Activity)",         fillcolor="#8844FF", fontcolor="white", penwidth=3]
        BVAS_resp  [label="BVAS Response\n(≥50% reduction)",        fillcolor="#AAAAFF"]
        Comp_remiss[label="Complete\nRemission\n(BVAS=0, 3-6mo)", fillcolor="#44AA00", fontcolor="white", penwidth=3]
        Partial_rem[label="Partial\nRemission",                     fillcolor="#88CC44"]
        Relapse    [label="Disease\nRelapse",                       fillcolor="#CC4400", fontcolor="white", penwidth=2.5]
        VDI_score  [label="Vasculitis Damage\nIndex (VDI)",        fillcolor="#AA88FF"]
        ESRD_end   [label="ESRD\n(Dialysis/Tx)",                   fillcolor="#880000", fontcolor="white", penwidth=2.5]
        Mortality  [label="All-cause\nMortality",                   fillcolor="#440000", fontcolor="white", penwidth=3]
        QoL        [label="Quality of Life\n(SF-36 / EQ-5D)",     fillcolor="#88AAFF"]

        CD20_depl  -> ANCA_suppr [label="→ ANCA↓\n(weeks-months)"]
        B_repop    -> Relapse    [label="→ ANCA\nresurgence"]
        ANCA_suppr -> BVAS_score [label="disease\ncontrol"]
        GC_suppr   -> BVAS_score [label="symptom\ncontrol"]
        BVAS_score -> BVAS_resp  [label="≥50%↓"]
        BVAS_score -> Comp_remiss [label="BVAS=0"]
        BVAS_resp  -> Partial_rem
        Comp_remiss-> Relapse    [label="risk if\nANCA rising"]
        Relapse    -> VDI_score  [label="damage\naccrual"]
        BVAS_score -> VDI_score  [label="cumulative\ndamage"]
        Comp_remiss-> QoL        [label="improved\nQoL"]
        Relapse    -> QoL        [label="QoL↓"]
        CY_tox     -> QoL        [label="treatment\nburden"]
    }

    // ================================================================
    // INTER-CLUSTER EDGES
    // ================================================================

    // Risk -> Innate
    GEN_RISK -> Mono_circ   [label="monocyte\nactivation"]
    GEN_RISK -> DC_myeloid  [label="DC\nmaturation"]
    Silica_exp -> Mac_M1   [label="silicosis\nM1 stimulus"]
    Infect_trig -> DC_plasma [label="type I IFN\ninduction"]
    Drug_trig -> MPO_ANCA  [label="drug-induced\nANCA (pANCA)"]

    // Risk -> T cells
    GEN_RISK -> Naive_T    [label="T cell tolerance\nbreakdown"]

    // Risk -> B cells
    GEN_RISK -> Naive_B    [label="B cell\ntolerance loss"]

    // Innate -> T cells
    DC_myeloid -> Th1      [label="IL-12 / MHC-II"]
    DC_myeloid -> Th17     [label="IL-6/TGF-β/IL-23"]
    DC_myeloid -> Tfh      [label="ICOS-L\npresentation"]
    Mac_M1     -> Th1      [label="IL-12/IL-18"]
    DC_plasma  -> Th1      [label="IFN-α/β\npriming"]
    C5a        -> Mono_circ [label="C5aR\nactivation"]

    // Innate -> Neutrophil
    C5a     -> Neut_prime  [label="C5aR1\npriming"]
    C5aR1   -> Neut_prime  [label="downstream\nsignaling"]

    // T cells -> B cells
    Tfh      -> GC_B       [label="IL-21/CD40L\nGC support"]
    CD40L    -> GC_B       [label="CD40 ligation\nclass switch"]
    IL21_Tfh -> GC_B       [label="proliferation\nsurvival"]
    Th17     -> Naive_B    [label="IL-17A\nactivation"]
    T_B_cross-> BAFF       [label="BAFF\nupregulation"]

    // Cytokines -> Neutrophil
    TNFa   -> Neut_prime  [label="priming\n(TNF-R1)"]
    IL8    -> Neut_circ   [label="CXCR2\nchemotaxis"]
    GC_CSF -> Neut_circ   [label="mobilization"]

    // Cytokines -> Renal
    TGFb1  -> Renal_fibr  [label="SMAD2/3\nfibrogenesis"]

    // Cytokines -> Pulmonary
    TGFb1  -> Pulm_fibr   [label="fibrogenesis"]

    // Cytokines -> Endothelial
    TNFa   -> Endothel_act [label="NF-κB\nactivation"]
    IL1b   -> Endothel_act [label="IL-1R\nsignaling"]
    IL8    -> Endothel_act [label="angiogenesis"]

    // B cells -> Neutrophil
    MPO_ANCA -> ANCA_bind  [label="ANCA recognizes\nMPO on PMN"]

    // Neutrophil -> Cytokines
    Degranul -> TNFa       [label="TNF-α\nrelease"]
    Degranul -> IL8        [label="autocrine\nCXCL8"]
    ROS_PMN  -> IL1b       [label="NLRP3\nactivation"]
    NETs     -> IL33       [label="alarmin\nreleased"]

    // Neutrophil -> Endothelial
    ROS_PMN  -> Endothel_act [label="oxidative\ndamage"]
    Elastase -> Endothel_act [label="matrix\ndegradation"]
    Cathepsin-> Endothel_act [label="ECM\nproteolysis"]
    MPO_rel  -> Endothel_act [label="MPO-mediated\noxidation"]
    MAC_node -> Endothel    [label="C5b-9\nlysis"]
    NET_MPO  -> Endothel_act [label="chromatin\ndamage"]

    // Neutrophil -> B cells (feedback)
    NET_MPO  -> MPO_Ag      [label="autoantigen\npresentation"]
    NET_Cit  -> Epitope_spr [label="neoantigen\ngeneration"]

    // Endothelial -> Renal
    Endothel_act -> Glom_cap  [label="glomerular\ncapillaritis"]
    ICAM1        -> Neut_circ [label="PMN firm\nadhesion"]
    VCAM1        -> Mono_circ [label="monocyte\nadhesion"]
    Fibrinoid    -> RPGN      [label="fibrinoid\nnecrosis→GN"]
    Pauci_imm   -> RPGN      [label="glomerular\ninflammation"]

    // Endothelial -> Pulmonary
    Endothel_act -> Pulm_cap  [label="pulmonary\ncapillaritis"]
    Pauci_imm   -> Pulm_cap_it [label="capillary\nrupture trigger"]

    // Cytokines -> Disease scores
    TNFa   -> BVAS_score   [label="systemic\nflare"]
    IL6    -> CRP_ESR      [label="hepatic\nAPR"]
    CRP_ESR-> BVAS_score   [label="composite\nscore"]

    // Renal -> Endpoints
    GFR_node   -> BVAS_score  [label="renal\ncomponent"]
    RPGN       -> BVAS_score  [label="active GN"]
    GFR_node   -> ESRD_end   [label="GFR<15\n→ ESRD"]
    Creatinine -> BVAS_score  [label="renal\nimpairment"]

    // Pulmonary -> Endpoints
    DAH        -> BVAS_score  [label="pulmonary\ncomponent"]
    Resp_fail  -> Mortality
    DLCO_node  -> QoL         [label="exercise\ntolerance"]
    Hemoptysis -> BVAS_score  [label="pulmonary\nflare"]

    // Drug PK -> PD
    OH_CY     -> Plasma_cell  [label="DNA alkylation\nB/T cell kill", color="#AA0000"]
    OH_CY     -> GC_B        [label="lymphotoxicity", color="#AA0000"]
    OH_CY     -> Th1         [label="T cell\nsuppression", color="#AA0000"]
    OH_CY     -> Th17        [label="Th17\nsuppression", color="#AA0000"]
    OH_CY     -> CY_tox      [label="acrolein →\nbladder/gonad"]

    RTX_C     -> CD20_depl   [label="ADCC/CDC\nlysis"]
    CD20_Ag   -> CD20_depl   [label="RTX target"]

    PRED_C    -> GC_suppr    [label="GR binding\nnGRE/transrepression"]
    GC_suppr  -> Th17        [label="IL-17↓", color="#0000AA"]
    GC_suppr  -> TNFa        [label="TNF-α↓", color="#0000AA"]
    GC_suppr  -> IL1b        [label="IL-1β↓", color="#0000AA"]
    GC_suppr  -> Endothel_act [label="anti-inflam.", color="#0000AA"]
    GC_suppr  -> NLRP3       [label="inflammasome↓", color="#0000AA"]

    AZA_oral  -> GC_B        [label="6-MP: purine\nantagonist", color="#AA0000"]
    AZA_oral  -> Th1         [label="T cell\nsuppression", color="#AA0000"]

    MMF_oral  -> GC_B        [label="IMPDH\ninhibition", color="#AA0000"]
    MMF_oral  -> Plasma_cell [label="IMP → GMP\nblockade", color="#AA0000"]

    PLEX_treat-> MPO_ANCA    [label="antibody\nremoval", color="#0000AA"]
    PLEX_treat-> ANCA_titer  [label="rapid↓\n50-70%/session", color="#0000AA"]
    PLEX_treat-> C5a         [label="complement\nremoval", color="#0000AA"]

    Avacopan  -> C5aR1       [label="C5aR1 blockade\n(oral, Kd<1nM)", color="#0000AA"]
    Avacopan  -> Neut_prime  [label="PMN priming↓", color="#0000AA"]
    Avacopan  -> BVAS_score  [label="non-inferior\nto prednisone", color="#0000AA"]

    // Endpoints
    ANCA_titer -> BVAS_score
    CD20_depl  -> ANCA_suppr
    ANCA_suppr -> Comp_remiss [label="sustained\nANCA neg."]
    B_repop    -> GC_B       [label="→ ANCA\nresurgence"]

    // Caption
    Caption [label="MPA QSP Model v1.0 | Date: 2026-06-20\nNodes: 160+ | Clusters: 11\nKey drugs: CY · RTX · PRED · AZA · MMF · PLEX · Avacopan\nKey trials: RAVE · RITUXVAS · MYCYC · IMPROVE · MAINRITSAN · PEXIVAS · ADVOCATE",
             shape=note, fillcolor="#FFFFCC", style=filled, fontsize=9, margin="0.2,0.1"]
}
