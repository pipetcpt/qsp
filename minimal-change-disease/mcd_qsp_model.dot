digraph MCD_QSP_Model {
    // Global graph settings
    rankdir=LR;
    graph [
        label="Minimal Change Disease (MCD) — Quantitative Systems Pharmacology Model\nMechanistic Map: Genetic Susceptibility → Immune Dysregulation → Podocyte Injury → Nephrotic Syndrome → Clinical Consequences",
        labelloc=t,
        labeljust=c,
        fontname="Helvetica",
        fontsize=16,
        fontcolor="#1a1a2e",
        bgcolor="white",
        splines=ortho,
        nodesep=0.4,
        ranksep=0.8,
        pad=0.5
    ];
    node [fontname="Helvetica", fontsize=10, style=filled, shape=box, margin="0.15,0.08"];
    edge [fontname="Helvetica", fontsize=8, color="#555555"];

    // =========================================================
    // CLUSTER 1: Genetic Susceptibility Factors
    // =========================================================
    subgraph cluster_genetic {
        label="Genetic Susceptibility";
        style=filled;
        color="#4a90d9";
        fillcolor="#dbeafe";
        fontname="Helvetica Bold";
        fontsize=12;
        fontcolor="#1e3a5f";

        HLA_DR7    [label="HLA-DR7\n(MHC class II)",        fillcolor="lightblue"];
        HLA_DQB1   [label="HLA-DQB1*0302\n(MHC class II)", fillcolor="lightblue"];
        NPHS1_gene [label="NPHS1 gene\n(Nephrin locus)",    fillcolor="lightblue"];
        NPHS2_gene [label="NPHS2 gene\n(Podocin locus)",    fillcolor="lightblue"];
        WT1_gene   [label="WT1\n(Wilms Tumor 1 TF)",        fillcolor="lightblue"];
        PLCE1_gene [label="PLCE1\n(Phospholipase Cε1)",     fillcolor="lightblue"];
        LAMB2_gene [label="LAMB2\n(Laminin β2 chain)",      fillcolor="lightblue"];
        SMARCAL1   [label="SMARCAL1\n(DNA remodeling)",     fillcolor="lightblue"];
    }

    // =========================================================
    // CLUSTER 2: Environmental Triggers
    // =========================================================
    subgraph cluster_trigger {
        label="Environmental Triggers";
        style=filled;
        color="#e67e22";
        fillcolor="#fef3c7";
        fontname="Helvetica Bold";
        fontsize=12;
        fontcolor="#7c4a00";

        Viral_URI   [label="Viral Upper\nRespiratory Infection",  fillcolor="lightyellow"];
        EBV         [label="EBV / CMV\nInfection",               fillcolor="lightyellow"];
        Allergen    [label="Allergen Exposure\n(atopy, food)",    fillcolor="lightyellow"];
        NSAID_trig  [label="NSAIDs / COX-1\nInhibitors",         fillcolor="lightyellow"];
        Vaccines    [label="Vaccines\n(hepatitis, influenza)",    fillcolor="lightyellow"];
        BeeStings   [label="Bee Stings /\nHymenoptera",          fillcolor="lightyellow"];
        Lymphoma    [label="Hodgkin Lymphoma\n(paraneoplastic)",  fillcolor="lightyellow"];
        Thymoma     [label="Thymoma\n(paraneoplastic)",           fillcolor="lightyellow"];
        Lithium_trig[label="Lithium / Gold\nDrug-induced",        fillcolor="lightyellow"];
    }

    // =========================================================
    // CLUSTER 3: T Cell Receptor Signaling & Immune Activation
    // =========================================================
    subgraph cluster_immune_activation {
        label="T Cell Receptor Signaling & Immune Activation";
        style=filled;
        color="#27ae60";
        fillcolor="#d1fae5";
        fontname="Helvetica Bold";
        fontsize=12;
        fontcolor="#064e3b";

        TCR        [label="T Cell Receptor (TCR)\nαβ heterodimer",   fillcolor="lightgreen"];
        CD3        [label="CD3 Complex\n(ζ, γ, δ, ε chains)",        fillcolor="lightgreen"];
        CD4        [label="CD4 Co-receptor\n(MHC class II binding)",  fillcolor="lightgreen"];
        ZAP70      [label="ZAP-70\n(Tyrosine kinase)",               fillcolor="wheat"];
        LAT        [label="LAT\n(Linker for Activation of T cells)", fillcolor="wheat"];
        SLP76      [label="SLP-76\n(Scaffold protein)",              fillcolor="wheat"];
        PLCg1      [label="PLCγ1\n(Phospholipase Cγ1)",             fillcolor="wheat"];
        IP3        [label="IP3\n(Inositol triphosphate)",            fillcolor="wheat"];
        DAG        [label="DAG\n(Diacylglycerol)",                   fillcolor="wheat"];
        Ca2plus    [label="Ca²⁺ release\n(ER store)",               fillcolor="wheat"];
        PKC_theta  [label="PKCθ\n(Protein kinase Cθ)",              fillcolor="wheat"];
        Calcineurin[label="Calcineurin\n(Phosphatase PP2B)",         fillcolor="wheat"];
        NFAT       [label="NFAT\n(Nuclear Factor Activated T cells)",fillcolor="wheat"];
        NFkB       [label="NF-κB\n(p65/p50 dimer)",                  fillcolor="wheat"];
        AP1        [label="AP-1\n(Fos/Jun)",                         fillcolor="wheat"];
        mTOR       [label="mTOR\n(mTORC1/mTORC2)",                  fillcolor="wheat"];
        PI3K_T     [label="PI3K\n(p110δ in T cells)",               fillcolor="wheat"];
        Akt_T      [label="Akt / PKB\n(T cell)",                    fillcolor="wheat"];
        CTLA4      [label="CTLA-4\n(Immune checkpoint)",             fillcolor="lightgreen"];
        PD1        [label="PD-1\n(Programmed death-1)",              fillcolor="lightgreen"];
    }

    // =========================================================
    // CLUSTER 4: T Cell Subsets & Cytokines
    // =========================================================
    subgraph cluster_tcell_subsets {
        label="T Cell Subsets & Cytokine Milieu";
        style=filled;
        color="#8e44ad";
        fillcolor="#ede9fe";
        fontname="Helvetica Bold";
        fontsize=12;
        fontcolor="#3b0764";

        Th0        [label="Naïve CD4+ T cell\n(Th0)",              fillcolor="lightgreen"];
        Th2        [label="Th2 Cells\n(key in MCD)",               fillcolor="lightgreen"];
        Th1        [label="Th1 Cells\n(regulatory)",               fillcolor="lightgreen"];
        Th17       [label="Th17 Cells",                             fillcolor="lightgreen"];
        Treg       [label="Regulatory T cells\n(Treg)",            fillcolor="lightgreen"];
        Tfh        [label="Follicular Th cells\n(Tfh)",            fillcolor="lightgreen"];

        IL4        [label="IL-4\n(Th2 cytokine)",                  fillcolor="lightyellow"];
        IL5        [label="IL-5\n(Eosinophil activator)",          fillcolor="lightyellow"];
        IL13       [label="IL-13\n(B cell activation)",            fillcolor="lightyellow"];
        IL25       [label="IL-25 / IL-17E\n(Th2 inducer)",        fillcolor="lightyellow"];
        IL33       [label="IL-33\n(Alarmin, ST2 ligand)",          fillcolor="lightyellow"];
        IFNg       [label="IFN-γ\n(Th1 effector)",                fillcolor="lightyellow"];
        IL2        [label="IL-2\n(T cell growth factor)",          fillcolor="lightyellow"];
        IL12       [label="IL-12\n(Th1 inducing)",                 fillcolor="lightyellow"];
        IL17A      [label="IL-17A\n(Th17 effector)",               fillcolor="lightyellow"];
        IL17F      [label="IL-17F\n(Th17 effector)",               fillcolor="lightyellow"];
        IL21       [label="IL-21\n(Tfh/Th17 cytokine)",            fillcolor="lightyellow"];
        IL23       [label="IL-23\n(Th17 stabilizer)",              fillcolor="lightyellow"];
        FOXP3      [label="FOXP3\n(Treg master TF)",               fillcolor="lightgreen"];
        IL10       [label="IL-10\n(Anti-inflammatory)",            fillcolor="lightyellow"];
        IL6        [label="IL-6\n(Pleiotropic cytokine)",          fillcolor="lightyellow"];
        TGFb       [label="TGF-β\n(Immunosuppressive)",            fillcolor="lightyellow"];
        CXCR5      [label="CXCR5\n(Tfh homing receptor)",         fillcolor="lightgreen"];
    }

    // =========================================================
    // CLUSTER 5: B Cell Activation & Antibody Production
    // =========================================================
    subgraph cluster_bcell {
        label="B Cell Activation & Antibody Production";
        style=filled;
        color="#2980b9";
        fillcolor="#dbeafe";
        fontname="Helvetica Bold";
        fontsize=12;
        fontcolor="#1e3a8a";

        Bcell      [label="Naïve B Cell\n(CD19+CD20+)",            fillcolor="lightblue"];
        CD19       [label="CD19\n(B cell co-receptor)",             fillcolor="lightblue"];
        CD20       [label="CD20\n(B cell marker)",                  fillcolor="lightblue"];
        BTK        [label="BTK\n(Bruton Tyrosine Kinase)",          fillcolor="wheat"];
        BCR        [label="BCR\n(B cell receptor complex)",         fillcolor="lightblue"];
        GCB        [label="Germinal Center\nB cell (GCB)",          fillcolor="lightblue"];
        PlasmaCell [label="Plasma Cell\n(antibody secreting)",      fillcolor="lightblue"];
        IgE        [label="IgE Production\n(class switch)",         fillcolor="lightyellow"];
        Anti_nephrin[label="Anti-nephrin\nAntibodies (IgG4)",       fillcolor="lightyellow"];
        MemoryB    [label="Memory B Cell",                          fillcolor="lightblue"];
        BAFF       [label="BAFF / BLyS\n(B cell survival factor)", fillcolor="lightyellow"];
        APRIL      [label="APRIL\n(Proliferation factor)",         fillcolor="lightyellow"];
    }

    // =========================================================
    // CLUSTER 6: Circulating Permeability Factors
    // =========================================================
    subgraph cluster_permeability_factor {
        label="Circulating Permeability Factors";
        style=filled;
        color="#c0392b";
        fillcolor="#fee2e2";
        fontname="Helvetica Bold";
        fontsize=12;
        fontcolor="#7f1d1d";

        suPAR      [label="suPAR\n(Soluble uPAR — CD87)",          fillcolor="lightsalmon"];
        Hemopexin  [label="Hemopexin\n(Heme-binding protein)",      fillcolor="lightsalmon"];
        CLC1       [label="Cardiotrophin-like\nCytokine-1 (CLC-1)", fillcolor="lightsalmon"];
        VPF        [label="Vascular Permeability\nFactor (VPF)",    fillcolor="lightsalmon"];
        VEGF_circ  [label="Circulating VEGF\n(systemic)",           fillcolor="lightsalmon"];
        Angpt2     [label="Angiopoietin-2\n(destabilizes vessels)", fillcolor="lightsalmon"];
        uPAR_pod   [label="uPAR on Podocyte\n(CD87 receptor)",      fillcolor="lightsalmon"];
        integrin_b3[label="αvβ3 Integrin\n(suPAR receptor)",        fillcolor="lightsalmon"];
    }

    // =========================================================
    // CLUSTER 7: Podocyte Biology & Slit Diaphragm
    // =========================================================
    subgraph cluster_podocyte {
        label="Podocyte Biology & Slit Diaphragm Signaling";
        style=filled;
        color="#e74c3c";
        fillcolor="#fce4ec";
        fontname="Helvetica Bold";
        fontsize=12;
        fontcolor="#7f1d1d";

        Nephrin    [label="Nephrin (NPHS1)\n(slit diaphragm)",      fillcolor="lightcoral"];
        Podocin    [label="Podocin (NPHS2)\n(lipid raft anchor)",   fillcolor="lightcoral"];
        CD2AP      [label="CD2AP\n(actin linker)",                   fillcolor="lightcoral"];
        Actinin4   [label="α-Actinin-4\n(ACTN4)",                   fillcolor="lightcoral"];
        Synaptopodin[label="Synaptopodin\n(actin stabilizer)",      fillcolor="lightcoral"];
        TRPC6      [label="TRPC6 Channel\n(Ca²⁺ entry)",           fillcolor="lightcoral"];
        WT1_pod    [label="WT1 TF\n(podocyte survival)",            fillcolor="lightcoral"];
        Cofilin1   [label="Cofilin-1\n(actin severing)",            fillcolor="lightcoral"];
        RhoA       [label="RhoA GTPase\n(stress fibers)",           fillcolor="wheat"];
        Rac1       [label="Rac1 GTPase\n(lamellipodia)",            fillcolor="wheat"];
        Cdc42      [label="Cdc42 GTPase\n(filopodia)",              fillcolor="wheat"];
        ActinPoly  [label="Actin Polymerization\n(foot processes)", fillcolor="lightcoral"];
        FPE        [label="Foot Process\nEffacement (FPE)",          fillcolor="lightcoral", shape=diamond];
        ZO1        [label="ZO-1\n(tight junction protein)",         fillcolor="lightcoral"];
        Neph1      [label="Neph1 (KIRREL)\n(slit junction)",        fillcolor="lightcoral"];
        VEGFA_pod  [label="VEGF-A secretion\n(by podocytes)",       fillcolor="lightcoral"];
        Angpt1     [label="Angiopoietin-1\n(Tie2 ligand)",          fillcolor="lightcoral"];
        PI3K_pod   [label="PI3K\n(podocyte survival)",              fillcolor="wheat"];
        Akt_pod    [label="Akt / PKB\n(podocyte)",                  fillcolor="wheat"];
        mTORC2_pod [label="mTORC2\n(podocyte actin)",              fillcolor="wheat"];
        p38MAPK    [label="p38 MAPK\n(stress kinase)",             fillcolor="wheat"];
        SrcKinase  [label="Src Kinase\n(Nephrin phosphorylation)", fillcolor="wheat"];
    }

    // =========================================================
    // CLUSTER 8: Glomerular Filtration Barrier (GBM)
    // =========================================================
    subgraph cluster_gbm {
        label="Glomerular Filtration Barrier";
        style=filled;
        color="#16a085";
        fillcolor="#d1fae5";
        fontname="Helvetica Bold";
        fontsize=12;
        fontcolor="#064e3b";

        GBM        [label="GBM\n(Glomerular Basement Membrane)",    fillcolor="lightcoral"];
        Laminin521 [label="Laminin-521\n(α5β2γ1 trimer)",          fillcolor="lightcoral"];
        ColIVa3a4  [label="Collagen IV α3α4α5\n(GBM scaffold)",    fillcolor="lightcoral"];
        Agrin      [label="Agrin\n(heparan sulfate PG)",            fillcolor="lightcoral"];
        HSPG       [label="HSPG\n(Heparan Sulfate PG — charge barrier)", fillcolor="lightcoral"];
        Perlecan   [label="Perlecan\n(basement membrane PG)",       fillcolor="lightcoral"];
        Glycocalyx [label="Endothelial Glycocalyx\n(charge barrier)",fillcolor="lightcoral"];
        Syndecan4  [label="Syndecan-4\n(PG on endothelium)",        fillcolor="lightcoral"];
        Glypican1  [label="Glypican-1\n(GPI-anchored PG)",          fillcolor="lightcoral"];
        FenestEnd  [label="Fenestrated\nEndothelium",               fillcolor="lightcoral"];
        FiltrSlit  [label="Filtration Slit\n(~40 nm width)",        fillcolor="lightcoral"];
        BarrierInt [label="Barrier Integrity\n(charge + size)",     fillcolor="lightcoral", shape=diamond];
    }

    // =========================================================
    // CLUSTER 9: Tubular Handling
    // =========================================================
    subgraph cluster_tubule {
        label="Proximal Tubule Albumin Handling";
        style=filled;
        color="#7f8c8d";
        fillcolor="#f1f5f9";
        fontname="Helvetica Bold";
        fontsize=12;
        fontcolor="#1e293b";

        Megalin    [label="Megalin (LRP2)\n(endocytic receptor)",   fillcolor="lightblue"];
        Cubilin    [label="Cubilin\n(co-receptor)",                  fillcolor="lightblue"];
        LysoDeg    [label="Lysosomal\nDegradation",                 fillcolor="lightblue"];
        THP        [label="Tamm-Horsfall Protein\n(uromodulin)",    fillcolor="lightblue"];
        TubInj     [label="Tubulo-interstitial\nInjury",             fillcolor="lightsalmon"];
    }

    // =========================================================
    // CLUSTER 10: Proteinuria & Nephrotic Syndrome
    // =========================================================
    subgraph cluster_proteinuria {
        label="Proteinuria & Nephrotic Syndrome Definition";
        style=filled;
        color="#d35400";
        fillcolor="#fff7ed";
        fontname="Helvetica Bold";
        fontsize=12;
        fontcolor="#7c2d12";

        AlbFilt    [label="Albumin Filtration\n(normally <30 mg/day)",fillcolor="lightsalmon"];
        IgGFilt    [label="IgG Filtration\n(selectivity marker)",    fillcolor="lightsalmon"];
        LMWprot    [label="Low-MW Proteins\n(β2-microglobulin, RBP)",fillcolor="lightsalmon"];
        UrProt35   [label="Proteinuria\n>3.5 g/day (nephrotic)",    fillcolor="lightsalmon", shape=diamond];
        UPCR       [label="UPCR\n(Urine Protein/Creatinine >3500 mg/g)", fillcolor="lightsalmon"];
        UACR       [label="UACR\n(Urine Albumin/Creatinine ratio)", fillcolor="lightsalmon"];
        Lipiduria  [label="Lipiduria\n(Oval fat bodies)",            fillcolor="lightsalmon"];
        SelectIndex[label="Selectivity Index\n(IgG/Transferrin ratio)", fillcolor="lightsalmon"];
    }

    // =========================================================
    // CLUSTER 11: Clinical Consequences (Nephrotic Syndrome)
    // =========================================================
    subgraph cluster_consequences {
        label="Clinical Consequences — Nephrotic Syndrome";
        style=filled;
        color="#c0392b";
        fillcolor="#fde8e8";
        fontname="Helvetica Bold";
        fontsize=12;
        fontcolor="#7f1d1d";

        HypoAlb    [label="Hypoalbuminemia\n(<25 g/L)",             fillcolor="lightsalmon"];
        OncoPress  [label="Oncotic Pressure ↓\n(colloid osmotic P)",fillcolor="lightsalmon"];
        NaRetent   [label="Na+/Water Retention\n(underfill/overflow)",fillcolor="lightsalmon"];
        RAAS_act   [label="RAAS Activation\n(renin-angiotensin-aldo)", fillcolor="lightsalmon"];
        Renin      [label="Renin↑\n(juxtaglomerular)",              fillcolor="lightsalmon"];
        AngII      [label="Angiotensin II↑",                        fillcolor="lightsalmon"];
        Aldosterone[label="Aldosterone↑\n(Na+ reabsorption)",       fillcolor="lightsalmon"];
        ANP_BNP    [label="ANP/BNP\n(atrial natriuretic peptides)", fillcolor="lightsalmon"];
        AQP2       [label="AQP2 Upregulation\n(water channel)",     fillcolor="lightsalmon"];
        Edema      [label="Edema Formation\n(periorbital, pitting)", fillcolor="lightsalmon", shape=diamond];
        Ascites    [label="Ascites\n(peritoneal fluid)",             fillcolor="lightsalmon"];
        PleuralEff [label="Pleural Effusion",                       fillcolor="lightsalmon"];
    }

    // =========================================================
    // CLUSTER 12: Lipid Metabolism Dysregulation
    // =========================================================
    subgraph cluster_lipid {
        label="Lipid Metabolism in Nephrotic Syndrome";
        style=filled;
        color="#f39c12";
        fillcolor="#fef9c3";
        fontname="Helvetica Bold";
        fontsize=12;
        fontcolor="#78350f";

        HepaticVLDL[label="Hepatic VLDL\nOverproduction",           fillcolor="lightyellow"];
        LPL_reduce [label="LPL Activity↓\n(lipoprotein lipase)",    fillcolor="lightyellow"];
        Hypercholest[label="Hypercholesterolemia\n(>200 mg/dL)",    fillcolor="lightyellow"];
        Hypertrig  [label="Hypertriglyceridemia\n(>150 mg/dL)",     fillcolor="lightyellow"];
        ElevLDL    [label="Elevated LDL\n(small dense LDL)",        fillcolor="lightyellow"];
        ApoB100    [label="Apo B-100↑\n(VLDL/LDL scaffold)",       fillcolor="lightyellow"];
        ApoCIII    [label="Apo CIII↑\n(LPL inhibitor)",            fillcolor="lightyellow"];
        PCSK9_up   [label="PCSK9 Upregulation\n(LDL-R degradation)",fillcolor="lightyellow"];
        LipiduriaOut[label="Lipiduria Output\n(lipid casts)",       fillcolor="lightyellow"];
    }

    // =========================================================
    // CLUSTER 13: Renal Function
    // =========================================================
    subgraph cluster_renal_function {
        label="Renal Function & Progression";
        style=filled;
        color="#0891b2";
        fillcolor="#e0f7fa";
        fontname="Helvetica Bold";
        fontsize=12;
        fontcolor="#0c4a6e";

        eGFR       [label="eGFR\n(CKD-EPI, mL/min/1.73m²)",       fillcolor="lightblue"];
        SerumCr    [label="Serum Creatinine\n(mg/dL)",              fillcolor="lightblue"];
        BUN        [label="BUN\n(Blood Urea Nitrogen)",             fillcolor="lightblue"];
        SecFSGS    [label="Secondary FSGS\n(steroid-resistant MCD)",fillcolor="lightsalmon"];
        AKI_risk   [label="AKI Risk\n(acute kidney injury)",        fillcolor="lightsalmon"];
    }

    // =========================================================
    // CLUSTER 14: Coagulation / Thrombosis
    // =========================================================
    subgraph cluster_coagulation {
        label="Hypercoagulability in Nephrotic Syndrome";
        style=filled;
        color="#6d28d9";
        fillcolor="#ede9fe";
        fontname="Helvetica Bold";
        fontsize=12;
        fontcolor="#3b0764";

        HyperCoag  [label="Hypercoagulable State",                  fillcolor="lightyellow"];
        ATIII_loss [label="AT-III Loss\n(urinary)",                  fillcolor="lightyellow"];
        ProtS_loss [label="Protein S/C Loss\n(urinary)",            fillcolor="lightyellow"];
        FibrinUp   [label="Fibrinogen↑\n(acute phase)",             fillcolor="lightyellow"];
        DVT_PE     [label="DVT / PE Risk↑\n(venous thromboembolism)",fillcolor="lightsalmon", shape=diamond];
        RenalVeinT [label="Renal Vein\nThrombosis",                 fillcolor="lightsalmon"];
        Plt_activ  [label="Platelet Activation↑",                   fillcolor="lightyellow"];
    }

    // =========================================================
    // CLUSTER 15: Drug PK
    // =========================================================
    subgraph cluster_drugs_pk {
        label="Drug Pharmacokinetics";
        style=filled;
        color="#be185d";
        fillcolor="#fce7f3";
        fontname="Helvetica Bold";
        fontsize=12;
        fontcolor="#831843";

        // Prednisolone / Prednisone
        Pred_depot [label="Prednisone\n(prodrug, oral)",            fillcolor="lightpink"];
        Pred_Cp    [label="Prednisolone Cp\n(active drug, central)", fillcolor="lightpink"];
        Pred_periph[label="Prednisolone\n(peripheral compartment)", fillcolor="lightpink"];

        // Cyclosporine
        CsA_gut    [label="CsA Absorption\n(P-gp efflux in gut)",   fillcolor="lightpink"];
        CsA_Cp     [label="CsA Cp\n(CYP3A4 metabolism)",            fillcolor="lightpink"];
        CsA_PBMC   [label="CsA in PBMC\n(intracellular)",           fillcolor="lightpink"];

        // Tacrolimus
        Tacro_Cp   [label="Tacrolimus Cp\n(FK506, narrow TI)",      fillcolor="lightpink"];
        Tacro_RBC  [label="Tacrolimus\n(RBC-bound 99%)",            fillcolor="lightpink"];

        // Rituximab
        Rtx_Cp     [label="Rituximab Cp\n(TMDD — central)",         fillcolor="lightpink"];
        Rtx_periph [label="Rituximab\n(peripheral compartment)",     fillcolor="lightpink"];
        CD20_bound [label="CD20-Rituximab\n(target complex)",        fillcolor="lightpink"];

        // Cyclophosphamide
        Cyc_prodrug[label="Cyclophosphamide\n(prodrug, oral/IV)",    fillcolor="lightpink"];
        Cyc_4OH    [label="4-OH-Cyclophosphamide\n(active metabolite)", fillcolor="lightpink"];
        Acrolein   [label="Acrolein\n(toxic metabolite → bladder)",  fillcolor="lightpink"];

        // MMF / MPA
        MMF_oral   [label="MMF\n(Mycophenolate mofetil, oral)",      fillcolor="lightpink"];
        MPA_Cp     [label="MPA Cp\n(active acid form)",              fillcolor="lightpink"];
        MPA_MPAG   [label="MPAG\n(inactive glucuronide)",            fillcolor="lightpink"];

        // ACTH
        ACTH_depot [label="ACTH Depot\n(Acthar Gel, SC/IM)",         fillcolor="lightpink"];
        ACTH_Cp    [label="ACTH Cp\n(active peptide)",               fillcolor="lightpink"];
    }

    // =========================================================
    // CLUSTER 16: Drug PD / Mechanisms of Action
    // =========================================================
    subgraph cluster_drugs_pd {
        label="Drug Pharmacodynamics & Mechanisms of Action";
        style=filled;
        color="#7c3aed";
        fillcolor="#f5f3ff";
        fontname="Helvetica Bold";
        fontsize=12;
        fontcolor="#4c1d95";

        GR_complex [label="GR-Prednisolone\nComplex (nuclear)",     fillcolor="plum"];
        GR_transrep[label="GR Transrepression\n(NF-κB/AP-1 block)", fillcolor="plum"];
        GR_transact[label="GR Transactivation\n(anti-inflam genes)",fillcolor="plum"];
        CaN_inhib  [label="Calcineurin Inhibition\n(CsA-CypA/FK506-FKBP12)", fillcolor="plum"];
        NFAT_block [label="NFAT Nuclear\nTranslocation ↓",          fillcolor="plum"];
        CD20_depl  [label="CD20 Depletion\n(ADCC + CDC)",           fillcolor="plum"];
        BCR_signal [label="BCR Signaling ↓\n(Rituximab downstream)",fillcolor="plum"];
        IMPDH_inhib[label="IMPDH Inhibition\n(MPA blocks guanosine)",fillcolor="plum"];
        DNA_alkyl  [label="DNA Alkylation\n(Cyclophosphamide)",      fillcolor="plum"];
        Bcell_deplete[label="B Cell Depletion\n(Cyclophosphamide)", fillcolor="plum"];
        ACEi_block [label="ACEi/ARB\n(RAAS blockade — reno-protect)", fillcolor="plum"];
        AngII_inhib[label="Ang II ↓\n(ACEi/ARB effect)",            fillcolor="plum"];
        ACTH_MCR   [label="ACTH→MC1R/MC3R\n(melanocortin receptors)",fillcolor="plum"];
        ACTH_pod   [label="ACTH direct\npodocyte effect",           fillcolor="plum"];
        mTOR_inhib_drug[label="mTOR Inhibitor\n(Sirolimus — rescue)",fillcolor="plum"];
        Rituximab  [label="Rituximab\n(anti-CD20 mAb)",             fillcolor="plum"];
        Prednisone [label="Prednisone /\nPrednisolone",             fillcolor="plum"];
        Cyclosporine[label="Cyclosporine A\n(CsA)",                 fillcolor="plum"];
        Tacrolimus [label="Tacrolimus\n(FK506)",                    fillcolor="plum"];
        Cyclophosphamide_drug[label="Cyclophosphamide\n(alkylating agent)", fillcolor="plum"];
        MMF_drug   [label="MMF / MPA\n(antimetabolite)",            fillcolor="plum"];
        ACTH_drug  [label="ACTH\n(Acthar Gel)",                     fillcolor="plum"];
    }

    // =========================================================
    // EDGES: Genetic → Susceptibility
    // =========================================================
    HLA_DR7    -> TCR     [label="presents Ag", color="#4a90d9"];
    HLA_DQB1   -> TCR     [label="presents Ag", color="#4a90d9"];
    NPHS1_gene -> Nephrin  [label="encodes", color="#4a90d9"];
    NPHS2_gene -> Podocin  [label="encodes", color="#4a90d9"];
    WT1_gene   -> WT1_pod  [label="encodes", color="#4a90d9"];
    PLCE1_gene -> PLCg1    [label="encodes PLC", color="#4a90d9"];
    LAMB2_gene -> Laminin521[label="encodes β2", color="#4a90d9"];
    SMARCAL1   -> WT1_pod  [label="chromatin\nremodeling", color="#4a90d9"];

    // =========================================================
    // EDGES: Environmental Triggers → Immune Activation
    // =========================================================
    Viral_URI  -> TCR     [label="viral Ag\npresentation", color="#e67e22"];
    EBV        -> Bcell   [label="B cell\ninfection", color="#e67e22"];
    Allergen   -> Th2     [label="Th2 skewing", color="#e67e22"];
    NSAID_trig -> Th2     [label="COX-1 inhib\n→Th2 shift", color="#e67e22"];
    Vaccines   -> TCR     [label="adjuvant\nactivation", color="#e67e22"];
    BeeStings  -> IL33    [label="alarmin\nrelease", color="#e67e22"];
    Lymphoma   -> VPF     [label="tumor\nderived VPF", color="#e67e22"];
    Thymoma    -> Treg    [label="Treg\ndysregulation", color="#e67e22"];
    Lithium_trig -> NFkB  [label="NF-κB\nactivation", color="#e67e22"];

    // =========================================================
    // EDGES: TCR Signaling Cascade
    // =========================================================
    TCR        -> CD3     [label="forms\ncomplex"];
    CD4        -> TCR     [label="co-receptor\nstabilizes"];
    CD3        -> ZAP70   [label="ITAM\nphosphorylation"];
    ZAP70      -> LAT     [label="phosphorylates"];
    ZAP70      -> SLP76   [label="phosphorylates"];
    LAT        -> PLCg1   [label="recruits"];
    SLP76      -> PLCg1   [label="scaffold"];
    PLCg1      -> IP3     [label="cleaves PIP2\n→IP3"];
    PLCg1      -> DAG     [label="cleaves PIP2\n→DAG"];
    IP3        -> Ca2plus  [label="ER Ca²⁺\nrelease"];
    Ca2plus    -> Calcineurin [label="activates"];
    DAG        -> PKC_theta [label="activates"];
    PKC_theta  -> NFkB    [label="IKK activation\n→NF-κB"];
    Calcineurin -> NFAT   [label="dephosphorylates\n(nuclear import)"];
    NFAT       -> IL2     [label="transcribes"];
    NFAT       -> IL4     [label="transcribes"];
    NFkB       -> IL2     [label="transcribes"];
    NFkB       -> IL6     [label="transcribes", color="#888888"];
    AP1        -> IL2     [label="transcribes"];
    ZAP70      -> PI3K_T  [label="activates"];
    PI3K_T     -> Akt_T   [label="PIP3→Akt"];
    Akt_T      -> mTOR    [label="activates\nmTORC1"];
    CTLA4      -> ZAP70   [label="inhibits\n(checkpoint)", color="red", style=dashed];
    PD1        -> PI3K_T  [label="inhibits\n(checkpoint)", color="red", style=dashed];

    // =========================================================
    // EDGES: T Cell Differentiation
    // =========================================================
    Th0        -> Th2     [label="IL-4 skewing"];
    Th0        -> Th1     [label="IL-12 skewing"];
    Th0        -> Th17    [label="IL-6+TGF-β\nskewing"];
    Th0        -> Treg    [label="TGF-β+IL-2\nskewing"];
    Th0        -> Tfh     [label="IL-21+CXCR5"];
    IL4        -> Th0     [label="promotes\nTh2 fate"];
    IL12       -> Th1     [label="promotes\nTh1 fate"];
    Th2        -> IL4     [label="secretes", color="#8e44ad"];
    Th2        -> IL5     [label="secretes", color="#8e44ad"];
    Th2        -> IL13    [label="secretes", color="#8e44ad"];
    Th1        -> IFNg    [label="secretes", color="#8e44ad"];
    Th1        -> IL2     [label="secretes", color="#8e44ad"];
    Th17       -> IL17A   [label="secretes", color="#8e44ad"];
    Th17       -> IL17F   [label="secretes", color="#8e44ad"];
    Th17       -> IL21    [label="secretes", color="#8e44ad"];
    IL23       -> Th17    [label="maintains\nTh17"];
    Treg       -> FOXP3   [label="expresses"];
    Treg       -> IL10    [label="secretes", color="#8e44ad"];
    Treg       -> TGFb    [label="secretes", color="#8e44ad"];
    IL10       -> Th2     [label="counter-reg", color="red", style=dashed];
    Tfh        -> IL21    [label="secretes"];
    Tfh        -> CXCR5   [label="expresses"];
    IL33       -> Th2     [label="amplifies\nTh2"];
    IL25       -> Th2     [label="Th2 inducer"];

    // =========================================================
    // EDGES: B Cell Activation & Antibody Production
    // =========================================================
    Bcell      -> CD19    [label="co-receptor"];
    Bcell      -> CD20    [label="expresses"];
    Bcell      -> BCR     [label="surface receptor"];
    IL4        -> Bcell   [label="class switch\nto IgE"];
    IL13       -> Bcell   [label="class switch\nto IgE"];
    IL21       -> Bcell   [label="GC reaction"];
    BCR        -> BTK     [label="activates"];
    BTK        -> PLCg1   [label="phosphorylates"];
    BAFF       -> Bcell   [label="survival"];
    APRIL      -> Bcell   [label="proliferation"];
    Bcell      -> GCB     [label="germinal\ncenter"];
    GCB        -> PlasmaCell [label="differentiation"];
    GCB        -> MemoryB [label="memory\ngeneration"];
    PlasmaCell -> IgE     [label="secretes"];
    PlasmaCell -> Anti_nephrin [label="secretes\nIgG4"];
    Tfh        -> GCB     [label="cognate\nhelp"];

    // =========================================================
    // EDGES: Permeability Factor Production & Effects
    // =========================================================
    Th2        -> suPAR   [label="induces\nproduction", color="#c0392b"];
    Th17       -> suPAR   [label="induces", color="#c0392b"];
    PlasmaCell -> Hemopexin[label="indirect\neffect"];
    Lymphoma   -> CLC1    [label="tumor\nsecretes CLC-1"];
    suPAR      -> uPAR_pod [label="binds\n(CD87 on podocyte)"];
    suPAR      -> integrin_b3 [label="activates\nαvβ3"];
    integrin_b3 -> RhoA   [label="Rho-GEF\nactivation"];
    Hemopexin  -> Nephrin  [label="disrupts\nslit diaphragm", color="red"];
    CLC1       -> FPE     [label="induces FPE", color="red"];
    VEGF_circ  -> FenestEnd[label="maintains\nfenestrae"];
    Anti_nephrin -> Nephrin[label="antibody\nbinding → injury", color="red"];
    Anti_nephrin -> FPE   [label="causes FPE", color="red"];
    Angpt2     -> Glycocalyx[label="disrupts\nglycocalyx", color="red"];

    // =========================================================
    // EDGES: Podocyte Signaling & Structural Integrity
    // =========================================================
    Nephrin    -> Podocin  [label="anchors\nvia lipid raft"];
    Nephrin    -> CD2AP   [label="links to\nactin"];
    Nephrin    -> SrcKinase[label="activates\nSrc/Fyn"];
    SrcKinase  -> PI3K_pod [label="activates"];
    PI3K_pod   -> Akt_pod  [label="PIP3→Akt"];
    Akt_pod    -> mTORC2_pod[label="activates"];
    mTORC2_pod -> ActinPoly[label="regulates\nactin"];
    Podocin    -> TRPC6    [label="modulates\nCa²⁺ entry"];
    TRPC6      -> Ca2plus  [label="Ca²⁺ influx"];
    WT1_pod    -> Nephrin   [label="transcribes"];
    WT1_pod    -> Podocin   [label="transcribes"];
    CD2AP      -> Actinin4  [label="links"];
    Actinin4   -> ActinPoly [label="cross-links\nactin"];
    Synaptopodin -> RhoA   [label="stabilizes\nactin fibers"];
    RhoA       -> ActinPoly [label="stress fibers\nformed"];
    Rac1       -> ActinPoly [label="lamellipodia"];
    Cdc42      -> ActinPoly [label="filopodia"];
    Cofilin1   -> ActinPoly [label="severs\nactin", color="red"];
    p38MAPK    -> Cofilin1  [label="activates"];
    suPAR      -> RhoA     [label="activates\nvia αvβ3"];
    ActinPoly  -> FPE      [label="disruption\n→ FPE", color="red"];
    Nephrin    -> ZO1      [label="slit\ndiaphragm"];
    ZO1        -> Neph1    [label="junction\ncomplex"];
    Neph1      -> FiltrSlit [label="maintains\nslit"];
    VEGFA_pod  -> FenestEnd [label="endothelial\nsurvival"];
    Angpt1     -> FenestEnd [label="Tie2\nstabilization"];
    FPE        -> BarrierInt[label="disrupts", color="red"];
    FiltrSlit  -> BarrierInt[label="maintains"];

    // =========================================================
    // EDGES: GBM & Filtration Barrier
    // =========================================================
    Laminin521 -> GBM      [label="scaffold"];
    ColIVa3a4  -> GBM      [label="scaffold"];
    Agrin      -> GBM      [label="HS PG"];
    HSPG       -> GBM      [label="charge\nbarrier"];
    Perlecan   -> GBM      [label="PG component"];
    Glycocalyx -> FenestEnd[label="covers\nfenestrae"];
    Syndecan4  -> Glycocalyx[label="component"];
    Glypican1  -> Glycocalyx[label="component"];
    GBM        -> BarrierInt[label="size barrier"];
    HSPG       -> BarrierInt[label="charge barrier"];
    Glycocalyx -> BarrierInt[label="charge barrier"];
    BarrierInt -> AlbFilt  [label="breach→\nproteinuria", color="red"];

    // =========================================================
    // EDGES: Proteinuria → Nephrotic Syndrome
    // =========================================================
    AlbFilt    -> UrProt35 [label="albumin\nloss"];
    IgGFilt    -> SelectIndex[label="selectivity\ncalculation"];
    LMWprot    -> UrProt35 [label="contributes"];
    UrProt35   -> UPCR     [label="measured as"];
    UrProt35   -> UACR     [label="measured as"];
    UrProt35   -> HypoAlb  [label="urinary\nlosses", color="red"];
    Lipiduria  -> UPCR     [label="lipid casts"];

    // =========================================================
    // EDGES: Proximal Tubule Handling
    // =========================================================
    AlbFilt    -> Megalin  [label="endocytosis"];
    AlbFilt    -> Cubilin  [label="endocytosis"];
    Megalin    -> LysoDeg  [label="lysosomal\nprocessing"];
    Cubilin    -> LysoDeg  [label="lysosomal\nprocessing"];
    THP        -> AlbFilt  [label="tubular\nprotection"];
    LysoDeg    -> TubInj   [label="overload\n→ injury"];

    // =========================================================
    // EDGES: Nephrotic Consequences
    // =========================================================
    HypoAlb    -> OncoPress[label="reduced\nalbuminemia"];
    OncoPress  -> NaRetent [label="capillary\nultrafiltration↑"];
    NaRetent   -> RAAS_act [label="triggers"];
    RAAS_act   -> Renin    [label="activates"];
    Renin      -> AngII    [label="generates\nAng II"];
    AngII      -> Aldosterone[label="adrenal\nstimulation"];
    Aldosterone-> AQP2     [label="collecting\nduct"];
    ANP_BNP    -> NaRetent [label="counter-reg\n↓Na retention", color="red", style=dashed];
    NaRetent   -> Edema    [label="extravascular\nfluid"];
    Edema      -> Ascites  [label="severe"];
    Edema      -> PleuralEff[label="severe"];

    // =========================================================
    // EDGES: Lipid Metabolism
    // =========================================================
    HypoAlb    -> HepaticVLDL[label="↑synthetic\nresponse"];
    HepaticVLDL -> Hypercholest[label="↑TC"];
    HepaticVLDL -> Hypertrig  [label="↑TG"];
    LPL_reduce -> Hypertrig   [label="impaired\nclearance"];
    Hypertrig  -> ElevLDL    [label="CETP\nmediated"];
    Hypercholest-> ElevLDL   [label="VLDL→LDL"];
    ApoB100    -> HepaticVLDL [label="scaffold"];
    ApoCIII    -> LPL_reduce  [label="LPL\ninhibition", color="red"];
    PCSK9_up   -> ElevLDL    [label="↓LDL-R"];
    ElevLDL    -> LipiduriaOut[label="lipid\nfiltration"];
    LipiduriaOut -> Lipiduria [label="→oval fat\nbodies"];

    // =========================================================
    // EDGES: Renal Function
    // =========================================================
    FPE        -> eGFR     [label="initially\npreserved"];
    TubInj     -> eGFR     [label="↓ over time", color="red"];
    eGFR       -> SerumCr  [label="inverse\nrelation"];
    eGFR       -> BUN      [label="inverse\nrelation"];
    TubInj     -> SecFSGS  [label="FSGS\ntransition"];
    SecFSGS    -> AKI_risk [label="acute\ndecompensation"];

    // =========================================================
    // EDGES: Coagulation
    // =========================================================
    UrProt35   -> ATIII_loss [label="urinary\nAT-III loss"];
    UrProt35   -> ProtS_loss [label="urinary\nProtein S/C"];
    HypoAlb    -> FibrinUp  [label="↑fibrinogen\n(compensation)"];
    ATIII_loss -> HyperCoag  [label="anticoag loss\n→ prothrombotic"];
    ProtS_loss -> HyperCoag  [label="anticoag loss"];
    FibrinUp   -> HyperCoag  [label="procoagulant"];
    Plt_activ  -> HyperCoag  [label="platelet\nactivation"];
    HyperCoag  -> DVT_PE    [label="VTE risk"];
    HyperCoag  -> RenalVeinT[label="renal vein\nthrombosis"];

    // =========================================================
    // EDGES: Drug PK Internal
    // =========================================================
    Pred_depot -> Pred_Cp   [label="11β-HSD1\nactivation"];
    Pred_Cp    -> Pred_periph[label="distribution\nVd~0.7 L/kg"];
    Pred_periph -> Pred_Cp  [label="redistribution"];

    CsA_gut    -> CsA_Cp   [label="absorption\nF~30%"];
    CsA_Cp     -> CsA_PBMC [label="intracellular\nuptake"];

    Tacro_Cp   -> Tacro_RBC [label="99% RBC\nbound"];

    Rtx_Cp     -> CD20_bound [label="CD20 binding\n(TMDD)"];
    Rtx_Cp     -> Rtx_periph [label="distribution"];
    Rtx_periph -> Rtx_Cp    [label="redistribution"];

    Cyc_prodrug -> Cyc_4OH  [label="CYP2B6/3A4\nactivation"];
    Cyc_4OH    -> Acrolein  [label="spontaneous\ndecomposition"];

    MMF_oral   -> MPA_Cp    [label="esterase\ncleavage"];
    MPA_Cp     -> MPA_MPAG  [label="UGT1A9\nglucuronidation"];

    ACTH_depot -> ACTH_Cp   [label="SC release\n(zero-order)"];

    // =========================================================
    // EDGES: Drug PK → PD Linkage
    // =========================================================
    // Steroids
    Pred_Cp    -> Prednisone [label="PK drives\nPD"];
    Prednisone -> GR_complex [label="GR binding\n(Kd~5 nM)"];
    GR_complex -> GR_transrep[label="nuclear\ntransrep"];
    GR_complex -> GR_transact[label="nuclear\ntransact"];
    GR_transrep -> NFkB    [label="inhibits\n(IκBα ↑)", color="red", style=dashed];
    GR_transrep -> AP1     [label="inhibits", color="red", style=dashed];
    GR_transact -> IL10    [label="induces\nanti-inflam genes"];

    // Calcineurin Inhibitors
    CsA_PBMC   -> Cyclosporine[label="PK→PD"];
    Tacro_RBC  -> Tacrolimus  [label="PK→PD"];
    Cyclosporine -> CaN_inhib [label="CsA-CypA complex\n→CaN block"];
    Tacrolimus  -> CaN_inhib  [label="FK506-FKBP12\n→CaN block"];
    CaN_inhib  -> NFAT_block  [label="→NFAT\ncytoplasmic"];
    NFAT_block -> IL2         [label="↓IL-2\ntranscription", color="red", style=dashed];
    NFAT_block -> IL4         [label="↓cytokines", color="red", style=dashed];

    // Rituximab
    Rtx_Cp     -> Rituximab   [label="PK→PD"];
    Rituximab  -> CD20_depl   [label="ADCC+CDC\ndepletion"];
    CD20_depl  -> Bcell       [label="depletes\nB cells", color="red", style=dashed];
    CD20_depl  -> BCR_signal  [label="downstream\n↓"];
    CD20_bound -> CD20_depl   [label="internalization\n+ cell killing"];

    // Cyclophosphamide
    Cyc_4OH    -> Cyclophosphamide_drug[label="PK→PD"];
    Cyclophosphamide_drug -> DNA_alkyl [label="crosslinks\nDNA"];
    DNA_alkyl  -> Bcell_deplete[label="B cell\napoptosis"];
    Bcell_deplete -> PlasmaCell[label="↓plasma cells", color="red", style=dashed];

    // MMF
    MPA_Cp     -> MMF_drug   [label="PK→PD"];
    MMF_drug   -> IMPDH_inhib[label="non-competitive\nIMPDH block"];
    IMPDH_inhib -> Bcell     [label="↓guanosine\n→B cell arrest", color="red", style=dashed];

    // ACEi/ARB
    ACEi_block -> AngII_inhib[label="ACE\ninhibition"];
    AngII_inhib -> AngII     [label="↓Ang II\nlevel", color="red", style=dashed];
    AngII_inhib -> RAAS_act  [label="RAAS\nblockade", color="red", style=dashed];
    ACEi_block -> AlbFilt    [label="↓intraglomerular\nP", color="red", style=dashed];

    // ACTH
    ACTH_Cp    -> ACTH_drug  [label="PK→PD"];
    ACTH_drug  -> ACTH_MCR   [label="MC1R/MC3R\nbinding"];
    ACTH_MCR   -> Treg       [label="↑Treg\nfunction"];
    ACTH_MCR   -> Th2        [label="↓Th2\nresponse", color="red", style=dashed];
    ACTH_drug  -> ACTH_pod   [label="direct\npodocyte MC1R"];
    ACTH_pod   -> Nephrin    [label="↑nephrin\nexpression"];
    ACTH_pod   -> ActinPoly  [label="stabilizes\nactin"];

    // mTOR inhibitor
    mTOR_inhib_drug -> mTOR  [label="rapamycin\ncomplex"];
    mTOR       -> Akt_T      [label="feedback\nloop", style=dashed];

    // =========================================================
    // EDGES: Disease → Clinical Biomarkers (final outputs)
    // =========================================================
    UrProt35   -> HypoAlb   [label="protein\nurinary loss"];
    HypoAlb    -> Lipiduria  [label="↑hepatic\nlipid synth"];
    HypoAlb    -> HyperCoag  [label="↓AT-III\nsynthesis"];
    UrProt35   -> eGFR      [label="tubular\nstress", style=dashed];
    Edema      -> AKI_risk  [label="organ\nhypoperfusion", style=dashed];
    SecFSGS    -> UrProt35  [label="persistent\nproteinuria"];

    // =========================================================
    // SUMMARY OUTPUT NODES (clinical outcomes)
    // =========================================================
    Complete_Remission [label="Complete Remission\n(UPCR <200 mg/g)", shape=ellipse, fillcolor="#bbf7d0", style=filled];
    Partial_Remission  [label="Partial Remission\n(UPCR ↓>50%)", shape=ellipse, fillcolor="#fef9c3", style=filled];
    Relapse            [label="Relapse\n(UPCR >2000 mg/g)", shape=ellipse, fillcolor="#fecaca", style=filled];
    SRNS               [label="Steroid-Resistant\nNephrotic Syndrome (SRNS)", shape=ellipse, fillcolor="#fecaca", style=filled];

    GR_transrep -> Complete_Remission [label="steroid\nremission"];
    CD20_depl   -> Complete_Remission [label="B cell\ndepletion cure"];
    CaN_inhib   -> Partial_Remission  [label="CNI\npartial response"];
    SecFSGS     -> SRNS               [label="FSGS\nconversion"];
    Bcell       -> Relapse            [label="B cell\nrepopulation"];
    IMPDH_inhib -> Partial_Remission  [label="MMF\nsteroid sparing"];

    // =========================================================
    // Legend
    // =========================================================
    subgraph cluster_legend {
        label="Legend";
        style=filled;
        color="#888888";
        fillcolor="#f8fafc";
        fontname="Helvetica Bold";
        fontsize=11;
        rank=same;

        L_genetic  [label="Genetic / Molecular", fillcolor="lightblue",   style=filled, shape=box, width=1.8];
        L_immune   [label="Immune Cells",         fillcolor="lightgreen",  style=filled, shape=box, width=1.8];
        L_cytokine [label="Cytokines / Mediators",fillcolor="lightyellow", style=filled, shape=box, width=1.8];
        L_podocyte [label="Podocyte / Structural", fillcolor="lightcoral",  style=filled, shape=box, width=1.8];
        L_clinical [label="Clinical Manifestations",fillcolor="lightsalmon",style=filled, shape=box, width=1.8];
        L_pk       [label="Drug PK",              fillcolor="lightpink",   style=filled, shape=box, width=1.8];
        L_pd       [label="Drug PD / MoA",        fillcolor="plum",        style=filled, shape=box, width=1.8];
        L_signal   [label="Signaling Molecules",   fillcolor="wheat",       style=filled, shape=box, width=1.8];

        L_genetic -> L_immune   [style=invis];
        L_immune  -> L_cytokine [style=invis];
        L_cytokine-> L_podocyte [style=invis];
        L_podocyte-> L_clinical [style=invis];
        L_clinical-> L_pk       [style=invis];
        L_pk      -> L_pd       [style=invis];
        L_pd      -> L_signal   [style=invis];
    }
}
