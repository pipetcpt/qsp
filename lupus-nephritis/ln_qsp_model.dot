digraph LupusNephritis_QSP {
    graph [
        label="Lupus Nephritis — Quantitative Systems Pharmacology Map\nImmune Dysregulation · Glomerular Pathology · Drug PK/PD",
        labelloc=t, labeljust=c,
        fontname="Helvetica", fontsize=18, fontcolor="#1a1a2e",
        bgcolor="#f8f9fa",
        rankdir=TB,
        splines=ortho,
        nodesep=0.4, ranksep=0.6,
        pad=0.5
    ]
    node [fontname="Helvetica", fontsize=10, style="filled,rounded", shape=box]
    edge [fontname="Helvetica", fontsize=8, color="#555555"]

    /* ================================================================
       SUBGRAPH 1: TRIGGERING FACTORS & INNATE IMMUNITY
    ================================================================ */
    subgraph cluster_innate {
        label="Innate Immune Activation"
        style=filled; fillcolor="#fff3cd"; color="#e0a800"; penwidth=2;
        fontsize=13; fontcolor="#7d4e00";

        UV [label="UV Light\nExposure", fillcolor="#ffecb3"]
        Infection [label="Viral/Bacterial\nInfection", fillcolor="#ffecb3"]
        NETosis [label="NETosis\n(Neutrophil Extracellular Traps)", fillcolor="#ffd54f"]
        dsDNA_release [label="Nuclear Material\nRelease (dsDNA, histones)", fillcolor="#ffd54f"]
        TLR7 [label="TLR7\n(ssRNA sensing)", fillcolor="#ffb300"]
        TLR9 [label="TLR9\n(dsDNA sensing)", fillcolor="#ffb300"]
        cGAS [label="cGAS-STING\nPathway", fillcolor="#ff8f00"]
        pDC [label="Plasmacytoid Dendritic\nCell (pDC)", fillcolor="#ffa000"]
        IFNa [label="Type I IFN\n(IFN-α/β)", fillcolor="#e65100", fontcolor="white"]
        IFNsig [label="IFN Signature\nGenes (ISG15, MX1)", fillcolor="#bf360c", fontcolor="white"]
        Complement_act [label="Complement\nActivation (C1q↓)", fillcolor="#ff6d00"]
        DAMP [label="DAMPs\n(HMGB1, uric acid)", fillcolor="#ffd54f"]

        UV -> NETosis
        Infection -> TLR7
        Infection -> TLR9
        NETosis -> dsDNA_release
        dsDNA_release -> TLR9
        dsDNA_release -> cGAS
        DAMP -> TLR9
        DAMP -> pDC
        TLR7 -> pDC
        TLR9 -> pDC
        cGAS -> IFNa [label="STING→IRF3"]
        pDC -> IFNa [label="IRF7 activation"]
        IFNa -> IFNsig
        IFNa -> Complement_act
    }

    /* ================================================================
       SUBGRAPH 2: ADAPTIVE IMMUNE — T CELLS
    ================================================================ */
    subgraph cluster_Tcell {
        label="T Cell Dysregulation"
        style=filled; fillcolor="#e8f5e9"; color="#388e3c"; penwidth=2;
        fontsize=13; fontcolor="#1b5e20";

        Th0 [label="Naive T Cell\n(Th0)", fillcolor="#c8e6c9"]
        Th1 [label="Th1\n(IFN-γ, TNF-α)", fillcolor="#a5d6a7"]
        Th2 [label="Th2\n(IL-4, IL-13)", fillcolor="#a5d6a7"]
        Th17 [label="Th17\n(IL-17A, IL-21)", fillcolor="#66bb6a"]
        Tfh [label="T Follicular Helper\n(Tfh, CXCR5+PD-1+)", fillcolor="#43a047"]
        Treg [label="Regulatory T Cell\n(Foxp3+)", fillcolor="#81c784"]
        CD8_T [label="Cytotoxic T Cell\n(CD8+)", fillcolor="#a5d6a7"]
        IL17 [label="IL-17A\n(renal inflammation)", fillcolor="#2e7d32", fontcolor="white"]
        IL21 [label="IL-21\n(B cell stimulation)", fillcolor="#1b5e20", fontcolor="white"]
        IFNg [label="IFN-γ", fillcolor="#66bb6a"]
        Treg_suppress [label="Treg\nSuppression ↓", fillcolor="#e57373"]

        Th0 -> Th1 [label="IL-12"]
        Th0 -> Th2 [label="IL-4"]
        Th0 -> Th17 [label="TGF-β+IL-6"]
        Th0 -> Tfh [label="ICOS+CXCR5"]
        Th0 -> Treg [label="TGF-β"]
        Th17 -> IL17
        Tfh -> IL21
        Th1 -> IFNg
        IFNa -> Th1 [label="JAK-STAT pathway"]
        IFNa -> Treg_suppress
        Treg -> Treg_suppress [dir=none]
    }

    /* ================================================================
       SUBGRAPH 3: B CELLS & AUTOANTIBODY
    ================================================================ */
    subgraph cluster_Bcell {
        label="B Cell Hyperactivation & Autoantibodies"
        style=filled; fillcolor="#e3f2fd"; color="#1565c0"; penwidth=2;
        fontsize=13; fontcolor="#0d47a1";

        Naive_B [label="Naive B Cell", fillcolor="#bbdefb"]
        GC_B [label="Germinal Center\nB Cell (BCR)", fillcolor="#90caf9"]
        Memory_B [label="Memory B Cell", fillcolor="#64b5f6"]
        Plasma_B [label="Long-lived\nPlasma Cell", fillcolor="#1e88e5", fontcolor="white"]
        BAFF [label="BLyS/BAFF\n(B cell survival)", fillcolor="#1565c0", fontcolor="white"]
        APRIL [label="APRIL\n(plasma cell survival)", fillcolor="#0d47a1", fontcolor="white"]
        Anti_dsDNA [label="Anti-dsDNA\nAntibody (IgG)", fillcolor="#e53935", fontcolor="white"]
        Anti_C1q [label="Anti-C1q\nAntibody", fillcolor="#e53935", fontcolor="white"]
        Anti_Smith [label="Anti-Sm\nAntibody", fillcolor="#c62828", fontcolor="white"]
        IC [label="Immune Complexes\n(IgG/C1q/dsDNA)", fillcolor="#b71c1c", fontcolor="white"]

        Naive_B -> GC_B [label="BCR + T cell help"]
        GC_B -> Memory_B
        GC_B -> Plasma_B [label="IL-21, BAFF"]
        BAFF -> Naive_B [label="survival"]
        BAFF -> Memory_B
        APRIL -> Plasma_B [label="survival"]
        Plasma_B -> Anti_dsDNA
        Plasma_B -> Anti_C1q
        Plasma_B -> Anti_Smith
        IL21 -> GC_B [label="stimulate"]
        IFNa -> BAFF [label="↑ expression"]
        Anti_dsDNA -> IC
        Anti_C1q -> IC
        dsDNA_release -> IC [style=dashed]
    }

    /* ================================================================
       SUBGRAPH 4: COMPLEMENT SYSTEM
    ================================================================ */
    subgraph cluster_complement {
        label="Complement System"
        style=filled; fillcolor="#fce4ec"; color="#880e4f"; penwidth=2;
        fontsize=13; fontcolor="#560027";

        C1q [label="C1q\n(IC recognition)", fillcolor="#f8bbd0"]
        C4 [label="C4\n(classical pathway)", fillcolor="#f48fb1"]
        C3 [label="C3 / C3b\n(opsonization)", fillcolor="#f06292"]
        C5 [label="C5a\n(chemotaxis)", fillcolor="#ec407a"]
        MAC [label="MAC\n(C5b-9, lysis)", fillcolor="#880e4f", fontcolor="white"]
        C3_nephritis [label="C3 Nephritis\nFactor", fillcolor="#e91e63"]
        Properdin [label="Properdin\n(alt. pathway)", fillcolor="#f48fb1"]

        IC -> C1q [label="bind IC"]
        C1q -> C4 [label="classical"]
        C4 -> C3
        C3 -> C5 [label="C5 convertase"]
        C5 -> MAC
        Properdin -> C3 [label="alternative"]
        C3_nephritis -> C3 [label="↓ cleavage"]
        Anti_C1q -> C1q [label="inhibit"]
    }

    /* ================================================================
       SUBGRAPH 5: GLOMERULAR PATHOLOGY
    ================================================================ */
    subgraph cluster_glomerulus {
        label="Glomerular Pathology (ISN/RPS Classification)"
        style=filled; fillcolor="#ede7f6"; color="#4527a0"; penwidth=2;
        fontsize=13; fontcolor="#1a0030";

        Mesangial [label="Mesangial Cell\nActivation (Class I/II)", fillcolor="#d1c4e9"]
        IC_deposit [label="IC Deposition\n(sub-endo/epi)", fillcolor="#b39ddb"]
        Endothelial_inj [label="Endothelial Cell\nInjury", fillcolor="#9575cd"]
        GBM_damage [label="GBM Damage\n(class III/IV)", fillcolor="#7e57c2"]
        Podocyte [label="Podocyte\nInjury/Loss", fillcolor="#673ab7", fontcolor="white"]
        Slit_diaphragm [label="Slit Diaphragm\nDisruption (nephrin↓)", fillcolor="#5e35b1", fontcolor="white"]
        Proteinuria [label="Proteinuria\n(UPCR ≥0.5)", fillcolor="#4a148c", fontcolor="white"]
        Mesangial_exp [label="Mesangial\nExpansion", fillcolor="#ce93d8"]
        Crescent [label="Cellular Crescent\nFormation", fillcolor="#9c27b0", fontcolor="white"]
        Sclerosis [label="Segmental\nSclerosis", fillcolor="#7b1fa2", fontcolor="white"]

        IC -> IC_deposit
        IC_deposit -> Mesangial
        IC_deposit -> Endothelial_inj
        IC_deposit -> GBM_damage
        C5 -> Endothelial_inj [label="neutrophil recruit"]
        MAC -> Podocyte [label="C5b-9 attack"]
        GBM_damage -> Podocyte
        Podocyte -> Slit_diaphragm
        Slit_diaphragm -> Proteinuria
        Mesangial -> Mesangial_exp
        IL17 -> Endothelial_inj [label="PMN chemotaxis"]
        Endothelial_inj -> Crescent [label="fibrin/PMN"]
        GBM_damage -> Sclerosis [label="chronic"]
    }

    /* ================================================================
       SUBGRAPH 6: TUBULOINTERSTITIAL
    ================================================================ */
    subgraph cluster_tubulo {
        label="Tubulointerstitial Compartment"
        style=filled; fillcolor="#e0f7fa"; color="#006064"; penwidth=2;
        fontsize=13; fontcolor="#004d40";

        Tubular_cell [label="Proximal Tubular\nCell (PTC)", fillcolor="#b2ebf2"]
        IC_tubular [label="IC Deposition\n(tubular)", fillcolor="#80deea"]
        ROS [label="Reactive Oxygen\nSpecies (ROS)", fillcolor="#4dd0e1"]
        Tubular_inj [label="Tubular Injury\n(KIM-1↑)", fillcolor="#00acc1"]
        TGFb [label="TGF-β1\n(fibrosis driver)", fillcolor="#00838f", fontcolor="white"]
        Myofibroblast [label="Myofibroblast\nActivation", fillcolor="#006064", fontcolor="white"]
        Interstitial_fib [label="Interstitial\nFibrosis", fillcolor="#004d40", fontcolor="white"]
        eGFR [label="eGFR Decline\n(CKD progression)", fillcolor="#37474f", fontcolor="white"]
        NGAL [label="NGAL\n(tubular biomarker)", fillcolor="#546e7a"]

        IC_tubular -> Tubular_cell
        Tubular_cell -> ROS
        ROS -> Tubular_inj
        Tubular_inj -> TGFb
        TGFb -> Myofibroblast
        Myofibroblast -> Interstitial_fib
        Interstitial_fib -> eGFR [label="irreversible"]
        Tubular_inj -> NGAL
        IL17 -> Tubular_inj [label="direct toxicity"]
        IC -> IC_tubular [style=dashed]
    }

    /* ================================================================
       SUBGRAPH 7: RENAL HEMODYNAMICS & CLINICAL ENDPOINTS
    ================================================================ */
    subgraph cluster_hemodynamics {
        label="Renal Hemodynamics & Clinical Endpoints"
        style=filled; fillcolor="#fff8e1"; color="#f57f17"; penwidth=2;
        fontsize=13; fontcolor="#e65100";

        GFR [label="GFR\n(mL/min/1.73m²)", fillcolor="#ffe082"]
        RPF [label="Renal Plasma Flow\n(RPF)", fillcolor="#ffd54f"]
        RAAS_renal [label="Intrarenal\nRAAS Activation", fillcolor="#ffb300"]
        AngII_renal [label="Angiotensin II\n(renal)", fillcolor="#ff8f00"]
        Efferent_constr [label="Efferent Arteriole\nConstriction", fillcolor="#e65100", fontcolor="white"]
        Hyperfiltration [label="Intraglomerular\nHypertension", fillcolor="#bf360c", fontcolor="white"]
        UPCR [label="Urine Protein:\nCreatinine Ratio", fillcolor="#ffa726"]
        Hematuria [label="Hematuria\n(RBC casts)", fillcolor="#ef6c00"]
        SLEDAI_renal [label="SLEDAI Renal\nScore", fillcolor="#e65100", fontcolor="white"]
        CRRP [label="Complete Renal\nResponse (CRRP)", fillcolor="#f57f17"]
        PRRP [label="Partial Renal\nResponse (PRRP)", fillcolor="#ffa000"]

        GBM_damage -> GFR [label="↓"]
        Sclerosis -> GFR [label="↓"]
        eGFR -> GFR
        Proteinuria -> UPCR
        Endothelial_inj -> Hematuria
        Crescent -> Hematuria
        UPCR -> SLEDAI_renal
        Hematuria -> SLEDAI_renal
        GFR -> SLEDAI_renal
        SLEDAI_renal -> CRRP [label="UPCR<0.5+\neGFR≥60"]
        SLEDAI_renal -> PRRP [label="UPCR<1.0+\neGFR≥60"]
        RAAS_renal -> AngII_renal
        AngII_renal -> Efferent_constr
        Efferent_constr -> Hyperfiltration
        Hyperfiltration -> GBM_damage [label="chronic"]
        RPF -> GFR
    }

    /* ================================================================
       SUBGRAPH 8: DRUG PK/PD — HYDROXYCHLOROQUINE
    ================================================================ */
    subgraph cluster_HCQ {
        label="Drug PK/PD: Hydroxychloroquine (HCQ)"
        style=filled; fillcolor="#e8eaf6"; color="#283593"; penwidth=2;
        fontsize=13; fontcolor="#1a237e";

        HCQ_dose [label="HCQ Dose\n(200–400 mg/day)", fillcolor="#c5cae9"]
        HCQ_gut [label="HCQ Gut\nAbsorption (F~0.74)", fillcolor="#9fa8da"]
        HCQ_blood [label="HCQ Blood\nConcentration", fillcolor="#7986cb"]
        HCQ_tissue [label="HCQ Tissue\nDistribution (large Vd)", fillcolor="#5c6bc0"]
        HCQ_lysosome [label="HCQ Lysosomal\nAccumulation", fillcolor="#3949ab", fontcolor="white"]
        HCQ_TLR [label="TLR7/9\nInhibition", fillcolor="#283593", fontcolor="white"]
        HCQ_IFN [label="IFN-α\nReduction", fillcolor="#1a237e", fontcolor="white"]
        HCQ_IC [label="IC Clearance\n↑", fillcolor="#3f51b5", fontcolor="white"]

        HCQ_dose -> HCQ_gut
        HCQ_gut -> HCQ_blood [label="ka=0.38/h"]
        HCQ_blood -> HCQ_tissue [label="Vd=800 L/kg"]
        HCQ_tissue -> HCQ_lysosome [label="concentrate"]
        HCQ_lysosome -> HCQ_TLR [label="raise pH"]
        HCQ_TLR -> HCQ_IFN [label="↓ signaling"]
        HCQ_TLR -> HCQ_IC [label="↓ FcR"]
        HCQ_IFN -> IFNa [label="inhibit", color="#283593"]
        HCQ_IC -> IC [label="promote\nclearance", color="#283593"]
    }

    /* ================================================================
       SUBGRAPH 9: DRUG PK/PD — MYCOPHENOLATE (MMF/MPA)
    ================================================================ */
    subgraph cluster_MMF {
        label="Drug PK/PD: Mycophenolate Mofetil (MMF/MPA)"
        style=filled; fillcolor="#f3e5f5"; color="#6a1b9a"; penwidth=2;
        fontsize=13; fontcolor="#4a148c";

        MMF_dose [label="MMF Dose\n(2–3 g/day)", fillcolor="#e1bee7"]
        MMF_gut [label="MMF GI\nAbsorption (F~0.94)", fillcolor="#ce93d8"]
        MPA_plasma [label="MPA Plasma\nConc. (free)", fillcolor="#ba68c8"]
        MPA_IMPDH [label="IMPDH\nInhibition (I/II)", fillcolor="#ab47bc"]
        GMP_depletion [label="Guanosine\nDepletion (lymphocyte-specific)", fillcolor="#8e24aa", fontcolor="white"]
        T_proliferate [label="T Cell\nProliferation ↓", fillcolor="#7b1fa2", fontcolor="white"]
        B_proliferate [label="B Cell\nProliferation ↓", fillcolor="#6a1b9a", fontcolor="white"]
        Ab_production [label="Antibody\nProduction ↓", fillcolor="#4a148c", fontcolor="white"]
        MPA_EC [label="Enterohepatic\nCirculation (EHC)", fillcolor="#ce93d8"]
        MPA_MPAG [label="MPAG (inactive\nglucuronide)", fillcolor="#ba68c8"]

        MMF_dose -> MMF_gut
        MMF_gut -> MPA_plasma [label="hydrolysis F~0.94"]
        MPA_plasma -> MPA_IMPDH [label="non-competitive"]
        MPA_IMPDH -> GMP_depletion
        GMP_depletion -> T_proliferate
        GMP_depletion -> B_proliferate
        B_proliferate -> Ab_production
        MPA_plasma -> MPA_MPAG [label="UGT1A9"]
        MPA_MPAG -> MPA_EC [label="gut bacteria\ndeconjugate"]
        MPA_EC -> MPA_plasma [label="reabsorb"]
        T_proliferate -> Tfh [label="↓", color="#6a1b9a"]
        B_proliferate -> GC_B [label="↓", color="#6a1b9a"]
        Ab_production -> Anti_dsDNA [label="↓", color="#6a1b9a"]
    }

    /* ================================================================
       SUBGRAPH 10: DRUG PK/PD — VOCLOSPORIN (VCS)
    ================================================================ */
    subgraph cluster_VCS {
        label="Drug PK/PD: Voclosporin (Calcineurin Inhibitor)"
        style=filled; fillcolor="#e0f2f1"; color="#004d40"; penwidth=2;
        fontsize=13; fontcolor="#00251a";

        VCS_dose [label="VCS Dose\n(23.7 mg BID)", fillcolor="#b2dfdb"]
        VCS_gut [label="VCS Oral\nAbsorption", fillcolor="#80cbc4"]
        VCS_plasma [label="VCS Plasma\nConcentration", fillcolor="#4db6ac"]
        VCS_CaN [label="Calcineurin\nInhibition", fillcolor="#26a69a"]
        NFAT_block [label="NFAT\nDephosphorylation ↓", fillcolor="#00897b", fontcolor="white"]
        IL2_block [label="IL-2\nProduction ↓", fillcolor="#00796b", fontcolor="white"]
        Th17_vcs [label="Th17\nDifferentiation ↓", fillcolor="#00695c", fontcolor="white"]
        Podocyte_vcs [label="Podocyte\nStabilization ↑", fillcolor="#004d40", fontcolor="white"]
        VCS_CYP3A4 [label="CYP3A4\nMetabolism", fillcolor="#80cbc4"]

        VCS_dose -> VCS_gut
        VCS_gut -> VCS_plasma [label="Tmax~1.5h"]
        VCS_plasma -> VCS_CaN [label="cyclophilin binding"]
        VCS_CaN -> NFAT_block
        NFAT_block -> IL2_block
        IL2_block -> Th17_vcs [label="↓ T activation"]
        VCS_CaN -> Podocyte_vcs [label="synaptopodin\nstabilization"]
        Podocyte_vcs -> Podocyte [label="protect", color="#004d40"]
        Th17_vcs -> IL17 [label="↓", color="#004d40"]
        VCS_plasma -> VCS_CYP3A4 [label="CL/F≈31.6 L/h"]
    }

    /* ================================================================
       SUBGRAPH 11: DRUG PK/PD — BELIMUMAB (BLyS/BAFF inhibitor)
    ================================================================ */
    subgraph cluster_BEL {
        label="Drug PK/PD: Belimumab (anti-BLyS mAb)"
        style=filled; fillcolor="#fff3e0"; color="#e65100"; penwidth=2;
        fontsize=13; fontcolor="#bf360c";

        BEL_dose [label="Belimumab\n(10 mg/kg IV q4w)", fillcolor="#ffe0b2"]
        BEL_PK [label="Belimumab\nPlasma (2-cmt)", fillcolor="#ffcc80"]
        BEL_BAFF [label="BLyS/BAFF\nNeutralization", fillcolor="#ffb74d"]
        BEL_Naive_B [label="Naive/Transitional\nB Cell ↓", fillcolor="#ffa726"]
        BEL_Memory_B [label="Memory B Cell\n(partial ↓)", fillcolor="#ef6c00", fontcolor="white"]
        BEL_Plasma_B [label="Plasma Cell\n(minor effect)", fillcolor="#e65100", fontcolor="white"]
        BEL_Dsdna [label="Anti-dsDNA ↓\n(delayed 6–12 mo)", fillcolor="#bf360c", fontcolor="white"]
        BEL_SFI [label="SFI\n(BAFF:APRIL ratio)", fillcolor="#ffd54f"]
        SC_BEL [label="Belimumab SC\n(200 mg wk)", fillcolor="#ffe0b2"]

        BEL_dose -> BEL_PK [label="CL=2.8 mL/h/kg"]
        SC_BEL -> BEL_PK [label="F~0.74"]
        BEL_PK -> BEL_BAFF [label="target-mediated"]
        BEL_BAFF -> BEL_Naive_B [label="↓ survival signal"]
        BEL_BAFF -> BEL_Memory_B
        BEL_BAFF -> BEL_Plasma_B
        BEL_Naive_B -> Naive_B [label="↓", color="#e65100"]
        BEL_Memory_B -> Memory_B [label="↓", color="#e65100"]
        BEL_Plasma_B -> Plasma_B [label="minimal", color="#e65100", style=dashed]
        BEL_Naive_B -> BEL_Dsdna
        BEL_SFI -> BEL_BAFF
        BAFF -> BEL_BAFF [dir=none, style=dashed]
    }

    /* ================================================================
       SUBGRAPH 12: DRUG PK/PD — ANIFROLUMAB (anti-IFNAR)
    ================================================================ */
    subgraph cluster_ANI {
        label="Drug PK/PD: Anifrolumab (anti-IFNAR1 mAb)"
        style=filled; fillcolor="#fce4ec"; color="#880e4f"; penwidth=2;
        fontsize=13; fontcolor="#560027";

        ANI_dose [label="Anifrolumab\n(300 mg IV q4w)", fillcolor="#f8bbd0"]
        ANI_PK [label="Anifrolumab\nPlasma Conc.", fillcolor="#f48fb1"]
        ANI_IFNAR [label="IFNAR1\nBlockade", fillcolor="#f06292"]
        ANI_ISG [label="ISG Score\n↓ (>75% inhibition)", fillcolor="#ec407a"]
        ANI_pDC [label="pDC\nIFN-α ↓", fillcolor="#e91e63"]
        ANI_B_diff [label="B Cell IFN-driven\nDifferentiation ↓", fillcolor="#ad1457", fontcolor="white"]
        ANI_NTZ [label="Nasopharyngitis\n(herpes zoster ↑)", fillcolor="#f06292"]

        ANI_dose -> ANI_PK [label="Vd=5.6 L"]
        ANI_PK -> ANI_IFNAR [label="TMDD"]
        ANI_IFNAR -> ANI_ISG
        ANI_IFNAR -> ANI_pDC [label="↓ signaling"]
        ANI_pDC -> IFNa [label="↓", color="#880e4f"]
        ANI_ISG -> IFNsig [label="↓", color="#880e4f"]
        ANI_B_diff -> GC_B [label="↓", color="#880e4f"]
        ANI_IFNAR -> ANI_B_diff
        ANI_IFNAR -> ANI_NTZ [style=dashed, label="immunosup."]
    }

    /* ================================================================
       SUBGRAPH 13: CYCLOPHOSPHAMIDE (INDUCTION)
    ================================================================ */
    subgraph cluster_CYC {
        label="Drug PK/PD: Cyclophosphamide (Induction)"
        style=filled; fillcolor="#efebe9"; color="#3e2723"; penwidth=2;
        fontsize=13; fontcolor="#1b0000";

        CYC_dose [label="CYC IV\n(Euro-Lupus 500 mg q2w×6\nor NIH 0.75 g/m²)", fillcolor="#d7ccc8"]
        CYC_liver [label="Hepatic Activation\n(CYP2B6/3A4)", fillcolor="#bcaaa4"]
        CYC_PM [label="Phosphoramide\nMustard (active)", fillcolor="#a1887f"]
        CYC_DNA [label="DNA Cross-linking\n(alkylation)", fillcolor="#795548"]
        CYC_lympho [label="Lymphocyte\nApoptosis (B+T)", fillcolor="#6d4c41", fontcolor="white"]
        CYC_gonad [label="Gonadal\nToxicity (FSH↑)", fillcolor="#5d4037", fontcolor="white"]
        CYC_bladder [label="Acrolein →\nHemorrhagic Cystitis", fillcolor="#4e342e", fontcolor="white"]
        MESNA [label="MESNA\n(urothelial protection)", fillcolor="#bcaaa4"]

        CYC_dose -> CYC_liver
        CYC_liver -> CYC_PM [label="N-dealkylation"]
        CYC_PM -> CYC_DNA
        CYC_DNA -> CYC_lympho
        CYC_lympho -> Plasma_B [label="↓ profound", color="#3e2723"]
        CYC_lympho -> Memory_B [label="↓", color="#3e2723"]
        CYC_PM -> CYC_bladder [label="acrolein metabolite"]
        CYC_PM -> CYC_gonad
        MESNA -> CYC_bladder [label="neutralize"]
    }

    /* ================================================================
       SUBGRAPH 14: GLUCOCORTICOID (GC)
    ================================================================ */
    subgraph cluster_GC {
        label="Drug PK/PD: Glucocorticoids"
        style=filled; fillcolor="#f1f8e9"; color="#33691e"; penwidth=2;
        fontsize=13; fontcolor="#1b5e20";

        GC_dose [label="GC Dose\n(prednisone 0.5–1 mg/kg/d\n± pulse methylpred)", fillcolor="#dcedc8"]
        GC_receptor [label="GR Binding\n(cytoplasmic GR)", fillcolor="#c5e1a5"]
        GC_transrep [label="NF-κB / AP-1\nTransrepression", fillcolor="#aed581"]
        GC_transact [label="GRE-mediated\nTransactivation", fillcolor="#9ccc65"]
        GC_IL6 [label="IL-6 ↓", fillcolor="#8bc34a"]
        GC_TNF [label="TNF-α ↓", fillcolor="#8bc34a"]
        GC_IFNg [label="IFN-γ ↓", fillcolor="#8bc34a"]
        GC_bone [label="Bone Loss\n(osteoblast ↓)", fillcolor="#ff7043"]
        GC_meta [label="Metabolic SE\n(HbA1c↑, BP↑)", fillcolor="#ff7043"]
        GC_ACTH [label="HPA Axis\nSuppression", fillcolor="#e64a19", fontcolor="white"]
        GC_Treg [label="Treg\n↑ (partial)", fillcolor="#aed581"]

        GC_dose -> GC_receptor
        GC_receptor -> GC_transrep
        GC_receptor -> GC_transact
        GC_transrep -> GC_IL6
        GC_transrep -> GC_TNF
        GC_transrep -> GC_IFNg
        GC_GRE [label="GRE genes\n(IκBα, IL-10)", fillcolor="#c5e1a5"]
        GC_transact -> GC_GRE
        GC_GRE -> GC_Treg
        GC_dose -> GC_bone [label="chronic use"]
        GC_dose -> GC_meta
        GC_dose -> GC_ACTH [label="feedback ↓"]
        GC_IL6 -> IL6 [label="↓", color="#33691e"]
        GC_IFNg -> IFNg [label="↓", color="#33691e"]
    }

    /* ================================================================
       SUBGRAPH 15: CYTOKINE NETWORK
    ================================================================ */
    subgraph cluster_cytokines {
        label="Inflammatory Cytokine Network"
        style=filled; fillcolor="#fafafa"; color="#607d8b"; penwidth=2;
        fontsize=13; fontcolor="#263238";

        IL6 [label="IL-6\n(STAT3 signaling)", fillcolor="#b0bec5"]
        IL10 [label="IL-10\n(anti-inflammatory)", fillcolor="#90a4ae"]
        IL18 [label="IL-18\n(inflammasome)", fillcolor="#78909c"]
        IL33 [label="IL-33\n(ST2 receptor)", fillcolor="#607d8b", fontcolor="white"]
        TNFa [label="TNF-α\n(NF-κB)", fillcolor="#546e7a", fontcolor="white"]
        MCP1 [label="MCP-1/CCL2\n(monocyte recruitment)", fillcolor="#455a64", fontcolor="white"]
        CXCL10 [label="CXCL10/IP-10\n(IFN-driven)", fillcolor="#37474f", fontcolor="white"]

        IL6 -> Plasma_B [label="differentiation"]
        IL6 -> Mesangial [label="↑ proliferation"]
        IL10 -> GC_B [label="survival"]
        IL10 -> Plasma_B
        TNFa -> Endothelial_inj [label="activate"]
        MCP1 -> Mesangial [label="recruit monocyte"]
        IL18 -> IFNg [label="synergize"]
        CXCL10 -> pDC [label="recruit"]
        IFNa -> CXCL10 [label="induce"]
        IFNa -> IL6 [label="↑"]
    }

    /* ================================================================
       INTER-CLUSTER EDGES (key connections)
    ================================================================ */
    IFNa -> BAFF [label="↑ expression"]
    IC -> C1q [style=dashed]
    BAFF -> Naive_B
    IL21 -> GC_B
    C5 -> Endothelial_inj
    IC -> IC_deposit
    Podocyte -> Proteinuria
    eGFR -> GFR
    Sclerosis -> eGFR [label="↓"]
    Interstitial_fib -> eGFR [label="↓"]

    /* Drug → disease effects */
    MMF_gut -> MPA_plasma
    VCS_CaN -> NFAT_block
    BEL_PK -> BEL_BAFF
    ANI_PK -> ANI_IFNAR
    CYC_DNA -> CYC_lympho
    GC_receptor -> GC_transrep
}
