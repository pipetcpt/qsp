digraph CRC_QSP {
  graph [
    label="Colorectal Cancer (CRC) — Quantitative Systems Pharmacology Model\nWnt·KRAS·PI3K·TP53·TGF-β · TME · MSI/MMR · Angiogenesis · Multi-drug PK/PD"
    fontsize=22 fontname="Helvetica" labelloc=t
    splines=ortho overlap=false rankdir=LR
    bgcolor="#F7F9FC"
  ]
  node [fontname="Helvetica" fontsize=11 style="filled,rounded" shape=box]
  edge [fontname="Helvetica" fontsize=9]

  /* ═══════════════════════════════════════════════════════════
     CLUSTER 1 — WNT / β-CATENIN PATHWAY
  ═══════════════════════════════════════════════════════════ */
  subgraph cluster_wnt {
    label="Wnt / β-Catenin Pathway" fontsize=14 fontcolor="#4A235A"
    style=filled fillcolor="#F5EEF8" color="#8E44AD"

    Wnt_ligand   [label="Wnt Ligands\n(Wnt3a/5a)" fillcolor="#D7BDE2"]
    FZD          [label="Frizzled Receptor\n(FZD)" fillcolor="#D7BDE2"]
    LRP5_6       [label="LRP5/6 Co-receptor" fillcolor="#D7BDE2"]
    DVL          [label="Dishevelled\n(DVL)" fillcolor="#D7BDE2"]
    APC          [label="APC\n(tumor suppressor)" fillcolor="#F1948A" fontcolor="white"]
    AXIN         [label="AXIN1/2" fillcolor="#D7BDE2"]
    GSK3B        [label="GSK-3β" fillcolor="#D7BDE2"]
    CK1a         [label="CK1α" fillcolor="#D7BDE2"]
    BCAT_dest    [label="β-Catenin\n(Destruction Complex)" fillcolor="#F1948A"]
    BCAT_free    [label="β-Catenin (Free)\n→ Nuclear" fillcolor="#82E0AA"]
    TCF_LEF      [label="TCF/LEF\nTranscription Factor" fillcolor="#82E0AA"]
    cMYC_wnt     [label="c-Myc\n(Wnt target)" fillcolor="#F9E79F"]
    CCND1_wnt    [label="Cyclin D1\n(Wnt target)" fillcolor="#F9E79F"]
    AXIN2_fb     [label="AXIN2\n(Negative feedback)" fillcolor="#D7BDE2"]
    RNF43        [label="RNF43\n(Frizzled ubiquitination)" fillcolor="#F1948A"]
    RSPO         [label="R-spondin/LGRS5\nStem cell marker" fillcolor="#82E0AA"]
  }

  /* ═══════════════════════════════════════════════════════════
     CLUSTER 2 — RAS / MAPK SIGNALING
  ═══════════════════════════════════════════════════════════ */
  subgraph cluster_ras {
    label="RAS / MAPK Signaling" fontsize=14 fontcolor="#1A5276"
    style=filled fillcolor="#EBF5FB" color="#2980B9"

    EGFR         [label="EGFR\n(ErbB1)" fillcolor="#AED6F1"]
    HER2         [label="HER2\n(ErbB2)" fillcolor="#AED6F1"]
    GRB2         [label="GRB2/SOS" fillcolor="#AED6F1"]
    RAS          [label="RAS\n(KRAS/NRAS/HRAS)" fillcolor="#F1948A" fontcolor="white"]
    KRAS_mut     [label="KRAS Mutation\nG12C/G12D/G12V" fillcolor="#E74C3C" fontcolor="white"]
    BRAF_node    [label="BRAF\n(V600E mutation)" fillcolor="#F1948A" fontcolor="white"]
    CRAF         [label="CRAF (RAF1)" fillcolor="#AED6F1"]
    MEK1         [label="MEK1/2" fillcolor="#AED6F1"]
    ERK1         [label="ERK1/2" fillcolor="#AED6F1"]
    RSK          [label="RSK1/2" fillcolor="#AED6F1"]
    ELK1         [label="ELK1/AP-1" fillcolor="#F9E79F"]
    cFOS_cJUN    [label="c-Fos/c-Jun\nImmediate Early Genes" fillcolor="#F9E79F"]
    cMYC_ras     [label="c-Myc\n(RAS target)" fillcolor="#F9E79F"]
    DUSP6        [label="DUSP6/MKP-3\n(ERK feedback)" fillcolor="#AED6F1"]
    SPRY         [label="Sprouty\n(ERK inhibitor)" fillcolor="#AED6F1"]
  }

  /* ═══════════════════════════════════════════════════════════
     CLUSTER 3 — PI3K / AKT / mTOR PATHWAY
  ═══════════════════════════════════════════════════════════ */
  subgraph cluster_pi3k {
    label="PI3K / AKT / mTOR Pathway" fontsize=14 fontcolor="#1E8449"
    style=filled fillcolor="#EAFAF1" color="#27AE60"

    PI3K         [label="PI3Kα/δ\n(PIK3CA mutation)" fillcolor="#A9DFBF"]
    PTEN         [label="PTEN\n(tumor suppressor)" fillcolor="#F1948A" fontcolor="white"]
    PIP2         [label="PIP2" fillcolor="#A9DFBF"]
    PIP3         [label="PIP3" fillcolor="#A9DFBF"]
    PDK1         [label="PDK1" fillcolor="#A9DFBF"]
    AKT          [label="AKT1/2/3" fillcolor="#A9DFBF"]
    mTORC1       [label="mTORC1\n(Raptor complex)" fillcolor="#A9DFBF"]
    mTORC2       [label="mTORC2\n(Rictor complex)" fillcolor="#A9DFBF"]
    S6K          [label="p70 S6K" fillcolor="#F9E79F"]
    fourEBP1     [label="4E-BP1\n(eIF4E release)" fillcolor="#F9E79F"]
    TSC1_2       [label="TSC1/TSC2\n(Hamartin/Tuberin)" fillcolor="#A9DFBF"]
    FOXO         [label="FOXO1/3\n(survival/apoptosis)" fillcolor="#F9E79F"]
    SGK1         [label="SGK1\n(AKT substrate)" fillcolor="#A9DFBF"]
  }

  /* ═══════════════════════════════════════════════════════════
     CLUSTER 4 — TP53 / DNA DAMAGE / APOPTOSIS
  ═══════════════════════════════════════════════════════════ */
  subgraph cluster_tp53 {
    label="TP53 / DNA Damage / Apoptosis" fontsize=14 fontcolor="#7D6608"
    style=filled fillcolor="#FEFCE8" color="#B7950B"

    DNA_damage   [label="DNA Damage\n(DSB/SSB)" fillcolor="#FAD7A0"]
    ATM_ATR      [label="ATM/ATR\nKinases" fillcolor="#FAD7A0"]
    CHK1_2       [label="CHK1/CHK2" fillcolor="#FAD7A0"]
    TP53         [label="TP53\n(R175H/R248W/R273H)" fillcolor="#F1948A" fontcolor="white"]
    MDM2         [label="MDM2\n(TP53 ubiquitinase)" fillcolor="#FAD7A0"]
    p21          [label="p21 (CDKN1A)\nCell cycle arrest" fillcolor="#F9E79F"]
    PUMA         [label="PUMA (BBC3)\nPro-apoptotic" fillcolor="#FAD7A0"]
    BAX          [label="BAX/BAK\nMitochondrial pore" fillcolor="#FAD7A0"]
    BCL2         [label="BCL-2/BCL-XL\nAnti-apoptotic" fillcolor="#82E0AA"]
    CytC         [label="Cytochrome c\nRelease" fillcolor="#FAD7A0"]
    Casp9        [label="Caspase-9\nApoptosome" fillcolor="#FAD7A0"]
    Casp3_7      [label="Caspase-3/7\nExecutioner" fillcolor="#FAD7A0"]
    PARP         [label="PARP\n(cleavage)" fillcolor="#FAD7A0"]
    NOXA         [label="NOXA\nPro-apoptotic" fillcolor="#FAD7A0"]
  }

  /* ═══════════════════════════════════════════════════════════
     CLUSTER 5 — CELL CYCLE
  ═══════════════════════════════════════════════════════════ */
  subgraph cluster_cellcycle {
    label="Cell Cycle Regulation" fontsize=14 fontcolor="#641E16"
    style=filled fillcolor="#FDEDEC" color="#C0392B"

    G1_phase     [label="G1 Phase\nCell Growth" fillcolor="#FADBD8"]
    S_phase      [label="S Phase\nDNA Synthesis" fillcolor="#FADBD8"]
    G2_phase     [label="G2/M Phase\nMitosis" fillcolor="#FADBD8"]
    CCND1        [label="Cyclin D1/D2/D3" fillcolor="#FADBD8"]
    CCNE         [label="Cyclin E\n(CDK2 partner)" fillcolor="#FADBD8"]
    CCNA         [label="Cyclin A/B\nS/G2-M" fillcolor="#FADBD8"]
    CDK4_6       [label="CDK4/CDK6" fillcolor="#FADBD8"]
    CDK2         [label="CDK2" fillcolor="#FADBD8"]
    RB1          [label="RB1 (pRb)\nHypophosphorylated" fillcolor="#82E0AA"]
    RB1p         [label="pRb (phospho)\nInactivated" fillcolor="#FADBD8"]
    E2F          [label="E2F1/2/3\nTranscription" fillcolor="#FADBD8"]
    p27          [label="p27 (CDKN1B)\nCDK inhibitor" fillcolor="#82E0AA"]
    p16          [label="p16 (CDKN2A)\nCDK4/6 inhibitor" fillcolor="#82E0AA"]
  }

  /* ═══════════════════════════════════════════════════════════
     CLUSTER 6 — TGF-β / EMT / METASTASIS
  ═══════════════════════════════════════════════════════════ */
  subgraph cluster_tgfb {
    label="TGF-β / EMT / Metastasis" fontsize=14 fontcolor="#154360"
    style=filled fillcolor="#EAF2FF" color="#1565C0"

    TGFb         [label="TGF-β1/2/3\nLigands" fillcolor="#AED6F1"]
    TGFbR1       [label="TGF-βR1\n(ALK5)" fillcolor="#AED6F1"]
    TGFbR2       [label="TGF-βR2" fillcolor="#AED6F1"]
    SMAD2_3      [label="SMAD2/3\n(Phospho-R-SMAD)" fillcolor="#AED6F1"]
    SMAD4        [label="SMAD4\n(Co-SMAD)" fillcolor="#F1948A" fontcolor="white"]
    SMAD7        [label="SMAD7\n(I-SMAD feedback)" fillcolor="#AED6F1"]
    SNAI1        [label="SNAIL/SLUG\nEMT transcription" fillcolor="#F9E79F"]
    TWIST        [label="TWIST1/2\nEMT transcription" fillcolor="#F9E79F"]
    ZEB1_2       [label="ZEB1/ZEB2\nEMT transcription" fillcolor="#F9E79F"]
    E_cadherin   [label="E-Cadherin\n(CDH1) ↓ in EMT" fillcolor="#82E0AA"]
    Vimentin     [label="Vimentin/\nN-Cadherin ↑" fillcolor="#FADBD8"]
    MMP2_9       [label="MMP-2/9\nECM degradation" fillcolor="#FAD7A0"]
    CXCL12       [label="CXCL12/CXCR4\nMetastasis homing" fillcolor="#FAD7A0"]
    Liver_met    [label="Liver Metastasis\nMicroenvironment" fillcolor="#E74C3C" fontcolor="white"]
  }

  /* ═══════════════════════════════════════════════════════════
     CLUSTER 7 — TUMOR MICROENVIRONMENT (TME)
  ═══════════════════════════════════════════════════════════ */
  subgraph cluster_tme {
    label="Tumor Microenvironment (TME)" fontsize=14 fontcolor="#145A32"
    style=filled fillcolor="#E9F7EF" color="#1E8449"

    CD8T         [label="CD8+ T Cells\n(Cytotoxic)" fillcolor="#A9DFBF"]
    CD4T         [label="CD4+ Th1 Cells\n(Helper)" fillcolor="#A9DFBF"]
    Treg         [label="Regulatory T Cells\n(FoxP3+)" fillcolor="#F1948A"]
    NK_cell      [label="NK Cells\n(NKG2D)" fillcolor="#A9DFBF"]
    MDSC         [label="MDSCs\n(G-MDSC/M-MDSC)" fillcolor="#F1948A"]
    M1_mac       [label="M1 Macrophage\n(Pro-inflammatory)" fillcolor="#A9DFBF"]
    M2_mac       [label="M2 Macrophage\n(Pro-tumorigenic TAM)" fillcolor="#F1948A"]
    DC           [label="Dendritic Cells\n(Antigen Presentation)" fillcolor="#A9DFBF"]
    CAF          [label="Cancer-Associated\nFibroblasts (CAF)" fillcolor="#FAD7A0"]
    IFNg         [label="IFN-γ\n(T cell effector)" fillcolor="#A9DFBF"]
    IL10         [label="IL-10\n(Immunosuppressive)" fillcolor="#F1948A"]
    IL6_tme      [label="IL-6\n(CAF secreted)" fillcolor="#FAD7A0"]
    TNFa_tme     [label="TNF-α\n(M1 secreted)" fillcolor="#A9DFBF"]
    TGFb_tme     [label="TGF-β\n(Treg/MDSC)" fillcolor="#F1948A"]
    VEGF_tme     [label="VEGF\n(Hypoxia induced)" fillcolor="#FAD7A0"]
  }

  /* ═══════════════════════════════════════════════════════════
     CLUSTER 8 — IMMUNE CHECKPOINTS
  ═══════════════════════════════════════════════════════════ */
  subgraph cluster_checkpoint {
    label="Immune Checkpoint Axis" fontsize=14 fontcolor="#4A235A"
    style=filled fillcolor="#F4ECF7" color="#8E44AD"

    PD1          [label="PD-1\n(CD279, T cell)" fillcolor="#D7BDE2"]
    PDL1         [label="PD-L1\n(CD274, tumor/APC)" fillcolor="#D7BDE2"]
    PDL2         [label="PD-L2\n(CD273)" fillcolor="#D7BDE2"]
    CTLA4        [label="CTLA-4\n(CD152, T cell)" fillcolor="#D7BDE2"]
    CD80_86      [label="CD80/CD86\n(B7-1/B7-2, APC)" fillcolor="#D7BDE2"]
    TIM3         [label="TIM-3\n(HAVCR2)" fillcolor="#D7BDE2"]
    Gal9         [label="Galectin-9\n(TIM-3 ligand)" fillcolor="#D7BDE2"]
    LAG3         [label="LAG-3\n(CD223)" fillcolor="#D7BDE2"]
    MHCII        [label="MHC Class II\n(CD4 T activation)" fillcolor="#D7BDE2"]
    TCR          [label="TCR Complex\n(CD3/CD28)" fillcolor="#A9DFBF"]
    neoantigen   [label="Neoantigens\n(MSI-H/TMB-H)" fillcolor="#A9DFBF"]
    TIGIT        [label="TIGIT\n(Emerging checkpoint)" fillcolor="#D7BDE2"]
  }

  /* ═══════════════════════════════════════════════════════════
     CLUSTER 9 — ANGIOGENESIS
  ═══════════════════════════════════════════════════════════ */
  subgraph cluster_angio {
    label="Angiogenesis" fontsize=14 fontcolor="#6E2F1A"
    style=filled fillcolor="#FEF9E7" color="#D68910"

    HIF1a        [label="HIF-1α\n(Hypoxia sensor)" fillcolor="#F9E79F"]
    VEGFA        [label="VEGF-A\n(VEGF165)" fillcolor="#F9E79F"]
    VEGFB        [label="VEGF-B/C/D" fillcolor="#FAD7A0"]
    VEGFR1       [label="VEGFR1\n(FLT1)" fillcolor="#FAD7A0"]
    VEGFR2       [label="VEGFR2\n(KDR)" fillcolor="#FAD7A0"]
    Ang1_2       [label="Angiopoietin-1/2\n(Tie2 ligand)" fillcolor="#FAD7A0"]
    Tie2         [label="Tie2 Receptor" fillcolor="#FAD7A0"]
    PlGF         [label="PlGF\n(Placenta GF)" fillcolor="#FAD7A0"]
    DLL4         [label="DLL4/Notch\n(Tip cell regulation)" fillcolor="#FAD7A0"]
    FGFR         [label="FGF/FGFR\n(Angiogenesis)" fillcolor="#FAD7A0"]
    Endothelial  [label="Endothelial Sprouting\nNew Vessel Formation" fillcolor="#FADBD8"]
    VesselDens   [label="Tumor Vessel Density\n(IHC: CD31/CD34)" fillcolor="#FADBD8"]
  }

  /* ═══════════════════════════════════════════════════════════
     CLUSTER 10 — MSI / MMR STATUS
  ═══════════════════════════════════════════════════════════ */
  subgraph cluster_msi {
    label="Microsatellite Instability (MSI) / MMR" fontsize=14 fontcolor="#1A5276"
    style=filled fillcolor="#EBF5FB" color="#2471A3"

    MLH1         [label="MLH1\n(hMutLα)" fillcolor="#AED6F1"]
    MSH2         [label="MSH2\n(hMutSα/β)" fillcolor="#AED6F1"]
    MSH6         [label="MSH6\n(hMutSα)" fillcolor="#AED6F1"]
    PMS2         [label="PMS2\n(hMutLα)" fillcolor="#AED6F1"]
    MSI_H        [label="MSI-High\nCMS1 Subtype" fillcolor="#82E0AA"]
    MSS          [label="MSS\n(Microsatellite Stable)" fillcolor="#FADBD8"]
    TMB          [label="Tumor Mutational\nBurden (TMB-H)" fillcolor="#F9E79F"]
    BRAF_V600E   [label="BRAF V600E\n(sporadic MSI)" fillcolor="#F1948A" fontcolor="white"]
    Lynch_syn    [label="Lynch Syndrome\n(Germline MMR)" fillcolor="#AED6F1"]
    neoant_msi   [label="Frameshift\nNeoantigens" fillcolor="#A9DFBF"]
  }

  /* ═══════════════════════════════════════════════════════════
     CLUSTER 11 — DRUG PK/PD
  ═══════════════════════════════════════════════════════════ */
  subgraph cluster_drugs {
    label="Drug PK / PD" fontsize=14 fontcolor="#212F3C"
    style=filled fillcolor="#F2F3F4" color="#566573"

    /* 5-FU */
    FU_dose      [label="5-FU Dose\n(400 mg/m² IV bolus)" fillcolor="#85C1E9"]
    FU_plasma    [label="5-FU Plasma\n(Cp, μg/mL)" fillcolor="#85C1E9"]
    FUTP         [label="FUTP/FdUMP\n(Active metabolites)" fillcolor="#85C1E9"]
    TS_inhib     [label="Thymidylate Synthase\nInhibition" fillcolor="#85C1E9"]
    DPD          [label="DPD (DPYD)\n5-FU catabolism" fillcolor="#FAD7A0"]
    LV           [label="Leucovorin (LV)\nFolinic acid" fillcolor="#85C1E9"]

    /* Oxaliplatin */
    OX_dose      [label="Oxaliplatin\n85 mg/m² IV" fillcolor="#A9CCE3"]
    OX_plasma    [label="Oxaliplatin Plasma\n(Free Pt)" fillcolor="#A9CCE3"]
    OX_adduct    [label="Pt-DNA Adducts\n(Interstrand XL)" fillcolor="#A9CCE3"]

    /* Irinotecan */
    IRI_dose     [label="Irinotecan\n180 mg/m²" fillcolor="#7DCEA0"]
    IRI_plasma   [label="Irinotecan Plasma\n(Cp, μg/mL)" fillcolor="#7DCEA0"]
    SN38         [label="SN-38 (Active)\n(UGT1A1*28)" fillcolor="#7DCEA0"]
    SN38G        [label="SN-38G\n(Glucuronide)" fillcolor="#7DCEA0"]
    Top1_inhib   [label="Topoisomerase I\nInhibition" fillcolor="#7DCEA0"]

    /* Bevacizumab */
    BEV_dose     [label="Bevacizumab\n5 mg/kg Q2W" fillcolor="#F1948A"]
    BEV_plasma   [label="Bevacizumab Plasma\n(Cmax ~200 μg/mL)" fillcolor="#F1948A"]
    BEV_VEGF     [label="BEV-VEGF Complex\n(Neutralized)" fillcolor="#F1948A"]

    /* Cetuximab/Panitumumab */
    CTX_dose     [label="Cetuximab\n400→250 mg/m²" fillcolor="#D7BDE2"]
    CTX_plasma   [label="Cetuximab Plasma\n(EGFR occupancy)" fillcolor="#D7BDE2"]
    EGFR_inhib   [label="EGFR Inhibition\n(RAS WT only)" fillcolor="#D7BDE2"]

    /* Pembrolizumab */
    PEM_dose     [label="Pembrolizumab\n200 mg Q3W" fillcolor="#A9DFBF"]
    PEM_plasma   [label="Pembrolizumab Plasma\n(PD-1 occupancy)" fillcolor="#A9DFBF"]
    PD1_block    [label="PD-1 Blockade\n(T cell rescue)" fillcolor="#A9DFBF"]

    /* Regorafenib */
    REG_dose     [label="Regorafenib\n160 mg QD" fillcolor="#FAD7A0"]
    REG_plasma   [label="Regorafenib Plasma" fillcolor="#FAD7A0"]
    MultiKinase  [label="Multi-kinase Inhibition\n(VEGFR/PDGFR/BRAF/RET)" fillcolor="#FAD7A0"]
  }

  /* ═══════════════════════════════════════════════════════════
     CLUSTER 12 — CLINICAL ENDPOINTS & BIOMARKERS
  ═══════════════════════════════════════════════════════════ */
  subgraph cluster_endpoints {
    label="Clinical Endpoints & Biomarkers" fontsize=14 fontcolor="#1B2631"
    style=filled fillcolor="#FDFEFE" color="#717D7E"

    Tumor_cells  [label="Tumor Cell Burden\n(viable/apoptotic)" fillcolor="#FADBD8"]
    RECIST       [label="RECIST 1.1\n(CR/PR/SD/PD)" fillcolor="#F9E79F"]
    CEA          [label="CEA Biomarker\n(ng/mL)" fillcolor="#F9E79F"]
    CA199        [label="CA 19-9\n(Pancreatic/biliary)" fillcolor="#F9E79F"]
    ctDNA        [label="ctDNA / cfDNA\n(Liquid biopsy)" fillcolor="#A9DFBF"]
    RAS_status   [label="RAS/BRAF Status\n(tumor genotype)" fillcolor="#AED6F1"]
    MSI_test     [label="MSI Testing\n(PCR/IHC/NGS)" fillcolor="#AED6F1"]
    ORR          [label="Objective Response Rate\n(ORR %)" fillcolor="#FADBD8"]
    PFS_end      [label="Progression-Free\nSurvival (PFS)" fillcolor="#FADBD8"]
    OS_end       [label="Overall Survival\n(OS months)" fillcolor="#FADBD8"]
    QoL          [label="QoL Score\n(EORTC QLQ-CR29)" fillcolor="#F9E79F"]
    Toxicity     [label="Toxicity\n(CTCAE Grade 3-4)" fillcolor="#FADBD8"]
  }

  /* ═══════════════════════════════════════════════════════════
     EDGES — WNT PATHWAY
  ═══════════════════════════════════════════════════════════ */
  Wnt_ligand -> FZD [color="#8E44AD"]
  FZD -> LRP5_6 [color="#8E44AD"]
  LRP5_6 -> DVL [color="#8E44AD"]
  DVL -> BCAT_dest [label="Inhibits" color="#C0392B"]
  APC -> BCAT_dest [label="Scaffold" color="#8E44AD"]
  AXIN -> BCAT_dest [label="Scaffold" color="#8E44AD"]
  GSK3B -> BCAT_dest [label="Phosphorylates" color="#8E44AD"]
  CK1a -> BCAT_dest [label="Primes" color="#8E44AD"]
  BCAT_dest -> BCAT_free [label="Degraded\n(Wnt OFF)" color="#C0392B" style=dashed]
  APC -> BCAT_free [label="APC mut→\nfree β-cat" color="#C0392B"]
  BCAT_free -> TCF_LEF [label="Nuclear\ntranslocation" color="#27AE60"]
  TCF_LEF -> cMYC_wnt [label="Transcription" color="#27AE60"]
  TCF_LEF -> CCND1_wnt [label="Transcription" color="#27AE60"]
  TCF_LEF -> AXIN2_fb [label="Negative fb" color="#C0392B" style=dashed]
  RSPO -> RNF43 [label="Inhibits\n(ZNRF3/RNF43)" color="#27AE60"]
  RNF43 -> FZD [label="Ubiquitinates↓" color="#C0392B"]
  CCND1_wnt -> CCND1 [color="#C0392B"]
  cMYC_wnt -> cMYC_ras [color="#C0392B"]

  /* ═══════════════════════════════════════════════════════════
     EDGES — RAS/MAPK
  ═══════════════════════════════════════════════════════════ */
  EGFR -> GRB2 [color="#2980B9"]
  HER2 -> GRB2 [color="#2980B9"]
  GRB2 -> RAS [label="SOS-GEF" color="#2980B9"]
  RAS -> BRAF_node [color="#2980B9"]
  RAS -> CRAF [color="#2980B9"]
  BRAF_node -> MEK1 [color="#2980B9"]
  CRAF -> MEK1 [color="#2980B9"]
  MEK1 -> ERK1 [color="#2980B9"]
  ERK1 -> RSK [color="#2980B9"]
  ERK1 -> ELK1 [color="#2980B9"]
  ERK1 -> DUSP6 [label="Negative fb" color="#C0392B" style=dashed]
  ERK1 -> SPRY [label="Negative fb" color="#C0392B" style=dashed]
  ELK1 -> cFOS_cJUN [color="#2980B9"]
  cFOS_cJUN -> cMYC_ras [color="#2980B9"]
  KRAS_mut -> RAS [label="Constitutive\nactivation" color="#E74C3C"]
  SPRY -> EGFR [label="Inhibits" color="#C0392B"]
  DUSP6 -> ERK1 [label="Dephosphorylates" color="#C0392B"]
  RAS -> PI3K [color="#2980B9"]
  EGFR -> PI3K [color="#2980B9"]

  /* ═══════════════════════════════════════════════════════════
     EDGES — PI3K/AKT
  ═══════════════════════════════════════════════════════════ */
  PI3K -> PIP3 [label="PIP2→PIP3" color="#27AE60"]
  PIP2 -> PI3K [color="#27AE60"]
  PTEN -> PIP3 [label="PIP3→PIP2\n(Opposes)" color="#C0392B"]
  PIP3 -> PDK1 [color="#27AE60"]
  PDK1 -> AKT [label="Thr308" color="#27AE60"]
  mTORC2 -> AKT [label="Ser473" color="#27AE60"]
  AKT -> mTORC1 [label="TSC inhibition" color="#27AE60"]
  AKT -> TSC1_2 [label="Phospho-inhibit" color="#C0392B"]
  TSC1_2 -> mTORC1 [label="GAP for Rheb" color="#C0392B"]
  mTORC1 -> S6K [color="#27AE60"]
  mTORC1 -> fourEBP1 [label="Phospho-release" color="#27AE60"]
  AKT -> FOXO [label="Nuclear export" color="#C0392B"]
