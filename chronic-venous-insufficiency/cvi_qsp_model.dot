// Chronic Venous Insufficiency (CVI) QSP Mechanistic Map
// Generated for QSP Disease Model Library
// Layout: Left-to-Right, color-coded clusters

digraph CVI_QSP {
    rankdir=LR;
    graph [
        fontname="Helvetica",
        fontsize=11,
        bgcolor="white",
        splines=spline,
        nodesep=0.4,
        ranksep=0.8,
        label="Chronic Venous Insufficiency (CVI)\nQuantitative Systems Pharmacology Mechanistic Map",
        labelloc=t,
        labeljust=c,
        fontsize=16
    ];
    node [
        fontname="Helvetica",
        fontsize=9,
        style="filled,rounded",
        shape=box,
        margin="0.15,0.08"
    ];
    edge [
        fontname="Helvetica",
        fontsize=8,
        arrowsize=0.7
    ];

    // =========================================================
    // CLUSTER 1: Risk Factors
    // =========================================================
    subgraph cluster_risk {
        label="Risk Factors";
        style=filled;
        fillcolor="#FFEBEE";
        color="#C62828";
        fontcolor="#C62828";
        fontsize=12;
        fontname="Helvetica-Bold";

        aging        [label="Aging\n(collagen↓, valve\ndegradation)", fillcolor="#FFCDD2", color="#C62828"];
        obesity      [label="Obesity\n(BMI↑, IVC\npressure↑)", fillcolor="#FFCDD2", color="#C62828"];
        pregnancy    [label="Pregnancy\n(hormonal, IVC\ncompression)", fillcolor="#FFCDD2", color="#C62828"];
        family_hx    [label="Family History\n(genetic\npredisposition)", fillcolor="#FFCDD2", color="#C62828"];
        female_sex   [label="Female Sex\n(estrogen effects\non veins)", fillcolor="#FFCDD2", color="#C62828"];
        prolong_stand [label="Prolonged\nStanding\n(occupation)", fillcolor="#FFCDD2", color="#C62828"];
        prior_dvt    [label="Prior DVT\n(post-thrombotic\nsyndrome)", fillcolor="#FFCDD2", color="#C62828"];
        leg_trauma   [label="Leg Trauma\n(valve damage,\nfibrous scarring)", fillcolor="#FFCDD2", color="#C62828"];
        FOXC2_gene   [label="FOXC2 Gene\n(valve development\nmutation)", fillcolor="#FFCDD2", color="#C62828"];
        MMP_poly     [label="MMP\nPolymorphisms\n(ECM turnover↑)", fillcolor="#FFCDD2", color="#C62828"];
    }

    // =========================================================
    // CLUSTER 2: Venous Anatomy / Hemodynamics
    // =========================================================
    subgraph cluster_hemodynamics {
        label="Venous Anatomy & Hemodynamics";
        style=filled;
        fillcolor="#E3F2FD";
        color="#1565C0";
        fontcolor="#1565C0";
        fontsize=12;
        fontname="Helvetica-Bold";

        GSV          [label="Great Saphenous\nVein (GSV)", fillcolor="#BBDEFB", color="#1565C0"];
        SSV          [label="Small Saphenous\nVein (SSV)", fillcolor="#BBDEFB", color="#1565C0"];
        deep_veins   [label="Deep Veins\n(femoral, popliteal,\ntibial)", fillcolor="#BBDEFB", color="#1565C0"];
        perforator   [label="Perforator Veins\n(fascial\npenetrating)", fillcolor="#BBDEFB", color="#1565C0"];
        venous_valves [label="Venous Valves\n(bicuspid, intimal\nleaflets)", fillcolor="#BBDEFB", color="#1565C0"];
        valve_incomp [label="Valve\nIncompetence\n(structural failure)", fillcolor="#90CAF9", color="#1565C0", penwidth=2];
        retro_flow   [label="Retrograde\nFlow / Reflux\n(mL/s)", fillcolor="#BBDEFB", color="#1565C0"];
        AVP          [label="Ambulatory\nVenous Pressure\n(AVP, mmHg)", fillcolor="#90CAF9", color="#1565C0", penwidth=2];
        cap_pressure [label="Capillary\nPressure\n(mmHg)", fillcolor="#BBDEFB", color="#1565C0"];
        calf_pump    [label="Calf Muscle\nPump Function\n(EF%)", fillcolor="#BBDEFB", color="#1565C0"];
        VRT          [label="Venous Refill\nTime (VRT, s)", fillcolor="#BBDEFB", color="#1565C0"];
        venous_vol   [label="Venous Volume\n(mL)", fillcolor="#BBDEFB", color="#1565C0"];
        SVI          [label="Saphenous Vein\nIncompetence\nIndex (SVI)", fillcolor="#BBDEFB", color="#1565C0"];
        reflux_index [label="Reflux Index\n(RI, s)", fillcolor="#BBDEFB", color="#1565C0"];
    }

    // =========================================================
    // CLUSTER 3: Endothelial Biology
    // =========================================================
    subgraph cluster_endothelial {
        label="Endothelial Biology";
        style=filled;
        fillcolor="#E8F5E9";
        color="#2E7D32";
        fontcolor="#2E7D32";
        fontsize=12;
        fontname="Helvetica-Bold";

        wall_shear   [label="Wall Shear\nStress (WSS)\n(Pa)", fillcolor="#C8E6C9", color="#2E7D32"];
        eNOS         [label="eNOS\nActivity\n(endothelial NOS)", fillcolor="#C8E6C9", color="#2E7D32"];
        NO           [label="Nitric Oxide\n(NO)\n(vasodilation)", fillcolor="#A5D6A7", color="#2E7D32", penwidth=2];
        ET1          [label="Endothelin-1\n(ET-1)\n(vasoconstriction)", fillcolor="#C8E6C9", color="#2E7D32"];
        ICAM1        [label="ICAM-1\n(adhesion\nmolecule)", fillcolor="#C8E6C9", color="#2E7D32"];
        VCAM1        [label="VCAM-1\n(adhesion\nmolecule)", fillcolor="#C8E6C9", color="#2E7D32"];
        E_selectin   [label="E-Selectin\n(leukocyte\nrolling)", fillcolor="#C8E6C9", color="#2E7D32"];
        P_selectin   [label="P-Selectin\n(platelet &\nleukocyte)", fillcolor="#C8E6C9", color="#2E7D32"];
        vasc_perm    [label="Vascular\nPermeability\n(Kf, mL/min/mmHg)", fillcolor="#A5D6A7", color="#2E7D32", penwidth=2];
        VEGF         [label="VEGF\n(angiogenesis,\npermeability)", fillcolor="#C8E6C9", color="#2E7D32"];
        HIF1a        [label="HIF-1α\n(hypoxia-inducible\nfactor)", fillcolor="#C8E6C9", color="#2E7D32"];
        tissue_hypox [label="Tissue\nHypoxia\n(pO2↓)", fillcolor="#C8E6C9", color="#2E7D32"];
        ROS          [label="Reactive Oxygen\nSpecies (ROS)\n(oxidative stress)", fillcolor="#C8E6C9", color="#2E7D32"];
        EC_apoptosis [label="EC Apoptosis\n(endothelial\ncell death)", fillcolor="#C8E6C9", color="#2E7D32"];
    }

    // =========================================================
    // CLUSTER 4: Leukocyte Trafficking
    // =========================================================
    subgraph cluster_leukocyte {
        label="Leukocyte Trafficking";
        style=filled;
        fillcolor="#FFF3E0";
        color="#E65100";
        fontcolor="#E65100";
        fontsize=12;
        fontname="Helvetica-Bold";

        WBC_marg     [label="WBC\nMargination\n(venular trapping)", fillcolor="#FFE0B2", color="#E65100"];
        neutro_act   [label="Neutrophil\nActivation\n(oxidative burst)", fillcolor="#FFE0B2", color="#E65100"];
        macro_act    [label="Macrophage\nActivation\n(M1/M2 ratio)", fillcolor="#FFE0B2", color="#E65100"];
        mast_degran  [label="Mast Cell\nDegranulation\n(histamine, heparin)", fillcolor="#FFE0B2", color="#E65100"];
        T_cell_infil [label="T Cell\nInfiltration\n(CD4/CD8)", fillcolor="#FFE0B2", color="#E65100"];
        B_cells      [label="B Cells\n(local\nantibody)", fillcolor="#FFE0B2", color="#E65100"];
        leuko_trap   [label="Leukocyte\nTrapping\n(microvascular)", fillcolor="#FFCC80", color="#E65100", penwidth=2];
        neutro_elast [label="Neutrophil\nElastase\n(protease)", fillcolor="#FFE0B2", color="#E65100"];
        NETs         [label="NETs\n(Neutrophil\nExtracell Traps)", fillcolor="#FFE0B2", color="#E65100"];
        phagocytosis [label="Phagocytosis\n(debris\nclearance)", fillcolor="#FFE0B2", color="#E65100"];
    }

    // =========================================================
    // CLUSTER 5: Inflammatory Mediators
    // =========================================================
    subgraph cluster_inflammatory {
        label="Inflammatory Mediators";
        style=filled;
        fillcolor="#F3E5F5";
        color="#6A1B9A";
        fontcolor="#6A1B9A";
        fontsize=12;
        fontname="Helvetica-Bold";

        IL1b         [label="IL-1β\n(pro-inflammatory\ncytokine)", fillcolor="#E1BEE7", color="#6A1B9A"];
        IL6          [label="IL-6\n(acute phase,\nchemotaxis)", fillcolor="#E1BEE7", color="#6A1B9A"];
        TNFa         [label="TNF-α\n(NF-κB\nactivation)", fillcolor="#CE93D8", color="#6A1B9A", penwidth=2];
        IL4_IL13     [label="IL-4/IL-13\n(Th2, M2\npolarization)", fillcolor="#E1BEE7", color="#6A1B9A"];
        TGFb         [label="TGF-β\n(fibrosis,\nECM synthesis)", fillcolor="#CE93D8", color="#6A1B9A", penwidth=2];
        IL10         [label="IL-10\n(anti-inflammatory\nresolution)", fillcolor="#E1BEE7", color="#6A1B9A"];
        CRP          [label="CRP\n(systemic\ninflammation)", fillcolor="#E1BEE7", color="#6A1B9A"];
        fibrinogen   [label="Fibrinogen\n(acute phase\nprotein)", fillcolor="#E1BEE7", color="#6A1B9A"];
        MCP1         [label="MCP-1\n(monocyte\nchemoattractant)", fillcolor="#E1BEE7", color="#6A1B9A"];
        RANTES       [label="RANTES\n(CCL5, T cell\nrecruitment)", fillcolor="#E1BEE7", color="#6A1B9A"];
        histamine    [label="Histamine\n(vasodilation,\npermeability)", fillcolor="#E1BEE7", color="#6A1B9A"];
        serotonin    [label="Serotonin\n(platelet,\nvasoconstriction)", fillcolor="#E1BEE7", color="#6A1B9A"];
        bradykinin   [label="Bradykinin\n(pain, edema,\nvasodilation)", fillcolor="#E1BEE7", color="#6A1B9A"];
        substance_P  [label="Substance P\n(neurogenic\ninflammation)", fillcolor="#E1BEE7", color="#6A1B9A"];
    }

    // =========================================================
    // CLUSTER 6: Coagulation / Fibrinolysis
    // =========================================================
    subgraph cluster_coagulation {
        label="Coagulation & Fibrinolysis";
        style=filled;
        fillcolor="#FBE9E7";
        color="#BF360C";
        fontcolor="#BF360C";
        fontsize=12;
        fontname="Helvetica-Bold";

        tissue_factor [label="Tissue Factor\n(TF, coagulation\ninit.)", fillcolor="#FFCCBC", color="#BF360C"];
        thrombin     [label="Thrombin\n(serine protease,\nfibrin gen.)", fillcolor="#FFAB91", color="#BF360C", penwidth=2];
        fibrin       [label="Fibrin\n(clot\nstructure)", fillcolor="#FFCCBC", color="#BF360C"];
        platelets    [label="Platelets\n(activation,\naggregation)", fillcolor="#FFCCBC", color="#BF360C"];
        PAI1         [label="PAI-1\n(fibrinolysis\ninhibitor)", fillcolor="#FFCCBC", color="#BF360C"];
        tPA          [label="t-PA\n(tissue\nplasminogen act.)", fillcolor="#FFCCBC", color="#BF360C"];
        plasmin      [label="Plasmin\n(fibrin\ndegradation)", fillcolor="#FFCCBC", color="#BF360C"];
        fibrin_cuff  [label="Fibrin Cuff\n(pericapillary\nbarrier)", fillcolor="#FFAB91", color="#BF360C", penwidth=2];
        DVT          [label="Deep Vein\nThrombosis\n(DVT)", fillcolor="#FFCCBC", color="#BF360C"];
        PTS          [label="Post-Thrombotic\nSyndrome\n(PTS)", fillcolor="#FFCCBC", color="#BF360C"];
        D_dimer      [label="D-Dimer\n(fibrin\ndegradation prod.)", fillcolor="#FFCCBC", color="#BF360C"];
        vWF          [label="von Willebrand\nFactor (vWF)\n(platelet adhesion)", fillcolor="#FFCCBC", color="#BF360C"];
    }

    // =========================================================
    // CLUSTER 7: ECM Remodeling
    // =========================================================
    subgraph cluster_ECM {
        label="ECM Remodeling";
        style=filled;
        fillcolor="#E8F5E9";
        color="#1B5E20";
        fontcolor="#1B5E20";
        fontsize=12;
        fontname="Helvetica-Bold";

        fibroblasts  [label="Fibroblasts\n(ECM\nproducers)", fillcolor="#A5D6A7", color="#1B5E20"];
        myofibroblast [label="Myofibroblasts\n(αSMA+,\ncontractile)", fillcolor="#A5D6A7", color="#1B5E20"];
        collagen_I   [label="Collagen I\n(fibrillar,\nscaffold)", fillcolor="#81C784", color="#1B5E20", penwidth=2];
        collagen_III [label="Collagen III\n(reticular,\nrepair)", fillcolor="#A5D6A7", color="#1B5E20"];
        collagen_IV  [label="Collagen IV\n(basement\nmembrane)", fillcolor="#A5D6A7", color="#1B5E20"];
        MMP1         [label="MMP-1\n(collagenase-1,\ncol I/III cleave)", fillcolor="#A5D6A7", color="#1B5E20"];
        MMP2         [label="MMP-2\n(gelatinase A,\ncol IV cleave)", fillcolor="#A5D6A7", color="#1B5E20"];
        MMP3         [label="MMP-3\n(stromelysin-1,\nbroad spectrum)", fillcolor="#A5D6A7", color="#1B5E20"];
        MMP9         [label="MMP-9\n(gelatinase B,\ninflammation)", fillcolor="#81C784", color="#1B5E20", penwidth=2];
        MMP13        [label="MMP-13\n(collagenase-3,\ncartilage/skin)", fillcolor="#A5D6A7", color="#1B5E20"];
        TIMP1        [label="TIMP-1\n(MMP\ninhibitor)", fillcolor="#A5D6A7", color="#1B5E20"];
        TIMP2        [label="TIMP-2\n(MMP-2\ninhibitor)", fillcolor="#A5D6A7", color="#1B5E20"];
        elastin      [label="Elastin\n(vascular\nelasticity)", fillcolor="#A5D6A7", color="#1B5E20"];
        hyaluronic   [label="Hyaluronic Acid\n(HA, glycosamino-\nglycan)", fillcolor="#A5D6A7", color="#1B5E20"];
        fibronectin  [label="Fibronectin\n(cell adhesion,\nwound repair)", fillcolor="#A5D6A7", color="#1B5E20"];
        SMC_switch   [label="SMC Phenotype\nSwitch\n(synthetic)", fillcolor="#81C784", color="#1B5E20", penwidth=2];
        lipodermato  [label="Lipoderma-\ntosclerosis\n(fibro-sclerosis)", fillcolor="#66BB6A", color="#1B5E20", penwidth=2];
    }

    // =========================================================
    // CLUSTER 8: Microcirculation & Skin Changes
    // =========================================================
    subgraph cluster_microcirculation {
        label="Microcirculation & Skin Changes";
        style=filled;
        fillcolor="#F9FBE7";
        color="#827717";
        fontcolor="#827717";
        fontsize=12;
        fontname="Helvetica-Bold";

        cap_hypert   [label="Capillary\nHypertension\n(mmHg↑)", fillcolor="#F0F4C3", color="#827717", penwidth=2];
        interst_edema [label="Interstitial\nEdema\n(protein-rich)", fillcolor="#E6EE9C", color="#827717", penwidth=2];
        lymph_over   [label="Lymphatic\nOverload\n(insufficiency)", fillcolor="#F0F4C3", color="#827717"];
        hemosiderin  [label="Hemosiderin\nDeposition\n(RBC extravasat.)", fillcolor="#F0F4C3", color="#827717"];
        melanocyte   [label="Melanocyte\nActivation\n(hyperpigmentation)", fillcolor="#F0F4C3", color="#827717"];
        stasis_derm  [label="Stasis\nDermatitis\n(eczema)", fillcolor="#E6EE9C", color="#827717"];
        atrophie_bl  [label="Atrophie\nBlanche\n(white scarring)", fillcolor="#F0F4C3", color="#827717"];
        microthrombi [label="Microthrombi\n(capillary\nocclusion)", fillcolor="#F0F4C3", color="#827717"];
        pericyte_loss [label="Pericyte\nLoss\n(capillary support)", fillcolor="#F0F4C3", color="#827717"];
        telangiect   [label="Telangiectasia\n(dilated\nmicrovessels)", fillcolor="#F0F4C3", color="#827717"];
    }

    // =========================================================
    // CLUSTER 9: Wound Healing & Venous Ulceration
    // =========================================================
    subgraph cluster_wound {
        label="Wound Healing & Venous Ulceration";
        style=filled;
        fillcolor="#ECEFF1";
        color="#37474F";
        fontcolor="#37474F";
        fontsize=12;
        fontname="Helvetica-Bold";

        skin_breakdown [label="Skin\nBreakdown\n(ulcer initiation)", fillcolor="#CFD8DC", color="#37474F", penwidth=2];
        ulcer_area   [label="Ulcer Area\n(cm², healing\ntrajectory)", fillcolor="#B0BEC5", color="#37474F", penwidth=2];
        biofilm      [label="Biofilm\n(bacterial,\nPseudomonas/MRSA)", fillcolor="#CFD8DC", color="#37474F"];
        keratino_mig [label="Keratinocyte\nMigration\n(re-epithelial.)", fillcolor="#CFD8DC", color="#37474F"];
        granulation  [label="Granulation\nTissue\n(fibroblast/vessel)", fillcolor="#CFD8DC", color="#37474F"];
        re_epithel   [label="Re-epithelialization\nRate\n(mm/day)", fillcolor="#CFD8DC", color="#37474F"];
        EGF_KGF      [label="EGF / KGF\n(epithelial\ngrowth factors)", fillcolor="#CFD8DC", color="#37474F"];
        PDGF_BB      [label="PDGF-BB\n(platelet-derived\ngrowth factor)", fillcolor="#CFD8DC", color="#37474F"];
        wound_cont   [label="Wound\nContraction\n(myofibroblast)", fillcolor="#CFD8DC", color="#37474F"];
        scar_form    [label="Scar\nFormation\n(collagen remodel.)", fillcolor="#CFD8DC", color="#37474F"];
        wound_pain   [label="Wound Pain\n(nociceptor,\nneuropeptides)", fillcolor="#CFD8DC", color="#37474F"];
        wound_infect [label="Wound\nInfection\n(bacterial load)", fillcolor="#CFD8DC", color="#37474F"];
    }

    // =========================================================
    // CLUSTER 10: Drug PK/PD
    // =========================================================
    subgraph cluster_drugs {
        label="Drug PK/PD";
        style=filled;
        fillcolor="#EDE7F6";
        color="#4527A0";
        fontcolor="#4527A0";
        fontsize=12;
        fontname="Helvetica-Bold";

        // MPFF (Micronized Purified Flavonoid Fraction - Daflon)
        MPFF_oral    [label="MPFF\nOral Dose\n(500mg tablet)", fillcolor="#D1C4E9", color="#4527A0", shape=diamond];
        MPFF_gut     [label="MPFF\nGut\n(absorption 70%)", fillcolor="#D1C4E9", color="#4527A0"];
        MPFF_plasma  [label="MPFF\nPlasma\n(Cmax ~1.5μg/mL)", fillcolor="#B39DDB", color="#4527A0", penwidth=2];
        MPFF_PD      [label="MPFF PD\n(venotonic,\nanti-inflam)", fillcolor="#9575CD", color="#4527A0", penwidth=2];

        // Pentoxifylline
        PTX_oral     [label="Pentoxifylline\nOral Dose\n(400mg)", fillcolor="#D1C4E9", color="#4527A0", shape=diamond];
        PTX_plasma   [label="PTX Plasma\n(Cmax ~0.5μg/mL\nt½ ~1h)", fillcolor="#D1C4E9", color="#4527A0"];
        PTX_PD       [label="PTX PD\n(hemorheology,\nanti-TNFα)", fillcolor="#B39DDB", color="#4527A0", penwidth=2];

        // LMWH
        LMWH_SC      [label="LMWH\nSC Depot\n(enoxaparin)", fillcolor="#D1C4E9", color="#4527A0", shape=diamond];
        LMWH_central [label="LMWH\nCentral\n(anti-Xa 0.5-1.2)", fillcolor="#D1C4E9", color="#4527A0"];
        LMWH_PD      [label="LMWH PD\n(anti-Xa,\nanti-thrombin)", fillcolor="#B39DDB", color="#4527A0", penwidth=2];

        // Rutosides
        ruto_oral    [label="Rutosides\nOral Dose\n(hydroxyethyl)", fillcolor="#D1C4E9", color="#4527A0", shape=diamond];
        ruto_plasma  [label="Rutoside\nPlasma\n(Cmax ~1μg/mL)", fillcolor="#D1C4E9", color="#4527A0"];
        ruto_PD      [label="Rutoside PD\n(capillary protect.,\nanti-edema)", fillcolor="#B39DDB", color="#4527A0", penwidth=2];

        // Compression therapy
        compression  [label="Compression\nTherapy\n(20-40 mmHg)", fillcolor="#D1C4E9", color="#4527A0", shape=parallelogram];
        compress_PD  [label="Compression\nPD\n(AVP↓, edema↓)", fillcolor="#9575CD", color="#4527A0", penwidth=2];

        // Wound care
        wound_care   [label="Wound Care\n(dressings,\ndebridement)", fillcolor="#D1C4E9", color="#4527A0", shape=parallelogram];
        antibiotics  [label="Antibiotics\n(topical/systemic\ninfection ctrl)", fillcolor="#D1C4E9", color="#4527A0", shape=diamond];
    }

    // =========================================================
    // CLUSTER 11: Clinical Endpoints
    // =========================================================
    subgraph cluster_endpoints {
        label="Clinical Endpoints";
        style=filled;
        fillcolor="#FCE4EC";
        color="#880E4F";
        fontcolor="#880E4F";
        fontsize=12;
        fontname="Helvetica-Bold";

        CEAP         [label="CEAP\nClassification\n(C0-C6)", fillcolor="#F8BBD9", color="#880E4F", penwidth=2];
        VCSS         [label="VCSS\n(Venous Clinical\nSeverity Score)", fillcolor="#F48FB1", color="#880E4F", penwidth=2];
        pain_VAS     [label="Pain VAS\n(0-10 cm\nvisual analogue)", fillcolor="#F8BBD9", color="#880E4F"];
        heaviness    [label="Heaviness /\nFatigue Score\n(patient-reported)", fillcolor="#F8BBD9", color="#880E4F"];
        edema_score  [label="Edema Score\n(ankle circ.,\npitting grade)", fillcolor="#F8BBD9", color="#880E4F"];
        skin_score   [label="Skin Changes\nScore\n(pigmentation, LDS)", fillcolor="#F8BBD9", color="#880E4F"];
        ulcer_heal   [label="Ulcer Healing\nRate\n(% healed at 12wk)", fillcolor="#F48FB1", color="#880E4F", penwidth=2];
        ulcer_recur  [label="Ulcer\nRecurrence\n(% at 1yr)", fillcolor="#F8BBD9", color="#880E4F"];
        CIVIQ        [label="CIVIQ QoL\n(Chronic Venous\nInsufficiency QoL)", fillcolor="#F8BBD9", color="#880E4F"];
        AVVQ         [label="AVVQ\n(Aberdeen Varicose\nVein Questionnaire)", fillcolor="#F8BBD9", color="#880E4F"];
        duplex_US    [label="Duplex\nUltrasound\n(reflux, anatomy)", fillcolor="#F8BBD9", color="#880E4F"];
        APG          [label="APG\n(Air Plethysmography\nEF, VV, RVF)", fillcolor="#F8BBD9", color="#880E4F"];
    }

    // =========================================================
    // EDGES: Risk Factors → Hemodynamics
    // =========================================================
    aging        -> venous_valves   [label="collagen\ndegradation", style=bold, color="#C62828", penwidth=2];
    aging        -> calf_pump       [label="muscle\natrophy", style=bold, color="#C62828"];
    obesity      -> AVP             [label="IVC\npressure↑", style=bold, color="#C62828", penwidth=2];
    pregnancy    -> valve_incomp    [label="hormonal\nrelaxin", style=bold, color="#C62828"];
    family_hx    -> venous_valves   [label="inherited\nweakness", color="#C62828"];
    FOXC2_gene   -> venous_valves   [label="valve\ndevelopment↓", color="#C62828"];
    MMP_poly     -> MMP9            [label="↑ MMP9\nexpression", color="#C62828"];
    prior_dvt    -> valve_incomp    [label="post-thrombotic\ndamage", style=bold, color="#C62828", penwidth=2];
    prior_dvt    -> PTS             [label="leads to", style=bold, color="#C62828"];
    prolong_stand -> AVP            [label="hydrostatic\nload", color="#C62828"];
    leg_trauma   -> valve_incomp    [label="direct\ndamage", color="#C62828"];
    female_sex   -> valve_incomp    [label="estrogen\neffects", color="#C62828"];

    // =========================================================
    // EDGES: Venous Anatomy → Hemodynamics Cascade
    // =========================================================
    GSV          -> valve_incomp    [label="primary\nvarices", color="#1565C0"];
    SSV          -> valve_incomp    [label="posterior\ninsufficiency", color="#1565C0"];
    perforator   -> retro_flow      [label="outward\ntransmission", color="#1565C0"];
    venous_valves -> valve_incomp   [label="structural\nfailure", style=bold, color="#1565C0", penwidth=2];
    valve_incomp -> retro_flow      [label="reversal of\nflow", style=bold, color="#1565C0", penwidth=2];
    retro_flow   -> AVP             [label="pressure\nbuild-up", style=bold, color="#1565C0", penwidth=2];
    AVP          -> cap_pressure    [label="transmitted\npressure", style=bold, color="#1565C0", penwidth=2];
    AVP          -> VRT             [label="refill\ntime↓", color="#1565C0"];
    AVP          -> SVI             [label="severity\nindex↑", color="#1565C0"];
    calf_pump    -> AVP             [label="EF↓ → AVP↑", style=dashed, color="#1565C0"];
    venous_vol   -> AVP             [label="venous\nvolume↑", color="#1565C0"];
    reflux_index -> retro_flow      [label="quantifies", color="#1565C0"];
    deep_veins   -> DVT             [label="thrombosis\nsite", color="#1565C0"];

    // =========================================================
    // EDGES: Hemodynamics → Endothelial Biology
    // =========================================================
    cap_pressure -> wall_shear      [label="oscillatory\nshear", style=bold, color="#1565C0", penwidth=2];
    AVP          -> tissue_hypox    [label="capillary\nocclusion", color="#1565C0"];
    wall_shear   -> eNOS            [label="shear\nactivation", style=bold, color="#2E7D32", penwidth=2];
    wall_shear   -> ICAM1           [label="low shear\ninduces", color="#2E7D32"];
    wall_shear   -> VCAM1           [label="low shear\ninduces", color="#2E7D32"];
    eNOS         -> NO              [label="catalysis", style=bold, color="#2E7D32", penwidth=2];
    NO           -> vasc_perm       [label="↓ permeability\n(protective)", style=dashed, color="#2E7D32"];
    NO           -> ET1             [label="inhibits", style=dashed, color="#2E7D32", arrowhead=tee];
    tissue_hypox -> HIF1a           [label="stabilization", style=bold, color="#2E7D32", penwidth=2];
    HIF1a        -> VEGF            [label="transcription↑", style=bold, color="#2E7D32"];
    HIF1a        -> ET1             [label="ET-1↑", color="#2E7D32"];
    VEGF         -> vasc_perm       [label="permeability↑", style=bold, color="#2E7D32", penwidth=2];
    ET1          -> vasc_perm       [label="permeability↑", color="#2E7D32"];
    ROS          -> eNOS            [label="uncoupling\n(NO↓)", style=dashed, color="#2E7D32", arrowhead=tee];
    ROS          -> EC_apoptosis    [label="oxidative\nstress", color="#2E7D32"];
    ROS          -> ICAM1           [label="expression↑", color="#2E7D32"];
    ICAM1        -> WBC_marg        [label="firm\nadhesion", style=bold, color="#E65100", penwidth=2];
    VCAM1        -> WBC_marg        [label="firm\nadhesion", style=bold, color="#E65100"];
    E_selectin   -> WBC_marg        [label="rolling\ncapture", color="#E65100"];
    P_selectin   -> WBC_marg        [label="platelet\nadhesion", color="#E65100"];
    P_selectin   -> platelets       [label="platelet\nactivation", color="#BF360C"];

    // =========================================================
    // EDGES: Capillary Pressure → Microcirculation
    // =========================================================
    cap_pressure -> cap_hypert      [label="direct\ntransmission", style=bold, color="#827717", penwidth=2];
    cap_hypert   -> interst_edema   [label="fluid\nfiltration↑", style=bold, color="#827717", penwidth=2];
    cap_hypert   -> microthrombi    [label="stasis,\nhypercoagul.", color="#827717"];
    interst_edema -> lymph_over     [label="overloads\nlymphatics", style=bold, color="#827717"];
    interst_edema -> stasis_derm    [label="chronic\nskinn change", color="#827717"];
    microthrombi -> pericyte_loss   [label="ischemia", color="#827717"];

    // =========================================================
    // EDGES: Endothelial → Leukocyte Trafficking
    // =========================================================
    vasc_perm    -> WBC_marg        [label="diapedesis↑", color="#E65100"];
    WBC_marg     -> neutro_act      [label="activation", style=bold, color="#E65100", penwidth=2];
    WBC_marg     -> leuko_trap      [label="venular\ntrapping", style=bold, color="#E65100", penwidth=2];
    WBC_marg     -> macro_act       [label="transmig-\nration", color="#E65100"];
    neutro_act   -> neutro_elast    [label="degranulation", color="#E65100"];
    neutro_act   -> NETs            [label="NET release", color="#E65100"];
    neutro_act   -> ROS             [label="NADPH\noxidase", color="#2E7D32"];
    mast_degran  -> histamine       [label="release", style=bold, color="#6A1B9A"];
    mast_degran  -> serotonin       [label="release", color="#6A1B9A"];
    macro_act    -> TNFa            [label="secretion↑", style=bold, color="#6A1B9A", penwidth=2];
    macro_act    -> IL1b            [label="secretion↑", style=bold, color="#6A1B9A", penwidth=2];
    macro_act    -> MCP1            [label="secretion↑", color="#6A1B9A"];
    T_cell_infil -> IL4_IL13        [label="Th2\ncytokines", color="#6A1B9A"];
    T_cell_infil -> RANTES          [label="CCL5\nsecretion", color="#6A1B9A"];
    leuko_trap   -> tissue_hypox    [label="O2\nconsumption↑", color="#2E7D32"];
    phagocytosis -> hemosiderin     [label="RBC\ndegradation", color="#827717"];

    // =========================================================
    // EDGES: Inflammatory Mediators
    // =========================================================
    TNFa         -> ICAM1           [label="NF-κB\nupregulation", style=bold, color="#6A1B9A", penwidth=2];
    TNFa         -> VCAM1           [label="expression↑", style=bold, color="#6A1B9A"];
    TNFa         -> MMP9            [label="MMP↑", style=bold, color="#1B5E20", penwidth=2];
    TNFa         -> E_selectin      [label="expression↑", color="#2E7D32"];
    IL1b         -> IL6             [label="amplification", color="#6A1B9A"];
    IL1b         -> MMP1            [label="MMP↑", color="#1B5E20"];
    IL1b         -> MMP3            [label="MMP↑", color="#1B5E20"];
    IL1b         -> COX2 [label="COX2→\nbradykinin synth", color="#6A1B9A"];
    IL6          -> CRP             [label="acute phase\nresponse", color="#6A1B9A"];
    IL6          -> fibrinogen      [label="hepatic\nsynthesis↑", color="#6A1B9A"];
    TGFb         -> fibroblasts     [label="activation\n(profibrotic)", style=bold, color="#1B5E20", penwidth=2];
    TGFb         -> myofibroblast   [label="EMT/MET\ndifferentiation", style=bold, color="#1B5E20", penwidth=2];
    TGFb         -> TIMP1           [label="TIMP↑\n(fibrosis)", color="#1B5E20"];
    TGFb         -> collagen_I      [label="synthesis↑", style=bold, color="#1B5E20"];
    IL10         -> TNFa            [label="feedback\ninhibition", style=dashed, color="#6A1B9A", arrowhead=tee];
    IL10         -> IL1b            [label="inhibition", style=dashed, color="#6A1B9A", arrowhead=tee];
    MCP1         -> macro_act       [label="chemotaxis", color="#E65100"];
    MCP1         -> T_cell_infil    [label="recruitment", color="#E65100"];
    RANTES       -> T_cell_infil    [label="migration", color="#E65100"];
    histamine    -> vasc_perm       [label="H1 receptor\npermeability↑", color="#2E7D32"];
    bradykinin   -> vasc_perm       [label="BK2 receptor\npermeability↑", color="#2E7D32"];
    bradykinin   -> wound_pain      [label="pain\nnociception", color="#37474F"];
    substance_P  -> mast_degran     [label="neurogenic\nstimulation", color="#E65100"];
    substance_P  -> wound_pain      [label="pain\nsignaling", color="#37474F"];

    // Hidden COX2 node for pathway completeness
    COX2 [label="COX-2\n(prostaglandin\nsynthesis)", fillcolor="#E1BEE7", color="#6A1B9A", style="filled,rounded"];
    COX2 -> bradykinin [label="prostaglandin\nsynergy", color="#6A1B9A"];

    // =========================================================
    // EDGES: Coagulation Cascade
    // =========================================================
    tissue_factor -> thrombin       [label="extrinsic\nactivation", style=bold, color="#BF360C", penwidth=2];
    fibrinogen    -> fibrin         [label="thrombin\ncleavage", color="#BF360C"];
    thrombin      -> fibrin         [label="polymerization", style=bold, color="#BF360C", penwidth=2];
    thrombin      -> platelets      [label="PAR1\nactivation", color="#BF360C"];
    vWF          -> platelets       [label="Ib/IX/V\nbinding", color="#BF360C"];
    fibrin        -> fibrin_cuff    [label="pericapillary\ndeposition", style=bold, color="#BF360C", penwidth=2];
    PAI1         -> tPA             [label="inhibits", style=dashed, color="#BF360C", arrowhead=tee];
    tPA          -> plasmin         [label="activation", color="#BF360C"];
    plasmin       -> D_dimer        [label="fibrin\ndegradation", color="#BF360C"];
    plasmin       -> fibrin_cuff    [label="dissolution", style=dashed, color="#BF360C", arrowhead=tee];
    fibrin_cuff   -> tissue_hypox   [label="O2 diffusion\nbarrier", style=bold, color="#2E7D32", penwidth=2];
    DVT           -> PTS            [label="sequela", style=bold, color="#BF360C"];
    TNFa          -> PAI1           [label="PAI-1↑\n(fibrinolysis↓)", color="#BF360C"];
    IL6           -> tissue_factor  [label="TF expression↑", color="#BF360C"];

    // =========================================================
    // EDGES: ECM Remodeling
    // =========================================================
    fibroblasts  -> collagen_I      [label="synthesis", style=bold, color="#1B5E20", penwidth=2];
    fibroblasts  -> collagen_III    [label="synthesis", color="#1B5E20"];
    fibroblasts  -> fibronectin     [label="synthesis", color="#1B5E20"];
    fibroblasts  -> hyaluronic      [label="HA\nsynthesis", color="#1B5E20"];
    myofibroblast -> collagen_I     [label="excess\ndeposition", style=bold, color="#1B5E20", penwidth=2];
    myofibroblast -> elastin        [label="elastin↓\n(degradation)", style=dashed, color="#1B5E20"];
    myofibroblast -> wound_cont     [label="contractile\nforce", color="#37474F"];
    MMP1         -> collagen_I      [label="degradation", style=dashed, color="#1B5E20", arrowhead=tee];
    MMP1         -> collagen_III    [label="degradation", style=dashed, color="#1B5E20", arrowhead=tee];
    MMP2         -> collagen_IV     [label="degradation", style=dashed, color="#1B5E20", arrowhead=tee];
    MMP3         -> fibronectin     [label="degradation", style=dashed, color="#1B5E20", arrowhead=tee];
    MMP9         -> elastin         [label="elastin\ndegradation", style=dashed, color="#1B5E20", arrowhead=tee];
    MMP13        -> collagen_I      [label="degradation", style=dashed, color="#1B5E20", arrowhead=tee];
    TIMP1        -> MMP1            [label="inhibition", style=dashed, color="#1B5E20", arrowhead=tee];
    TIMP1        -> MMP3            [label="inhibition", style=dashed, color="#1B5E20", arrowhead=tee];
    TIMP1        -> MMP9            [label="inhibition", style=dashed, color="#1B5E20", arrowhead=tee];
    TIMP2        -> MMP2            [label="inhibition", style=dashed, color="#1B5E20", arrowhead=tee];
    neutro_elast -> collagen_IV     [label="cleavage", style=dashed, color="#1B5E20", arrowhead=tee];
    neutro_elast -> TIMP1           [label="TIMP\ndegradation", style=dashed, color="#1B5E20", arrowhead=tee];
    SMC_switch   -> MMP2            [label="MMP2\nproduction↑", color="#1B5E20"];
    SMC_switch   -> MMP9            [label="MMP9\nproduction↑", color="#1B5E20"];
    collagen_I   -> lipodermato     [label="fibro-sclerosis", style=bold, color="#1B5E20", penwidth=2];
    lipodermato  -> skin_breakdown  [label="tissue\nischemia", style=bold, color="#37474F", penwidth=2];
    IL4_IL13     -> fibroblasts     [label="Th2-driven\nfibrosis", color="#1B5E20"];
    NETs         -> MMP9            [label="MMP release\nfrom NETs", color="#1B5E20"];

    // =========================================================
    // EDGES: Microcirculation → Skin Changes
    // =========================================================
    leuko_trap   -> microthrombi    [label="coagulation\nactivation", color="#827717"];
    hemosiderin  -> melanocyte      [label="iron\nstimulation", color="#827717"];
    hemosiderin  -> stasis_derm     [label="skin\nirritation", color="#827717"];
    melanocyte   -> stasis_derm     [label="hyperpig-\nmentation", color="#827717"];
    pericyte_loss -> cap_hypert     [label="capillary\ndysregulation", color="#827717"];
    pericyte_loss -> telangiect     [label="vascular\ndilation", color="#827717"];
    lymph_over   -> interst_edema   [label="lymph\nfailure", color="#827717"];
    stasis_derm  -> skin_breakdown  [label="chronic\nchange", style=bold, color="#37474F", penwidth=2];
    atrophie_bl  -> skin_breakdown  [label="atrophic\nulceration", color="#37474F"];
    microthrombi -> atrophie_bl     [label="ischemic\nsclerosis", color="#827717"];

    // =========================================================
    // EDGES: Wound Healing
    // =========================================================
    skin_breakdown -> ulcer_area    [label="wound\nestablishment", style=bold, color="#37474F", penwidth=2];
    ulcer_area   -> biofilm         [label="infection\nrisk↑", color="#37474F"];
    biofilm      -> wound_infect    [label="bacterial\nburden", style=bold, color="#37474F"];
    wound_infect -> TNFa            [label="systemic\ninflammation", color="#6A1B9A"];
    wound_infect -> IL1b            [label="local\ncytokines", color="#6A1B9A"];
    EGF_KGF      -> keratino_mig    [label="keratinocyte\nstimulation", color="#37474F"];
    PDGF_BB      -> fibroblasts     [label="fibroblast\nrecruitment", color="#1B5E20"];
    PDGF_BB      -> granulation     [label="angiogenesis\n& matrix", color="#37474F"];
    keratino_mig -> re_epithel      [label="migration\nrate", color="#37474F"];
    granulation  -> re_epithel      [label="scaffold\nprovision", color="#37474F"];
    re_epithel   -> ulcer_area      [label="wound\nclosure↑", style=dashed, color="#37474F", arrowhead=tee];
    wound_cont   -> ulcer_area      [label="area\nreduction", style=dashed, color="#37474F", arrowhead=tee];
    scar_form    -> atrophie_bl     [label="scar\ncontracture", color="#827717"];
    fibrin_cuff  -> keratino_mig    [label="migration\nbarrier", style=dashed, color="#37474F", arrowhead=tee];
    fibrin_cuff  -> granulation     [label="impairs\nangiogenesis", style=dashed, color="#37474F", arrowhead=tee];
    MMP9         -> keratino_mig    [label="basement\nmembrane cleave", color="#37474F"];

    // =========================================================
    // EDGES: Drug PK/PD Pathways
    // =========================================================
    // MPFF PK
    MPFF_oral    -> MPFF_gut        [label="ka=0.8 h⁻¹\nF=70%", color="#4527A0"];
    MPFF_gut     -> MPFF_plasma     [label="absorption\ndistribution", color="#4527A0"];
    // MPFF PD effects
    MPFF_plasma  -> MPFF_PD         [label="EC50=0.4μg/mL", style=bold, color="#4527A0", penwidth=2];
    MPFF_PD      -> ET1             [label="ET-1↓", style=dashed, color="#4527A0", arrowhead=tee];
    MPFF_PD      -> vasc_perm       [label="perm↓", style=dashed, color="#4527A0", arrowhead=tee];
    MPFF_PD      -> WBC_marg        [label="adhesion↓", style=dashed, color="#4527A0", arrowhead=tee];
    MPFF_PD      -> TNFa            [label="TNF-α↓", style=dashed, color="#4527A0", arrowhead=tee];
    MPFF_PD      -> AVP             [label="venotonus↑\nAVP↓", style=dashed, color="#4527A0", arrowhead=tee];

    // PTX PK/PD
    PTX_oral     -> PTX_plasma      [label="ka=1.2 h⁻¹\nt½=1h", color="#4527A0"];
    PTX_plasma   -> PTX_PD          [label="EC50=0.3μg/mL", style=bold, color="#4527A0"];
    PTX_PD       -> TNFa            [label="TNF-α↓\n(PDE4 inhib)", style=dashed, color="#4527A0", arrowhead=tee];
    PTX_PD       -> WBC_marg        [label="deformability↑\nadhesion↓", style=dashed, color="#4527A0", arrowhead=tee];
    PTX_PD       -> fibrin_cuff     [label="fibrinolysis↑\ncuff↓", style=dashed, color="#4527A0", arrowhead=tee];
    PTX_PD       -> ulcer_area      [label="healing↑", style=dashed, color="#4527A0", arrowhead=tee];

    // LMWH PK/PD
    LMWH_SC      -> LMWH_central    [label="ka=0.5 h⁻¹\nF=92%", color="#4527A0"];
    LMWH_central -> LMWH_PD        [label="anti-Xa\nEC50", style=bold, color="#4527A0"];
    LMWH_PD     -> thrombin         [label="thrombin↓", style=dashed, color="#4527A0", arrowhead=tee];
    LMWH_PD     -> fibrin           [label="fibrin↓", style=dashed, color="#4527A0", arrowhead=tee];
    LMWH_PD     -> DVT              [label="DVT\nprevention", style=dashed, color="#4527A0", arrowhead=tee];

    // Rutosides PK/PD
    ruto_oral    -> ruto_plasma     [label="ka=0.6 h⁻¹\nF=50%", color="#4527A0"];
    ruto_plasma  -> ruto_PD         [label="EC50=0.8μg/mL", style=bold, color="#4527A0"];
    ruto_PD      -> vasc_perm       [label="capillary\nprotection", style=dashed, color="#4527A0", arrowhead=tee];
    ruto_PD      -> interst_edema   [label="edema↓", style=dashed, color="#4527A0", arrowhead=tee];
    ruto_PD      -> ROS             [label="antioxidant", style=dashed, color="#4527A0", arrowhead=tee];

    // Compression therapy
    compression  -> compress_PD     [label="gradient\npressure", style=bold, color="#4527A0", penwidth=2];
    compress_PD  -> AVP             [label="AVP↓", style=dashed, color="#4527A0", arrowhead=tee, penwidth=2];
    compress_PD  -> interst_edema   [label="edema↓", style=dashed, color="#4527A0", arrowhead=tee];
    compress_PD  -> calf_pump       [label="pump\nassist", style=dashed, color="#4527A0"];
    compress_PD  -> retro_flow      [label="reflux↓", style=dashed, color="#4527A0", arrowhead=tee];
    compress_PD  -> ulcer_heal      [label="healing↑", style=dashed, color="#4527A0", arrowhead=tee];

    // Wound care and antibiotics
    wound_care   -> biofilm         [label="debridement\nbiofilm↓", style=dashed, color="#4527A0", arrowhead=tee];
    wound_care   -> granulation     [label="moist\nenvironment", color="#4527A0"];
    antibiotics  -> wound_infect    [label="infection↓", style=dashed, color="#4527A0", arrowhead=tee];
    antibiotics  -> biofilm         [label="biofilm↓", style=dashed, color="#4527A0", arrowhead=tee];

    // =========================================================
    // EDGES: Clinical Endpoints
    // =========================================================
    AVP          -> CEAP            [label="hemodynamic\nseverity", style=bold, color="#880E4F", penwidth=2];
    ulcer_area   -> CEAP            [label="C5=healed\nC6=active", style=bold, color="#880E4F", penwidth=2];
    lipodermato  -> CEAP            [label="C4b\nclassification", color="#880E4F"];
    stasis_derm  -> CEAP            [label="C4a\nclassification", color="#880E4F"];
    interst_edema -> CEAP           [label="C3\nclassification", color="#880E4F"];
    CEAP         -> VCSS            [label="informs\nscoring", color="#880E4F"];
    pain_VAS     -> VCSS            [label="pain\ncomponent", color="#880E4F"];
    edema_score  -> VCSS            [label="edema\ncomponent", color="#880E4F"];
    skin_score   -> VCSS            [label="skin\ncomponent", color="#880E4F"];
    ulcer_area   -> ulcer_heal      [label="primary\nendpoint", style=bold, color="#880E4F", penwidth=2];
    ulcer_heal   -> ulcer_recur     [label="long-term\noutcome", color="#880E4F"];
    VCSS         -> CIVIQ           [label="correlates\nwith QoL", color="#880E4F"];
    pain_VAS     -> CIVIQ           [label="QoL\nimpact", color="#880E4F"];
    heaviness    -> CIVIQ           [label="functional\nlimitation", color="#880E4F"];
    CEAP         -> AVVQ            [label="varicose\nassessment", color="#880E4F"];
    retro_flow   -> duplex_US       [label="measured by\nDUS", color="#880E4F"];
    AVP          -> APG             [label="APG\nplethysmo-\ngraphy", color="#880E4F"];
    calf_pump    -> APG             [label="EF measured\nby APG", color="#880E4F"];
    interst_edema -> edema_score    [label="ankle\ncircumference", color="#880E4F"];
    wound_pain   -> pain_VAS        [label="ulcer\npain VAS", color="#880E4F"];
    bradykinin   -> pain_VAS        [label="pain\nperception", color="#880E4F"];

    // =========================================================
    // ADDITIONAL CROSS-CLUSTER CONNECTIONS
    // =========================================================
    // PTS → valve incompetence (feedback)
    PTS          -> valve_incomp    [label="post-thrombotic\nvalve damage", style=bold, color="#BF360C", penwidth=2];
    PTS          -> deep_veins      [label="obstruction", color="#BF360C"];

    // Fibrin cuff impacts microcirculation
    fibrin_cuff  -> cap_hypert      [label="capillary\nocclusion", color="#827717"];

    // ECM → wound healing
    collagen_I   -> granulation     [label="scaffold\nfor repair", color="#37474F"];
    fibronectin  -> keratino_mig    [label="migration\nsubstrate", color="#37474F"];
    hyaluronic   -> granulation     [label="HA matrix\nsupport", color="#37474F"];

    // Endothelial dysfunction → coagulation
    EC_apoptosis -> tissue_factor   [label="TF exposure\non apoptosis", color="#BF360C"];
    vasc_perm    -> fibrin_cuff     [label="plasma\nprotein leak", color="#BF360C"];

    // Inflammatory mediators ↔ ECM
    IL1b         -> MMP1            [label="MMP1↑", color="#1B5E20"];
    IL1b         -> MMP3            [label="MMP3↑", color="#1B5E20"];
    TNFa         -> MMP1            [label="MMP1↑", color="#1B5E20"];
    IL4_IL13     -> TIMP1           [label="Th2 fibrosis\nTIMP↑", color="#1B5E20"];

    // Skin changes → ulceration
    hemosiderin  -> skin_breakdown  [label="iron-induced\ntoxicity", color="#37474F"];

    // Wound healing ↔ inflammatory mediators
    EGF_KGF      -> re_epithel      [label="epithelial\ngrowth↑", color="#37474F"];
    PDGF_BB      -> wound_cont      [label="fibroblast\ncontraction", color="#37474F"];
    IL10         -> ulcer_heal      [label="resolution\npromotes heal", color="#37474F"];

    // Calf pump ↔ compression
    compress_PD  -> venous_vol      [label="venous\nvolume↓", style=dashed, color="#4527A0", arrowhead=tee];

    // DUS measures reflux
    duplex_US    -> reflux_index    [label="measures\nreflux index", color="#880E4F"];
    duplex_US    -> valve_incomp    [label="diagnoses\nincompetence", color="#880E4F"];

    // Gravity / functional aspects
    prolong_stand -> calf_pump      [label="fatigue →\nEF↓", color="#C62828"];

    // MPFF improves CEAP
    MPFF_PD      -> edema_score     [label="edema↓", style=dashed, color="#4527A0", arrowhead=tee];
    MPFF_PD      -> pain_VAS        [label="pain↓", style=dashed, color="#4527A0", arrowhead=tee];
    MPFF_PD      -> heaviness       [label="heaviness↓", style=dashed, color="#4527A0", arrowhead=tee];

    // PTX improves QoL
    PTX_PD       -> CIVIQ           [label="QoL↑", style=dashed, color="#4527A0", arrowhead=tee];

    // SMC phenotype switch pathway
    AVP          -> SMC_switch      [label="pressure\nstress", color="#1B5E20"];
    TGFb         -> SMC_switch      [label="phenotype\nswitch↑", color="#1B5E20"];

    // Venous hypertension → ET-1
    AVP          -> ET1             [label="shear\nstress→ET1↑", color="#2E7D32"];

    // ROS → ECM
    ROS          -> MMP2            [label="MMP2\nactivation", color="#1B5E20"];
    ROS          -> MMP9            [label="MMP9\nactivation", color="#1B5E20"];

    // Skin score endpoint
    lipodermato  -> skin_score      [label="dermato-\nsclerosis", color="#880E4F"];
    stasis_derm  -> skin_score      [label="dermatitis\ncomponent", color="#880E4F"];
    hemosiderin  -> skin_score      [label="pigmentation\nscore", color="#880E4F"];

    // Heaviness / fatigue
    AVP          -> heaviness       [label="venous\nhypertension", color="#880E4F"];
    interst_edema -> heaviness      [label="limb\nweight↑", color="#880E4F"];

}
