digraph PAN_QSP {

  graph [
    rankdir=TB,
    splines=false,
    nodesep=0.4,
    ranksep=0.7,
    fontname="Helvetica",
    bgcolor="white",
    label="Polyarteritis Nodosa (PAN) — QSP Mechanistic Map\n결절성 다발동맥염 정량적 시스템 약리학 지도",
    labelloc=t,
    fontsize=18,
    compound=true
  ]
  node [fontname="Helvetica", fontsize=9, style=filled, margin="0.1,0.05"]
  edge [fontsize=8, fontname="Helvetica"]

  // ─────────────────────────────────────────────
  // CLUSTER 1: TRIGGERS
  // ─────────────────────────────────────────────
  subgraph cluster_triggers {
    label="Initiating Triggers"
    style=filled
    fillcolor="#FFF5F5"
    color=firebrick
    fontsize=12
    fontcolor=firebrick

    HBV         [label="HBV\nHepatitis B Virus", shape=ellipse, fillcolor=lightcoral]
    Strep       [label="Streptococcal\nInfection", shape=ellipse, fillcolor=lightcoral]
    Drug_Rxn    [label="Drug Reaction\n(sulfonamides, thiazides)", shape=ellipse, fillcolor=lightcoral]
    Idiopathic  [label="Idiopathic\n(~60% cases)", shape=ellipse, fillcolor=lightcoral]
    HCV         [label="HCV\nHepatitis C Virus", shape=ellipse, fillcolor=lightcoral]
    Parvovirus  [label="Parvovirus B19\nInfection", shape=ellipse, fillcolor=lightcoral]
    CMV         [label="CMV\nInfection", shape=ellipse, fillcolor=lightcoral]
    HBsAg       [label="HBsAg\n(surface antigen)", shape=ellipse, fillcolor=lightyellow]
    HBeAg       [label="HBeAg\n(e antigen)", shape=ellipse, fillcolor=lightyellow]
    Antigen_IC  [label="Antigen-Antibody\nImmune Complex Formation", shape=box, fillcolor=lightpink]
    APC_Trigger [label="Antigen Presenting\nCell Activation", shape=box, fillcolor=lightblue]
    TLR_PAMP    [label="TLR-PAMP\nRecognition", shape=box, fillcolor=plum]
  }

  // ─────────────────────────────────────────────
  // CLUSTER 2: INNATE IMMUNITY
  // ─────────────────────────────────────────────
  subgraph cluster_innate {
    label="Innate Immunity & Inflammatory Mediators"
    style=filled
    fillcolor="#F0F8FF"
    color=steelblue
    fontsize=12
    fontcolor=steelblue

    Neutrophil  [label="Neutrophils\n(PMN)", shape=ellipse, fillcolor=lightblue]
    Macrophage  [label="Macrophages\n(M1 activated)", shape=ellipse, fillcolor=lightblue]
    NKcell      [label="NK Cells", shape=ellipse, fillcolor=lightblue]
    MastCell    [label="Mast Cells", shape=ellipse, fillcolor=lightblue]
    DendriticC  [label="Dendritic Cells\n(plasmacytoid/myeloid)", shape=ellipse, fillcolor=lightblue]
    Monocyte    [label="Monocytes\n(circulating)", shape=ellipse, fillcolor=lightblue]

    IL1b        [label="IL-1β", shape=ellipse, fillcolor=lightyellow]
    TNFa        [label="TNF-α", shape=ellipse, fillcolor=lightyellow]
    IL6         [label="IL-6", shape=ellipse, fillcolor=lightyellow]
    IL8         [label="IL-8\n(CXCL8)", shape=ellipse, fillcolor=lightyellow]
    IL12        [label="IL-12", shape=ellipse, fillcolor=lightyellow]
    IFNg        [label="IFN-γ", shape=ellipse, fillcolor=lightyellow]
    IL18        [label="IL-18", shape=ellipse, fillcolor=lightyellow]
    GM_CSF      [label="GM-CSF", shape=ellipse, fillcolor=lightyellow]

    ROS         [label="Reactive Oxygen\nSpecies (ROS)", shape=ellipse, fillcolor=lightyellow]
    MPO         [label="Myeloperoxidase\n(MPO)", shape=ellipse, fillcolor=wheat]
    Elastase    [label="Neutrophil\nElastase (NE)", shape=ellipse, fillcolor=wheat]
    NET         [label="Neutrophil\nExtracellular Traps\n(NETs)", shape=box, fillcolor=lightpink]
    HMGB1       [label="HMGB1\n(alarmin)", shape=ellipse, fillcolor=lightyellow]
    DAMPs       [label="DAMPs\n(uric acid, HMGB1,\nheat shock proteins)", shape=ellipse, fillcolor=lightyellow]
    PAMPs       [label="PAMPs\n(LPS, viral RNA)", shape=ellipse, fillcolor=lightyellow]
    TLR4        [label="TLR4\n(LPS receptor)", shape=ellipse, fillcolor=plum]
    TLR7_9      [label="TLR7/TLR9\n(viral nucleic acid)", shape=ellipse, fillcolor=plum]
    NFkB        [label="NF-κB\n(transcription factor)", shape=box, fillcolor=lightyellow]
    Inflammasome [label="NLRP3\nInflammasome", shape=box, fillcolor=lightpink]
  }

  // ─────────────────────────────────────────────
  // CLUSTER 3: ADAPTIVE IMMUNITY
  // ─────────────────────────────────────────────
  subgraph cluster_adaptive {
    label="Adaptive Immunity"
    style=filled
    fillcolor="#F0FFF0"
    color=darkgreen
    fontsize=12
    fontcolor=darkgreen

    Bcell       [label="B Cells", shape=ellipse, fillcolor=lightblue]
    Th1         [label="Th1 Cells\n(IFN-γ, IL-2)", shape=ellipse, fillcolor=lightblue]
    Th2         [label="Th2 Cells\n(IL-4, IL-13)", shape=ellipse, fillcolor=lightblue]
    Th17        [label="Th17 Cells\n(IL-17A, IL-22)", shape=ellipse, fillcolor=lightblue]
    CD8_CTL     [label="CD8+ CTL\n(cytotoxic T cells)", shape=ellipse, fillcolor=lightblue]
    Treg        [label="Regulatory T cells\n(Foxp3+ Tregs)", shape=ellipse, fillcolor=lightblue]
    PlasmaCell  [label="Plasma Cells\n(Ab-secreting)", shape=ellipse, fillcolor=lightblue]

    IgG         [label="IgG\n(antibody)", shape=ellipse, fillcolor=lightyellow]
    IgM         [label="IgM\n(antibody)", shape=ellipse, fillcolor=lightyellow]
    IgA         [label="IgA\n(antibody)", shape=ellipse, fillcolor=lightyellow]
    ImmComplex  [label="Immune Complexes\n(Ag-Ab)", shape=box, fillcolor=lightpink]
    FcgR        [label="FcγR\n(Fc receptor)", shape=ellipse, fillcolor=plum]
    ADCC        [label="ADCC\n(Ab-dependent cell\ncytotoxicity)", shape=box, fillcolor=lightpink]

    MHCII       [label="MHC-II\n(antigen presentation)", shape=ellipse, fillcolor=plum]
    CD80_86     [label="CD80/CD86\n(co-stimulation)", shape=ellipse, fillcolor=plum]
    CD28        [label="CD28\n(T cell activation)", shape=ellipse, fillcolor=plum]
    CTLA4       [label="CTLA-4\n(T cell inhibition)", shape=ellipse, fillcolor=plum]
    IL17A       [label="IL-17A", shape=ellipse, fillcolor=lightyellow]
    IL4         [label="IL-4", shape=ellipse, fillcolor=lightyellow]
    IL2         [label="IL-2", shape=ellipse, fillcolor=lightyellow]
    IL10_adapt  [label="IL-10\n(regulatory)", shape=ellipse, fillcolor=lightyellow]
  }

  // ─────────────────────────────────────────────
  // CLUSTER 4: COMPLEMENT CASCADE
  // ─────────────────────────────────────────────
  subgraph cluster_complement {
    label="Complement Cascade"
    style=filled
    fillcolor="#F8F0FF"
    color=purple
    fontsize=12
    fontcolor=purple

    C1q         [label="C1q\n(pattern recognition)", shape=ellipse, fillcolor=lavender]
    C1r         [label="C1r", shape=ellipse, fillcolor=lavender]
    C1s         [label="C1s", shape=ellipse, fillcolor=lavender]
    C4          [label="C4", shape=ellipse, fillcolor=lavender]
    C4b         [label="C4b", shape=ellipse, fillcolor=lavender]
    C2          [label="C2", shape=ellipse, fillcolor=lavender]
    C3          [label="C3", shape=ellipse, fillcolor=lavender]
    C3a         [label="C3a\n(anaphylatoxin)", shape=ellipse, fillcolor=lavender]
    C3b         [label="C3b\n(opsonin)", shape=ellipse, fillcolor=lavender]
    C5          [label="C5", shape=ellipse, fillcolor=lavender]
    C5a         [label="C5a\n(potent anaphylatoxin)", shape=ellipse, fillcolor=lavender]
    C5b         [label="C5b", shape=ellipse, fillcolor=lavender]
    MAC         [label="MAC\n(C5b-9\nMembrane Attack Complex)", shape=box, fillcolor=lightpink]
    FactorB     [label="Factor B\n(alternative pathway)", shape=ellipse, fillcolor=lavender]
    FactorD     [label="Factor D\n(alternative pathway)", shape=ellipse, fillcolor=lavender]
    Properdin   [label="Properdin\n(stabilizer)", shape=ellipse, fillcolor=lavender]
    MBL         [label="MBL\n(lectin pathway)", shape=ellipse, fillcolor=lavender]
    MASP1       [label="MASP-1", shape=ellipse, fillcolor=lavender]
    MASP2       [label="MASP-2", shape=ellipse, fillcolor=lavender]
    CR1         [label="CR1\n(CD35, receptor)", shape=ellipse, fillcolor=plum]
    CR3         [label="CR3\n(CD11b/CD18)", shape=ellipse, fillcolor=plum]
    C3aR        [label="C3aR\n(receptor)", shape=ellipse, fillcolor=plum]
    C5aR        [label="C5aR\n(CD88)", shape=ellipse, fillcolor=plum]
    DAF         [label="DAF\n(CD55, inhibitor)", shape=ellipse, fillcolor=lavender]
    CD59        [label="CD59\n(protectin, inhibitor)", shape=ellipse, fillcolor=lavender]
    ClassicPath [label="Classical Pathway\nActivation", shape=box, fillcolor=lavender]
    AltPath     [label="Alternative Pathway\nActivation", shape=box, fillcolor=lavender]
    LectinPath  [label="Lectin Pathway\nActivation", shape=box, fillcolor=lavender]
  }

  // ─────────────────────────────────────────────
  // CLUSTER 5: VASCULAR ENDOTHELIUM
  // ─────────────────────────────────────────────
  subgraph cluster_endothelium {
    label="Vascular Endothelium & Inflammation"
    style=filled
    fillcolor="#FFFFF0"
    color=goldenrod
    fontsize=12
    fontcolor=goldenrod

    ICAM1       [label="ICAM-1\n(CD54)", shape=ellipse, fillcolor=plum]
    VCAM1       [label="VCAM-1\n(CD106)", shape=ellipse, fillcolor=plum]
    Eselectin   [label="E-selectin\n(CD62E)", shape=ellipse, fillcolor=plum]
    Pselectin   [label="P-selectin\n(CD62P)", shape=ellipse, fillcolor=plum]
    Integrin    [label="Integrin\n(LFA-1/Mac-1)", shape=ellipse, fillcolor=plum]
    Rolling     [label="Leukocyte Rolling\n(selectin-mediated)", shape=box, fillcolor=lightpink]
    Adhesion    [label="Firm Adhesion\n(integrin-mediated)", shape=box, fillcolor=lightpink]
    Transmig    [label="Leukocyte\nTransmigration", shape=box, fillcolor=lightpink]
    VWF         [label="von Willebrand\nFactor (VWF)", shape=ellipse, fillcolor=lightyellow]
    Endothelin1 [label="Endothelin-1\n(vasoconstriction)", shape=ellipse, fillcolor=lightyellow]
    NO_eNOS     [label="NO/eNOS\n(vasodilation)", shape=ellipse, fillcolor=lightyellow]
    Prostacyclin [label="Prostacyclin\n(PGI2, anti-thrombotic)", shape=ellipse, fillcolor=lightyellow]
    TXA2        [label="Thromboxane A2\n(pro-thrombotic)", shape=ellipse, fillcolor=lightyellow]
    PAF         [label="Platelet Activating\nFactor (PAF)", shape=ellipse, fillcolor=lightyellow]
    VEGF_endo   [label="VEGF\n(vascular permeability)", shape=ellipse, fillcolor=lightyellow]
    Angiopoietin [label="Angiopoietin-2\n(vessel destabilization)", shape=ellipse, fillcolor=lightyellow]
    TightJxn    [label="Tight Junction\nDisruption", shape=box, fillcolor=lightpink]
    MMP2        [label="MMP-2\n(gelatinase A)", shape=ellipse, fillcolor=wheat]
    MMP9        [label="MMP-9\n(gelatinase B)", shape=ellipse, fillcolor=wheat]
    BMdeg       [label="Basement Membrane\nDegradation", shape=box, fillcolor=lightpink]
    EndoActivation [label="Endothelial\nActivation/Dysfunction", shape=box, fillcolor=lightpink]
  }

  // ─────────────────────────────────────────────
  // CLUSTER 6: ARTERIAL WALL / VASCULAR DAMAGE
  // ─────────────────────────────────────────────
  subgraph cluster_vascular_damage {
    label="Arterial Wall Damage (Medium-vessel Vasculitis)"
    style=filled
    fillcolor="#FFF0F0"
    color=red
    fontsize=12
    fontcolor=red

    FibrinoidNecrosis [label="Fibrinoid\nNecrosis", shape=box, fillcolor=lightpink]
    TransmuralInflam  [label="Transmural\nInflammation", shape=box, fillcolor=lightpink]
    Microaneurysm     [label="Microaneurysm\nFormation", shape=box, fillcolor=lightpink]
    Thrombosis_art    [label="Luminal\nThrombosis", shape=box, fillcolor=lightpink]
    FibrinDepo        [label="Fibrin\nDeposition", shape=box, fillcolor=lightpink]
    PlatAgg           [label="Platelet\nAggregation", shape=box, fillcolor=lightpink]
    PDGF              [label="PDGF\n(platelet-derived GF)", shape=ellipse, fillcolor=lightyellow]
    TGFb_vasc         [label="TGF-β\n(vascular remodeling)", shape=ellipse, fillcolor=lightyellow]
    VEGF_vasc         [label="VEGF\n(angiogenesis)", shape=ellipse, fillcolor=lightyellow]
    SMC_Prolif        [label="Smooth Muscle Cell\nProliferation", shape=box, fillcolor=lightpink]
    IntimalHyper      [label="Intimal\nHyperplasia", shape=box, fillcolor=lightpink]
    MediaDestruction  [label="Media Layer\nDestruction", shape=box, fillcolor=lightpink]
    SegmentalNecrosis [label="Segmental\nArterial Necrosis", shape=box, fillcolor=lightpink]
    ArterialStenosis  [label="Arterial\nStenosis/Occlusion", shape=box, fillcolor=lightpink]
  }

  // ─────────────────────────────────────────────
  // CLUSTER 7: ORGAN-SPECIFIC DAMAGE
  // ─────────────────────────────────────────────
  subgraph cluster_organ {
    label="Organ-Specific Damage"
    style=filled
    fillcolor="#FFF8F0"
    color=darkorange
    fontsize=12
    fontcolor=darkorange

    // Kidney
    RenalMicroaneurysm [label="Renal Artery\nMicroaneurysm", shape=box, fillcolor=lightpink]
    RenalHTN    [label="Renovascular\nHypertension", shape=diamond, fillcolor=lightsalmon]
    Proteinuria [label="Proteinuria\n(tubular ischemia)", shape=diamond, fillcolor=lightsalmon]
    RenalInfarct [label="Renal\nInfarction", shape=box, fillcolor=lightpink]

    // Peripheral Nerve
    MononeuritisM [label="Mononeuritis\nMultiplex", shape=diamond, fillcolor=lightsalmon]
    SchwannDamage [label="Schwann Cell\nDamage", shape=box, fillcolor=lightpink]
    AxonalDegen   [label="Axonal\nDegeneration", shape=box, fillcolor=lightpink]
    NerveIschemia [label="Vasa Nervorum\nIschemia", shape=box, fillcolor=lightpink]

    // GI
    MesentericIschemiaGI [label="Mesenteric\nIschemia", shape=box, fillcolor=lightpink]
    BowelInfarct  [label="Bowel\nInfarction", shape=box, fillcolor=lightpink]
    Perforation   [label="GI\nPerforation", shape=diamond, fillcolor=lightsalmon]

    // Skin
    LivedoRetic   [label="Livedo\nReticularis", shape=diamond, fillcolor=lightsalmon]
    SkinNodules   [label="Subcutaneous\nNodules", shape=diamond, fillcolor=lightsalmon]
    SkinUlcers    [label="Skin\nUlcers", shape=diamond, fillcolor=lightsalmon]
    DigitalIsch   [label="Digital\nIschemia", shape=diamond, fillcolor=lightsalmon]

    // Heart
    CoronaryArteritis [label="Coronary\nArteritis", shape=box, fillcolor=lightpink]
    MyocardialIsch    [label="Myocardial\nIschemia", shape=diamond, fillcolor=lightsalmon]

    // Muscle / Testis
    Myalgia       [label="Myalgia /\nMyositis", shape=diamond, fillcolor=lightsalmon]
    Orchitis      [label="Orchitis\n(testicular pain)", shape=diamond, fillcolor=lightsalmon]
    MuscleDamage  [label="Muscle\nIschemia", shape=box, fillcolor=lightpink]
  }

  // ─────────────────────────────────────────────
  // CLUSTER 8: COAGULATION & THROMBOSIS
  // ─────────────────────────────────────────────
  subgraph cluster_coagulation {
    label="Coagulation & Thrombosis"
    style=filled
    fillcolor="#FFF0F8"
    color=darkred
    fontsize=12
    fontcolor=darkred

    TissueFactor  [label="Tissue Factor\n(TF / CD142)", shape=ellipse, fillcolor=lightyellow]
    Thrombin      [label="Thrombin\n(Factor IIa)", shape=ellipse, fillcolor=wheat]
    Prothrombin   [label="Prothrombin\n(Factor II)", shape=ellipse, fillcolor=lightyellow]
    Fibrinogen    [label="Fibrinogen\n(Factor I)", shape=ellipse, fillcolor=lightyellow]
    Fibrin_coag   [label="Fibrin\n(clot matrix)", shape=ellipse, fillcolor=lightyellow]
    Ddimer        [label="D-dimer\n(fibrin degradation)", shape=ellipse, fillcolor=lightyellow]
    TFPI          [label="TFPI\n(coagulation inhibitor)", shape=ellipse, fillcolor=lavender]
    Antithrombin  [label="Antithrombin III\n(inhibitor)", shape=ellipse, fillcolor=lavender]
    ProteinC      [label="Protein C\n(anticoagulant)", shape=ellipse, fillcolor=lavender]
    ProteinS      [label="Protein S\n(cofactor)", shape=ellipse, fillcolor=lavender]
    PAI1          [label="PAI-1\n(fibrinolysis inhibitor)", shape=ellipse, fillcolor=lightyellow]
    tPA           [label="tPA\n(fibrinolysis activator)", shape=ellipse, fillcolor=wheat]
    PlatActivation [label="Platelet\nActivation", shape=box, fillcolor=lightpink]
    TXA2_coag     [label="TXA2\n(platelet activator)", shape=ellipse, fillcolor=lightyellow]
    ADP_coag      [label="ADP\n(platelet agonist)", shape=ellipse, fillcolor=lightyellow]
    GPIIbIIIa     [label="GPIIb/IIIa\n(fibrinogen receptor)", shape=ellipse, fillcolor=plum]
    VWF_coag      [label="VWF\n(platelet tethering)", shape=ellipse, fillcolor=lightyellow]
  }

  // ─────────────────────────────────────────────
  // CLUSTER 9: RESOLUTION & FIBROSIS
  // ─────────────────────────────────────────────
  subgraph cluster_repair {
    label="Resolution, Repair & Fibrosis"
    style=filled
    fillcolor="#F0FFF8"
    color=seagreen
    fontsize=12
    fontcolor=seagreen

    IL10_res      [label="IL-10\n(anti-inflammatory)", shape=ellipse, fillcolor=lightyellow]
    TGFb1         [label="TGF-β1\n(fibrogenic)", shape=ellipse, fillcolor=lightyellow]
    Treg_res      [label="Regulatory T cells\n(resolution)", shape=ellipse, fillcolor=lightblue]
    M2macrophage  [label="M2 Macrophages\n(anti-inflammatory)", shape=ellipse, fillcolor=lightblue]
    FibroblastAct [label="Fibroblast\nActivation", shape=box, fillcolor=lightpink]
    Collagen_I    [label="Collagen Type I\n(fibrosis)", shape=ellipse, fillcolor=lightyellow]
    Collagen_III  [label="Collagen Type III\n(fibrosis)", shape=ellipse, fillcolor=lightyellow]
    MMP_balance   [label="MMP/TIMP\nBalance", shape=box, fillcolor=wheat]
    TIMP1         [label="TIMP-1\n(MMP inhibitor)", shape=ellipse, fillcolor=wheat]
    ArtScar       [label="Arterial\nScar/Stenosis", shape=box, fillcolor=lightpink]
    HIF1a         [label="HIF-1α\n(hypoxia response)", shape=ellipse, fillcolor=lightyellow]
    Hypoxia       [label="Tissue\nHypoxia/Ischemia", shape=box, fillcolor=lightpink]
    MyoFibroblast [label="Myofibroblast\nTransdifferentiation", shape=box, fillcolor=lightpink]
    NF_kB_repair  [label="NF-κB\n(repair phase)", shape=box, fillcolor=lightyellow]
  }

  // ─────────────────────────────────────────────
  // CLUSTER 10: PREDNISOLONE PK
  // ─────────────────────────────────────────────
  subgraph cluster_pk_pred {
    label="Prednisolone Pharmacokinetics"
    style=filled
    fillcolor="#F0FFF0"
    color=darkgreen
    fontsize=12
    fontcolor=darkgreen

    Pred_Dose     [label="Prednisolone\nOral Dose\n(0.5-1 mg/kg/day)", shape=hexagon, fillcolor=lightgreen]
    Pred_Gut      [label="GI Absorption\n(F~80%)", shape=box, fillcolor=lightgreen]
    Pred_Plasma   [label="Prednisolone\nPlasma (Cp)\n[μg/mL]", shape=ellipse, fillcolor=lightgreen]
    Pred_Binding  [label="Protein Binding\n(CBG, albumin ~75%)", shape=box, fillcolor=lightgreen]
    Pred_Free     [label="Free Prednisolone\n(unbound, active)", shape=ellipse, fillcolor=lightgreen]
    Pred_Liver    [label="Hepatic\nMetabolism", shape=box, fillcolor=lightgreen]
    Pred_CYP3A4   [label="CYP3A4\n(major metabolizer)", shape=ellipse, fillcolor=wheat]
    Pred_Metab    [label="Inactive\nMetabolites", shape=ellipse, fillcolor=lightgreen]
    Pred_Renal    [label="Renal\nExcretion", shape=box, fillcolor=lightgreen]
    Pred_Vd       [label="Volume of\nDistribution (Vd~1 L/kg)", shape=ellipse, fillcolor=lightgreen]
    Pred_T12      [label="t½ ~3-4h\n(plasma)", shape=ellipse, fillcolor=lightgreen]
  }

  // ─────────────────────────────────────────────
  // CLUSTER 11: CYCLOPHOSPHAMIDE PK
  // ─────────────────────────────────────────────
  subgraph cluster_pk_cyc {
    label="Cyclophosphamide Pharmacokinetics"
    style=filled
    fillcolor="#F0F8FF"
    color=navy
    fontsize=12
    fontcolor=navy

    CYC_Dose      [label="Cyclophosphamide\nIV Dose\n(0.5-1 g/m² monthly)", shape=hexagon, fillcolor=lightgreen]
    CYC_Plasma    [label="Cyclophosphamide\nPlasma (Cp)\n[μmol/L]", shape=ellipse, fillcolor=lightgreen]
    CYC_CYP2B6    [label="CYP2B6\n(hepatic activation)", shape=ellipse, fillcolor=wheat]
    CYC_CYP3A4    [label="CYP3A4\n(hepatic activation)", shape=ellipse, fillcolor=wheat]
    OH_CYC        [label="4-OH-CYC\n(active metabolite)", shape=ellipse, fillcolor=lightgreen]
    Aldophosph    [label="Aldophosphamide\n(intermediate)", shape=ellipse, fillcolor=lightgreen]
    Acrolein      [label="Acrolein\n(bladder toxin)", shape=ellipse, fillcolor=lightyellow]
    PhosphoMustard [label="Phosphoramide\nMustard\n(alkylating agent)", shape=ellipse, fillcolor=lightgreen]
    DNA_Alkylation [label="DNA\nAlkylation\n(crosslinking)", shape=box, fillcolor=lightpink]
    CYC_Renal     [label="Renal\nExcretion", shape=box, fillcolor=lightgreen]
    MESNA         [label="MESNA\n(uroprotection)", shape=hexagon, fillcolor=lightgreen]
    MESNA_protect [label="Acrolein\nDetoxification", shape=box, fillcolor=lightgreen]
    CYC_T12       [label="t½ ~4-6h", shape=ellipse, fillcolor=lightgreen]
  }

  // ─────────────────────────────────────────────
  // CLUSTER 12: DRUG PHARMACODYNAMICS
  // ─────────────────────────────────────────────
  subgraph cluster_pd {
    label="Drug Pharmacodynamics"
    style=filled
    fillcolor="#F8FFF0"
    color=forestgreen
    fontsize=12
    fontcolor=forestgreen

    // Prednisolone PD
    GR_Binding    [label="Glucocorticoid\nReceptor (GR) Binding", shape=box, fillcolor=plum]
    GRE_Trans     [label="GRE\nTransactivation", shape=box, fillcolor=lightyellow]
    IkB_Induct    [label="IκB Induction\n(NF-κB inhibitor)", shape=box, fillcolor=lightyellow]
    NFkB_Inhib    [label="NF-κB\nInhibition", shape=box, fillcolor=lightpink]
    Cytokine_Supp [label="Cytokine\nSuppression\n(IL-1β, TNF-α, IL-6)", shape=box, fillcolor=lightpink]
    Immuno_Supp   [label="Broad\nImmunosuppression", shape=box, fillcolor=lightpink]
    AP1_Inhib     [label="AP-1\nInhibition", shape=box, fillcolor=lightpink]

    // Cyclophosphamide PD
    Lympho_Depl   [label="Lymphocyte\nDepletion", shape=box, fillcolor=lightpink]
    Bcell_Supp    [label="B Cell\nSuppression", shape=box, fillcolor=lightpink]
    Ab_Reduc      [label="Antibody\nReduction", shape=box, fillcolor=lightpink]
    Tcell_Supp    [label="T Cell\nSuppression", shape=box, fillcolor=lightpink]
    IC_Reduc      [label="Immune Complex\nReduction", shape=box, fillcolor=lightpink]

    // Azathioprine PD
    AZA_Drug      [label="Azathioprine\n(maintenance)", shape=hexagon, fillcolor=lightgreen]
