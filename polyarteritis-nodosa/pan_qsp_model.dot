  Seroconversion -> Antigen_IC [arrowhead=tee, style=dashed, color=darkgreen, penwidth=2]

  // =============================================================
  // EDGES — BIOMARKERS (from pathological processes)
  // =============================================================
  IL6 -> ESR [color=orange, arrowhead=normal]
  IL6 -> CRP [color=orange, arrowhead=normal]
  IL1b -> CRP [color=orange, arrowhead=normal]
  ImmComplex -> IC_Level [color=blue, arrowhead=normal]
  C3 -> C3_C4_BM [color=purple, arrowhead=normal]
  C4 -> C3_C4_BM [color=purple, arrowhead=normal]
  RenalHTN -> Creatinine [color=red, arrowhead=normal]
  RenalInfarct -> eGFR [color=red, arrowhead=normal]
  Proteinuria -> Urinalysis [color=red, arrowhead=normal]
  Neutrophil -> CBC [color=blue, arrowhead=normal]
  TransmuralInflam -> BVAS [color=red, arrowhead=normal]
  RenalHTN -> FFS [color=red, arrowhead=normal]
  Perforation -> FFS [color=red, arrowhead=normal, label="GI involvement"]
  Microaneurysm -> Angiography [color=red, arrowhead=normal]
  MononeuritisM -> NCS [color=red, arrowhead=normal]
  FibrinoidNecrosis -> SkinBiopsy [color=red, arrowhead=normal]
  HBV -> HBsAg_BM [color=red, arrowhead=normal]
  HBV -> LFT [color=red, arrowhead=normal]
  Fibrinogen_BM -> ESR [color=orange, arrowhead=normal]
  IgG -> ANCA_BM [color=blue, arrowhead=normal]
  ANCA_BM -> Neutrophil [color=red, arrowhead=normal, style=dashed, label="priming", constraint=false]

  // =============================================================
  // EXTRA CROSS-CLUSTER EDGES (pathophysiology loops)
  // =============================================================
  IL17A -> Neutrophil [color=orange, arrowhead=normal, label="recruit"]
  IL8 -> Neutrophil [color=red, arrowhead=normal, label="recruit"]
  C5a -> MastCell [color=purple, arrowhead=normal]
  MastCell -> PAF [color=red, arrowhead=normal]
  PAF -> PlatActivation [color=red, arrowhead=normal]
  ImmComplex -> AltPath [color=purple, arrowhead=normal]
  TNFa -> TissueFactor [color=red, arrowhead=normal]
  IL1b -> PAI1 [color=red, arrowhead=normal]
  TNFa -> PAI1 [color=red, arrowhead=normal]
  ROS -> DNA_Alkylation [color=red, arrowhead=normal, style=dashed, label="oxidative\nstress"]
  HIF1a -> TGFb1 [color=red, arrowhead=normal]
  TGFb1 -> Treg [color=blue, arrowhead=normal]
  Treg -> Treg_res [color=seagreen, arrowhead=normal]

}
