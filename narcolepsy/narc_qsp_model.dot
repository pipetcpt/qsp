digraph NarcolepsyQSP {
  graph [
    rankdir=LR,
    fontname="Helvetica",
    fontsize=11,
    label="Narcolepsy Type 1 — Quantitative Systems Pharmacology (QSP) Mechanistic Map\nOrexin Deficiency · Autoimmune Pathogenesis · Wake/Sleep Regulation · Pharmacological Interventions",
    labelloc=t,
    labeljust=c,
    splines=ortho,
    overlap=false,
    nodesep=0.4,
    ranksep=1.0,
    bgcolor="#F8F9FA"
  ];
  node [shape=box, style="rounded,filled", fontname="Helvetica", fontsize=9, margin="0.15,0.08"];
  edge [fontsize=8, fontname="Helvetica", penwidth=1.2];

  // ============================================================
  // CLUSTER 01: Autoimmune Pathogenesis
  // ============================================================
  subgraph cluster_01 {
    label="Cluster 1: Autoimmune Pathogenesis";
    style=filled;
    color="#C0392B";
    bgcolor="#FADBD8";
    fontsize=11;
    fontcolor="#7B241C";
    fontname="Helvetica-Bold";

    HLA_DQB1 [label="HLA-DQB1*06:02\n(Susceptibility allele ~98%)", fillcolor="#E74C3C", fontcolor=white];
    HLA_DQA1 [label="HLA-DQA1*01:02\n(Co-susceptibility allele)", fillcolor="#E74C3C", fontcolor=white];
    MHC_II [label="MHC Class II\nAntigen Presentation", fillcolor="#EC7063"];
    CD4_T [label="CD4+ T Helper Cells\n(Autoreactive)", fillcolor="#F1948A"];
    CD8_T [label="CD8+ Cytotoxic T Cells\n(Orexin neuron targeting)", fillcolor="#F1948A"];
    Th17 [label="Th17 Cells\nIL-17 production", fillcolor="#F1948A"];
    Treg_fail [label="Regulatory T Cell\nFailure / Dysfunction", fillcolor="#F5B7B1"];
    B_cells [label="B Cells\nAutoantibody production", fillcolor="#F5B7B1"];
    Ab_orexin [label="Anti-Orexin\nAutoantibodies", fillcolor="#FADBD8"];
    Ab_TRIB2 [label="Anti-TRIB2\nAutoantibodies\n(Tribbles homolog 2)", fillcolor="#FADBD8"];
    NK_cells [label="NK Cells\n(Cytotoxicity)", fillcolor="#F5B7B1"];
    Mol_mimicry [label="Molecular Mimicry\n(H1N1 / Pandemrix)", fillcolor="#F9EBEA"];
    H1N1_Ag [label="H1N1 Nucleoprotein\nAntigens (nHA, pH1N1)", fillcolor="#F9EBEA"];
    Pandemrix [label="Pandemrix Vaccine\n(AS03-adjuvanted)", fillcolor="#F9EBEA"];
    IFN_gamma [label="IFN-γ\nPro-inflammatory", fillcolor="#FADBD8"];
    TNF_alpha [label="TNF-α\nNeuroinflammation", fillcolor="#FADBD8"];
    IL6 [label="IL-6\nInflammatory cytokine", fillcolor="#FADBD8"];
    complement [label="Complement Activation\n(C3, C5)", fillcolor="#FADBD8"];
  }

  // ============================================================
  // CLUSTER 02: Lateral Hypothalamus – Orexin Neurons
  // ============================================================
  subgraph cluster_02 {
    label="Cluster 2: Lateral Hypothalamus – Orexin Neurons";
    style=filled;
    color="#1A5276";
    bgcolor="#D6EAF8";
    fontsize=11;
    fontcolor="#1A5276";
    fontname="Helvetica-Bold";

    LH_region [label="Lateral Hypothalamus\n(LH) Region", fillcolor="#2980B9", fontcolor=white];
    HCRT_gene [label="HCRT Gene\n(Hypocretin/Orexin\nPrecursor Gene, Chr 17q21)", fillcolor="#3498DB", fontcolor=white];
    prepro_orexin [label="Prepro-Orexin\nPolypeptide (130 aa)", fillcolor="#5DADE2"];
    OXA [label="Orexin-A (OXA)\nHypocretin-1\n(33 aa, disulfide bonds)", fillcolor="#5DADE2"];
    OXB [label="Orexin-B (OXB)\nHypocretin-2\n(28 aa, linear)", fillcolor="#5DADE2"];
    OX_neuron_count [label="Orexin Neuron Count\nNormal: ~70,000\nNT1: <10% remaining", fillcolor="#85C1E9"];
    OX_neuron_dest [label="Orexin Neuron\nDestruction\n(Apoptosis/Necroptosis)", fillcolor="#AED6F1"];
    CSF_OXA [label="CSF Hypocretin-1\nNormal: >200 pg/mL\nNT1: <110 pg/mL\n(Diagnostic threshold)", fillcolor="#D6EAF8", shape=diamond];
    neuroinflam [label="Neuroinflammation\n(BBB disruption)", fillcolor="#AED6F1"];
    OX_projections [label="Orexin Neuronal\nProjections\n(Widespread brain)", fillcolor="#D6EAF8"];
  }

  // ============================================================
  // CLUSTER 03: Orexin Receptor System
  // ============================================================
  subgraph cluster_03 {
    label="Cluster 3: Orexin Receptor System";
    style=filled;
    color="#1E8449";
    bgcolor="#D5F5E3";
    fontsize=11;
    fontcolor="#1E8449";
    fontname="Helvetica-Bold";

    OX1R [label="OX1R (Orexin Receptor 1)\nHigh affinity: OXA\nLow affinity: OXB\n(Chr 1p33)", fillcolor="#27AE60", fontcolor=white];
    OX2R [label="OX2R (Orexin Receptor 2)\nEqual affinity: OXA+OXB\nCritical for wake/sleep\n(Chr 6p11)", fillcolor="#27AE60", fontcolor=white];
    Gq_protein [label="Gq Protein Coupling\n(OX1R, OX2R)", fillcolor="#52BE80"];
    PLC [label="Phospholipase C (PLC)\nActivation", fillcolor="#58D68D"];
    IP3 [label="IP3\n(Inositol triphosphate)", fillcolor="#82E0AA"];
    DAG [label="DAG\n(Diacylglycerol)", fillcolor="#82E0AA"];
    PKC [label="PKC\n(Protein kinase C)", fillcolor="#A9DFBF"];
    Ca2plus_release [label="Ca2+ Release\nER stores", fillcolor="#A9DFBF"];
    cAMP_pathway [label="cAMP / PKA\nPathway (Gs coupling)", fillcolor="#82E0AA"];
    MAPK [label="MAPK / ERK\nSignaling", fillcolor="#A9DFBF"];
    receptor_internaliz [label="Receptor\nInternalization\n(β-arrestin mediated)", fillcolor="#D5F5E3"];
    OX_desensitize [label="OXR Desensitization\nDownregulation", fillcolor="#D5F5E3"];
    Gi_coupling [label="Gi Protein Coupling\n(Inhibit adenylyl cyclase)", fillcolor="#A9DFBF"];
  }

  // ============================================================
  // CLUSTER 04: Wake-Promoting Monoaminergic Systems
  // ============================================================
  subgraph cluster_04 {
    label="Cluster 4: Wake-Promoting Monoaminergic Systems";
    style=filled;
    color="#7D6608";
    bgcolor="#FEF9E7";
    fontsize=11;
    fontcolor="#7D6608";
    fontname="Helvetica-Bold";

    // Locus Coeruleus
    LC [label="Locus Coeruleus (LC)\nNoradrenergic Neurons\nWake-active", fillcolor="#F39C12", fontcolor=white];
    NE_release [label="Norepinephrine (NE)\nRelease", fillcolor="#F5B041"];
    alpha1R [label="α1-Adrenergic Receptor\n(α1R)\nExcitatory postsynaptic", fillcolor="#F7DC6F"];
    alpha2R [label="α2-Adrenergic Receptor\n(α2R)\nPresynaptic autoreceptor", fillcolor="#F7DC6F"];
    betaAR [label="β-Adrenergic Receptor\n(β-AR)\nCortical arousal", fillcolor="#F7DC6F"];
    NET [label="NET\n(Norepinephrine\nTransporter)", fillcolor="#FDEBD0"];

    // TMN
    TMN [label="Tuberomammillary\nNucleus (TMN)\nHistaminergic Neurons\nWake-active", fillcolor="#CA6F1E", fontcolor=white];
    Hist_release [label="Histamine Release\n(Arousal promotion)", fillcolor="#DC7633"];
    H1R [label="H1 Receptor (H1R)\nPostsynaptic arousal", fillcolor="#E59866"];
    H2R [label="H2 Receptor (H2R)\nCortical activation", fillcolor="#E59866"];
    H3R [label="H3 Receptor (H3R)\nAutoreceptor\n(Inhibits histamine release)", fillcolor="#EDBB99"];
    HDC [label="Histidine\nDecarboxylase (HDC)\n(Histamine synthesis)", fillcolor="#FDEBD0"];

    // VTA Dopamine
    VTA [label="Ventral Tegmental Area\n(VTA)\nDopaminergic Neurons", fillcolor="#D4AC0D", fontcolor=white];
    DA_release [label="Dopamine (DA)\nRelease", fillcolor="#D4E6F1"];
    D1R [label="D1 Receptor (D1R)\nGs-coupled, wake", fillcolor="#AED6F1"];
    D2R [label="D2 Receptor (D2R)\nGi-coupled, complex", fillcolor="#AED6F1"];
    DAT [label="DAT\n(Dopamine\nTransporter)", fillcolor="#D6EAF8"];
    mesolimbic [label="Mesolimbic Pathway\n(Reward/Motivation)", fillcolor="#EBF5FB"];

    // DRN Serotonin
    DRN [label="Dorsal Raphe Nucleus\n(DRN)\nSerotonergic Neurons\nWake/REM-off", fillcolor="#8E44AD", fontcolor=white];
    serotonin_rel [label="Serotonin (5-HT)\nRelease", fillcolor="#A569BD"];
    HT1A [label="5-HT1A Receptor\nAutoreceptor\n(Inhibitory)", fillcolor="#C39BD3"];
    HT2A [label="5-HT2A Receptor\nPostsynaptic\n(Arousal/cortex)", fillcolor="#C39BD3"];
    SERT [label="SERT\n(Serotonin\nTransporter)", fillcolor="#D2B4DE"];

    // BF Cholinergic
    BF [label="Basal Forebrain (BF)\nCholinergic Neurons\n(Wake/REM-on)", fillcolor="#E74C3C", fontcolor=white];
    ACh_release [label="Acetylcholine (ACh)\nRelease", fillcolor="#F1948A"];
    mAChR [label="Muscarinic AChR\n(M1-M5) Cortical\ndesynchronization", fillcolor="#F5B7B1"];
    nAChR [label="Nicotinic AChR\nFast excitatory", fillcolor="#F5B7B1"];
    choline_T [label="Choline\nTransporter\n(CHT1)", fillcolor="#FADBD8"];
  }

  // ============================================================
  // CLUSTER 05: Sleep-Promoting Systems (VLPO)
  // ============================================================
  subgraph cluster_05 {
    label="Cluster 5: Sleep-Promoting Systems (VLPO & Circadian)";
    style=filled;
    color="#154360";
    bgcolor="#D6EAF8";
    fontsize=11;
    fontcolor="#154360";
    fontname="Helvetica-Bold";

    VLPO [label="VLPO\n(Ventrolateral Preoptic Area)\nGABAergic Neurons\nSleep-active", fillcolor="#1F618D", fontcolor=white];
    GABA_vlpo [label="GABA Release\n(VLPO output)", fillcolor="#2874A6"];
    galanin [label="Galanin\nNeuropeptide\n(Inhibitory)", fillcolor="#2E86C1"];
    adenosine [label="Adenosine Accumulation\n(Sleep drive indicator)", fillcolor="#3498DB"];
    A1R [label="Adenosine A1 Receptor\n(A1R)\nInhibitory on wake neurons", fillcolor="#5DADE2"];
    A2AR [label="Adenosine A2A Receptor\n(A2AR)\nActivates VLPO", fillcolor="#5DADE2"];
    Process_S [label="Homeostatic\nSleep Pressure\n(Process S)", fillcolor="#85C1E9", shape=diamond];
    SCN [label="SCN\n(Suprachiasmatic Nucleus)\nCircadian master clock", fillcolor="#1A5276", fontcolor=white];
    melatonin [label="Melatonin\n(MT1/MT2 receptors)", fillcolor="#2980B9"];
    BMAL1 [label="BMAL1\nCore clock gene\n(Transcription factor)", fillcolor="#5DADE2"];
    CLOCK [label="CLOCK\nCore clock gene\n(Dimerizes with BMAL1)", fillcolor="#5DADE2"];
    CRY [label="CRY1/CRY2\nNegative feedback\nclock genes", fillcolor="#85C1E9"];
    PER [label="PER1/PER2/PER3\nPeriod genes\nNegative feedback", fillcolor="#85C1E9"];
    Process_C [label="Circadian Drive (C)\n(Wake-promoting signal)", fillcolor="#AED6F1", shape=diamond];
    POA_inhib [label="Preoptic Area Inhibition\nof Wake Systems", fillcolor="#D6EAF8"];
  }

  // ============================================================
  // CLUSTER 06: REM Sleep Regulation & Cataplexy
  // ============================================================
  subgraph cluster_06 {
    label="Cluster 6: REM Sleep Regulation & Cataplexy";
    style=filled;
    color="#6C3483";
    bgcolor="#F4ECF7";
    fontsize=11;
    fontcolor="#6C3483";
    fontname="Helvetica-Bold";

    PPT_LDT [label="PPT/LDT\n(Pedunculopontine/\nLaterodorsal Tegmental)\nCholinergic REM-on", fillcolor="#7D3C98", fontcolor=white];
    REM_on_Ach [label="REM-on ACh\nNeurons (Active\nduring REM sleep)", fillcolor="#884EA0"];
    SubC [label="Subcoeruleus (SubC)\nGlutamatergic\nREM-on neurons", fillcolor="#9B59B6"];
    vlPAG [label="vlPAG\n(Ventrolateral PAG)\nREM-off / Gating", fillcolor="#A569BD"];
    LPT [label="LPT\n(Lateral Pontine\nTegmentum) REM-off", fillcolor="#A569BD"];
    glycine_atonia [label="Glycinergic Neurons\nSpinal Motor Atonia\n(REM muscle atonia)", fillcolor="#BB8FCE"];
    GABA_atonia [label="GABAergic Neurons\nMotor Inhibition\n(REM atonia)", fillcolor="#BB8FCE"];
    atonia_circuit [label="REM Atonia Circuit\nGlycine + GABA\nSpinal cord", fillcolor="#D2B4DE"];
    amygdala [label="Amygdala\n(Emotional triggers\nfor cataplexy)", fillcolor="#E8DAEF"];
    strong_emotion [label="Strong Emotions\n(Laughter, surprise,\nanger, fear)", fillcolor="#F0E6F6"];
    cataplexy_trigger [label="Cataplexy Trigger\n(Emotional → motor\ncollapse)", fillcolor="#E8DAEF", shape=diamond];
    LC_REM_off [label="LC (Noradrenergic)\nREM-off silencing\n(NE withdrawal)", fillcolor="#C39BD3"];
    DRN_REM_off [label="DRN (Serotonergic)\nREM-off silencing\n(5-HT withdrawal)", fillcolor="#C39BD3"];
    REM_intrusion [label="REM Sleep Intrusion\ninto Wakefulness\n(Abnormal in NT1)", fillcolor="#D2B4DE", shape=diamond];
    SOREMP [label="SOREMP\n(Sleep-Onset REM Period)\n≥2 on MSLT = diagnostic", fillcolor="#D2B4DE", shape=diamond];
  }

  // ============================================================
  // CLUSTER 07: Clinical Symptoms & Tetrad
  // ============================================================
  subgraph cluster_07 {
    label="Cluster 7: Clinical Symptoms & Tetrad";
    style=filled;
    color="#7E5109";
    bgcolor="#FDFEFE";
    fontsize=11;
    fontcolor="#7E5109";
    fontname="Helvetica-Bold";

    EDS [label="EDS\n(Excessive Daytime\nSleepiness)\nPrimary symptom", fillcolor="#784212", fontcolor=white, shape=diamond];
    ESS_score [label="ESS Score (0-24)\n>10 = pathological\nNT1 avg: 17-18", fillcolor="#A04000", fontcolor=white];
    cataplexy [label="Cataplexy Episodes\nSudden bilateral\nmuscle weakness\n(Preserved consciousness)", fillcolor="#A04000", fontcolor=white, shape=diamond];
    cataplexy_freq [label="Cataplexy Frequency\n(Weekly rate)\n0.5-5x/week avg", fillcolor="#C0392B"];
    cataplexy_severity [label="Cataplexy Severity\nPartial vs complete\ncollapse", fillcolor="#C0392B"];
    HH [label="Hypnagogic\nHallucinations\n(Sleep onset)", fillcolor="#CB4335"];
    HP [label="Hypnopompic\nHallucinations\n(Sleep offset)", fillcolor="#CB4335"];
    sleep_paralysis [label="Sleep Paralysis\n(REM atonia\nduring wake)", fillcolor="#E74C3C"];
    disrupted_sleep [label="Disrupted\nNocturnal Sleep\n(Frequent awakenings)", fillcolor="#EC7063"];
    auto_behavior [label="Automatic Behavior\n(Amnesia episodes,\nperformance decline)", fillcolor="#F1948A"];
    cognitive_impair [label="Cognitive Impairment\n(Memory, attention)", fillcolor="#F5B7B1"];
  }

  // ============================================================
  // CLUSTER 08: Drug PK Compartments
  // ============================================================
  subgraph cluster_08 {
    label="Cluster 8: Drug PK Compartments";
    style=filled;
    color="#117864";
    bgcolor="#E8F8F5";
    fontsize=11;
    fontcolor="#117864";
    fontname="Helvetica-Bold";

    // Sodium oxybate
    GHB_dose [label="Sodium Oxybate\n(GHB) Dose\n2.25-9g/night bid", fillcolor="#148F77", fontcolor=white];
    GHB_GI [label="GHB GI Absorption\nRapid, near complete\nt½abs ~0.5h", fillcolor="#1ABC9C"];
    GHB_plasma [label="GHB Plasma\nPK: t½ ~1h\nNon-linear kinetics", fillcolor="#48C9B0"];
    GHB_brain [label="GHB Brain\nPenetration\n(High Vd)", fillcolor="#76D7C4"];
    GHB_metab [label="GHB Metabolism\n→ GABA → succinate\n(Krebs cycle)", fillcolor="#A2D9CE"];

    // Modafinil/Armodafinil
    MOD_dose [label="Modafinil/\nArmodafinil Dose\n100-400mg/day", fillcolor="#148F77", fontcolor=white];
    MOD_abs [label="Modafinil\nAbsorption\nt½abs ~2h", fillcolor="#1ABC9C"];
    MOD_plasma [label="Modafinil Plasma\nt½ ~12-15h\nProtein binding 60%", fillcolor="#48C9B0"];
    MOD_brain [label="Modafinil Brain\nPenetration\nModerate Vd", fillcolor="#76D7C4"];

    // Pitolisant
    PIT_dose [label="Pitolisant Dose\n4.45-35.6mg/day", fillcolor="#148F77", fontcolor=white];
    PIT_abs [label="Pitolisant\nOral Absorption\nRapid, Tmax ~3h", fillcolor="#1ABC9C"];
    PIT_plasma [label="Pitolisant Plasma\nt½ ~10-12h\nHigh protein binding 91%", fillcolor="#48C9B0"];
    PIT_brain [label="Pitolisant Brain\nPenetration\nHigh CNS distribution", fillcolor="#76D7C4"];

    // Solriamfetol
    SOL_dose [label="Solriamfetol Dose\n75-150mg/day", fillcolor="#148F77", fontcolor=white];
    SOL_abs [label="Solriamfetol\nAbsorption\nt½abs ~0.5-1h", fillcolor="#1ABC9C"];
    SOL_plasma [label="Solriamfetol Plasma\nt½ ~7h\nLow protein binding <20%", fillcolor="#48C9B0"];
    SOL_brain [label="Solriamfetol Brain\nPenetration\nActive transport", fillcolor="#76D7C4"];

    // Venlafaxine/Fluoxetine
    SNRI_dose [label="Venlafaxine/\nFluoxetine Dose\n(Anticataplectic)", fillcolor="#148F77", fontcolor=white];
    SNRI_abs [label="SNRI/SSRI\nAbsorption\nOral bioavail >90%", fillcolor="#1ABC9C"];
    SNRI_plasma [label="SNRI/SSRI Plasma\nVenlafaxine t½ ~5h\nFluoxetine t½ ~4-6d", fillcolor="#48C9B0"];
    SNRI_brain [label="SNRI/SSRI Brain\nPenetration\nHigh CNS distribution", fillcolor="#76D7C4"];

    // TAK-994
    TAK994_dose [label="TAK-994\n(OX2R Agonist)\nExperimental", fillcolor="#0E6655", fontcolor=white];
    TAK994_PK [label="TAK-994 PK\nOral bioavailability\nPhase 1/2 trials", fillcolor="#17A589"];
  }

  // ============================================================
  // CLUSTER 09: Pharmacological Targets & Effects
  // ============================================================
  subgraph cluster_09 {
    label="Cluster 9: Pharmacological Targets & Effects";
    style=filled;
    color="#1B2631";
    bgcolor="#EAECEE";
    fontsize=11;
    fontcolor="#1B2631";
    fontname="Helvetica-Bold";

    // GHB targets
    GABA_B_R [label="GABA-B Receptor\n(GHB → GABA-B\nagonism)", fillcolor="#2C3E50", fontcolor=white];
    GHB_R [label="GHB Receptor\n(Specific\nlow-affinity)", fillcolor="#34495E", fontcolor=white];
    SWS_enhance [label="SWS Enhancement\n(N3 slow wave sleep\nConsolidation)", fillcolor="#5D6D7E", shape=diamond];
    GH_release [label="GH Release\n(Growth hormone\nSWS-coupled)", fillcolor="#717D7E"];

    // DAT/NET inhibition (wake)
    DAT_inhib [label="DAT Inhibition\n(Modafinil, Solriamfetol)\nDA reuptake block", fillcolor="#616A6B", fontcolor=white];
    NET_inhib [label="NET Inhibition\n(Modafinil, Solriamfetol)\nNE reuptake block", fillcolor="#616A6B", fontcolor=white];
    DA_increase [label="DA Increase\n(Wakefulness\npromotion)", fillcolor="#808B96", shape=diamond];
    NE_increase [label="NE Increase\n(Arousal\npromotion)", fillcolor="#808B96", shape=diamond];

    // H3R inverse agonism
    H3R_inv_ag [label="H3R Inverse\nAgonism\n(Pitolisant)", fillcolor="#4D5656", fontcolor=white];
    Hist_increase [label="Histamine\nIncrease\n(Wake promotion)", fillcolor="#717D7E", shape=diamond];

    // SERT/NET inhibition (anticataplectic)
    SERT_inhib [label="SERT Inhibition\n(Fluoxetine,\nVenlafaxine)\nAnticataplectic", fillcolor="#4D5656", fontcolor=white];
    NET_inhib2 [label="NET Inhibition\n(Venlafaxine)\nREM suppression", fillcolor="#4D5656", fontcolor=white];
    REM_suppress [label="REM Suppression\n(Anticataplectic\nmechanism)", fillcolor="#808B96", shape=diamond];

    // OX2R agonism
    OX2R_ag [label="OX2R Agonism\n(TAK-994)\nDirect wake\npromotion", fillcolor="#2C3E50", fontcolor=white];
    wake_direct [label="Direct Wake\nPromotion\n(OX2R pathway)", fillcolor="#717D7E", shape=diamond];

    // Caffeine
    caffeine [label="Caffeine\nAdenosine\nAntagonist", fillcolor="#5D6D7E", fontcolor=white];
    A1R_block [label="A1R Blockade\n(Caffeine)", fillcolor="#85929E"];
    A2AR_block [label="A2AR Blockade\n(Caffeine)", fillcolor="#85929E"];
  }

  // ============================================================
  // CLUSTER 10: Biomarkers & Clinical Endpoints
  // ============================================================
  subgraph cluster_10 {
    label="Cluster 10: Biomarkers & Clinical Endpoints";
    style=filled;
    color="#0B5345";
    bgcolor="#D0ECE7";
    fontsize=11;
    fontcolor="#0B5345";
    fontname="Helvetica-Bold";

    CSF_OXA_bio [label="CSF Hypocretin-1\nBiomarker\nNormal: >200 pg/mL\nNT1 diagnostic: <110 pg/mL", fillcolor="#117864", fontcolor=white, shape=diamond];
    MSLT [label="MSLT\n(Multiple Sleep\nLatency Test)", fillcolor="#148F77", fontcolor=white, shape=diamond];
    mean_SL [label="Mean Sleep Latency\n(Normal >10min\nNT1: <8min)", fillcolor="#1ABC9C"];
    SOREMP_count [label="SOREMP Count\n≥2 REM periods\nin 5 opportunities", fillcolor="#48C9B0"];
    PSG [label="PSG\n(Polysomnography)\nOvernight recording", fillcolor="#148F77", fontcolor=white, shape=diamond];
    REM_latency [label="REM Latency\n(Normal: >90min\nNT1: often <20min)", fillcolor="#1ABC9C"];
    sleep_efficiency [label="Sleep Efficiency\n(%TST/TIB)\nNT1 often reduced", fillcolor="#48C9B0"];
    pct_REM [label="%REM\n(Normal: 20-25%\nMay be redistributed)", fillcolor="#76D7C4"];
    pct_N3 [label="%N3 SWS\n(Often preserved\nor reduced in NT1)", fillcolor="#76D7C4"];
    ESS_bio [label="ESS Score (0-24)\n(Epworth Sleepiness\nScale)", fillcolor="#1ABC9C", shape=diamond];
    cataplexy_rate [label="Cataplexy Weekly Rate\n(Primary endpoint\nin trials)", fillcolor="#48C9B0", shape=diamond];
    actigraphy [label="Actigraphy Metrics\nW/S fragmentation\nActigraphic efficiency", fillcolor="#76D7C4"];
    wearable [label="Wearable Sensors\n(Continuous monitoring)", fillcolor="#A2D9CE"];
  }

  // ============================================================
  // CLUSTER 11: Flip-Flop Switch & Wake/Sleep State
  // ============================================================
  subgraph cluster_11 {
    label="Cluster 11: Flip-Flop Switch & Wake/Sleep State";
    style=filled;
    color="#512E5F";
    bgcolor="#F5EEF8";
    fontsize=11;
    fontcolor="#512E5F";
    fontname="Helvetica-Bold";

    wake_state [label="WAKE State\n(Active, alert)\nBistable", fillcolor="#7D3C98", fontcolor=white, shape=diamond];
    sleep_state [label="SLEEP State\n(NREM cycling)\nBistable", fillcolor="#884EA0", fontcolor=white, shape=diamond];
    REM_state [label="REM State\n(Paradoxical sleep)\nBistable", fillcolor="#9B59B6", fontcolor=white, shape=diamond];
    flipflop [label="Flip-Flop Switch\nMutual inhibition\n(Wake ↔ Sleep)", fillcolor="#A569BD"];
    state_instability [label="State Instability\nin Narcolepsy\n(Blurred boundaries)", fillcolor="#BB8FCE", shape=diamond];
    NREM_cycling [label="NREM/REM Cycling\nNormal: 90-min ultradian\nNT1: disrupted", fillcolor="#C39BD3"];
    wake_sleep_trans [label="Wake-to-Sleep\nTransition\n(Normally stable)", fillcolor="#D2B4DE"];
    sleep_wake_trans [label="Sleep-to-Wake\nTransition\n(Normally stable)", fillcolor="#D2B4DE"];
    orexin_stabilize [label="Orexin Stabilization\nRole in flip-flop\n(Normal function)", fillcolor="#E8DAEF"];
    orexin_loss_instab [label="Orexin Loss →\nState Instability\n(NT1 pathophysiology)", fillcolor="#F4ECF7", shape=diamond];
    theta_power [label="EEG Theta Power\n(Drowsiness marker)\nIncreased in NT1", fillcolor="#E8DAEF"];
  }

  // ============================================================
