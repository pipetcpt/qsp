        C3b_reduction -> MAC [label="reduces\nMAC formation" style=dashed color=green]
        CP_block -> Hb_increase [label="less hemolysis"]
        CP_block -> LDH_decrease [label="less hemolysis"]
        SUTI_plasma -> SUTI_t12 [label="determines"]
        SUTI_plasma -> SUTI_Cmax [label="peak"]
    }

