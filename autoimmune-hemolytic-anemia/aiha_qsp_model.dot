        GR -> nGRE [label="transrepression\n(NF-κB↓)"]
        nGRE -> NFkB_B [label="inhibits" style=dashed color=green]
        GRE -> PRED_FcR [label="downregulates\nFcγR expression"]
        GRE -> PRED_Ab [label="reduces\nautoantibody production"]
        PRED_FcR -> Phagocytosis [label="reduces" style=dashed color=green]
        PRED_Ab -> Opsonin [label="reduces" style=dashed color=green]
        PRED_plasma -> PRED_Vd [label="distributed into"]
        PRED_plasma -> PRED_CL [label="cleared by"]

