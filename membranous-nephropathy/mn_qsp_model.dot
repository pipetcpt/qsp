digraph MembranousNephropathy {
    graph [
        label="Membranous Nephropathy QSP Mechanistic Map",
        labelloc=t,
        fontname="Helvetica",
        fontsize=16,
        rankdir=TB,
        splines=true,
        nodesep=0.4,
        ranksep=0.6,
        bgcolor="white"
    ];
    node [fontname="Helvetica", fontsize=9, style=filled, shape=box];
    edge [fontname="Helvetica", fontsize=8];

    /* ============================================================
       CLUSTER 1: Antigen Presentation
    ============================================================ */
    subgraph cluster_antigen {
        label="Antigen Presentation & APC";
        style=filled;
        fillcolor="#FFF8DC";
        color="#8B6914";
        fontsize=11;
        fontname="Helvetica Bold";

        PLA2R1 [label="PLA2R1\n(M-type PLA2 receptor)", fillcolor="#FFD700", shape=diamond];
        THSD7A [label="THSD7A\n(Thrombospondin\ndomain-containing 7A)", fillcolor="#FFD700", shape=diamond];
        NELL1  [label="NELL1\n(Neural EGF-like\nprotein 1)", fillcolor="#FFD700"];
        EXT1   [label="EXT1\n(Exostosin 1)", fillcolor="#FFD700"];
        EXT2   [label="EXT2\n(Exostosin 2)", fillcolor="#FFD700"];
        PCDH7  [label="PCDH7\n(Protocadherin 7)", fillcolor="#FFD700"];
        Sema3B [label="Sema3B\n(Semaphorin 3B)", fillcolor="#FFD700"];
        NCAM1  [label="NCAM1\n(Neural cell adhesion\nmolecule 1)", fillcolor="#FFD700"];
        Antigen_proc [label="Antigen\nProcessing\n(Proteasome/Lysosome)", fillcolor="#FFA07A", shape=ellipse];
        APC    [label="APC\n(Antigen Presenting Cell\nDendritic Cell/Macrophage)", fillcolor="#FFA07A", shape=ellipse];
        MHC_II [label="MHC-II\n(HLA-DQA1, HLA-DRB1)", fillcolor="#FFA07A", shape=diamond];
        TCR    [label="TCR\n(T Cell Receptor)", fillcolor="#FFA07A"];
        CD80_86 [label="CD80/CD86\n(Co-stimulation)", fillcolor="#FFA07A"];
        IL12_APC [label="IL-12\n(from APC)", fillcolor="#FFA07A"];
    }

    /* ============================================================
       CLUSTER 2: T Cell Activation & Help
    ============================================================ */
    subgraph cluster_tcell {
        label="T Cell Activation & Help";
        style=filled;
        fillcolor="#E6F3FF";
        color="#003399";
        fontsize=11;
        fontname="Helvetica Bold";

        CD4_Th  [label="CD4+ Th2 Cell\n(Effector T Helper)", fillcolor="#87CEEB", shape=ellipse];
        Tfh     [label="Tfh\n(T Follicular Helper)", fillcolor="#87CEEB", shape=ellipse];
        Th2_diff [label="Th2\nDifferentiation", fillcolor="#B0D4F1"];
        IL4     [label="IL-4\n(Tfh/Th2 cytokine)", fillcolor="#B0D4F1", shape=diamond];
        IL13    [label="IL-13\n(Th2 cytokine)", fillcolor="#B0D4F1", shape=diamond];
        IL21    [label="IL-21\n(Tfh cytokine)", fillcolor="#B0D4F1", shape=diamond];
        IL5     [label="IL-5", fillcolor="#B0D4F1"];
        ICOS    [label="ICOS\n(Inducible Co-stimulator)", fillcolor="#B0D4F1"];
        ICOSL   [label="ICOSL\n(ICOS Ligand on B cell)", fillcolor="#B0D4F1"];
        CD40L   [label="CD40L\n(CD154, on T cell)", fillcolor="#B0D4F1", shape=diamond];
        IL10_T  [label="IL-10\n(immunoregulatory)", fillcolor="#B0D4F1"];
        Treg    [label="Treg\n(Regulatory T Cell\nFoxP3+)", fillcolor="#98FB98", shape=ellipse];
        CTLA4   [label="CTLA-4\n(negative regulator)", fillcolor="#98FB98", shape=diamond];
        PD1     [label="PD-1\n(T cell exhaustion)", fillcolor="#98FB98"];
        PDL1    [label="PD-L1\n(on APC/B cell)", fillcolor="#98FB98"];
        TGFb_T  [label="TGF-β\n(Treg suppression)", fillcolor="#98FB98"];
        STAT6   [label="STAT6\n(IL-4/IL-13 signaling)", fillcolor="#B0D4F1"];
        GATA3   [label="GATA3\n(Th2 TF)", fillcolor="#B0D4F1"];
    }

    /* ============================================================
       CLUSTER 3: B Cell Biology
    ============================================================ */
    subgraph cluster_bcell {
        label="B Cell Biology & Antibody Production";
        style=filled;
        fillcolor="#FFF0F5";
        color="#8B0000";
        fontsize=11;
        fontname="Helvetica Bold";

        NaiveB  [label="Naive B Cell\n(IgM+IgD+)", fillcolor="#FFB6C1", shape=ellipse];
        GCB     [label="Germinal Center B Cell\n(Affinity maturation)", fillcolor="#FF69B4", shape=ellipse];
        MemoryB [label="Memory B Cell\n(Long-lived)", fillcolor="#FF69B4", shape=ellipse];
        PlasmaCell [label="Long-lived\nPlasma Cell\n(Bone marrow)", fillcolor="#DC143C", shape=ellipse];
        CD20_B  [label="CD20\n(B cell surface marker)", fillcolor="#FFB6C1", shape=diamond];
        IgG4_switch [label="IgG4 Class\nSwitch\n(IL-4/IL-13 driven)", fillcolor="#FF8C94", shape=diamond];
        IgG1_switch [label="IgG1 Class\nSwitch", fillcolor="#FF8C94"];
        anti_PLA2R1_IgG4 [label="anti-PLA2R1\nIgG4\n(pathogenic Ab)", fillcolor="#DC143C", shape=diamond];
        anti_PLA2R1_IgG1 [label="anti-PLA2R1\nIgG1\n(complement-fixing)", fillcolor="#DC143C"];
        anti_THSD7A_IgG4 [label="anti-THSD7A\nIgG4", fillcolor="#DC143C"];
        BCR     [label="BCR\n(B Cell Receptor)", fillcolor="#FFB6C1"];
        BTK     [label="BTK\n(Bruton's Tyrosine Kinase)", fillcolor="#FFB6C1", shape=diamond];
        PI3K_AKT [label="PI3K/AKT\n(survival signaling)", fillcolor="#FFB6C1"];
        BAFF    [label="BAFF\n(B cell survival factor)", fillcolor="#FFB6C1", shape=diamond];
        APRIL   [label="APRIL\n(plasma cell survival)", fillcolor="#FFB6C1", shape=diamond];
        CD40_B  [label="CD40\n(on B cell)", fillcolor="#FFB6C1"];
        BLIMP1  [label="BLIMP1\n(plasma cell TF)", fillcolor="#FFB6C1"];
        AID     [label="AID\n(class switch\nrecombinase)", fillcolor="#FFB6C1"];
    }

    /* ============================================================
       CLUSTER 4: Complement System
    ============================================================ */
    subgraph cluster_complement {
        label="Complement System";
        style=filled;
        fillcolor="#F0FFF0";
        color="#006400";
        fontsize=11;
        fontname="Helvetica Bold";

        C1q   [label="C1q\n(Classical pathway\ninit.)", fillcolor="#90EE90", shape=diamond];
        C1r   [label="C1r\n(serine protease)", fillcolor="#90EE90"];
        C1s   [label="C1s\n(serine protease)", fillcolor="#90EE90"];
        C4    [label="C4\n(C4a+C4b)", fillcolor="#90EE90"];
        C2    [label="C2\n(C2a+C2b)", fillcolor="#90EE90"];
        C3_conv_classic [label="C3 Convertase\n(C4b2a)\nClassical", fillcolor="#32CD32", shape=diamond];
        MBL   [label="MBL\n(Mannose-binding\nlectin)", fillcolor="#90EE90"];
        MASP1 [label="MASP1\n(MBL-assoc.\nserine protease)", fillcolor="#90EE90"];
        MASP2 [label="MASP2\n(MBL-assoc.\nserine protease)", fillcolor="#90EE90"];
        C3b   [label="C3b\n(opsonin)", fillcolor="#32CD32", shape=diamond];
        FactorB [label="Factor B\n(Alt. pathway)", fillcolor="#90EE90"];
        FactorD [label="Factor D\n(Alt. pathway)", fillcolor="#90EE90"];
        Properdin [label="Properdin\n(stabilizes C3bBb)", fillcolor="#90EE90"];
        C3_conv_alt [label="C3 Convertase\n(C3bBb)\nAlternative", fillcolor="#32CD32", shape=diamond];
        C5_conv [label="C5 Convertase\n(C4b2a3b)", fillcolor="#32CD32", shape=diamond];
        C5a   [label="C5a\n(anaphylatoxin)", fillcolor="#FF4500", shape=diamond];
        C5aR1 [label="C5aR1\n(on podocytes)", fillcolor="#FF4500", shape=diamond];
        C5b   [label="C5b\n(MAC initiation)", fillcolor="#FF6347"];
        C6    [label="C6", fillcolor="#FF6347"];
        C7    [label="C7", fillcolor="#FF6347"];
        C8    [label="C8", fillcolor="#FF6347"];
        C9    [label="C9\n(polymerization)", fillcolor="#FF6347"];
        C5b9_MAC [label="C5b-9\n(MAC)\nMembrane Attack\nComplex", fillcolor="#FF0000", shape=diamond];
        sC5b9 [label="sC5b9\n(soluble MAC\nbiomarker)", fillcolor="#00CED1", shape=ellipse];
        CD59  [label="CD59\n(MAC inhibitor\non podocytes)", fillcolor="#98FB98", shape=diamond];
        C1inh [label="C1-Inhibitor\n(serpin)", fillcolor="#98FB98", shape=diamond];
        FactorH [label="Factor H\n(Alt. pathway\nregulator)", fillcolor="#98FB98", shape=diamond];
        FI    [label="Factor I\n(C3b cleavage)", fillcolor="#98FB98"];
        C4BP  [label="C4BP\n(C4b regulator)", fillcolor="#98FB98"];
    }

    /* ============================================================
       CLUSTER 5: Podocyte Biology
    ============================================================ */
    subgraph cluster_podocyte {
        label="Podocyte Biology";
        style=filled;
        fillcolor="#FFFACD";
        color="#8B8000";
        fontsize=11;
        fontname="Helvetica Bold";

        FootProcess [label="Foot Process\n(Podocyte effacement)", fillcolor="#FFD700", shape=diamond];
        SlitDiaphragm [label="Slit Diaphragm\n(filtration barrier)", fillcolor="#FFD700", shape=diamond];
        Nephrin [label="Nephrin\n(NPHS1)\nslitDiaphragm protein", fillcolor="#DAA520", shape=diamond];
        Podocin [label="Podocin\n(NPHS2)", fillcolor="#DAA520"];
        CD2AP  [label="CD2AP\n(adaptor protein)", fillcolor="#DAA520"];
        WT1    [label="WT1\n(podocyte TF)", fillcolor="#DAA520"];
        Synaptopodin [label="Synaptopodin\n(actin regulator)", fillcolor="#DAA520"];
        Actin_cyto [label="Actin\nCytoskeleton\n(F-actin)", fillcolor="#DAA520", shape=diamond];
        VEGF_pod [label="VEGF-A\n(from podocyte\nendothelial crosstalk)", fillcolor="#DAA520"];
        ROS    [label="ROS\n(Reactive Oxygen\nSpecies)", fillcolor="#FF8C00", shape=diamond];
        Podocyte_apoptosis [label="Podocyte\nApoptosis", fillcolor="#FF4500", shape=diamond];
        Caspase3 [label="Caspase-3\n(apoptosis exec.)", fillcolor="#FF4500"];
        Podocyte_detach [label="Podocyte\nDetachment\n(podocyturia)", fillcolor="#FF4500", shape=diamond];
        Podocyte_loss [label="Podocyte\nDensity Loss\n(irreversible)", fillcolor="#FF0000", shape=diamond];
        mTOR_pod [label="mTOR\n(podocyte survival)", fillcolor="#DAA520"];
        Nox_NADPH [label="NADPH Oxidase\n(superoxide source)", fillcolor="#FF8C00"];
    }

    /* ============================================================
       CLUSTER 6: Glomerular Basement Membrane
    ============================================================ */
    subgraph cluster_gbm {
        label="Glomerular Basement Membrane (GBM)";
        style=filled;
        fillcolor="#F5F5DC";
        color="#696969";
        fontsize=11;
        fontname="Helvetica Bold";

        Laminin521 [label="Laminin-521\n(α5β2γ1)", fillcolor="#D2B48C"];
        ColIV  [label="Collagen IV\n(α3α4α5 network)", fillcolor="#D2B48C"];
        Agrin  [label="Agrin\n(heparan sulfate PG)", fillcolor="#D2B48C"];
        Nidogen [label="Nidogen\n(GBM scaffold)", fillcolor="#D2B48C"];
        Subep_deposits [label="Subepithelial\nImmune Deposits\n(IgG4+C3)", fillcolor="#8B4513", shape=diamond];
        GBM_thickening [label="GBM\nThickening\n(structural remodel)", fillcolor="#8B4513", shape=diamond];
        Spike_formation [label="Spike\nFormation\n(GBM projections)", fillcolor="#8B4513", shape=diamond];
        Tuft_area [label="Glomerular Tuft\nArea Reduction", fillcolor="#8B4513", shape=diamond];
        MMP2   [label="MMP-2\n(GBM remodeling)", fillcolor="#D2B48C"];
        MMP9   [label="MMP-9\n(GBM remodeling)", fillcolor="#D2B48C"];
        TIMP   [label="TIMP\n(MMP inhibitor)", fillcolor="#D2B48C"];
        SubEp_area [label="Subepithelial\nDeposit Area\n(histology)", fillcolor="#8B4513"];
    }

    /* ============================================================
       CLUSTER 7: Tubular Function
    ============================================================ */
    subgraph cluster_tubule {
        label="Tubular Function & Injury";
        style=filled;
        fillcolor="#F0F8FF";
        color="#4169E1";
        fontsize=11;
        fontname="Helvetica Bold";

        Megalin  [label="Megalin\n(LRP2, albumin\nreabsorption receptor)", fillcolor="#B0C4DE", shape=diamond];
        Cubilin  [label="Cubilin\n(co-receptor for\nMegalin)", fillcolor="#B0C4DE"];
        Albumin_reab [label="Albumin\nReabsorption\n(proximal tubule)", fillcolor="#B0C4DE"];
        Lipid_droplets [label="Lipid Droplets\n(tubular lipotoxicity)", fillcolor="#B0C4DE"];
        Tubular_injury [label="Tubular Injury\n(oxidative/lipotoxic)", fillcolor="#4169E1", shape=diamond];
        NGAL   [label="NGAL\n(Neutrophil gelatinase-\nassoc. lipocalin)", fillcolor="#00CED1", shape=ellipse];
        KIM1   [label="KIM-1\n(kidney injury\nmolecule-1)", fillcolor="#00CED1", shape=ellipse];
        NAG    [label="NAG\n(N-acetyl-β-\nglucosaminidase)", fillcolor="#00CED1"];
        Tubular_fibrosis [label="Tubular\nFibrosis\n(interstitial)", fillcolor="#4169E1"];
        TGFb_tub [label="TGF-β\n(fibrosis driver\nin tubule)", fillcolor="#4169E1"];
        FGF23  [label="FGF-23\n(phosphate handling)", fillcolor="#B0C4DE"];
    }

    /* ============================================================
       CLUSTER 8: Rituximab PK
    ============================================================ */
    subgraph cluster_pk_rituximab {
        label="Rituximab PK (TMDD Model)";
        style=filled;
        fillcolor="#FFE4E1";
        color="#8B0000";
        fontsize=11;
        fontname="Helvetica Bold";

        RTX_dose  [label="Rituximab Dose\n(375 mg/m² or 1g IV)", fillcolor="#FF4500", shape=ellipse];
        RTX_central [label="RTX Central\nCompartment\n(Vc ~ 3.1 L)", fillcolor="#FF6347"];
        RTX_peripheral [label="RTX Peripheral\nCompartment\n(Vp ~ 3.4 L)", fillcolor="#FF6347"];
        RTX_TMDD [label="TMDD\n(CD20-mediated\nelimination)", fillcolor="#FF4500", shape=diamond];
        CD20_RTX_complex [label="CD20:RTX\nComplex\n(internalized)", fillcolor="#FF4500", shape=diamond];
        FcRn_recycling [label="FcRn Recycling\n(IgG half-life\nextension)", fillcolor="#FF6347"];
        RTX_clearance [label="RTX Clearance\n(CL ~ 0.14 L/h)", fillcolor="#FF6347"];
        RTX_halflife [label="RTX Half-life\n(t½ ~ 22 days)", fillcolor="#FF6347"];
        RTX_Cmax [label="RTX Cmax\n(Tmax ~ 4h)", fillcolor="#FF6347"];
    }

    /* ============================================================
       CLUSTER 9: Immunosuppressant PK
    ============================================================ */
    subgraph cluster_pk_immunosup {
        label="Immunosuppressant PK";
        style=filled;
        fillcolor="#FFE4B5";
        color="#8B4513";
        fontsize=11;
        fontname="Helvetica Bold";

        TAC_dose  [label="Tacrolimus Dose\n(0.05–0.1 mg/kg/d)", fillcolor="#FF8C00", shape=ellipse];
        TAC_GI    [label="TAC GI Absorption\n(F ~ 25%, variable)", fillcolor="#FFA500"];
        TAC_blood  [label="TAC Blood\n(FK506, whole blood\nC0 target 5–10 ng/mL)", fillcolor="#FFA500", shape=diamond];
        TAC_CYP3A4 [label="TAC CYP3A4\nMetabolism\n(liver/gut)", fillcolor="#FFA500"];
        TAC_peripheral [label="TAC Peripheral\nCompartment\n(Vd ~ 1000 L)", fillcolor="#FFA500"];
        CsA_dose  [label="Cyclosporine A Dose", fillcolor="#FF8C00", shape=ellipse];
        CsA_central [label="CsA Central\nCompartment\n(Sandimmun)", fillcolor="#FFA500"];
        CPx_dose  [label="Cyclophosphamide\nDose (0.5–1 g/m²)", fillcolor="#FF8C00", shape=ellipse];
        CPx_central [label="CPx Central\nCompartment", fillcolor="#FFA500"];
        CPx_4OH   [label="4-OH-CPx\n(active metabolite)", fillcolor="#FFA500"];
        CPx_acrolein [label="Acrolein\n(bladder toxic\nmetabolite)", fillcolor="#FFA500"];
        MMF_dose  [label="MMF Dose\n(1–2 g/d)", fillcolor="#FF8C00", shape=ellipse];
        MMF_MPA   [label="MPA\n(active form of MMF\nIMPDH inhibitor)", fillcolor="#FFA500", shape=diamond];
        MPAG      [label="MPAG\n(inactive glucuronide)", fillcolor="#FFA500"];
    }

    /* ============================================================
       CLUSTER 10: Drug PD Mechanisms
    ============================================================ */
    subgraph cluster_pd_drugs {
        label="Drug PD Mechanisms";
        style=filled;
        fillcolor="#FFF0E6";
        color="#FF4500";
        fontsize=11;
        fontname="Helvetica Bold";

        CD20_occupancy [label="CD20 Occupancy\nby RTX (%)", fillcolor="#FF6347", shape=diamond];
        Bcell_depletion [label="B Cell\nDepletion\n(>95%)", fillcolor="#FF0000", shape=diamond];
        Bcell_reconstitution [label="B Cell\nReconstitution\n(6–12 months)", fillcolor="#FF6347", shape=diamond];
        Calcineurin_inh [label="Calcineurin\nInhibition\n(TAC/CsA)", fillcolor="#FF8C00", shape=diamond];
        NFAT_block [label="NFAT\nDephosphorylation\nBlocked", fillcolor="#FF8C00", shape=diamond];
        IL2_suppress [label="IL-2\nSuppression\n(T cell cytokine)", fillcolor="#FF8C00"];
        IMPDH_inh  [label="IMPDH\nInhibition\n(MMF/MPA)", fillcolor="#FF8C00", shape=diamond];
        Purine_synth_block [label="Purine Synthesis\nBlock\n(lymphocyte\nselective)", fillcolor="#FF8C00"];
        ACE_inh    [label="ACE Inhibitor\n(Ramipril/Enalapril)", fillcolor="#FF4500", shape=ellipse];
        ARB        [label="ARB\n(AT1R Blocker\nLosartan/Irbesartan)", fillcolor="#FF4500", shape=ellipse];
        AngII_reduce [label="AngII Reduction\n(ACEi effect)", fillcolor="#FF6347", shape=diamond];
        AT1R_block [label="AT1R Blockade\n(ARB effect)", fillcolor="#FF6347", shape=diamond];
        Efferent_dilate [label="Efferent Arteriole\nDilation", fillcolor="#FF6347"];
        GlomP_reduce [label="Glomerular\nPressure Reduction", fillcolor="#FF6347", shape=diamond];
        Proteinuria_red [label="Proteinuria\nReduction\n(RAAS blockade)", fillcolor="#FF6347"];
        ACTH_drug  [label="ACTH\n(Tetracosactide\nSynacthen)", fillcolor="#FF4500", shape=ellipse];
        Cortisol_up [label="Cortisol↑\n(adrenal\nstimulation)", fillcolor="#FF8C00"];
        GR_activation [label="Glucocorticoid\nReceptor Activation", fillcolor="#FF8C00", shape=diamond];
        NF_kB_suppress [label="NF-κB\nSuppression\n(anti-inflammatory)", fillcolor="#FF8C00"];
        Belimumab  [label="Belimumab\n(anti-BAFF mAb)", fillcolor="#DC143C", shape=ellipse];
        Obinutuzumab [label="Obinutuzumab\n(anti-CD20 mAb\ntype II)", fillcolor="#DC143C", shape=ellipse];
        Avacopan  [label="Avacopan\n(C5aR1 inhibitor)", fillcolor="#DC143C", shape=ellipse];
        Sparsentan [label="Sparsentan\n(dual ET-A/AT1R\nblocker)", fillcolor="#DC143C", shape=ellipse];
    }

    /* ============================================================
       CLUSTER 11: RAAS
    ============================================================ */
    subgraph cluster_raas {
        label="RAAS (Renin-Angiotensin-Aldosterone System)";
        style=filled;
        fillcolor="#E6FFE6";
        color="#006400";
        fontsize=11;
        fontname="Helvetica Bold";

        Renin  [label="Renin\n(from JGA cells)", fillcolor="#90EE90", shape=diamond];
        Angiotensinogen [label="Angiotensinogen\n(liver)", fillcolor="#90EE90"];
        AngI   [label="Angiotensin I\n(decapeptide)", fillcolor="#90EE90"];
        ACE    [label="ACE\n(Ang-converting\nenzyme)", fillcolor="#32CD32", shape=diamond];
        AngII  [label="Angiotensin II\n(vasoactive)", fillcolor="#32CD32", shape=diamond];
        AT1R   [label="AT1R\n(vasoconstriction\nfibrosis)", fillcolor="#32CD32", shape=diamond];
        AT2R   [label="AT2R\n(vasodilation\nprotective)", fillcolor="#32CD32"];
        Aldosterone [label="Aldosterone\n(adrenal cortex)", fillcolor="#32CD32", shape=diamond];
        MR     [label="MR\n(mineralocorticoid\nreceptor)", fillcolor="#32CD32"];
        Na_retention [label="Na+ Retention\n(collecting duct)", fillcolor="#32CD32"];
        Sympathetic_efferent [label="Sympathetic\nEfferent\n(tubular NaCl\nreabsorption)", fillcolor="#90EE90"];
        Bradykinin [label="Bradykinin\n(ACEi accumulation)", fillcolor="#90EE90"];
        NO_vascular [label="NO\n(vascular\nprotection)", fillcolor="#90EE90"];
        GFR_autoregulation [label="GFR\nAutoregulation\n(afferent/efferent\ntone)", fillcolor="#32CD32", shape=diamond];
        Efferent_art [label="Efferent\nArteriole Tone", fillcolor="#32CD32", shape=diamond];
    }

    /* ============================================================
       CLUSTER 12: Clinical Outcomes
    ============================================================ */
    subgraph cluster_outcomes {
        label="Clinical Outcomes";
        style=filled;
        fillcolor="#F0FFF0";
        color="#228B22";
        fontsize=11;
        fontname="Helvetica Bold";

        Proteinuria_24h [label="24h Urine Protein\n(g/day)\n[primary endpoint]", fillcolor="#00FF00", shape=diamond];
        Serum_albumin [label="Serum Albumin\n(g/dL)\n[normal >3.5]", fillcolor="#00FF00", shape=diamond];
        eGFR   [label="eGFR\n(CKD-EPI, mL/min/1.73m²)\n[normal >60]", fillcolor="#00FF00", shape=diamond];
        Serum_creatinine [label="Serum Creatinine\n(mg/dL)", fillcolor="#00FF00"];
        CR_complete [label="Complete Remission\n(Proteinuria <0.3 g/d\nalbumin >3.5 g/dL)", fillcolor="#006400", shape=diamond];
        PR_partial [label="Partial Remission\n(Proteinuria 0.3–3.5 g/d\n50% reduction)", fillcolor="#228B22", shape=diamond];
        ESRD_risk [label="ESRD Risk\n(10-yr progression\n~30–40%)", fillcolor="#8B0000", shape=diamond];
        Edema   [label="Edema\n(peripheral/pulmonary)", fillcolor="#32CD32", shape=diamond];
        Hyperlipidemia [label="Hyperlipidemia\n(reactive, liver\nlipoprotein↑)", fillcolor="#32CD32"];
        Thrombosis_risk [label="Thrombosis Risk\n(DVT/PE\nhypercoagulability)", fillcolor="#FF4500", shape=diamond];
        Nephrotic_syndrome [label="Nephrotic\nSyndrome\n(full clinical\npicture)", fillcolor="#8B0000", shape=diamond];
        Hypertension [label="Hypertension\n(RAAS activated)", fillcolor="#FF4500"];
        CKD_progression [label="CKD Progression\n(stage 1→5)", fillcolor="#8B0000", shape=diamond];
        Infection_risk [label="Infection Risk\n(immunosupp.)", fillcolor="#FF8C00"];
        Spontaneous_remission [label="Spontaneous\nRemission\n(~30% at 5yr)", fillcolor="#228B22"];
    }

    /* ============================================================
       CLUSTER 13: Biomarkers
    ============================================================ */
    subgraph cluster_biomarkers {
        label="Biomarkers (Monitoring & Surrogate Endpoints)";
        style=filled;
        fillcolor="#E0FFFF";
        color="#008B8B";
        fontsize=11;
        fontname="Helvetica Bold";

        antiPLA2R1_titer [label="anti-PLA2R1 Ab Titer\n(ELISA, RU/mL)\n[key surrogate]", fillcolor="#00CED1", shape=diamond];
        antiTHSD7A_titer [label="anti-THSD7A Ab Titer\n(ELISA)", fillcolor="#00CED1", shape=ellipse];
        SerumC3  [label="Serum C3\n(g/L, complement\nconsumption)", fillcolor="#00CED1", shape=ellipse];
        SerumC4  [label="Serum C4\n(g/L, classical\npathway marker)", fillcolor="#00CED1", shape=ellipse];
        CD19_count [label="CD19+ Count\n(cells/μL)\n[B cell depletion\nmonitor]", fillcolor="#00CED1", shape=diamond];
        CD20_count [label="CD20+ Count\n(cells/μL)", fillcolor="#00CED1", shape=ellipse];
        uPCR    [label="uPCR\n(Urine Protein:\nCreatinine Ratio\nmg/mg)", fillcolor="#00CED1", shape=diamond];
        Serum_IgG4 [label="Serum IgG4\n(mg/dL)\n[disease activity]", fillcolor="#00CED1", shape=ellipse];
        Serum_IgG [label="Serum IgG\n(total, mg/dL)", fillcolor="#00CED1", shape=ellipse];
        FactorH_serum [label="Factor H\n(serum level\ncomplement reg.)", fillcolor="#00CED1", shape=ellipse];
        sC5b9_serum [label="sC5b9 (urine)\n(MAC biomarker\ncomplement activ.)", fillcolor="#00CED1", shape=diamond];
        Serum_LDL [label="Serum LDL\n(mg/dL)\n[secondary endpoint]", fillcolor="#00CED1", shape=ellipse];
        Fibrinogen [label="Fibrinogen\n(mg/dL)\n[coagulation\nhyperactivation]", fillcolor="#00CED1", shape=ellipse];
        BUN     [label="BUN\n(blood urea\nnitrogen)", fillcolor="#00CED1", shape=ellipse];
        Cystatin_C [label="Cystatin C\n(GFR marker)", fillcolor="#00CED1", shape=ellipse];
    }

    /* ============================================================
       INTRA-CLUSTER & INTER-CLUSTER EDGES
    ============================================================ */

    /* --- Antigen cluster internal --- */
    PLA2R1 -> Antigen_proc [color=blue, label="shed/processed"];
    THSD7A -> Antigen_proc [color=blue];
    NELL1 -> Antigen_proc [color=blue];
    EXT1 -> Antigen_proc [color=blue];
    EXT2 -> Antigen_proc [color=blue];
    Antigen_proc -> APC [color=blue];
    APC -> MHC_II [color=blue, label="peptide:MHC-II"];
    APC -> CD80_86 [color=blue];
    APC -> IL12_APC [color=blue];

    /* --- Antigen → T cell activation --- */
    MHC_II -> TCR [color=blue, label="TCR engagement", style=bold];
    CD80_86 -> CTLA4 [color=red, label="inhibitory signal"];
    CD80_86 -> ICOS [color=blue, label="co-stimulation"];
    TCR -> CD4_Th [color=blue, style=bold];
    IL12_APC -> Th2_diff [color=red, label="Th1 bias\n(MN is Th2)", style=dashed];

    /* --- T cell internal --- */
    CD4_Th -> Tfh [color=blue, label="follicular\nmigration"];
    CD4_Th -> Th2_diff [color=blue];
    Th2_diff -> IL4 [color=blue];
    Th2_diff -> IL13 [color=blue];
    Th2_diff -> IL5 [color=blue];
    Th2_diff -> STAT6 [color=blue];
    STAT6 -> GATA3 [color=blue];
    GATA3 -> IL4 [color=blue];
    Tfh -> IL21 [color=blue];
    Tfh -> IL4 [color=blue];
    Tfh -> CD40L [color=blue];
    Tfh -> ICOS [color=blue];
    ICOS -> ICOSL [color=blue, dir=both, label="bidirectional\nco-stim"];
    CD4_Th -> IL10_T [color=blue];
    CD4_Th -> CD40L [color=blue];
    Treg -> CTLA4 [color=blue];
    Treg -> TGFb_T [color=blue];
    Treg -> IL10_T [color=blue];
    TGFb_T -> CD4_Th [color=red, label="suppression"];
    PD1 -> CD4_Th [color=red, label="T cell inhibition"];
    PDL1 -> PD1 [color=red];

    /* --- T cell → B cell help --- */
    IL4 -> IgG4_switch [color=blue, label="IgG4 isotype\nswitch driver", style=bold];
    IL13 -> IgG4_switch [color=blue, label="IgG4 isotype\nswitch"];
    IL21 -> GCB [color=blue, label="GC reaction"];
    IL21 -> PlasmaCell [color=blue, label="differentiation"];
    CD40L -> CD40_B [color=blue, label="T-B interaction", style=bold];

    /* --- B cell internal --- */
    BCR -> NaiveB [color=blue, label="antigen recognition"];
    NaiveB -> GCB [color=blue, label="GC entry"];
    GCB -> AID [color=blue];
    AID -> IgG4_switch [color=blue];
    AID -> IgG1_switch [color=blue];
    GCB -> MemoryB [color=blue, label="memory\nformation"];
    GCB -> PlasmaCell [color=blue, label="PC\ndifferentiation"];
    BAFF -> NaiveB [color=blue, label="survival"];
    BAFF -> GCB [color=blue, label="survival"];
    APRIL -> PlasmaCell [color=blue, label="long-lived PC\nsurvival"];
    CD40_B -> GCB [color=blue, label="GC entry\nsurvival"];
    BTK -> BCR [color=blue, label="downstream\nsignaling"];
    BCR -> PI3K_AKT [color=blue];
    PI3K_AKT -> NaiveB [color=blue, label="survival"];
    BLIMP1 -> PlasmaCell [color=blue, label="PC commitment TF"];
    IgG4_switch -> anti_PLA2R1_IgG4 [color=blue, style=bold, label="PLA2R1-specific"];
    IgG4_switch -> anti_THSD7A_IgG4 [color=blue];
    IgG1_switch -> anti_PLA2R1_IgG1 [color=blue];
    CD20_B -> NaiveB [color=gray, label="expressed on\nnaive/GC B cells"];
    CD20_B -> GCB [color=gray];
    PlasmaCell -> anti_PLA2R1_IgG4 [color=blue, label="secretion", style=bold];
    PlasmaCell -> anti_PLA2R1_IgG1 [color=blue, label="secretion"];

    /* --- Antibodies → GBM deposits --- */
    anti_PLA2R1_IgG4 -> Subep_deposits [color=blue, label="subepithelial\ndeposition", style=bold];
    anti_PLA2R1_IgG1 -> Subep_deposits [color=blue];
    anti_THSD7A_IgG4 -> Subep_deposits [color=blue];
    Subep_deposits -> C1q [color=blue, label="IgG1/IgM→\nClassical", style=dashed];

    /* --- Complement classical pathway --- */
    C1q -> C1r [color=blue, label="activation"];
    C1r -> C1s [color=blue];
    C1s -> C4 [color=blue, label="cleavage"];
    C1s -> C2 [color=blue, label="cleavage"];
    C4 -> C3_conv_classic [color=blue];
    C2 -> C3_conv_classic [color=blue];
    C1inh -> C1r [color=red, label="inhibition"];
    C1inh -> C1s [color=red, label="inhibition"];

    /* --- MBL/Lectin pathway --- */
    MBL -> MASP1 [color=blue];
    MBL -> MASP2 [color=blue];
    MASP2 -> C4 [color=blue, label="cleavage"];
    MASP2 -> C2 [color=blue, label="cleavage"];
    MASP1 -> C3_conv_classic [color=blue];

    /* --- Complement effector --- */
    C3_conv_classic -> C3b [color=blue, label="C3 cleavage", style=bold];
    C3b -> FactorB [color=blue, label="alternative\npathway\namplification"];
    FactorD -> FactorB [color=blue, label="Bb formation"];
    FactorB -> C3_conv_alt [color=blue];
    C3b -> C3_conv_alt [color=blue];
    Properdin -> C3_conv_alt [color=blue, label="stabilization"];
    C3_conv_alt -> C3b [color=blue, label="amplification loop", style=bold];
    C3_conv_classic -> C5_conv [color=blue];
    C3_conv_alt -> C5_conv [color=blue];
    C3b -> C5_conv [color=blue];
    C5_conv -> C5a [color=blue, label="C5 cleavage", style=bold];
    C5_conv -> C5b [color=blue];
    C5b -> C6 [color=blue];
    C6 -> C7 [color=blue];
    C7 -> C8 [color=blue];
    C8 -> C9 [color=blue];
    C9 -> C5b9_MAC [color=blue, label="polymerization", style=bold];
    C5b9_MAC -> sC5b9 [color=gray, label="soluble form\nbiomarker"];
    FactorH -> C3b [color=red, label="factor I\ncofactor\n(inactivation)"];
    FactorH -> C3_conv_alt [color=red, label="decay\nacceleration"];
    FI -> C3b [color=red, label="cleavage"];
    C4BP -> C4 [color=red, label="regulation"];
    CD59 -> C5b9_MAC [color=red, label="MAC\ninhibition", style=bold];

    /* --- Complement → Podocyte injury --- */
    C5a -> C5aR1 [color=blue, label="binding", style=bold];
    C5aR1 -> Podocyte_apoptosis [color=red, label="apoptosis\nsignaling"];
    C5aR1 -> ROS [color=red, label="NADPH ox.\nactivation"];
    C5aR1 -> Nox_NADPH [color=red];
    C5b9_MAC -> ROS [color=red, label="oxidative\nburst", style=bold];
    C5b9_MAC -> SlitDiaphragm [color=red, label="disruption", style=bold];
    C5b9_MAC -> Podocyte_apoptosis [color=red, label="pore formation"];
    C5b9_MAC -> Caspase3 [color=red];
    Nox_NADPH -> ROS [color=blue];

    /* --- Podocyte internal --- */
    ROS -> SlitDiaphragm [color=red, label="oxidative\ndamage"];
    ROS -> Nephrin [color=red, label="tyrosine\noxidation"];
    ROS -> Podocin [color=red];
    ROS -> Actin_cyto [color=red, label="cytoskeletal\nremodeling"];
    SlitDiaphragm -> Nephrin [color=blue];
    SlitDiaphragm -> Podocin [color=blue];
    SlitDiaphragm -> CD2AP [color=blue];
    Nephrin -> Actin_cyto [color=blue, label="signaling"];
    Podocin -> Actin_cyto [color=blue];
    Synaptopodin -> Actin_cyto [color=blue, label="F-actin\nstabilization"];
    WT1 -> Nephrin [color=blue, label="transcription"];
    WT1 -> Synaptopodin [color=blue];
    WT1 -> Podocyte_apoptosis [color=red, label="anti-apoptotic"];
    Caspase3 -> Podocyte_apoptosis [color=blue];
    Podocyte_apoptosis -> Podocyte_detach [color=blue, label="podocyturia"];
    Podocyte_detach -> Podocyte_loss [color=blue, style=bold];
    Podocyte_loss -> FootProcess [color=red, label="effacement"];
    Actin_cyto -> FootProcess [color=red, label="foot process\neffacement"];
    mTOR_pod -> Podocyte_apoptosis [color=red, label="survival\npathway"];
    VEGF_pod -> FootProcess [color=blue, label="maintenance"];

    /* --- Podocyte → GBM --- */
    FootProcess -> SlitDiaphragm [color=blue, dir=both];
    Subep_deposits -> GBM_thickening [color=blue, label="progressive\ndeposition", style=bold];
    GBM_thickening -> Spike_formation [color=blue, label="GBM\ngrowth\naround\ndeposits"];
    Spike_formation -> SubEp_area [color=blue];
    GBM_thickening -> Tuft_area [color=red, label="tuft\ncompression"];
    MMP2 -> GBM_thickening [color=blue, label="remodeling"];
    MMP9 -> GBM_thickening [color=blue];
    TIMP -> MMP2 [color=red, label="inhibition"];
    TIMP -> MMP9 [color=red];

    /* --- Podocyte → Proteinuria --- */
    FootProcess -> Proteinuria_24h [color=blue, label="barrier loss\n→ protein leak", style=bold];
    SlitDiaphragm -> Proteinuria_24h [color=blue, label="permselectivity\nloss"];

    /* --- GBM → Outcomes --- */
    GBM_thickening -> eGFR [color=red, label="filtration\nimpairment"];
    Tuft_area -> eGFR [color=red, label="surface area\nreduction"];

    /* --- Tubule --- */
    Proteinuria_24h -> Megalin [color=blue, label="excess\nprotein load"];
    Megalin -> Albumin_reab [color=blue];
    Cubilin -> Albumin_reab [color=blue];
    Albumin_reab -> Lipid_droplets [color=blue, label="FA-bound albumin\nuptake"];
    Lipid_droplets -> Tubular_injury [color=blue, label="lipotoxicity"];
    Tubular_injury -> NGAL [color=blue, label="biomarker\nrelease"];
    Tubular_injury -> KIM1 [color=blue];
    Tubular_injury -> NAG [color=blue];
    Tubular_injury -> Tubular_fibrosis [color=blue, label="progressive"];
    TGFb_tub -> Tubular_fibrosis [color=blue, label="fibrosis\ndriver"];
    Tubular_injury -> TGFb_tub [color=blue];
    Tubular_fibrosis -> eGFR [color=red, label="tubulointerstitial\ndamage"];

    /* --- Proteinuria → Outcomes --- */
    Proteinuria_24h -> Serum_albumin [color=red, label="protein loss\n→ hypoalbuminemia", style=bold];
    Proteinuria_24h -> uPCR [color=blue, label="monitoring\nsurrogate"];
    Proteinuria_24h -> Edema [color=blue, label="oncotic P↓"];
    Proteinuria_24h -> Hyperlipidemia [color=blue, label="liver lipoprotein\ncompensation"];
    Proteinuria_24h -> Thrombosis_risk [color=blue, label="loss of\nantithrombin III"];
    Proteinuria_24h -> Nephrotic_syndrome [color=blue, style=bold];
    Serum_albumin -> Nephrotic_syndrome [color=blue];
    Serum_albumin -> Edema [color=red, label="oncotic\npressure↓"];
    Hyperlipidemia -> Thrombosis_risk [color=blue];
    Hyperlipidemia -> Serum_LDL [color=blue, label="LDL↑"];
    Thrombosis_risk -> Fibrinogen [color=blue, label="hypercoag.\nstate"];
    eGFR -> Serum_creatinine [color=red, label="inverse\nrelationship"];
    eGFR -> ESRD_risk [color=red, label="progressive\ndecline"];
    Serum_creatinine -> BUN [color=blue];
    eGFR -> CKD_progression [color=red, style=bold];
    Nephrotic_syndrome -> ESRD_risk [color=red, label="risk factor"];
    Proteinuria_24h -> CR_complete [color=blue, label="<0.3g/d"];
    Proteinuria_24h -> PR_partial [color=blue, label="0.3-3.5g/d"];
    Proteinuria_24h -> Hypertension [color=blue, label="RAAS activation"];

    /* --- RAAS system --- */
    Renin -> Angiotensinogen [color=blue, label="cleavage"];
    Angiotensinogen -> AngI [color=blue];
    ACE -> AngI [color=blue, label="conversion"];
    AngI -> AngII [color=blue];
    AngII -> AT1R [color=blue, label="binding"];
    AngII -> AT2R [color=blue];
    AT1R -> Efferent_art [color=blue, label="efferent\nvasoconstriction"];
    AT1R -> Aldosterone [color=blue, label="adrenal\nstimulation"];
    AT1R -> Na_retention [color=blue];
    Aldosterone -> MR [color=blue];
    MR -> Na_retention [color=blue];
    Na_retention -> Edema [color=blue, label="volume\nexpansion"];
    Na_retention -> Hypertension [color=blue];
    Sympathetic_efferent -> Na_retention [color=blue];
    Efferent_art -> GFR_autoregulation [color=blue, label="efferent tone\n→ GFR maintained"];
    GFR_autoregulation -> eGFR [color=blue];
    ACE -> Bradykinin [color=red, label="degradation"];
    Bradykinin -> NO_vascular [color=blue, label="vasodil.\nNO release"];
    AT2R -> NO_vascular [color=blue, label="protective"];
    Hypertension -> eGFR [color=red, label="hypertensive\nnephropathy"];
    Serum_albumin -> Renin [color=blue, label="hypoalbuminemia\n→ RAAS activation"];

    /* --- RAAS → Outcomes --- */
    Efferent_art -> GlomP_reduce [color=red, label="ACEi/ARB\neffect\n(reduce)"];

    /* --- Rituximab PK --- */
    RTX_dose -> RTX_central [color=orange, label="IV infusion"];
    RTX_central -> RTX_peripheral [color=orange, label="distribution\nQ ~ 0.09 L/h"];
    RTX_peripheral -> RTX_central [color=orange];
    RTX_central -> RTX_TMDD [color=orange, label="CD20\nmediated\nuptake"];
    RTX_TMDD -> CD20_RTX_complex [color=orange];
    CD20_RTX_complex -> RTX_clearance [color=orange, label="internalization\n+ degradation"];
    RTX_central -> FcRn_recycling [color=orange];
    FcRn_recycling -> RTX_halflife [color=orange];
    RTX_central -> RTX_Cmax [color=orange];
    RTX_central -> RTX_clearance [color=orange, label="linear CL"];

    /* --- Immunosuppressant PK --- */
    TAC_dose -> TAC_GI [color=orange, label="oral\nabsorption"];
    TAC_GI -> TAC_blood [color=orange, label="F~25%"];
    TAC_blood -> TAC_CYP3A4 [color=orange, label="metabolism"];
    TAC_blood -> TAC_peripheral [color=orange, label="distribution"];
    TAC_peripheral -> TAC_blood [color=orange];
    CsA_dose -> CsA_central [color=orange];
    CPx_dose -> CPx_central [color=orange];
    CPx_central -> CPx_4OH [color=orange, label="CYP2B6/3A4\nactivation"];
    CPx_4OH -> CPx_acrolein [color=orange, label="bladder\ntoxin"];
    MMF_dose -> MMF_MPA [color=orange, label="hydrolysis"];
    MMF_MPA -> MPAG [color=orange, label="UGT\nglucuronidation"];

    /* --- Drug PD: RTX → B cells --- */
    RTX_central -> CD20_occupancy [color=red, label="CD20\nengagement", style=bold];
    CD20_occupancy -> Bcell_depletion [color=red, label="ADCC/CDC/\napoptosis", style=bold];
    Bcell_depletion -> NaiveB [color=red, label="depletion"];
    Bcell_depletion -> GCB [color=red, label="depletion"];
    Bcell_depletion -> CD19_count [color=red, label="CD19↓"];
    Bcell_depletion -> CD20_count [color=red, label="CD20↓"];
    Bcell_depletion -> Bcell_reconstitution [color=blue, label="recovery\n6-12m", style=dashed];
    Bcell_reconstitution -> NaiveB [color=blue, label="new naive B cells"];
    Bcell_depletion -> anti_PLA2R1_IgG4 [color=red, label="Ab production↓"];
    Obinutuzumab -> CD20_B [color=red, label="type II anti-CD20\nhigher efficacy"];

    /* --- Tacrolimus/CsA PD --- */
    TAC_blood -> Calcineurin_inh [color=red, label="FK506:FKBP12\ncalcineurin", style=bold];
    CsA_central -> Calcineurin_inh [color=red, label="CsA:cyclophilin\ncalcineurin"];
    Calcineurin_inh -> NFAT_block [color=red, style=bold];
    NFAT_block -> IL2_suppress [color=red];
    IL2_suppress -> CD4_Th [color=red, label="T cell\nproliferation↓"];
    Calcineurin_inh -> Podocin [color=blue, label="direct podocyte\nprotection"];
    Calcineurin_inh -> Actin_cyto [color=blue, label="synaptopodin\nstabilization"];

    /* --- Cyclophosphamide PD --- */
    CPx_4OH -> GCB [color=red, label="alkylation\nDNA damage"];
    CPx_4OH -> PlasmaCell [color=red, label="plasma cell\nkilling"];
    CPx_4OH -> CD4_Th [color=red, label="T cell\nsuppression"];

    /* --- MMF PD --- */
    MMF_MPA -> IMPDH_inh [color=red, style=bold];
    IMPDH_inh -> Purine_synth_block [color=red];
    Purine_synth_block -> GCB [color=red, label="lymphocyte\nproliferation↓"];
    Purine_synth_block -> CD4_Th [color=red, label="T cell\nproliferation↓"];

    /* --- ACEi/ARB PD --- */
    ACE_inh -> ACE [color=red, label="ACE inhibition", style=bold];
    ACE_inh -> AngII_reduce [color=red];
    AngII_reduce -> AT1R [color=red, label="AngII↓\n→ AT1R\nless activated"];
    ARB -> AT1R_block [color=red, label="competitive\nblockade", style=bold];
    AT1R_block -> Efferent_dilate [color=blue, label="efferent\nvasodilation"];
    AngII_reduce -> Efferent_dilate [color=blue];
    Efferent_dilate -> GlomP_reduce [color=blue, style=bold];
    GlomP_reduce -> Proteinuria_red [color=blue, style=bold];
    Proteinuria_red -> Proteinuria_24h [color=red, label="antiproteinuric\neffect"];

    /* --- ACTH --- */
    ACTH_drug -> Cortisol_up [color=blue, label="adrenal\nstimulation"];
    Cortisol_up -> GR_activation [color=blue];
    GR_activation -> NF_kB_suppress [color=red];
    NF_kB_suppress -> IL4 [color=red, label="cytokine\nsuppression"];
    NF_kB_suppress -> IL13 [color=red];
    NF_kB_suppress -> ROS [color=red, label="oxidative\nburst↓"];
    GR_activation -> CD20_B [color=red, label="steroid\neffect\non B cells"];

    /* --- Belimumab --- */
    Belimumab -> BAFF [color=red, label="BAFF blockade", style=bold];

    /* --- Avacopan --- */
    Avacopan -> C5aR1 [color=red, label="C5aR1\nblockade", style=bold];

    /* --- Sparsentan --- */
    Sparsentan -> AT1R_block [color=red, label="AT1R block"];
    Sparsentan -> Efferent_dilate [color=blue];

    /* --- Biomarker connections --- */
    anti_PLA2R1_IgG4 -> antiPLA2R1_titer [color=gray, label="measured\nin serum"];
    anti_THSD7A_IgG4 -> antiTHSD7A_titer [color=gray];
    antiPLA2R1_titer -> Proteinuria_24h [color=blue, label="predicts\nactivity", style=dashed];
    antiPLA2R1_titer -> CR_complete [color=blue, label="Ab↓ predicts\nremission", style=dashed];
    SerumC3 -> C3b [color=gray, label="consumption\nmarker"];
    SerumC4 -> C4 [color=gray, label="consumption\nmarker"];
    C3_conv_classic -> SerumC3 [color=red, label="C3 depletion"];
    C4 -> SerumC4 [color=red, label="C4 depletion"];
    NaiveB -> CD19_count [color=blue, label="CD19+ cells"];
    GCB -> CD19_count [color=blue];
    NaiveB -> CD20_count [color=blue];
    GCB -> CD20_count [color=blue];
    Proteinuria_24h -> uPCR [color=blue];
    PlasmaCell -> Serum_IgG4 [color=blue, label="IgG4\nsecretion"];
    PlasmaCell -> Serum_IgG [color=blue];
    FactorH -> FactorH_serum [color=gray];
    sC5b9 -> sC5b9_serum [color=gray, label="urinary\nmarker"];
    Hyperlipidemia -> Serum_LDL [color=blue];
    Thrombosis_risk -> Fibrinogen [color=blue];
    Serum_creatinine -> BUN [color=blue];
    eGFR -> Cystatin_C [color=blue, label="inverse"];

    /* --- Disease Activity → Spontaneous Remission --- */
    antiPLA2R1_titer -> Spontaneous_remission [color=blue, label="Ab clearance\n→ remission", style=dashed];
    Spontaneous_remission -> Proteinuria_24h [color=red, label="protein↓", style=dashed];
}
