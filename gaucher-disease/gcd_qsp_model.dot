digraph GaucherDiseaseQSP {
    graph [
        label="Gaucher Disease — Quantitative Systems Pharmacology Map\nGlucocerebrosidase (GBA) Deficiency · Lysosomal Storage · Systemic Manifestations · Drug PK/PD"
        labelloc=t fontsize=22 fontname="Helvetica-Bold"
        rankdir=LR bgcolor="#FAFAF8"
        splines=ortho nodesep=0.4 ranksep=0.7
    ]
    node [fontname="Helvetica" fontsize=10 style="filled,rounded" shape=box]
    edge [fontname="Helvetica" fontsize=9]

    /* =====================================================================
       CLUSTER 1: DRUG ADMINISTRATION & PK
       ===================================================================== */
    subgraph cluster_pk {
        label="Drug PK / Pharmacokinetics" style=filled fillcolor="#E8F4FD"
        fontsize=14 fontname="Helvetica-Bold" color="#2980B9"

        /* ERT */
        node [fillcolor="#AED6F1"]
        IMIG_DOSE [label="Imiglucerase\n60 U/kg IV Q2W" shape=parallelogram]
        VELA_DOSE [label="Velaglucerase α\n60 U/kg IV Q2W" shape=parallelogram]
        TALI_DOSE [label="Taliglucerase α\n60 U/kg IV Q2W" shape=parallelogram]
        IMIG_C    [label="Imiglucerase\nPlasma (C_imig)\nCL=1.4 L/h/kg"]
        IMIG_T    [label="Imiglucerase\nTissue"]
        VELA_C    [label="Velaglucerase α\nPlasma"]
        TALI_C    [label="Taliglucerase α\nPlasma"]

        /* SRT oral */
        node [fillcolor="#D5EEF8"]
        MIGS_GUT  [label="Miglustat\nGut (ka=0.6/h)"]
        MIGS_C    [label="Miglustat\nPlasma\nF=97%, t½=6h"]
        ELIS_GUT  [label="Eliglustat\nGut (ka=0.8/h)"]
        ELIS_C    [label="Eliglustat\nPlasma\nF~20%(EM), t½=4h"]
        VENG_GUT  [label="Venglustat\nGut (ka=0.5/h)"]
        VENG_C    [label="Venglustat\nPlasma (CNS-penetrant)"]
        VENG_CNS  [label="Venglustat\nCNS / Brain"]
    }

    /* =====================================================================
       CLUSTER 2: LYSOSOMAL ENZYME BIOLOGY
       ===================================================================== */
    subgraph cluster_enzyme {
        label="Lysosomal GBA Enzyme Biology" style=filled fillcolor="#FEF9E7"
        fontsize=14 fontname="Helvetica-Bold" color="#D4AC0D"

        node [fillcolor="#FCF3CF"]
        GBA_GENE   [label="GBA1 Gene\n(chromosome 1q22)" shape=diamond]
        GBA_mRNA   [label="GBA1 mRNA\nTranscript"]
        GBA_PRE    [label="Pre-pro-GBA\n(ER synthesis)"]
        GBA_GLYC   [label="Glycosylated GBA\n(N-linked, ER/Golgi)"]
        M6PR_BIND  [label="M6P Receptor\nBinding (Golgi→Lysosome)" shape=diamond]
        GBA_LYS    [label="Lysosomal GBA\n(active enzyme)"]
        GBA_MUT    [label="Mutant GBA\n(N370S, L444P, etc.)\nMisfolded/Unstable" fillcolor="#F9E79F"]
        UGGT_ER    [label="ER Quality Control\n(UGGT, Calnexin/Calreticulin)"]
        ERAD       [label="ERAD Pathway\n(proteasomal deg.)" fillcolor="#FDEBD0"]

        /* ERT uptake */
        M6PR_ERT   [label="M6P Receptor\nMediated ERT Uptake\n(macrophage/hepatocyte)"]
        GBA_ERT    [label="Exogenous GBA\n(from ERT in lysosome)"]

        /* Chaperone */
        CHAP_SMALL [label="Pharmacological\nChaperone (PC)\nAmbroxol (off-label)" fillcolor="#FDEBD0"]
        GBA_CHAP   [label="PC-stabilised\nGBA (WT/variant)"]
    }

    /* =====================================================================
       CLUSTER 3: SUBSTRATE ACCUMULATION
       ===================================================================== */
    subgraph cluster_substrate {
        label="Glucosphingolipid Substrate Accumulation" style=filled fillcolor="#FDEDEC"
        fontsize=14 fontname="Helvetica-Bold" color="#C0392B"

        node [fillcolor="#FADBD8"]
        GLC_SYN    [label="Glucosylceramide\nSynthase (GCS)\nUGCG gene"]
        GC_MAC     [label="GlucoCeramide (GC)\nMacrophage Lysosome\n↑↑ Gaucher Cell"]
        GC_LIVER   [label="GC — Liver\n(Kupffer cells)"]
        GC_SPLEEN  [label="GC — Spleen\n(resident macrophages)"]
        GC_BONE    [label="GC — Bone Marrow\n(infiltrating macrophages)"]
        GC_CNS     [label="GC — CNS\n(microglia) [Type 2/3]"]
        LYSO_GC    [label="Lyso-GlucoCeramide\n(lyso-GL1)\n[Biomarker]"]
        GL1_PLASMA [label="Plasma GL-1 / lyso-GL1\n[Primary PD Biomarker]"]
        GLUCOSPH   [label="Glucosylsphingosine\n(psychosine-like)\nNeurotoxic [Type 2/3]"]
        SPHING     [label="Sphingomyelin\nCeramide Pathway\nDisruption"]
        GBA2_ENZ   [label="Non-lysosomal GBA2\n(cytosolic, GC→Cer)"]
    }

    /* =====================================================================
       CLUSTER 4: GAUCHER CELL FORMATION & MACROPHAGE BIOLOGY
       ===================================================================== */
    subgraph cluster_gaucher_cell {
        label="Gaucher Cell Formation & Macrophage Dysfunction" style=filled fillcolor="#F5EEF8"
        fontsize=14 fontname="Helvetica-Bold" color="#7D3C98"

        node [fillcolor="#E8DAEF"]
        MAC_NAIVE  [label="Naive Monocyte\n(bone marrow)"]
        MAC_CIRC   [label="Circulating Monocyte\nM-CSF, CCL2"]
        MAC_TISSUE [label="Tissue Macrophage\n(liver/spleen/bone)"]
        GAUCHER_C  [label="Gaucher Cell\n(lipid-laden macrophage)\nWrainkled tissue paper"]
        GC_ENGULF  [label="GC Engulfment\n(incomplete digestion)"]
        NPC1L1_UP  [label="NPC1L1 upregulation\nCholesterol dysregulation"]
        INFLAM_MAC [label="Inflammatory\nActivation\nNF-κB ↑"]
        MTOR_PATH  [label="mTOR Pathway\nActivation"]
        AUTOPHAGY  [label="Autophagy\nImpairment"]
        TGF_MAC    [label="TGF-β secretion\n(fibrogenic signal)"]
        M2_POLAR   [label="M2 Polarization\n(anti-inflam/fibrotic)"]
    }

    /* =====================================================================
       CLUSTER 5: CYTOKINE / INFLAMMATION
       ===================================================================== */
    subgraph cluster_cytokine {
        label="Cytokine & Inflammatory Signalling" style=filled fillcolor="#E8F8F5"
        fontsize=14 fontname="Helvetica-Bold" color="#1E8449"

        node [fillcolor="#A9DFBF"]
        IL1B   [label="IL-1β\n(NLRP3 inflammasome)"]
        IL6    [label="IL-6\n(↑↑ active Gaucher)"]
        TNF    [label="TNF-α\n(macrophage)"]
        IL10   [label="IL-10\n(anti-inflam)"]
        IL12   [label="IL-12\n(Th1 skewing)"]
        MIP1A  [label="MIP-1α (CCL3)\nosteoclast activating"]
        RANK_L [label="RANKL\n(bone resorption ↑)"]
        OPG    [label="OPG\n(bone resorption ↓)"]
        CXCL10 [label="CXCL10 / IP-10\n(T-cell chemoattractant)"]
        CHITR  [label="Chitotriosidase\n(macrophage activation marker)"]
        CCL18  [label="CCL18 / PARC\n(fibrosis/macrophage)"]
        FERRIT [label="Serum Ferritin\n↑ (inflammation marker)"]
        ANGPT2 [label="Angiopoietin-2\n(vascular remodeling)"]
    }

    /* =====================================================================
       CLUSTER 6: ORGAN MANIFESTATIONS
       ===================================================================== */
    subgraph cluster_organs {
        label="Organ Manifestations" style=filled fillcolor="#FEF5E7"
        fontsize=14 fontname="Helvetica-Bold" color="#CA6F1E"

        node [fillcolor="#FAD7A0"]
        /* Spleen */
        SPLENOMEG [label="Splenomegaly\nSV [mL]"]
        SPLENIC_GC [label="Splenic GC Burden\n[GC_spleen]"]
        HYPERSPLEN [label="Hypersplenism\n(sequestration↑)"]

        /* Liver */
        HEPATOMEG [label="Hepatomegaly\nLV [×normal]"]
        LIVER_GC  [label="Hepatic GC Burden\n[GC_liver]"]
        FIBROSIS_L[label="Hepatic Fibrosis\nFibrosis Score"]
        ALT_AST   [label="ALT/AST\n(hepatocyte damage)"]

        /* Bone */
        BONE_MARR [label="Bone Marrow\nInfiltration [%]"]
        ERLICH_CR [label="Erlenmayer Flask\nDeformity"]
        BMD       [label="Bone Mineral Density\n(DXA T-score)"]
        OSTEONECROSIS [label="Avascular Necrosis\n/ Osteonecrosis"]
        BONE_PAIN [label="Bone Pain / Crisis\n(VAS)"]
        OSTEOPOR  [label="Osteoporosis/Osteopenia\nFracture Risk"]

        /* Blood */
        ANEMIA    [label="Anemia\nHemoglobin [g/dL]"]
        THROMBO   [label="Thrombocytopenia\nPlatelet [×10⁹/L]"]
        BLEEDING  [label="Bleeding Risk\nPlatelet <60 criterion"]

        /* Lung */
        PULM_HYPERT [label="Pulmonary Hypertension\n(rare complication)"]
        LUNG_INFILT [label="Lung Infiltration\n(interstitial)"]
    }

    /* =====================================================================
       CLUSTER 7: NEUROLOGICAL (TYPE 2/3)
       ===================================================================== */
    subgraph cluster_neuro {
        label="Neuronopathic Gaucher (Type 2 & 3)" style=filled fillcolor="#EBF5FB"
        fontsize=14 fontname="Helvetica-Bold" color="#1A5276"

        node [fillcolor="#AED6F1"]
        GBA_CNS_L  [label="CNS GBA Activity\n(low in Type 2/3)"]
        MICRO_ACTV [label="Microglial Activation\n(neuroinflammation)"]
        NEURO_DEG  [label="Neurodegeneration\n(cortex/cerebellum)"]
        NEURON_L   [label="Neuron Loss\n(Type 2: rapid)"]
        OCC_PALSY  [label="Oculomotor Apraxia\n(Type 3 hallmark)"]
        SEIZURE    [label="Seizures\n(Type 2/3)"]
        PSYCHOS    [label="Psychosis / Cognitive\nDecline (Type 3)"]
        PD_RISK    [label="Parkinson's Disease Risk\n↑5× (GBA heterozygous)"]
        ALPHA_SYN  [label="α-Synuclein\nAccumulation\n(GBA-PD link)"]
        LEWY_BODY  [label="Lewy Body Formation\n(GBA-PD)"]
    }

    /* =====================================================================
       CLUSTER 8: HEMATOPOIESIS
       ===================================================================== */
    subgraph cluster_heme {
        label="Hematopoiesis & Bone Marrow" style=filled fillcolor="#F9F9F9"
        fontsize=14 fontname="Helvetica-Bold" color="#616A6B"

        node [fillcolor="#D5D8DC"]
        HSC       [label="Hematopoietic\nStem Cell (HSC)"]
        ERYTHRO   [label="Erythropoiesis\n(BFU-E → RBC)"]
        MEGAK     [label="Megakaryopoiesis\n(→ Platelets)"]
        MYELO     [label="Myelopoiesis\n(→ Monocyte/Neutrophil)"]
        EPO       [label="EPO\n(erythropoietin)"]
        TPO       [label="TPO\n(thrombopoietin)"]
        BONE_MARR_COMP [label="Bone Marrow\nCompetition\n(GC burden displaces\nnormal hematopoiesis)"]
        OSTEO_B   [label="Osteoblast\n(bone formation)"]
        OSTEO_C   [label="Osteoclast\n(bone resorption)\nRANKL-driven"]
    }

    /* =====================================================================
       CLUSTER 9: PD EFFECT ENDPOINTS
       ===================================================================== */
    subgraph cluster_pd {
        label="PD Effect / Clinical Endpoints" style=filled fillcolor="#F0FFF0"
        fontsize=14 fontname="Helvetica-Bold" color="#186A3B"

        node [fillcolor="#82E0AA"]
        GL1_RED   [label="Plasma GL-1\nReduction [%]"]
        LYSOGL1_R [label="Lyso-GL1\nReduction [%]\n[Highly sensitive PD marker]"]
        CHITR_RED [label="Chitotriosidase\nNormalisation [U/L]"]
        HGB_RESP  [label="Hb Response\n≥1 g/dL increase"]
        PLT_RESP  [label="Platelet Response\n≥1.5× baseline"]
        SV_RESP   [label="Spleen Volume\nReduction ≥30%"]
        LV_RESP   [label="Liver Volume\nReduction ≥20%"]
        BMD_RESP  [label="BMD Improvement\n(T-score change)"]
        QoL       [label="Quality of Life\n(SF-36, Gaucher score)"]
        BONE_RESP [label="Bone Crisis\nFrequency Reduction"]
        PULM_RESP [label="Pulmonary\nImprovement (6MWT)"]
    }

    /* =====================================================================
       CLUSTER 10: DRUG PHARMACODYNAMICS
       ===================================================================== */
    subgraph cluster_drug_pd {
        label="Drug PD Mechanisms" style=filled fillcolor="#F4F6F7"
        fontsize=14 fontname="Helvetica-Bold" color="#34495E"

        node [fillcolor="#D7DBDD"]
        ERT_MECH  [label="ERT Mechanism\nM6P → endocytosis\n→ lysosome delivery"]
        ERT_GBA   [label="Restored GBA\nActivity in Macrophage\nEmax=85%, EC50=0.6 U/mL"]
        SRT_MECH  [label="SRT Mechanism\nGCS inhibition\n→ substrate ↓"]
        MIGS_GCS  [label="Miglustat\nGCS IC50=50 μM\n(non-selective)"]
        ELIS_GCS  [label="Eliglustat\nGCS IC50=10 nM\n(selective, CYP2D6)"]
        VENG_GCS2 [label="Venglustat\nGCS+GBA2 IC50\n(CNS penetrant, p-gp -)"]
        CHAP_MECH [label="Chaperone Mechanism\nAmbroxol binds active\nsite → stabilises GBA"]
        GENE_THER [label="Gene Therapy\n(in development)\nlentiviral GBA1"]
    }

    /* =====================================================================
       EDGES — Drug PK
       ===================================================================== */
    IMIG_DOSE -> IMIG_C [label="IV bolus\nk10=0.35/h" color="#2980B9"]
    VELA_DOSE -> VELA_C [label="IV infusion" color="#2980B9"]
    TALI_DOSE -> TALI_C [label="IV infusion" color="#2980B9"]
    IMIG_C -> IMIG_T [label="k12=0.18/h"]
    IMIG_T -> IMIG_C [label="k21=0.08/h"]
    MIGS_GUT -> MIGS_C [label="ka=0.6/h"]
    ELIS_GUT -> ELIS_C [label="ka=0.8/h\nCYP2D6"]
    VENG_GUT -> VENG_C [label="ka=0.5/h"]
    VENG_C -> VENG_CNS [label="CNS penetration\nKp_brain=0.3"]

    /* Drug → PD mechanism */
    IMIG_C -> M6PR_ERT [label="M6PR binding\nKd=6 nM" color="#D35400" style=bold]
    VELA_C -> M6PR_ERT [color="#D35400"]
    TALI_C -> M6PR_ERT [color="#D35400"]
    M6PR_ERT -> GBA_ERT [label="lysosomal\ndelivery"]
    GBA_ERT -> ERT_GBA [color="#27AE60" style=bold]
    ERT_GBA -> ERT_MECH

    MIGS_C -> MIGS_GCS [label="GCS inhibition\n(low selectivity)"]
    ELIS_C -> ELIS_GCS [label="GCS inhibition\n(high selectivity)"]
    VENG_C -> VENG_GCS2
    VENG_CNS -> VENG_GCS2 [label="CNS SRT effect"]
    CHAP_SMALL -> CHAP_MECH -> GBA_CHAP

    /* =====================================================================
       EDGES — Enzyme Biology
       ===================================================================== */
    GBA_GENE -> GBA_mRNA -> GBA_PRE -> GBA_GLYC
    GBA_GLYC -> UGGT_ER [label="folding check"]
    GBA_GLYC -> M6PR_BIND -> GBA_LYS
    GBA_MUT -> UGGT_ER [label="misfolded" color="#E74C3C"]
    UGGT_ER -> ERAD [label="irreparable\nmutant" color="#E74C3C"]
    GBA_CHAP -> GBA_LYS [label="rescued\nfrom ERAD" color="#27AE60"]

    /* GBA activity → substrate degradation */
    GBA_LYS -> GC_MAC [label="degrades GC\n(↓ accumulation)" color="#27AE60" dir=both arrowhead=tee arrowtail=normal]
    GBA_ERT -> GC_MAC [label="ERT\ndegrades GC" color="#27AE60"]

    /* =====================================================================
       EDGES — Substrate Accumulation
       ===================================================================== */
    GLC_SYN -> GC_MAC [label="synthesis" color="#E74C3C"]
    GC_MAC -> GC_LIVER  [label="trafficking"]
    GC_MAC -> GC_SPLEEN [label="trafficking"]
    GC_MAC -> GC_BONE   [label="trafficking"]
    GC_MAC -> GC_CNS    [label="CNS [Type 2/3]"]
    GC_MAC -> LYSO_GC   [label="partial hydrolysis"]
    LYSO_GC -> GL1_PLASMA [label="export\n→ biomarker"]
    GC_MAC -> GLUCOSPH  [label="alternative\npathway"]
    GBA2_ENZ -> GC_MAC  [dir=back label="non-lysosomal\nclearance"]

    /* SRT blocks synthesis */
    MIGS_GCS -> GLC_SYN [label="inhibit\n(Imax=80%)" color="#8E44AD" arrowhead=tee]
    ELIS_GCS -> GLC_SYN [label="inhibit\n(Imax=95%)" color="#8E44AD" arrowhead=tee]
    VENG_GCS2 -> GLC_SYN [label="inhibit (CNS+)" color="#8E44AD" arrowhead=tee]

    /* =====================================================================
       EDGES — Gaucher Cell Formation
       ===================================================================== */
    MAC_NAIVE -> MAC_CIRC [label="M-CSF\nCCL2 gradient"]
    MAC_CIRC -> MAC_TISSUE [label="tissue\nhoming"]
    MAC_TISSUE -> GC_ENGULF [label="phagocytosis"]
    GC_ENGULF -> GAUCHER_C [label="GC accumulation\n(incomplete digestion)"]
    GAUCHER_C -> INFLAM_MAC [label="NF-κB\nactivation"]
    GAUCHER_C -> NPC1L1_UP
    GAUCHER_C -> MTOR_PATH
    MTOR_PATH -> AUTOPHAGY [arrowhead=tee]
    GAUCHER_C -> TGF_MAC -> M2_POLAR

    /* =====================================================================
       EDGES — Cytokines
       ===================================================================== */
    INFLAM_MAC -> IL1B [label="NLRP3"]
    INFLAM_MAC -> IL6  [label="activation"]
    INFLAM_MAC -> TNF  [label="activation"]
    INFLAM_MAC -> MIP1A
    INFLAM_MAC -> CHITR [label="secretion ↑↑"]
    M2_POLAR -> IL10 [label="anti-inflam"]
    M2_POLAR -> CCL18
    IL1B -> IL6 [label="amplification"]
    IL12 -> CXCL10 [label="Th1 induction"]
    MIP1A -> RANK_L [label="osteoclast\nactivation"]
    RANK_L -> OSTEO_C [label="RANKL/RANK\nsignaling" color="#E74C3C"]
    OPG -> RANK_L [arrowhead=tee label="decoy\nreceptor"]
    GAUCHER_C -> FERRIT [label="↑ ferritin\n(inflammation)"]
    GAUCHER_C -> ANGPT2 [label="vascular\nactivation"]

    /* =====================================================================
       EDGES — Organ Manifestations
       ===================================================================== */
    GC_SPLEEN -> SPLENIC_GC -> SPLENOMEG [label="macrophage\ninfiltration"]
    SPLENOMEG -> HYPERSPLEN [label="sequestration"]
    HYPERSPLEN -> ANEMIA [label="hemolytic\ncomponent"]
    HYPERSPLEN -> THROMBO [label="platelet\nsequestration"]

    GC_LIVER -> LIVER_GC -> HEPATOMEG
    TGF_MAC -> FIBROSIS_L [label="stellate cell\nactivation"]
    HEPATOMEG -> ALT_AST [label="pressure/\ninfiltration"]

    GC_BONE -> BONE_MARR [label="macrophage\ninfiltration"]
    BONE_MARR -> BONE_MARR_COMP [label="displaces\nhematopoiesis"]
    BONE_MARR_COMP -> ERYTHRO [arrowhead=tee label="suppression"]
    BONE_MARR_COMP -> MEGAK [arrowhead=tee label="suppression"]
    BONE_MARR -> ERLICH_CR [label="cortical\nexpansion"]
    OSTEO_C -> BMD [arrowhead=tee label="resorption"]
    OSTEO_B -> BMD [label="formation"]
    RANK_L -> OSTEONECROSIS [label="ischaemia +\nosteoclast"]
    OSTEONECROSIS -> BONE_PAIN
    BMD -> OSTEOPOR [label="T-score ≤-2.5"]

    ERYTHRO -> ANEMIA [arrowhead=tee label="reduced\nproduction"]
    MEGAK -> THROMBO [arrowhead=tee label="reduced\nproduction"]
    THROMBO -> BLEEDING [label="<60×10⁹/L"]

    GC_CNS -> MICRO_ACTV
    GC_CNS -> GBA_CNS_L

    /* =====================================================================
       EDGES — Neurological
       ===================================================================== */
    GBA_CNS_L -> GLUCOSPH [label="accumulates"]
    GLUCOSPH -> NEURO_DEG [label="neurotoxic" color="#E74C3C"]
    MICRO_ACTV -> NEURO_DEG
    NEURO_DEG -> NEURON_L -> OCC_PALSY
    NEURO_DEG -> SEIZURE
    NEURON_L -> PSYCHOS
    GBA_MUT -> PD_RISK [label="heterozygous\nGBA mutation\n(GBA-PD)" color="#8E44AD" style=dashed]
    ALPHA_SYN -> LEWY_BODY
    GBA_LYS -> ALPHA_SYN [label="GBA↓ →\nα-syn↑" arrowhead=tee color="#8E44AD"]

    /* =====================================================================
       EDGES — Hematopoiesis
       ===================================================================== */
    HSC -> ERYTHRO
    HSC -> MEGAK
    HSC -> MYELO
    EPO -> ERYTHRO [label="stimulate"]
    TPO -> MEGAK [label="stimulate"]
    MYELO -> MAC_CIRC
    ERYTHRO -> ANEMIA [dir=back label="output"]
    MEGAK -> THROMBO [dir=back label="output"]

    /* =====================================================================
       EDGES — PD Endpoints (Treatment Effects)
       ===================================================================== */
    ERT_GBA -> GL1_RED [label="GC clearance\n→ GL-1↓" color="#27AE60" style=bold]
    ERT_GBA -> LYSOGL1_R [color="#27AE60"]
    ERT_GBA -> CHITR_RED [color="#27AE60"]
    ERT_GBA -> SV_RESP [label="Spleen Vol\nreduction"]
    ERT_GBA -> LV_RESP [label="Liver Vol\nreduction"]
    ERT_GBA -> HGB_RESP [label="Hb↑"]
    ERT_GBA -> PLT_RESP [label="Plt↑"]
    ERT_GBA -> BMD_RESP [label="bone\nimprovement"]

    GL1_RED -> QoL [label="functional\nimprovement"]
    SV_RESP -> QoL
    HGB_RESP -> QoL
    BONE_RESP -> QoL
    BMD_RESP -> BONE_RESP

    /* Pulmonary */
    GAUCHER_C -> PULM_HYPERT [label="vascular\ninfiltration"]
    GAUCHER_C -> LUNG_INFILT
    PULM_HYPERT -> PULM_RESP [label="treatment\nresponse"]

    /* SRT endpoints */
    MIGS_GCS -> GL1_RED [label="substrate\nreduction" color="#8E44AD"]
    ELIS_GCS -> GL1_RED [color="#8E44AD"]
    ELIS_GCS -> LYSOGL1_R [color="#8E44AD"]
    VENG_GCS2 -> GL1_RED [color="#8E44AD"]

    /* =====================================================================
       GLOBAL ANNOTATIONS
       ===================================================================== */
    LEGEND [shape=note style=filled fillcolor="#FFFDE7"
        label="Legend\n━━━━━━━━━━━━━━━━━━━━━━━━\nBlue: ERT (enzyme replacement)\nPurple: SRT (substrate reduction)\nGreen: Beneficial effect\nRed: Pathological process\nDashed: Indirect / GBA-PD link\n━━━━━━━━━━━━━━━━━━━━━━━━\nAbbreviations\nGBA: glucocerebrosidase\nGC: glucocerebroside\nGL-1: glucosylsphingosine\nM6P: mannose-6-phosphate\nSRT: substrate reduction therapy\nERT: enzyme replacement therapy\nPC: pharmacological chaperone"
    ]
}
