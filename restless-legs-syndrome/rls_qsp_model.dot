digraph RLS_QSP_Model {
  rankdir=LR;
  graph [fontname="Helvetica", fontsize=12, labelloc=t,
         label="Restless Legs Syndrome (Willis-Ekbom Disease) — Quantitative Systems Pharmacology Model\nBrain Iron · Dopamine · Adenosine · Opioid · Glutamate · α2δ · BTBD9/MEIS1 · Augmentation",
         splines=true, overlap=false, concentrate=true, nodesep=0.30, ranksep=0.55, bgcolor="#FBFCFE"];
  node  [fontname="Helvetica", fontsize=10, shape=box, style="rounded,filled", color="#1f2937", penwidth=1.1];
  edge  [fontname="Helvetica", fontsize=9, color="#4b5563", arrowsize=0.7];

  // ============================================================
  // 1. GENETIC SUSCEPTIBILITY
  // ============================================================
  subgraph cluster_genetics {
    label="1. Genetic Susceptibility (GWAS · ~22 risk loci)";
    style="rounded,filled"; fillcolor="#FEE2E2"; color="#B91C1C";
    BTBD9   [label="BTBD9\n(Chr 6p21)\nOR≈1.7 (rs9357271)", fillcolor="#FECACA"];
    MEIS1   [label="MEIS1\n(Chr 2p14)\nOR≈1.8 (rs2300478)", fillcolor="#FECACA"];
    MAP2K5  [label="MAP2K5/SKOR1\n(Chr 15q23)", fillcolor="#FECACA"];
    PTPRD   [label="PTPRD\n(Chr 9p23)", fillcolor="#FECACA"];
    TOX3    [label="TOX3/BC034767\n(Chr 16q12)", fillcolor="#FECACA"];
    MEIS1AS [label="MEIS1-AS3\n(antisense lncRNA)", fillcolor="#FECACA"];
    Familial [label="Family history\n(40-90% probands)", fillcolor="#FDE68A"];
    Heritability [label="Heritability ~70%\n(twin studies)", fillcolor="#FDE68A"];
  }

  // ============================================================
  // 2. IRON HOMEOSTASIS (SYSTEMIC & CNS)
  // ============================================================
  subgraph cluster_iron {
    label="2. Iron Homeostasis (Systemic + Brain)";
    style="rounded,filled"; fillcolor="#FFEDD5"; color="#9A3412";
    DietIron   [label="Dietary Fe²⁺ /Fe³⁺", fillcolor="#FED7AA"];
    DMT1_gut   [label="DMT1 (gut)", fillcolor="#FED7AA"];
    Ferroportin[label="Ferroportin\n(enterocyte basolateral)", fillcolor="#FED7AA"];
    Hepcidin   [label="Hepcidin (HAMP)\nliver master regulator", fillcolor="#FED7AA"];
    SerumFe    [label="Serum iron / TSAT", fillcolor="#FDBA74"];
    Ferritin   [label="Serum Ferritin\n(<75 µg/L = low)\n(<50 = deficient in RLS)", fillcolor="#FDBA74"];
    TfR_BBB    [label="TfR1 at BBB\n(brain capillary endothelium)", fillcolor="#FDBA74"];
    CSFFerritin[label="CSF Ferritin ↓\n(Earley 2000 Neurology)", fillcolor="#FB923C"];
    BrainFe    [label="Brain Iron Pool\n(SN · putamen · thalamus)\n↓ ~30% in RLS (Connor 2003)", fillcolor="#F97316"];
    IRP1_2     [label="IRP1/2 IRE binding\n(altered Fe sensing)", fillcolor="#FB923C"];
    DCYTB      [label="DCYTB / SLC11A2", fillcolor="#FED7AA"];
  }

  // ============================================================
  // 3. DOPAMINE SYSTEM (A11 → STRIATUM/SPINAL CORD)
  // ============================================================
  subgraph cluster_da {
    label="3. Dopaminergic System (A11 hypothalamic-spinal · nigrostriatal)";
    style="rounded,filled"; fillcolor="#DBEAFE"; color="#1E40AF";
    A11        [label="A11 neurons\n(diencephalic-spinal\ndopamine projection)", fillcolor="#BFDBFE"];
    SN_VTA     [label="Substantia nigra /\nVTA (DA cell bodies)", fillcolor="#BFDBFE"];
    TH         [label="Tyrosine Hydroxylase\n(rate-limit, Fe²⁺ cofactor)", fillcolor="#93C5FD"];
    DA_synth   [label="DA synthesis\n(↑ in RLS, paradox)", fillcolor="#93C5FD"];
    DA_release [label="Striatal DA release", fillcolor="#93C5FD"];
    D1R        [label="D1 receptor\n(direct pathway)", fillcolor="#60A5FA"];
    D2R        [label="D2 receptor\n(presynaptic + postsyn)", fillcolor="#60A5FA"];
    D3R        [label="D3 receptor\n(limbic, high affinity)", fillcolor="#60A5FA"];
    DAT        [label="DAT (SLC6A3)\nstriatal ↓ density\n(Earley 2011 SPECT)", fillcolor="#60A5FA"];
    SpinalDA   [label="Spinal DA tone\n(↓ overnight)", fillcolor="#60A5FA"];
    AADC       [label="Aromatic AA decarboxylase\n(DDC)", fillcolor="#93C5FD"];
    MAO_B      [label="MAO-B / COMT\n(DA degradation)", fillcolor="#93C5FD"];
  }

  // ============================================================
  // 4. ADENOSINE SYSTEM (FERRÉ HYPOTHESIS)
  // ============================================================
  subgraph cluster_adenosine {
    label="4. Adenosine System (Ferré 2018: A1↓ unleashes glutamate/dopamine)";
    style="rounded,filled"; fillcolor="#E0E7FF"; color="#3730A3";
    ATP_pool   [label="Extracellular ATP", fillcolor="#C7D2FE"];
    CD73       [label="CD73 ectonucleotidase", fillcolor="#C7D2FE"];
    Adenosine  [label="Extracellular Adenosine", fillcolor="#A5B4FC"];
    A1R        [label="A1 receptor\n↓ in RLS (iron-dep.)", fillcolor="#818CF8"];
    A2AR       [label="A2A receptor\n(striatal, on D2 neurons)", fillcolor="#818CF8"];
    ADK        [label="Adenosine kinase\n(removal)", fillcolor="#C7D2FE"];
    ENT1       [label="Equilibrative\nnucleoside transporter (ENT1)", fillcolor="#C7D2FE"];
    Caffeine   [label="Caffeine\n(A1/A2A antagonist)\n→ symptom trigger", fillcolor="#A5B4FC"];
    Hypoxanth  [label="Hypoxanthine\n(purine salvage)", fillcolor="#C7D2FE"];
  }

  // ============================================================
  // 5. GLUTAMATE / GABA BALANCE
  // ============================================================
  subgraph cluster_glutamate {
    label="5. Cortical-Spinal Glutamate / GABA Hyperexcitability";
    style="rounded,filled"; fillcolor="#DCFCE7"; color="#166534";
    GluRelease [label="Cortico-thalamic\nGlutamate release ↑\n(Allen 2013 MRS)", fillcolor="#BBF7D0"];
    NMDA       [label="NMDA receptor", fillcolor="#86EFAC"];
    AMPA       [label="AMPA receptor", fillcolor="#86EFAC"];
    mGluR5     [label="mGluR5", fillcolor="#86EFAC"];
    GABA       [label="GABA tone (↓)", fillcolor="#86EFAC"];
    a2d        [label="VGCC α2δ-1 subunit\n(Cav2.1/2.2)\n→ gabapentinoid target", fillcolor="#4ADE80"];
    SpinalSens [label="Spinal cord\nsensory hyperexcitability", fillcolor="#4ADE80"];
    SensCort   [label="Sensorimotor cortex\nhyperexcitability\n(TMS↑ ICF)", fillcolor="#4ADE80"];
  }

  // ============================================================
  // 6. OPIOID SYSTEM
  // ============================================================
  subgraph cluster_opioid {
    label="6. Endogenous Opioid System (β-endorphin / met-enkephalin)";
    style="rounded,filled"; fillcolor="#FCE7F3"; color="#9D174D";
    BetaEnd    [label="β-endorphin", fillcolor="#FBCFE8"];
    Enkephalin [label="Met/Leu-enkephalin", fillcolor="#FBCFE8"];
    MOR        [label="µ-opioid receptor (MOR)\nstriatum / PAG / spinal", fillcolor="#F9A8D4"];
    KOR        [label="κ-opioid receptor", fillcolor="#F9A8D4"];
    DOR        [label="δ-opioid receptor", fillcolor="#F9A8D4"];
    PAG        [label="Periaqueductal gray\n(descending inhibition)", fillcolor="#F9A8D4"];
    DescInhib  [label="Descending\npain/sensory inhibition", fillcolor="#F472B6"];
  }

  // ============================================================
  // 7. SPINAL CORD / PERIPHERAL SENSORY CIRCUIT (PLMS)
  // ============================================================
  subgraph cluster_spinal {
    label="7. Spinal Cord + Periphery (PLMS · flexor reflex · small fiber)";
    style="rounded,filled"; fillcolor="#F5F5F4"; color="#44403C";
    DRG        [label="Dorsal root ganglion\nC/Aδ small fibers", fillcolor="#E7E5E4"];
    DorsalHorn [label="Spinal dorsal horn\n(lamina I-V)", fillcolor="#E7E5E4"];
    VentralHorn[label="Spinal ventral horn\n(α motoneuron)", fillcolor="#E7E5E4"];
    FlexorRefl [label="Babinski-like\nflexor reflex (BTA↑)", fillcolor="#D6D3D1"];
    PLMS       [label="Periodic Limb Movements\nin Sleep (PLMS index)\n(>15/h = abnl)", fillcolor="#A8A29E"];
    PLMW       [label="Periodic Limb Movements\nWhile Awake (PLMW)\n(SIT test)", fillcolor="#A8A29E"];
    SmallFiber [label="Small-fiber\nneuropathy comorbid\n(IENFD↓ ~30%)", fillcolor="#D6D3D1"];
    HypoxiaP   [label="Peripheral tissue\nhypoxia (NIRS↓)", fillcolor="#D6D3D1"];
  }

  // ============================================================
  // 8. CIRCADIAN / SLEEP ARCHITECTURE
  // ============================================================
  subgraph cluster_circadian {
    label="8. Circadian Rhythm · Sleep Architecture (Worse at night)";
    style="rounded,filled"; fillcolor="#EDE9FE"; color="#5B21B6";
    SCN        [label="Suprachiasmatic nucleus\n(master clock)", fillcolor="#DDD6FE"];
    Melatonin  [label="Pineal Melatonin\n(↑ evening)", fillcolor="#C4B5FD"];
    CoreTemp   [label="Core body temperature\n(↓ evening)", fillcolor="#C4B5FD"];
    DA_circ    [label="Circadian DA\n(trough at night)", fillcolor="#A78BFA"];
    SleepOnset [label="Sleep onset latency ↑", fillcolor="#A78BFA"];
    WASO       [label="Wake after sleep\nonset (WASO) ↑", fillcolor="#A78BFA"];
    REM        [label="REM sleep ↓", fillcolor="#A78BFA"];
    N3         [label="N3 slow-wave ↓", fillcolor="#A78BFA"];
    Arousals   [label="Cortical arousals", fillcolor="#A78BFA"];
  }

  // ============================================================
  // 9. AUGMENTATION & RISK FACTORS
  // ============================================================
  subgraph cluster_aug {
    label="9. Augmentation (long-term DA agonist toxicity) + Triggers";
    style="rounded,filled"; fillcolor="#FFFBEB"; color="#92400E";
    DA_LongExp [label="Chronic DA agonist\nexposure", fillcolor="#FEF3C7"];
    DA_OvrDrv  [label="Postsynaptic D1\novershoot / D2 desensitization", fillcolor="#FDE68A"];
    Augmenta   [label="Augmentation\n(earlier onset, spread)\n7-yr risk ~60% pramipexole", fillcolor="#FCD34D"];
    ICDs       [label="Impulse control\ndisorders (ICDs)", fillcolor="#FCD34D"];
    Triggers   [label="Triggers:\nSSRI · antihistamine · DA-blocker\nantiemetic (metoclopramide)\ncaffeine · ETOH · sleep-deprivation", fillcolor="#FEF3C7"];
    Pregnancy  [label="Pregnancy\n(3rd trimester, ↓Fe)", fillcolor="#FEF3C7"];
    ESRD       [label="ESRD / hemodialysis\n(20-60% RLS)", fillcolor="#FEF3C7"];
  }

  // ============================================================
  // 10. DRUG PK COMPARTMENTS
  // ============================================================
  subgraph cluster_pk {
    label="10. Drug PK Compartments";
    style="rounded,filled"; fillcolor="#F0FDFA"; color="#0F766E";
    DrugDepot  [label="Oral / transdermal /\nIV depot", fillcolor="#CCFBF1"];
    Central    [label="Central plasma\n(V1)", fillcolor="#99F6E4"];
    Periph     [label="Peripheral tissue\n(V2)", fillcolor="#99F6E4"];
    CNS_pk     [label="CNS effect site\n(Ce, ke0)", fillcolor="#5EEAD4"];
    Liver      [label="Liver (CYP3A4/CYP1A2)\nmetabolism", fillcolor="#99F6E4"];
    Renal      [label="Renal CL (eGFR-dep)", fillcolor="#99F6E4"];
  }

  // ============================================================
  // 11. PHARMACOTHERAPIES
  // ============================================================
  subgraph cluster_drugs {
    label="11. Pharmacotherapies (1st-line: α2δ · 2nd: DA agonist · IV iron · opioids)";
    style="rounded,filled"; fillcolor="#FAE8FF"; color="#86198F";
    Pramipexole[label="Pramipexole\n0.125-0.5 mg PO\nD3>D2 agonist", fillcolor="#F5D0FE"];
    Ropinirole [label="Ropinirole\n0.25-4 mg PO\nD2/D3 agonist", fillcolor="#F5D0FE"];
    Rotigotine [label="Rotigotine\n1-3 mg/24h patch\nD3>D2>D1", fillcolor="#F5D0FE"];
    Gabapentin [label="Gabapentin enacarbil\n600 mg PO (XR prodrug)\nα2δ-1 ligand", fillcolor="#F0ABFC"];
    Gabap      [label="Gabapentin\n300-1800 mg PO", fillcolor="#F0ABFC"];
    Pregabalin [label="Pregabalin\n150-450 mg PO", fillcolor="#F0ABFC"];
    OxyNal     [label="Oxycodone / Naloxone PR\n5/2.5 - 40/20 mg BID", fillcolor="#E879F9"];
    Methadone  [label="Methadone (low dose)\n2.5-10 mg PO", fillcolor="#E879F9"];
    Tramadol   [label="Tramadol\n50-200 mg PO", fillcolor="#E879F9"];
    IVIron     [label="IV iron\n(FCM 750-1500 mg ·\nferric carboxymaltose)", fillcolor="#D946EF"];
    POIron     [label="Oral ferrous sulfate\n325 mg TID + vit C", fillcolor="#D946EF"];
    Dipy       [label="Dipyridamole\n(adenosine reuptake inh.)\nemerging", fillcolor="#F5D0FE"];
    Clonazepam [label="Clonazepam\n(legacy GABA-A)", fillcolor="#F0ABFC"];
    Bupropion  [label="Bupropion\n(DA/NE, SSRI alternative)", fillcolor="#F5D0FE"];
  }

  // ============================================================
  // 12. CLINICAL ENDPOINTS / OUTCOMES
  // ============================================================
  subgraph cluster_clinical {
    label="12. Clinical Endpoints (IRLS, CGI-I, PLMS index, SQ, QoL)";
    style="rounded,filled"; fillcolor="#FEF3C7"; color="#854D0E";
    IRLS       [label="IRLS score\n(0-40; >20 severe)", fillcolor="#FDE68A"];
    CGI_I      [label="CGI-I (1-7)\n(much improved ≤2)", fillcolor="#FDE68A"];
    PSQI       [label="PSQI sleep quality", fillcolor="#FDE68A"];
    ESS        [label="ESS daytime sleepiness", fillcolor="#FDE68A"];
    QoL_RLSQoL [label="RLS-QLI", fillcolor="#FDE68A"];
    HAMD       [label="HAM-D depression\n(comorbid 40%)", fillcolor="#FDE68A"];
    Cardio     [label="Nocturnal BP/HR surges\n(PLMS-linked CV risk)", fillcolor="#FDE68A"];
    Mortality  [label="Long-term CV/mortality\nhazard (HR≈1.4)", fillcolor="#F59E0B"];
  }

  // ============================================================
  //                          EDGES
  // ============================================================

  // Genetics → iron + dopamine
  Heritability -> Familial;
  Familial -> BTBD9; Familial -> MEIS1;
  BTBD9   -> IRP1_2 [label="iron sensing"];
  MEIS1   -> A11    [label="dev. of A11 neurons"];
  MEIS1AS -> MEIS1;
  MAP2K5  -> SpinalDA;
  PTPRD   -> A11;
  TOX3    -> BrainFe;
  BTBD9   -> BrainFe   [label="↓ uptake"];
  MEIS1   -> BrainFe   [label="↓ deposition"];

  // Iron transport
  DietIron -> DMT1_gut -> Ferroportin -> SerumFe;
  Hepcidin -> Ferroportin [label="−"];
  SerumFe  -> Ferritin;
  SerumFe  -> TfR_BBB -> BrainFe;
  IRP1_2   -> TfR_BBB;
  DCYTB    -> DMT1_gut;
  Ferritin -> CSFFerritin [style=dashed];
  CSFFerritin -> BrainFe  [label="diagnostic surrogate"];

  // Iron → dopamine system
  BrainFe -> TH        [label="Fe²⁺ cofactor"];
  TH      -> DA_synth -> DA_release;
  DA_release -> D1R; DA_release -> D2R; DA_release -> D3R;
  DA_release -> DAT [label="reuptake"];
  AADC -> DA_synth;
  MAO_B -> DA_release [label="−"];
  BrainFe -> DAT  [label="DAT density"];
  BrainFe -> D2R  [label="D2 density ↓"];
  SN_VTA  -> DA_release;
  A11     -> SpinalDA;
  SpinalDA -> DorsalHorn [label="presyn. inhibition"];

  // Iron → adenosine
  BrainFe -> A1R [label="A1↓ when Fe↓\n(Ferré)"];
  BrainFe -> ENT1;
  ATP_pool -> CD73 -> Adenosine;
  Adenosine -> A1R; Adenosine -> A2AR;
  ADK -> Adenosine [label="−"];
  ENT1 -> Adenosine [label="uptake"];
  Adenosine -> Hypoxanth;
  A1R -> GluRelease [label="− (presyn.)"];
  A1R -> DA_release [label="− tone"];
  A2AR -> D2R [label="heteromer\nA2A-D2"];
  Caffeine -> A1R [label="antagonist"];
  Caffeine -> A2AR [label="antagonist"];

  // Glutamate/GABA
  GluRelease -> NMDA -> SensCort;
  GluRelease -> AMPA -> SpinalSens;
  GluRelease -> mGluR5;
  GABA -> SensCort [label="− (↓ in RLS)"];
  a2d -> GluRelease [label="VGCC trafficking"];
  SensCort -> Arousals;
  SpinalSens -> DRG;

  // Opioid
  BetaEnd -> MOR; Enkephalin -> MOR; Enkephalin -> DOR;
  MOR -> PAG -> DescInhib;
  DescInhib -> DorsalHorn [label="−"];
  DescInhib -> SpinalSens [label="−"];

  // Spinal motor / sensory
  DRG -> DorsalHorn -> VentralHorn -> FlexorRefl -> PLMS;
  DorsalHorn -> PLMW;
  SmallFiber -> DRG;
  HypoxiaP -> DRG;
  SpinalSens -> FlexorRefl;
  SpinalDA -> FlexorRefl [label="− tonic"];

  // Circadian / sleep
  SCN -> Melatonin; SCN -> CoreTemp;
  Melatonin -> DA_circ [label="phase ref."];
  CoreTemp -> SleepOnset;
  DA_circ -> SpinalDA [label="nocturnal trough"];
  SleepOnset -> WASO; WASO -> REM; WASO -> N3;
  PLMS -> Arousals -> WASO;
  Arousals -> Cardio;

  // Augmentation
  Pramipexole -> DA_LongExp; Ropinirole -> DA_LongExp; Rotigotine -> DA_LongExp [label="lowest risk\n(transdermal)"];
  DA_LongExp -> DA_OvrDrv -> Augmenta;
  Augmenta -> IRLS [label="↑↑"];
  Augmenta -> ICDs;
  DA_LongExp -> ICDs [label="D3 limbic"];
  Triggers -> IRLS; Triggers -> PLMS;
  Pregnancy -> Ferritin [label="↓"];
  ESRD -> Ferritin [label="dialysis losses"];
  ESRD -> Hepcidin [label="↑"];

  // Drug PK & target binding
  DrugDepot -> Central; Central -> Periph;
  Central -> CNS_pk; CNS_pk -> Periph [style=dashed];
  Central -> Liver; Liver -> Central [label="hepatic CL"];
  Central -> Renal;
  Pramipexole -> Central; Ropinirole -> Central; Rotigotine -> Central;
  Gabapentin -> Central; Gabap -> Central; Pregabalin -> Central;
  OxyNal -> Central; Methadone -> Central; Tramadol -> Central;
  IVIron -> SerumFe [label="rapid replete"];
  POIron -> SerumFe [label="slow, gut limited"];
  Dipy -> Adenosine [label="↑ (block ENT1)"];

  // Drugs → targets
  Pramipexole -> D3R [label="agonist"];
  Pramipexole -> D2R [label="agonist"];
  Ropinirole  -> D2R [label="agonist"];
  Ropinirole  -> D3R [label="agonist"];
  Rotigotine  -> D3R [label="agonist"];
  Rotigotine  -> D2R [label="agonist"];
  Rotigotine  -> D1R [label="weak agonist"];
  Gabapentin  -> a2d [label="binder"];
  Gabap       -> a2d [label="binder"];
  Pregabalin  -> a2d [label="binder"];
  OxyNal      -> MOR [label="oxy agonist"];
  OxyNal      -> MOR [label="gut nal antag.\n(low constipation)"];
  Methadone   -> MOR; Methadone -> NMDA [label="weak antag."];
  Tramadol    -> MOR [label="weak agonist"];
  Tramadol    -> MAO_B [style=dashed,label="weak SNRI"];
  Clonazepam  -> GABA [label="GABA-A PAM"];
  Bupropion   -> DAT  [label="reuptake inh."];

  // Targets → physiology → endpoints
  D3R -> SpinalDA [label="↑ tone"];
  D2R -> DA_release [label="autoreceptor−"];
  a2d -> SensCort [label="−"];
  a2d -> DorsalHorn [label="−"];
  MOR -> PLMS [label="↓"];
  MOR -> IRLS [label="↓ symptoms"];
  SpinalDA -> IRLS [label="− symptoms"];
  PLMS -> IRLS;
  PLMW -> IRLS;
  IRLS -> CGI_I;
  WASO -> PSQI; N3 -> PSQI; REM -> PSQI;
  PSQI -> ESS;
  IRLS -> QoL_RLSQoL;
  QoL_RLSQoL -> HAMD;
  Cardio -> Mortality;
  PSQI -> HAMD;

  // Cross-cluster signature edges
  BrainFe -> Adenosine [style=dashed,label="Quiroz 2010"];
  IVIron  -> BrainFe   [label="restores"];
  IVIron  -> IRLS      [label="−"];
  POIron  -> IRLS      [label="− (if ferritin<75)"];
  Gabap   -> Augmenta  [style=dotted,label="no augmentation"];
  Pregabalin -> Augmenta [style=dotted,label="non-augmenting"];
  OxyNal  -> Augmenta  [style=dotted,label="rescue"];

  // Decorative legend
  subgraph cluster_legend {
    label="Legend";
    style="rounded,filled"; fillcolor="#F8FAFC"; color="#475569";
    L1 [label="Risk gene", fillcolor="#FECACA"];
    L2 [label="Iron pool",  fillcolor="#FDBA74"];
    L3 [label="Dopamine",   fillcolor="#60A5FA"];
    L4 [label="Adenosine",  fillcolor="#818CF8"];
    L5 [label="Glutamate/GABA", fillcolor="#86EFAC"];
    L6 [label="Opioid",     fillcolor="#F9A8D4"];
    L7 [label="Spinal/PNS", fillcolor="#A8A29E"];
    L8 [label="Circadian",  fillcolor="#A78BFA"];
    L9 [label="Drug",       fillcolor="#F0ABFC"];
    L10[label="Endpoint",   fillcolor="#FDE68A"];
  }
}
