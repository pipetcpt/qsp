digraph ChronicHypothyroidism_QSP {
    graph [rankdir=LR, compound=true, fontname="Helvetica", fontsize=10,
           bgcolor="#f8f9fa",
           label="Chronic Hypothyroidism QSP Model\n만성 갑상선 기능 저하증 정량적 시스템 약리학 모델",
           labelloc=top, labeljust=center, fontsize=14, nodesep=0.4, ranksep=0.8]
    node [style=filled, fontname="Helvetica", fontsize=8, margin="0.1,0.05", height=0.4]
    edge [fontname="Helvetica", fontsize=7, arrowsize=0.6]

    // =====================================================================
    // CLUSTER 1: HYPOTHALAMUS
    // =====================================================================
    subgraph cluster_hypothalamus {
        label="시상하부 (Hypothalamus)"
        style=filled; fillcolor="#e8f5e9"; color="#2e7d32"; penwidth=2

        TRH         [label="TRH\n(Thyrotropin-Releasing\nHormone)", shape=oval, fillcolor="#a5d6a7"]
        TRH_syn     [label="TRH 합성\nKsyn_TRH", shape=box, fillcolor="#c8e6c9"]
        TRH_neurons [label="TRH 신경세포\n(PVN, Paraventricular\nNucleus)", shape=box, fillcolor="#c8e6c9"]
        TRH_portal  [label="문맥 혈류\n(Portal Blood)", shape=diamond, fillcolor="#dcedc8"]
        Cold_stim   [label="한랭 자극\n(Cold Exposure)", shape=box, fillcolor="#b2dfdb"]
        Fasting     [label="공복 억제\n(Fasting → TRH ↓)", shape=box, fillcolor="#b2dfdb"]
        Stress      [label="스트레스/코르티솔\n(Stress/Cortisol → TRH ↓)", shape=box, fillcolor="#ffcdd2"]
        DA_hypo     [label="도파민\n(Dopamine → TRH ↓)", shape=oval, fillcolor="#b2dfdb"]
        SST_hypo    [label="소마토스타틴\n(Somatostatin → TRH ↓)", shape=oval, fillcolor="#b2dfdb"]
        TRH_deg     [label="TRH 분해\n(kdeg, t½ ≈ 40 min)", shape=box, fillcolor="#dcedc8"]
    }

    // =====================================================================
    // CLUSTER 2: ANTERIOR PITUITARY
    // =====================================================================
    subgraph cluster_pituitary {
        label="뇌하수체 전엽 (Anterior Pituitary)"
        style=filled; fillcolor="#e3f2fd"; color="#1565c0"; penwidth=2

        TSH           [label="TSH\n(Thyroid Stimulating\nHormone)", shape=oval, fillcolor="#90caf9"]
        Thyrotroph    [label="갑상선자극세포\n(Thyrotroph Cells)", shape=box, fillcolor="#bbdefb"]
        TSH_syn       [label="TSH 합성\n(Glycoprotein)", shape=box, fillcolor="#bbdefb"]
        TSH_glycos    [label="TSH 당화\n(N-glycosylation\n생물활성 결정)", shape=box, fillcolor="#b3e5fc"]
        TSH_bio       [label="TSH 생물활성\n(Bioactive TSH)", shape=box, fillcolor="#b3e5fc"]
        TSH_sec       [label="TSH 분비\n(Pulsatile, 밤에 최대)", shape=box, fillcolor="#bbdefb"]
        TRH_R         [label="TRH 수용체\n(TRH-R, Gq/IP3/PKC)", shape=box, fillcolor="#b3e5fc"]
        fT4_fb_pit    [label="T4 음성 피드백\n(fT4 → TSH ↓\nHill EC50≈15 pmol/L)", shape=diamond, fillcolor="#bbdefb"]
        fT3_fb_pit    [label="T3 음성 피드백\n(D2 변환 → pit. T3 ↑\n→ TSH ↓)", shape=diamond, fillcolor="#bbdefb"]
        TSH_deg       [label="TSH 분해\n(t½ ≈ 1 hour)", shape=box, fillcolor="#ddeeff"]
        Prolactin     [label="프로락틴\n(Prolactin ↑\nTRH 자극)", shape=oval, fillcolor="#c5cae9"]
    }

    // =====================================================================
    // CLUSTER 3: THYROID GLAND
    // =====================================================================
    subgraph cluster_thyroid {
        label="갑상선 (Thyroid Gland)"
        style=filled; fillcolor="#fce4ec"; color="#880e4f"; penwidth=2

        TSHR          [label="TSH 수용체\n(TSHR, GPCR\nGαs/cAMP/PKA)", shape=box, fillcolor="#f48fb1"]
        cAMP_thy      [label="cAMP\n(TSH→AC→PKA 신호)", shape=oval, fillcolor="#f8bbd9"]
        NIS           [label="NIS\n(Na⁺/I⁻ Symporter\nSLC5A5)", shape=box, fillcolor="#f48fb1"]
        Iodide_up     [label="요오드 능동 섭취\n(Active I⁻ Uptake\n농도 기울기 역방향)", shape=box, fillcolor="#f8bbd9"]
        Pendrin       [label="펜드린\n(Pendrin SLC26A4\nI⁻ → 여포강)", shape=box, fillcolor="#f8bbd9"]
        DUOX          [label="DUOX1/2\n(H₂O₂ 생성효소\n산화요오드에 필수)", shape=box, fillcolor="#f8bbd9"]
        TPO           [label="TPO\n(Thyroid Peroxidase\n요오드 유기화·결합)", shape=oval, fillcolor="#f48fb1"]
        Tg            [label="티로글로불린\n(Thyroglobulin, Tg\n갑상선 호르몬 전구체)", shape=box, fillcolor="#f8bbd9"]
        MIT           [label="MIT\n(Monoiodotyrosine)", shape=box, fillcolor="#f8bbd9"]
        DIT           [label="DIT\n(Diiodotyrosine)", shape=box, fillcolor="#f8bbd9"]
        T4_syn        [label="T4 합성\n(DIT + DIT → T4)", shape=box, fillcolor="#f48fb1"]
        T3_syn        [label="T3 합성\n(MIT + DIT → T3)", shape=box, fillcolor="#f48fb1"]
        Follicle      [label="갑상선 여포\n(Thyroid Follicle\n콜로이드 저장)", shape=box, fillcolor="#f8bbd9"]
        Endocytosis   [label="내세포 작용\n(Endocytosis of Tg\nTSH 자극 시 ↑)", shape=box, fillcolor="#f8bbd9"]
        T4_sec        [label="T4 분비\n(80-90% of output\n~110 μg/day)", shape=box, fillcolor="#f48fb1"]
        T3_sec        [label="T3 분비\n(10-20% of output\n~10 μg/day)", shape=box, fillcolor="#f48fb1"]
        Wolff         [label="Wolff-Chaikoff\n(과잉 I⁻ → 자체 억제\n단기 방어)", shape=diamond, fillcolor="#e91e63", fontcolor=white]
        Iodine_sup    [label="요오드 공급\n(Dietary Iodine\n권장: 150 μg/day)", shape=box, fillcolor="#f8bbd9"]
        T4_intrathy   [label="갑상선 내 T4\n(Intraglandular T4\n저장풀)", shape=oval, fillcolor="#f48fb1"]
    }

    // =====================================================================
    // CLUSTER 4: PATHOLOGICAL CAUSES
    // =====================================================================
    subgraph cluster_etiology {
        label="발병 원인 (Etiology / Pathological Causes)"
        style=filled; fillcolor="#eceff1"; color="#37474f"; penwidth=2

        Hashimoto     [label="하시모토 갑상선염\n(Hashimoto's Thyroiditis)\n가장 흔한 원인 (HLA-DR3/5)", shape=box, fillcolor="#b0bec5"]
        Post_Tx       [label="갑상선 절제술 후\n(Post-Thyroidectomy\n부분/전절제)", shape=box, fillcolor="#cfd8dc"]
        Post_RAI      [label="방사성 요오드 치료 후\n(Post-RAI Ablation\nI-131)", shape=box, fillcolor="#cfd8dc"]
        Drug_ind      [label="약물 유발\n(Drug-Induced)\nAmiodarone · Lithium\nIFN-α · Anti-PD1", shape=box, fillcolor="#cfd8dc"]
        Central_hypo  [label="중추성 갑저\n(Central Hypothyroidism\n뇌하수체/시상하부)", shape=box, fillcolor="#cfd8dc"]
        Iodine_def    [label="요오드 결핍\n(Iodine Deficiency\n전 세계 가장 흔한 원인)", shape=box, fillcolor="#cfd8dc"]
        Congenital    [label="선천성 갑저\n(Congenital Hypothyroidism\nNIS/TPO 돌연변이)", shape=box, fillcolor="#cfd8dc"]
        Transient     [label="일시적 갑저\n(Transient\n산후/아급성 갑상선염)", shape=box, fillcolor="#cfd8dc"]
        Infiltrative  [label="침윤성 질환\n(Infiltrative Disease\n아밀로이드/림프종)", shape=box, fillcolor="#cfd8dc"]
        Anti_TPO_Ab   [label="항TPO 항체\n(Anti-TPO Ab ↑\n>500 IU/mL)", shape=oval, fillcolor="#90a4ae"]
        Anti_Tg_Ab    [label="항Tg 항체\n(Anti-Tg Ab ↑)", shape=oval, fillcolor="#90a4ae"]
        CD8_T         [label="세포독성 T세포\n(CD8+ T-cell\n갑상선 세포 파괴)", shape=oval, fillcolor="#b0bec5"]
        CD4_Th1       [label="Th1 림프구\n(IFN-γ, TNF-α\n여포 손상)", shape=oval, fillcolor="#b0bec5"]
        B_cell        [label="B세포·자가항체\n(B-cell Autoimmunity)", shape=oval, fillcolor="#b0bec5"]
    }

    // =====================================================================
    // CLUSTER 5: HORMONE BINDING & DISTRIBUTION
    // =====================================================================
    subgraph cluster_binding {
        label="갑상선 호르몬 결합·수송 (Hormone Binding & Distribution)"
        style=filled; fillcolor="#ede7f6"; color="#4527a0"; penwidth=2

        TBG           [label="TBG\n(Thyroxine Binding Globulin\n75% of T4 binding)", shape=oval, fillcolor="#b39ddb"]
        TTR           [label="트랜스티레틴\n(Transthyretin/TTR\n10% of T4 binding)", shape=oval, fillcolor="#b39ddb"]
        ALB_bind      [label="알부민 결합\n(Albumin\n15% of T4 binding)", shape=oval, fillcolor="#b39ddb"]
        TT4           [label="총 T4\n(Total T4\n~100 nmol/L)", shape=oval, fillcolor="#9575cd"]
        TT3           [label="총 T3\n(Total T3\n~1.8 nmol/L)", shape=oval, fillcolor="#9575cd"]
        FT4           [label="유리 T4\n(Free T4\n~15–20 pmol/L\n0.02% free)", shape=oval, fillcolor="#7e57c2", fontcolor=white]
        FT3           [label="유리 T3\n(Free T3\n~5 pmol/L\n0.3% free)", shape=oval, fillcolor="#7e57c2", fontcolor=white]
        rT3           [label="역-T3\n(Reverse T3\n~0.4 nmol/L\n비활성)", shape=oval, fillcolor="#ce93d8"]
        TBG_syn       [label="TBG 간 합성\n(Hepatic TBG Synthesis)", shape=box, fillcolor="#d1c4e9"]
        Estrogen_TBG  [label="에스트로겐 → TBG ↑\n(임신·경구피임약)", shape=box, fillcolor="#d1c4e9"]
        Androgens_TBG [label="안드로겐 → TBG ↓\n(테스토스테론)", shape=box, fillcolor="#d1c4e9"]
        TR_alpha      [label="갑상선 수용체 α\n(TRα1/TRα2\n심장·골격근)", shape=box, fillcolor="#9575cd", fontcolor=white]
        TR_beta       [label="갑상선 수용체 β\n(TRβ1/TRβ2\n간·뇌·갑상선)", shape=box, fillcolor="#9575cd", fontcolor=white]
        TR_nuclear    [label="핵 전사 인자\n(Nuclear Transcription\nTRE 결합 → 유전자 발현)", shape=box, fillcolor="#b39ddb"]
    }

    // =====================================================================
    // CLUSTER 6: PERIPHERAL METABOLISM (DEIODINASES)
    // =====================================================================
    subgraph cluster_deiodinase {
        label="말초 대사 (Deiodinases & Peripheral Metabolism)"
        style=filled; fillcolor="#fff8e1"; color="#f57f17"; penwidth=2

        D1            [label="D1\n(Deiodinase Type 1\n간·신장·갑상선\nT4→T3 & T4→rT3)", shape=box, fillcolor="#ffe082"]
        D2            [label="D2\n(Deiodinase Type 2\n뇌·뇌하수체·갑상선\nT4→T3 우선)", shape=box, fillcolor="#ffe082"]
        D3            [label="D3\n(Deiodinase Type 3\n태반·뇌·피부\nT3·T4→rT3·T2)", shape=box, fillcolor="#ffe082"]
        T4_to_T3      [label="T4 → T3 변환\n(outer ring\n5'-탈요오드화\n80%의 T3 공급원)", shape=box, fillcolor="#ffd54f"]
        T4_to_rT3     [label="T4 → rT3 변환\n(inner ring\n5-탈요오드화\n비활성)", shape=box, fillcolor="#ffd54f"]
        T3_to_T2      [label="T3 → T2\n(불활성 대사물)", shape=box, fillcolor="#ffe0b2"]
        Selenium      [label="셀레늄\n(Selenium\n탈요오드화효소\n셀레노시스테인)", shape=box, fillcolor="#ffe0b2"]
        Hepatic_conj  [label="간 결합·배설\n(Glucuronidation\nSulfation\nBiliary excretion)", shape=box, fillcolor="#ffcc80"]
        Enterohepatic [label="장간 순환\n(Enterohepatic\nCirculation\n10-15% 재흡수)", shape=box, fillcolor="#ffcc80"]
        Renal_excr    [label="신장 배설\n(Renal Excretion\n소변 T4/T3)", shape=box, fillcolor="#ffcc80"]
        T4_halflife   [label="T4 반감기\n(t½ = 6-7일\nkel = 0.0041 h⁻¹)", shape=diamond, fillcolor="#ffe082"]
        T3_halflife   [label="T3 반감기\n(t½ = 24시간\nkel = 0.029 h⁻¹)", shape=diamond, fillcolor="#ffe082"]
        rT3_halflife  [label="rT3 반감기\n(t½ = 4-5시간\nkel = 0.145 h⁻¹)", shape=diamond, fillcolor="#ffe082"]
    }

    // =====================================================================
    // CLUSTER 7: DRUG PK — LEVOTHYROXINE & LIOTHYRONINE
    // =====================================================================
    subgraph cluster_drug_pk {
        label="약물 PK — 레보티록신 / 리오티로닌 (Drug PK: LT4 / LT3)"
        style=filled; fillcolor="#e0f7fa"; color="#006064"; penwidth=2

        LT4_dose      [label="레보티록신 용량\n(Levothyroxine, LT4)\n25–200 μg/일\n표준: 1.6 μg/kg/day", shape=box, fillcolor="#80deea"]
        LT3_dose      [label="리오티로닌 용량\n(Liothyronine, LT3)\n5–25 μg/일\n2×/day 분할투여", shape=box, fillcolor="#80deea"]
        LT4_gut       [label="LT4 위장관\n(Gut Compartment)\n흡수 지연부위", shape=box, fillcolor="#b2ebf2"]
        LT4_central   [label="LT4 중앙 구획\n(Central Compartment)\nV1 ≈ 15 L", shape=box, fillcolor="#80deea"]
        LT4_periph    [label="LT4 말초 구획\n(Peripheral Compartment)\nVss ≈ 700 L", shape=box, fillcolor="#80deea"]
        LT3_gut       [label="LT3 위장관\n(LT3 Gut)", shape=box, fillcolor="#b2ebf2"]
        LT3_central   [label="LT3 중앙 구획\n(LT3 Central\nV1 ≈ 15 L)", shape=box, fillcolor="#80deea"]
        Ka_LT4        [label="Ka = 0.35 h⁻¹\n(T½abs ≈ 2h)", shape=diamond, fillcolor="#b2ebf2"]
        F_LT4         [label="F = 0.65–0.80\n(생체이용률\n공복 투여 권장)", shape=diamond, fillcolor="#b2ebf2"]
        Vd_LT4        [label="Vd = 10 L/kg\n(70kg: Vd≈700L\nTBG 결합 포함)", shape=diamond, fillcolor="#b2ebf2"]
        CL_LT4        [label="CL = 1.2 L/h\n(t½ ≈ 7일\n주로 D1 대사)", shape=diamond, fillcolor="#b2ebf2"]
        F_LT3         [label="F = 0.95\n(LT3 거의 완전 흡수)", shape=diamond, fillcolor="#b2ebf2"]
        CL_LT3        [label="CL_LT3 = 2.5 L/h\n(t½ LT3 ≈ 24h)", shape=diamond, fillcolor="#b2ebf2"]
        Drug_int      [label="약물 상호작용\n(Drug Interactions)\nCa²⁺ · Fe²⁺ · PPI\n콜레스티라민 · 수크랄페이트", shape=box, fillcolor="#e0f7fa"]
        Food_effect   [label="식이 영향\n(Food Effect\n공복 흡수 F ↑\n식후 F 20% ↓)", shape=box, fillcolor="#e0f7fa"]
        Combo_tx      [label="T4+T3 병용요법\n(Combination Therapy\n일부 증상 잔존 환자)", shape=box, fillcolor="#80deea"]
        LT4_Tmax      [label="Tmax ≈ 2-4 h\n(단일 용량)", shape=diamond, fillcolor="#b2ebf2"]
        LT4_SS        [label="SS 달성: 6-8주\n(5 × t½ 후)", shape=diamond, fillcolor="#b2ebf2"]
    }

    // =====================================================================
    // CLUSTER 8: CARDIOVASCULAR EFFECTS
    // =====================================================================
    subgraph cluster_cvs {
        label="심혈관계 효과 (Cardiovascular Effects)"
        style=filled; fillcolor="#ffebee"; color="#b71c1c"; penwidth=2

        HR_eff        [label="심박수\n(Heart Rate\n갑저: ↓40-60 bpm\n정상: 60-100 bpm)", shape=oval, fillcolor="#ef9a9a"]
        CO_eff        [label="심박출량\n(Cardiac Output\n갑저: 20-30% ↓)", shape=oval, fillcolor="#ef9a9a"]
        SV_eff        [label="일회박출량\n(Stroke Volume ↓)", shape=oval, fillcolor="#ffcdd2"]
        SVR_eff       [label="말초혈관저항\n(SVR ↑ 30-60%\n이완기 고혈압)", shape=oval, fillcolor="#ef9a9a"]
        BP_eff        [label="혈압\n(Blood Pressure\n이완기 고혈압 30%)", shape=oval, fillcolor="#ef9a9a"]
        LDL_eff       [label="LDL 콜레스테롤\n(LDL ↑ 25-35%\nLDL-R 발현 ↓)", shape=oval, fillcolor="#ffcdd2"]
        TC_eff        [label="총 콜레스테롤\n(Total Cholesterol\n↑ 30-40%)", shape=oval, fillcolor="#ffcdd2"]
        TG_eff        [label="중성지방\n(Triglycerides ↑\nLPL 활성 ↓)", shape=oval, fillcolor="#ffcdd2"]
        HDL_eff       [label="HDL 콜레스테롤\n(HDL ↓\nCETP 활성 ↓)", shape=oval, fillcolor="#ffcdd2"]
        Contractility [label="심근 수축력\n(Myocardial Contractility ↓\nMHC-α → MHC-β 전환)", shape=oval, fillcolor="#ef9a9a"]
        Pericardial   [label="심낭 삼출\n(Pericardial Effusion\n점액성 GAG 축적)", shape=box, fillcolor="#ffcdd2"]
        QT_prolong    [label="QT 연장\n(QT Prolongation\n서맥 연관)", shape=box, fillcolor="#ffcdd2"]
        LDLR_expr     [label="LDL 수용체 발현\n(LDLR mRNA ↓\nSREBP 조절)", shape=box, fillcolor="#ffcdd2"]
        CV_risk       [label="심혈관 위험도\n(CV Risk ↑\n죽상동맥경화 가속)", shape=oval, fillcolor="#ef9a9a"]
        Beta_AR       [label="베타-아드레날린 수용체\n(β-AR 발현 ↓\nT3에 의해 조절)", shape=box, fillcolor="#ffcdd2"]
    }

    // =====================================================================
    // CLUSTER 9: METABOLIC EFFECTS
    // =====================================================================
    subgraph cluster_metab {
        label="대사 효과 (Metabolic Effects)"
        style=filled; fillcolor="#f3e5f5"; color="#6a1b9a"; penwidth=2

        BMR_eff       [label="기초대사율\n(BMR ↓ 15-30%\nUCP2/3 발현 ↓)", shape=oval, fillcolor="#ce93d8"]
        Weight_gain   [label="체중 증가\n(Weight Gain 2-10 kg\nGAG·수분 축적)", shape=oval, fillcolor="#ce93d8"]
        Thermogen     [label="열 생산 감소\n(Thermogenesis ↓\n추위 불내성)", shape=oval, fillcolor="#ce93d8"]
        Glucose_metab [label="포도당 대사\n(Glucose Metabolism ↓\nGLUT4 발현 ↓)", shape=oval, fillcolor="#e1bee7"]
        Insulin_sens  [label="인슐린 감수성\n(Insulin Resistance ↑\n당뇨 위험)", shape=box, fillcolor="#e1bee7"]
        FA_ox         [label="지방산 산화\n(FA Oxidation ↓\nβ-oxidation 효소 ↓)", shape=box, fillcolor="#e1bee7"]
        Lipogenesis   [label="지방 합성 ↑\n(Adipogenesis ↑\n중심성 비만)", shape=box, fillcolor="#e1bee7"]
        Na_retention  [label="나트륨 저류\n(Na⁺ Retention\nAVP 증가)", shape=box, fillcolor="#e1bee7"]
        Hyponatremia  [label="저나트륨혈증\n(Hyponatremia\n중증 갑저)", shape=box, fillcolor="#e1bee7"]
        Carotenemia   [label="카로테네미아\n(Carotenemia\n피부 황색 띰)", shape=box, fillcolor="#e1bee7"]
        SHBG_eff      [label="SHBG 감소\n(SHBG ↓\n유리 테스토스테론 ↑)", shape=box, fillcolor="#e1bee7"]
        Homocysteine  [label="호모시스테인 ↑\n(Hyperhomocysteinemia\nCV 위험 인자)", shape=box, fillcolor="#e1bee7"]
    }

    // =====================================================================
    // CLUSTER 10: NEUROLOGICAL / PSYCHIATRIC EFFECTS
    // =====================================================================
    subgraph cluster_neuro {
        label="신경·정신계 효과 (Neurological & Psychiatric Effects)"
        style=filled; fillcolor="#e8f5e9"; color="#1b5e20"; penwidth=2

        Cognition     [label="인지 기능 저하\n(Cognitive Impairment\n기억력·처리속도 ↓)", shape=oval, fillcolor="#a5d6a7"]
        Depression    [label="우울증\n(Depression\n세로토닌 저하)", shape=oval, fillcolor="#a5d6a7"]
        Fatigue       [label="만성 피로\n(Fatigue/Lethargy\nATP 합성 ↓)", shape=oval, fillcolor="#a5d6a7"]
        DTR_relax     [label="심건반사 이완 지연\n(Delayed DTR Relaxation\n진단적 지표)", shape=oval, fillcolor="#c8e6c9"]
        Periph_neuro  [label="말초신경병증\n(Peripheral Neuropathy\n감각이상)", shape=box, fillcolor="#c8e6c9"]
        Cerebellar    [label="소뇌 운동실조\n(Cerebellar Ataxia\n심각한 갑저)", shape=box, fillcolor="#c8e6c9"]
        Hearing       [label="청력 저하\n(Sensorineural\nHearing Loss)", shape=box, fillcolor="#c8e6c9"]
        Sleep_dist    [label="수면 장애\n(Sleep Disturbance\n수면 무호흡증 위험)", shape=box, fillcolor="#c8e6c9"]
        Myx_coma      [label="점액수종 혼수\n(Myxedema Coma)\n[생명 위협 중증]", shape=box, fillcolor="#f44336", fontcolor=white]
        Psychosis     [label="갑상선 정신증\n(Myxedema Psychosis\n망상·환각)", shape=box, fillcolor="#c8e6c9"]
        Serotoni      [label="세로토닌 감소\n(Serotonin ↓\nT3 → TPH 발현 ↑)", shape=box, fillcolor="#c8e6c9"]
        Dopamine_CNS  [label="도파민 결핍\n(Dopamine ↓\n운동 기능 저하)", shape=box, fillcolor="#c8e6c9"]
    }

    // =====================================================================
    // CLUSTER 11: BONE & MUSCULOSKELETAL EFFECTS
    // =====================================================================
    subgraph cluster_bone {
        label="골격·근육계 효과 (Bone & Musculoskeletal Effects)"
        style=filled; fillcolor="#e0f2f1"; color="#004d40"; penwidth=2

        Bone_turn     [label="골 교체율 감소\n(Bone Turnover ↓\nOPG/RANKL 변화)", shape=oval, fillcolor="#80cbc4"]
        BMD_eff       [label="골밀도\n(BMD 변화\n과치료 시 ↓\n갑저 시 느린 교체)", shape=oval, fillcolor="#80cbc4"]
        Osteocalcin   [label="오스테오칼신\n(Osteocalcin ↓\n골형성 마커)", shape=box, fillcolor="#b2dfdb"]
        CTX           [label="CTX ↓\n(골흡수 감소\nCollagen crosslinks)", shape=box, fillcolor="#b2dfdb"]
        CK_elev       [label="CK 상승\n(Creatine Kinase ↑\n근육 손상 마커)", shape=box, fillcolor="#b2dfdb"]
        Myopathy      [label="갑상선 근병증\n(Hypothyroid Myopathy\n근력 저하·경련)", shape=oval, fillcolor="#80cbc4"]
        Arthralgia    [label="관절통\n(Arthralgia/Joint Pain\n관절강 삼출)", shape=box, fillcolor="#b2dfdb"]
        Carpal_tun    [label="수근관 증후군\n(Carpal Tunnel Syndrome\nGAG 침착)", shape=box, fillcolor="#b2dfdb"]
        Growth_delay  [label="성장 지연\n(소아 성장 지연\n골화 지연\nIGF-1 감소)", shape=box, fillcolor="#b2dfdb"]
    }

    // =====================================================================
    // CLUSTER 12: GI, SKIN & REPRODUCTIVE EFFECTS
    // =====================================================================
    subgraph cluster_gi_skin_repro {
        label="소화기·피부·생식계 효과 (GI, Skin & Reproductive Effects)"
        style=filled; fillcolor="#fff3e0"; color="#e65100"; penwidth=2

        GI_mot        [label="위장관 운동 저하\n(GI Motility ↓\nACh 방출 ↓)", shape=oval, fillcolor="#ffcc80"]
        Constipation  [label="변비\n(Constipation\n환자의 ~60%)", shape=oval, fillcolor="#ffcc80"]
        Macroglossia  [label="거대 혀\n(Macroglossia\nGAG 침착)", shape=box, fillcolor="#ffe0b2"]
        Ascites       [label="복수\n(Ascites·흉수\n심한 점액수종)", shape=box, fillcolor="#ffe0b2"]
        Dry_skin      [label="건조한 피부\n(Dry/Rough Skin\n피지·땀샘 ↓)", shape=oval, fillcolor="#ffcc80"]
        Hair_loss     [label="탈모·건조 모발\n(Hair Loss/Dry Hair\n모발 주기 교란)", shape=oval, fillcolor="#ffcc80"]
        Brittle_nails [label="부서진 손발톱\n(Brittle Nails)", shape=box, fillcolor="#ffe0b2"]
        Myxedema_skin [label="점액수종성 피부\n(Non-pitting Edema\nGAG 피하 축적)", shape=box, fillcolor="#ffcc80"]
        Periorbital   [label="안주위 부종\n(Periorbital Edema\n특징적 외모)", shape=box, fillcolor="#ffe0b2"]
        Menstrual_irr [label="월경 이상\n(Menstrual Irregularity\n과다·희발·무월경)", shape=oval, fillcolor="#ffcc80"]
        Infertility   [label="불임\n(Infertility\n습관성 유산)", shape=oval, fillcolor="#ffcc80"]
        Galactorrhea  [label="유즙 분비\n(Galactorrhea\nProlactin 상승)", shape=box, fillcolor="#ffe0b2"]
        Libido_dec    [label="성욕 감소\n(Decreased Libido\nSHBG·안드로겐 변화)", shape=box, fillcolor="#ffe0b2"]
    }

    // =====================================================================
    // CLUSTER 13: CLINICAL ENDPOINTS & MONITORING
    // =====================================================================
    subgraph cluster_endpoints {
        label="임상 지표 & 모니터링 (Clinical Endpoints & Monitoring)"
        style=filled; fillcolor="#e8eaf6"; color="#1a237e"; penwidth=2

        TSH_lab       [label="혈청 TSH\n(Serum TSH)\n목표: 0.5–2.5 mIU/L\n갑저: >10 mIU/L", shape=oval, fillcolor="#7986cb"]
        FT4_lab       [label="유리 T4\n(Free T4)\n목표: 12–22 pmol/L\n갑저: <10 pmol/L", shape=oval, fillcolor="#7986cb"]
        FT3_lab       [label="유리 T3\n(Free T3)\n참고: 3.5–6.5 pmol/L", shape=oval, fillcolor="#9fa8da"]
        TT4_lab       [label="총 T4\n(Total T4)\n참고: 58–161 nmol/L", shape=oval, fillcolor="#9fa8da"]
        TT3_lab       [label="총 T3\n(Total T3)\n참고: 1.2–2.7 nmol/L", shape=oval, fillcolor="#9fa8da"]
        Symptom_sc    [label="증상 점수\n(Hypothyroid Symptom Scale\nBillewicz/HYST Score)", shape=oval, fillcolor="#7986cb"]
        LDL_lab       [label="LDL 콜레스테롤\n(목표 <100 mg/dL\n이차성 이상지질혈증)", shape=oval, fillcolor="#9fa8da"]
        BMD_score     [label="골밀도 T점수\n(BMD T-score\n과치료 모니터링)", shape=oval, fillcolor="#9fa8da"]
        QoL_sc        [label="삶의 질\n(ThyDQoL\n치료 만족도)", shape=oval, fillcolor="#7986cb"]
        Anti_TPO_t    [label="항TPO 역가\n(Anti-TPO Titer\n추적 검사)", shape=oval, fillcolor="#9fa8da"]
        Tg_level      [label="티로글로불린\n(Thyroglobulin Level\n갑상선 잔존 조직)", shape=oval, fillcolor="#9fa8da"]
        Dose_adj      [label="용량 조정\n(Dose Adjustment\n4-6주마다 재평가\n0.5 mIU < TSH < 2.5)", shape=box, fillcolor="#5c6bc0", fontcolor=white]
        Subclinical   [label="준임상적 갑저\n(Subclinical Hypothyroidism\nTSH 4.5-10, 정상 T4)", shape=oval, fillcolor="#9fa8da"]
    }

    // =====================================================================
    // EDGES
    // =====================================================================

    // — Hypothalamus internal —
    TRH_neurons -> TRH_syn -> TRH
    TRH -> TRH_portal
    TRH -> TRH_deg [style=dashed, label="분해"]
    Cold_stim -> TRH_neurons [color="#1565c0", label="+"]
    Fasting -> TRH_neurons [color=red, arrowhead=tee, label="−"]
    Stress -> TRH_neurons [color=red, arrowhead=tee, label="−"]
    DA_hypo -> TRH_neurons [color=red, arrowhead=tee, label="−"]
    SST_hypo -> TRH_neurons [color=red, arrowhead=tee, label="−"]

    // — Hypothalamus → Pituitary —
    TRH_portal -> TRH_R [lhead=cluster_pituitary, label="문맥 전달"]

    // — Pituitary internal —
    TRH_R -> Thyrotroph -> TSH_syn -> TSH_glycos -> TSH_bio -> TSH_sec -> TSH
    TSH -> TSH_deg [style=dashed, label="t½≈1h"]
    fT4_fb_pit -> TSH_syn [color=red, arrowhead=tee, label="−"]
    fT3_fb_pit -> TSH_syn [color=red, arrowhead=tee, label="−"]
    FT4 -> fT4_fb_pit
    FT3 -> fT3_fb_pit
    D2 -> fT3_fb_pit [style=dashed, label="pit. T4→T3"]
    TRH -> Prolactin [style=dashed, label="부수 자극"]

    // — Pituitary → Thyroid —
    TSH -> TSHR [label="TSHR 활성화"]

    // — Thyroid internal —
    TSHR -> cAMP_thy [label="Gαs/AC/PKA"]
    cAMP_thy -> NIS [label="발현 ↑"]
    cAMP_thy -> TPO [label="활성 ↑"]
    cAMP_thy -> Tg [label="합성 ↑"]
    cAMP_thy -> Endocytosis [label="Tg 내재화 ↑"]
    Iodine_sup -> Iodide_up
    NIS -> Iodide_up [label="능동 수송"]
    Iodide_up -> Pendrin [label="여포강 방출"]
    DUOX -> TPO [label="H₂O₂ 공급"]
    Pendrin -> TPO [label="I⁻ 유기화"]
    TPO -> MIT [label="Tg-Tyr 요오드화"]
    TPO -> DIT
    MIT -> T3_syn [label="MIT+DIT → T3"]
    DIT -> T4_syn [label="DIT+DIT → T4"]
    Tg -> T4_syn [label="지지체"]
    Tg -> T3_syn [label="지지체"]
    T4_syn -> Follicle
    T3_syn -> Follicle
    Follicle -> Endocytosis
    Endocytosis -> T4_intrathy
    T4_intrathy -> T4_sec
    T4_intrathy -> T3_sec
    Wolff -> NIS [color=red, arrowhead=tee, label="과잉 I⁻ 자동조절"]

    // — Etiology → Thyroid —
    Anti_TPO_Ab -> Hashimoto
    Anti_Tg_Ab -> Hashimoto
    CD8_T -> Hashimoto
    CD4_Th1 -> Hashimoto
    B_cell -> Anti_TPO_Ab
    B_cell -> Anti_Tg_Ab
    Hashimoto -> Follicle [color=red, arrowhead=tee, label="림프구 침윤\n여포 파괴"]
    Hashimoto -> TPO [color=red, arrowhead=tee, label="TPO 억제"]
    Post_Tx -> T4_sec [color=red, arrowhead=tee, style=dashed, label="갑상선 소실"]
    Post_RAI -> Follicle [color=red, arrowhead=tee, style=dashed, label="I-131 파괴"]
    Drug_ind -> TPO [color=red, arrowhead=tee, label="Amiodarone\nLithium"]
    Drug_ind -> NIS [color=red, arrowhead=tee, label="Lithium → I⁻\n방출 억제"]
    Iodine_def -> Iodide_up [color=red, arrowhead=tee, label="요오드 부족"]
    Central_hypo -> TSH [color=red, arrowhead=tee, style=dashed, label="TSH 결핍"]
    Infiltrative -> Follicle [color=red, arrowhead=tee, style=dashed]

    // — Thyroid → Hormone Pool —
    T4_sec -> TT4
    T3_sec -> TT3

    // — Hormone Binding —
    TT4 -> TBG [style=dashed, label="75% bound"]
    TT4 -> TTR [style=dashed, label="10% bound"]
    TT4 -> ALB_bind [style=dashed, label="15% bound"]
    TT4 -> FT4 [label="0.02% free"]
    TT3 -> FT3 [label="0.3% free"]
    TBG_syn -> TBG
    Estrogen_TBG -> TBG_syn [label="↑"]
    Androgens_TBG -> TBG_syn [color=red, arrowhead=tee, label="↓"]
    FT4 -> TR_alpha [label="핵 수용체 결합"]
    FT4 -> TR_beta
    FT3 -> TR_alpha [label="더 강한 결합"]
    FT3 -> TR_beta
    TR_alpha -> TR_nuclear
    TR_beta -> TR_nuclear

    // — Drug PK —
    LT4_dose -> LT4_gut [label="경구 투여"]
    Drug_int -> Ka_LT4 [color=red, arrowhead=tee, label="흡수 ↓"]
    Food_effect -> F_LT4 [label="식이 영향"]
    Ka_LT4 -> LT4_gut
    F_LT4 -> LT4_gut
    LT4_Tmax -> LT4_gut
    LT4_gut -> LT4_central [label="Ka·F 흡수"]
    LT4_central -> LT4_periph [label="k12 (조직 분포)"]
    LT4_periph -> LT4_central [label="k21 (재순환)"]
    Vd_LT4 -> LT4_central
    CL_LT4 -> LT4_central [label="대사·배설"]
    LT4_SS -> LT4_central [style=dashed]
    LT4_central -> TT4 [label="외인성 T4 기여\n(mol. wt 776.9)"]
    LT3_dose -> LT3_gut [label="경구 투여"]
    F_LT3 -> LT3_gut
    CL_LT3 -> LT3_central
    LT3_gut -> LT3_central [label="Ka_LT3 흡수"]
    LT3_central -> TT3 [label="외인성 T3 기여\n(mol. wt 650.9)"]
    Combo_tx -> LT4_dose
    Combo_tx -> LT3_dose

    // — Peripheral Metabolism —
    FT4 -> D1
    FT4 -> D2
    FT4 -> D3
    D1 -> T4_to_T3
    D2 -> T4_to_T3
    D3 -> T4_to_rT3
    T4_to_T3 -> TT3 [label="80%의 T3 공급"]
    T4_to_rT3 -> rT3
    FT3 -> D3 [label="T3→T2"]
    D3 -> T3_to_T2
    Selenium -> D1 [style=dashed]
    Selenium -> D2 [style=dashed]
    Selenium -> D3 [style=dashed]
    T4_halflife -> D1 [style=dashed]
    T3_halflife -> D1 [style=dashed]
    rT3_halflife -> D3 [style=dashed]
    FT4 -> Hepatic_conj -> Enterohepatic
    FT3 -> Hepatic_conj
    TT4 -> Renal_excr [style=dashed]

    // — Cardiovascular Effects —
    TR_nuclear -> Beta_AR [label="β-AR 발현 조절"]
    FT3 -> HR_eff [label="T3 → β-AR\nCa²⁺ 핸들링 ↑"]
    FT3 -> Contractility [label="T3 → MHC-α\nSERCA2 ↑"]
    Beta_AR -> HR_eff
    Contractility -> CO_eff
    HR_eff -> CO_eff
    SV_eff -> CO_eff
    Contractility -> SV_eff
    FT3 -> SVR_eff [color=red, arrowhead=tee, label="T3 → NO ↑\n혈관 이완"]
    SVR_eff -> BP_eff
    FT4 -> LDLR_expr [label="LDLR 전사 ↑"]
    LDLR_expr -> LDL_eff [color=red, arrowhead=tee, label="LDLR ↓ → LDL ↑"]
    LDL_eff -> TC_eff
    TT3 -> TG_eff [color=red, arrowhead=tee, label="LPL 활성 ↓"]
    TT3 -> HDL_eff [color=red, arrowhead=tee]
    LDL_eff -> CV_risk
    TG_eff -> CV_risk
    CO_eff -> Pericardial [style=dashed]
    HR_eff -> QT_prolong [style=dashed, label="서맥 연관"]
    LDL_eff -> LDL_lab
    Homocysteine -> CV_risk

    // — Metabolic Effects —
    TR_nuclear -> BMR_eff [label="UCP 유전자 발현"]
    FT3 -> BMR_eff [label="미토콘드리아\n산화적 인산화 ↑"]
    BMR_eff -> Thermogen
    BMR_eff -> Weight_gain [color=red, arrowhead=tee, label="BMR ↓ → 체중 ↑"]
    FT3 -> Glucose_metab [label="GLUT4 발현"]
    Glucose_metab -> Insulin_sens
    FT3 -> FA_ox [label="β-산화 효소 ↑"]
    FT3 -> Lipogenesis [color=red, arrowhead=tee]
    FT3 -> Na_retention [color=red, arrowhead=tee, label="AVP 증가"]
    Na_retention -> Hyponatremia [style=dashed]
    FT4 -> Carotenemia [style=dashed, label="카로텐 변환 ↓"]
    FT3 -> SHBG_eff
    FT3 -> Homocysteine [color=red, arrowhead=tee, label="메티오닌대사 ↓"]

    // — Neuro Effects —
    TR_nuclear -> Serotoni [label="TPH 발현 조절"]
    TR_nuclear -> Dopamine_CNS [label="TH 발현 조절"]
    FT3 -> Cognition [label="신경 연접\n가소성 ↑"]
    Serotoni -> Depression [color=red, arrowhead=tee]
    Dopamine_CNS -> Depression [color=red, arrowhead=tee]
    FT3 -> Depression [color=red, arrowhead=tee, label="T3 ↓ → 기분 ↓"]
    FT3 -> Fatigue [color=red, arrowhead=tee, label="ATP ↓"]
    FT3 -> DTR_relax [color=red, arrowhead=tee, label="근육 이완 지연"]
    FT3 -> Periph_neuro [style=dashed]
    FT3 -> Sleep_dist [style=dashed]
    FT3 -> Psychosis [color=red, arrowhead=tee, style=dashed]
    Fatigue -> Myx_coma [style=dashed, color=red, label="중증"]
    Myopathy -> Myx_coma [style=dashed, color=red]

    // — Bone & Musculoskeletal —
    TR_nuclear -> Bone_turn [label="OPG/RANKL\n전사 조절"]
    FT3 -> Bone_turn [label="골세포 T3 수용체"]
    Bone_turn -> BMD_eff
    Bone_turn -> Osteocalcin
    Bone_turn -> CTX
    FT3 -> CK_elev [color=red, arrowhead=tee, label="근육 대사 ↓"]
    CK_elev -> Myopathy
    FT3 -> Arthralgia [style=dashed]
    FT3 -> Carpal_tun [style=dashed, label="GAG 침착"]
    FT3 -> Growth_delay [style=dashed]
    BMD_eff -> BMD_score

    // — GI/Skin/Repro —
    FT3 -> GI_mot [label="평활근 수축"]
    GI_mot -> Constipation [color=red, arrowhead=tee]
    FT3 -> Dry_skin [color=red, arrowhead=tee, label="피지·땀샘 ↓"]
    FT3 -> Hair_loss [color=red, arrowhead=tee, label="모발 주기 ↓"]
    FT3 -> Myxedema_skin [color=red, arrowhead=tee, label="GAG 축적"]
    Myxedema_skin -> Periorbital
    Myxedema_skin -> Weight_gain [style=dashed]
    GI_mot -> Ascites [style=dashed]
    Prolactin -> Galactorrhea
    Prolactin -> Menstrual_irr [color=red, arrowhead=tee]
    FT3 -> Menstrual_irr [color=red, arrowhead=tee]
    Menstrual_irr -> Infertility
    FT3 -> Libido_dec [color=red, arrowhead=tee]

    // — Clinical Endpoints Aggregation —
    TSH -> TSH_lab
    FT4 -> FT4_lab
    FT3 -> FT3_lab
    TT4 -> TT4_lab
    TT3 -> TT3_lab
    Anti_TPO_Ab -> Anti_TPO_t
    Tg -> Tg_level
    Fatigue -> Symptom_sc
    Weight_gain -> Symptom_sc
    Constipation -> Symptom_sc
    Depression -> Symptom_sc
    Dry_skin -> Symptom_sc
    Hair_loss -> Symptom_sc
    Myopathy -> Symptom_sc
    DTR_relax -> Symptom_sc
    Symptom_sc -> QoL_sc
    TSH_lab -> Subclinical [style=dashed]

    // — Treatment Feedback Loop (constraint=false to avoid rank cycle) —
    TSH_lab -> Dose_adj [style=dashed, color=purple, constraint=false]
    FT4_lab -> Dose_adj [style=dashed, color=purple, constraint=false]
    Dose_adj -> LT4_dose [color=purple, constraint=false]
}
