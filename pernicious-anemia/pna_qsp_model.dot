digraph PerniciousAnemia_QSP {
  graph [
    label="Pernicious Anemia (악성 빈혈) — QSP Mechanistic Map\nAutoimmune Gastric Atrophy · Cobalamin Deficiency · Megaloblastic Anemia · Neurological Sequelae\nDrug PK/PD: Cyanocobalamin · Hydroxocobalamin · High-dose Oral B12"
    labelloc=t
    fontsize=22
    fontname="Helvetica-Bold"
    splines=ortho
    rankdir=TB
    bgcolor="#F8F9FA"
    nodesep=0.45
    ranksep=0.70
    compound=true
    style=filled
    fillcolor="#F8F9FA"
  ]
  node [fontname="Helvetica" fontsize=10 style="filled,rounded" shape=box]
  edge [fontname="Helvetica" fontsize=8 arrowsize=0.8]

  /* ============================================================
     CLUSTER 1: Genetic & Environmental Risk Factors
     ============================================================ */
  subgraph cluster_genetics {
    label="Genetic & Environmental Risk Factors"
    style=filled fillcolor="#E8F4FD" color="#2980B9" penwidth=2
    fontsize=13 fontname="Helvetica-Bold"

    HLA_DR3   [label="HLA-DR3\n(Autoimmune Risk)" fillcolor="#AED6F1"]
    HLA_DR4   [label="HLA-DR4\n(Autoimmune Risk)" fillcolor="#AED6F1"]
    CTLA4_var [label="CTLA4 Polymorphism\n(T-reg Impairment)" fillcolor="#AED6F1"]
    PTPN22_var[label="PTPN22 Variant\n(Signal Transduction)" fillcolor="#AED6F1"]
    Family_hx [label="Family History\n(PA/Autoimmune)" fillcolor="#AED6F1"]
    H_pylori  [label="H. pylori\n(Molecular Mimicry)" fillcolor="#FDEBD0"]
    EBV_viral [label="EBV / Viral\n(Environmental Trigger)" fillcolor="#FDEBD0"]
    Age_sex   [label="Age >60 / Female Sex\n(Prevalence Peak)" fillcolor="#D5DBDB"]
    Other_AI  [label="Other Autoimmune\n(Thyroid, T1DM, Vitiligo)" fillcolor="#FDEBD0"]
    Env_toxin [label="Environmental / Dietary\n(Nitrous Oxide, Vegan)" fillcolor="#FDEBD0"]
  }

  /* ============================================================
     CLUSTER 2: Gastric Autoimmunity
     ============================================================ */
  subgraph cluster_gastric_autoimmunity {
    label="Gastric Autoimmunity (위자가면역)"
    style=filled fillcolor="#FDEDEC" color="#E74C3C" penwidth=2
    fontsize=13 fontname="Helvetica-Bold"

    Parietal_cell  [label="Gastric Parietal Cell\n(H+/K+ ATPase Source)" fillcolor="#F1948A"]
    HK_ATPase      [label="H+/K+ ATPase\n(Proton Pump)" fillcolor="#F1948A"]
    Chief_cell     [label="Chief Cell\n(Pepsinogen Source)" fillcolor="#FAD7A0"]
    Anti_PC_Ab     [label="Anti-Parietal Cell Ab\n(Type I Ab, 90% PA)" fillcolor="#EC407A" fontcolor=white]
    Anti_IF_Ab_T1  [label="Anti-IF Ab Type I\n(Blocking, 70% PA)" fillcolor="#EC407A" fontcolor=white]
    Anti_IF_Ab_T2  [label="Anti-IF Ab Type II\n(Binding, 35-40% PA)" fillcolor="#EC407A" fontcolor=white]
    CD4_Th1        [label="Autoreactive CD4+\nTh1 Cells" fillcolor="#F1948A"]
    CD8_CTL        [label="CD8+ Cytotoxic T\nLymphocytes" fillcolor="#F1948A"]
    Treg_defect    [label="Regulatory T Cell\nDeficiency" fillcolor="#F1948A"]
    IL17_cells     [label="IL-17 Secreting\nTh17 Cells" fillcolor="#F1948A"]
    IFN_gamma_GA   [label="IFN-γ\n(Th1 Cytokine)" fillcolor="#F8C8C8"]
    TNF_alpha_GA   [label="TNF-α\n(Gastric Mucosa)" fillcolor="#F8C8C8"]
    Complement_act [label="Complement\nActivation (C3/C4)" fillcolor="#F8C8C8"]
    B_cell_PA      [label="Autoreactive B Cells\n(Anti-PC/IF Ab Producers)" fillcolor="#F1948A"]
    Gastric_atrophy[label="Corpus Gastric\nAtrophy (Grade 3-4)" fillcolor="#E74C3C" fontcolor=white]
    Achlorhydria   [label="Achlorhydria\n(pH >4 fasting)" fillcolor="#E74C3C" fontcolor=white]
    Gastrin_high   [label="↑ Serum Gastrin\n(Hypergastrinemia)" fillcolor="#F8C8C8"]
    ECL_hyperplasia[label="ECL Cell\nHyperplasia" fillcolor="#F8C8C8"]
  }

  /* ============================================================
     CLUSTER 3: Dietary B12 & GI Processing
     ============================================================ */
  subgraph cluster_dietary {
    label="Dietary Cobalamin & GI Processing (식이 코발라민 처리)"
    style=filled fillcolor="#E9F7EF" color="#27AE60" penwidth=2
    fontsize=13 fontname="Helvetica-Bold"

    Dietary_Cbl    [label="Dietary Cobalamin\n(Food Protein-Bound B12)" fillcolor="#A9DFBF"]
    Salivary_HC    [label="Salivary Haptocorrin\n(R-Binder, HC)" fillcolor="#A9DFBF"]
    Cbl_HC_complex [label="Cobalamin-Haptocorrin\n(Stomach Complex)" fillcolor="#82E0AA"]
    Gastric_pH     [label="Gastric pH\n(Normal 1-2, PA >4)" fillcolor="#FAD7A0"]
    Pepsinogen     [label="Pepsinogen → Pepsin\n(Protein Digestion)" fillcolor="#A9DFBF"]
    Pancreatic_pr  [label="Pancreatic Proteases\n(Trypsin/Chymotrypsin)" fillcolor="#A9DFBF"]
    Free_Cbl_duo   [label="Free Cobalamin\n(Duodenum)" fillcolor="#A9DFBF"]
    IF_protein     [label="Intrinsic Factor (IF)\n(66 kDa Glycoprotein)" fillcolor="#27AE60" fontcolor=white]
    IF_reduced     [label="↓ IF Production\n(Parietal Cell Loss)" fillcolor="#E74C3C" fontcolor=white]
    IF_Cbl_complex [label="IF-Cobalamin Complex\n(Duodenum/Jejunum)" fillcolor="#27AE60" fontcolor=white]
    IF_blocking_Ab [label="IF Antibody\nBlocking Absorption" fillcolor="#E74C3C" fontcolor=white]
    Ileum_pH_env   [label="Ileal pH 7.4\n(Optimal Cubilin Binding)" fillcolor="#A9DFBF"]
  }

  /* ============================================================
     CLUSTER 4: Ileal Absorption Mechanism
     ============================================================ */
  subgraph cluster_absorption {
    label="Ileal Cobalamin Absorption (회장 흡수)"
    style=filled fillcolor="#EBF5FB" color="#2471A3" penwidth=2
    fontsize=13 fontname="Helvetica-Bold"

    Cubilin_R      [label="Cubilin Receptor\n(CUBN, Ileal Enterocyte)" fillcolor="#85C1E9"]
    Amnionless_R   [label="Amnionless (AMN)\nCo-Receptor" fillcolor="#85C1E9"]
    Cubilin_AMN    [label="Cubam Complex\n(CUBN+AMN)" fillcolor="#5DADE2"]
    IF_Cubilin_bind[label="IF-Cbl Binding\nto Cubam" fillcolor="#5DADE2"]
    IF_Ab_block    [label="Anti-IF Ab Blocks\nCubilin Binding" fillcolor="#E74C3C" fontcolor=white]
    Endocytosis_IEC[label="Receptor-Mediated\nEndocytosis" fillcolor="#85C1E9"]
    Lysosomal_proc [label="Lysosomal Processing\n(IF Degradation)" fillcolor="#85C1E9"]
    Free_Cbl_IEC   [label="Free Cobalamin\n(Enterocyte Cytoplasm)" fillcolor="#5DADE2"]
    MMACHC_IEC     [label="MMACHC Enzyme\n(Cob(III)alamin Reductase)" fillcolor="#5DADE2"]
    MRP1_export    [label="MRP1 Transporter\n(Basolateral Export)" fillcolor="#85C1E9"]
    Megalin_backup [label="Megalin (LRP2)\nBackup Pathway" fillcolor="#AED6F1"]
    Portal_vein    [label="Portal Circulation\n(B12 to Liver)" fillcolor="#5DADE2"]
    Passive_abs    [label="Passive Absorption\n(~1% without IF)" fillcolor="#D6EAF8"]
  }

  /* ============================================================
     CLUSTER 5: Plasma Transport
     ============================================================ */
  subgraph cluster_plasma_transport {
    label="Plasma Cobalamin Transport (혈장 수송)"
    style=filled fillcolor="#F4ECF7" color="#8E44AD" penwidth=2
    fontsize=13 fontname="Helvetica-Bold"

    Plasma_Cbl_total [label="Total Plasma B12\n(Normal: 200-900 pg/mL)" fillcolor="#C39BD3"]
    TC_II            [label="Transcobalamin II\n(TC-II, Active Transport)" fillcolor="#9B59B6" fontcolor=white]
    HoloTC           [label="Holo-Transcobalamin\n(HoloTC, Active B12 ~20%)" fillcolor="#9B59B6" fontcolor=white]
    TC_I             [label="Transcobalamin I\n(Haptocorrin, ~80% plasma)" fillcolor="#C39BD3"]
    TC_III           [label="Transcobalamin III\n(Granulocyte Derived)" fillcolor="#C39BD3"]
    CD320_receptor   [label="CD320 Receptor\n(TC-II Uptake, All Cells)" fillcolor="#C39BD3"]
    Liver_TC_II      [label="Liver TCII Receptor\n(Major Uptake Site)" fillcolor="#C39BD3"]
    Enterohepa_circ  [label="Enterohepatic\nRecirculation (~0.5-9 µg/day)" fillcolor="#C39BD3"]
    MMA_plasma       [label="Methylmalonic Acid\n(MMA, Functional B12 Marker)" fillcolor="#F1948A"]
    tHcy_plasma      [label="Total Homocysteine\n(tHcy, B12+Folate Marker)" fillcolor="#F1948A"]
    HoloTC_diagnostic[label="HoloTC <35 pmol/L\n(Earliest Depletion Marker)" fillcolor="#D2B4DE"]
    Plasma_B12_low   [label="Serum B12 <200 pg/mL\n(Late-Stage Depletion)" fillcolor="#E74C3C" fontcolor=white]
  }

  /* ============================================================
     CLUSTER 6: Intracellular Cobalamin Metabolism
     ============================================================ */
  subgraph cluster_intracellular {
    label="Intracellular Cobalamin Metabolism (세포내 코발라민 대사)"
    style=filled fillcolor="#FEFDE7" color="#D4AC0D" penwidth=2
    fontsize=13 fontname="Helvetica-Bold"

    Cyto_Cbl       [label="Cytoplasmic\nCobalamin" fillcolor="#F9E79F"]
    MMACHC_cyto    [label="MMACHC\n(Cob Reductase)" fillcolor="#F7DC6F"]
    Cob_II         [label="Cob(II)alamin\n(Intermediate)" fillcolor="#F7DC6F"]
    MeCbl          [label="Methylcobalamin\n(Cytoplasm, Methionine Synthase)" fillcolor="#F4D03F"]
    AdoCbl         [label="Adenosylcobalamin\n(Mitochondria, Mutase)" fillcolor="#F4D03F"]
    MetSyn         [label="Methionine Synthase\n(MTR, requires MeCbl)" fillcolor="#D4AC0D" fontcolor=white]
    Methionine_prod[label="Methionine\nProduction" fillcolor="#F9E79F"]
    SAM_prod       [label="S-Adenosylmethionine\n(SAM, Methyl Donor)" fillcolor="#F9E79F"]
    DNA_methyl     [label="DNA Methylation\n(Epigenetic Control)" fillcolor="#F9E79F"]
    MTHFR_enzyme   [label="MTHFR Enzyme\n(5-MTHF → THF Cycle)" fillcolor="#F7DC6F"]
    Folate_trap    [label="Methyl-Folate Trap\n(↑ 5-MTHF, ↓ THF)" fillcolor="#E74C3C" fontcolor=white]
    THF_pool       [label="Tetrahydrofolate\n(THF) Pool" fillcolor="#F9E79F"]
    dTMP_synthesis [label="dTMP Synthesis\n(Thymidylate)" fillcolor="#F9E79F"]
    MutB_enzyme    [label="Methylmalonyl-CoA\nMutase (MUT, AdoCbl)" fillcolor="#D4AC0D" fontcolor=white]
    SuccinylCoA    [label="Succinyl-CoA\n(TCA Cycle Entry)" fillcolor="#F9E79F"]
    MMA_cell       [label="↑ Methylmalonic Acid\n(MutB Dysfunction)" fillcolor="#F1948A"]
    OddFattyAcid   [label="Odd-Chain Fatty Acids\n(Neurotoxic Lipids)" fillcolor="#F1948A"]
  }

  /* ============================================================
     CLUSTER 7: Hematopoiesis & Megaloblastic Anemia
     ============================================================ */
  subgraph cluster_hematopoiesis {
    label="Hematopoiesis & Megaloblastic Anemia (조혈 및 거대아세포 빈혈)"
    style=filled fillcolor="#FFF3E0" color="#E67E22" penwidth=2
    fontsize=13 fontname="Helvetica-Bold"

    HSC            [label="Hematopoietic Stem\nCell (HSC)" fillcolor="#FAD7A0"]
    BFU_E          [label="BFU-E\n(Erythroid Progenitor)" fillcolor="#FAD7A0"]
    CFU_E          [label="CFU-E\n(Committed Progenitor)" fillcolor="#FAD7A0"]
    ProErythro     [label="ProErythroblast\n(Earliest Recognizable)" fillcolor="#FAD7A0"]
    Megaloblast    [label="Megaloblast\n(DNA Synthesis Arrested)" fillcolor="#E74C3C" fontcolor=white]
    NC_dissociation[label="Nuclear-Cytoplasmic\nDissociation" fillcolor="#E74C3C" fontcolor=white]
    DNA_synth_fail [label="↓ DNA Synthesis\n(Thymidylate Deficiency)" fillcolor="#E74C3C" fontcolor=white]
    Ineff_eryth    [label="Ineffective\nErythropoiesis" fillcolor="#E74C3C" fontcolor=white]
    Intramedullary_hem[label="Intramedullary\nHemolysis" fillcolor="#E74C3C" fontcolor=white]
    Macrocyte      [label="Macrocyte / Macro-\nOvalocyte (MCV >100)" fillcolor="#E67E22" fontcolor=white]
    HypersegNeutro [label="Hypersegmented\nNeutrophil (≥5 lobes)" fillcolor="#E67E22" fontcolor=white]
    EPO_level      [label="Erythropoietin\n(↑ EPO Response)" fillcolor="#FAD7A0"]
    Reticulocyte   [label="Reticulocyte Response\n(Crisis: Day 4-10)" fillcolor="#FAD7A0"]
    Megakaryo_abn  [label="Giant Megakaryocytes\n(Thrombocytopenia)" fillcolor="#FDEBD0"]
    LDH_high       [label="↑ LDH\n(Intramedullary Hemolysis)" fillcolor="#FAD7A0"]
    Indirect_bili  [label="↑ Indirect Bilirubin\n(Hemolysis Marker)" fillcolor="#FAD7A0"]
    Iron_cycling   [label="Iron Cycling\n(Serum Fe Normal/↑)" fillcolor="#FAD7A0"]
  }

  /* ============================================================
     CLUSTER 8: Neurological Effects (SCD)
     ============================================================ */
  subgraph cluster_neurological {
    label="Neurological Sequelae — Subacute Combined Degeneration (신경계 합병증)"
    style=filled fillcolor="#E8F8F5" color="#1ABC9C" penwidth=2
    fontsize=13 fontname="Helvetica-Bold"

    Myelin_synth   [label="Myelin Synthesis\n(Requires MeCbl/AdoCbl)" fillcolor="#A2D9CE"]
    MBP_synthesis  [label="Myelin Basic Protein\n(MBP, DNA Methylation)" fillcolor="#A2D9CE"]
    SAM_myelin     [label="SAM → Methyl Groups\n(Myelin Maintenance)" fillcolor="#A2D9CE"]
    SCD_spinal     [label="Subacute Combined\nDegeneration (SCD)" fillcolor="#1ABC9C" fontcolor=white]
    Dorsal_col_dmg [label="Dorsal Column\nDamage (Proprioception)" fillcolor="#1ABC9C" fontcolor=white]
    Lateral_col_dmg[label="Corticospinal Tract\nDamage (Motor)" fillcolor="#1ABC9C" fontcolor=white]
    Peripheral_np  [label="Peripheral Neuropathy\n(Sensory, Glove-Stocking)" fillcolor="#1ABC9C" fontcolor=white]
    Neuro_toxic_met[label="Neurotoxic Metabolites\n(MMA, Odd-Chain FA)" fillcolor="#E74C3C" fontcolor=white]
    Cognitive_imp  [label="Cognitive Impairment\n(Dementia, B12 Deficiency)" fillcolor="#A2D9CE"]
    Optic_np       [label="Optic Neuropathy\n(Vision Loss)" fillcolor="#A2D9CE"]
    Neuro_score    [label="Neurological Disability\nScore (0-10 scale)" fillcolor="#76D7C4"]
    Lhermitte_sign [label="Lhermitte Sign\n(Electric Shock Sensation)" fillcolor="#A2D9CE"]
    Romberg_test   [label="Romberg Test\n(Balance / Proprioception)" fillcolor="#A2D9CE"]
  }

  /* ============================================================
     CLUSTER 9: Drug PK/PD
     ============================================================ */
  subgraph cluster_drug_pkpd {
    label="Drug PK/PD — Cobalamin Supplementation (약물 PK/PD)"
    style=filled fillcolor="#F9EBEA" color="#C0392B" penwidth=2
    fontsize=13 fontname="Helvetica-Bold"

    CN_B12_IM      [label="Cyanocobalamin\n(IM, 1000 µg dose)" fillcolor="#F1948A"]
    OH_B12_IM      [label="Hydroxocobalamin\n(IM, 1000 µg dose)" fillcolor="#F1948A"]
    CN_B12_oral    [label="Cyanocobalamin\n(Oral, 1000-2000 µg/day)" fillcolor="#FAD7A0"]
    MeCbl_oral     [label="Methylcobalamin\n(Oral, 1500 µg/day)" fillcolor="#FAD7A0"]
    Sublingua_B12  [label="Sublingual B12\n(Buccal Absorption)" fillcolor="#FAD7A0"]
    Nasal_B12      [label="Intranasal Cyano-\ncobalamin (Nascobal)" fillcolor="#FAD7A0"]
    IM_depot       [label="IM Depot\n(Muscle Absorption)" fillcolor="#F1948A"]
    IM_Ka          [label="Ka (IM)\n~0.3-0.5 h⁻¹" fillcolor="#F8C8C8"]
    Oral_passive_F [label="Passive Oral F\n(~1%, IF-independent)" fillcolor="#F8C8C8"]
    Vd_B12         [label="Vd: ~50 L/kg\n(Wide Distribution)" fillcolor="#F8C8C8"]
    t_half_plasma  [label="t½ Plasma: ~6h\n(TC-II bound)" fillcolor="#F8C8C8"]
    Renal_excretion[label="Renal Excretion\n(Excess Free B12)" fillcolor="#F8C8C8"]
    CL_B12         [label="Clearance\n~0.035 L/h/kg" fillcolor="#F8C8C8"]
    Loading_dose   [label="Loading: 1000 µg IM\nDaily × 7 Days" fillcolor="#C0392B" fontcolor=white]
    Maintenance    [label="Maintenance: 1000 µg\nIM Monthly" fillcolor="#C0392B" fontcolor=white]
  }

  /* ============================================================
     CLUSTER 10: Clinical Endpoints & Biomarkers
     ============================================================ */
  subgraph cluster_endpoints {
    label="Clinical Endpoints & Biomarkers (임상 지표)"
    style=filled fillcolor="#F0F3F4" color="#566573" penwidth=2
    fontsize=13 fontname="Helvetica-Bold"

    Hb_level       [label="Hemoglobin\n(g/dL, Normal: M>13, F>12)" fillcolor="#ABB2B9"]
    MCV_value      [label="MCV (fL)\n(Normal 80-100, PA >100)" fillcolor="#ABB2B9"]
    MCHC_value     [label="MCHC\n(Normal or Slightly ↓)" fillcolor="#ABB2B9"]
    RDW_value      [label="RDW\n(↑, Anisocytosis)" fillcolor="#ABB2B9"]
    Retic_count    [label="Reticulocyte Count\n(Crisis Response)" fillcolor="#ABB2B9"]
    Serum_B12_level[label="Serum B12 <200 pg/mL\n(Deficiency Threshold)" fillcolor="#566573" fontcolor=white]
    HoloTC_level   [label="HoloTC <35 pmol/L\n(Functional Deficiency)" fillcolor="#566573" fontcolor=white]
    MMA_level_EP   [label="MMA >0.4 µmol/L\n(Functional B12 Deficiency)" fillcolor="#566573" fontcolor=white]
    Hcy_level_EP   [label="Homocysteine >15 µmol/L\n(B12+Folate Deficiency)" fillcolor="#566573" fontcolor=white]
    Gastrin_EP     [label="Serum Gastrin >100 pg/mL\n(Achlorhydria Response)" fillcolor="#ABB2B9"]
    AntiIF_titer   [label="Anti-IF Ab Titer\n(Diagnostic, 70% Sens)" fillcolor="#ABB2B9"]
    AntiPC_titer   [label="Anti-PC Ab Titer\n(Sensitive, 90%, Low Spec)" fillcolor="#ABB2B9"]
    Gastric_endosc [label="Gastric Endoscopy\n(Corpus Atrophy Grade)" fillcolor="#ABB2B9"]
    Schilling_test [label="Schilling Test\n(Historical, Replaced)" fillcolor="#ABB2B9"]
    Clinical_remiss[label="Clinical Remission\n(Hb Normal + Neuro Stable)" fillcolor="#2ECC71" fontcolor=white]
  }

  /* ============================================================
     CLUSTER 11: Comorbidities & Long-term Complications
     ============================================================ */
  subgraph cluster_complications {
    label="Long-term Complications & Comorbidities (장기 합병증)"
    style=filled fillcolor="#FDFEFE" color="#7F8C8D" penwidth=2
    fontsize=13 fontname="Helvetica-Bold"

    Gastric_ca_risk[label="Gastric Cancer Risk\n(↑ 2-3× vs General Pop)" fillcolor="#E74C3C" fontcolor=white]
    Gastric_NET    [label="Gastric Carcinoid\n(ECL Hyperplasia → NET)" fillcolor="#E74C3C" fontcolor=white]
    CVD_risk       [label="↑ Cardiovascular Risk\n(↑ Homocysteine)" fillcolor="#F1948A"]
    DVT_risk       [label="Venous Thromboembolism\n(Hyperhomocysteinemia)" fillcolor="#F1948A"]
    Other_AI_assoc [label="Assoc. Autoimmune\n(Hashimoto, T1DM, RA)" fillcolor="#FDEBD0"]
    Bone_density   [label="Reduced Bone Density\n(B12 Deficiency Effects)" fillcolor="#D5DBDB"]
    Infertility    [label="Female Infertility\n(DNA Synthesis Impaired)" fillcolor="#D5DBDB"]
    Monitoring_endosc[label="Endoscopic Surveillance\n(Every 3-5 Years)" fillcolor="#D5DBDB"]
  }

  /* ============================================================
     CROSS-CLUSTER EDGES
     ============================================================ */

  // Genetics → Gastric Autoimmunity
  HLA_DR3   -> Anti_PC_Ab  [label="predispose" color="#2980B9"]
  HLA_DR4   -> Anti_PC_Ab  [label="predispose" color="#2980B9"]
  CTLA4_var -> Treg_defect [label="impairs" color="#2980B9"]
  PTPN22_var-> CD4_Th1     [label="activates" color="#2980B9"]
  H_pylori  -> Anti_PC_Ab  [label="molecular mimicry\n(H+/K+ ATPase)" color="#E67E22" style=dashed]
  EBV_viral -> CD4_Th1     [label="triggers" color="#E67E22" style=dashed]
  Family_hx -> Anti_PC_Ab  [label="heritable risk" color="#2980B9"]
  Other_AI  -> Anti_PC_Ab  [label="co-occurrence" color="#7F8C8D" style=dashed]
  Age_sex   -> Gastric_atrophy [label="age-related\ndecline" color="#7F8C8D"]

  // Gastric Autoimmunity internal
  Anti_PC_Ab  -> HK_ATPase     [label="targets" color="#E74C3C" arrowhead=tee]
  Anti_PC_Ab  -> Parietal_cell [label="destroys" color="#E74C3C" arrowhead=tee style=bold]
  CD4_Th1     -> CD8_CTL       [label="activates" color="#C0392B"]
  CD8_CTL     -> Parietal_cell [label="cytolysis" color="#C0392B" style=bold]
  Treg_defect -> CD4_Th1       [label="fails to suppress" color="#C0392B" arrowhead=tee]
  IL17_cells  -> Gastric_atrophy [label="tissue damage" color="#C0392B"]
  IFN_gamma_GA -> Parietal_cell [label="induces apoptosis" color="#C0392B"]
  TNF_alpha_GA -> Gastric_atrophy [label="promotes" color="#C0392B"]
  Complement_act -> Parietal_cell [label="MAC formation" color="#C0392B"]
  B_cell_PA   -> Anti_PC_Ab    [label="produces" color="#C0392B"]
  B_cell_PA   -> Anti_IF_Ab_T1 [label="produces" color="#C0392B"]
  B_cell_PA   -> Anti_IF_Ab_T2 [label="produces" color="#C0392B"]
  Parietal_cell -> Gastric_atrophy [label="progressive loss" color="#E74C3C" style=bold]
  Gastric_atrophy -> Achlorhydria  [label="→" color="#E74C3C" style=bold]
  Gastric_atrophy -> IF_reduced    [label="→" color="#E74C3C" style=bold]
  Achlorhydria    -> Gastrin_high  [label="→ G-cell reflex" color="#E67E22"]
  Gastrin_high    -> ECL_hyperplasia [label="trophic effect" color="#E67E22"]

  // Dietary Processing
  Dietary_Cbl -> Salivary_HC    [label="binds" color="#27AE60"]
  Salivary_HC -> Cbl_HC_complex [label="forms" color="#27AE60"]
  Cbl_HC_complex -> Gastric_pH  [label="stable at" color="#27AE60"]
  Pepsinogen  -> Cbl_HC_complex [label="pepsin degrades\nfood protein" color="#27AE60"]
  Pancreatic_pr -> Cbl_HC_complex [label="releases Cbl\nfrom HC" color="#27AE60"]
  Pancreatic_pr -> Free_Cbl_duo [label="generates" color="#27AE60"]
  IF_protein   -> IF_Cbl_complex [label="binds free Cbl" color="#27AE60" style=bold]
  IF_reduced   -> IF_protein    [label="reduces" color="#E74C3C" arrowhead=tee]
  Anti_IF_Ab_T1 -> IF_Cbl_complex [label="blocks formation" color="#E74C3C" arrowhead=tee]
  Achlorhydria  -> Gastric_pH   [label="raises" color="#E74C3C"]
  Gastric_pH    -> IF_protein   [label="↑pH impairs\nrelease" color="#E74C3C" arrowhead=tee style=dashed]
  Free_Cbl_duo -> IF_Cbl_complex [label="combines with IF" color="#27AE60"]

  // Absorption
  IF_Cbl_complex -> IF_Cubilin_bind [label="→ ileum" color="#2471A3" style=bold]
  Cubilin_R    -> Cubilin_AMN   [label="co-assembles" color="#2471A3"]
  Amnionless_R -> Cubilin_AMN   [label="co-assembles" color="#2471A3"]
  Cubilin_AMN  -> IF_Cubilin_bind [label="binds" color="#2471A3" style=bold]
  Anti_IF_Ab_T2 -> IF_Cubilin_bind [label="blocks" color="#E74C3C" arrowhead=tee]
  IF_Ab_block  -> IF_Cubilin_bind  [label="competes" color="#E74C3C" arrowhead=tee]
  IF_Cubilin_bind -> Endocytosis_IEC [label="triggers" color="#2471A3"]
  Endocytosis_IEC -> Lysosomal_proc [label="→" color="#2471A3"]
  Lysosomal_proc -> Free_Cbl_IEC [label="releases Cbl" color="#2471A3"]
  Free_Cbl_IEC -> MMACHC_IEC    [label="processed by" color="#2471A3"]
  MMACHC_IEC -> MRP1_export     [label="exports" color="#2471A3"]
  MRP1_export -> Portal_vein    [label="to portal\ncirculation" color="#2471A3"]
  Passive_abs -> Portal_vein    [label="direct\n(1% dose)" color="#7F8C8D" style=dashed]
  Megalin_backup -> Free_Cbl_IEC [label="alternative\nuptake" color="#AED6F1" style=dashed]
  Ileum_pH_env -> IF_Cubilin_bind [label="optimal pH" color="#27AE60"]

  // Plasma Transport
  Portal_vein    -> Plasma_Cbl_total [label="delivers" color="#8E44AD"]
  Plasma_Cbl_total -> TC_II         [label="~20% binds" color="#8E44AD"]
  Plasma_Cbl_total -> TC_I          [label="~80% binds" color="#8E44AD"]
  TC_II  -> HoloTC                  [label="forms" color="#8E44AD" style=bold]
  HoloTC -> CD320_receptor          [label="cellular uptake" color="#8E44AD" style=bold]
  HoloTC -> Liver_TC_II             [label="hepatic uptake" color="#8E44AD"]
  TC_I   -> Enterohepa_circ         [label="recycled via\nbile" color="#8E44AD"]
  Plasma_B12_low  -> MMA_plasma     [label="↓B12 → ↑MMA" color="#E74C3C"]
  Plasma_B12_low  -> tHcy_plasma    [label="↓B12 → ↑Hcy" color="#E74C3C"]
  HoloTC_diagnostic -> Plasma_B12_low [label="precedes" color="#8E44AD" style=dashed]

  // Intracellular Metabolism
  CD320_receptor -> Cyto_Cbl        [label="delivers Cbl" color="#D4AC0D"]
  Cyto_Cbl -> MMACHC_cyto           [label="processed" color="#D4AC0D"]
  MMACHC_cyto -> Cob_II             [label="reduces" color="#D4AC0D"]
  Cob_II  -> MeCbl                  [label="cytoplasm\nactivation" color="#D4AC0D"]
  Cob_II  -> AdoCbl                 [label="mitochondria\nactivation" color="#D4AC0D"]
  MeCbl   -> MetSyn                 [label="cofactor" color="#D4AC0D" style=bold]
  MetSyn  -> Methionine_prod        [label="catalyzes\nHcy → Met" color="#D4AC0D"]
  Methionine_prod -> SAM_prod       [label="→" color="#D4AC0D"]
  SAM_prod -> DNA_methyl            [label="methyl donor" color="#D4AC0D"]
  MTHFR_enzyme -> Folate_trap       [label="5-MTHF\naccumulates" color="#E74C3C"]
  Folate_trap -> THF_pool           [label="↓ THF" color="#E74C3C" arrowhead=tee]
  THF_pool -> dTMP_synthesis        [label="required for" color="#D4AC0D"]
  AdoCbl  -> MutB_enzyme            [label="cofactor" color="#D4AC0D" style=bold]
  MutB_enzyme -> SuccinylCoA        [label="MMA → Suc-CoA" color="#D4AC0D"]
  MutB_enzyme -> MMA_cell           [label="↑ if deficient" color="#E74C3C" arrowhead=tee style=dashed]
  MMA_cell -> OddFattyAcid          [label="→" color="#E74C3C"]

  // Hematopoiesis
  dTMP_synthesis -> DNA_synth_fail  [label="↓ thymidylate\n→ arrested" color="#E74C3C" arrowhead=tee]
  DNA_synth_fail -> Megaloblast     [label="causes" color="#E74C3C" style=bold]
  Megaloblast -> NC_dissociation    [label="→" color="#E74C3C"]
  Megaloblast -> Ineff_eryth        [label="→" color="#E74C3C"]
  Ineff_eryth -> Intramedullary_hem [label="→" color="#E74C3C"]
  Intramedullary_hem -> LDH_high    [label="releases" color="#E67E22"]
  Intramedullary_hem -> Indirect_bili [label="releases" color="#E67E22"]
  HSC -> BFU_E                      [label="differentiates" color="#E67E22"]
  BFU_E -> CFU_E                    [label="matures" color="#E67E22"]
  CFU_E -> ProErythro               [label="matures" color="#E67E22"]
  ProErythro -> Megaloblast         [label="arrested\n(B12 def)" color="#E74C3C"]
  EPO_level -> BFU_E                [label="stimulates" color="#E67E22"]
  Reticulocyte -> Macrocyte         [label="after treatment\nmatures to" color="#27AE60"]
  Macrocyte -> HypersegNeutro       [label="concurrent" color="#E67E22" style=dashed]

  // Neurological
  OddFattyAcid -> Neuro_toxic_met   [label="incorporated\ninto myelin" color="#1ABC9C"]
  MMA_cell -> Neuro_toxic_met       [label="directly toxic" color="#E74C3C"]
  Neuro_toxic_met -> SCD_spinal     [label="→" color="#1ABC9C" style=bold]
  SAM_prod -> SAM_myelin            [label="→" color="#1ABC9C"]
  SAM_myelin -> Myelin_synth        [label="enables" color="#1ABC9C"]
  SAM_myelin -> MBP_synthesis       [label="methylates" color="#1ABC9C"]
  Myelin_synth -> SCD_spinal        [label="↓ → degeneration" color="#E74C3C" arrowhead=tee]
  SCD_spinal -> Dorsal_col_dmg      [label="→" color="#1ABC9C" style=bold]
  SCD_spinal -> Lateral_col_dmg     [label="→" color="#1ABC9C" style=bold]
  SCD_spinal -> Peripheral_np       [label="→" color="#1ABC9C" style=bold]
  Dorsal_col_dmg -> Romberg_test    [label="→" color="#1ABC9C"]
  Lateral_col_dmg -> Cognitive_imp  [label="→" color="#1ABC9C" style=dashed]
  Peripheral_np -> Lhermitte_sign   [label="→" color="#1ABC9C"]
  SCD_spinal -> Neuro_score         [label="scores" color="#1ABC9C"]
  Optic_np -> Neuro_score           [label="scores" color="#1ABC9C"]

  // Drug PK
  CN_B12_IM -> IM_depot             [label="injected" color="#C0392B" style=bold]
  OH_B12_IM -> IM_depot             [label="injected" color="#C0392B" style=bold]
  IM_depot  -> Plasma_Cbl_total     [label="Ka: 0.4 h⁻¹\nabsorption" color="#C0392B" style=bold]
  CN_B12_oral -> Oral_passive_F     [label="1% passive" color="#C0392B"]
  MeCbl_oral -> Oral_passive_F      [label="1% passive" color="#C0392B"]
  Oral_passive_F -> Portal_vein     [label="→ plasma" color="#C0392B"]
  Plasma_Cbl_total -> Vd_B12        [label="distributes\n(Vd ~50 L/kg)" color="#8E44AD"]
  Plasma_Cbl_total -> t_half_plasma [label="t½ ~6h" color="#8E44AD"]
  Plasma_Cbl_total -> Renal_excretion [label="excess excreted" color="#8E44AD"]
  CL_B12 -> Renal_excretion         [label="governs" color="#8E44AD"]
  Loading_dose -> CN_B12_IM         [label="regimen" color="#C0392B" style=bold]
  Maintenance -> CN_B12_IM          [label="regimen" color="#C0392B"]
  Nasal_B12 -> Plasma_Cbl_total     [label="intranasal\nabsorption" color="#C0392B" style=dashed]
  Sublingua_B12 -> Plasma_Cbl_total [label="buccal\nabsorption" color="#C0392B" style=dashed]

  // Endpoints
  Hb_level     -> Clinical_remiss  [label="target Hb ≥12" color="#566573"]
  Neuro_score  -> Clinical_remiss  [label="stable neuro" color="#566573"]
  Serum_B12_level -> HoloTC_level  [label="parallel" color="#566573" style=dashed]
  MMA_level_EP -> Hcy_level_EP     [label="co-elevated" color="#566573" style=dashed]
  AntiIF_titer -> Serum_B12_level  [label="correlates with" color="#566573" style=dashed]
  Gastric_endosc -> Gastric_EP_score [label="documents" color="#566573"]
  Macrocyte -> MCV_value           [label="↑ MCV" color="#E67E22" style=bold]
  Ineff_eryth -> Hb_level          [label="↓ Hb" color="#E74C3C" arrowhead=tee style=bold]

  // Complications
  ECL_hyperplasia -> Gastric_NET   [label="→ carcinoid" color="#7F8C8D"]
  Gastric_atrophy -> Gastric_ca_risk [label="→ gastric cancer" color="#7F8C8D"]
  tHcy_plasma -> CVD_risk          [label="endothelial\ndamage" color="#7F8C8D"]
  tHcy_plasma -> DVT_risk          [label="thrombogenic" color="#7F8C8D"]
  Anti_PC_Ab  -> Other_AI_assoc    [label="overlap\nsyndromes" color="#7F8C8D" style=dashed]

  // Treatment effect arrows
  CN_B12_IM -> Plasma_Cbl_total    [label="rapidly replenishes" color="#27AE60" style=bold]
  Plasma_Cbl_total -> Reticulocyte [label="triggers crisis\n(Day 4-10)" color="#27AE60" style=bold]
  Reticulocyte -> Hb_level         [label="restores" color="#27AE60" style=bold]
  Plasma_Cbl_total -> MMA_plasma   [label="↓ MMA" color="#27AE60" arrowhead=tee]
  Plasma_Cbl_total -> tHcy_plasma  [label="↓ Hcy" color="#27AE60" arrowhead=tee]
  Plasma_Cbl_total -> Neuro_score  [label="stabilizes\n(partial recovery)" color="#27AE60"]

  // Hidden node for layout
  Gastric_EP_score [label="Endoscopic\nAtrophy Score" fillcolor="#ABB2B9" style="filled,rounded"]
}
