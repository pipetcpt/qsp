digraph PBC_QSP {
  graph [
    label="Primary Biliary Cholangitis (PBC) — Quantitative Systems Pharmacology Map\nGenerated: 2026-06-17 | Version 1.0",
    labelloc=t, labeljust=c,
    fontname="Helvetica", fontsize=22, fontcolor="#1a1a2e",
    bgcolor="#f8f9fa",
    layout=fdp, K=1.2, overlap=prism, splines=curved,
    compound=true
  ]
  node [fontname="Helvetica", fontsize=10, style="filled,rounded", shape=box, margin="0.15,0.08"]
  edge [fontname="Helvetica", fontsize=8, arrowsize=0.7]

  // ─────────────────────────────────────────────────────────────────────
  // CLUSTER 1: Genetic & Environmental Triggers
  // ─────────────────────────────────────────────────────────────────────
  subgraph cluster_genetic {
    label="① Genetic & Environmental Triggers"
    style=filled; fillcolor="#e8f4f8"; color="#2196F3"; penwidth=2
    fontname="Helvetica-Bold"; fontsize=13; fontcolor="#2196F3"

    HLA_DRB1 [label="HLA-DRB1*08\n(Risk allele)", fillcolor="#bbdefb"]
    IL12A_gene [label="IL12A gene\nvariant (rs1131699)", fillcolor="#bbdefb"]
    IL12RB2_gene [label="IL12RB2 gene\nvariant", fillcolor="#bbdefb"]
    STAT4_gene [label="STAT4 gene\n(rs7574865)", fillcolor="#bbdefb"]
    CD80_gene [label="CD80/CD86\nco-stimulation genes", fillcolor="#bbdefb"]
    CTLA4_gene [label="CTLA4 gene\nvariant", fillcolor="#bbdefb"]
    IRF5_gene [label="IRF5 gene\n(interferon regulatory)", fillcolor="#bbdefb"]
    IKBKE_gene [label="IKBKE/TNFSF15\ngene loci", fillcolor="#bbdefb"]
    Xenobiotic_trigger [label="Xenobiotics\n(halothane, DBCP,\ntrichloroethylene)", fillcolor="#ffcdd2"]
    Infection_trigger [label="Infectious triggers\n(Novosphingobium,\nE. coli, Lactobacillus)", fillcolor="#ffcdd2"]
    Molecular_mimicry [label="Molecular mimicry\n(PDC-E2 cross-reactivity\nwith microbial antigens)", fillcolor="#ffccbc"]
    Gut_dysbiosis [label="Gut microbiome\ndysbiosis", fillcolor="#ffccbc"]
    Epigenetic_changes [label="Epigenetic dysregulation\n(DNA methylation,\nhistone modification)", fillcolor="#f8bbd0"]
    X_chromosome [label="X chromosome\nmonosomy/dosage\n(female predominance 9:1)", fillcolor="#f8bbd0"]
  }

  // ─────────────────────────────────────────────────────────────────────
  // CLUSTER 2: Innate Immune Activation
  // ─────────────────────────────────────────────────────────────────────
  subgraph cluster_innate {
    label="② Innate Immune System Activation"
    style=filled; fillcolor="#fff3e0"; color="#FF9800"; penwidth=2
    fontname="Helvetica-Bold"; fontsize=13; fontcolor="#FF9800"

    pDC_resting [label="Plasmacytoid DC\n(pDC, resting)", fillcolor="#fff9c4"]
    pDC_activated [label="pDC activated\n(TLR7/TLR9-driven)", fillcolor="#f57f17", fontcolor=white]
    TLR7_TLR9 [label="TLR7 / TLR9\n(endosomal PRRs)", fillcolor="#ffe082"]
    Type_I_IFN [label="Type I IFN\n(IFN-α/β)", fillcolor="#ffb300", fontcolor=white]
    IFN_signaling [label="IFNAR → JAK1/TYK2\n→ STAT1/STAT2/IRF9", fillcolor="#ffe082"]
    NK_cells [label="NK cells\n(cytotoxicity)", fillcolor="#ffe0b2"]
    NKT_cells [label="NKT cells\n(CD1d-restricted)", fillcolor="#ffe0b2"]
    Kupffer_cells [label="Kupffer cells\n(liver macrophage M1)", fillcolor="#ff8f00", fontcolor=white]
    NLRP3_inflammasome [label="NLRP3 inflammasome\n(activation by BAs)", fillcolor="#ffb74d"]
    IL18_innate [label="IL-18\n(alarmin)", fillcolor="#ffe082"]
    IL1b_innate [label="IL-1β\n(NLRP3 product)", fillcolor="#ffb74d"]
    TNFa_macro [label="TNF-α\n(Kupffer/macrophage)", fillcolor="#ff8f00", fontcolor=white]
    IL6_macro [label="IL-6\n(pleiotropic)", fillcolor="#ffe082"]
    Complement_activation [label="Complement pathway\n(C3/C4 activation)", fillcolor="#fff9c4"]
    mDC [label="Myeloid DC\n(antigen presentation)", fillcolor="#ffe0b2"]
    ILC_cells [label="ILC1 / ILC2\n(innate lymphoid)", fillcolor="#ffe0b2"]
  }

  // ─────────────────────────────────────────────────────────────────────
  // CLUSTER 3: Adaptive Immune Response
  // ─────────────────────────────────────────────────────────────────────
  subgraph cluster_adaptive {
    label="③ Adaptive Immune Response (Loss of Tolerance)"
    style=filled; fillcolor="#fce4ec"; color="#E91E63"; penwidth=2
    fontname="Helvetica-Bold"; fontsize=13; fontcolor="#E91E63"

    AMA_IgM [label="AMA (IgM class)\nAnti-mitochondrial Ab\n(≥95% sensitivity)", fillcolor="#f48fb1"]
    AMA_IgG [label="AMA (IgG class)\nAnti-PDC-E2 IgG", fillcolor="#f48fb1"]
    AntiSp100 [label="ANA anti-sp100\n(sp100 nuclear antigen)", fillcolor="#f8bbd0"]
    AntiGp210 [label="ANA anti-gp210\n(nuclear pore complex)", fillcolor="#f8bbd0"]
    B_cells [label="B lymphocytes\n(autoreactive)", fillcolor="#e91e63", fontcolor=white]
    Plasma_cells [label="Plasma cells\n(IgM hypersecretion)", fillcolor="#e91e63", fontcolor=white]
    IgM_elevated [label="Serum IgM↑↑\n(hallmark biomarker)", fillcolor="#f48fb1"]
    Th1_cells [label="CD4+ Th1 cells\n(IFN-γ dominant)", fillcolor="#ad1457", fontcolor=white]
    IFNg_Th1 [label="IFN-γ\n(Th1 effector)", fillcolor="#f48fb1"]
    Th17_cells [label="CD4+ Th17 cells\n(IL-17 axis)", fillcolor="#e91e63", fontcolor=white]
    IL17_Th17 [label="IL-17A / IL-21\n(Th17 effectors)", fillcolor="#f48fb1"]
    IL23_axis [label="IL-23/IL-12 axis\n(Th17 polarization)", fillcolor="#f8bbd0"]
    Treg_cells [label="Foxp3+ Treg\n(suppression defect)", fillcolor="#f06292"]
    IL10_Treg [label="IL-10 / TGF-β\n(Treg output, reduced)", fillcolor="#fce4ec"]
    CTL_CD8 [label="CD8+ CTL\n(cytotoxic T cells)", fillcolor="#c2185b", fontcolor=white]
    Perforin_GrzB [label="Perforin/Granzyme B\n(CTL effectors)", fillcolor="#f8bbd0"]
    CXCR3_homing [label="CXCR3-CXCL10\n(effector T cell homing\nto portal tracts)", fillcolor="#fce4ec"]
    Tfh_cells [label="Tfh cells\n(B cell help for AMA)", fillcolor="#f48fb1"]
    Germinal_center [label="Germinal center\n(AMA class switch)", fillcolor="#fce4ec"]
  }

  // ─────────────────────────────────────────────────────────────────────
  // CLUSTER 4: Cholangiocyte Biology & Damage
  // ─────────────────────────────────────────────────────────────────────
  subgraph cluster_cholangiocyte {
    label="④ Cholangiocyte (Biliary Epithelial Cell) Biology"
    style=filled; fillcolor="#e8eaf6"; color="#3F51B5"; penwidth=2
    fontname="Helvetica-Bold"; fontsize=13; fontcolor="#3F51B5"

    BEC [label="Biliary Epithelial Cells\n(Cholangiocytes)", fillcolor="#9fa8da"]
    PDCE2_exposure [label="PDC-E2 surface exposure\n(apotopes on BEC\nafter apoptosis)", fillcolor="#7986cb"]
    Glutathione_defect [label="Impaired GSH secretion\nin bile (unique to BEC)\n→ apotope persistence", fillcolor="#7986cb"]
    BEC_apoptosis [label="BEC apoptosis\n(FasL/TRAIL/CTL)", fillcolor="#3949ab", fontcolor=white]
    FasL_TRAIL [label="FasL / TRAIL\n(death receptor signals)", fillcolor="#7986cb"]
    BEC_senescence [label="BEC senescence\n(p21/p16↑, SA-β-gal+)", fillcolor="#9fa8da"]
    SASP [label="SASP\n(Senescence-Associated\nSecretory Phenotype)", fillcolor="#7986cb"]
    IL8_CXCL1 [label="IL-8 / CXCL1\n(SASP chemokines)", fillcolor="#c5cae9"]
    CXCL16_BEC [label="CXCL16\n(NKT cell chemoattractant)", fillcolor="#c5cae9"]
    MHC_upregulation [label="MHC-I upregulation\n(IFN-γ → CTL target)", fillcolor="#9fa8da"]
    AQP1_water [label="AQP1 (Aquaporin-1)\n(bile ductule water transport)", fillcolor="#c5cae9"]
    Cholangiocyte_secretion [label="Bicarbonate umbrella\n(HCO₃⁻ secretion\nviaAE2/CFTR/AQP1)", fillcolor="#9fa8da"]
    Ductopenia [label="Ductopenia\n(vanishing bile duct\nsyndrome, F3-F4)", fillcolor="#283593", fontcolor=white]
    AE2_defect [label="AE2 (SLC4A2) defect\n(anion exchanger\ndownregulation in PBC)", fillcolor="#7986cb"]
    Bile_duct_repair [label="Biliary progenitors\n(ductular reaction)", fillcolor="#c5cae9"]
  }

  // ─────────────────────────────────────────────────────────────────────
  // CLUSTER 5: Bile Acid Metabolism & Transport
  // ─────────────────────────────────────────────────────────────────────
  subgraph cluster_bile_acid {
    label="⑤ Bile Acid Metabolism & Enterohepatic Circulation"
    style=filled; fillcolor="#e0f2f1"; color="#009688"; penwidth=2
    fontname="Helvetica-Bold"; fontsize=13; fontcolor="#009688"

    FXR_liver [label="FXR (NR1H4)\n(Farnesoid X Receptor\nin hepatocyte)", fillcolor="#80cbc4"]
    FXR_intestine [label="FXR intestinal\n(ileal enterocyte)", fillcolor="#80cbc4"]
    TGR5 [label="TGR5 / GPBAR1\n(BA-activated GPCR)", fillcolor="#4db6ac"]
    FGF19 [label="FGF19\n(ileal FXR product;\ninhibits BA synthesis)", fillcolor="#00897b", fontcolor=white]
    FGFR4_bKL [label="FGFR4 / β-Klotho\n(liver FGF19 receptor)", fillcolor="#80cbc4"]
    CYP7A1 [label="CYP7A1\n(rate-limiting BA synthesis\ncholesterol 7α-hydroxylase)", fillcolor="#26a69a", fontcolor=white]
    CYP8B1 [label="CYP8B1\n(12α-hydroxylase;\ncholic acid synthesis)", fillcolor="#4db6ac"]
    CYP27A1 [label="CYP27A1\n(mitochondrial\nsterol 27-hydroxylase)", fillcolor="#80cbc4"]
    CYP2C8 [label="CYP2C8\n(alternative BA hydroxylation)", fillcolor="#b2dfdb"]
    NTCP [label="NTCP (SLC10A1)\n(Na-taurocholate\ncotransporting polypeptide)", fillcolor="#4db6ac"]
    OATP1B1 [label="OATP1B1/1B3\n(organic anion transporter\n→ BA uptake)", fillcolor="#80cbc4"]
    BSEP [label="BSEP (ABCB11)\n(bile salt export pump\ncanalicular BA secretion)", fillcolor="#26a69a", fontcolor=white]
    MRP2 [label="MRP2 (ABCC2)\n(canalicular conjugate\nexport)", fillcolor="#4db6ac"]
    MRP3 [label="MRP3 (ABCC3)\n(basolateral BA efflux\nto blood — overflow)", fillcolor="#80cbc4"]
    MRP4 [label="MRP4 (ABCC4)\n(basolateral BA/drug efflux)", fillcolor="#b2dfdb"]
    ASBT [label="ASBT (SLC10A2)\n(ileal BA reabsorption;\napical transporter)", fillcolor="#4db6ac"]
    IBABP [label="IBABP (FABP6)\n(ileal bile acid binding\nprotein, intracellular)", fillcolor="#b2dfdb"]
    OSTa_OSTb [label="OSTα/OSTβ\n(basolateral ileal BA efflux\nto portal)", fillcolor="#80cbc4"]
    Hydrophobic_BA [label="Hydrophobic BA pool\n(CDCA, DCA, LCA\n— hepatotoxic)", fillcolor="#d32f2f", fontcolor=white]
    Hydrophilic_BA [label="Hydrophilic BA pool\n(UDCA, TUDCA\n— hepatoprotective)", fillcolor="#00897b", fontcolor=white]
    Serum_BA [label="Serum bile acids↑\n(cholestasis marker\n>10 μmol/L = abnormal)", fillcolor="#4db6ac"]
    BA_glucuronidation [label="BA glucuronidation\n(UGT1A3/2B4\ndetoxification)", fillcolor="#b2dfdb"]
    BA_sulfation [label="BA sulfation\n(SULT2A1\ndetoxification)", fillcolor="#b2dfdb"]
  }

  // ─────────────────────────────────────────────────────────────────────
  // CLUSTER 6: Hepatocyte Injury & Cholestasis
  // ─────────────────────────────────────────────────────────────────────
  subgraph cluster_hepatocyte {
    label="⑥ Hepatocyte Injury, Cholestasis & Systemic Effects"
    style=filled; fillcolor="#fff8e1"; color="#FFC107"; penwidth=2
    fontname="Helvetica-Bold"; fontsize=13; fontcolor="#FFC107"

    Hepatocyte [label="Hepatocyte\n(parenchymal cell)", fillcolor="#fff59d"]
    BA_toxicity [label="BA cytotoxicity\n(detergent effect:\nmembrane disruption)", fillcolor="#f9a825", fontcolor=white]
    ROS_hepatocyte [label="ROS / Oxidative stress\n(mitochondrial uncoupling)", fillcolor="#ffb300"]
    ER_stress [label="ER stress / UPR\n(unfolded protein response)", fillcolor="#ffe082"]
    Mitochondrial_dysfunction [label="Mitochondrial dysfunction\n(BA → CYC release\n→ apoptosis)", fillcolor="#ffb300"]
    ALP_enzyme [label="ALP (Alkaline Phosphatase)\n↑↑ primary biomarker\n(normal <ULN=up to 120 IU/L)", fillcolor="#f57f17", fontcolor=white]
    GGT_enzyme [label="GGT (γ-GT)\n(cholestasis marker)", fillcolor="#ffe082"]
    Bilirubin_conjugated [label="Conjugated bilirubin↑\n(cholestatic jaundice;\npoor prognosis >ULN)", fillcolor="#f9a825", fontcolor=white]
    Bilirubin_unconjugated [label="Unconjugated bilirubin\n(hepatocellular injury)", fillcolor="#ffe082"]
    AST_ALT [label="AST / ALT\n(hepatocellular necrosis)", fillcolor="#ffe082"]
    Albumin [label="Albumin↓\n(synthetic function lost)", fillcolor="#fff59d"]
    INR_PT [label="INR / PT↑\n(coagulopathy)", fillcolor="#fff59d"]
    Pruritus_mediators [label="Pruritus mediators\n(LPA: lysophosphatidic acid;\nendogenous opioids;\nautotaxin↑)", fillcolor="#ffcc02"]
    Fatigue_central [label="Fatigue pathobiology\n(central — brain serotonin;\nperipheral — mitochondria)", fillcolor="#fff59d"]
    Vitamin_D_defect [label="Vitamin D malabsorption\n(fat-soluble vitamin)", fillcolor="#fff59d"]
    BMD_loss [label="Bone density loss\n(cholestatic osteoporosis)", fillcolor="#ffe082"]
    Hyperlipidemia [label="Hyperlipidemia\n(lipoprotein X;\ncholesterol↑ in early PBC)", fillcolor="#ffe082"]
    Sicca_syndrome [label="Sicca syndrome\n(dry eye/dry mouth;\nSjögren's overlap)", fillcolor="#fff59d"]
  }

  // ─────────────────────────────────────────────────────────────────────
  // CLUSTER 7: Fibrogenesis & Disease Progression
  // ─────────────────────────────────────────────────────────────────────
  subgraph cluster_fibrosis {
    label="⑦ Fibrogenesis & Disease Progression"
    style=filled; fillcolor="#f3e5f5"; color="#9C27B0"; penwidth=2
    fontname="Helvetica-Bold"; fontsize=13; fontcolor="#9C27B0"

    HSC_quiescent [label="Quiescent HSC\n(hepatic stellate cell\nvitamin A storing)", fillcolor="#e1bee7"]
    HSC_activated [label="Activated HSC\n(myofibroblast;\nα-SMA+, collagen+)", fillcolor="#7b1fa2", fontcolor=white]
    TGFb1_fibro [label="TGF-β1\n(master profibrotic)", fillcolor="#9c27b0", fontcolor=white]
    SMAD2_3 [label="SMAD2/3 signaling\n(TGF-β → nuclear\nfibrotic gene activation)", fillcolor="#ce93d8"]
    PDGF_BB [label="PDGF-BB\n(HSC proliferation)", fillcolor="#ba68c8"]
    Collagen_I_III [label="Collagen I / III\n(ECM deposition\nportal fibrosis)", fillcolor="#7b1fa2", fontcolor=white]
    MMP1_13 [label="MMP-1 / MMP-13\n(matrix metalloproteinases\nfibrolytic)", fillcolor="#ce93d8"]
    TIMP1_2 [label="TIMP-1 / TIMP-2\n(MMP inhibitors\nanti-fibrolytic)", fillcolor="#ba68c8"]
    Portal_fibroblasts [label="Portal fibroblasts\n(collagen type I secretion)", fillcolor="#e1bee7"]
    Fibrosis_score [label="Histological fibrosis\n(Metavir F0→F4;\nLudwig I→IV)", fillcolor="#9c27b0", fontcolor=white]
    Portal_hypertension [label="Portal hypertension\n(HVPG >5 mmHg)", fillcolor="#6a1b9a", fontcolor=white]
    Esophageal_varices [label="Esophageal varices\n(portal HTN complication)", fillcolor="#ce93d8"]
    Ascites [label="Ascites\n(decompensation)", fillcolor="#e1bee7"]
    HCC_risk [label="HCC risk↑\n(hepatocellular carcinoma\n>15× vs general)", fillcolor="#6a1b9a", fontcolor=white]
    Cirrhosis [label="Cirrhosis\n(end-stage liver disease)", fillcolor="#4a148c", fontcolor=white]
    Liver_transplant [label="Liver transplantation\n(≥8% at 10y in\nnon-responders)", fillcolor="#e1bee7"]
    Wnt_signaling [label="Wnt/β-catenin\n(HSC activation)", fillcolor="#ce93d8"]
    YAP1_TAZ [label="YAP1/TAZ\n(mechanosensing\nfibrosis amplification)", fillcolor="#e1bee7"]
  }

  // ─────────────────────────────────────────────────────────────────────
  // CLUSTER 8: Drug PK/PD Mechanisms
  // ─────────────────────────────────────────────────────────────────────
  subgraph cluster_drug_pk {
    label="⑧ Pharmacological Interventions & PK/PD"
    style=filled; fillcolor="#e8f5e9"; color="#4CAF50"; penwidth=2
    fontname="Helvetica-Bold"; fontsize=13; fontcolor="#4CAF50"

    UDCA_dose [label="UDCA\n13–15 mg/kg/day\n(Ursodeoxycholic acid)", shape=ellipse, fillcolor="#a5d6a7"]
    UDCA_gut [label="UDCA gut\ncompartment\n(F≈60%, EHC)", fillcolor="#c8e6c9"]
    UDCA_liver [label="UDCA hepatic\n(enriches hydrophilic BA pool)", fillcolor="#81c784"]
    UDCA_effect [label="UDCA effects:\n→ BSEP/MRP2↑\n→ FXR partial agonist\n→ bicarbonate umbrella\n→ hepatoprotection", fillcolor="#66bb6a"]

    OCA_dose [label="OCA 5–10 mg/day\n(Obeticholic acid;\nFDA 2016 — POISE trial)", shape=ellipse, fillcolor="#ffab91"]
    OCA_liver [label="OCA hepatic\n(100× FXR affinity\nvs CDCA)", fillcolor="#ff8a65"]
    OCA_FXR [label="OCA → FXR activation\n→ FGF19↑\n→ CYP7A1↓\n→ BSEP↑/ASBT↓", fillcolor="#ff7043"]
    OCA_pruritus [label="OCA side effect:\nPruritus↑↑\n(dose-limiting)", fillcolor="#ffccbc"]

    ELF_dose [label="Elafibranor 80 mg/day\n(PPAR δ/α dual agonist;\nFDA Jun 2024\n— ELATIVE trial)", shape=ellipse, fillcolor="#b39ddb"]
    ELF_central [label="Elafibranor Cp\n(Cmax ~2 μg/mL;\nT½ ~20h)", fillcolor="#ce93d8"]
    ELF_PPAR [label="Elafibranor → PPARα/δ\n→ ALP↓ 51% normalization\n→ BA detox↑\n→ Anti-inflammatory", fillcolor="#9c27b0", fontcolor=white]

    SEL_dose [label="Seladelpar 10 mg/day\n(PPAR δ selective;\nFDA Aug 2024\n— RESPONSE trial)", shape=ellipse, fillcolor="#80deea"]
    SEL_central [label="Seladelpar Cp\n(Cmax ~0.3 μg/mL;\nT½ ~14h)", fillcolor="#4dd0e1"]
    SEL_PPAR [label="Seladelpar → PPARδ\n→ ALP normalization 25%\n→ Pruritus↓ (vs OCA)\n→ GGT↓", fillcolor="#00838f", fontcolor=white]

    Bezafibrate_dose [label="Bezafibrate 400 mg/day\n(pan-PPAR α/δ/γ;\nfibrate; off-label)", shape=ellipse, fillcolor="#ffe082"]
    Bezafibrate_liver [label="Bezafibrate hepatic\n(PPARα >> δ,γ)", fillcolor="#ffd54f"]

    Budesonide_dose [label="Budesonide 9 mg/day\n(corticosteroid;\nnon-cirrhotic PBC)", shape=ellipse, fillcolor="#ef9a9a"]
    Budesonide_liver [label="Budesonide liver\n(first-pass ~90%;\nreduced systemic SE)", fillcolor="#e57373"]
    Budesonide_GR [label="Budesonide → GR\n→ NF-κB↓\n→ Th1/Th17↓\n→ Immune suppression", fillcolor="#c62828", fontcolor=white]

    Rituximab_dose [label="Rituximab 1g×2\n(Anti-CD20;\noff-label, AMA↓ refractory)", shape=ellipse, fillcolor="#bcaaa4"]
    Fibrates_class [label="Other fibrates\n(Fenofibrate, Ciprofibrate\nalternative PPAR options)", fillcolor="#d7ccc8"]
  }

  // ─────────────────────────────────────────────────────────────────────
  // CLUSTER 9: PPAR Signaling Network
  // ─────────────────────────────────────────────────────────────────────
  subgraph cluster_ppar {
    label="⑨ Nuclear Receptor & PPAR Signaling"
    style=filled; fillcolor="#e1f5fe"; color="#0288D1"; penwidth=2
    fontname="Helvetica-Bold"; fontsize=13; fontcolor="#0288D1"

    PPARa [label="PPARα (NR1C1)\n(liver dominant;\nFA β-oxidation, BA detox)", fillcolor="#81d4fa"]
    PPARd [label="PPARδ/β (NR1C2)\n(ubiquitous;\ncholangiocyte key)", fillcolor="#81d4fa"]
    PPARg [label="PPARγ (NR1C3)\n(adipogenesis;\nliver minimal)", fillcolor="#b3e5fc"]
    FXR_nuclear [label="FXR (NR1H4)\n(bile acid sensor)", fillcolor="#4fc3f7"]
    RXR_hetero [label="RXR heterodimerization\n(obligate partner for\nPPAR/FXR/LXR)", fillcolor="#b3e5fc"]
    PPAR_PPRE [label="PPRE consensus sequence\n(5'-AGGTCANAGGTCA-3'\ntarget gene promoters)", fillcolor="#b3e5fc"]
    CYP4A_omega [label="CYP4A11\n(PPARα target;\nBA ω-oxidation)", fillcolor="#81d4fa"]
    ABCG5_G8 [label="ABCG5/ABCG8\n(PPARδ target;\nbiliary cholesterol secretion)", fillcolor="#81d4fa"]
    UGT1A3_UGT2B4 [label="UGT1A3 / UGT2B4\n(PPARα target;\nBA glucuronidation)", fillcolor="#b3e5fc"]
    SULT2A1_drug [label="SULT2A1\n(PPARα/δ target;\nBA sulfation → detox)", fillcolor="#b3e5fc"]
    FGF21_PPAR [label="FGF21\n(PPARα target;\nanti-fibrotic, metabolic)", fillcolor="#4fc3f7"]
    HMGCR_PPARd [label="HMGCR suppression\n(PPARδ → cholesterol\nefflux from liver)", fillcolor="#81d4fa"]
    SHP [label="SHP (NR0B2)\n(FXR → SHP → CYP7A1↓\nnegative feedback BA)", fillcolor="#4fc3f7"]
    LRH1 [label="LRH-1 (NR5A2)\n(CYP7A1 transcription\nFXR-independent)", fillcolor="#b3e5fc"]
    FKBP5_GR [label="FKBP5\n(GR chaperone;\nbudesonide response\nmodifier)", fillcolor="#e1f5fe"]
  }

  // ─────────────────────────────────────────────────────────────────────
  // CLUSTER 10: Clinical Endpoints & Biomarkers
  // ─────────────────────────────────────────────────────────────────────
  subgraph cluster_endpoints {
    label="⑩ Clinical Endpoints, Biomarkers & Risk Scores"
    style=filled; fillcolor="#efebe9"; color="#795548"; penwidth=2
    fontname="Helvetica-Bold"; fontsize=13; fontcolor="#795548"

    ALP_response [label="ALP response\n(primary endpoint:\nALP <1.67×ULN +\nbilirubin ≤ULN)", fillcolor="#a1887f"]
    Bilirubin_norm [label="Bilirubin normalization\n(≤ULN = GLOBE\ngood prognosis)", fillcolor="#8d6e63"]
    GLOBE_score [label="GLOBE Score\n(transplant-free survival\nat 5y prediction)", fillcolor="#6d4c41", fontcolor=white]
    UKPBC_score [label="UK-PBC risk score\n(5- and 10-year\nmortality estimate)", fillcolor="#6d4c41", fontcolor=white]
    Paris_criteria [label="Paris criteria I/II\n(UDCA biochemical\nresponse definition)", fillcolor="#a1887f"]
    Barcelona_criteria [label="Barcelona criteria\n(ALP>40% drop at 1y)", fillcolor="#a1887f"]
    Pruritus_NRS [label="Pruritus NRS\n(0–10 numeric\nrating scale)", fillcolor="#bcaaa4"]
    Fatigue_PBC40 [label="Fatigue / PBC-40\n(disease-specific QoL)", fillcolor="#bcaaa4"]
    FibroScan_LSM [label="FibroScan LSM\n(liver stiffness kPa;\ncirrhosis >16.9 kPa)", fillcolor="#a1887f"]
    ELF_panel [label="ELF panel\n(enhanced liver fibrosis\nHA/PIIINP/TIMP-1)", fillcolor="#8d6e63"]
    AMA_titer [label="AMA titer\n(1:40 diagnostic;\nno correlation w/severity)", fillcolor="#bcaaa4"]
    IgM_serum [label="IgM level\n(hallmark; correlates\nwith active disease)", fillcolor="#8d6e63"]
    Liver_biopsy [label="Liver biopsy\n(Metavir/Ludwig staging;\nnot always required)", fillcolor="#a1887f"]
    Transplant_free_survival [label="Transplant-free\nsurvival\n(primary outcome RCTs)", fillcolor="#4e342e", fontcolor=white]
    ALP_ULN [label="ALP <ULN\n(normalization;\ngoal ELATIVE/RESPONSE)", fillcolor="#6d4c41", fontcolor=white]
    Composite_endpoint [label="Paris II composite:\nALP<1.5×ULN +\nAST≤2×ULN + bili≤ULN", fillcolor="#a1887f"]
    GGT_response [label="GGT response\n(PPARδ therapy marker)", fillcolor="#bcaaa4"]
