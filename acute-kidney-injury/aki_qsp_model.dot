digraph AKI_QSP {
    graph [rankdir=LR, fontname="Helvetica", fontsize=11,
           label="Acute Kidney Injury (AKI): Comprehensive QSP Mechanistic Map\nIschemia-Reperfusion · Nephrotoxic · Sepsis-Associated · Drug PK/PD · Recovery",
           labelloc=t, labeljust=c, nodesep=0.3, ranksep=0.7,
           splines=curved, bgcolor="#F8F9FA"];
    node [shape=box, style="filled,rounded", fontname="Helvetica", fontsize=9];
    edge [fontname="Helvetica", fontsize=8, arrowsize=0.7];

    /* =========================================================
       CLUSTER 1: TRIGGERS & RISK FACTORS
       ========================================================= */
    subgraph cluster_triggers {
        label="① Triggers & Risk Factors";
        style=filled; fillcolor="#FFF3E0"; color="#E65100";
        fontsize=10; fontcolor="#E65100";

        sepsis       [label="Sepsis / Septic\nShock", fillcolor="#FF8A65"];
        ischemia     [label="Ischemia-Reperfusion\nInjury (IRI)", fillcolor="#FF8A65"];
        nephrotoxins [label="Nephrotoxic Agents\n(Aminoglycosides,\nContrast Media, Cisplatin)", fillcolor="#FF8A65"];
        surgery      [label="Major Surgery /\nCardiopulmonary Bypass", fillcolor="#FFCC80"];
        hypovolemia  [label="Hypovolemia /\nDehydration", fillcolor="#FFCC80"];
        cardiogenic  [label="Cardiogenic Shock /\nHeart Failure", fillcolor="#FFCC80"];
        chronic_risk [label="Pre-existing CKD /\nDiabetes / Age >65", fillcolor="#FFCC80"];
        nonsteroidal [label="NSAID /\nCalcineurin Inhibitor", fillcolor="#FFCC80"];
        rhabdomy     [label="Rhabdomyolysis /\nMyoglobin Toxicity", fillcolor="#FFB74D"];
        obstruction  [label="Urinary Tract\nObstruction", fillcolor="#FFB74D"];
    }

    /* =========================================================
       CLUSTER 2: RENAL MICROVASCULAR DYSFUNCTION
       ========================================================= */
    subgraph cluster_vascular {
        label="② Renal Microvascular Dysfunction";
        style=filled; fillcolor="#E3F2FD"; color="#0D47A1";
        fontsize=10; fontcolor="#0D47A1";

        rbf          [label="Renal Blood Flow\n(RBF) ↓", fillcolor="#90CAF9"];
        afferent     [label="Afferent Arteriole\nVasoconstriction", fillcolor="#90CAF9"];
        efferent     [label="Efferent Arteriole\nDysregulation", fillcolor="#90CAF9"];
        gcp          [label="Glomerular Capillary\nPressure ↓", fillcolor="#BBDEFB"];
        endothelin   [label="Endothelin-1 ↑\n(ET-1)", fillcolor="#64B5F6"];
        angioII      [label="Angiotensin II ↑\n(Ang II / RAAS)", fillcolor="#64B5F6"];
        no_synth     [label="eNOS Dysfunction /\nNO ↓", fillcolor="#64B5F6"];
        txa2         [label="Thromboxane A2 ↑\n(TXA2)", fillcolor="#64B5F6"];
        pgs          [label="Prostaglandins ↓\n(PGE2, PGI2)", fillcolor="#90CAF9"];
        adenosine    [label="Adenosine ↑\n(TGF Activation)", fillcolor="#90CAF9"];
        microthromb  [label="Microvascular\nThrombosis / Fibrin", fillcolor="#EF9A9A"];
        peritubcap   [label="Peritubular Capillary\nRarefaction", fillcolor="#90CAF9"];
        outer_med    [label="Outer Medullary\nHypoxia (pO2 < 20 mmHg)", fillcolor="#64B5F6"];
    }

    /* =========================================================
       CLUSTER 3: TUBULAR CELL INJURY
       ========================================================= */
    subgraph cluster_tubular {
        label="③ Tubular Cell Injury (Proximal Tubule / TAL)";
        style=filled; fillcolor="#FCE4EC"; color="#880E4F";
        fontsize=10; fontcolor="#880E4F";

        atp_depletion [label="ATP Depletion\n(↓ OXPHOS)", fillcolor="#F48FB1"];
        mito_dysfunc  [label="Mitochondrial\nDysfunction\n(ΔΨm collapse)", fillcolor="#F48FB1"];
        mpt_pore      [label="mPTP Opening\n(Ca²⁺ overload)", fillcolor="#F06292"];
        ros_mito      [label="Mitochondrial ROS\n(O₂•⁻, H₂O₂)", fillcolor="#F06292"];
        cytochrome_c  [label="Cytochrome c\nRelease", fillcolor="#EC407A"];
        casp9         [label="Caspase-9\nActivation", fillcolor="#EC407A"];
        casp3         [label="Caspase-3/7\nActivation", fillcolor="#E91E63"];
        apoptosis     [label="Tubular Cell\nAPOPTOSIS", fillcolor="#C2185B", fontcolor=white];
        necrosis      [label="Tubular Cell\nNECROSIS\n(Regulated)", fillcolor="#AD1457", fontcolor=white];
        ferroptosis   [label="FERROPTOSIS\n(GPx4↓, Lipid perox)", fillcolor="#880E4F", fontcolor=white];
        loss_polarity [label="Loss of Cell Polarity\n(Na-K-ATPase mislocaliz.)", fillcolor="#F8BBD0"];
        shedding      [label="Brush Border\nShedding / Blebbing", fillcolor="#F8BBD0"];
        tight_junc    [label="Tight Junction\nDisruption", fillcolor="#F8BBD0"];
        tubular_cast  [label="Intratubular\nCast Formation", fillcolor="#F48FB1"];
        backleak      [label="Tubular Backleak\n(filtrate → blood)", fillcolor="#F48FB1"];
        obstruct_tube [label="Tubular\nObstruction", fillcolor="#F48FB1"];
        viability     [label="Tubular Cell\nViability (TCV)", fillcolor="#F8BBD0"];
    }

    /* =========================================================
       CLUSTER 4: OXIDATIVE STRESS & INFLAMMATION MEDIATORS
       ========================================================= */
    subgraph cluster_oxidative {
        label="④ Oxidative Stress";
        style=filled; fillcolor="#F3E5F5"; color="#4A148C";
        fontsize=10; fontcolor="#4A148C";

        ros_total   [label="Total ROS ↑\n(Superoxide, OH•)", fillcolor="#CE93D8"];
        nrf2        [label="Nrf2\n(Antioxidant TF)", fillcolor="#AB47BC"];
        ho1         [label="HO-1 / NQO1\n(Cytoprotective)", fillcolor="#9C27B0"];
        catalase    [label="Catalase /\nSOD ↓", fillcolor="#CE93D8"];
        glutathione [label="Glutathione (GSH)\nDepletion", fillcolor="#CE93D8"];
        gpx4        [label="GPx4 ↓\n(Ferroptosis gate)", fillcolor="#AB47BC"];
        lipid_perox [label="Lipid Peroxidation\n(4-HNE, MDA)", fillcolor="#CE93D8"];
        iron_free   [label="Labile Iron Pool ↑\n(Free Fe²⁺)", fillcolor="#AB47BC"];
        nox_enzymes [label="NADPH Oxidase\n(NOX2, NOX4)", fillcolor="#CE93D8"];
    }

    /* =========================================================
       CLUSTER 5: INNATE IMMUNE / INFLAMMATORY CASCADE
       ========================================================= */
    subgraph cluster_immune {
        label="⑤ Innate Immune & Inflammatory Cascade";
        style=filled; fillcolor="#E8F5E9"; color="#1B5E20";
        fontsize=10; fontcolor="#1B5E20";

        damps       [label="DAMPs Release\n(HMGB1, ATP, HSP70)", fillcolor="#A5D6A7"];
        tlr4        [label="TLR4 / TLR2\n(Pattern Recognition)", fillcolor="#66BB6A"];
        nfkb        [label="NF-κB Activation\n(p65/p50)", fillcolor="#43A047"];
        nlrp3       [label="NLRP3 Inflammasome\n(Caspase-1)", fillcolor="#43A047"];
        il1b        [label="IL-1β / IL-18 ↑\n(Pyroptosome)", fillcolor="#388E3C"];
        il6         [label="IL-6 ↑", fillcolor="#2E7D32"];
        tnfa        [label="TNF-α ↑", fillcolor="#2E7D32"];
        il10        [label="IL-10\n(Anti-inflammatory)", fillcolor="#A5D6A7"];
        neutrophils [label="Neutrophil\nInfiltration\n(ICAM-1, selectins)", fillcolor="#66BB6A"];
        netosis     [label="NETosis\n(NET formation)", fillcolor="#43A047"];
        macrophage  [label="Macrophage\nActivation (M1)", fillcolor="#66BB6A"];
        complement  [label="Complement\nActivation (C3a, C5a)", fillcolor="#A5D6A7"];
        lps_systemic[label="Systemic LPS\n(Gram-neg. sepsis)", fillcolor="#A5D6A7"];
        cxcl1       [label="CXCL1 / CXCL2\n(Neutrophil chemoattractant)", fillcolor="#A5D6A7"];
        icam1       [label="ICAM-1\n(Endothelial)", fillcolor="#A5D6A7"];
        mcp1        [label="MCP-1 / CCL2\n(Monocyte recruit)", fillcolor="#A5D6A7"];
    }

    /* =========================================================
       CLUSTER 6: GFR & URINARY DYNAMICS
       ========================================================= */
    subgraph cluster_gfr {
        label="⑥ Glomerular Filtration & Urinary Output";
        style=filled; fillcolor="#E0F7FA"; color="#006064";
        fontsize=10; fontcolor="#006064";

        gfr         [label="GFR\n(mL/min/1.73m²)", fillcolor="#80DEEA"];
        scr         [label="Serum Creatinine\n(sCr, mg/dL)", fillcolor="#80DEEA"];
        bun         [label="BUN\n(mg/dL)", fillcolor="#80DEEA"];
        urine_out   [label="Urine Output\n(mL/kg/h)", fillcolor="#80DEEA"];
        oliguria    [label="Oliguria\n(< 0.5 mL/kg/h)", fillcolor="#4DD0E1"];
        anuria      [label="Anuria\n(< 50 mL/24h)", fillcolor="#00BCD4"];
        aki_stage   [label="AKI Staging\n(KDIGO: 1→2→3)", fillcolor="#00ACC1", fontcolor=white];
        kfre        [label="Kidney Failure\nRisk (dialysis)", fillcolor="#00838F", fontcolor=white];
        fluid_bal   [label="Fluid Balance /\nFluid Overload", fillcolor="#80DEEA"];
        tubular_fx  [label="Tubular Function\n(FENa, FEUN)", fillcolor="#B2EBF2"];
    }

    /* =========================================================
       CLUSTER 7: BIOMARKERS
       ========================================================= */
    subgraph cluster_biomarkers {
        label="⑦ AKI Biomarkers";
        style=filled; fillcolor="#FFFDE7"; color="#F57F17";
        fontsize=10; fontcolor="#F57F17";

        ngal        [label="NGAL\n(Neutrophil Gelatinase\nAssociated Lipocalin)", fillcolor="#FFF176"];
        kim1        [label="KIM-1\n(Kidney Injury\nMolecule-1)", fillcolor="#FFF176"];
        il18_urine  [label="Urinary IL-18", fillcolor="#FFF9C4"];
        cystatin_c  [label="Cystatin C\n(Serum)", fillcolor="#FFF9C4"];
        timp2_igfbp7[label="TIMP-2 × IGFBP7\n([TIMP-2]×[IGFBP7])", fillcolor="#FFF176"];
        l_fabp      [label="L-FABP\n(Liver-type FABP)", fillcolor="#FFF9C4"];
        crp_pct     [label="CRP / PCT\n(Infection/Sepsis)", fillcolor="#FFF9C4"];
        exosomes    [label="Urinary Exosomes\n(miR-21, miR-155)", fillcolor="#FFF9C4"];
    }

    /* =========================================================
       CLUSTER 8: DRUG PK — FUROSEMIDE
       ========================================================= */
    subgraph cluster_furosemide {
        label="⑧ Drug PK – Furosemide (Loop Diuretic)";
        style=filled; fillcolor="#E8EAF6"; color="#1A237E";
        fontsize=10; fontcolor="#1A237E";

        fur_oral    [label="Furosemide\nIV/PO Dose", fillcolor="#9FA8DA"];
        fur_central [label="Furosemide\nCentral Cmpt (C1)", fillcolor="#7986CB"];
        fur_periph  [label="Furosemide\nPeripheral Cmpt (C2)", fillcolor="#7986CB"];
        fur_tubule  [label="Furosemide\nTubular Secretion\n(OAT1/OAT3)", fillcolor="#5C6BC0"];
        fur_nkcc2   [label="NKCC2 Inhibition\n(mTAL)", fillcolor="#3F51B5"];
        fur_naexcr  [label="Natriuresis /\nDiuresis ↑", fillcolor="#3949AB"];
        fur_resist  [label="Diuretic Resistance\n(Tubular Atrophy)", fillcolor="#9FA8DA"];
    }

    /* =========================================================
       CLUSTER 9: DRUG PK — VASOPRESSORS & SUPPORTIVE
       ========================================================= */
    subgraph cluster_vasopressors {
        label="⑨ Drug PK/PD – Vasopressors & Supportive";
        style=filled; fillcolor="#EFEBE9"; color="#3E2723";
        fontsize=10; fontcolor="#3E2723";

        norepi_dose [label="Norepinephrine\nInfusion (mcg/kg/min)", fillcolor="#BCAAA4"];
        norepi_pk   [label="NE Central Cmpt\n(t½ ~2.5 min)", fillcolor="#A1887F"];
        alpha1_rec  [label="α1-Adrenoceptor\nActivation (MAP↑)", fillcolor="#8D6E63"];
        dopa_dose   [label="Dopamine / Vasopressin\nSupport", fillcolor="#BCAAA4"];
        nac_dose    [label="N-Acetylcysteine (NAC)\nIV / Oral", fillcolor="#A1887F"];
        nac_pk      [label="NAC Plasma\nConcentration", fillcolor="#8D6E63"];
        nac_gsh     [label="NAC → GSH\nReplenishment", fillcolor="#6D4C41"];
        nac_no      [label="NAC → NO\nEnhancement", fillcolor="#6D4C41"];
        sodium_bic  [label="Sodium Bicarbonate\n(Contrast prophylaxis)", fillcolor="#BCAAA4"];
        fluidIV     [label="IV Fluid Resuscitation\n(Crystalloid / Colloid)", fillcolor="#A1887F"];
        crrt        [label="CRRT\n(Continuous Renal\nReplacement Therapy)", fillcolor="#8D6E63", style="filled,rounded,bold"];
        ihd         [label="Intermittent\nHemodialysis (IHD)", fillcolor="#8D6E63", style="filled,rounded,bold"];
        deferoxam   [label="Deferoxamine\n(Iron Chelation)", fillcolor="#A1887F"];
    }

    /* =========================================================
       CLUSTER 10: REPAIR & RECOVERY
       ========================================================= */
    subgraph cluster_repair {
        label="⑩ Tubular Repair & Recovery";
        style=filled; fillcolor="#F9FBE7"; color="#827717";
        fontsize=10; fontcolor="#827717";

        dedifferen  [label="Tubular Cell\nDedifferentiation\n(KRT8+, Vim+)", fillcolor="#DCE775"];
        proliferat  [label="Tubular Epithelial\nCell Proliferation\n(Ki-67+, PCNA+)", fillcolor="#D4E157"];
        redifferen  [label="Redifferentiation\n& Maturation", fillcolor="#CDDC39"];
        egf_axis    [label="EGF / HGF\nProliferative Signals", fillcolor="#C6D000"];
        igf1_axis   [label="IGF-1 / IGF-1R\nSurvival Signals", fillcolor="#C6D000"];
        wnt_path    [label="Wnt/β-catenin\n(Repair + Fibrosis)", fillcolor="#AFB42B"];
        notch_path  [label="Notch Signaling\n(Repair Coordination)", fillcolor="#AFB42B"];
        stem_rec    [label="Renal Progenitor\nCells (CD24+/CD133+)", fillcolor="#DCE775"];
        bone_marrow [label="Bone Marrow\nDerived MSC\n(Paracrine repair)", fillcolor="#DCE775"];
        recovery_gfr[label="GFR Recovery\n(Partial / Complete)", fillcolor="#C6D000"];
    }

    /* =========================================================
       CLUSTER 11: MALADAPTIVE REPAIR → CKD PROGRESSION
       ========================================================= */
    subgraph cluster_fibrosis {
        label="⑪ Maladaptive Repair → AKI-to-CKD Transition";
        style=filled; fillcolor="#FFF8E1"; color="#FF6F00";
        fontsize=10; fontcolor="#FF6F00";

        maladaptive [label="Maladaptive Repair\n(G2/M arrest)", fillcolor="#FFE082"];
        tgfb        [label="TGF-β1 ↑\n(Pro-fibrotic Master)", fillcolor="#FFD740"];
        smad23      [label="SMAD2/3\nPhosphorylation", fillcolor="#FFC107"];
        myofibrob   [label="Myofibroblast\nActivation\n(α-SMA+, FSP1+)", fillcolor="#FFB300"];
        collagen    [label="Collagen Type I/III\nDeposition (ECM)", fillcolor="#FFA000"];
        tubular_atr [label="Tubular Atrophy\n(< 25% PT remaining)", fillcolor="#FF8F00"];
        glom_scler  [label="Glomerulosclerosis\nProgression", fillcolor="#FF6F00", fontcolor=white];
        ckd_prog    [label="CKD Progression\n(GFR < 60 sustained)", fillcolor="#E65100", fontcolor=white];
        esrd        [label="ESRD / Dialysis\nDependency", fillcolor="#BF360C", fontcolor=white];
        hypoxia_ckd [label="Tubular Hypoxia\n→ HIF-1α activation", fillcolor="#FFE082"];
        pdgfb       [label="PDGF-B /\nFGF2 Fibrosis", fillcolor="#FFE082"];
        snail_twist [label="Epithelial-Mesenchymal\nTransition (EMT)", fillcolor="#FFD740"];
    }

    /* =========================================================
       CLUSTER 12: CLINICAL OUTCOMES
       ========================================================= */
    subgraph cluster_outcomes {
        label="⑫ Clinical Outcomes & Endpoints";
        style=filled; fillcolor="#ECEFF1"; color="#263238";
        fontsize=10; fontcolor="#263238";

        mortality   [label="In-Hospital\nMortality ↑", fillcolor="#B0BEC5"];
        icu_stay    [label="ICU LOS\nProlongation", fillcolor="#B0BEC5"];
        ventilation [label="Mechanical Ventilation\nRequirement", fillcolor="#90A4AE"];
        volume_over [label="Fluid Overload ↑\n(Pulmonary Edema)", fillcolor="#90A4AE"];
        acidosis    [label="Metabolic Acidosis\n(pH < 7.35)", fillcolor="#78909C"];
        hyperkalemia[label="Hyperkalemia\n(K+ > 5.5 mEq/L)", fillcolor="#78909C"];
        cardiac_comp[label="Cardiac Complications\n(AKI-Heart Crosstalk)", fillcolor="#607D8B"];
        infection_r [label="Secondary Infection\n(Immune Paralysis)", fillcolor="#607D8B"];
        renal_recov [label="Complete Renal\nRecovery", fillcolor="#B0BEC5"];
        partial_rec [label="Partial Recovery\n(Residual CKD risk)", fillcolor="#B0BEC5"];
        dialysis_dep[label="Dialysis\nDependency (1yr)", fillcolor="#78909C"];
    }

    /* ===================
       EDGES: TRIGGERS → VASCULAR
       =================== */
    sepsis       -> lps_systemic [label="gram-neg LPS"];
    sepsis       -> damps        [label="DAMPs"];
    sepsis       -> no_synth     [label="iNOS↑ / eNOS↓"];
    sepsis       -> rbf          [label="vasodilation →\nhypoperfusion", color=red];
    ischemia     -> rbf          [label="perfusion↓", color=red];
    ischemia     -> atp_depletion[color=red];
    ischemia     -> ros_mito     [color=red];
    cardiogenic  -> rbf          [label="CO↓", color=red];
    hypovolemia  -> rbf          [label="volume↓", color=red];
    surgery      -> ischemia     [label="clamp/bypass"];
    nephrotoxins -> atp_depletion[label="direct toxicity", color=red];
    nephrotoxins -> ros_mito     [color=red];
    nonsteroidal -> pgs          [label="COX inhibition →\nPGE2↓", color=red];
    rhabdomy     -> iron_free    [label="myoglobin\nFe release"];
    rhabdomy     -> tubular_cast [label="myoglobin casts"];
    obstruction  -> tubular_fx   [label="backpressure", color=red];
    chronic_risk -> viability    [label="baseline↓"];

    /* VASCULAR internal */
    rbf          -> gcp          [label="perfusion pressure↓", color=red];
    rbf          -> outer_med    [label="medullary hypoxia", color=red];
    angioII      -> afferent     [label="constrict", color=red];
    endothelin   -> afferent     [label="constrict", color=red];
    no_synth     -> afferent     [label="vasodilat.↓", color=red, style=dashed];
    txa2         -> afferent     [label="constrict", color=red];
    pgs          -> afferent     [label="vasodilat.↓→constrict", color=red, style=dashed];
    adenosine    -> afferent     [label="TGF constrict", color=red];
    gcp          -> gfr          [label="driving pressure↓", color=red];
    rbf          -> peritubcap   [label="post-injury rarefaction", color=orange];
    peritubcap   -> outer_med    [color=red];
    outer_med    -> atp_depletion[color=red];
    microthromb  -> peritubcap   [color=red];

    /* TUBULAR internal */
    atp_depletion -> mito_dysfunc[color=red];
    mito_dysfunc  -> ros_mito    [color=red];
    mito_dysfunc  -> mpt_pore    [color=red];
    mito_dysfunc  -> cytochrome_c[color=red];
    mpt_pore      -> cytochrome_c[color=red];
    cytochrome_c  -> casp9       [color=red];
    casp9         -> casp3       [color=red];
    casp3         -> apoptosis   [color=darkred];
    atp_depletion -> necrosis    [label="severe ATP depletion", color=darkred];
    ros_mito      -> necrosis    [color=red];
    gpx4          -> ferroptosis [label="GPx4↓ → lipid perox", color=red, style=dashed];
    iron_free     -> ferroptosis [color=red];
    lipid_perox   -> ferroptosis [color=red];
    atp_depletion -> loss_polarity [color=red];
    loss_polarity -> shedding    [color=red];
    shedding      -> tubular_cast[color=orange];
    tight_junc    -> backleak    [label="paracellular leak", color=red];
    tubular_cast  -> obstruct_tube[color=red];
    obstruct_tube -> backleak    [color=orange];
    apoptosis     -> viability   [color=red];
    necrosis      -> viability   [color=red];
    ferroptosis   -> viability   [color=red];
    viability     -> gfr         [label="effective\nfiltering↓", color=red];

    /* OXIDATIVE STRESS internal */
    ros_mito -> ros_total  [color=purple];
    nox_enzymes -> ros_total[color=purple];
    ros_total -> catalase   [label="deplete", color=red];
    ros_total -> glutathione[label="oxidize", color=red];
    glutathione -> gpx4     [label="GSH substrate", color=blue];
    ros_total -> lipid_perox[color=red];
    ros_total -> nrf2       [label="stress activate", color=blue];
    nrf2      -> ho1        [label="transcription", color=blue];
    nrf2      -> catalase   [label="transcription", color=blue];
    nrf2      -> glutathione[label="GCL/GSS↑", color=blue];
    iron_free -> ros_total  [label="Fenton rxn (OH•)", color=red];

    /* IMMUNE CASCADE */
    lps_systemic -> tlr4   [label="LPS binding", color=orange];
    damps        -> tlr4   [label="danger signal", color=orange];
    necrosis     -> damps  [label="cell lysis", color=orange];
    ros_total    -> nfkb   [color=orange];
    tlr4         -> nfkb   [label="MyD88/TRIF", color=orange];
    nfkb         -> tnfa   [color=red];
    nfkb         -> il6    [color=red];
    nfkb         -> il1b   [label="via NLRP3", color=red];
    nfkb         -> icam1  [color=red];
    nfkb         -> cxcl1  [color=red];
    nfkb         -> mcp1   [color=red];
    nlrp3        -> il1b   [label="Casp1 cleavage", color=red];
    ros_total    -> nlrp3  [label="activates", color=orange];
    il6          -> neutrophils [label="mobilize", color=orange];
    cxcl1        -> neutrophils [label="chemoattract", color=orange];
    icam1        -> neutrophils [label="adhesion", color=orange];
    neutrophils  -> netosis [color=red];
    neutrophils  -> ros_total [label="respiratory burst", color=red];
    mcp1         -> macrophage  [label="recruit M1", color=orange];
    macrophage   -> tnfa   [label="M1 cytokines", color=red];
    complement   -> microthromb [label="C5b-9", color=red];
    il10         -> nfkb   [label="inhibit", color=blue, style=dashed];
    il6          -> il10   [label="feedback", color=blue];
    tnfa         -> apoptosis [label="extrinsic path\n(Casp8)", color=red];
    tnfa         -> no_synth  [label="iNOS induction\n(high dose→NO toxicity)", color=orange];

    /* GFR / BIOMARKER links */
    gfr          -> scr        [label="inverse", color=red];
    gfr          -> urine_out  [label="→ oliguria", color=red];
    urine_out    -> oliguria   [label="< 0.5 mL/kg/h", color=red];
    oliguria     -> anuria     [label="< 50 mL/24h", color=red];
    scr          -> aki_stage  [label="KDIGO ΔCr ×1.5→×2→×3", color=red];
    urine_out    -> aki_stage  [label="KDIGO Cr-indep", color=red];
    aki_stage    -> kfre       [color=red];
    aki_stage    -> mortality  [color=red];
    backleak     -> scr        [label="falsely elev.", color=orange];
    fluid_bal    -> volume_over[color=orange];
    viability    -> ngal       [label="tubular injury\nexpression↑", color=orange];
    viability    -> kim1       [label="tubular shedding↑", color=orange];
    il1b         -> il18_urine [color=orange];
    gfr          -> cystatin_c [label="inverse filter", color=red];
    viability    -> timp2_igfbp7 [label="G2/M arrest marker", color=orange];
    viability    -> l_fabp     [color=orange];

    /* FUROSEMIDE */
    fur_oral  -> fur_central [color=navy];
    fur_central -> fur_periph [label="distribution", color=navy, style=dashed];
    fur_central -> fur_tubule [label="OAT1/3 secretion\n(active)", color=navy];
    fur_tubule  -> fur_nkcc2  [label="NKCC2 block", color=navy];
    fur_nkcc2   -> fur_naexcr [color=navy];
    fur_naexcr  -> urine_out  [label="diuresis↑", color=navy];
    fur_naexcr  -> fluid_bal  [label="volume reduction", color=navy];
    viability   -> fur_resist  [label="tubular atrophy↓\nOAT expression↓", color=gray];
    fur_resist  -> fur_tubule  [label="↓secretion efficacy", color=gray, style=dashed];

    /* VASOPRESSORS */
    norepi_dose -> norepi_pk  [color=brown];
    norepi_pk   -> alpha1_rec [label="α1 agonism", color=brown];
    alpha1_rec  -> rbf        [label="MAP↑→\nafferent autoregulation", color=blue];
    fluidIV     -> rbf        [label="preload restoration", color=blue];
    fluidIV     -> fluid_bal  [color=blue];
    nac_dose    -> nac_pk     [color=teal];
    nac_pk      -> nac_gsh    [label="cysteine precursor", color=teal];
    nac_pk      -> nac_no     [label="thiol-NO exchange", color=teal];
    nac_gsh     -> glutathione [label="GSH↑", color=blue];
    nac_no      -> no_synth   [label="eNOS↑→vasodilat.", color=blue];
    sodium_bic  -> ros_total  [label="pH↑→ Fenton↓", color=blue, style=dashed];
    crrt        -> scr        [label="creatinine clearance↑", color=blue];
    crrt        -> fluid_bal  [label="volume removal", color=blue];
    crrt        -> il6        [label="cytokine adsorption", color=blue, style=dashed];
    crrt        -> hyperkalemia [label="K+ clearance", color=blue];
    ihd         -> scr        [label="intermittent clearance", color=blue];
    deferoxam   -> iron_free  [label="chelate Fe²⁺", color=blue];
    deferoxam   -> ferroptosis [label="inhibit", color=blue, style=dashed];

    /* REPAIR */
    recovery_gfr -> renal_recov  [label="complete", color=green];
    recovery_gfr -> partial_rec  [label="partial", color=green];
    egf_axis    -> proliferat    [color=green];
    igf1_axis   -> proliferat    [color=green];
    wnt_path    -> proliferat    [color=green];
    notch_path  -> dedifferen    [color=green, style=dashed];
    stem_rec    -> proliferat    [color=green];
    bone_marrow -> egf_axis      [label="HGF paracrine", color=green];
    dedifferen  -> proliferat    [color=green];
    proliferat  -> redifferen    [color=green];
    redifferen  -> recovery_gfr  [color=green];
    il10        -> egf_axis      [label="repair cytokine", color=green, style=dashed];
    viability   -> dedifferen    [label="surviving cells", color=blue];

    /* MALADAPTIVE REPAIR → CKD */
    maladaptive -> tgfb        [color=red];
    tgfb        -> smad23      [color=red];
    smad23      -> myofibrob   [color=red];
    smad23      -> snail_twist [color=red];
    snail_twist -> myofibrob   [color=red];
    myofibrob   -> collagen    [color=red];
    collagen    -> tubular_atr [color=red];
    collagen    -> glom_scler  [color=red];
    tubular_atr -> ckd_prog    [color=red];
    glom_scler  -> ckd_prog    [color=red];
    ckd_prog    -> esrd        [color=darkred];
    hypoxia_ckd -> tgfb        [color=red];
    outer_med   -> hypoxia_ckd [color=red];
    wnt_path    -> tgfb        [label="maladaptive Wnt", color=orange, style=dashed];
    pdgfb       -> myofibrob   [color=red];
    nfkb        -> tgfb        [label="inflammatory\nfibrosis", color=red];
    il6         -> tgfb        [color=red, style=dashed];
    peritubcap  -> hypoxia_ckd [color=red];
    aki_stage   -> maladaptive [label="AKI severity", color=red];

    /* OUTCOMES */
    ckd_prog    -> dialysis_dep[color=darkred];
    aki_stage   -> icu_stay    [color=red];
    aki_stage   -> ventilation [label="fluid overload →\npulm. edema", color=red];
    volume_over -> ventilation [color=red];
    il6         -> cardiac_comp[label="cardiorenal\ncrosstalk", color=orange];
    tnfa        -> cardiac_comp[color=orange];
    acidosis    -> cardiac_comp[color=red];
    hyperkalemia-> cardiac_comp[label="arrhythmia risk", color=red];
    aki_stage   -> acidosis    [label="H⁺ retention", color=red];
    aki_stage   -> hyperkalemia[label="K⁺ retention", color=red];
    neutrophils -> infection_r [label="dysregulation", color=orange, style=dashed];
    mortality   -> kfre        [color=red, style=invis];

    /* CROSS-LINKS */
    il6         -> cystatin_c  [label="inflammation\nbias (minor)", color=gray, style=dashed];
    acidosis    -> mito_dysfunc[label="pH↓→ mtDNA\ndamage", color=orange, style=dashed];
    crrt        -> maladaptive [label="early CRRT may\nlimit", color=blue, style=dashed];
}
