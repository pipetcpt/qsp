digraph TB_QSP_Model {
  graph [
    label="Tuberculosis (Mtb) QSP Mechanistic Map\nM. tuberculosis Infection, Host Immunity, and RIPE Drug PK/PD"
    labelloc=t fontsize=22 fontname="Helvetica-Bold"
    rankdir=LR bgcolor="#F8F9FA"
    splines=curved nodesep=0.4 ranksep=1.2
    compound=true concentrate=true
  ]
  node [fontname="Helvetica" fontsize=10 style="filled,rounded" shape=box margin="0.15,0.05"]
  edge [fontname="Helvetica" fontsize=8 arrowsize=0.7]

  //=========================================================
  // CLUSTER 1: M. tuberculosis Bacterial States
  //=========================================================
  subgraph cluster_bacteria {
    label="🦠 Mycobacterium tuberculosis States"
    style=filled fillcolor="#FFF3CD" color="#F0AD4E" penwidth=2 fontsize=13 fontname="Helvetica-Bold"

    Mtb_aerosol    [label="Mtb Aerosol\n(Inhaled Droplet\nNuclei)" fillcolor="#FFECB3" color="#E65100"]
    Mtb_alveolar   [label="Mtb Alveolar\nDeposition" fillcolor="#FFE082" color="#E65100"]
    AR_free        [label="Active Replicating\n(Extracellular)\nAR_free" fillcolor="#FF8F00" fontcolor=white color="#E65100"]
    AR_intra       [label="Active Replicating\n(Intracellular)\nAR_intra" fillcolor="#FF6F00" fontcolor=white color="#E65100"]
    SR_intra       [label="Slowly Replicating\n(Intracellular)\nSR_intra" fillcolor="#FFB300" color="#E65100"]
    NR_persist     [label="Non-Replicating\nPersister\nNR_persist" fillcolor="#FFF8E1" color="#E65100"]
    DR_AR          [label="Drug-Resistant\nActive (DR-AR)" fillcolor="#D84315" fontcolor=white]
    DR_SR          [label="Drug-Resistant\nSlow (DR-SR)" fillcolor="#BF360C" fontcolor=white]
    Bacterial_load [label="Total Bacterial\nLoad (CFU/mL)" shape=diamond fillcolor="#FFCC02" color="#E65100"]
    Log_phase      [label="Exponential\nGrowth Phase" fillcolor="#FFF3E0" color="#E65100"]
    Stationary_ph  [label="Stationary\nPhase / Niche" fillcolor="#FFF3E0" color="#E65100"]
    Persistence    [label="Persistence\n(Wayne's Dormancy)" fillcolor="#FFF8E1" color="#E65100"]
    Mut_rate       [label="Spontaneous\nMutation Rate\n(10⁻⁶–10⁻⁸)" fillcolor="#FCE4EC" color="#E65100"]
    Efflux_expr    [label="Efflux Pump\nOver-Expression\n(WhiB7, Rv1258c)" fillcolor="#FCE4EC" color="#C62828"]
    Bacterial_kill [label="Drug-Induced\nKilling / Clearance" shape=diamond fillcolor="#E8F5E9" color="#2E7D32"]
  }

  //=========================================================
  // CLUSTER 2: Innate Immunity
  //=========================================================
  subgraph cluster_innate {
    label="🛡️ Innate Immune Response"
    style=filled fillcolor="#E3F2FD" color="#1565C0" penwidth=2 fontsize=13 fontname="Helvetica-Bold"

    AM_rest        [label="Alveolar Macrophage\n(Resting) AM⁰" fillcolor="#BBDEFB" color="#1565C0"]
    AM_inf         [label="Infected Macrophage\n(M_inf)" fillcolor="#90CAF9" color="#1565C0"]
    AM_act         [label="Activated Macrophage\n(M_act)" fillcolor="#42A5F5" fontcolor=white color="#0D47A1"]
    MDM            [label="Monocyte-Derived\nMacrophage (MDM)" fillcolor="#BBDEFB" color="#1565C0"]
    Monocyte       [label="Blood Monocyte\n(Classical CD14++)" fillcolor="#E3F2FD" color="#1565C0"]
    DC             [label="Dendritic Cell\n(DC)" fillcolor="#90CAF9" color="#1565C0"]
    Neutrophil     [label="Neutrophil (PMN)\nEarly Recruitment" fillcolor="#BBDEFB" color="#1565C0"]
    NK_cell        [label="NK Cell\n(IFN-γ, Cytotox)" fillcolor="#BBDEFB" color="#1565C0"]
    Phagocytosis   [label="Phagocytosis\n(FcR, CR3, MR)" shape=ellipse fillcolor="#E1F5FE" color="#0288D1"]
    Phagosome      [label="Phagosome\nMaturation" fillcolor="#E1F5FE" color="#0288D1"]
    Phago_escape   [label="Phagosomal\nEscape (Mtb)" fillcolor="#FFCCBC" color="#BF360C"]
    Foam_cell      [label="Foam Cell\n(Lipid-Laden Mφ)" fillcolor="#B3E5FC" color="#0277BD"]
    Apoptosis_inn  [label="Apoptosis\n(Innate Cells)" shape=diamond fillcolor="#E8F5E9" color="#1B5E20"]
    Necrosis_inn   [label="Necrosis /\nPyroptosis" shape=diamond fillcolor="#FFEBEE" color="#B71C1C"]
    Inflammasome   [label="NLRP3\nInflammasome" fillcolor="#E3F2FD" color="#1565C0"]
  }

  //=========================================================
  // CLUSTER 3: Adaptive Immunity
  //=========================================================
  subgraph cluster_adaptive {
    label="🧬 Adaptive Immune Response"
    style=filled fillcolor="#F3E5F5" color="#6A1B9A" penwidth=2 fontsize=13 fontname="Helvetica-Bold"

    Naive_CD4      [label="Naïve CD4+\nT Helper Cell" fillcolor="#E1BEE7" color="#6A1B9A"]
    Th1            [label="Th1 Cell\n(IFN-γ⁺ TNF-α⁺)" fillcolor="#9C27B0" fontcolor=white color="#4A148C"]
    Th17           [label="Th17 Cell\n(IL-17A⁺)" fillcolor="#CE93D8" color="#6A1B9A"]
    Treg           [label="Regulatory T Cell\n(FoxP3⁺ Treg)" fillcolor="#F8BBD9" color="#880E4F"]
    Naive_CD8      [label="Naïve CD8+\nCytotoxic T" fillcolor="#E1BEE7" color="#6A1B9A"]
    CTL            [label="Cytotoxic T\n(CD8+ CTL)\nPerforin/Granzyme" fillcolor="#8E24AA" fontcolor=white color="#4A148C"]
    Memory_CD4     [label="Memory CD4+\n(T_CM, T_EM)" fillcolor="#CE93D8" color="#6A1B9A"]
    Memory_CD8     [label="Memory CD8+\n(Long-Term)" fillcolor="#CE93D8" color="#6A1B9A"]
    B_cell         [label="B Cell\n(Humoral)" fillcolor="#F3E5F5" color="#6A1B9A"]
    Plasma_cell    [label="Plasma Cell\n(IgG, IgA)" fillcolor="#EDE7F6" color="#6A1B9A"]
    T_activation   [label="TCR Signal /\nMHC-II Ag Pres." shape=ellipse fillcolor="#EDE7F6" color="#7B1FA2"]
    T_exhaustion   [label="T Cell Exhaustion\n(PD-1⁺ TIM-3⁺)" fillcolor="#FCE4EC" color="#880E4F"]
    Lymph_node     [label="Lymph Node\n(Draining)" fillcolor="#EDE7F6" color="#6A1B9A"]
    MAIT_cell      [label="MAIT Cell\n(MR1-Restricted)" fillcolor="#E8EAF6" color="#1A237E"]
    gd_T_cell      [label="γδ T Cell\n(Vγ9Vδ2)" fillcolor="#E8EAF6" color="#1A237E"]
  }

  //=========================================================
  // CLUSTER 4: Cytokine / Mediator Network
  //=========================================================
  subgraph cluster_cytokines {
    label="⚡ Cytokine & Mediator Network"
    style=filled fillcolor="#E8F5E9" color="#1B5E20" penwidth=2 fontsize=13 fontname="Helvetica-Bold"

    IL12           [label="IL-12 / IL-23\n(DC, Mφ → Th1)" fillcolor="#C8E6C9" color="#1B5E20"]
    IFNg           [label="IFN-γ\n(Macrophage Act.)" fillcolor="#4CAF50" fontcolor=white color="#1B5E20"]
    TNFa           [label="TNF-α\n(Granuloma Main.)" fillcolor="#2E7D32" fontcolor=white color="#1B5E20"]
    IL10           [label="IL-10\n(Anti-Inflammatory)" fillcolor="#A5D6A7" color="#1B5E20"]
    IL6            [label="IL-6\n(Acute Phase)" fillcolor="#C8E6C9" color="#1B5E20"]
    IL17A          [label="IL-17A\n(Neutrophil Recr.)" fillcolor="#C8E6C9" color="#1B5E20"]
    TGFb           [label="TGF-β\n(Fibrosis, Treg)" fillcolor="#DCEDC8" color="#33691E"]
    IL1b           [label="IL-1β\n(Inflammasome)" fillcolor="#C8E6C9" color="#1B5E20"]
    IL18           [label="IL-18\n(IFN-γ Co-inducer)" fillcolor="#DCEDC8" color="#33691E"]
    CXCL10         [label="CXCL10 / IP-10\n(T Cell Chemokin)" fillcolor="#F1F8E9" color="#558B2F"]
    CCL2           [label="CCL2 / MCP-1\n(Monocyte Recr.)" fillcolor="#F1F8E9" color="#558B2F"]
    ROS            [label="ROS / O₂⁻\n(Oxidative Burst)" fillcolor="#FFF9C4" color="#F57F17"]
    NO_prod        [label="Nitric Oxide (NO)\niNOS Activation" fillcolor="#FFF9C4" color="#F57F17"]
    PGE2           [label="PGE₂\n(Cox-2 Product)" fillcolor="#F3E5F5" color="#6A1B9A"]
    LTB4           [label="LTB₄\n(Leukotriene B4)" fillcolor="#F3E5F5" color="#6A1B9A"]
  }

  //=========================================================
  // CLUSTER 5: Granuloma Dynamics
  //=========================================================
  subgraph cluster_granuloma {
    label="🔴 Granuloma Formation & Dynamics"
    style=filled fillcolor="#FCE4EC" color="#880E4F" penwidth=2 fontsize=13 fontname="Helvetica-Bold"

    Early_gran     [label="Early Granuloma\n(Loose Aggregate)" fillcolor="#F8BBD9" color="#880E4F"]
    Organ_gran     [label="Organized\nGranuloma (Stable)" fillcolor="#F48FB1" color="#AD1457"]
    Caseous_center [label="Caseous Necrosis\n(Central Core)" fillcolor="#C2185B" fontcolor=white color="#880E4F"]
    Fibrous_cap    [label="Fibrous Capsule\n(Walling-Off)" fillcolor="#FCE4EC" color="#880E4F"]
    Cavity         [label="Cavity Formation\n(Liquefaction)" fillcolor="#B71C1C" fontcolor=white color="#880E4F"]
    Reactivation   [label="Reactivation Risk\n(LTBI → Active)" shape=diamond fillcolor="#FFCDD2" color="#C62828"]
    Calcification  [label="Calcification\n(Healed/Ghon)" fillcolor="#E8F5E9" color="#2E7D32"]
    Lymph_cuff     [label="Lymphocyte Cuff\n(Outer Zone)" fillcolor="#F8BBD9" color="#880E4F"]
    Mφ_zone        [label="Macrophage Zone\n(Epithelioid Cells)" fillcolor="#F48FB1" color="#AD1457"]
    Giant_cell     [label="Langhans Giant\nCell (Fused Mφ)" fillcolor="#F48FB1" color="#AD1457"]
    Hypoxia        [label="Granuloma\nHypoxia" fillcolor="#FFCCBC" color="#BF360C"]
    Gran_stability  [label="Granuloma\nStability Index" shape=diamond fillcolor="#E8F5E9" color="#1B5E20"]
  }

  //=========================================================
  // CLUSTER 6: Drug PK
  //=========================================================
  subgraph cluster_pk {
    label="💊 Drug Pharmacokinetics (PK)"
    style=filled fillcolor="#E8EAF6" color="#1A237E" penwidth=2 fontsize=13 fontname="Helvetica-Bold"

    RIF_dose       [label="Rifampicin (RIF)\nDose: 10 mg/kg/d" shape=hexagon fillcolor="#3949AB" fontcolor=white]
    RIF_gut        [label="RIF Gut\n(Absorption)\nF=0.68" fillcolor="#C5CAE9" color="#1A237E"]
    RIF_plasma     [label="RIF Plasma\nCmax 8–24 mg/L" fillcolor="#7986CB" fontcolor=white color="#1A237E"]
    RIF_lung       [label="RIF Lung/Lesion\nPenetration ~0.25" fillcolor="#9FA8DA" color="#1A237E"]
    INH_dose       [label="Isoniazid (INH)\nDose: 5 mg/kg/d" shape=hexagon fillcolor="#1565C0" fontcolor=white]
    INH_plasma     [label="INH Plasma\nCmax 3–5 mg/L" fillcolor="#90CAF9" color="#1565C0"]
    INH_slow       [label="INH Slow\nAcetylator (NAT2*)" fillcolor="#BBDEFB" color="#1565C0"]
    INH_fast       [label="INH Fast\nAcetylator (NAT2†)" fillcolor="#E3F2FD" color="#1565C0"]
    PZA_dose       [label="Pyrazinamide (PZA)\nDose: 25 mg/kg/d" shape=hexagon fillcolor="#00695C" fontcolor=white]
    PZA_plasma     [label="PZA Plasma\nCmax 20–60 mg/L" fillcolor="#80CBC4" color="#00695C"]
    EMB_dose       [label="Ethambutol (EMB)\nDose: 15 mg/kg/d" shape=hexagon fillcolor="#4E342E" fontcolor=white]
    EMB_plasma     [label="EMB Plasma\nCmax 2–5 mg/L" fillcolor="#BCAAA4" color="#4E342E"]
    BDQ_dose       [label="Bedaquiline (BDQ)\nDR-TB: 400→200 mg" shape=hexagon fillcolor="#6A1B9A" fontcolor=white]
    BDQ_plasma     [label="BDQ Plasma\n+ M2 Metabolite" fillcolor="#CE93D8" color="#6A1B9A"]
    CYP3A4_ind     [label="CYP3A4 Induction\n(RIF Autoinduction)" fillcolor="#FFECB3" color="#E65100"]
    Drug_interact  [label="Drug-Drug\nInteractions" fillcolor="#FFECB3" color="#E65100"]
  }

  //=========================================================
  // CLUSTER 7: Drug PD / Resistance
  //=========================================================
  subgraph cluster_pd {
    label="⚗️ Drug PD & Resistance Mechanisms"
    style=filled fillcolor="#F1F8E9" color="#33691E" penwidth=2 fontsize=13 fontname="Helvetica-Bold"

    RIF_PD         [label="RIF Effect\nRNA Polymerase (rpoB)\nBactericidal" fillcolor="#AED581" color="#33691E"]
    INH_PD         [label="INH Effect\nKatG→InhA→Mycolic\nBactericidal (AR)" fillcolor="#8BC34A" fontcolor=white color="#33691E"]
    PZA_PD         [label="PZA Effect\nAcidic pH Dep.\nSterilizing (SR/NR)" fillcolor="#558B2F" fontcolor=white color="#33691E"]
    EMB_PD         [label="EMB Effect\nArabinogalactan Syn.\nBacteriostatic" fillcolor="#9CCC65" color="#33691E"]
    BDQ_PD         [label="BDQ Effect\nATP Synthase (atpE)\nBactericidal" fillcolor="#7CB342" color="#33691E"]
    Emax_model     [label="Emax/Sigmoidal PD\nModel (Hill Eqn)" shape=ellipse fillcolor="#DCEDC8" color="#33691E"]
    MIC_RIF        [label="MIC RIF\n≤0.5 mg/L (S)\n>1 mg/L (R)" fillcolor="#F9FBE7" color="#33691E"]
    MIC_INH        [label="MIC INH\n≤0.2 mg/L (S)\n>1 mg/L (R)" fillcolor="#F9FBE7" color="#33691E"]
    Resist_rpoB    [label="rpoB Mutation\n(RIF Resistance\n95% of RR-TB)" fillcolor="#FFCCBC" color="#BF360C"]
    Resist_katG    [label="katG/inhA Mut.\n(INH Resistance\n~80% of HR-TB)" fillcolor="#FFCCBC" color="#BF360C"]
    MDR_TB         [label="MDR-TB\n(RIF+INH Resist.)" fillcolor="#D84315" fontcolor=white]
    XDR_TB         [label="XDR-TB\n(MDR+FQ+Inj.)" fillcolor="#B71C1C" fontcolor=white]
  }

  //=========================================================
  // CLUSTER 8: Clinical Endpoints
  //=========================================================
  subgraph cluster_endpoints {
    label="📊 Clinical Endpoints & Outcomes"
    style=filled fillcolor="#FFFDE7" color="#F57F17" penwidth=2 fontsize=13 fontname="Helvetica-Bold"

    Sputum_smear   [label="Sputum Smear\n(AFB +/−)" fillcolor="#FFF9C4" color="#F57F17"]
    Sputum_cult    [label="Sputum Culture\n(Mtb CFU)" fillcolor="#FFF176" color="#F9A825"]
    Cult_conv      [label="Culture Conversion\n(Negative at 2 mo)" shape=diamond fillcolor="#F9A825" fontcolor=white]
    Tx_success     [label="Treatment Success\n(WHO: Cure + Compl.)" shape=diamond fillcolor="#43A047" fontcolor=white]
    Tx_failure     [label="Treatment Failure\n(Culture+ at 5 mo)" shape=diamond fillcolor="#E53935" fontcolor=white]
    Relapse        [label="Relapse Rate\n(post-Tx 12 mo)" fillcolor="#FFCCBC" color="#BF360C"]
    FEV1           [label="Lung Function\nFEV₁ % predicted" fillcolor="#FFF9C4" color="#F57F17"]
    CXR_cavitation [label="Chest X-Ray\nCavity Status" fillcolor="#FFF9C4" color="#F57F17"]
    Weight         [label="Body Weight\n(Nutritional Status)" fillcolor="#FFF9C4" color="#F57F17"]
    Fever          [label="Fever Resolution\n(Temp < 37.5°C)" fillcolor="#FFF9C4" color="#F57F17"]
    HIV_status     [label="HIV Co-infection\nCD4 count" fillcolor="#FCE4EC" color="#880E4F"]
    DM_status      [label="Diabetes Mellitus\nHbA1c / Glucose" fillcolor="#E8EAF6" color="#1A237E"]
  }

  //=========================================================
  // CLUSTER 9: Host Risk Factors
  //=========================================================
  subgraph cluster_host {
    label="👤 Host & Environmental Factors"
    style=filled fillcolor="#EFEBE9" color="#4E342E" penwidth=2 fontsize=13 fontname="Helvetica-Bold"

    BCG_vacc       [label="BCG Vaccination\n(Trained Immunity)" fillcolor="#D7CCC8" color="#4E342E"]
    LTBI           [label="Latent TB Infection\n(LTBI, 1/3 world pop)" fillcolor="#BCAAA4" color="#4E342E"]
    TST_IGRA       [label="TST / IGRA Test\n(IFN-γ Release)" fillcolor="#D7CCC8" color="#4E342E"]
    Malnutrition   [label="Malnutrition\n(BMI < 18.5)" fillcolor="#FFCCBC" color="#BF360C"]
    Crowding       [label="Overcrowding /\nPoor Ventilation" fillcolor="#EFEBE9" color="#4E342E"]
    Smoking        [label="Smoking\n(Mφ Dysfunction)" fillcolor="#FFCCBC" color="#BF360C"]
    Alcohol        [label="Alcohol Use\n(Immune Suppression)" fillcolor="#FFCCBC" color="#BF360C"]
    Age_factor     [label="Age / Elderly\n(Waning Immunity)" fillcolor="#EFEBE9" color="#4E342E"]
    Cortico_use    [label="Corticosteroid Use\n(Iatrogenic Risk)" fillcolor="#FFECB3" color="#E65100"]
    Anti_TNF       [label="Anti-TNF Therapy\n(Reactivation Risk)" fillcolor="#FFECB3" color="#E65100"]
    Pregnancy      [label="Pregnancy\n(Immune Modulation)" fillcolor="#F8BBD9" color="#880E4F"]
  }

  //=========================================================
  // INTER-CLUSTER EDGES
  //=========================================================

  // Infection pathway
  Mtb_aerosol -> Mtb_alveolar [label="droplet settling" color="#E65100"]
  Mtb_alveolar -> Phagocytosis [label="engulfment" color="#1565C0"]
  Phagocytosis -> AM_inf [label="infected" color="#1565C0"]
  Phagocytosis -> Phagosome [label="phagosome" color="#1565C0"]
  Phagosome -> Phago_escape [label="Mtb escape" color="#BF360C" style=dashed]
  AM_inf -> AR_intra [label="intracellular growth" color="#E65100"]
  Phago_escape -> AR_free [label="extracellular release" color="#E65100"]
  AR_intra -> AR_free [label="cell lysis" color="#E65100"]
  AR_free -> AR_intra [label="re-uptake" color="#1565C0" style=dashed]
  AR_free -> Bacterial_load [color="#E65100" style=bold]
  AR_intra -> Bacterial_load [color="#E65100" style=bold]
  SR_intra -> Bacterial_load [color="#FFB300"]
  NR_persist -> Bacterial_load [color="#FFF8E1" style=dashed]

  // Bacterial state transitions
  AR_free -> AR_intra [label="phagocytosis" color="#1565C0" style=dashed]
  AR_intra -> SR_intra [label="stress/hypoxia" color="#BF360C"]
  SR_intra -> NR_persist [label="dormancy" color="#BF360C"]
  NR_persist -> AR_intra [label="reactivation" color="#E65100" style=dashed]
  Log_phase -> AR_free [color="#E65100"]
  Stationary_ph -> SR_intra [color="#FFB300"]
  Persistence -> NR_persist [color="#FFF8E1"]
  Hypoxia -> SR_intra [label="induces SR" color="#BF360C"]
  Hypoxia -> NR_persist [label="induces dormancy" color="#BF360C" style=dashed]

  // Drug resistance
  Mut_rate -> DR_AR [label="selection" color="#C62828"]
  Mut_rate -> DR_SR [color="#C62828"]
  Efflux_expr -> DR_AR [color="#C62828"]
  Resist_rpoB -> DR_AR [color="#C62828"]
  Resist_katG -> DR_AR [color="#C62828"]
  DR_AR -> MDR_TB [label="if INH+RIF resist" color="#D84315" style=bold]
  MDR_TB -> XDR_TB [label="additional resist" color="#B71C1C" style=bold]

  // Innate immune activation
  AM_inf -> IL12 [label="secretion" color="#1B5E20"]
  AM_inf -> TNFa [color="#1B5E20"]
  AM_inf -> IL1b [color="#1B5E20"]
  AM_inf -> Inflammasome [color="#1B5E20"]
  Inflammasome -> IL1b [color="#1B5E20"]
  AM_inf -> Necrosis_inn [label="Mtb-driven" color="#B71C1C" style=dashed]
  IFNg -> AM_act [label="M1 activation" color="#1B5E20" style=bold]
  TNFa -> AM_act [label="co-activation" color="#1B5E20"]
  AM_act -> ROS [color="#F57F17"]
  AM_act -> NO_prod [color="#F57F17"]
  ROS -> AR_intra [label="bacterial killing" color="#1B5E20" style=dashed arrowhead=tee]
  NO_prod -> AR_intra [label="killing" color="#1B5E20" style=dashed arrowhead=tee]
  AM_rest -> AM_inf [label="Mtb uptake" color="#E65100"]
  AM_inf -> AM_act [label="IFN-γ" color="#1B5E20"]
  AM_act -> Apoptosis_inn [label="apoptosis" color="#1B5E20"]
  Apoptosis_inn -> AR_intra [label="kills Mtb" color="#1B5E20" arrowhead=tee]
  Monocyte -> MDM [label="differentiation" color="#1565C0"]
  MDM -> AM_inf [label="recruitment" color="#1565C0"]
  MDM -> AM_act [label="pre-activated" color="#1565C0"]
  DC -> Lymph_node [label="antigen transport" color="#6A1B9A"]
  DC -> IL12 [color="#1B5E20"]
  Neutrophil -> AR_free [label="extracell killing" color="#1B5E20" arrowhead=tee]
  NK_cell -> IFNg [label="early IFN-γ" color="#1B5E20"]
  AM_inf -> Foam_cell [label="lipid engulf" color="#0277BD"]
  Foam_cell -> SR_intra [label="niche" color="#E65100"]

  // Adaptive immune activation
  DC -> T_activation [color="#7B1FA2"]
  Lymph_node -> T_activation [color="#7B1FA2"]
  T_activation -> Naive_CD4 [style=dashed]
  Naive_CD4 -> Th1 [label="IL-12 + IFN-γ" color="#9C27B0"]
  Naive_CD4 -> Th17 [label="IL-6 + TGF-β" color="#9C27B0"]
  Naive_CD4 -> Treg [label="TGF-β + IL-10" color="#880E4F"]
  IL12 -> Th1 [label="polarization" color="#9C27B0" style=bold]
  Naive_CD8 -> CTL [label="CD8 activation" color="#9C27B0"]
  Th1 -> IFNg [label="secretion" color="#1B5E20" style=bold]
  Th1 -> TNFa [color="#1B5E20"]
  CTL -> AM_inf [label="cytotoxic kill" color="#9C27B0" arrowhead=tee]
  CTL -> AR_intra [label="perforin/granzyme" color="#9C27B0" arrowhead=tee]
  Th17 -> IL17A [color="#1B5E20"]
  IL17A -> Neutrophil [label="recruitment" color="#1565C0"]
  Treg -> IL10 [color="#1B5E20"]
  Treg -> TGFb [color="#1B5E20"]
  Treg -> Th1 [label="suppression" color="#880E4F" arrowhead=tee style=dashed]
  Th1 -> Memory_CD4 [label="long-term" color="#9C27B0"]
  CTL -> Memory_CD8 [label="long-term" color="#9C27B0"]
  B_cell -> Plasma_cell [color="#6A1B9A"]
  Plasma_cell -> Bacterial_load [label="IgG (limited)" color="#6A1B9A" style=dashed arrowhead=tee]
  MAIT_cell -> IFNg [label="rapid IFN-γ" color="#1B5E20"]
  gd_T_cell -> TNFa [color="#1B5E20"]
  T_exhaustion -> Th1 [label="functional impair" arrowhead=tee color="#880E4F" style=dashed]

  // Cytokine network
  IFNg -> TNFa [label="synergism" color="#1B5E20"]
  TNFa -> CCL2 [color="#1B5E20"]
  CCL2 -> Monocyte [label="chemotaxis" color="#1565C0"]
  IL6 -> B_cell [color="#6A1B9A"]
  IL10 -> IL12 [label="negative" arrowhead=tee color="#880E4F" style=dashed]
  IL10 -> TNFa [label="negative" arrowhead=tee color="#880E4F" style=dashed]
  IL10 -> Th1 [label="suppression" arrowhead=tee color="#880E4F" style=dashed]
  TGFb -> Fibrous_cap [label="fibrosis" color="#880E4F"]
  CXCL10 -> Th1 [label="recruitment" color="#9C27B0"]
  PGE2 -> IL10 [label="immunomod." color="#6A1B9A"]
  LTB4 -> Neutrophil [label="chemotaxis" color="#1565C0"]

  // Granuloma dynamics
