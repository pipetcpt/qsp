digraph CF_QSP {
    graph [
        label="Cystic Fibrosis (CF) QSP Mechanistic Map\nCFTR Gene → Protein Processing → Channel Function → Airway Disease → Clinical Outcomes",
        labelloc="t",
        fontsize=22,
        fontname="Helvetica-Bold",
        bgcolor="#FAFAFA",
        rankdir=TB,
        splines=spline,
        nodesep=0.5,
        ranksep=0.8,
        pad=0.5,
        concentrate=false,
        tooltip="CF QSP Model — complete mechanistic diagram"
    ];
    node [
        shape=box,
        style="filled,rounded",
        fontname="Helvetica",
        fontsize=10,
        margin="0.15,0.08"
    ];
    edge [
        fontname="Helvetica",
        fontsize=9,
        penwidth=1.2
    ];

    /* =========================================================
       CLUSTER 1: CFTR Gene & mRNA
       ========================================================= */
    subgraph cluster_gene {
        label="① CFTR Gene & mRNA";
        style=filled;
        fillcolor="#EBF3FB";
        color="#4472C4";
        penwidth=2;
        fontname="Helvetica-Bold";
        fontsize=13;

        CFTR_gene [label="CFTR Gene\nChr7q31.2", fillcolor="#4472C4", fontcolor=white];
        CFTR_promoter [label="CFTR Promoter\n(SPI1, FOXA1)", fillcolor="#5B9BD5", fontcolor=white];
        CFTR_mRNA [label="CFTR mRNA\n6.1 kb", fillcolor="#5B9BD5", fontcolor=white];
        CFTR_NMD [label="Nonsense-Mediated\nDecay (Class I)", fillcolor="#9DC3E6"];
        CFTR_translation [label="Ribosomal\nTranslation", fillcolor="#9DC3E6"];
        CFTR_protein_nascent [label="Nascent CFTR\nPolypeptide\n1480 aa", fillcolor="#9DC3E6"];
        mut_class1 [label="Class I\n(Nonsense/Splice)\nW1282X, G542X", fillcolor="#FF0000", fontcolor=white];
        mut_class2 [label="Class II\n(Processing)\nΔF508 (~70%)", fillcolor="#FF4444", fontcolor=white];
        mut_class3 [label="Class III\n(Gating)\nG551D", fillcolor="#FF8888"];
        mut_class4 [label="Class IV\n(Conductance)\nR117H", fillcolor="#FFBBBB"];
        mut_class5 [label="Class V\n(Reduced Qty)\n3849+10kbC→T", fillcolor="#FFDDDD"];
        mut_class6 [label="Class VI\n(Membrane\nStability)", fillcolor="#FFE8E8"];
    }

    /* =========================================================
       CLUSTER 2: CFTR Protein Processing & QC
       ========================================================= */
    subgraph cluster_processing {
        label="② CFTR Protein Processing & QC";
        style=filled;
        fillcolor="#EFF6E8";
        color="#70AD47";
        penwidth=2;
        fontname="Helvetica-Bold";
        fontsize=13;

        BiP_HSPA5 [label="BiP/HSPA5\nER Chaperone", fillcolor="#70AD47", fontcolor=white];
        Calnexin [label="Calnexin\n(glycan sensor)", fillcolor="#70AD47", fontcolor=white];
        Hsp70 [label="Hsp70/Hsc70\nCytosolic", fillcolor="#A9D18E"];
        Hsp90 [label="Hsp90\nCo-chaperone", fillcolor="#A9D18E"];
        FKBP8 [label="FKBP8\nStabilizer", fillcolor="#C5E0B4"];
        Bag1 [label="Bag1/CHIP\nUbiquitin E3", fillcolor="#E2EFDA"];
        RNF5 [label="RNF5\nERAD E3 Ligase", fillcolor="#E2EFDA"];
        CFTR_band_B [label="CFTR Band B\n(Core Glycosylated\n~150 kDa)", fillcolor="#548235", fontcolor=white];
        CFTR_ERAD [label="CFTR ERAD\n(ΔF508 ~99%)", fillcolor="#FF4444", fontcolor=white];
        proteasome_26S [label="26S Proteasome\nDegradation", fillcolor="#FF8888"];
        CFTR_rescued [label="Rescued CFTR\n(Corrector target)", fillcolor="#70AD47", fontcolor=white];
        ELX_site [label="Elexacaftor\nBinding NBD1\n(VX-445)", fillcolor="#FFD700"];
        VX809_site [label="Lumacaftor\nBinding MSD1\n(VX-809)", fillcolor="#FFC000"];
        TEZ_site [label="Tezacaftor\nBinding MSD1\n(VX-661)", fillcolor="#FFB300"];
    }

    /* =========================================================
       CLUSTER 3: CFTR Channel (Membrane)
       ========================================================= */
    subgraph cluster_channel {
        label="③ CFTR Channel (Membrane)";
        style=filled;
        fillcolor="#E6F6FD";
        color="#00B0F0";
        penwidth=2;
        fontname="Helvetica-Bold";
        fontsize=13;

        CFTR_band_C [label="CFTR Band C\n(Complex Glycosylated\n~170 kDa)", fillcolor="#00B0F0", fontcolor=white];
        Golgi_trafficking [label="Golgi Trafficking\n(Rab11-FIP3)", fillcolor="#00B0F0", fontcolor=white];
        CFTR_apical [label="CFTR at Apical\nMembrane", fillcolor="#0070C0", fontcolor=white];
        NHERF1 [label="NHERF1/EBP50\nPDZ Scaffold", fillcolor="#47B5C7", fontcolor=white];
        PKA_CFTR [label="PKA\n(cAMP-activated)", fillcolor="#47B5C7", fontcolor=white];
        cAMP [label="cAMP\n(AC/PDE6 balance)", fillcolor="#86CEDC"];
        CFTR_NBD1 [label="NBD1\n(ATP binding)", fillcolor="#86CEDC"];
        CFTR_NBD2 [label="NBD2\n(ATP hydrolysis)", fillcolor="#86CEDC"];
        CFTR_open [label="CFTR Open State\n(Po ~0.3–0.5)", fillcolor="#00B0F0", fontcolor=white];
        CFTR_closed [label="CFTR Closed State\n(Inhibited)", fillcolor="#005EA7", fontcolor=white];
        Cl_efflux [label="Cl⁻ Efflux\n(lumen)", fillcolor="#86CEDC"];
        HCO3_efflux [label="HCO₃⁻ Efflux\npH ↑ lumen", fillcolor="#86CEDC"];
        CFTR_endocytosis [label="CFTR\nEndocytosis\n(Clathrin)", fillcolor="#005EA7", fontcolor=white];
        IVA_potentiation [label="Ivacaftor\nPotentiation ↑Po", fillcolor="#FFD700"];
        CFTR_function_pct [label="CFTR Function\n(% Normal)", fillcolor="#0070C0", fontcolor=white];
    }

    /* =========================================================
       CLUSTER 4: ENaC & Ion Transport
       ========================================================= */
    subgraph cluster_enac {
        label="④ ENaC & Ion Transport";
        style=filled;
        fillcolor="#FEF0E7";
        color="#ED7D31";
        penwidth=2;
        fontname="Helvetica-Bold";
        fontsize=13;

        ENaC_alpha [label="ENaC α\n(Inactive)", fillcolor="#ED7D31", fontcolor=white];
        ENaC_activated [label="ENaC Activated\n(αβγ cleaved)", fillcolor="#ED7D31", fontcolor=white];
        ENaC_cleavage [label="Furin/Prostasin\nENaC Cleavage", fillcolor="#F4B183"];
        Na_apical [label="Na⁺ Absorption\n(ENaC→Na/K-ATPase)", fillcolor="#F4B183"];
        CFTR_inhibit_ENaC [label="CFTR ⊣ ENaC\n(Direct inhibition)", fillcolor="#FF7F27", fontcolor=white];
        NKCC1 [label="NKCC1\n(Basolateral)", fillcolor="#F4B183"];
        Na_K_ATPase [label="Na/K-ATPase\n(Basolateral)", fillcolor="#F4B183"];
        TMEM16A [label="TMEM16A/ANO1\nCa²⁺-activated Cl⁻", fillcolor="#FBE5D6"];
        KCa31 [label="KCa3.1\nK⁺ channel", fillcolor="#FBE5D6"];
        transep_potential [label="Transepithelial\nPotential (Δψ)", fillcolor="#FFD966"];
        NPD [label="Nasal Potential\nDifference (NPD)\n(biomarker)", fillcolor="#FFD966"];
    }

    /* =========================================================
       CLUSTER 5: Airway Surface Liquid & MCC
       ========================================================= */
    subgraph cluster_asl {
        label="⑤ Airway Surface Liquid & MCC";
        style=filled;
        fillcolor="#F3EEF8";
        color="#7030A0";
        penwidth=2;
        fontname="Helvetica-Bold";
        fontsize=13;

        PCL [label="Periciliary Layer\n(PCL, ~7 μm)", fillcolor="#7030A0", fontcolor=white];
        ASL_height [label="ASL Height\n(collapsed <7μm\nin CF)", fillcolor="#7030A0", fontcolor=white];
        MUC5B [label="MUC5B Mucin\n(gel layer)", fillcolor="#9E5FB5", fontcolor=white];
        MUC5AC [label="MUC5AC Mucin\n(surface gel)", fillcolor="#9E5FB5", fontcolor=white];
        mucus_viscoelasticity [label="Mucus\nViscoelasticity↑\n(G', G'')", fillcolor="#B78CC1"];
        mucus_hydration [label="Mucus Hydration\n(Osmotic Pressure)", fillcolor="#C2A3CF"];
        MCC_rate [label="Mucociliary\nClearance Rate", fillcolor="#9E5FB5", fontcolor=white];
        cilia_beat [label="Cilia Beat\nFrequency (CBF)", fillcolor="#C2A3CF"];
        mucus_plug [label="Mucus Plug\nFormation", fillcolor="#FF0000", fontcolor=white];
        eDNA [label="Extracellular DNA\n(NETs + lysis)", fillcolor="#B78CC1"];
        DNase_effect [label="Dornase alfa\nDNA hydrolysis", fillcolor="#FFD700"];
        HTS_effect [label="Hypertonic Saline\n(7% NaCl osmotic)", fillcolor="#FFD700"];
        mannitol_DPI [label="Inhaled Mannitol\n(osmotic action)", fillcolor="#FFD700"];
    }

    /* =========================================================
       CLUSTER 6: Airway Inflammation
       ========================================================= */
    subgraph cluster_inflammation {
        label="⑥ Airway Inflammation";
        style=filled;
        fillcolor="#FFF0F0";
        color="#C00000";
        penwidth=2;
        fontname="Helvetica-Bold";
        fontsize=13;

        epithelial_injury [label="Airway Epithelial\nInjury/Barrier↓", fillcolor="#FF0000", fontcolor=white];
        DAMPs [label="DAMPs\n(HMGB1, ATP)", fillcolor="#FF4444", fontcolor=white];
        TLR4 [label="TLR4\n(LPS sensing)", fillcolor="#FF6B6B", fontcolor=white];
        TLR5 [label="TLR5\n(Flagellin)", fillcolor="#FF6B6B", fontcolor=white];
        NLRP3 [label="NLRP3\nInflammasome", fillcolor="#FF6B6B", fontcolor=white];
        NF_kB [label="NF-κB\nActivation", fillcolor="#C00000", fontcolor=white];
        IL8 [label="IL-8/CXCL8\n(Neutrophil\nChemokine)", fillcolor="#FF8888"];
        IL1beta [label="IL-1β\n(mature form)", fillcolor="#FF8888"];
        TNFa [label="TNF-α\n(proinflammatory)", fillcolor="#FF8888"];
        IL6 [label="IL-6\n(acute phase)", fillcolor="#FFA0A0"];
        IL17A [label="IL-17A\n(Th17/ILC3)", fillcolor="#FFA0A0"];
        GMCSF [label="GM-CSF\n(neutrophil\npriming)", fillcolor="#FFC0C0"];
        neutrophil_influx [label="Neutrophil Influx\ninto Airways", fillcolor="#CC0000", fontcolor=white];
        neutrophil_ROS [label="ROS Burst\n(NADPH oxidase)", fillcolor="#FF4444", fontcolor=white];
        MPO [label="Myeloperoxidase\n(HOCl generation)", fillcolor="#FF6666", fontcolor=white];
        NE_elastase [label="Neutrophil\nElastase (NE)", fillcolor="#FF6666", fontcolor=white];
        cathepsinG [label="Cathepsin G\n(protease)", fillcolor="#FF9999"];
        NETs [label="Neutrophil\nExtracellular Traps", fillcolor="#FF6666", fontcolor=white];
        ROS [label="ROS / Oxidative\nStress", fillcolor="#FF4444", fontcolor=white];
        Nrf2 [label="Nrf2\n(Antioxidant Resp)", fillcolor="#70AD47", fontcolor=white];
        IL10 [label="IL-10\n(Anti-inflammatory)", fillcolor="#70AD47", fontcolor=white];
        TGFb1 [label="TGF-β1\n(Remodeling)", fillcolor="#FFA0A0"];
        macrophage_impaired [label="CF Macrophage\n(Impaired Phagocytosis)", fillcolor="#FF8888"];
        Th17 [label="Th17 Cell\n(IL-17/IL-21/IL-22)", fillcolor="#FF6B6B", fontcolor=white];
        AZI_antiinflam [label="Azithromycin\nAnti-inflammatory", fillcolor="#FFD700"];
    }

    /* =========================================================
       CLUSTER 7: Microbiology & Biofilm
       ========================================================= */
    subgraph cluster_infection {
        label="⑦ Microbiology & Biofilm";
        style=filled;
        fillcolor="#FBF3EC";
        color="#843C0C";
        penwidth=2;
        fontname="Helvetica-Bold";
        fontsize=13;

        Pa_initial [label="P. aeruginosa\nEarly (Non-mucoid)", fillcolor="#843C0C", fontcolor=white];
        Pa_mucoid [label="P. aeruginosa\nMucoid Transition", fillcolor="#843C0C", fontcolor=white];
        Pa_biofilm [label="P. aeruginosa\nBiofilm", fillcolor="#692200", fontcolor=white];
        alginate [label="Alginate\nOverproduction", fillcolor="#A05C2C", fontcolor=white];
        quorum_sensing [label="Quorum Sensing\n(lasI/rhlI)", fillcolor="#A05C2C", fontcolor=white];
        Sa_MRSA [label="S. aureus / MRSA\n(early colonizer)", fillcolor="#7B3B0E", fontcolor=white];
        H_influenzae [label="H. influenzae\n(early)", fillcolor="#9B5C3E", fontcolor=white];
        Stenotrophomonas [label="Stenotrophomonas\nmaltophilia", fillcolor="#9B5C3E", fontcolor=white];
        Burkholderia [label="Burkholderia\ncepacia complex", fillcolor="#692200", fontcolor=white];
        bacterial_burden [label="Total Bacterial\nBurden (CFU/mL)", fillcolor="#843C0C", fontcolor=white];
        TOBRA [label="Tobramycin\n(inhaled/TOBI)", fillcolor="#FFD700"];
        AZLI [label="Aztreonam lysine\n(AZLI)", fillcolor="#FFD700"];
        IV_antibiotics [label="IV Antibiotics\n(exacerbation)", fillcolor="#FFD700"];
        antibiotic_PD [label="Antibiotic PD\n(Emax/EC50)", fillcolor="#FFF2CC"];
        resistance_develop [label="Antibiotic\nResistance", fillcolor="#FF4444", fontcolor=white];
    }

    /* =========================================================
       CLUSTER 8: Lung Function & Structural Damage
       ========================================================= */
    subgraph cluster_lung {
        label="⑧ Lung Function & Structural Damage";
        style=filled;
        fillcolor="#EFF2F5";
        color="#44546A";
        penwidth=2;
        fontname="Helvetica-Bold";
        fontsize=13;

        FEV1_pct [label="FEV1 % predicted\n(ppFEV1)", fillcolor="#44546A", fontcolor=white];
        FVC [label="FVC % predicted", fillcolor="#44546A", fontcolor=white];
        RV_TLC [label="RV/TLC\n(Air Trapping)", fillcolor="#5C6E7E", fontcolor=white];
        LCI [label="Lung Clearance\nIndex (LCI)\n(<7 normal)", fillcolor="#5C6E7E", fontcolor=white];
        bronchiectasis [label="Bronchiectasis\nCTSS Score", fillcolor="#758499", fontcolor=white];
        airway_obstruction [label="Small Airway\nObstruction", fillcolor="#758499", fontcolor=white];
        FEV1_decline [label="FEV1 Decline\n(% predicted/yr)", fillcolor="#B4C7D9"];
        exacerbation [label="Pulmonary\nExacerbation\n(event)", fillcolor="#FF0000", fontcolor=white];
        exacerbation_rate [label="Exacerbation Rate\n(events/yr)", fillcolor="#FF4444", fontcolor=white];
        hospitalization [label="Hospitalization\n(days/yr)", fillcolor="#FF8888"];
        transplant_criteria [label="Lung Transplant\nCriteria\n(ppFEV1<30%)", fillcolor="#CC0000", fontcolor=white];
        CFQ_R [label="CFQ-R\n(Respiratory\nDomain Score)", fillcolor="#B4C7D9"];
        PGIC [label="PGIC\n(Patient Global\nImpression)", fillcolor="#B4C7D9"];
    }

    /* =========================================================
       CLUSTER 9: CFTR Modulator PK/PD
       ========================================================= */
    subgraph cluster_modulators {
        label="⑨ CFTR Modulator PK/PD";
        style=filled;
        fillcolor="#FFFBE6";
        color="#BF8F00";
        penwidth=2;
        fontname="Helvetica-Bold";
        fontsize=13;

        IVA_dose_node [label="Ivacaftor\n150mg q12h p.o.", fillcolor="#FF6600", fontcolor=white];
        IVA_gut [label="Ivacaftor Gut\n(Ka=0.75/h)", fillcolor="#FFA500"];
        IVA_central [label="Ivacaftor Central\n(Vd=353L, Cl=17.3L/h\nt½=12h)", fillcolor="#FFC000"];
        IVA_periph [label="Ivacaftor\nPeripheral", fillcolor="#FFD966"];
        IVA_lung [label="Ivacaftor Lung\nConc. (target)", fillcolor="#FFD966"];
        IVA_M1 [label="IVA M1/M6\nMetabolites", fillcolor="#FFE699"];
        CYP3A4 [label="CYP3A4\n(IVA/ELX/TEZ\nMetabolism)", fillcolor="#BF8F00", fontcolor=white];
        ELX_dose_node [label="Elexacaftor\n200mg q24h p.o.", fillcolor="#FF6600", fontcolor=white];
        ELX_gut [label="Elexacaftor Gut\n(Ka=0.56/h)", fillcolor="#FFA500"];
        ELX_central [label="Elexacaftor Central\n(Vd=193L, t½=27h\nCl=4.1L/h)", fillcolor="#FFC000"];
        TEZ_dose_node [label="Tezacaftor\n100mg q24h p.o.", fillcolor="#FF6600", fontcolor=white];
        TEZ_gut [label="Tezacaftor Gut\n(Ka=0.65/h)", fillcolor="#FFA500"];
        TEZ_central [label="Tezacaftor Central\n(Vd=271L, t½=14h\nCl=13.5L/h)", fillcolor="#FFC000"];
        ETI_combo [label="ELX/TEZ/IVA\n(TRIKAFTA)\nCombination", fillcolor="#FF6600", fontcolor=white];
        CFTR_correction [label="CFTR Correction\n(ELX+TEZ synergy)", fillcolor="#FF8C00", fontcolor=white];
        sweat_Cl [label="Sweat Chloride\n(mmol/L)\n<60 normal", fillcolor="#FFD966"];
    }

    /* =========================================================
       CLUSTER 10: Other Respiratory & Systemic Therapies
       ========================================================= */
    subgraph cluster_other_rx {
        label="⑩ Other Respiratory & Systemic Therapies";
        style=filled;
        fillcolor="#F2F8F2";
        color="#548235";
        penwidth=2;
        fontname="Helvetica-Bold";
        fontsize=13;

        DNase_dose [label="Dornase alfa\n2.5mg inh. qd", fillcolor="#C5E0B4"];
        HTS_dose [label="Hypertonic Saline\n7% NaCl inh. bid", fillcolor="#C5E0B4"];
        ivacaftor_food [label="High-fat Meal\n↑IVA absorption 3×", fillcolor="#FFE699"];
        bronchodilator [label="SABA/LABA\nBronchodilator", fillcolor="#DDEBF7"];
        inhaled_CS [label="Inhaled\nCorticosteroids\n(ICS)", fillcolor="#DDEBF7"];
        PPI_pancr [label="Pancreatic\nEnzyme PERT\n(CREON)", fillcolor="#FCE4D6"];
        insulin_CFRD [label="Insulin Therapy\n(CFRD)", fillcolor="#FCE4D6"];
        Vit_ADEK [label="Fat-soluble\nVitamins A,D,E,K", fillcolor="#FCE4D6"];
        lumacaftor_drug [label="Lumacaftor\n(VX-809/ORKAMBI)", fillcolor="#FFC000"];
        gene_therapy_future [label="Future:\nCFTR mRNA/Gene\nTherapy", fillcolor="#E2EFDA"];
    }

    /* =========================================================
       CLUSTER 11: Systemic Effects
       ========================================================= */
    subgraph cluster_systemic {
        label="⑪ Systemic Effects";
        style=filled;
        fillcolor="#FFF4F4";
        color="#FF7F7F";
        penwidth=2;
        fontname="Helvetica-Bold";
        fontsize=13;

        CF_pancreas [label="Exocrine\nPancreatic\nInsufficiency (~85%)", fillcolor="#FF7F7F", fontcolor=white];
        malabsorption [label="Fat Malabsorption\nSteatorrhea", fillcolor="#FF9999"];
        BMI_status [label="BMI / Nutritional\nStatus", fillcolor="#FFB3B3"];
        CFRD [label="CF-Related\nDiabetes\n(CFRD ~35%)", fillcolor="#FF4444", fontcolor=white];
        insulin_def [label="Insulin Deficiency\n(Fibrosis→Beta\ncell loss)", fillcolor="#FF6666", fontcolor=white];
        liver_disease [label="CF Liver Disease\n(~10%)", fillcolor="#FF9999"];
        liver_fibrosis_cf [label="CF Hepatic\nFibrosis", fillcolor="#FFA0A0"];
        bone_density_cf [label="Bone Mineral\nDensity ↓", fillcolor="#FFB3B3"];
        male_infertility [label="Male Infertility\nCBAVD (99%)", fillcolor="#FFCCCC"];
        chronic_sinusitis [label="Chronic\nRhinosinusitis", fillcolor="#FFCCCC"];
        CF_arthropathy [label="CF Arthropathy\n(episodic)", fillcolor="#FFCCCC"];
    }

    /* =========================================================
       CLUSTER 12: Clinical Endpoints & Biomarkers
       ========================================================= */
    subgraph cluster_biomarkers {
        label="⑫ Clinical Endpoints & Biomarkers";
        style=filled;
        fillcolor="#EBF4FA";
        color="#2F75B6";
        penwidth=2;
        fontname="Helvetica-Bold";
        fontsize=13;

        sweat_test_endpoint [label="Sweat Chloride Test\n<30 normal\n30-60 indeterminate\n>60 CF", fillcolor="#DEEAF1"];
        NPD_endpoint [label="NPD Test\n(-5 to -40mV normal\n>0mV CF)", fillcolor="#DEEAF1"];
        spirometry_endpoint [label="Spirometry\nppFEV1 target ≥70%", fillcolor="#DEEAF1"];
        LCI_endpoint [label="LCI <7.0\n(normal)", fillcolor="#DEEAF1"];
        exacerbation_endpoint [label="Exacerbation Rate\n(primary endpoint)", fillcolor="#BDD7EE"];
        time_to_event [label="Time to First\nExacerbation", fillcolor="#BDD7EE"];
        ppFEV1_change [label="ΔppFEV1\n(primary endpoint\n+14.3% Trikafta)", fillcolor="#9BC2E6"];
        sweat_Cl_change [label="ΔSweat Chloride\n(-41.8 mmol/L\nTrikafta)", fillcolor="#9BC2E6"];
        CFQ_R_endpoint [label="CFQ-R Resp.\n(+17.4 pts Trikafta)", fillcolor="#BDD7EE"];
        transplant_free_surv [label="Transplant-Free\nSurvival", fillcolor="#2F75B6", fontcolor=white];
    }

    /* ==========================================================
       EDGES — CLUSTER 1: Gene → mRNA → Translation → Protein
       ========================================================== */
    CFTR_promoter -> CFTR_gene [label="drives transcription", color="#4472C4"];
    CFTR_gene -> CFTR_mRNA [label="transcription", color="#4472C4", penwidth=2];
    CFTR_mRNA -> CFTR_translation [label="ribosome\nloading", color="#4472C4"];
    CFTR_mRNA -> CFTR_NMD [label="premature stop\ncodon target", color="#FF4444", style=dashed, constraint=false];
    CFTR_translation -> CFTR_protein_nascent [label="synthesis", color="#4472C4", penwidth=2];

    /* Mutation effects on gene/mRNA */
    mut_class1 -> CFTR_mRNA [label="truncates mRNA", arrowhead=tee, color="#FF0000", penwidth=2];
    mut_class1 -> CFTR_NMD [label="triggers NMD", color="#FF0000"];
    mut_class2 -> CFTR_protein_nascent [label="misfolding\nΔF508", arrowhead=tee, color="#FF4444", penwidth=2];
    mut_class5 -> CFTR_mRNA [label="reduced\nquantity", arrowhead=tee, color="#FF8888"];
    CFTR_NMD -> CFTR_mRNA [label="degradation", arrowhead=tee, color="#FF0000"];

    /* ==========================================================
       EDGES — CLUSTER 2: Chaperones, ERAD, Correctors
       ========================================================== */
    CFTR_protein_nascent -> BiP_HSPA5 [label="ER entry", color="#548235"];
    CFTR_protein_nascent -> Calnexin [label="glycan\nrecognition", color="#548235"];
    BiP_HSPA5 -> CFTR_band_B [label="proper folding\n→ Band B", color="#548235", penwidth=2];
    Calnexin -> CFTR_band_B [label="glycosylation\ncheck", color="#548235"];
    Hsp70 -> CFTR_band_B [label="cytosolic\nstabilization", color="#70AD47"];
    Hsp90 -> CFTR_band_B [label="co-chaperone\nsupport", color="#70AD47"];
    FKBP8 -> CFTR_band_B [label="stabilizes\nΔF508", color="#A9D18E"];
    Hsp70 -> Bag1 [label="recruits CHIP\nfor ERAD", color="#CC0000"];
    Bag1 -> CFTR_ERAD [label="ubiquitination", color="#FF4444"];
    RNF5 -> CFTR_ERAD [label="E3 ubiquitin\nligation", color="#FF4444"];
    mut_class2 -> CFTR_ERAD [label="ΔF508\nmisfolded→ERAD", color="#FF0000", penwidth=2.5];
    CFTR_ERAD -> proteasome_26S [label="polyUb-protein\ndegradation", color="#FF4444", penwidth=2];
    CFTR_band_B -> CFTR_ERAD [label="quality\ncontrol fail", color="#FF6666", style=dashed];
    CFTR_band_B -> CFTR_rescued [label="passes QC\n(normal/corrected)", color="#548235", penwidth=2];

    /* Corrector drugs */
    ELX_site -> CFTR_band_B [label="stabilizes NBD1\n→rescues folding", color="#FF8C00", penwidth=2.5, style=dashed];
    VX809_site -> CFTR_band_B [label="MSD1 correction", color="#FFC000", penwidth=2, style=dashed];
    TEZ_site -> CFTR_band_B [label="MSD1 stabilization", color="#FFB300", penwidth=2, style=dashed];
