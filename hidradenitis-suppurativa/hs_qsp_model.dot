digraph HS_QSP_Model {
    graph [
        label = "Hidradenitis Suppurativa (HS) — Quantitative Systems Pharmacology Model\nMechanistic Map: Follicular Biology · Innate/Adaptive Immunity · TNF-α · IL-17 · Hormonal · Microbiome · Drug PK/PD · Clinical Endpoints"
        labelloc = "t"
        fontsize = 16
        fontname = "Helvetica-Bold"
        rankdir = "TB"
        compound = true
        splines = ortho
        bgcolor = "#F8F9FA"
        overlap = false
        nodesep = 0.25
        ranksep = 0.5
        pad = 0.5
    ]
    node [fontname="Helvetica" fontsize=9 style="filled,rounded" shape=box]
    edge [fontname="Helvetica" fontsize=7 arrowsize=0.7]

    // ============================================================
    // CLUSTER 1: Predisposing & Triggering Factors
    // ============================================================
    subgraph cluster_triggers {
        label = "1. Predisposing & Triggering Factors"
        style = "filled,rounded"
        color = "#CC6600"
        fillcolor = "#FFF8F0"
        fontsize = 12
        fontcolor = "#CC6600"

        NCSTN   [label="NCSTN\nMutation"     fillcolor="#FFB347" shape=diamond]
        PSEN1   [label="PSEN1\nMutation"     fillcolor="#FFB347" shape=diamond]
        PSEN2   [label="PSEN2\nMutation"     fillcolor="#FFB347" shape=diamond]
        PSENEN  [label="PSENEN\nMutation"    fillcolor="#FFB347" shape=diamond]
        POFUT1  [label="POFUT1/POGLUT1\nMutation" fillcolor="#FFB347" shape=diamond]
        FamHist [label="Family\nHistory (HS)" fillcolor="#FFD700"]
        smoking [label="Cigarette\nSmoking"  fillcolor="#D3D3D3"]
        obesity_node [label="Obesity /\nMetabolic Syn" fillcolor="#FFA07A"]
        mech_stress [label="Mechanical\nFriction/Stress" fillcolor="#D3D3D3"]
        heat_sweat  [label="Heat &\nSweating"      fillcolor="#D3D3D3"]
        IBD_assoc   [label="IBD/\nComorbidity"     fillcolor="#FFDAB9"]
        psych_stress[label="Psychosocial\nStress"  fillcolor="#D3D3D3"]
        menstrual   [label="Menstrual\nCycle"       fillcolor="#FFB6C1"]
        FH_axis     [label="HPA Axis\nDysregulation" fillcolor="#FFD700"]
    }

    // ============================================================
    // CLUSTER 2: Follicular Biology & Occlusion
    // ============================================================
    subgraph cluster_follicular {
        label = "2. Follicular Biology & Occlusion"
        style = "filled,rounded"
        color = "#8B4513"
        fillcolor = "#FFF5EE"
        fontsize = 12
        fontcolor = "#8B4513"

        gamma_sec      [label="γ-Secretase\nComplex"       fillcolor="#DEB887"]
        notch_sig      [label="Notch\nSignaling"           fillcolor="#DEB887"]
        wnt_sig        [label="Wnt/β-catenin\nSignaling"   fillcolor="#F4A460"]
        KRT_expr       [label="Keratin 6A/10\nExpression"  fillcolor="#F4A460"]
        keratinocyte_p [label="Keratinocyte\nHyperproliferation" fillcolor="#F4A460"]
        follicular_hk  [label="Follicular\nHyperkeratosis" fillcolor="#CD853F"]
        comedone       [label="Comedone\nFormation"        fillcolor="#CD853F"]
        follicular_occ [label="Follicular\nOcclusion"      fillcolor="#A0522D" fontcolor="white"]
        PSU_dilation   [label="Pilosebaceous Unit\nDilation" fillcolor="#8B4513" fontcolor="white"]
        follicular_rup [label="Follicular\nRupture ★"     fillcolor="#8B0000" fontcolor="white"]
        sebaceous_gl   [label="Sebaceous\nGland"          fillcolor="#FFE4B5"]
        sebum_prod     [label="Sebum\nProduction"         fillcolor="#FFE4B5"]
        AR_fol         [label="Androgen Receptor\n(Follicular)" fillcolor="#FF8C00"]
        infundibulum   [label="Infundibular\nEpithelium"  fillcolor="#F5DEB3"]
    }

    // ============================================================
    // CLUSTER 3: Innate Immune Activation
    // ============================================================
    subgraph cluster_innate {
        label = "3. Innate Immune Activation"
        style = "filled,rounded"
        color = "#8B0000"
        fillcolor = "#FFF0F0"
        fontsize = 12
        fontcolor = "#8B0000"

        TLR2  [label="TLR2"  fillcolor="#FF6B6B"]
        TLR4  [label="TLR4"  fillcolor="#FF6B6B"]
        TLR5  [label="TLR5"  fillcolor="#FF6B6B"]
        TLR9  [label="TLR9"  fillcolor="#FF6B6B"]
        NOD1  [label="NOD1"  fillcolor="#FF9999"]
        NOD2  [label="NOD2"  fillcolor="#FF9999"]
        NLRP3 [label="NLRP3\nInflammasome ★" fillcolor="#DC143C" fontcolor="white"]
        AIM2  [label="AIM2\nInflammasome"  fillcolor="#CC1122" fontcolor="white"]

        DAMP_keratin [label="Keratin\nDAMPs"    fillcolor="#FFB6C1"]
        urate_crys   [label="Urate\nCrystals"  fillcolor="#FFB6C1"]
        PAMP_bact    [label="Bacterial\nPAMPs" fillcolor="#FFCCCC"]
        NET_debris   [label="NET\nDebris"      fillcolor="#FFB6C1"]

        pro_IL1b  [label="Pro-IL-1β\n(inactive)" fillcolor="#FFA07A"]
        IL1b      [label="IL-1β ★"  fillcolor="#FF4500" fontcolor="white"]
        IL18      [label="IL-18"    fillcolor="#FF6347" fontcolor="white"]
        IL6       [label="IL-6 ★"  fillcolor="#FF4500" fontcolor="white"]
        IL8_CXCL8 [label="IL-8/CXCL8\n(Neutrophil\nChemokine)" fillcolor="#FF8C00" fontcolor="white"]
        IL12      [label="IL-12"   fillcolor="#FF7F50"]
        IL23      [label="IL-23 ★" fillcolor="#FF4500" fontcolor="white"]
        CXCL1     [label="CXCL1/2\n(GROα/β)"  fillcolor="#FFA07A"]
        CCL2      [label="CCL2/MCP-1\n(Macrophage)" fillcolor="#FFA07A"]

        macroM1   [label="M1 Macro-\nphage ★"  fillcolor="#B22222" fontcolor="white"]
        macroM2   [label="M2 Macro-\nphage"    fillcolor="#8B0000" fontcolor="white"]
        neutrophil[label="Neutrophil ★" fillcolor="#DC143C" fontcolor="white"]
        mast_cell [label="Mast Cell"   fillcolor="#C71585" fontcolor="white"]
        DC_cell   [label="Dendritic\nCell (DC)" fillcolor="#8B0000" fontcolor="white"]
        NK_cell   [label="NK Cell"     fillcolor="#A52A2A" fontcolor="white"]

        NFkB      [label="NF-κB\nActivation ★" fillcolor="#B22222" fontcolor="white"]
        IKK_comp  [label="IKKβ\nComplex"        fillcolor="#CD5C5C"]
        AP1       [label="AP-1\n(Jun/Fos)"     fillcolor="#CD5C5C"]

        C3a       [label="C3a"  fillcolor="#FF9999"]
        C5a       [label="C5a ★" fillcolor="#FF4444" fontcolor="white"]
        MAC_c5b9  [label="MAC\n(C5b-9)" fillcolor="#CC0000" fontcolor="white"]
        complement[label="Complement\nCascade"  fillcolor="#FF6666"]
    }

    // ============================================================
    // CLUSTER 4: Adaptive Immunity
    // ============================================================
    subgraph cluster_adaptive {
        label = "4. Adaptive Immune Response"
        style = "filled,rounded"
        color = "#00008B"
        fillcolor = "#F0F0FF"
        fontsize = 12
        fontcolor = "#00008B"

        Th1   [label="Th1 Cell"   fillcolor="#4169E1" fontcolor="white"]
        Th17  [label="Th17 Cell ★" fillcolor="#0000CD" fontcolor="white"]
        Th22  [label="Th22 Cell"  fillcolor="#1E90FF"]
        Treg  [label="Treg Cell"  fillcolor="#6495ED"]
        CD8T  [label="CD8+ Cyto-\ntoxic T"   fillcolor="#4682B4" fontcolor="white"]
        iTreg [label="iTreg\n(induced)"  fillcolor="#87CEEB"]

        B_cell   [label="B Cell"    fillcolor="#7B68EE"]
        plasma_c [label="Plasma\nCell"    fillcolor="#6A5ACD" fontcolor="white"]
        auto_Ab  [label="Anti-HS\nAntibodies" fillcolor="#9370DB"]

        IFNg  [label="IFN-γ"   fillcolor="#1E90FF"]
        IL17A [label="IL-17A ★" fillcolor="#0000FF" fontcolor="white"]
        IL17F [label="IL-17F"  fillcolor="#0000CD" fontcolor="white"]
        IL22  [label="IL-22 ★" fillcolor="#0066FF" fontcolor="white"]
        IL4   [label="IL-4"    fillcolor="#6495ED"]
        IL13  [label="IL-13"   fillcolor="#6495ED"]
        IL10  [label="IL-10\n(Anti-inflam)" fillcolor="#87CEEB"]
        IL21  [label="IL-21\n(Th17 help)"  fillcolor="#4169E1" fontcolor="white"]

        STAT3 [label="STAT3\nActivation"   fillcolor="#4169E1" fontcolor="white"]
        RORgt [label="RORγt\n(Th17 TF)"   fillcolor="#0000FF" fontcolor="white"]
        TBET  [label="T-bet\n(Th1 TF)"    fillcolor="#4169E1" fontcolor="white"]
        FOXP3 [label="FOXP3\n(Treg TF)"   fillcolor="#6495ED"]
    }

    // ============================================================
    // CLUSTER 5: TNF-α Signaling
    // ============================================================
    subgraph cluster_tnf {
        label = "5. TNF-α Signaling Pathway"
        style = "filled,rounded"
        color = "#006400"
        fillcolor = "#F0FFF0"
        fontsize = 12
        fontcolor = "#006400"

        TNFa      [label="TNF-α ★"    fillcolor="#228B22" fontcolor="white"]
        sTNFa     [label="Soluble\nTNF-α"   fillcolor="#32CD32"]
        tmTNFa    [label="tmTNF-α\n(membrane)" fillcolor="#228B22" fontcolor="white"]
        TNFR1     [label="TNFR1\n(p55)"  fillcolor="#006400" fontcolor="white"]
        TNFR2     [label="TNFR2\n(p75)"  fillcolor="#006400" fontcolor="white"]
        TRAF2_tnf [label="TRAF2"        fillcolor="#228B22" fontcolor="white"]
        casp8     [label="Caspase-8\nApoptosis" fillcolor="#90EE90"]
        ADAM17    [label="ADAM17/TACE\n(TNF shedding)" fillcolor="#3CB371"]
        RIP1      [label="RIP1\nKinase"  fillcolor="#2E8B57" fontcolor="white"]
        TNF_NF    [label="TNF→NF-κB\nFeedforward" fillcolor="#2E8B57" fontcolor="white"]
    }

    // ============================================================
    // CLUSTER 6: Hormonal & Metabolic Factors
    // ============================================================
    subgraph cluster_hormonal {
        label = "6. Hormonal & Metabolic Factors"
        style = "filled,rounded"
        color = "#FF1493"
        fillcolor = "#FFF0F8"
        fontsize = 12
        fontcolor = "#CC0066"

        testosterone [label="Testosterone" fillcolor="#FFB6C1"]
        DHT          [label="DHT\n(5α-DHT)"  fillcolor="#FF69B4"]
        DHEAS        [label="DHEAS\n(Adrenal)" fillcolor="#FFB6C1"]
        AR_sys       [label="Androgen\nReceptor (AR)" fillcolor="#FF1493" fontcolor="white"]
        fiveAlphaRed [label="5α-Reductase\n(SRD5A)" fillcolor="#C71585" fontcolor="white"]
        SHBG         [label="SHBG\n(binding)"  fillcolor="#FFB6C1"]
        estradiol    [label="Estradiol\n(E2)"   fillcolor="#FF69B4"]
        GnRH         [label="GnRH"            fillcolor="#FFB6C1"]
        LH_FSH       [label="LH / FSH"        fillcolor="#FFB6C1"]

        insulin_res  [label="Insulin\nResistance"    fillcolor="#FF8C00" fontcolor="white"]
        adipokines   [label="Adipokines\n(Leptin↑,Adiponectin↓)" fillcolor="#FFA500"]
        IGF1         [label="IGF-1"   fillcolor="#FF7F50"]
        mTOR         [label="mTOR\nPathway"  fillcolor="#FF6347"]
        AKT_PI3K     [label="PI3K/AKT\nPathway"  fillcolor="#FF7F50"]
        cortisol     [label="Cortisol\n(HPA)"  fillcolor="#FFD700"]
    }

    // ============================================================
    // CLUSTER 7: Skin Microbiome & Biofilm
    // ============================================================
    subgraph cluster_microbiome {
        label = "7. Skin Microbiome & Biofilm"
        style = "filled,rounded"
        color = "#808000"
        fillcolor = "#FFFFF0"
        fontsize = 12
        fontcolor = "#808000"

        S_aureus   [label="S. aureus\n★"       fillcolor="#9ACD32"]
        S_epiderm  [label="S. epidermidis" fillcolor="#ADFF2F"]
        C_acnes    [label="Cutibacterium\nacnes" fillcolor="#7CFC00"]
        Anaerobes  [label="Anaerobic\nBacteria" fillcolor="#6B8E23"]
        Corynebact [label="Corynebacterium\nspp."  fillcolor="#ADFF2F"]
        biofilm    [label="Biofilm\nFormation ★" fillcolor="#808000" fontcolor="white"]
        biofilm_mx [label="Biofilm\nMatrix (EPS)" fillcolor="#556B2F" fontcolor="white"]
        AMR        [label="Antimicrobial\nResistance" fillcolor="#6B8E23" fontcolor="white"]
        dysbiosis  [label="Microbiome\nDysbiosis" fillcolor="#8B8000" fontcolor="white"]

        AMP        [label="Antimicrobial\nPeptides"  fillcolor="#9ACD32"]
        beta_def   [label="β-Defensins\n(hBD-2/3)"  fillcolor="#9ACD32"]
        cathelicid [label="Cathelicidin\n(LL-37)"   fillcolor="#ADFF2F"]
        skin_barr  [label="Skin Barrier\nDysfunction" fillcolor="#8B8000" fontcolor="white"]
        FLG_expr   [label="Filaggrin\nExpression↓"  fillcolor="#CCCC00"]
    }

    // ============================================================
    // CLUSTER 8: Fibrosis, Wound Healing & Tissue Remodeling
    // ============================================================
    subgraph cluster_fibrosis {
        label = "8. Fibrosis, Wound Healing & Tissue Remodeling"
        style = "filled,rounded"
        color = "#8B4513"
        fillcolor = "#FFF8DC"
        fontsize = 12
        fontcolor = "#8B4513"

        TGFb       [label="TGF-β ★"       fillcolor="#DEB887"]
        TGFbR      [label="TGF-βR/\nSMAD2/3"  fillcolor="#D2691E" fontcolor="white"]
        myofibro   [label="Myofibroblast\nActivation" fillcolor="#A0522D" fontcolor="white"]
        collagen   [label="Collagen I/III\nDeposition" fillcolor="#8B4513" fontcolor="white"]
        MMP3       [label="MMP-3"   fillcolor="#DAA520"]
        MMP9       [label="MMP-9"   fillcolor="#DAA520"]
        MMP1       [label="MMP-1"   fillcolor="#DAA520"]
        TIMP1      [label="TIMP-1\n(MMP Inhib)" fillcolor="#B8860B"]
        fibroblast [label="Dermal\nFibroblast"  fillcolor="#CD853F"]
        sinus_tract[label="Sinus Tracts\n& Scars ★"  fillcolor="#8B0000" fontcolor="white"]
        VEGF       [label="VEGF\n(Angiogenesis)" fillcolor="#DAA520"]
        angiogen   [label="Neoangio-\ngenesis"     fillcolor="#B8860B" fontcolor="white"]
        ECM_rem    [label="ECM\nRemodeling"    fillcolor="#A0522D" fontcolor="white"]
        alpha_SMA  [label="α-SMA\nExpression"   fillcolor="#CD853F"]
        CTGF       [label="CTGF/\nCCN2"         fillcolor="#DEB887"]
    }

    // ============================================================
    // CLUSTER 9: Drug PK / PD
    // ============================================================
    subgraph cluster_drugs {
        label = "9. Drug Pharmacokinetics & Pharmacodynamics"
        style = "filled,rounded"
        color = "#800080"
        fillcolor = "#FFF0FF"
        fontsize = 12
        fontcolor = "#800080"

        // ----- Adalimumab (anti-TNF) -----
        ADA_dose  [label="Adalimumab\nDose (SC)"      fillcolor="#9932CC" fontcolor="white"]
        ADA_abs   [label="ADA Absorption\nDepot"      fillcolor="#BA55D3"]
        ADA_Cc    [label="ADA Central\nCmpt (C)"      fillcolor="#8B008B" fontcolor="white"]
        ADA_Cp    [label="ADA Peripheral\nCmpt (P)"   fillcolor="#800080" fontcolor="white"]
        ADA_F     [label="ADA Bioavail.\n(F=0.64)"    fillcolor="#DA70D6"]
        ADA_CL    [label="ADA Clearance\n(0.22 L/d)"  fillcolor="#DA70D6"]
        ADA_PD    [label="ADA→TNF-α\nSuppression"     fillcolor="#9370DB" fontcolor="white"]
        ADA_Ab    [label="Anti-ADA\nAntibodies (ADA)"  fillcolor="#EE82EE"]
        ADA_trough[label="ADA Trough\n(Target≥7.5)"   fillcolor="#DDA0DD"]
        TDM_ADA   [label="Therapeutic\nDrug Monitor"  fillcolor="#C8A2C8"]

        // ----- Secukinumab (anti-IL-17A) -----
        SEC_dose  [label="Secukinumab\nDose (SC)"     fillcolor="#7B68EE" fontcolor="white"]
        SEC_abs   [label="SEC Absorption\nDepot"      fillcolor="#9966CC"]
        SEC_Cc    [label="SEC Central\nCmpt (C)"      fillcolor="#6A5ACD" fontcolor="white"]
        SEC_F     [label="SEC Bioavail.\n(F=0.73)"    fillcolor="#9966CC"]
        SEC_CL    [label="SEC Clearance\n(0.19 L/d)"  fillcolor="#9966CC"]
        SEC_PD    [label="SEC→IL-17A\nSuppression"    fillcolor="#663399" fontcolor="white"]

        // ----- Bimekizumab (anti-IL-17A/F) -----
        BIM_dose  [label="Bimekizumab\nDose (SC)"     fillcolor="#5F4B8B" fontcolor="white"]
        BIM_Cc    [label="BIM Central\nCmpt (C)"      fillcolor="#4B3A7A" fontcolor="white"]
        BIM_PD    [label="BIM→IL-17A\n+IL-17F Supp."  fillcolor="#3A2A6A" fontcolor="white"]

        // ----- Ixekizumab (anti-IL-17A) -----
        IXE_dose  [label="Ixekizumab\nDose (SC)"  fillcolor="#6B3FA0" fontcolor="white"]
        IXE_PD    [label="IXE→IL-17A\nSuppression" fillcolor="#5A2D91" fontcolor="white"]

        // ----- Risankizumab (anti-IL-23) -----
        RISA_dose [label="Risankizumab\nDose (SC)"  fillcolor="#4B2082" fontcolor="white"]
        RISA_PD   [label="RISA→IL-23\nSuppression"  fillcolor="#3A1872" fontcolor="white"]

        // ----- Antibiotics -----
        doxy      [label="Doxycycline\n(100 mg BID)" fillcolor="#9370DB" fontcolor="white"]
        clinda    [label="Clindamycin\n(Topical/Oral)" fillcolor="#9370DB" fontcolor="white"]
        rifampin  [label="Rifampicin\n(300 mg BID)" fillcolor="#9370DB" fontcolor="white"]
        metronidaz[label="Metronidazole\n(Combination)" fillcolor="#9370DB" fontcolor="white"]
        AB_eff    [label="Antibiotic→\nBiofilm Disruption" fillcolor="#800080" fontcolor="white"]

        // ----- Hormonal therapies -----
        OCP_node  [label="OCP\n(Drospirenone/EE)" fillcolor="#FF69B4"]
        spiro     [label="Spironolactone\n(Anti-androgen)" fillcolor="#FF1493" fontcolor="white"]
        finaster  [label="Finasteride\n(5α-Red Inhib)" fillcolor="#C71585" fontcolor="white"]
        horm_eff  [label="Hormonal→\nDHT Reduction" fillcolor="#DB7093" fontcolor="white"]

        // ----- Retinoids / Zinc -----
        retinoid  [label="Acitretin/\nIsotretinoin" fillcolor="#DA70D6"]
        ret_eff   [label="Retinoid→\nFollicular Norm." fillcolor="#BA55D3"]
        zinc_node [label="Zinc\nSupplement"         fillcolor="#9370DB" fontcolor="white"]
        zinc_eff  [label="Zinc→NF-κB\nInhibition"  fillcolor="#8B008B" fontcolor="white"]

        // ----- JAK inhibitor -----
        JAKi      [label="JAK Inhibitor\n(Povorcitinib)" fillcolor="#6B21A8" fontcolor="white"]
        JAKi_eff  [label="JAKi→STAT3\nInhibition"        fillcolor="#581C87" fontcolor="white"]

        // ----- Metformin -----
        metform   [label="Metformin\n(Metabolic)"  fillcolor="#9333EA" fontcolor="white"]
        metform_eff[label="Metformin→\nmTOR Inhibition" fillcolor="#7C3AED" fontcolor="white"]
    }

    // ============================================================
    // CLUSTER 10: Clinical Endpoints & Disease Staging
    // ============================================================
    subgraph cluster_endpoints {
        label = "10. Clinical Endpoints & Disease Staging"
        style = "filled,rounded"
        color = "#2F4F4F"
        fillcolor = "#F5FFFA"
        fontsize = 12
        fontcolor = "#2F4F4F"

        hurley1    [label="Hurley Stage I\n(Isolated abscess)" fillcolor="#90EE90"]
        hurley2    [label="Hurley Stage II\n(Recurrent + sinus)" fillcolor="#FFD700"]
        hurley3    [label="Hurley Stage III\n(Diffuse/extensive)" fillcolor="#FF4500" fontcolor="white"]

        abscess    [label="Abscess ★"    fillcolor="#DC143C" fontcolor="white"]
        nodule     [label="Inflammatory\nNodule ★"   fillcolor="#B22222" fontcolor="white"]
        fistula    [label="Fistula/Draining\nSinus" fillcolor="#8B0000" fontcolor="white"]
        AN_count   [label="AN Count\n(A+N score) ★" fillcolor="#3CB371" fontcolor="white"]
        IHS4       [label="IHS4\nScore ★"            fillcolor="#2E8B57" fontcolor="white"]
        HiSCR      [label="HiSCR\n(≥50% AN↓) ★"    fillcolor="#006400" fontcolor="white"]
        DLQI       [label="DLQI\n(QoL)"              fillcolor="#228B22" fontcolor="white"]
        VAS_pain   [label="VAS Pain\nScore"          fillcolor="#20B2AA"]
        HADS       [label="HADS\n(Anxiety/Dep)"      fillcolor="#2E8B57" fontcolor="white"]
        LRINEC     [label="LRINEC\nScore"            fillcolor="#3CB371" fontcolor="white"]
        SOS_HS     [label="SOS-HS\n(Symptom Score)" fillcolor="#228B22" fontcolor="white"]

        remission  [label="Clinical\nRemission"  fillcolor="#32CD32"]
        recurrence [label="Disease\nRecurrence"  fillcolor="#FF6347"]
        flare      [label="Disease\nFlare"        fillcolor="#FF0000" fontcolor="white"]

        axilla     [label="Axillary\nRegion"        fillcolor="#F5DEB3"]
        groin      [label="Inguinal/\nPerineal"     fillcolor="#F5DEB3"]
        infra_mamm [label="Inframammary\nFold"      fillcolor="#F5DEB3"]
        buttocks   [label="Buttocks/\nPerianal"     fillcolor="#F5DEB3"]
        body_count [label="Body Region\nCount"      fillcolor="#DEB887"]
    }

    // ============================================================
    // EDGES — Pathway Connections
    // ============================================================

    // -- Genetics → Follicular --
    NCSTN   -> gamma_sec [label="LoF" color="red" style="dashed"]
    PSEN1   -> gamma_sec [label="mutation" color="red" style="dashed"]
    PSEN2   -> gamma_sec [label="mutation" color="red" style="dashed"]
    PSENEN  -> gamma_sec [label="mutation" color="red" style="dashed"]
    POFUT1  -> notch_sig [label="glycosylation\ndefect" color="red" style="dashed"]
    FamHist -> follicular_hk [color="darkred" style="dashed"]
    gamma_sec -> notch_sig   [label="impairs ↓" color="red" arrowhead="tee"]
    notch_sig -> keratinocyte_p [label="regulates" color="purple"]
    notch_sig -> follicular_hk  [label="↓Notch→\n↑keratin" color="red"]
    notch_sig -> wnt_sig        [label="crosstalk" color="purple" style="dashed"]
    wnt_sig   -> keratinocyte_p [color="purple"]
    KRT_expr  -> follicular_hk  [color="saddlebrown"]

    // -- Environment → Follicular --
    mech_stress  -> follicular_occ [color="brown"]
    heat_sweat   -> sebum_prod     [color="orange"]
    smoking      -> NFkB           [color="darkred" style="dashed"]
    smoking      -> follicular_hk  [color="brown" style="dashed"]
    IBD_assoc    -> NFkB           [color="red" style="dashed"]
    psych_stress -> FH_axis        [color="gray"]
    FH_axis      -> cortisol       [label="↓cortisol" color="gold"]
    cortisol     -> NFkB           [label="↓anti-inflam" color="red"]

    // -- Hormonal → Follicular --
    LH_FSH    -> testosterone    [color="deeppink"]
    GnRH      -> LH_FSH          [label="pituitary" color="deeppink"]
    DHEAS     -> testosterone    [color="pink" style="dashed"]
    testosterone -> fiveAlphaRed  [color="deeppink"]
    fiveAlphaRed -> DHT           [color="deeppink"]
    DHT        -> AR_fol          [label="binds" color="deeppink"]
    AR_fol     -> sebum_prod      [label="↑sebum" color="orange"]
    AR_fol     -> keratinocyte_p  [label="↑prolif" color="orange"]
    menstrual  -> testosterone    [color="pink"]
    menstrual  -> flare           [label="premenstrual\nflare" color="pink"]
    SHBG       -> testosterone    [label="binds/sequesters" color="pink" arrowhead="tee"]
    estradiol  -> SHBG            [label="↑SHBG" color="pink"]

    // -- Follicular cascade --
    keratinocyte_p -> follicular_hk  [color="saddlebrown"]
    sebum_prod     -> follicular_occ [color="saddlebrown"]
    follicular_hk  -> comedone       [color="saddlebrown"]
    comedone       -> follicular_occ [color="saddlebrown"]
    infundibulum   -> follicular_hk  [label="keratinization" color="saddlebrown"]
    follicular_occ -> PSU_dilation   [label="obstruction" color="darkred"]
    PSU_dilation   -> follicular_rup [label="pressure→\nrupture" color="red"]
    sebaceous_gl   -> sebum_prod     [color="orange"]

    // -- Follicular rupture → Innate --
    follicular_rup -> DAMP_keratin [label="releases" color="red"]
    follicular_rup -> PAMP_bact    [label="exposes" color="red"]
    follicular_rup -> NFkB         [label="danger\nsignal" color="darkred"]

    // -- Microbiome → Innate --
    S_aureus   -> TLR2    [label="LTA/PGN" color="olive"]
    S_aureus   -> TLR9    [label="CpG DNA" color="olive"]
    S_aureus   -> biofilm [label="forms" color="olive"]
    Anaerobes  -> biofilm [label="forms" color="olive"]
    C_acnes    -> TLR2    [color="olive"]
    PAMP_bact  -> TLR4    [label="LPS" color="olive"]
    PAMP_bact  -> TLR2    [color="olive"]
    PAMP_bact  -> NOD2    [label="MDP" color="olive"]
    dysbiosis  -> PAMP_bact [color="olive"]
    S_aureus   -> dysbiosis [color="olive"]
    biofilm    -> biofilm_mx [color="olive"]
    biofilm    -> AMR        [color="olive"]
    biofilm    -> dysbiosis  [label="perpetuates" color="olive"]

    // -- Skin barrier --
    FLG_expr   -> skin_barr  [label="↓FLG→\n↑permeability" color="darkred"]
    skin_barr  -> S_aureus   [label="↑colonization" color="olive"]
    IL17A      -> skin_barr  [label="↓barrier" color="blue" arrowhead="tee"]
    IL22       -> skin_barr  [label="↓claudin-1" color="blue" arrowhead="tee"]
    AMP        -> S_aureus   [label="antimicrobial" color="olive" arrowhead="tee"]
    beta_def   -> S_aureus   [label="antimicrobial" color="olive" arrowhead="tee"]
    cathelicid -> biofilm    [label="disrupts" color="olive" arrowhead="tee"]
    IL17A      -> beta_def   [label="↑hBD-2/3" color="blue"]
    IL22       -> AMP        [label="↑AMPs" color="blue"]

    // -- Pattern recognition → Inflammasome/NFkB --
    TLR2  -> NFkB    [label="MyD88" color="red"]
    TLR4  -> NFkB    [label="TRIF/\nMyD88" color="red"]
    TLR5  -> NFkB    [color="red"]
    TLR9  -> NFkB    [label="IRF3" color="red"]
    NOD1  -> NFkB    [label="RIP2K" color="red"]
    NOD2  -> NFkB    [label="RIP2K" color="red"]
    TLR4  -> AP1     [color="red"]
    NFkB  -> AP1     [label="cooperate" color="red" style="dashed"]

    DAMP_keratin -> NLRP3   [label="activates" color="darkred"]
    urate_crys   -> NLRP3   [label="crystals" color="red"]
    PAMP_bact    -> NLRP3   [label="signal 2" color="red"]
    NET_debris   -> NLRP3   [label="mtDNA" color="red"]
    DAMP_keratin -> AIM2    [label="dsDNA" color="red"]
    NLRP3 -> pro_IL1b [label="caspase-1\ncleavage" color="darkred"]
    NLRP3 -> IL18     [label="caspase-1" color="red"]
    AIM2  -> IL1b     [label="caspase-1" color="red"]
    pro_IL1b -> IL1b  [label="activated" color="red"]

    // -- NFkB → Cytokines --
    NFkB -> TNFa      [label="transcription" color="green"]
    NFkB -> IL6       [label="transcription" color="orange"]
    NFkB -> IL8_CXCL8 [label="transcription" color="orange"]
    NFkB -> IL12      [label="transcription" color="purple"]
    NFkB -> IL23      [label="transcription" color="purple"]
    NFkB -> CXCL1     [color="orange"]
    NFkB -> CCL2      [color="orange"]
    IKK_comp -> NFkB  [label="IκB phosph." color="red"]

    // -- Macrophage --
    follicular_rup -> macroM1  [label="recruits" color="brown"]
    CCL2           -> macroM1  [label="recruits" color="brown"]
    IL1b           -> macroM1  [label="activates" color="red"]
    IFNg           -> macroM1  [label="M1 polarize" color="blue"]
    macroM1 -> TNFa     [label="secretes" color="green"]
    macroM1 -> IL6      [label="secretes" color="orange"]
    macroM1 -> IL12     [color="purple"]
    macroM1 -> IL23     [color="purple"]
    macroM1 -> NFkB     [label="feedforward" color="darkred"]
    macroM1 -> macroM2  [label="IL-4→M2\nresolution" color="blue" style="dashed"]
    macroM2 -> IL10     [label="secretes" color="green"]
    macroM2 -> TGFb     [label="secretes" color="saddlebrown"]
    IL4     -> macroM2  [label="M2 polarize" color="blue"]
    IL13    -> macroM2  [label="M2 polarize" color="blue"]

    // -- DC --
    PAMP_bact -> DC_cell [label="matures" color="brown"]
    DC_cell   -> IL12    [label="secretes" color="purple"]
    DC_cell   -> IL23    [label="secretes" color="purple"]
    DC_cell   -> Th1     [label="primes" color="blue"]
    DC_cell   -> Th17    [label="primes" color="blue"]

    // -- NK cell --
    IL12 -> NK_cell   [label="activates" color="purple"]
    NK_cell -> IFNg   [label="secretes" color="blue"]
    NK_cell -> TNFa   [label="secretes" color="green"]

    // -- Neutrophil --
    IL8_CXCL8 -> neutrophil [label="recruits" color="orange"]
    CXCL1     -> neutrophil [label="recruits" color="orange"]
    C5a       -> neutrophil [label="recruits" color="red"]
    neutrophil -> NFkB   [label="activates" color="red"]
    neutrophil -> NLRP3  [label="NETs→\nactivates" color="red"]
    neutrophil -> NET_debris [label="releases" color="red"]
    neutrophil -> abscess [label="forms\npus" color="darkred"]
    neutrophil -> MMP9   [label="releases" color="brown"]
    neutrophil -> IL8_CXCL8 [label="amplifies" color="orange"]

    // -- Mast cell --
    mast_cell -> TNFa      [label="degranulates" color="green"]
    mast_cell -> IL8_CXCL8 [label="secretes" color="orange"]
    C3a       -> mast_cell [label="activates" color="red"]

    // -- Complement --
    PAMP_bact  -> complement [label="activates" color="red"]
    complement -> C3a        [color="red"]
    complement -> C5a        [color="red"]
    complement -> MAC_c5b9   [color="red"]
    C5a -> macroM1 [label="activates" color="brown"]
    MAC_c5b9 -> follicular_rup [label="cell lysis→\nDAMPs" color="red"]

    // -- T cell differentiation --
    IL12 -> Th1   [label="Th1 bias\n(TBET)" color="blue"]
    IL23 -> Th17  [label="maintenance" color="blue"]
    IL1b -> Th17  [label="differentiates" color="blue"]
    IL6  -> Th17  [label="+TGF-β" color="blue"]
    IL6  -> STAT3 [label="JAK1/2" color="blue"]
    STAT3 -> RORgt [label="activates" color="blue"]
    RORgt -> Th17  [label="master TF" color="blue"]
    IL12  -> TBET  [label="activates" color="blue"]
    TBET  -> Th1   [label="master TF" color="blue"]
    IL21  -> Th17  [label="autocrine" color="blue" style="dashed"]
    Th17  -> IL21  [label="secretes" color="blue"]
    IL6   -> FOXP3 [label="inhibits↓\n(Treg suppress)" color="red" arrowhead="tee"]
    TGFb  -> FOXP3 [label="induces\niTreg" color="saddlebrown"]
    FOXP3 -> iTreg [label="master TF" color="green"]
    FOXP3 -> Treg  [color="green"]
    Th17  -> IL17A [label="secretes" color="blue"]
    Th17  -> IL17F [label="secretes" color="blue"]
    Th17  -> IL22  [label="secretes" color="blue"]
    Th22  -> IL22  [label="secretes" color="blue"]
    Th1   -> IFNg  [label="secretes" color="blue"]
    CD8T  -> IFNg  [label="secretes" color="blue"]
    CD8T  -> TNFa  [label="secretes" color="green"]

    // -- B cell --
    Th1    -> B_cell    [label="T-B help" color="blue"]
    IL17A  -> B_cell    [label="promotes" color="blue"]
    B_cell -> plasma_c  [label="differentiates" color="purple"]
    plasma_c -> auto_Ab [label="secretes" color="purple"]

    // -- IL-17 effects --
    IL17A -> NFkB     [label="Act1→\nTRAF6→NF-κB" color="darkblue"]
    IL17A -> IL6      [label="synergizes" color="darkblue"]
    IL17A -> IL8_CXCL8[label="↑chemokine" color="darkblue"]
    IL17A -> AMP      [label="↑defensins" color="darkblue"]
    IL17A -> CXCL1    [label="↑CXCL1" color="darkblue"]
    IL17A -> TGFb     [label="↑TGF-β" color="darkblue"]
    IL17A -> MMP3     [label="↑MMP-3" color="brown"]
    IL17F -> NFkB     [label="similar\nIL-17A" color="darkblue"]
    IL17F -> IL8_CXCL8[color="darkblue"]

    // -- IL-22 effects --
    IL22 -> keratinocyte_p [label="↑prolif" color="blue"]
    IL22 -> AMP             [label="↑AMPs" color="blue"]
    IL22 -> skin_barr       [label="↑permeability" color="red" arrowhead="tee"]

    // -- TNF-α pathway --
    TNFa   -> sTNFa    [label="ADAM17\ncleavage" color="green"]
    TNFa   -> tmTNFa   [label="membrane" color="green"]
    sTNFa  -> TNFR1    [label="binds" color="green"]
    tmTNFa -> TNFR2    [label="binds" color="green"]
    TNFR1  -> TRAF2_tnf[color="green"]
    TNFR1  -> RIP1     [color="green"]
    TRAF2_tnf -> IKK_comp [label="activates" color="green"]
    RIP1   -> IKK_comp [color="green"]
    TNFR1  -> casp8    [label="apoptosis" color="green"]
    ADAM17 -> sTNFa    [color="green"]
    TNF_NF -> NFkB     [label="TNF→\nNF-κB loop" color="green"]
    TNFR1  -> TNF_NF   [color="green"]
    TNFa   -> ADAM17   [label="↑ADAM17\nexpression" color="green"]

    // -- Fibrosis --
    TGFb     -> TGFbR      [label="binds" color="saddlebrown"]
    TGFbR    -> myofibro   [label="SMAD2/3\nactivates" color="saddlebrown"]
    myofibro -> collagen    [label="secretes" color="saddlebrown"]
    myofibro -> TGFb        [label="autocrine\nloop" color="saddlebrown"]
    myofibro -> alpha_SMA   [label="expresses" color="saddlebrown"]
    myofibro -> CTGF        [label="secretes" color="saddlebrown"]
    fibroblast -> myofibro  [label="TGF-β→\ntransdiff." color="saddlebrown"]
    collagen   -> sinus_tract [label="forms\nscars" color="darkred"]
    CTGF       -> collagen   [label="↑collagen" color="saddlebrown"]

    // -- MMP/TIMP --
    MMP9   -> ECM_rem  [color="brown"]
    MMP3   -> ECM_rem  [color="brown"]
    MMP1   -> ECM_rem  [color="brown"]
    TIMP1  -> MMP9     [label="inhibits" color="green" arrowhead="tee"]
    TIMP1  -> MMP3     [label="inhibits" color="green" arrowhead="tee"]
    IL1b   -> MMP3     [label="↑MMP-3" color="red"]
    TNFa   -> MMP3     [label="↑MMP-3" color="green"]
    IL17A  -> MMP9     [label="↑MMP-9" color="blue"]

    // -- VEGF/Angiogenesis --
    VEGF   -> angiogen [label="stimulates" color="brown"]
    TNFa   -> VEGF     [label="↑VEGF" color="green"]
    IL1b   -> VEGF     [label="↑VEGF" color="red"]
    IL17A  -> VEGF     [label="↑VEGF" color="blue"]
    angiogen -> sinus_tract [label="vascularized\ntissue" color="brown"]

    // -- Metabolic --
    obesity_node  -> insulin_res  [color="orange"]
    obesity_node  -> adipokines   [color="orange"]
    obesity_node  -> AR_sys       [label="↑androgen\nconversion" color="deeppink"]
    insulin_res   -> IGF1         [label="↑IGF-1" color="orange"]
    insulin_res   -> mTOR         [color="orange"]
    IGF1          -> sebum_prod   [label="↑sebum" color="orange"]
    adipokines    -> NFkB         [label="leptin→\nNF-κB" color="orange"]
    mTOR          -> keratinocyte_p [label="↑prolif" color="orange"]
    mTOR          -> AKT_PI3K     [label="downstream" color="orange"]
    AKT_PI3K      -> mTOR         [label="upstream" color="orange" style="dashed"]

    // -- IL-10 anti-inflammatory --
    IL10  -> TNFa     [label="suppresses" color="blue" arrowhead="tee"]
    IL10  -> IL6      [label="suppresses" color="blue" arrowhead="tee"]
    IL10  -> NFkB     [label="inhibits" color="blue" arrowhead="tee"]
    IL10  -> IL12     [label="inhibits" color="blue" arrowhead="tee"]
    Treg  -> IL10     [label="secretes" color="green"]
    Treg  -> TGFb     [label="secretes" color="saddlebrown"]
    Treg  -> Th17     [label="suppresses" color="green" arrowhead="tee"]
    iTreg -> Th17     [label="suppresses" color="green" arrowhead="tee"]

    // -- Clinical outcomes --
    abscess    -> AN_count  [color="red"]
    nodule     -> AN_count  [color="red"]
    AN_count   -> IHS4      [label="×2" color="darkgreen"]
    fistula    -> IHS4      [label="×1" color="darkgreen"]
    nodule     -> IHS4      [label="×1" color="darkgreen"]
    IHS4       -> hurley1   [label="mild" color="darkgreen"]
    IHS4       -> hurley2   [label="moderate" color="orange"]
    IHS4       -> hurley3   [label="severe" color="red"]
    sinus_tract -> fistula  [label="develops" color="brown"]
    follicular_rup -> nodule[label="forms" color="brown"]
    IL1b   -> abscess       [label="↑↑" color="red"]
    TNFa   -> abscess       [label="↑" color="green"]
    IL17A  -> nodule        [label="↑inflam." color="blue"]
    IL6    -> flare         [label="triggers" color="orange"]
    body_count -> IHS4      [label="body\nregions" color="darkgreen"]

    axilla     -> body_count [color="gray"]
    groin      -> body_count [color="gray"]
    infra_mamm -> body_count [color="gray"]
    buttocks   -> body_count [color="gray"]

    AN_count  -> VAS_pain   [color="darkred"]
    fistula   -> VAS_pain   [color="darkred"]
    VAS_pain  -> DLQI       [color="purple"]
    AN_count  -> DLQI       [color="purple"]
    DLQI      -> HADS       [label="impacts" color="purple" style="dashed"]
    AN_count  -> HiSCR      [label="≥50% ↓\n= HiSCR+" color="darkgreen"]
    HiSCR     -> remission  [color="darkgreen"]
    IHS4      -> SOS_HS     [label="combined" color="darkgreen"]
    AN_count  -> LRINEC     [label="infection\nseverity" color="darkgreen"]

    hurley1 -> hurley2 [label="progression" color="orange"]
    hurley2 -> hurley3 [label="progression" color="red"]
    remission  -> recurrence [label="relapse" color="red" style="dashed"]
    recurrence -> flare      [color="red"]
    flare      -> follicular_rup [label="new\nruptures" color="red"]

    // ============================================================
    // DRUG EFFECTS
    // ============================================================

    // Adalimumab PK
    ADA_dose -> ADA_abs   [label="SC injection\nF=0.64" color="purple"]
    ADA_abs  -> ADA_Cc    [label="ka=0.28/d" color="purple"]
    ADA_Cc   -> ADA_Cp    [label="distribution\nQ=0.5 L/d" color="purple"]
    ADA_Cp   -> ADA_Cc    [label="redistribution" color="purple"]
    ADA_Cc   -> ADA_CL    [label="elimination\n0.22 L/d" color="purple"]
    ADA_F    -> ADA_Cc    [color="purple" style="dashed"]
    ADA_dose -> ADA_Ab    [label="immunogenicity\nrisk" color="pink" style="dashed"]
    ADA_Ab   -> ADA_Cc    [label="↑clearance\n(ADA+)" color="red"]
    ADA_Cc   -> ADA_trough[label="trough\nC_min" color="purple"]
    TDM_ADA  -> ADA_trough[label="monitors" color="purple"]
    ADA_Cc   -> ADA_PD    [label="Emax: EC50=\n0.2 μg/mL" color="purple"]
    ADA_PD   -> TNFa      [label="neutralizes\n(Imax=98%)" color="purple" arrowhead="tee"]
    ADA_PD   -> sTNFa     [label="neutralizes" color="purple" arrowhead="tee"]

    // Secukinumab PK/PD
    SEC_dose -> SEC_abs  [label="SC\nF=0.73" color="indigo"]
    SEC_abs  -> SEC_Cc   [label="ka=0.3/d" color="indigo"]
    SEC_Cc   -> SEC_CL   [label="0.19 L/d" color="indigo"]
    SEC_Cc   -> SEC_PD   [label="Emax model\nEC50=0.08" color="indigo"]
    SEC_PD   -> IL17A    [label="neutralizes" color="indigo" arrowhead="tee"]

    // Bimekizumab PK/PD
    BIM_dose -> BIM_Cc  [label="SC\nF=0.74" color="darkviolet"]
    BIM_Cc   -> BIM_PD  [label="Emax model" color="darkviolet"]
    BIM_PD   -> IL17A   [label="neutralizes" color="darkviolet" arrowhead="tee"]
    BIM_PD   -> IL17F   [label="neutralizes" color="darkviolet" arrowhead="tee"]

    // Ixekizumab PK/PD
    IXE_dose -> IXE_PD  [label="SC Emax" color="mediumpurple"]
    IXE_PD   -> IL17A   [label="neutralizes" color="mediumpurple" arrowhead="tee"]

    // Risankizumab PK/PD
    RISA_dose -> RISA_PD [label="SC Emax" color="navy"]
    RISA_PD   -> IL23    [label="neutralizes\n(p19 subunit)" color="navy" arrowhead="tee"]

    // Antibiotics PD
    doxy       -> AB_eff  [color="mediumpurple"]
    clinda     -> AB_eff  [color="mediumpurple"]
    rifampin   -> AB_eff  [color="mediumpurple"]
    metronidaz -> AB_eff  [color="mediumpurple"]
    AB_eff -> biofilm     [label="disrupts" color="mediumpurple" arrowhead="tee"]
    AB_eff -> S_aureus    [label="reduces" color="mediumpurple" arrowhead="tee"]
    AB_eff -> Anaerobes   [label="reduces" color="mediumpurple" arrowhead="tee"]
    AB_eff -> NFkB        [label="doxy: anti-inflam" color="purple" arrowhead="tee" style="dashed"]

    // Hormonal therapy PD
    OCP_node -> horm_eff  [color="deeppink"]
    spiro    -> horm_eff  [color="deeppink"]
    finaster -> horm_eff  [color="deeppink"]
    horm_eff -> DHT       [label="↓DHT" color="deeppink" arrowhead="tee"]
    horm_eff -> AR_fol    [label="↓AR act." color="deeppink" arrowhead="tee"]
    finaster -> fiveAlphaRed [label="inhibits" color="deeppink" arrowhead="tee"]
    spiro    -> AR_sys    [label="blocks AR" color="deeppink" arrowhead="tee"]

    // Retinoid PD
    retinoid -> ret_eff     [color="violet"]
    ret_eff  -> follicular_hk [label="normalizes" color="violet" arrowhead="tee"]
    ret_eff  -> sebum_prod    [label="↓sebum" color="violet" arrowhead="tee"]
    ret_eff  -> keratinocyte_p[label="↓prolif" color="violet" arrowhead="tee"]

    // Zinc PD
    zinc_node -> zinc_eff   [color="gray"]
    zinc_eff  -> NFkB       [label="inhibits" color="gray" arrowhead="tee"]
    zinc_eff  -> neutrophil [label="modulates" color="gray"]

    // JAK inhibitor PD
    JAKi    -> JAKi_eff  [color="darkviolet"]
    JAKi_eff -> STAT3    [label="inhibits\n(JAK1/2)" color="darkviolet" arrowhead="tee"]
    STAT3   -> IL17A     [label="↑IL-17A" color="blue" style="dashed"]
    STAT3   -> IL6       [label="↑IL-6\n(autocrine)" color="orange" style="dashed"]
    JAKi_eff -> IFNg     [label="↓IFN-γ\nsignaling" color="darkviolet" arrowhead="tee" style="dashed"]

    // Metformin PD
    metform  -> metform_eff   [color="violet"]
    metform_eff -> mTOR       [label="AMPK-\nmediated ↓" color="violet" arrowhead="tee"]
    metform_eff -> insulin_res [label="↓IR" color="violet" arrowhead="tee"]
    metform_eff -> NFkB       [label="anti-inflam" color="violet" arrowhead="tee" style="dashed"]
}
