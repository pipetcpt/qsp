digraph UC_QSP {
    rankdir=LR;
    compound=true;
    splines=ortho;
    graph [fontname="Helvetica", fontsize=10, overlap=false, nodesep=0.3, ranksep=0.8];
    node  [fontname="Helvetica", fontsize=9, style=filled, fillcolor=white];
    edge  [fontname="Helvetica", fontsize=8];

    // =====================================================
    // CLUSTER 1: GENETICS & RISK FACTORS
    // =====================================================
    subgraph cluster_genetics {
        label="Genetics & Risk Factors";
        style=filled; fillcolor=lightgoldenrodyellow;
        fontsize=12; fontcolor=darkgoldenrod;

        HLA_DQ        [label="HLA-DQ", shape=box];
        IL10_locus    [label="IL10 locus", shape=box];
        IL23R         [label="IL23R", shape=box];
        NOD2          [label="NOD2", shape=box];
        TNFSF15       [label="TNFSF15", shape=box];
        JAK2_variant  [label="JAK2 variant", shape=box];
        HNF4A         [label="HNF4A", shape=box];
        CDH1          [label="CDH1", shape=box];
        LAMB1         [label="LAMB1", shape=box];
        PTPN22        [label="PTPN22", shape=box];
        MHC_region    [label="MHC region", shape=box];
        SLC22A5       [label="SLC22A5", shape=box];
        IBD_loci_2q37 [label="IBD loci 2q37", shape=box];
        Smoking_protective [label="Smoking (protective)", shape=box, fillcolor=lightyellow];
        NSAIDs_risk   [label="NSAIDs (risk)", shape=box, fillcolor=lightyellow];
        Antibiotics_early [label="Early Antibiotics", shape=box, fillcolor=lightyellow];
        Western_diet  [label="Western Diet", shape=box, fillcolor=lightyellow];
        Stress_HPA    [label="HPA Stress Axis", shape=box, fillcolor=lightyellow];
    }

    // =====================================================
    // CLUSTER 2: EPITHELIAL BARRIER
    // =====================================================
    subgraph cluster_epithelial_barrier {
        label="Epithelial Barrier";
        style=filled; fillcolor=lightyellow;
        fontsize=12; fontcolor=goldenrod;

        Colonocyte            [label="Colonocyte", shape=box];
        Goblet_cell           [label="Goblet Cell", shape=box];
        MUC2                  [label="MUC2 Mucin", shape=box];
        MUC5AC                [label="MUC5AC", shape=box];
        ZO1_tight_junction    [label="ZO-1 (Tight Junction)", shape=box];
        Occludin              [label="Occludin", shape=box];
        Claudin1              [label="Claudin-1", shape=box];
        HBD2_defensin         [label="hBD-2 Defensin", shape=box];
        IEC_apoptosis         [label="IEC Apoptosis", shape=box];
        ER_stress_UPR         [label="ER Stress / UPR", shape=box];
        EGF_receptor          [label="EGF Receptor", shape=box];
        IGF1_receptor         [label="IGF-1 Receptor", shape=box];
        Epithelial_wound_healing [label="Epithelial Wound Healing", shape=box];
        MLCK_activation       [label="MLCK Activation", shape=box];
        LGR5_stem_cell        [label="LGR5+ Crypt Stem Cell", shape=box];
        Paneth_cell_metaplasia [label="Paneth Cell Metaplasia", shape=box];
        Tuft_cell_IL25        [label="Tuft Cell / IL-25", shape=box];
    }

    // =====================================================
    // CLUSTER 3: MICROBIOME
    // =====================================================
    subgraph cluster_microbiome {
        label="Microbiome & Luminal Environment";
        style=filled; fillcolor=honeydew;
        fontsize=12; fontcolor=darkgreen;

        F_prausnitzii_down  [label="F. prausnitzii down", shape=box];
        Bifidobacterium_down [label="Bifidobacterium down", shape=box];
        Roseburia_down      [label="Roseburia down", shape=box];
        E_coli_AIEC_up      [label="E. coli AIEC up", shape=box];
        C_difficile         [label="C. difficile", shape=box];
        Butyrate_SCFA       [label="Butyrate / SCFA", shape=box];
        LPS_MAMP            [label="LPS / MAMPs", shape=box];
        Secretory_IgA       [label="Secretory IgA", shape=box];
        Mucus_penetration   [label="Mucus Penetration", shape=box];
        Dysbiosis_index     [label="Dysbiosis Index", shape=box, fillcolor=lightcoral];
        TLR4_LPS_sensing    [label="TLR4 (LPS sensing)", shape=box];
        TLR2_sensing        [label="TLR2 sensing", shape=box];
        NOD2_MDP            [label="NOD2 / MDP", shape=box];
    }

    // =====================================================
    // CLUSTER 4: INNATE IMMUNITY
    // =====================================================
    subgraph cluster_innate {
        label="Innate Immunity";
        style=filled; fillcolor=lavender;
        fontsize=12; fontcolor=indigo;

        Macrophage_M1       [label="Macrophage M1", shape=box];
        Macrophage_M2       [label="Macrophage M2", shape=box];
        Recruited_monocyte  [label="Recruited Monocyte", shape=box];
        Neutrophil_influx   [label="Neutrophil Influx", shape=box, fillcolor=lavenderblush];
        CXCL8_gradient      [label="CXCL8 Gradient", shape=box];
        mDC                 [label="mDC", shape=box];
        pDC_IFNa            [label="pDC / IFN-a", shape=box];
        ILC1                [label="ILC1", shape=box];
        ILC2                [label="ILC2", shape=box];
        ILC3                [label="ILC3", shape=box];
        NKT_cell            [label="NKT Cell", shape=box];
        Mast_cell           [label="Mast Cell", shape=box];
        NLRP3_inflammasome  [label="NLRP3 Inflammasome", shape=box];
        Caspase1            [label="Caspase-1", shape=box];
        IL1beta_mature      [label="IL-1b (mature)", shape=box];
        IL18_mature         [label="IL-18 (mature)", shape=box];
        Complement_C3       [label="Complement C3", shape=box];
        C5a_receptor        [label="C5a Receptor", shape=box];
        ROS_NOX2            [label="ROS / NOX2", shape=box];
        MPO_neutrophil      [label="MPO (Neutrophil)", shape=box];
    }

    // =====================================================
    // CLUSTER 5: ADAPTIVE IMMUNITY
    // =====================================================
    subgraph cluster_adaptive {
        label="Adaptive Immunity";
        style=filled; fillcolor=aliceblue;
        fontsize=12; fontcolor=navy;

        CD4_naive           [label="CD4+ Naive T", shape=box];
        Th1_cell            [label="Th1 Cell", shape=box];
        Th2_cell            [label="Th2 Cell (UC dominant)", shape=box, fillcolor=lightskyblue];
        Th17_cell           [label="Th17 Cell", shape=box];
        Treg_cell           [label="Treg Cell", shape=box, fillcolor=lightgreen];
        CD8_CTL             [label="CD8+ CTL", shape=box];
        B_cell              [label="B Cell", shape=box];
        Plasma_cell         [label="Plasma Cell", shape=box];
        IgG_antibody        [label="IgG Antibody", shape=box];
        IgA_secretory       [label="Secretory IgA", shape=box];
        Mesenteric_LN       [label="Mesenteric LN", shape=box];
        Peyers_patch        [label="Peyer's Patch", shape=box];
        alpha4beta7_integrin [label="a4b7 Integrin", shape=box, fillcolor=lightskyblue];
        MAdCAM1_endothelium [label="MAdCAM-1 Endothelium", shape=box];
        CCR9_CCL25          [label="CCR9 / CCL25", shape=box];
        LPAM1_homing        [label="LPAM-1 Homing", shape=box];
        Tfh_cell            [label="Tfh Cell", shape=box];
        Memory_T_cell       [label="Memory T Cell", shape=box];
    }

    // =====================================================
    // CLUSTER 6: CYTOKINES & MEDIATORS
    // =====================================================
    subgraph cluster_cytokines {
        label="Cytokines & Mediators";
        style=filled; fillcolor=mistyrose;
        fontsize=12; fontcolor=darkred;

        TNFa   [label="TNF-a", shape=box, fillcolor=lightcoral];
        IL6    [label="IL-6", shape=box];
        IL1beta [label="IL-1b", shape=box];
        IL17A  [label="IL-17A", shape=box];
        IL17F  [label="IL-17F", shape=box];
        IL22   [label="IL-22", shape=box];
        IL12p70 [label="IL-12p70", shape=box];
        IL23p19 [label="IL-23p19", shape=box];
        IL4    [label="IL-4", shape=box];
        IL5    [label="IL-5", shape=box];
        IL13   [label="IL-13", shape=box, fillcolor=lightcoral];
        IL10   [label="IL-10", shape=box, fillcolor=lightgreen];
        TGFbeta1 [label="TGF-b1", shape=box];
        CXCL8  [label="CXCL8 / IL-8", shape=box];
        CCL2   [label="CCL2 / MCP-1", shape=box];
        IFNgamma [label="IFN-g", shape=box];
        TSLP   [label="TSLP", shape=box];
        IL25_IL33 [label="IL-25 / IL-33", shape=box];
        OSM    [label="OSM", shape=box];
        VEGF   [label="VEGF", shape=box];
        MMP1   [label="MMP-1", shape=box];
        MMP3   [label="MMP-3", shape=box];
        MMP9   [label="MMP-9", shape=box];
    }

    // =====================================================
    // CLUSTER 7: INTRACELLULAR SIGNALING
    // =====================================================
    subgraph cluster_signaling {
        label="Intracellular Signaling";
        style=filled; fillcolor=lightcyan;
        fontsize=12; fontcolor=darkcyan;

        JAK1   [label="JAK1", shape=box];
        JAK2   [label="JAK2", shape=box];
        JAK3   [label="JAK3", shape=box];
        TYK2   [label="TYK2", shape=box];
        STAT1  [label="STAT1", shape=box];
        STAT3  [label="STAT3", shape=box];
        STAT4  [label="STAT4", shape=box];
        STAT6  [label="STAT6", shape=box];
        NFkB_p65 [label="NF-kB p65", shape=box, fillcolor=lightyellow];
        IkBa   [label="IkBa", shape=box];
        IKKbeta [label="IKKb", shape=box];
        AP1    [label="AP-1", shape=box];
        p38_MAPK [label="p38 MAPK", shape=box];
        ERK    [label="ERK1/2", shape=box];
        mTOR   [label="mTOR", shape=box];
        PI3K_Akt [label="PI3K/Akt", shape=box];
        S1PR1_lymphocyte [label="S1PR1 (Lymphocyte)", shape=box];
        S1P_gradient [label="S1P Gradient", shape=box];
        PDE4   [label="PDE4", shape=box];
        cAMP_PKA [label="cAMP/PKA", shape=box];
        RORgt  [label="RORgt", shape=box];
        Tbet   [label="T-bet", shape=box];
        GATA3  [label="GATA3", shape=box];
        Foxp3  [label="FOXP3", shape=box];
        Lymphocyte_egress [label="Lymphocyte Egress", shape=box];
    }

    // =====================================================
    // CLUSTER 8: COLON PATHOLOGY
    // =====================================================
    subgraph cluster_colon_pathology {
        label="Colon Pathology";
        style=filled; fillcolor=linen;
        fontsize=12; fontcolor=saddlebrown;

        Crypt_abscess        [label="Crypt Abscess", shape=box, fillcolor=lightyellow];
        Cryptitis            [label="Cryptitis", shape=box];
        Goblet_cell_depletion [label="Goblet Cell Depletion", shape=box];
        Ulceration_erosion   [label="Ulceration / Erosion", shape=box, fillcolor=lightcoral];
        Pseudopolyp          [label="Pseudopolyp", shape=box];
        Submucosal_edema     [label="Submucosal Edema", shape=box];
        Crypt_distortion     [label="Crypt Distortion", shape=box];
        Muscularis_propria   [label="Muscularis Propria", shape=box];
        Toxic_megacolon_risk [label="Toxic Megacolon Risk", shape=box, fillcolor=lightcoral];
        Perforation_risk     [label="Perforation Risk", shape=box, fillcolor=lightcoral];
        Colorectal_cancer_risk [label="Colorectal Cancer Risk", shape=box, fillcolor=lightcoral];
        APC_Wnt_beta_catenin [label="APC/Wnt/b-catenin", shape=box];
        P53_mutation         [label="p53 Mutation", shape=box];
        MSI_pathway          [label="MSI Pathway", shape=box];
        Basal_plasmacytosis  [label="Basal Plasmacytosis", shape=box];
    }

    // =====================================================
    // CLUSTER 9: EXTRAINTESTINAL MANIFESTATIONS
    // =====================================================
    subgraph cluster_extraintestinal {
        label="Extraintestinal Manifestations";
        style=filled; fillcolor=lightsalmon;
        fontsize=12; fontcolor=darkred;

        PSC_liver                  [label="PSC / Liver", shape=box];
        Peripheral_arthropathy     [label="Peripheral Arthropathy", shape=box];
        Axial_spondyloarthropathy  [label="Axial SpA", shape=box];
        Uveitis                    [label="Uveitis", shape=box];
        Episcleritis               [label="Episcleritis", shape=box];
        Erythema_nodosum           [label="Erythema Nodosum", shape=box];
        Pyoderma_gangrenosum       [label="Pyoderma Gangrenosum", shape=box];
        Thromboembolic_disease     [label="Thromboembolic Disease", shape=box];
        Anemia_chronic             [label="Chronic Anemia", shape=box];
        Osteopenia_steroid         [label="Osteopenia (steroid)", shape=box];
        Primary_sclerosing_cholangitis [label="PSC", shape=box];
        Aphthous_ulcer_oral        [label="Aphthous Ulcer (oral)", shape=box];
    }

    // =====================================================
    // CLUSTER 10: DRUG PK
    // =====================================================
    subgraph cluster_drug_pk {
        label="Drug Pharmacokinetics";
        style=filled; fillcolor=lightgreen;
        fontsize=12; fontcolor=darkgreen;

        IFX_IV    [label="Infliximab IV Dose", shape=ellipse, fillcolor=palegreen];
        IFX_C1    [label="IFX Central (C1)", shape=box];
        IFX_C2    [label="IFX Peripheral (C2)", shape=box];
        IFX_RC    [label="IFX-TNF Complex (TMDD)", shape=box];

        VDZ_IV    [label="Vedolizumab IV Dose", shape=ellipse, fillcolor=palegreen];
        VDZ_C1    [label="VDZ Central (C1)", shape=box];
        VDZ_RC    [label="VDZ-a4b7 Complex (TMDD)", shape=box];

        TOF_GI    [label="Tofacitinib GI", shape=ellipse, fillcolor=palegreen];
        TOF_C1    [label="TOF Plasma", shape=box];

        OZA_GI    [label="Ozanimod GI", shape=ellipse, fillcolor=palegreen];
        OZA_C1    [label="OZA Plasma", shape=box];
        OZA_M1    [label="CC112273 (active metabolite)", shape=box];

        UST_IV    [label="Ustekinumab IV Induction", shape=ellipse, fillcolor=palegreen];
        UST_DEPOT [label="UST SC Depot", shape=box];
        UST_C1    [label="UST Plasma", shape=box];

        MESA_oral  [label="Mesalamine Oral", shape=ellipse, fillcolor=palegreen];
        MESA_colon [label="Mesalamine Colonic", shape=box];

        PRED_oral  [label="Prednisolone Oral", shape=ellipse, fillcolor=palegreen];
        PRED_C1    [label="Prednisolone Plasma", shape=box];
    }

    // =====================================================
    // CLUSTER 11: DRUG MECHANISMS
    // =====================================================
    subgraph cluster_drug_mech {
        label="Drug Mechanisms of Action";
        style=filled; fillcolor="#FFFACD";
        fontsize=12; fontcolor=darkorange;

        Anti_TNF_mechanism         [label="Anti-TNF Mechanism", shape=box, fillcolor=lightyellow];
        Anti_integrin_alpha4beta7  [label="Anti-a4b7 Integrin", shape=box, fillcolor=lightyellow];
        Anti_IL12_23_p40           [label="Anti-IL12/23 p40", shape=box, fillcolor=lightyellow];
        JAK_inhibition             [label="JAK Inhibition", shape=box, fillcolor=lightyellow];
        S1P1_modulation            [label="S1P1 Modulation", shape=box, fillcolor=lightyellow];
        COX2_5ASA                  [label="COX2 / 5-ASA", shape=box, fillcolor=lightyellow];
        NF_kB_steroids             [label="NF-kB / Steroids", shape=box, fillcolor=lightyellow];
        AZA_purine_analog          [label="AZA Purine Analog", shape=box, fillcolor=lightyellow];
        Calcineurin_inhibitor_rescue [label="Calcineurin Inhibitor", shape=box, fillcolor=lightyellow];
        FMT_microbiome             [label="FMT / Microbiome Rx", shape=box, fillcolor=lightyellow];
    }

    // =====================================================
    // CLUSTER 12: CLINICAL ENDPOINTS
    // =====================================================
    subgraph cluster_endpoints {
        label="Clinical Endpoints & Biomarkers";
        style=filled; fillcolor=lightgrey;
        fontsize=12; fontcolor=dimgray;

        CRP_serum          [label="CRP (Serum)", shape=parallelogram];
        ESR                [label="ESR", shape=parallelogram];
        Fecal_calprotectin [label="Fecal Calprotectin", shape=parallelogram];
        Albumin            [label="Albumin", shape=parallelogram];
        Hemoglobin         [label="Hemoglobin", shape=parallelogram];
        Mayo_total         [label="Mayo Total Score", shape=parallelogram, fillcolor=lightyellow];
        Mayo_partial       [label="Partial Mayo Score", shape=parallelogram];
        UCEIS_score        [label="UCEIS Score", shape=parallelogram];
        Geboes_histology   [label="Geboes Histology", shape=parallelogram];
        Mucosal_healing    [label="Mucosal Healing", shape=diamond, fillcolor=lightgreen];
        Deep_remission     [label="Deep Remission", shape=diamond, fillcolor=lightgreen];
        Remission_steroid_free [label="Steroid-free Remission", shape=parallelogram];
        Colectomy_rate     [label="Colectomy Rate", shape=parallelogram];
        EIM_activity       [label="EIM Activity", shape=parallelogram];
    }

    // =====================================================
    // EDGES: GENETICS -> EPITHELIAL/IMMUNE
    // =====================================================
    HLA_DQ -> CD4_naive [label="MHC-II"];
    IL23R -> Th17_cell [label="IL-23 signaling"];
    NOD2 -> NFkB_p65 [label="innate sensing"];
    HNF4A -> Colonocyte [label="transcription"];
    CDH1 -> ZO1_tight_junction [label="E-cadherin junction"];
    PTPN22 -> Treg_cell [label="Treg regulation"];
    Western_diet -> Dysbiosis_index [label="promotes"];
    Antibiotics_early -> Dysbiosis_index [label="promotes"];
    Stress_HPA -> NFkB_p65 [label="cortisol axis"];
    Stress_HPA -> Mast_cell [label="CRH activation"];
    IL10_locus -> IL10 [label="SNP reduced IL-10"];

    // =====================================================
    // EDGES: MICROBIOME -> INNATE/SIGNALING
    // =====================================================
    F_prausnitzii_down -> Butyrate_SCFA [label="reduced", style=dashed, color=red];
    Roseburia_down -> Butyrate_SCFA [label="reduced", style=dashed, color=red];
    Dysbiosis_index -> LPS_MAMP [label="releases"];
    Dysbiosis_index -> Mucus_penetration [label="promotes"];
    LPS_MAMP -> TLR4_LPS_sensing [label="activates"];
    TLR4_LPS_sensing -> NFkB_p65 [label="NF-kB"];
    TLR2_sensing -> NFkB_p65 [label="NF-kB"];
    NOD2_MDP -> NFkB_p65 [label="MDP sensing"];
    Butyrate_SCFA -> Treg_cell [label="induces"];
    Butyrate_SCFA -> Colonocyte [label="nourishes"];
    Mucus_penetration -> IEC_apoptosis [label="triggers"];
    C_difficile -> NLRP3_inflammasome [label="triggers"];
    E_coli_AIEC_up -> Macrophage_M1 [label="activates"];
    Secretory_IgA -> LPS_MAMP [label="neutralizes", style=dashed, color=blue];

    // =====================================================
    // EDGES: INNATE IMMUNITY NETWORK
    // =====================================================
    NLRP3_inflammasome -> Caspase1 [label="activates"];
    Caspase1 -> IL1beta_mature [label="cleaves"];
    Caspase1 -> IL18_mature [label="cleaves"];
    Macrophage_M1 -> TNFa [label="secretes"];
    Macrophage_M1 -> IL6 [label="secretes"];
    Macrophage_M1 -> IL12p70 [label="secretes"];
    Macrophage_M1 -> IL1beta [label="secretes"];
    IL10 -> Macrophage_M2 [label="polarizes"];
    Macrophage_M2 -> TGFbeta1 [label="secretes"];
    Recruited_monocyte -> Macrophage_M1 [label="differentiates"];
    CXCL8_gradient -> Neutrophil_influx [label="recruits"];
    IL1beta_mature -> CXCL8_gradient [label="induces"];
    Neutrophil_influx -> ROS_NOX2 [label="produces"];
    Neutrophil_influx -> MPO_neutrophil [label="releases"];
    MPO_neutrophil -> Ulceration_erosion [label="tissue damage"];
    ROS_NOX2 -> Ulceration_erosion [label="oxidative damage"];
    Complement_C3 -> C5a_receptor [label="generates C5a"];
    C5a_receptor -> Neutrophil_influx [label="amplifies"];
    ILC2 -> IL13 [label="secretes"];
    ILC3 -> IL22 [label="secretes"];
    Tuft_cell_IL25 -> ILC2 [label="activates via IL-25"];
    TSLP -> ILC2 [label="activates"];
    IL25_IL33 -> ILC2 [label="activates"];
    mDC -> Th17_cell [label="IL-23 polarization"];
    mDC -> Th1_cell [label="IL-12 polarization"];
    pDC_IFNa -> B_cell [label="activates"];

    // =====================================================
    // EDGES: ADAPTIVE IMMUNITY
    // =====================================================
    CD4_naive -> Th1_cell [label="IL-12/T-bet"];
    CD4_naive -> Th2_cell [label="IL-4/GATA3"];
    CD4_naive -> Th17_cell [label="IL-6/IL-23/RORgt"];
    CD4_naive -> Treg_cell [label="TGF-b/FOXP3"];
    Tbet -> Th1_cell [label="drives"];
    GATA3 -> Th2_cell [label="drives"];
    RORgt -> Th17_cell [label="drives"];
    Foxp3 -> Treg_cell [label="master TF"];
    Th1_cell -> IFNgamma [label="secretes"];
    Th2_cell -> IL4 [label="secretes"];
    Th2_cell -> IL5 [label="secretes"];
    Th2_cell -> IL13 [label="secretes"];
    Th17_cell -> IL17A [label="secretes"];
    Th17_cell -> IL17F [label="secretes"];
    Treg_cell -> IL10 [label="secretes"];
    Treg_cell -> TGFbeta1 [label="secretes"];
    IL10 -> NFkB_p65 [label="inhibits", style=dashed, color=blue, arrowhead=tee];
    IFNgamma -> Macrophage_M1 [label="activates"];
    alpha4beta7_integrin -> MAdCAM1_endothelium [label="gut homing"];
    MAdCAM1_endothelium -> Th2_cell [label="recruits to gut"];
    MAdCAM1_endothelium -> Th17_cell [label="recruits to gut"];
    CCR9_CCL25 -> LPAM1_homing [label="co-homing"];
    B_cell -> Plasma_cell [label="differentiates"];
    Plasma_cell -> IgG_antibody [label="secretes"];
    Plasma_cell -> IgA_secretory [label="secretes"];
    Memory_T_cell -> Th2_cell [label="reactivates"];
    Tfh_cell -> B_cell [label="helps"];

    // =====================================================
    // EDGES: CYTOKINE NETWORK
    // =====================================================
    IL17A -> CXCL8 [label="induces"];
    IL17A -> MMP3 [label="induces"];
    IL17A -> MMP9 [label="induces"];
    IL13 -> MUC2 [label="inhibits", style=dashed, color=red, arrowhead=tee];
    IL13 -> ZO1_tight_junction [label="disrupts", style=dashed, color=red];
    IL13 -> Goblet_cell_depletion [label="induces"];
    IL4 -> IL13 [label="promotes Th2"];
    IL4 -> STAT6 [label="STAT6"];
    IL6 -> STAT3 [label="STAT3"];
    IL6 -> CRP_serum [label="induces acute phase"];
    IL12p70 -> Tbet [label="induces T-bet"];
    IL12p70 -> Th1_cell [label="polarizes"];
    IL23p19 -> Th17_cell [label="maintains"];
    IL23p19 -> RORgt [label="upregulates"];
    TNFa -> ZO1_tight_junction [label="disrupts", style=dashed, color=red, arrowhead=tee];
    TNFa -> IEC_apoptosis [label="induces"];
    TNFa -> MMP1 [label="induces"];
    TNFa -> MMP3 [label="induces"];
    TNFa -> NFkB_p65 [label="NF-kB feedback"];
    TNFa -> PSC_liver [label="EIM"];
    TNFa -> EIM_activity [label="drives EIM"];
    CXCL8 -> Neutrophil_influx [label="recruits"];
    OSM -> STAT3 [label="STAT3"];
    VEGF -> Submucosal_edema [label="angiogenesis"];
    TGFbeta1 -> Treg_cell [label="induces FOXP3"];
    TGFbeta1 -> Epithelial_wound_healing [label="promotes"];

    // =====================================================
    // EDGES: SIGNALING NETWORK
    // =====================================================
    NFkB_p65 -> TNFa [label="transcription"];
    NFkB_p65 -> IL6 [label="transcription"];
    NFkB_p65 -> CXCL8 [label="transcription"];
    NFkB_p65 -> MMP9 [label="transcription"];
    IKKbeta -> IkBa [label="phosphorylates"];
    IkBa -> NFkB_p65 [label="inhibits", style=dashed, color=blue, arrowhead=tee];
    JAK1 -> STAT3 [label="phosphorylates"];
    JAK1 -> STAT1 [label="phosphorylates"];
    JAK2 -> STAT4 [label="phosphorylates"];
    JAK3 -> STAT6 [label="phosphorylates"];
