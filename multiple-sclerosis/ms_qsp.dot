digraph MS_QSP {
    graph [
        label="Multiple Sclerosis (MS) — Quantitative Systems Pharmacology Map\nPathophysiology · Neuroimmunology · Demyelination · Drug PK/PD · Clinical Endpoints"
        fontname="Helvetica" fontsize=20 labelloc=t
        rankdir=LR bgcolor="#FAFAFA"
        splines=curved nodesep=0.35 ranksep=0.9
        tooltip="MS QSP Mechanistic Map"
    ]
    node [fontname="Helvetica" fontsize=9 style="filled,rounded" shape=box margin="0.1,0.05"]
    edge [fontname="Helvetica" fontsize=7 arrowsize=0.65 penwidth=1.0]

    // ===================================================================
    // SUBGRAPH 1: Peripheral Immune Activation (Lymph Node / Periphery)
    // ===================================================================
    subgraph cluster_peripheral {
        label="1. Peripheral Immune Activation" fontsize=13 fontcolor="#1A5276"
        style=filled fillcolor="#EBF5FB" color="#2980B9" penwidth=2

        DC         [label="Dendritic Cell\n(mDC / pDC)" fillcolor="#AED6F1"]
        pDC        [label="Plasmacytoid DC\n(pDC)" fillcolor="#85C1E9"]
        Macrophage [label="Macrophage\n(M0 / M1)" fillcolor="#AED6F1"]
        MHC2       [label="MHC-II /\npeptide complex" fillcolor="#D6EAF8"]
        CD80_86    [label="CD80/CD86\n(B7 costimulatory)" fillcolor="#D6EAF8"]
        IL12_DC    [label="IL-12\n(DC-derived)" fillcolor="#AED6F1"]
        IL23_DC    [label="IL-23\n(DC-derived)" fillcolor="#AED6F1"]
        TypeI_IFN  [label="Type I IFN\n(IFN-α/β innate)" fillcolor="#D6EAF8"]

        Naive_CD4  [label="Naive CD4+\nT cell" fillcolor="#A9DFBF"]
        Naive_CD8  [label="Naive CD8+\nT cell" fillcolor="#A9DFBF"]
        TCR        [label="TCR signaling\n(Lck / ZAP70 / LAT)" fillcolor="#D5F5E3"]
        CD28_co    [label="CD28\ncostimulation" fillcolor="#D5F5E3"]
        CTLA4      [label="CTLA-4\n(checkpoint inhib)" fillcolor="#FADBD8"]
        PD1        [label="PD-1 / PD-L1\n(coinhibition)" fillcolor="#FADBD8"]
        TCR_act    [label="T Cell Activation\n(AKT / PI3K / PKC-θ)" fillcolor="#A9DFBF"]
        NFKB_T     [label="NF-κB\n(T cell)" fillcolor="#D5F5E3"]
        NFAT_T     [label="NFAT\n(calcineurin)" fillcolor="#D5F5E3"]
        AP1_T      [label="AP-1\n(c-Fos / c-Jun)" fillcolor="#D5F5E3"]
        IL2_T      [label="IL-2\n(T cell proliferation)" fillcolor="#A9DFBF"]

        DC -> MHC2
        DC -> CD80_86
        DC -> IL12_DC
        DC -> IL23_DC
        pDC -> TypeI_IFN [label="innate\nresponse"]
        Macrophage -> MHC2
        MHC2 -> TCR [label="antigen\npresentation"]
        CD80_86 -> CD28_co [label="B7-CD28\naxis"]
        CD28_co -> TCR_act [label="signal 2"]
        TCR -> TCR_act [label="signal 1"]
        TCR_act -> NFKB_T
        TCR_act -> NFAT_T
        TCR_act -> AP1_T
        TCR_act -> IL2_T [label="autocrine\ngrowth"]
        IL2_T -> Naive_CD4 [label="proliferates" style=dashed]
        CTLA4 -> TCR_act [label="inhibits" color="#C0392B" arrowhead=tee]
        PD1 -> TCR_act [label="inhibits" color="#C0392B" arrowhead=tee]
        Naive_CD4 -> TCR
        Naive_CD8 -> TCR
    }

    // ===================================================================
    // SUBGRAPH 2: T Cell Differentiation
    // ===================================================================
    subgraph cluster_tcell_diff {
        label="2. CD4+ T Cell Differentiation & Effector Cytokines" fontsize=13 fontcolor="#145A32"
        style=filled fillcolor="#EAFAF1" color="#1ABC9C" penwidth=2

        Th1        [label="Th1 Cell\n(IFN-γ+ CD4+)" fillcolor="#76D7C4"]
        Tbet       [label="T-bet\n(Th1 master TF)" fillcolor="#A9DFBF"]
        IFNg       [label="IFN-γ\n(Th1 signature)" fillcolor="#76D7C4"]
        TNFa       [label="TNF-α" fillcolor="#76D7C4"]
        LTa        [label="Lymphotoxin-α\n(LT-α)" fillcolor="#D5F5E3"]

        Th17       [label="Th17 Cell\n(IL-17+ CD4+)" fillcolor="#F9E79F"]
        RORgt      [label="RORγt\n(Th17 master TF)" fillcolor="#F9E79F"]
        IL17A      [label="IL-17A\n(Th17 effector)" fillcolor="#F9E79F"]
        IL17F      [label="IL-17F" fillcolor="#FCF3CF"]
        IL22_T     [label="IL-22\n(barrier)" fillcolor="#FCF3CF"]
        GM_CSF     [label="GM-CSF\n(Th17 → myeloid)" fillcolor="#F9E79F"]
        IL21_T     [label="IL-21\n(autocrine Th17)" fillcolor="#FCF3CF"]

        Treg       [label="Regulatory T cell\n(Foxp3+ Treg)" fillcolor="#FADBD8"]
        Foxp3      [label="Foxp3\n(Treg master TF)" fillcolor="#FADBD8"]
        IL10_Treg  [label="IL-10\n(Treg-derived)" fillcolor="#FADBD8"]
        TGFb_Treg  [label="TGF-β\n(Treg-derived)" fillcolor="#FADBD8"]
        IL35_Treg  [label="IL-35\n(Treg-derived)" fillcolor="#FADBD8"]

        Tc1        [label="CD8+ Tc1 Cell\n(cytotoxic)" fillcolor="#85C1E9"]
        Perforin   [label="Perforin /\nGranzyme B" fillcolor="#85C1E9"]
        Tc1_IFNg   [label="IFN-γ\n(CD8+-derived)" fillcolor="#AED6F1"]

        IL6_sig    [label="IL-6 + TGF-β\n(Th17 priming\nmilieu)" fillcolor="#FCF3CF"]

        // Th1
        IL12_DC -> Tbet [label="STAT4"]
        Tbet -> Th1
        Th1 -> IFNg
        Th1 -> TNFa
        Th1 -> LTa

        // Th17
        IL6_sig -> RORgt [label="STAT3"]
        IL23_DC -> RORgt [label="stabilizes"]
        RORgt -> Th17
        Th17 -> IL17A
        Th17 -> IL17F
        Th17 -> IL22_T
        Th17 -> GM_CSF
        Th17 -> IL21_T

        // Treg
        TGFb_Treg -> Foxp3 [label="SMAD"]
        Foxp3 -> Treg
        Treg -> IL10_Treg
        Treg -> TGFb_Treg
        Treg -> IL35_Treg
        IL10_Treg -> Th17 [label="inhibits" color="#C0392B" arrowhead=tee]
        IL10_Treg -> Th1 [label="inhibits" color="#C0392B" arrowhead=tee]
        IL35_Treg -> Th17 [label="inhibits" color="#C0392B" arrowhead=tee]

        // CD8
        Tc1 -> Perforin
        Tc1 -> Tc1_IFNg

        // Cross-regulation
        IFNg -> Th17 [label="cross-inhib" color="#C0392B" arrowhead=tee style=dashed]
        IL21_T -> Treg [label="inhibits" color="#C0392B" arrowhead=tee style=dashed]
    }

    // ===================================================================
    // SUBGRAPH 3: B Cell, Antibody & Complement
    // ===================================================================
    subgraph cluster_bcell {
        label="3. B Cell Activation, Antibody & Complement" fontsize=13 fontcolor="#6C3483"
        style=filled fillcolor="#F5EEF8" color="#8E44AD" penwidth=2

        Bcell      [label="Naive B Cell\n(CD19+/CD20+)" fillcolor="#D7BDE2"]
        BCR        [label="BCR signaling\n(Btk / Syk / PLCγ2)" fillcolor="#D7BDE2"]
        CD40L_T    [label="CD40L (CD154)\n(T cell surface)" fillcolor="#C39BD3"]
        CD40_B     [label="CD40\n(B cell surface)" fillcolor="#D7BDE2"]
        MemoryB    [label="Memory B Cell\n(CD27+)" fillcolor="#C39BD3"]
        PlasmaCell [label="Plasma Cell\n(antibody-secreting)" fillcolor="#C39BD3"]
        IgG_OCB    [label="IgG (OCB)\nOligoclonal Bands\n(CSF diagnostic)" fillcolor="#A569BD"]
        IgG_MOG    [label="Anti-MOG IgG\n(pathogenic)" fillcolor="#9B59B6"]
        IgG_MBP    [label="Anti-MBP Ab\n(anti-myelin)" fillcolor="#9B59B6"]
        BAFF_mol   [label="BAFF / APRIL\n(B cell survival)" fillcolor="#D2B4DE"]
        IL6_B      [label="IL-6\n(B cell diff / Ig sw)" fillcolor="#D2B4DE"]
        CD20_mol   [label="CD20\n(B cell surface\nmarker)" fillcolor="#D7BDE2"]

        C1q        [label="C1q\n(complement\ninit)" fillcolor="#E8DAEF"]
        C3         [label="C3 / C3b\n(opsonin)" fillcolor="#E8DAEF"]
        C5_comp    [label="C5 / C5a\n(anaphylatoxin)" fillcolor="#E8DAEF"]
        MAC        [label="MAC (C5b-9)\n(membrane attack)" fillcolor="#D7BDE2"]
        FCgR       [label="FcγR\n(phagocyte\nactivation)" fillcolor="#E8DAEF"]

        Bcell -> BCR
        BCR -> Bcell [label="activation"]
        CD40L_T -> CD40_B [label="T cell help"]
        CD40_B -> PlasmaCell [label="drives\ndifferentiation"]
        Bcell -> MemoryB
        Bcell -> PlasmaCell
        PlasmaCell -> IgG_OCB
        PlasmaCell -> IgG_MOG
        PlasmaCell -> IgG_MBP
        BAFF_mol -> Bcell [label="survival signal"]
        IL6_B -> PlasmaCell [label="Ig class\nswitch"]
        CD20_mol -> Bcell [label="surface marker"]
        IgG_MOG -> C1q [label="classical\npathway"]
        C1q -> C3
        C3 -> C5_comp
        C5_comp -> MAC
        IgG_MOG -> FCgR [label="activates\nmicroglia/OC"]
    }

    // ===================================================================
    // SUBGRAPH 4: S1P Signaling & Lymphocyte Trafficking
    // ===================================================================
    subgraph cluster_s1p {
        label="4. S1P Axis & Lymphocyte Egress" fontsize=13 fontcolor="#784212"
        style=filled fillcolor="#FEF9E7" color="#F39C12" penwidth=2

        S1P_mol    [label="Sphingosine-1-P\n(S1P)" fillcolor="#FAD7A0"]
        SphK12     [label="SphK1 / SphK2\n(S1P synthase)" fillcolor="#FAD7A0"]
        S1PR1      [label="S1PR1\n(lymphocyte egress)" fillcolor="#E59866"]
        S1PR3      [label="S1PR3\n(heart / lung)" fillcolor="#FDEBD0"]
        S1PR4      [label="S1PR4\n(immune cells)" fillcolor="#FDEBD0"]
        S1PR5      [label="S1PR5\n(NK cells / CNS)" fillcolor="#FDEBD0"]
        LN_retent  [label="LN Retention\n(lymphopenia)" fillcolor="#FAD7A0"]
        LN_egress  [label="Lymphocyte\nEgress to Blood" fillcolor="#A9DFBF"]
        Lymphopenia[label="Peripheral\nLymphopenia\n(biomarker)" fillcolor="#FAD7A0"]
        S1P_plasma [label="Plasma S1P\n(gradient)" fillcolor="#FDEBD0"]

        SphK12 -> S1P_mol [label="phosphorylates"]
        S1P_mol -> S1PR1 [label="activates"]
        S1P_mol -> S1PR3
        S1P_mol -> S1PR4
        S1P_mol -> S1PR5
        S1PR1 -> LN_egress [label="mediates"]
        S1P_plasma -> S1PR1 [label="gradient\ndrives egress"]
        LN_egress -> LN_retent [label="vs retention"]
        LN_retent -> Lymphopenia [label="causes"]
    }

    // ===================================================================
    // SUBGRAPH 5: Blood-Brain Barrier Disruption
    // ===================================================================
    subgraph cluster_bbb {
        label="5. Blood-Brain Barrier & Immune Cell Infiltration" fontsize=13 fontcolor="#1D6A39"
        style=filled fillcolor="#E9F7EF" color="#27AE60" penwidth=2

        BBB_Endo   [label="BBB Endothelium\n(tight junctions)" fillcolor="#A9DFBF"]
        Claudin5   [label="Claudin-5 /\nOccludin\n(TJ proteins)" fillcolor="#D5F5E3"]
        ZO1        [label="ZO-1\n(scaffolding TJ)" fillcolor="#D5F5E3"]
        VCAM1      [label="VCAM-1\n(T cell adhesion)" fillcolor="#A9DFBF"]
        ICAM1      [label="ICAM-1\n(T cell adhesion)" fillcolor="#A9DFBF"]
        Eselectin  [label="E-selectin\n(rolling)" fillcolor="#A9DFBF"]
        Pselectin  [label="P-selectin\n(rolling)" fillcolor="#D5F5E3"]
        VLA4       [label="α4β1 integrin\n(VLA-4 on T cell)" fillcolor="#76D7C4"]
        MMP9_BBB   [label="MMP-9\n(BBB disruption)" fillcolor="#FADBD8"]
        MMP2_BBB   [label="MMP-2\n(basement\nmembrane)" fillcolor="#FADBD8"]
        Pericyte   [label="Pericyte\n(BBB support)" fillcolor="#D5F5E3"]
        Astro_end  [label="Astrocyte Endfeet\n(BBB support)" fillcolor="#D5F5E3"]
        GadEnhance [label="Gadolinium\nEnhancement\n(active lesion MRI)" fillcolor="#FAD7A0"]
        Infiltration [label="Th1/Th17/CD8\nCNS Infiltration" fillcolor="#FADBD8"]

        IFNg -> VCAM1 [label="upregulates"]
        TNFa -> VCAM1 [label="upregulates"]
        TNFa -> ICAM1 [label="upregulates"]
        IL17A -> MMP9_BBB [label="upregulates"]
        GM_CSF -> MMP9_BBB [label="upregulates"]
        MMP9_BBB -> Claudin5 [label="degrades" color="#C0392B"]
        MMP9_BBB -> ZO1 [label="degrades" color="#C0392B"]
        MMP2_BBB -> Claudin5 [label="degrades" color="#C0392B"]
        Claudin5 -> BBB_Endo [label="maintains\nintegrity"]
        ZO1 -> BBB_Endo [label="maintains"]
        VCAM1 -> VLA4 [label="ligand-receptor\nbinding"]
        VLA4 -> Infiltration [label="mediates\ntransmigration"]
        Eselectin -> Infiltration [label="rolling"]
        Pselectin -> Infiltration [label="rolling"]
        ICAM1 -> Infiltration [label="arrest"]
        BBB_Endo -> GadEnhance [label="disruption →\nGd leakage"]
        Th1 -> Infiltration [label="VLA-4+"]
        Th17 -> Infiltration [label="VLA-4+"]
        Tc1 -> Infiltration [label="CD8+"]
    }

    // ===================================================================
    // SUBGRAPH 6: CNS Neuroinflammation
    // ===================================================================
    subgraph cluster_cns_inflam {
        label="6. CNS Neuroinflammation (Lesion Microenvironment)" fontsize=13 fontcolor="#78281F"
        style=filled fillcolor="#FDEDEC" color="#C0392B" penwidth=2

        Microglia0  [label="Homeostatic\nMicroglia" fillcolor="#FDEBD0"]
        MicrogliaM1 [label="Activated Microglia\n(M1 / pro-inflam)" fillcolor="#FADBD8"]
        MicrogliaM2 [label="Anti-inflam Microglia\n(M2 / DAM)" fillcolor="#A9DFBF"]
        AstroReact  [label="Reactive Astrocyte\n(A1 / A2)" fillcolor="#FADBD8"]
        CNS_Macro   [label="CNS Macrophage\n(monocyte-derived)" fillcolor="#FADBD8"]
        Neutrophil  [label="Neutrophil\n(transient CNS)" fillcolor="#FADBD8"]

        TNF_CNS    [label="TNF-α\n(CNS)" fillcolor="#FADBD8"]
        IL1b_CNS   [label="IL-1β\n(CNS)" fillcolor="#FADBD8"]
        IL6_CNS    [label="IL-6\n(CNS)" fillcolor="#FADBD8"]
        IL18_CNS   [label="IL-18\n(CNS; NLRP3)" fillcolor="#FADBD8"]
        CXCL10     [label="CXCL10 / IP-10\n(T cell chemoattract)" fillcolor="#FAD7A0"]
        CXCL12     [label="CXCL12 / SDF-1\n(niche maintenance)" fillcolor="#D5F5E3"]
        LTB4       [label="Leukotriene B4\n(neutrophil attract)" fillcolor="#FDEBD0"]
        PGE2_CNS   [label="PGE2 (COX-2)\n(pain / inflammation)" fillcolor="#FDEBD0"]
        NO_CNS     [label="Nitric Oxide\n(iNOS, neurotoxic)" fillcolor="#FADBD8"]
        ROS_CNS    [label="ROS / RNS\n(oxidative stress)" fillcolor="#FADBD8"]
        Glutamate  [label="Glutamate\n(excitotoxicity)" fillcolor="#FADBD8"]
        NLRP3      [label="NLRP3\nInflammasome" fillcolor="#FADBD8"]

        Infiltration -> MicrogliaM1 [label="activates"]
        Infiltration -> AstroReact [label="activates"]
        Infiltration -> CNS_Macro [label="differentiates"]
        Microglia0 -> MicrogliaM1 [label="alarm\nactivation"]
        MicrogliaM1 -> TNF_CNS
        MicrogliaM1 -> IL1b_CNS
        MicrogliaM1 -> IL6_CNS
        MicrogliaM1 -> CXCL10
        MicrogliaM1 -> NO_CNS
        MicrogliaM1 -> ROS_CNS
        MicrogliaM1 -> NLRP3
        NLRP3 -> IL1b_CNS [label="cleaves"]
        NLRP3 -> IL18_CNS [label="cleaves"]
        AstroReact -> CXCL10
        AstroReact -> LTB4
        AstroReact -> PGE2_CNS
        AstroReact -> Glutamate [label="impaired\nglutamate uptake"]
        FCgR -> MicrogliaM1 [label="IC → activation"]
        MAC -> MicrogliaM1 [label="complement\nactivation"]
        IFNg -> MicrogliaM1 [label="potentiates"]
        GM_CSF -> MicrogliaM1 [label="potent activator"]
        IL10_Treg -> MicrogliaM1 [label="dampens" color="#27AE60" arrowhead=tee]
        MicrogliaM1 -> MicrogliaM2 [label="IL-4/IL-10\nM1→M2 shift" style=dashed]
    }

    // ===================================================================
    // SUBGRAPH 7: Demyelination & Axonal Injury
    // ===================================================================
    subgraph cluster_demyelin {
        label="7. Oligodendrocyte Injury, Demyelination & Axonal Damage" fontsize=13 fontcolor="#784212"
        style=filled fillcolor="#FEF5E7" color="#E67E22" penwidth=2

        OligoH     [label="Oligodendrocyte\n(healthy / mature)" fillcolor="#A9DFBF"]
        OligoD     [label="Oligodendrocyte\n(stressed)" fillcolor="#FAD7A0"]
        OligoDead  [label="Oligodendrocyte\n(dead / apoptotic)" fillcolor="#FADBD8"]
        MBP_prot   [label="Myelin Basic\nProtein (MBP)" fillcolor="#A9DFBF"]
        MOG_prot   [label="MOG\n(surface antigen)" fillcolor="#A9DFBF"]
        PLP_prot   [label="Proteolipid\nProtein (PLP)" fillcolor="#A9DFBF"]
        Myelin_ok  [label="Intact Myelin\nSheath (healthy)" fillcolor="#A9DFBF"]
        Myelin_los [label="Demyelinated\nAxon Segment" fillcolor="#FADBD8"]
        WM_lesion  [label="White Matter\nLesion (T2 MRI)" fillcolor="#FAD7A0"]
        Axon_ok    [label="Axonal Integrity\n(healthy)" fillcolor="#A9DFBF"]
        Axon_inj   [label="Axonal Injury\n(APP+ / transection)" fillcolor="#FADBD8"]
        Nav16      [label="NaV1.6\n(ectopic expression)" fillcolor="#FDEBD0"]
        CaOvld     [label="Ca²+ Overload\n(via NCX reverse)" fillcolor="#FADBD8"]
        Mito_dysfn [label="Mitochondrial\nDysfunction" fillcolor="#FADBD8"]
        APP        [label="β-APP\n(axonal transport\nmarker)" fillcolor="#FDEBD0"]

        TNF_CNS -> OligoD [label="cytotoxic"]
        IL1b_CNS -> OligoD [label="cytotoxic"]
        NO_CNS -> OligoD [label="nitrosative\nstress"]
        ROS_CNS -> OligoD [label="oxidative\nstress"]
        Perforin -> OligoDead [label="direct\nlysis"]
        MAC -> OligoDead [label="complement\nlysis"]
        Glutamate -> OligoD [label="AMPA-R\nexcitotoxicity"]
        OligoD -> OligoDead [label="apoptosis\n(Bax/Bcl2)"]
        OligoH -> MBP_prot
        OligoH -> MOG_prot
        OligoH -> PLP_prot
        OligoH -> Myelin_ok [label="produces &\nmaintains"]
        OligoDead -> Myelin_los [label="demyelination"]
        Myelin_ok -> Myelin_los [label="stripping" color="#C0392B"]
        Myelin_los -> WM_lesion [label="lesion\nformation"]
        Myelin_los -> Axon_inj [label="loss of\ntrophic support"]
        Axon_ok -> Axon_inj [label="injury" color="#C0392B"]
        Axon_inj -> Nav16 [label="NaV1.2→1.6\nredistribution"]
        Nav16 -> CaOvld [label="Na influx →\nNCX reverse"]
        CaOvld -> Mito_dysfn [label="Ca²+ overload"]
        Mito_dysfn -> Axon_inj [label="energy\nfailure feedback" color="#C0392B"]
        Axon_inj -> APP [label="transport\ndisruption"]
        IgG_MOG -> OligoD [label="ADCC / opsonin"]
    }

    // ===================================================================
    // SUBGRAPH 8: Remyelination & Neuroprotection
    // ===================================================================
    subgraph cluster_remyelin {
        label="8. Remyelination, OPC Biology & Neuroprotection" fontsize=13 fontcolor="#1A5276"
        style=filled fillcolor="#EBF5FB" color="#2471A3" penwidth=2

        OPC        [label="OPC (oligodendrocyte\nprecursor cell)" fillcolor="#AED6F1"]
        OPC_migr   [label="OPC Migration\n(chemokinesis)" fillcolor="#AED6F1"]
        OPC_prolif [label="OPC Proliferation\n(PDGF-AA)" fillcolor="#AED6F1"]
        OPC_diff   [label="OPC Differentiation\n(maturation)" fillcolor="#D6EAF8"]
        Remyelin   [label="Remyelination\n(new myelin sheath)" fillcolor="#A9DFBF"]
        ShadowPl   [label="Shadow Plaque\n(thin remyelin)" fillcolor="#D5F5E3"]
        PDGFAA     [label="PDGF-AA\n(OPC mitogen)" fillcolor="#AED6F1"]
        FGF2       [label="FGF-2\n(OPC / neuroprotect)" fillcolor="#AED6F1"]
        Neuregulin [label="Neuregulin-1\n(ErbB4 → myelin)" fillcolor="#AED6F1"]
        LIF_OPC    [label="LIF\n(OPC survival)" fillcolor="#AED6F1"]
        LINGO1     [label="LINGO-1\n(remyelin\ninhibitor)" fillcolor="#FADBD8"]
        Nogo_A     [label="Nogo-A\n(CNS axon\ngrowth inhib)" fillcolor="#FADBD8"]
        Nrf2       [label="Nrf2 pathway\n(antioxidant\nneuroprotection)" fillcolor="#A9DFBF"]
        BDNF       [label="BDNF\n(neuroprotection\nTrkB)" fillcolor="#A9DFBF"]
        Wnt_remyel [label="Wnt / β-catenin\n(OPC diff\nregulator)" fillcolor="#D6EAF8"]

        OPC -> OPC_migr
        OPC -> OPC_prolif
        PDGFAA -> OPC_prolif [label="mitogen"]
        FGF2 -> OPC_migr [label="chemokinesis"]
        OPC_prolif -> OPC_diff
        OPC_migr -> OPC_diff
        Neuregulin -> OPC_diff [label="ErbB2/4\npromotes"]
        LIF_OPC -> OPC_diff [label="promotes"]
        LINGO1 -> OPC_diff [label="inhibits" color="#C0392B" arrowhead=tee]
        Nogo_A -> OPC_diff [label="inhibits" color="#C0392B" arrowhead=tee]
        Wnt_remyel -> OPC_diff [label="fine-tunes"]
        OPC_diff -> Remyelin [label="→ new\noligodendrocyte"]
        Remyelin -> ShadowPl [label="incomplete\nremyelination"]
        Remyelin -> Myelin_ok [label="restores" style=dashed color="#27AE60"]
        MicrogliaM2 -> PDGFAA [label="releases\ntrophic factors"]
        MicrogliaM2 -> BDNF [label="releases"]
        MicrogliaM2 -> FGF2 [label="releases"]
        BDNF -> Axon_ok [label="neuroprotects" color="#27AE60"]
        Nrf2 -> ROS_CNS [label="scavenges\nROS" color="#27AE60" arrowhead=tee]
        TNF_CNS -> LINGO1 [label="upregulates"]
        IL1b_CNS -> LINGO1 [label="upregulates"]
    }

    // ===================================================================
    // SUBGRAPH 9: Drug PK Compartments
    // ===================================================================
    subgraph cluster_drug_pk {
        label="9. Drug Pharmacokinetics" fontsize=13 fontcolor="#4A235A"
        style=filled fillcolor="#F5EEF8" color="#6C3483" penwidth=2

        // IFN-β
        IFNb_dose  [label="IFN-β dose\n(IM 30µg qw /\nSC 44µg tiw)" shape=oval fillcolor="#D7BDE2"]
        IFNb_C1    [label="IFN-β Central [C₁]\n(SC/IM depot)" fillcolor="#D7BDE2"]
        IFNb_C2    [label="IFN-β Peripheral\n[C₂]" fillcolor="#E8DAEF"]

        // Natalizumab (TMDD 2-comp)
        Nat_dose   [label="Natalizumab\n300 mg IV q4w" shape=oval fillcolor="#C39BD3"]
        Nat_C1     [label="Natalizumab\nCentral [Cₙ]" fillcolor="#C39BD3"]
        Nat_C2     [label="Natalizumab\nPeripheral [Cₙₚ]" fillcolor="#E8DAEF"]
        Nat_Bound  [label="Nat-α4β1\nbound complex" fillcolor="#A569BD"]
        alpha4_R   [label="Free α4β1\nintegrin (target)" fillcolor="#D7BDE2"]

        // Ocrelizumab
        Ocre_dose  [label="Ocrelizumab\n600 mg IV q6m" shape=oval fillcolor="#85C1E9"]
        Ocre_C1    [label="Ocrelizumab\nCentral [Cₒ]" fillcolor="#85C1E9"]
        Ocre_C2    [label="Ocrelizumab\nPeripheral [Cₒₚ]" fillcolor="#AED6F1"]

        // Siponimod (2-comp oral)
        Sip_dose   [label="Siponimod\n2 mg qd oral" shape=oval fillcolor="#FAD7A0"]
        Sip_C1     [label="Siponimod plasma\n[Cₛ]" fillcolor="#FAD7A0"]
        Sip_C2     [label="Siponimod\nDeep [Cₛₚ]" fillcolor="#FDEBD0"]

        // DMF
        DMF_dose   [label="DMF 240 mg\nbid oral" shape=oval fillcolor="#ABEBC6"]
        MMF_C1     [label="MMF plasma\n[Cₘ]" fillcolor="#ABEBC6"]

        // Cladribine
        Clad_dose  [label="Cladribine\n3.5 mg/kg (cycle)" shape=oval fillcolor="#F1948A"]
        Clad_C1    [label="Cladribine\nplasma [Cᶜ]" fillcolor="#F1948A"]

        // Ofatumumab
        Ofa_dose   [label="Ofatumumab\n20 mg SC qm" shape=oval fillcolor="#AED6F1"]
        Ofa_C1     [label="Ofatumumab\nplasma [Cₓ]" fillcolor="#AED6F1"]

        IFNb_dose -> IFNb_C1 [label="SC/IM\nka=0.3/h"]
        IFNb_C1 -> IFNb_C2 [label="Q₁/V₁"]
        IFNb_C2 -> IFNb_C1 [label="Q₁/V₂"]
        Nat_dose -> Nat_C1 [label="IV\ninfusion"]
        Nat_C1 -> Nat_C2 [label="Q/V₁"]
        Nat_C2 -> Nat_C1 [label="Q/V₂"]
        Nat_C1 -> Nat_Bound [label="kon·R\nTMDD"]
        Nat_Bound -> Nat_C1 [label="koff\nrelease"]
        alpha4_R -> Nat_Bound [label="binds"]
        Ocre_dose -> Ocre_C1 [label="IV\ninfusion"]
        Ocre_C1 -> Ocre_C2 [label="Q/V₁"]
        Ocre_C2 -> Ocre_C1 [label="Q/V₂"]
        Sip_dose -> Sip_C1 [label="oral\nka=0.5/h"]
        Sip_C1 -> Sip_C2 [label="Q/V₁"]
        Sip_C2 -> Sip_C1 [label="Q/V₂"]
        DMF_dose -> MMF_C1 [label="hydrolysis\nka=1.2/h"]
        Clad_dose -> Clad_C1 [label="oral\nka=0.4/h"]
        Ofa_dose -> Ofa_C1 [label="SC\nka=0.02/h"]
    }

    // ===================================================================
    // SUBGRAPH 10: Drug Pharmacodynamics
    // ===================================================================
    subgraph cluster_drug_pd {
        label="10. Drug Mechanisms of Action (Pharmacodynamics)" fontsize=13 fontcolor="#7D6608"
        style=filled fillcolor="#FFFDE7" color="#D4AC0D" penwidth=2

        // IFN-β PD
        IFNb_JAK   [label="IFN-β → JAK1/TYK2\n→ STAT1/STAT2\n→ ISGF3 complex" fillcolor="#D7BDE2"]
        IFNb_eff1  [label="↓ MMP-9 / VCAM-1\n(BBB protection)" fillcolor="#A9DFBF"]
        IFNb_eff2  [label="↓ IFN-γ / TNF-α\n(anti-inflammatory)" fillcolor="#A9DFBF"]
        IFNb_eff3  [label="↑ IL-10 / TGF-β\n(Treg induction)" fillcolor="#A9DFBF"]
        IFNb_eff4  [label="↓ T cell\ncrossBBB migration" fillcolor="#A9DFBF"]

        // Natalizumab PD
        Nat_VLA4   [label="Nat blocks\nVLA-4/VCAM-1\ninteraction" fillcolor="#C39BD3"]
        Nat_eff    [label="↓ CNS T cell /\nmonocyte infiltration" fillcolor="#A9DFBF"]

        // Ocrelizumab/Ofatumumab PD
        Anti_CD20  [label="Anti-CD20 mAb\n(Ocre/Ofa binding)" fillcolor="#85C1E9"]
        CDC_ADCC   [label="CDC / ADCC /\nphagocytosis" fillcolor="#AED6F1"]
        Bcell_depl [label="↓ B cells (>95%)\n↓ Ab, ↓ OCB\n↓ APC function" fillcolor="#A9DFBF"]

        // Siponimod PD
        Sip_S1PR   [label="Sip → S1PR1/5\nfunctional\nantagonism" fillcolor="#FAD7A0"]
        Sip_LN     [label="Lymphocyte retained\nin LN → lymphopenia" fillcolor="#FAD7A0"]

        // DMF PD
        DMF_NRF2   [label="DMF/MMF → Nrf2\n↑ HO-1/NQO1\nantioxidant genes" fillcolor="#ABEBC6"]
        DMF_NFKB   [label="DMF → ↓ NF-κB\n↓ inflammatory\ncytokine genes" fillcolor="#ABEBC6"]
        DMF_lymph  [label="↓ Th1/Th17 trafficking\n↑ Th2 shift\n(anti-inflam)" fillcolor="#ABEBC6"]

        // Cladribine PD
        Clad_DNA   [label="Cladribine → dATP\npools → DNA\nstrand breaks" fillcolor="#F1948A"]
        Clad_depl  [label="Lymphocyte\ndepletion\n(B >> T cells)" fillcolor="#F1948A"]

        // Glatiramer Acetate
        GA_dose2   [label="GA (Copaxone)\n20/40 mg SC" shape=oval fillcolor="#D5F5E3"]
        GA_Th2     [label="GA → MOG mimicry\n→ Th2/Treg shift\n(immune deviation)" fillcolor="#A9DFBF"]

        IFNb_C1 -> IFNb_JAK [label="IFNAR1/2\nbinding"]
        IFNb_JAK -> IFNb_eff1
        IFNb_JAK -> IFNb_eff2
        IFNb_JAK -> IFNb_eff3
        IFNb_JAK -> IFNb_eff4
        Nat_Bound -> Nat_VLA4 [label="blocks"]
        Nat_VLA4 -> Nat_eff
        Ocre_C1 -> Anti_CD20 [label="CD20 binding"]
        Ofa_C1 -> Anti_CD20 [label="CD20 binding"]
        Anti_CD20 -> CDC_ADCC
        CDC_ADCC -> Bcell_depl
        Sip_C1 -> Sip_S1PR [label="S1PR1/5\nbinding"]
        Sip_S1PR -> Sip_LN [label="receptor\ninternalization"]
        MMF_C1 -> DMF_NRF2 [label="Keap1 alkylation"]
        DMF_NRF2 -> Nrf2 [label="activates"]
        MMF_C1 -> DMF_NFKB [label="IKKβ inhibition"]
        DMF_NFKB -> NFKB_T [label="inhibits" color="#C0392B" arrowhead=tee]
        MMF_C1 -> DMF_lymph
        Clad_C1 -> Clad_DNA [label="intracellular\nphosphorylation"]
        Clad_DNA -> Clad_depl [label="apoptosis"]
        GA_dose2 -> GA_Th2
    }

    // ===================================================================
    // SUBGRAPH 11: Biomarkers
    // ===================================================================
    subgraph cluster_biomarkers {
        label="11. Biomarkers (Serum / CSF / MRI)" fontsize=13 fontcolor="#4D4D4D"
        style=filled fillcolor="#FDFEFE" color="#7F8C8D" penwidth=2

        NfL_bm     [label="NfL\n(Neurofilament light\nchain — serum/CSF)" fillcolor="#D6EAF8"]
        NfH_bm     [label="NfH\n(Neurofilament heavy\nchain — CSF)" fillcolor="#D6EAF8"]
        GFAP_bm    [label="GFAP\n(astrocyte damage\nbiomarker)" fillcolor="#D6EAF8"]
        CHI3L1_bm  [label="CHI3L1 / YKL-40\n(microglia / astrocyte)" fillcolor="#D6EAF8"]
        Osteopon   [label="Osteopontin\n(inflammation /\nTh17)" fillcolor="#D6EAF8"]
        sCD163_bm  [label="sCD163\n(macrophage\nactivation)" fillcolor="#D6EAF8"]
        OCB_CSF    [label="Oligoclonal Bands\n(CSF IgG — diagnosis)" fillcolor="#D7BDE2"]
        IgG_idx    [label="IgG Index\n(CSF/serum ratio)" fillcolor="#D7BDE2"]
        CHA_band   [label="CHI3L1 band\n(spinal fluid)" fillcolor="#D6EAF8"]
        Lymph_ct   [label="Lymphocyte Count\n(blood monitoring\nfor DMT safety)" fillcolor="#D6EAF8"]
        CD4_ct     [label="CD4+ Count\n(safety monitoring\nPML risk)" fillcolor="#D6EAF8"]
        JCV_Ab     [label="JCV Antibody Index\n(natalizumab\nPML risk)" fillcolor="#FAD7A0"]

        Axon_inj -> NfL_bm [label="releases into\nCSF/blood"]
        Axon_inj -> NfH_bm [label="releases\n(CSF)"]
        AstroReact -> GFAP_bm [label="GFAP shed"]
        MicrogliaM1 -> CHI3L1_bm [label="secretes"]
        AstroReact -> CHI3L1_bm [label="secretes"]
        Th17 -> Osteopon [label="IL-17 →\nosteopontin"]
        CNS_Macro -> sCD163_bm [label="sheds CD163"]
        IgG_OCB -> OCB_CSF [label="detected\nin CSF"]
        PlasmaCell -> IgG_idx [label="intrathecal\nIgG synthesis"]
        Sip_LN -> Lymph_ct [label="dose-dependent\nlymphopenia"]
        Clad_depl -> CD4_ct [label="CD4 nadir"]
        Nat_Bound -> JCV_Ab [label="monitor\nat 6m"]
    }

    // ===================================================================
    // SUBGRAPH 12: Clinical Endpoints & Disease Measures
    // ===================================================================
    subgraph cluster_clinical {
        label="12. Clinical Endpoints & Disease Outcome Measures" fontsize=13 fontcolor="#0D6B0D"
        style=filled fillcolor="#EAFAF1" color="#1D8348" penwidth=2

        EDSS      [label="EDSS Score\n(0–10 disability)" shape=diamond fillcolor="#A9DFBF"]
        ARR       [label="Annualized Relapse\nRate (ARR)" shape=diamond fillcolor="#A9DFBF"]
        T2vol     [label="T2 Lesion Volume\n(mm³, MRI)" shape=diamond fillcolor="#A9DFBF"]
        T1_BH     [label="T1 Black Holes\n(chronic axonal\nloss, MRI)" shape=diamond fillcolor="#FAD7A0"]
        BVL       [label="Brain Volume\nLoss (%/year)" shape=diamond fillcolor="#FAD7A0"]
        NEDA3     [label="NEDA-3\n(no new T2, no Gd+,\nno relapse)" shape=diamond fillcolor="#D5F5E3"]
        NEDA4     [label="NEDA-4\n(NEDA-3 +\nno BVL)" shape=diamond fillcolor="#D5F5E3"]
        T25FW     [label="T25-FW\n(gait speed)" shape=diamond fillcolor="#D6EAF8"]
        SDMT      [label="SDMT\n(cognitive speed)" shape=diamond fillcolor="#D6EAF8"]
        Fatigue   [label="Fatigue Score\n(FSS / MFIS)" shape=diamond fillcolor="#D6EAF8"]
        SPMS_conv [label="SPMS Conversion\n(progressive phase)" shape=diamond fillcolor="#FADBD8"]
        PIRA      [label="PIRA\n(progression\nindep. of relapses)" shape=diamond fillcolor="#FADBD8"]

        Myelin_los -> ARR [label="lesion activity\n→ relapses"]
        Axon_inj -> EDSS [label="accumulates\ndisability"]
        Axon_inj -> T1_BH [label="chronic\nblack holes"]
        Axon_inj -> BVL [label="neuronal /\naxonal atrophy"]
        WM_lesion -> T2vol [label="T2 signal"]
        GadEnhance -> T2vol [label="active lesions"]
        ARR -> NEDA3
        EDSS -> NEDA3
        T2vol -> NEDA3
        NEDA3 -> NEDA4
        BVL -> NEDA4
        Axon_inj -> T25FW [label="corticospinal\ntract"]
        Axon_inj -> SDMT [label="cortical /\ncallosal"]
        Fatigue -> EDSS [label="contributes"]
        BVL -> SPMS_conv [label="neuro-\ndegeneration"]
        NfL_bm -> SPMS_conv [label="predicts" style=dashed]
        Axon_inj -> PIRA [label="smouldering\ninflammation"]
        Remyelin -> ARR [label="reduces" color="#27AE60" arrowhead=tee]
        Nat_eff -> ARR [label="↓ 68%" color="#1A5276" arrowhead=tee]
        Sip_LN -> ARR [label="↓ 55%" color="#784212" arrowhead=tee]
        Bcell_depl -> ARR [label="↓ 47%" color="#1A5276" arrowhead=tee]
        Clad_depl -> ARR [label="↓ 58%" color="#C0392B" arrowhead=tee]
        IFNb_eff2 -> ARR [label="↓ 34%" color="#6C3483" arrowhead=tee]
        DMF_lymph -> ARR [label="↓ 49%" color="#27AE60" arrowhead=tee]
        GA_Th2 -> ARR [label="↓ 29%" color="#1D6A39" arrowhead=tee]
    }

    // ===================================================================
    // Cross-cluster connections (inter-subgraph wiring)
    // ===================================================================

    // TCR activation → T cell fate decisions
    TCR_act -> Th1     [label="IL-12 → STAT4\n→ T-bet" style=dashed]
    TCR_act -> Th17    [label="IL-6+TGF-β\n→ RORγt" style=dashed]
    TCR_act -> Treg    [label="TGF-β\n→ Foxp3" style=dashed]
    TCR_act -> Tc1     [label="CD8+\nactivation" style=dashed]
    TCR_act -> CD40L_T [label="T-B interaction"]

    // Cytokine feedback into differentiation
    IL12_DC -> TCR_act  [label="polarizing\nsignal 3"]
    IL6_B -> IL6_sig    [label="microenvironment"]
    BAFF_mol -> Bcell   [label="survival"]
    TypeI_IFN -> DC     [label="DC maturation"]
    TypeI_IFN -> TCR_act [label="promotes Th1"]

    // S1P axis connecting to lymphocyte trafficking
    S1PR1 -> Th1      [label="egress\ncontrol"]
    S1PR1 -> Th17     [label="egress\ncontrol"]
    S1PR1 -> Bcell    [label="egress\ncontrol"]
    Sip_LN -> Th1     [label="retains in LN" color="#784212" arrowhead=tee]
    Sip_LN -> Th17    [label="retains in LN" color="#784212" arrowhead=tee]
    Sip_LN -> Bcell   [label="retains in LN" color="#784212" arrowhead=tee]
    Sip_LN -> Lymphopenia [label="causes"]

    // T cell → BBB crossing
    Th1 -> VLA4    [label="expresses"]
    Th17 -> VLA4   [label="expresses"]
    Tc1 -> VLA4    [label="expresses"]

    // BBB → CNS
    TNFa -> BBB_Endo   [label="disrupts TJ"]

    // CNS cytokines → demyelination
    IL17A -> AstroReact [label="activates"]

    // Drug effects on CNS pathology
    IFNb_eff1 -> VCAM1   [label="reduces" color="#27AE60" arrowhead=tee]
    IFNb_eff1 -> MMP9_BBB [label="reduces" color="#27AE60" arrowhead=tee]
    IFNb_eff3 -> Treg   [label="↑ Treg"]
    IFNb_eff4 -> Infiltration [label="reduces" color="#27AE60" arrowhead=tee]
    Nat_eff -> Infiltration [label="blocks" color="#6C3483" arrowhead=tee]
    Bcell_depl -> IgG_MOG [label="reduces" color="#1A5276" arrowhead=tee]
    Bcell_depl -> OCB_CSF [label="reduces" color="#1A5276" arrowhead=tee]
    Clad_depl -> Th1    [label="depletes" color="#C0392B" arrowhead=tee]
    Clad_depl -> Th17   [label="depletes" color="#C0392B" arrowhead=tee]
    Clad_depl -> Bcell  [label="depletes" color="#C0392B" arrowhead=tee]
    GA_Th2 -> Treg      [label="promotes\nTreg"]
    DMF_NRF2 -> Nrf2    [label="upregulates"]

    // Remyelination links
    Remyelin -> Myelin_ok [label="restores" color="#27AE60" style=dashed]

    // Biomarker → clinical endpoint correlations
    WM_lesion -> T2vol  [label="sum total"]
    GadEnhance -> T2vol [label="active\nlesions"]
    NfL_bm -> EDSS      [label="correlates\nr=0.6" style=dashed]
    BVL -> NfL_bm       [label="reflects\nneurodegeneration" style=dashed]
    Lymph_ct -> Sip_C1  [label="PK/PD\nmonitoring" style=dashed]
    Lymphopenia -> Th1  [label="periphery\nreduction" color="#C0392B" arrowhead=tee]
    Lymphopenia -> Bcell [label="periphery\nreduction" color="#C0392B" arrowhead=tee]

    // CD40L T-B collaboration
    Th1 -> CD40L_T      [label="expresses\nCD40L"]
    CD40L_T -> Bcell    [label="T-B\ncollaboration"]
    Bcell -> IL6_B      [label="auto/paracrine"]

    // Complement → demyelination
    C5_comp -> Infiltration [label="chemoattracts\nneutrophils"]
    MAC -> OligoDead    [label="complement\nlysis"]

    // Myelination gradient
    Axon_ok -> Axon_inj [label="→ injury\naccrual" color="#C0392B"]
}
