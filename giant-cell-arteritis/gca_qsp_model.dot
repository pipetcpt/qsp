digraph GCA_QSP_Model {
    // Giant Cell Arteritis (GCA) — Comprehensive QSP Mechanistic Map
    // Generated: 2026-06-17 | Claude Code Routine (CCR)
    // Disease: 거대세포 동맥염 (Giant Cell Arteritis)
    // Treatments: Glucocorticoids, Tocilizumab, Abatacept, JAK inhibitors

    graph [
        label = "Giant Cell Arteritis (GCA)\nQuantitative Systems Pharmacology Model\n거대세포 동맥염 QSP 기계론적 지도"
        labelloc = "t"
        fontsize = 22
        fontname = "Helvetica-Bold"
        rankdir = "LR"
        splines = "curved"
        nodesep = 0.4
        ranksep = 0.8
        bgcolor = "#FAFAFA"
        compound = true
    ]

    node [fontname="Helvetica" fontsize=10 style="filled,rounded" shape=box]
    edge [fontname="Helvetica" fontsize=8 arrowsize=0.7]

    // =========================================================
    // CLUSTER 1: Disease Trigger & Genetic Risk
    // =========================================================
    subgraph cluster_trigger {
        label = "Genetic Risk & Disease Trigger\n유전 위험 및 질환 유발 인자"
        style = "filled,rounded"
        color = "#2C3E50"
        fillcolor = "#D5E8D4"
        fontcolor = "#1A252F"
        fontsize = 13

        UnknownTrigger [label="Unknown\nEnvironmental\nTrigger" fillcolor="#85C1E9" shape=ellipse]
        HLA_DRB1 [label="HLA-DRB1*04\nGenetic Risk" fillcolor="#85C1E9"]
        HLA_B8 [label="HLA-B8/DR3\nAssociation" fillcolor="#85C1E9"]
        AgeOver50 [label="Age >50y\nRisk Factor" fillcolor="#F8C471" shape=diamond]
        FemaleGender [label="Female Sex\n(3:1 ratio)" fillcolor="#F8C471" shape=diamond]
        MicrobialTrigger [label="Microbial Trigger\n(Varicella Zoster?)" fillcolor="#E8DAEF"]
        SmokingHistory [label="Smoking\nHistory" fillcolor="#F8C471" shape=diamond]
        EpigeneticMod [label="Epigenetic\nModification" fillcolor="#D7BDE2"]
        GeographicRisk [label="Northern\nEuropean\nAncestry" fillcolor="#85C1E9"]
        PreviousInfection [label="Previous\nRespiratory\nInfection" fillcolor="#E8DAEF"]
    }

    // =========================================================
    // CLUSTER 2: Innate Immunity
    // =========================================================
    subgraph cluster_innate {
        label = "Innate Immunity — Macrophages & Dendritic Cells\n선천면역 — 대식세포 및 수지상세포"
        style = "filled,rounded"
        color = "#E67E22"
        fillcolor = "#FDEBD0"
        fontcolor = "#784212"
        fontsize = 13

        VascularDC [label="Vascular\nDendritic Cells\n(VDC)" fillcolor="#F0B27A" shape=ellipse]
        DCimmature [label="Immature DC\n(Adventitia)" fillcolor="#FAD7A0"]
        DCmature [label="Mature DC\n(Activated)" fillcolor="#E59866"]
        DCmigration [label="DC Migration\n& Presentation" fillcolor="#E59866"]
        TLR4 [label="TLR4 / TLR7\nPRR Activation" fillcolor="#F0B27A"]
        NALP3 [label="NALP3\nInflammasome" fillcolor="#E74C3C" fontcolor="white"]
        MonocyteBlood [label="Blood\nMonocytes\n(Ly6C+)" fillcolor="#FAD7A0"]
        CCR2_receptor [label="CCR2 Receptor\nMonocyte Recruitment" fillcolor="#FDEBD0"]
        InflamMacrophage [label="Inflammatory\nMacrophage (M1)" fillcolor="#E74C3C" fontcolor="white"]
        RegMacrophage [label="Regulatory\nMacrophage (M2)" fillcolor="#2ECC71" fontcolor="white"]
        GiantCells [label="Multinucleated\nGiant Cells" fillcolor="#922B21" fontcolor="white"]
        TissueMacrophage [label="Tissue-Resident\nMacrophage" fillcolor="#E8DAEF"]
        NeutrophilRecruit [label="Neutrophil\nRecruitment" fillcolor="#AED6F1"]
        NKcell [label="NK Cells\n(IFN-γ prod)" fillcolor="#D7BDE2"]
        MastCell [label="Mast Cell\nActivation" fillcolor="#F9E79F"]
        Osteopontin_innate [label="Osteopontin\n(Macrophage Act.)" fillcolor="#FAD7A0"]
        CCL2 [label="CCL2/MCP-1\n(Chemokine)" fillcolor="#FAD7A0" shape=ellipse]
        CXCL10 [label="CXCL10/IP-10\n(T cell chemo)" fillcolor="#FAD7A0" shape=ellipse]
        CXCL9 [label="CXCL9/MIG\n(Th1 recruit)" fillcolor="#FAD7A0" shape=ellipse]
        CCL19 [label="CCL19/CCL21\n(DC migration)" fillcolor="#FAD7A0" shape=ellipse]
        ROS_innate [label="Reactive Oxygen\nSpecies (ROS)" fillcolor="#E74C3C" fontcolor="white"]
        iNOS_prod [label="iNOS → NO\nProduction" fillcolor="#E74C3C" fontcolor="white"]
        M1M2_balance [label="M1/M2\nPolarization\nBalance" fillcolor="#F8C471" shape=diamond]
    }

    // =========================================================
    // CLUSTER 3: Adaptive Immunity — T & B cells
    // =========================================================
    subgraph cluster_adaptive {
        label = "Adaptive Immunity — T Cells & B Cells\n적응면역 — T세포 및 B세포"
        style = "filled,rounded"
        color = "#27AE60"
        fillcolor = "#D5F5E3"
        fontcolor = "#1E8449"
        fontsize = 13

        NaiveCD4 [label="Naïve CD4+\nT Cells" fillcolor="#A9DFBF"]
        Th1cell [label="Th1 Cells\n(IFN-γ dominant)" fillcolor="#27AE60" fontcolor="white"]
        Th17cell [label="Th17 Cells\n(IL-17A/F)" fillcolor="#2ECC71" fontcolor="white"]
        Treg [label="Regulatory\nT Cells (Treg)" fillcolor="#1ABC9C" fontcolor="white"]
        CD8Tcell [label="CD8+ Cytotoxic\nT Cells" fillcolor="#138D75" fontcolor="white"]
        Bcell [label="B Cells" fillcolor="#A3E4D7"]
        PlasmaCell [label="Plasma Cells\n(Ab production)" fillcolor="#76D7C4"]
        MemoryTcell [label="Memory\nT Cells" fillcolor="#45B39D"]
        TCRactivation [label="TCR Activation\n(MHC-II/peptide)" fillcolor="#A9DFBF"]
        CD28costim [label="CD28\nCo-stimulation\n(T cell act.)" fillcolor="#A9DFBF"]
        CTLA4_checkpoint [label="CTLA-4\nCheckpoint\n(inhibitory)" fillcolor="#E8DAEF"]
        OX40L [label="OX40/OX40L\nT cell survival" fillcolor="#A9DFBF"]
        PDL1_pathway [label="PD-1/PD-L1\nInhibitory axis" fillcolor="#E8DAEF"]
        IL12_Th1diff [label="IL-12→\nTh1 Differentiation" fillcolor="#2ECC71" fontcolor="white"]
        IL23_Th17diff [label="IL-23→\nTh17 Differentiation" fillcolor="#27AE60" fontcolor="white"]
        STAT4_Th1 [label="STAT4 Activation\n(Th1 pathway)" fillcolor="#A9DFBF"]
        STAT3_Th17 [label="STAT3 Activation\n(Th17 pathway)" fillcolor="#A9DFBF"]
        RORgt [label="RORγt Transcription\n(Th17 master TF)" fillcolor="#76D7C4"]
        Tbet [label="T-bet Transcription\n(Th1 master TF)" fillcolor="#A9DFBF"]
        FoxP3 [label="FoxP3\n(Treg master TF)" fillcolor="#1ABC9C" fontcolor="white"]
    }

    // =========================================================
    // CLUSTER 4: Cytokine & Mediator Network
    // =========================================================
    subgraph cluster_cytokines {
        label = "Cytokine & Mediator Network\n사이토카인 및 매개물질 네트워크"
        style = "filled,rounded"
        color = "#F39C12"
        fillcolor = "#FEF9E7"
        fontcolor = "#784212"
        fontsize = 13

        IL6_cyto [label="IL-6\n(Key driver)" fillcolor="#E74C3C" fontcolor="white" shape=ellipse]
        IL1beta_cyto [label="IL-1β\n(Inflammasome)" fillcolor="#C0392B" fontcolor="white" shape=ellipse]
        TNFalpha_cyto [label="TNF-α\n(Endothelial act.)" fillcolor="#E74C3C" fontcolor="white" shape=ellipse]
        IFNgamma_cyto [label="IFN-γ\n(Macrophage act.)" fillcolor="#E67E22" fontcolor="white" shape=ellipse]
        IL17A_cyto [label="IL-17A\n(VEGF induction)" fillcolor="#F39C12" fontcolor="white" shape=ellipse]
        IL17F_cyto [label="IL-17F\n(Synergy w/ IL-17A)" fillcolor="#F8C471" shape=ellipse]
        IL23_cyto [label="IL-23\n(Th17 support)" fillcolor="#F0B27A" shape=ellipse]
        IL12_cyto [label="IL-12\n(Th1 support)" fillcolor="#E59866" shape=ellipse]
        IL18_cyto [label="IL-18\n(IFN-γ synergy)" fillcolor="#FAD7A0" shape=ellipse]
        IL10_cyto [label="IL-10\n(Anti-inflammatory)" fillcolor="#A9DFBF" shape=ellipse]
        TGFbeta_cyto [label="TGF-β\n(Fibrosis/Treg)" fillcolor="#85C1E9" shape=ellipse]
        VEGF_cyto [label="VEGF-A\n(Angiogenesis)" fillcolor="#9B59B6" fontcolor="white" shape=ellipse]
        PDGF_cyto [label="PDGF-BB\n(SMC proliferation)" fillcolor="#8E44AD" fontcolor="white" shape=ellipse]
        MMP1_cyto [label="MMP-1/3\n(Collagenase)" fillcolor="#922B21" fontcolor="white" shape=ellipse]
        MMP9_cyto [label="MMP-9\n(Gelatinase)" fillcolor="#922B21" fontcolor="white" shape=ellipse]
        Osteopontin_cyto [label="Osteopontin\n(T cell/Mac link)" fillcolor="#F8C471" shape=ellipse]
        Fibronectin [label="Fibronectin\n(ECM remodel)" fillcolor="#D7BDE2" shape=ellipse]
        Ang1 [label="Angiopoietin-1\n(Vessel stability)" fillcolor="#9B59B6" fontcolor="white" shape=ellipse]
        Ang2 [label="Angiopoietin-2\n(Vessel remodel)" fillcolor="#6C3483" fontcolor="white" shape=ellipse]
        CXCL13 [label="CXCL13\n(B cell recruit)" fillcolor="#D5EEF7" shape=ellipse]
        AcutePhaseResponse [label="Acute Phase\nResponse (Liver)" fillcolor="#FDEBD0"]
    }

    // =========================================================
    // CLUSTER 5: Vascular Pathology
    // =========================================================
    subgraph cluster_vascular {
        label = "Temporal Artery & Large Vessel Pathology\n측두동맥 및 대혈관 병리"
        style = "filled,rounded"
        color = "#C0392B"
        fillcolor = "#FADBD8"
        fontcolor = "#641E16"
        fontsize = 13

        TemporalArtery [label="Temporal Artery\n(Primary Target)" fillcolor="#E74C3C" fontcolor="white" shape=ellipse]
        Adventitia_layer [label="Adventitia\n(Outer Layer)\nDC/Macrophage rich" fillcolor="#F1948A"]
        Media_layer [label="Media\n(Middle Layer)\nSMC-containing" fillcolor="#EC7063"]
        Intima_layer [label="Intima\n(Inner Layer)" fillcolor="#E74C3C" fontcolor="white"]
        InternalElasticLamina [label="Internal Elastic\nLamina\n(Fragmentation)" fillcolor="#F5B7B1"]
        SmoothMuscleCell [label="Smooth Muscle\nCells (SMC)" fillcolor="#F1948A"]
        EndothelialCell [label="Endothelial\nCells (EC)" fillcolor="#F5CBA7"]
        IntimalHyperplasia [label="Intimal\nHyperplasia\n(SMC proliferation)" fillcolor="#C0392B" fontcolor="white"]
        LuminalStenosis [label="Luminal\nStenosis\n(≥50%)" fillcolor="#922B21" fontcolor="white"]
        GranulomaFormation [label="Granulomatous\nInflammation" fillcolor="#E74C3C" fontcolor="white"]
        GiantCellsVasc [label="Multinucleated\nGiant Cells\n(in vessel wall)" fillcolor="#7B241C" fontcolor="white"]
        CollagenDeposition [label="Collagen\nDeposition\n(Fibrosis)" fillcolor="#F5B7B1"]
        FibrinDeposition [label="Fibrin\nDeposition\n(Thrombosis)" fillcolor="#F9EBEA"]
        Neovascularization [label="Neovascularization\n(Angiogenesis)" fillcolor="#9B59B6" fontcolor="white"]
        AortaInvolvement [label="Aorta\nInvolvement\n(18-58% GCA)" fillcolor="#EC7063"]
        AorticDilation [label="Aortic\nDilation\nAneurysm risk" fillcolor="#E74C3C" fontcolor="white"]
        SubclavianStenosis [label="Subclavian\nArtery Stenosis" fillcolor="#F1948A"]
        OphthalmicArtery [label="Ophthalmic\nArtery Ischemia" fillcolor="#C0392B" fontcolor="white"]
    }

    // =========================================================
    // CLUSTER 6: Clinical Manifestations & Complications
    // =========================================================
    subgraph cluster_clinical {
        label = "Clinical Manifestations & Ischemic Complications\n임상 증상 및 허혈 합병증"
        style = "filled,rounded"
        color = "#8E44AD"
        fillcolor = "#F4ECF7"
        fontcolor = "#4A235A"
        fontsize = 13

        TempleHeadache [label="New Temporal\nHeadache\n(87% of pts)" fillcolor="#D7BDE2"]
        JawClaudication [label="Jaw\nClaudication\n(50% of pts)" fillcolor="#C39BD3"]
        ScalpTenderness [label="Scalp\nTenderness" fillcolor="#D7BDE2"]
        VisualDisturbance [label="Visual\nDisturbance\n(20-30%)" fillcolor="#9B59B6" fontcolor="white"]
        AION [label="AION\n(Anterior Ischemic\nOptic Neuropathy)" fillcolor="#6C3483" fontcolor="white"]
        Diplopia [label="Diplopia\n(Extraocular\nmuscle ischemia)" fillcolor="#9B59B6" fontcolor="white"]
        PermanentBlindness [label="Permanent\nBlindness\n(15-20%)" fillcolor="#4A235A" fontcolor="white"]
        PMR_symptoms [label="Polymyalgia\nRheumatica (PMR)\n(40-50% of GCA)" fillcolor="#D7BDE2"]
        ConstitutionalFever [label="Constitutional\nSymptoms\nFever (40°C)" fillcolor="#C39BD3"]
        WeightLoss_clin [label="Weight Loss\n& Night Sweats" fillcolor="#D7BDE2"]
        Fatigue_clin [label="Fatigue\n& Malaise" fillcolor="#E8DAEF"]
        Stroke_TIA [label="Stroke/TIA\n(Vertebrobasilar\nischemia)" fillcolor="#641E16" fontcolor="white"]
        AorticAneurysm_clin [label="Aortic\nAneurysm\n(Long-term)" fillcolor="#922B21" fontcolor="white"]
        AorticDissection_clin [label="Aortic\nDissection\n(Risk)" fillcolor="#7B241C" fontcolor="white"]
        LimbClaudication [label="Arm/Leg\nClaudication\n(>15%)" fillcolor="#C39BD3"]
        Raynaud_clin [label="Raynaud's\nPhenomenon" fillcolor="#D7BDE2"]
        DepressionAnxiety [label="Depression/\nAnxiety\n(QoL impact)" fillcolor="#EBDEF0"]
        ACR_criteria [label="ACR/EULAR\n2022 Classification\nCriteria (≥6 pts)" fillcolor="#A9CCE3" shape=diamond]
    }

    // =========================================================
    // CLUSTER 7: Laboratory Biomarkers & Imaging
    // =========================================================
    subgraph cluster_biomarkers {
        label = "Laboratory Biomarkers & Imaging\n실험실 바이오마커 및 영상검사"
        style = "filled,rounded"
        color = "#1ABC9C"
        fillcolor = "#D5F5E3"
        fontcolor = "#0E6655"
        fontsize = 13

        CRP_bm [label="CRP\n(most sensitive)\n[Normal: <5 mg/L]" fillcolor="#E74C3C" fontcolor="white"]
        ESR_bm [label="ESR\n[Normal: <20 mm/hr]\nSensitive 76-86%" fillcolor="#E74C3C" fontcolor="white"]
        Platelet_bm [label="Platelet Count\n(thrombocytosis)\n[400-600×10⁹/L]" fillcolor="#F8C471"]
        Hemoglobin_bm [label="Hemoglobin\n(normochromic anemia)\n[↓1-2 g/dL]" fillcolor="#AED6F1"]
        Fibrinogen_bm [label="Fibrinogen\n[>4 g/L]" fillcolor="#FAD7A0"]
        Ferritin_bm [label="Ferritin\n(elevated)" fillcolor="#FAD7A0"]
        IL6_serum_bm [label="Serum IL-6\n[>12.5 pg/mL → active]\nPK/PD surrogate" fillcolor="#E74C3C" fontcolor="white"]
        VEGF_serum_bm [label="Serum VEGF\n[>150 pg/mL active]\nAngiogenesis marker" fillcolor="#9B59B6" fontcolor="white"]
        sIL6R_serum_bm [label="Soluble IL-6R\n(sIL-6R)\n[TCZ PD marker]" fillcolor="#F8C471"]
        Albumin_bm [label="Albumin\n(↓ in active disease)" fillcolor="#AED6F1"]
        LFT_bm [label="LFT (ALP ↑)\nHepatic involvement" fillcolor="#D5DBDB"]
        TABiopsy [label="Temporal Artery\nBiopsy (TAB)\nGold standard Dx" fillcolor="#2C3E50" fontcolor="white" shape=diamond]
        PET_CT_bm [label="¹⁸F-FDG PET/CT\nLarge vessel\ninflammation" fillcolor="#2E86C1" fontcolor="white" shape=diamond]
        UltrasoundHalo [label="Temporal Artery\nUltrasound\n(Halo Sign)" fillcolor="#2E86C1" fontcolor="white" shape=diamond]
        MRA_imaging [label="MR Angiography\nLarge vessel GCA" fillcolor="#2E86C1" fontcolor="white" shape=diamond]
        GCA_DAS [label="GCA-DAS\n(Disease Activity\nScore)" fillcolor="#E74C3C" fontcolor="white" shape=diamond]
    }

    // =========================================================
    // CLUSTER 8: Drug PK Compartments
    // =========================================================
    subgraph cluster_drug_pk {
        label = "Drug Pharmacokinetics (PK)\n약물동태학"
        style = "filled,rounded"
        color = "#2980B9"
        fillcolor = "#D6EAF8"
        fontcolor = "#1A5276"
        fontsize = 13

        // Prednisone / Prednisolone PK
        Pred_dose_oral [label="Prednisone\nOral Dose\n(1-2 mg/kg/day)" fillcolor="#5DADE2" fontcolor="white"]
        Pred_GI [label="Prednisone\nGI Absorption\n(F=82%)" fillcolor="#85C1E9"]
        Pred_plasma_cpt [label="Prednisone\nPlasma\n[Cp]" fillcolor="#5DADE2" fontcolor="white"]
        Prednisolone_plasma_cpt [label="Prednisolone\nPlasma\n[Active metabolite]" fillcolor="#2E86C1" fontcolor="white"]
        Pred_tissue_cpt [label="Prednisolone\nTissue Distribution\n(Vd=0.49 L/kg)" fillcolor="#1A5276" fontcolor="white"]
        Pred_metabolism [label="Pred→Prednisolone\nHepatic Metabolism\n(11β-HSD)" fillcolor="#AED6F1"]

        // Tocilizumab PK
        TCZ_IV_dose [label="Tocilizumab IV\n8 mg/kg q4w\n(GiACTA regimen)" fillcolor="#1F618D" fontcolor="white"]
        TCZ_SC_dose [label="Tocilizumab SC\n162 mg qw/q2w" fillcolor="#2471A3" fontcolor="white"]
        TCZ_SC_depot [label="TCZ SC\nDepot\n(absorption site)" fillcolor="#5DADE2" fontcolor="white"]
        TCZ_central_cpt [label="Tocilizumab\nCentral Compartment\n[V1=3.72 L]" fillcolor="#1F618D" fontcolor="white"]
        TCZ_peripheral_cpt [label="Tocilizumab\nPeripheral Cpt\n[V2=3.44 L]" fillcolor="#2E86C1" fontcolor="white"]

        // IL-6 / IL-6R PK (TMDD)
        sIL6R_free_pk [label="Free sIL-6R\n(Soluble IL-6R)\n[Receptor pool]" fillcolor="#85C1E9"]
        mIL6R_free_pk [label="Free mIL-6R\n(Membrane IL-6R)\n[On hepatocytes]" fillcolor="#AED6F1"]
        TCZ_sIL6R_complex [label="TCZ:\nsIL-6R Complex\n(inactive)" fillcolor="#2C3E50" fontcolor="white"]
        TCZ_mIL6R_complex [label="TCZ:\nmIL-6R Complex\n(inactive)" fillcolor="#2C3E50" fontcolor="white"]
        IL6_free_pk [label="Free IL-6\n(Serum)\n[Biomarker]" fillcolor="#E74C3C" fontcolor="white"]
        IL6_bound_pk [label="IL-6:\nIL-6R Complex\n(active signaling)" fillcolor="#922B21" fontcolor="white"]

        // Other drugs PK
        Abatacept_dose [label="Abatacept\nCTLA4-Ig\n(CTLA4-GCA trial)" fillcolor="#8E44AD" fontcolor="white"]
        Upadacitinib_dose [label="Upadacitinib\nJAK1i 15mg QD\n(SELECT-GCA)" fillcolor="#7D3C98" fontcolor="white"]
        Baricitinib_dose [label="Baricitinib\nJAK1/2i 4mg QD\n(Investigational)" fillcolor="#6C3483" fontcolor="white"]
        Aspirin_dose [label="Low-dose\nAspirin\n(81mg/d, antiplatelet)" fillcolor="#A9DFBF"]
    }

    // =========================================================
    // CLUSTER 9: Drug PD Mechanisms
    // =========================================================
    subgraph cluster_drug_pd {
        label = "Drug Pharmacodynamics (PD) & Mechanisms of Action\n약력학 및 작용 기전"
        style = "filled,rounded"
        color = "#8E44AD"
        fillcolor = "#F0E6FF"
        fontcolor = "#4A235A"
        fontsize = 13

        // Glucocorticoid PD
        GReceptor [label="Glucocorticoid\nReceptor (GR-α)\n(Cytoplasmic)" fillcolor="#A569BD" fontcolor="white"]
        GR_activated [label="GR:Prednisolone\nComplex\n(Nuclear)" fillcolor="#8E44AD" fontcolor="white"]
        GRE_binding [label="GRE DNA\nBinding\n(Transactivation)" fillcolor="#7D3C98" fontcolor="white"]
        GILZ_expr [label="GILZ Expression\n(Anti-inflammatory\nMediator)" fillcolor="#C39BD3"]
        NFkB_inhib [label="NF-κB\nInhibition\n(Transrepression)" fillcolor="#6C3483" fontcolor="white"]
        AP1_inhib [label="AP-1\nInhibition" fillcolor="#7D3C98" fontcolor="white"]
        CYP3A4_induc [label="CYP3A4\nInduction\n(Metabolism)" fillcolor="#D7BDE2"]
        GC_immunosupp [label="GC\nImmunosuppression\n(T/B cell, Mono)" fillcolor="#8E44AD" fontcolor="white"]
        HPA_feedback [label="HPA Axis\nFeedback\nSuppression" fillcolor="#C39BD3"]

        // Tocilizumab PD
        IL6R_saturation [label="IL-6R\nSaturation\n(TCZ binding)" fillcolor="#2C3E50" fontcolor="white"]
        JAK1_STAT3_block [label="JAK1/STAT3\nSignaling Block\n(via IL-6R block)" fillcolor="#1F618D" fontcolor="white"]
        JAK_STAT3_active [label="JAK1→STAT3\nActivation\n(active disease)" fillcolor="#E74C3C" fontcolor="white"]
        Sgp130 [label="sGP130\n(IL-6 trans-signal\ninhibitor, natural)" fillcolor="#AED6F1"]
        IL6_transsign [label="IL-6 Trans-\nSignaling\n(via sIL-6R)" fillcolor="#E74C3C" fontcolor="white"]
        CRP_liver_suppress [label="CRP/Fibrinogen\nLiver Production\n(IL-6→ Hepatocyte)" fillcolor="#F0B27A"]

        // Abatacept PD
        Abatacept_target [label="CD80/CD86\nBlockade\n(Abatacept)" fillcolor="#7D3C98" fontcolor="white"]
        Tcell_anergy [label="T Cell\nAnergy\n(Co-stim. block)" fillcolor="#9B59B6" fontcolor="white"]

        // JAK inhibitor PD
        JAKi_target [label="JAK1/2\nInhibition\n(Upadacitinib)" fillcolor="#6C3483" fontcolor="white"]
        STAT3_inhib_drug [label="STAT3\nInhibition\n(JAKi effect)" fillcolor="#4A235A" fontcolor="white"]
        IFNg_block_JAKi [label="IFN-γ Signaling\nReduction\n(via JAKi)" fillcolor="#7D3C98" fontcolor="white"]

        // IL-17 inhibitor PD
        IL17inhib_target [label="IL-17A/F\nNeutralization\n(Ixekizumab, invest.)" fillcolor="#922B21" fontcolor="white"]
        VEGF_block_IL17 [label="VEGF ↓\n(via IL-17\nblockade)" fillcolor="#9B59B6" fontcolor="white"]
    }

    // =========================================================
    // CLUSTER 10: Glucocorticoid Side Effects & Safety
    // =========================================================
    subgraph cluster_side_effects {
        label = "Glucocorticoid Side Effects & Safety Monitoring\n글루코코르티코이드 부작용 및 안전성"
        style = "filled,rounded"
        color = "#7F8C8D"
        fillcolor = "#F2F3F4"
        fontcolor = "#2C3E50"
        fontsize = 13

        BMD_loss [label="Bone Mineral\nDensity Loss\n(↓3-5%/yr)" fillcolor="#BDC3C7"]
        Fracture_risk [label="Vertebral\nFracture Risk\n(↑ 5-fold)" fillcolor="#95A5A6"]
        GlucoseIntoler [label="Glucose\nIntolerance\n/Steroid DM" fillcolor="#F8C471"]
        HTN_GC [label="Hypertension\n(Fluid retention,\nRAAS activation)" fillcolor="#E74C3C" fontcolor="white"]
        CataractRisk [label="Posterior\nSubcapsular\nCataract" fillcolor="#AED6F1"]
