digraph VaD_QSP {
    graph [
        label="Vascular Dementia (VaD) — QSP Mechanistic Map\n혈관성 치매 정량적 시스템 약리학 기계론적 지도",
        fontsize=20, labelloc=t, fontname="Helvetica-Bold",
        rankdir=LR, splines=spline,
        bgcolor="white", nodesep=0.3, ranksep=0.8,
        tooltip="VaD QSP Model"
    ]
    node [fontname="Helvetica", fontsize=8, margin="0.07,0.04", style=filled]
    edge [fontsize=7, fontname="Helvetica", arrowsize=0.65]

    /* ============================================================
       1. Drug PK/PD Cluster
    ============================================================ */
    subgraph cluster_PK {
        label="1. Drug PK / PD"
        style=filled fillcolor="#E8EAF6" color="#3949AB"
        fontsize=11 fontname="Helvetica-Bold"

        AHT_dose   [label="AHT Dose\n(oral)" shape=box fillcolor="#C5CAE9"]
        AHT_depot  [label="AHT Gut Depot"    shape=box fillcolor="#C5CAE9"]
        AHT_plasma [label="AHT Plasma Cp"    shape=ellipse fillcolor="#9FA8DA"]
        AHT_brain  [label="AHT Brain Conc."  shape=ellipse fillcolor="#9FA8DA"]
        AHT_Emax   [label="AHT Effect:\nBP↓ + Vasoprotect" shape=diamond fillcolor="#7986CB"]

        APT_dose   [label="Antiplatelet\nDose (ASA/Clopi)" shape=box fillcolor="#C5CAE9"]
        APT_plasma [label="APT Plasma"       shape=ellipse fillcolor="#9FA8DA"]
        APT_Emax   [label="APT Effect:\nTXA2↓ COX1-inhib"  shape=diamond fillcolor="#7986CB"]

        STATIN_dose  [label="Statin Dose"    shape=box fillcolor="#C5CAE9"]
        STATIN_plasma[label="Statin Plasma"  shape=ellipse fillcolor="#9FA8DA"]
        STATIN_liver [label="HMG-CoA\nReductase Inhib"    shape=diamond fillcolor="#7986CB"]

        ACHEI_dose   [label="AChEI Dose\n(Donepezil)" shape=box fillcolor="#C5CAE9"]
        ACHEI_plasma [label="AChEI Plasma"   shape=ellipse fillcolor="#9FA8DA"]
        ACHEI_brain  [label="AChEI Brain\nEffect-site"    shape=diamond fillcolor="#7986CB"]

        MEM_dose   [label="Memantine\nDose"  shape=box fillcolor="#C5CAE9"]
        MEM_plasma [label="Memantine\nPlasma" shape=ellipse fillcolor="#9FA8DA"]
        MEM_brain  [label="Memantine Brain\nNMDA-R Block"  shape=diamond fillcolor="#7986CB"]

        CIL_dose   [label="Cilostazol\nDose" shape=box fillcolor="#C5CAE9"]
        CIL_plasma [label="Cilostazol\nPlasma (PDE3-i)"   shape=ellipse fillcolor="#9FA8DA"]

        NIC_dose   [label="Nimodipine/\nNicergoline Dose"  shape=box fillcolor="#C5CAE9"]
        NIC_plasma [label="Ca-CB / Ergot\nAlkaloid Plasma" shape=ellipse fillcolor="#9FA8DA"]

        AHT_dose -> AHT_depot -> AHT_plasma -> AHT_brain -> AHT_Emax
        APT_dose -> APT_plasma -> APT_Emax
        STATIN_dose -> STATIN_plasma -> STATIN_liver
        ACHEI_dose -> ACHEI_plasma -> ACHEI_brain
        MEM_dose -> MEM_plasma -> MEM_brain
        CIL_dose -> CIL_plasma
        NIC_dose -> NIC_plasma
    }

    /* ============================================================
       2. Vascular Risk Factors
    ============================================================ */
    subgraph cluster_VRF {
        label="2. Vascular Risk Factors"
        style=filled fillcolor="#FFEBEE" color="#C62828"
        fontsize=11 fontname="Helvetica-Bold"

        SBP       [label="Systolic BP\n(mmHg)"       shape=ellipse fillcolor="#FFCDD2"]
        DBP       [label="Diastolic BP\n(mmHg)"      shape=ellipse fillcolor="#FFCDD2"]
        PP        [label="Pulse Pressure"             shape=ellipse fillcolor="#FFCDD2"]
        LDL_c     [label="LDL-C (mg/dL)"             shape=ellipse fillcolor="#EF9A9A"]
        HDL_c     [label="HDL-C (mg/dL)"             shape=ellipse fillcolor="#FFCDD2"]
        TG_c      [label="Triglycerides"              shape=ellipse fillcolor="#FFCDD2"]
        FBG       [label="Fasting Glucose"            shape=ellipse fillcolor="#EF9A9A"]
        HbA1c     [label="HbA1c (%)"                 shape=ellipse fillcolor="#EF9A9A"]
        HOMA_IR   [label="HOMA-IR\n(Insulin Resist.)" shape=ellipse fillcolor="#FFCDD2"]
        AF_burden [label="AF Burden\n(% time)"        shape=ellipse fillcolor="#EF9A9A"]
        Smoking   [label="Smoking\n(pack-yrs)"        shape=ellipse fillcolor="#FFCDD2"]
        Obesity   [label="Obesity\n(BMI/waist)"       shape=ellipse fillcolor="#FFCDD2"]
        hsCRP     [label="hsCRP (mg/L)"               shape=ellipse fillcolor="#EF9A9A"]
        Homocys   [label="Homocysteine\n(μmol/L)"     shape=ellipse fillcolor="#EF9A9A"]
        ApoB      [label="ApoB\n(atherogenic LDL)"    shape=ellipse fillcolor="#FFCDD2"]

        SBP -> DBP
        SBP -> PP
        Obesity -> HOMA_IR -> HbA1c -> FBG
        Obesity -> TG_c
        LDL_c -> ApoB
        Smoking -> hsCRP
    }

    /* ============================================================
       3. Cerebrovascular Pathology
    ============================================================ */
    subgraph cluster_CVP {
        label="3. Cerebrovascular Pathology"
        style=filled fillcolor="#FBE9E7" color="#BF360C"
        fontsize=11 fontname="Helvetica-Bold"

        CBF       [label="Cerebral Blood\nFlow (mL/100g/min)"  shape=ellipse fillcolor="#FFCCBC"]
        CPP       [label="Cerebral Perf.\nPressure (CPP)"      shape=ellipse fillcolor="#FFCCBC"]
        ICP       [label="Intracranial\nPressure (ICP)"        shape=ellipse fillcolor="#FFCCBC"]
        Athero    [label="Large Vessel\nAtherosclerosis"       shape=ellipse fillcolor="#FF8A65"]
        Stenosis  [label="Arterial\nStenosis (%)"              shape=ellipse fillcolor="#FF8A65"]
        SVD       [label="Small Vessel\nDisease (SVD)"         shape=ellipse fillcolor="#FF8A65"]
        WMH       [label="WMH Volume\n(mL)"                   shape=ellipse fillcolor="#FF7043"]
        Lacunes   [label="Lacunar\nInfarcts (n)"               shape=ellipse fillcolor="#FF7043"]
        Microinf  [label="Cortical\nMicroinfarcts"             shape=ellipse fillcolor="#FF7043"]
        CMB       [label="Cerebral\nMicrobleeds"               shape=ellipse fillcolor="#FFCCBC"]
        CAA       [label="Cerebral Amyloid\nAngiopathy (CAA)"  shape=ellipse fillcolor="#FFCCBC"]
        Thrombosis[label="Thrombus\nFormation"                 shape=ellipse fillcolor="#FF8A65"]
        Embolism  [label="Cardioembolic\nStroke"               shape=ellipse fillcolor="#FF7043"]
        eNOS_e    [label="Endothelial\neNOS / NO"              shape=ellipse fillcolor="#FFCCBC"]

        CPP -> CBF
        ICP -> CPP [dir=back]
        Athero -> Stenosis -> CBF [label="(-)"]
        Athero -> Thrombosis
        SVD -> WMH
        SVD -> Lacunes
        SVD -> Microinf
        SVD -> CMB
        CAA -> CMB
        AF_burden -> Embolism
        eNOS_e -> CBF [label="(+) vasodilat"]
        SBP -> CPP
        SBP -> SVD [label="wall stress"]
        SBP -> Athero
    }

    /* ============================================================
       4. Blood-Brain Barrier
    ============================================================ */
    subgraph cluster_BBB {
        label="4. Blood-Brain Barrier (BBB) / Neurovascular Unit"
        style=filled fillcolor="#F3E5F5" color="#6A1B9A"
        fontsize=11 fontname="Helvetica-Bold"

        TJ_prot  [label="Tight Junction\nProteins\n(Claudin/Occludin/ZO-1)" shape=ellipse fillcolor="#E1BEE7"]
        BBB_perm [label="BBB Permeability\n(Ki, mL/g/min)"                  shape=ellipse fillcolor="#CE93D8"]
        Pericyte [label="Pericyte\nFunction"                                 shape=ellipse fillcolor="#E1BEE7"]
        Astro_ef [label="Astrocytic\nEnd-feet"                               shape=ellipse fillcolor="#E1BEE7"]
        MMP9_bbb [label="MMP-2/9\n(TJ degradation)"                        shape=ellipse fillcolor="#CE93D8"]
        AQP4     [label="Aquaporin-4\n(water channel)"                      shape=ellipse fillcolor="#E1BEE7"]
        RAGE_r   [label="RAGE\n(Aβ influx)"                                shape=ellipse fillcolor="#CE93D8"]
        LRP1_r   [label="LRP1\n(Aβ/Tau efflux)"                           shape=ellipse fillcolor="#E1BEE7"]
        PDGFR_b  [label="PDGFR-β\n(pericyte survival)"                    shape=ellipse fillcolor="#E1BEE7"]
        NVU      [label="Neurovascular\nUnit Integrity"                     shape=ellipse fillcolor="#BA68C8"]

        Pericyte -> TJ_prot
        Astro_ef -> TJ_prot
        MMP9_bbb -> TJ_prot [label="(-) degrade"]
        TJ_prot -> BBB_perm [label="(-)"]
        RAGE_r -> BBB_perm  [label="Aβ influx(+)"]
        LRP1_r -> BBB_perm  [label="efflux(-)"]
        BBB_perm -> NVU     [label="(-)"]
        PDGFR_b -> Pericyte
    }

    /* ============================================================
       5. Neuroinflammation
    ============================================================ */
    subgraph cluster_NI {
        label="5. Neuroinflammation"
        style=filled fillcolor="#FFF3E0" color="#E65100"
        fontsize=11 fontname="Helvetica-Bold"

        Micro_M0 [label="Resting\nMicroglia (M0)"      shape=ellipse fillcolor="#FFE0B2"]
        Micro_M1 [label="Pro-inflam\nMicroglia (M1)"   shape=ellipse fillcolor="#FFAB40"]
        Micro_M2 [label="Anti-inflam\nMicroglia (M2)"  shape=ellipse fillcolor="#FFE0B2"]
        Astro_A1 [label="Reactive\nAstrocytes (A1)"    shape=ellipse fillcolor="#FFAB40"]
        Astro_A2 [label="Protective\nAstrocytes (A2)"  shape=ellipse fillcolor="#FFE0B2"]
        IL1b     [label="IL-1β (pg/mL)"                shape=ellipse fillcolor="#FF6D00"]
        TNFa     [label="TNF-α (pg/mL)"                shape=ellipse fillcolor="#FF6D00"]
        IL6_n    [label="IL-6 (pg/mL)"                 shape=ellipse fillcolor="#FFAB40"]
        IL10_n   [label="IL-10\n(anti-inflam)"         shape=ellipse fillcolor="#FFE0B2"]
        IL18_n   [label="IL-18\n(inflammasome)"        shape=ellipse fillcolor="#FFAB40"]
        NLRP3_n  [label="NLRP3\nInflammasome"          shape=ellipse fillcolor="#FF6D00"]
        NF_kB    [label="NF-κB\n(transcription)"       shape=ellipse fillcolor="#FF6D00"]
        TGFb1_n  [label="TGF-β1\n(remodeling)"        shape=ellipse fillcolor="#FFAB40"]
        DAMPs    [label="DAMPs / PAMPs\n(HMGB1,mtDNA)" shape=ellipse fillcolor="#FFAB40"]
        Complement[label="Complement\n(C1q/C3/MAC)"   shape=ellipse fillcolor="#FFE0B2"]

        DAMPs -> NLRP3_n -> IL18_n -> IL1b
        DAMPs -> Micro_M1
        Micro_M0 -> Micro_M1 [label="activation"]
        Micro_M1 -> IL1b
        Micro_M1 -> TNFa
        Micro_M1 -> IL6_n
        Micro_M1 -> NF_kB
        Micro_M1 -> Astro_A1
        Micro_M2 -> IL10_n
        Astro_A2 -> TGFb1_n
        NF_kB -> TNFa
        NF_kB -> IL6_n
        IL1b -> NF_kB [label="amplify" constraint=false]
        NF_kB -> Micro_M1 [label="feedback" constraint=false]
        Complement -> Micro_M1
    }

    /* ============================================================
       6. Oxidative Stress
    ============================================================ */
    subgraph cluster_OS {
        label="6. Oxidative & Nitrosative Stress"
        style=filled fillcolor="#F1F8E9" color="#33691E"
        fontsize=11 fontname="Helvetica-Bold"

        Mito_dx [label="Mitochondrial\nDysfunction"   shape=ellipse fillcolor="#DCEDC8"]
        ROS     [label="ROS\n(O₂•⁻, H₂O₂)"           shape=ellipse fillcolor="#AED581"]
        eNOS_OS [label="eNOS-NO\n(vasoprotection)"    shape=ellipse fillcolor="#DCEDC8"]
        iNOS_OS [label="iNOS\n(excess NO)"            shape=ellipse fillcolor="#AED581"]
        ONOO    [label="Peroxynitrite\n(ONOO⁻)"       shape=ellipse fillcolor="#8BC34A"]
        NOX24   [label="NADPH Oxidase\n(NOX2/NOX4)"   shape=ellipse fillcolor="#AED581"]
        SOD_en  [label="SOD1/SOD2\n(antioxidant)"     shape=ellipse fillcolor="#DCEDC8"]
        GPx_en  [label="Catalase / GPx"               shape=ellipse fillcolor="#DCEDC8"]
        GSH_lvl [label="GSH / GSSG\nRatio"            shape=ellipse fillcolor="#DCEDC8"]
        LipPx   [label="Lipid Peroxidation\n(4-HNE/MDA)" shape=ellipse fillcolor="#8BC34A"]
        ProtCrb [label="Protein\nCarbonylation"       shape=ellipse fillcolor="#AED581"]
        DNA_ox  [label="DNA Oxidative\nDamage (8-OHdG)" shape=ellipse fillcolor="#AED581"]
        Nrf2    [label="Nrf2 / ARE\n(antioxidant gene)" shape=ellipse fillcolor="#DCEDC8"]

        Mito_dx -> ROS
        NOX24 -> ROS
        ROS -> LipPx
        ROS -> ProtCrb
        ROS -> DNA_ox
        iNOS_OS -> ONOO
        ROS -> ONOO [label="(+)"]
        SOD_en -> ROS [label="(-)" color=green]
        GPx_en -> ROS [label="(-)" color=green]
        GSH_lvl -> GPx_en [label="substrate"]
        Nrf2 -> SOD_en [label="(+)"]
        Nrf2 -> GPx_en [label="(+)"]
        Nrf2 -> GSH_lvl [label="(+)"]
        ROS -> Mito_dx [label="feedback" constraint=false]
    }

    /* ============================================================
       7. Neurotransmitter Systems
    ============================================================ */
    subgraph cluster_NT {
        label="7. Neurotransmitter Systems"
        style=filled fillcolor="#E3F2FD" color="#0D47A1"
        fontsize=11 fontname="Helvetica-Bold"

        ChAT     [label="Choline\nAcetyltransferase\n(ChAT)"  shape=ellipse fillcolor="#BBDEFB"]
        ACh_nt   [label="Acetylcholine\n(synaptic ACh)"       shape=ellipse fillcolor="#64B5F6"]
        AChE_enz [label="Acetylcholinesterase\n(AChE)"        shape=ellipse fillcolor="#BBDEFB"]
        nAChR    [label="Nicotinic AChR\n(α4β2/α7)"          shape=ellipse fillcolor="#BBDEFB"]
        mAChR    [label="Muscarinic AChR\n(M1/M2)"           shape=ellipse fillcolor="#BBDEFB"]
        Glut_nt  [label="Glutamate\n(synaptic)"               shape=ellipse fillcolor="#64B5F6"]
        NMDA_R   [label="NMDA Receptors\n(Ca²⁺ influx)"      shape=ellipse fillcolor="#1E88E5"]
        AMPA_R   [label="AMPA Receptors"                      shape=ellipse fillcolor="#BBDEFB"]
        mGluR5   [label="mGluR5\n(metabotropic)"             shape=ellipse fillcolor="#BBDEFB"]
        Dopamine [label="Dopamine (DA)\n(frontostriatal)"    shape=ellipse fillcolor="#BBDEFB"]
        Serotonin[label="Serotonin (5-HT)"                   shape=ellipse fillcolor="#BBDEFB"]
        NorEpi   [label="Norepinephrine\n(NE)"               shape=ellipse fillcolor="#BBDEFB"]
        GABA_i   [label="GABA\n(inhibitory tone)"            shape=ellipse fillcolor="#BBDEFB"]
        Excitotox[label="Excitotoxicity\n(Ca²⁺ overload)"   shape=ellipse fillcolor="#1E88E5"]

        ChAT -> ACh_nt
        AChE_enz -> ACh_nt [label="(-) degrade"]
        ACh_nt -> nAChR
        ACh_nt -> mAChR
        Glut_nt -> NMDA_R
        Glut_nt -> AMPA_R
        Glut_nt -> mGluR5
        NMDA_R -> Excitotox [label="excess Ca²⁺"]
        GABA_i -> NMDA_R   [label="(-) homeostasis"]
    }

    /* ============================================================
       8. Brain Structure & Neuronal Integrity
    ============================================================ */
    subgraph cluster_BRAIN {
        label="8. Brain Structure & Neuronal Integrity"
        style=filled fillcolor="#EDE7F6" color="#4527A0"
        fontsize=11 fontname="Helvetica-Bold"

        Hippocampus [label="Hippocampal\nVolume (cm³)"       shape=ellipse fillcolor="#D1C4E9"]
        CortThick   [label="Cortical\nThickness (mm)"        shape=ellipse fillcolor="#D1C4E9"]
        WM_integr   [label="WM Integrity\n(FA, DTI)"         shape=ellipse fillcolor="#D1C4E9"]
        SynDens     [label="Synaptic\nDensity (SV2A)"        shape=ellipse fillcolor="#B39DDB"]
        LTP_eff     [label="Long-Term\nPotentiation (LTP)"   shape=ellipse fillcolor="#B39DDB"]
        Neurogen    [label="Adult\nNeurogenesis (BDNF)"      shape=ellipse fillcolor="#D1C4E9"]
        BDNF        [label="BDNF (ng/mL)"                    shape=ellipse fillcolor="#B39DDB"]
        NGF_br      [label="Nerve Growth\nFactor (NGF)"      shape=ellipse fillcolor="#D1C4E9"]
        pTau        [label="p-Tau (T181)\n(CSF, pg/mL)"      shape=ellipse fillcolor="#9575CD"]
        tTau        [label="Total Tau\n(t-Tau, CSF)"         shape=ellipse fillcolor="#B39DDB"]
        Abeta42     [label="Aβ42 (CSF) /\nAmyloid PET"      shape=ellipse fillcolor="#9575CD"]
        Cytoskel    [label="Cytoskeletal\nIntegrity (NfL)"   shape=ellipse fillcolor="#D1C4E9"]
        NeuronDeath [label="Neuronal Death /\nApoptosis"     shape=ellipse fillcolor="#7E57C2"]

        BDNF -> Neurogen
        BDNF -> SynDens
        BDNF -> LTP_eff
        NGF_br -> Neurogen
        tTau -> pTau
        pTau -> Cytoskel [label="(-) tangles"]
        Cytoskel -> NeuronDeath [label="(-)"]
        NeuronDeath -> Hippocampus [label="(-)"]
        NeuronDeath -> CortThick   [label="(-)"]
        LTP_eff -> SynDens
    }

    /* ============================================================
       9. Clinical Outcomes
    ============================================================ */
    subgraph cluster_OUT {
        label="9. Clinical Outcomes"
        style=filled fillcolor="#E8F5E9" color="#1B5E20"
        fontsize=11 fontname="Helvetica-Bold"

        MMSE      [label="MMSE\n(0–30)"             shape=ellipse fillcolor="#C8E6C9"]
        ADAS_Cog  [label="ADAS-Cog\n(0–70)"        shape=ellipse fillcolor="#A5D6A7"]
        MoCA      [label="MoCA\n(0–30)"             shape=ellipse fillcolor="#C8E6C9"]
        ExecFunc  [label="Executive\nFunction"       shape=ellipse fillcolor="#C8E6C9"]
        ProcSpeed [label="Processing\nSpeed"         shape=ellipse fillcolor="#C8E6C9"]
        EpisMem   [label="Episodic\nMemory (RAVLT)"  shape=ellipse fillcolor="#C8E6C9"]
        Language  [label="Language\nFunction"        shape=ellipse fillcolor="#C8E6C9"]
        Visuosp   [label="Visuospatial\nFunction"    shape=ellipse fillcolor="#C8E6C9"]
        ADL       [label="ADL Score"                 shape=ellipse fillcolor="#A5D6A7"]
        IADL      [label="IADL Score"                shape=ellipse fillcolor="#A5D6A7"]
        NPI       [label="Neuropsychiatric\nInventory (NPI)" shape=ellipse fillcolor="#C8E6C9"]
        CDR_SB    [label="CDR-SB\n(0–18)"           shape=ellipse fillcolor="#66BB6A"]
        CDR_glob  [label="CDR Global\n(0–3)"         shape=ellipse fillcolor="#43A047"]
        StageVaD  [label="VaD Stage\n(MCI→Sev)"     shape=ellipse fillcolor="#2E7D32"]
        StrokeRisk[label="Recurrent\nStroke Risk"    shape=ellipse fillcolor="#A5D6A7"]
        QoL       [label="Quality of Life\n(EQ-5D)"  shape=ellipse fillcolor="#C8E6C9"]

        ExecFunc -> MMSE
        EpisMem -> MMSE
        ProcSpeed -> MMSE
        Language -> MMSE
        Visuosp -> MMSE
        IADL -> ADL
        ADL -> CDR_SB
        MMSE -> CDR_glob
        ADAS_Cog -> CDR_glob
        CDR_SB -> CDR_glob
        CDR_glob -> StageVaD
        MMSE -> QoL
        ADL -> QoL
        NPI -> QoL [label="(-)"]
        StageVaD -> StrokeRisk [label="adv stage→risk"]
    }

    /* ============================================================
       INTER-CLUSTER EDGES
    ============================================================ */

    /* Drug → Vascular Risk */
    AHT_Emax -> SBP       [label="(-) BP reduce"  color=blue fontcolor=blue]
    STATIN_liver -> LDL_c [label="(-) LDL-C↓"     color=blue fontcolor=blue]
    APT_Emax -> Thrombosis [label="(-) TXA2↓"     color=blue fontcolor=blue]
    CIL_plasma -> CBF      [label="(+) PDE3→vasorelax" color=blue fontcolor=blue]
    NIC_plasma -> CBF      [label="(+) Ca-block"   color=blue fontcolor=blue]
    NIC_plasma -> eNOS_e   [label="(+) eNOS↑"     color=blue]

    /* VRF → Cerebrovascular */
    LDL_c -> Athero       [label="plaque lipid"]
    hsCRP -> Athero       [label="inflam→plaque"]
    HbA1c -> SVD          [label="AGE→microvasc"]
    Homocys -> Athero     [label="endothel injury"]
    Homocys -> SVD
    Smoking -> Athero     [label="oxidative"]
    AHT_Emax -> SVD       [label="(-) wall stress" color=blue fontcolor=blue]

    /* CVP → BBB */
    CBF -> BBB_perm       [label="(ischemia->(+))" color=orange]
    Microinf -> BBB_perm  [label="(+) disrupt"      color=orange]
    SVD -> MMP9_bbb       [label="(+) activate"     color=orange]
    ROS -> MMP9_bbb       [label="(+)"              color=orange]
    Embolism -> CBF       [label="(-) acute"        color=red]

    /* BBB → NI */
    BBB_perm -> Micro_M1  [label="DAMPs entry"      color=orange]
    BBB_perm -> Astro_A1  [label="toxic entry"      color=orange]
    BBB_perm -> DAMPs     [label="cytokine influx"  color=orange]

    /* CBF → DAMPs / Neurotransmitters */
    CBF -> ChAT           [label="(-) ischemia"     color=red style=dashed]
    CBF -> Glut_nt        [label="(+) anoxic\nrelease" color=red style=dashed]
    NeuronDeath -> ChAT   [label="(-) neuron loss"  color=red]

    /* NI → Oxidative Stress */
    NF_kB -> NOX24        [label="(+) transcr."    color=orange]
    IL1b -> Mito_dx       [label="(+) mitopathy"   color=orange]
    TNFa -> ROS           [label="(+) NOX"         color=orange]
    IL1b -> iNOS_OS       [label="(+)"             color=orange]
    NF_kB -> iNOS_OS      [label="(+)"             color=orange]

    /* OS → Neurodegeneration */
    ROS -> pTau           [label="(+) kinase act." color=darkorange]
    ROS -> NeuronDeath    [label="(+) apoptosis"   color=darkorange]
    ONOO -> NeuronDeath   [label="(+) nitrosylation" color=darkorange]
    LipPx -> NeuronDeath  [label="(+)"             color=darkorange]
    ROS -> BBB_perm       [label="(+) TJ oxidation" color=darkorange]

    /* OS → NI (feedback) */
    ROS -> NF_kB          [label="(+) redox"       color=orange constraint=false]

    /* NI → BDNF */
    IL1b -> BDNF          [label="(-)"             color=red]
    TNFa -> BDNF          [label="(-)"             color=red]
    IL10_n -> BDNF        [label="(+) protect"     color=green]

    /* Drug → Neurotransmitters */
    ACHEI_brain -> AChE_enz [label="(-) AChE inhib." color=blue fontcolor=blue]
    MEM_brain -> NMDA_R     [label="(-) NMDA block"  color=blue fontcolor=blue]
    MEM_brain -> Excitotox  [label="(-)"             color=blue fontcolor=blue]

    /* Statin pleiotropic */
    STATIN_plasma -> NF_kB  [label="(-) pleiotropic" color=blue fontcolor=blue]
    STATIN_plasma -> MMP9_bbb [label="(-)"           color=blue fontcolor=blue]
    STATIN_plasma -> BDNF   [label="(+) pleiotropic" color=blue fontcolor=blue]
    STATIN_plasma -> eNOS_e [label="(+) eNOS↑"      color=blue fontcolor=blue]

    /* AHT pleiotropic */
    AHT_brain -> BBB_perm   [label="(-) RAAS-TJ" color=blue fontcolor=blue style=dashed]
    AHT_brain -> NF_kB      [label="(-) pleiop." color=blue fontcolor=blue style=dashed]

    /* NT → Brain Structure */
    ACh_nt -> EpisMem       [label="cholinergic→memory"]
    ACh_nt -> ExecFunc
    NMDA_R -> LTP_eff       [label="Ca²⁺-CAMKII"]
    LTP_eff -> EpisMem      [label="storage"]
    Excitotox -> NeuronDeath [label="(+) Ca²⁺ overload" color=red]

    /* Brain Structure → Cognition */
    SynDens -> MMSE         [label="(+)"]
    Hippocampus -> EpisMem  [label="(+)"]
    CortThick -> ExecFunc   [label="(+)"]
    WM_integr -> ProcSpeed  [label="(+)"]
    BDNF -> MMSE            [label="(+) neuroprot."]
    NeuronDeath -> MMSE     [label="(-)"     color=red]
    NeuronDeath -> ExecFunc [label="(-)"     color=red]
    WMH -> ProcSpeed        [label="(-)"     color=red]
    WMH -> ExecFunc         [label="(-)"     color=red]
    Lacunes -> MMSE         [label="(-)"     color=red]
    Microinf -> MMSE        [label="(-)"     color=red]

    /* CBF → Neuronal Death */
    CBF -> NeuronDeath      [label="(ischemia->(+))" color=red style=dashed]
    CBF -> Mito_dx          [label="(hypoxia->(+))"  color=red style=dashed]

    /* Stroke risk */
    Athero -> StrokeRisk    [label="rupture risk"]
    AF_burden -> StrokeRisk [label="embolism"]
    SBP -> StrokeRisk       [label="HTN→hemorrhage"]
    CMB -> StrokeRisk

    /* Aβ pathway */
    CAA -> Abeta42          [label="(+) vascular Aβ" color=purple]
    BBB_perm -> Abeta42     [label="(LRP1↓→Aβ accum)" color=purple]
    Abeta42 -> pTau         [label="Aβ→p-Tau kinase" color=purple]
    Abeta42 -> RAGE_r       [label="(+) influx feed" color=purple constraint=false]
}
