digraph MFS_QSP {
  graph [
    rankdir=TB
    fontname="Helvetica"
    fontsize=11
    label="Marfan Syndrome — Quantitative Systems Pharmacology Mechanistic Map\nFBN1 Mutation → TGF-β / MAPK Signalling → Aortic / Skeletal / Ocular Manifestations → Pharmacological Intervention"
    labelloc=t
    labelfontsize=15
    labelfontname="Helvetica-Bold"
    bgcolor="#F8F9FA"
    pad=0.6
    nodesep=0.35
    ranksep=0.55
    splines=ortho
  ]
  node [shape=box style="filled,rounded" fontname="Helvetica" fontsize=9 margin="0.12,0.06"]
  edge [fontname="Helvetica" fontsize=8 arrowsize=0.7]

  // ─────────────────────────────────────────────────────────────────────
  // CLUSTER 1 — Genetic & Molecular Foundation
  // ─────────────────────────────────────────────────────────────────────
  subgraph cluster_genetics {
    label="① Genetic & Molecular Foundation"
    style=filled fillcolor="#FFF3E0" color="#E65100" fontname="Helvetica-Bold" fontsize=10

    FBN1_gene        [label="FBN1 Gene\n(Chr 15q21.1)" fillcolor="#FFCC80"]
    FBN1_mut         [label="FBN1 Mutation\n(missense/nonsense/splice)" fillcolor="#FF8F00" fontcolor=white]
    FBN1_haplo       [label="Haploinsufficiency" fillcolor="#FFAB40"]
    FBN1_dom_neg     [label="Dominant-Negative Effect" fillcolor="#FFAB40"]
    FBN1_protein     [label="Fibrillin-1 Protein\n(defective / reduced)" fillcolor="#FFCC80"]
    FBN2             [label="Fibrillin-2\n(partial compensation)" fillcolor="#FFE0B2"]
    LTBP1            [label="LTBP-1\n(Latent TGF-β BP 1)" fillcolor="#FFE0B2"]
    LTBP3            [label="LTBP-3\n(Latent TGF-β BP 3)" fillcolor="#FFE0B2"]
    Microfibril_net  [label="Microfibril Network\n(disrupted)" fillcolor="#FFCC80"]
    ECM_scaffold     [label="ECM Structural\nScaffolding (↓)" fillcolor="#FFCC80"]
    LAP              [label="LAP (Latency-Associated\nPeptide)" fillcolor="#FFE0B2"]
    LLCB             [label="Large Latent Complex\n(LLC)" fillcolor="#FFE0B2"]
  }

  // ─────────────────────────────────────────────────────────────────────
  // CLUSTER 2 — TGF-β Signalling Pathway
  // ─────────────────────────────────────────────────────────────────────
  subgraph cluster_tgfb {
    label="② TGF-β Signalling Pathway"
    style=filled fillcolor="#E8F5E9" color="#2E7D32" fontname="Helvetica-Bold" fontsize=10

    LTGF_complex  [label="Latent TGF-β Complex\n(normally sequestered)" fillcolor="#A5D6A7"]
    Free_TGFb1    [label="Free TGF-β1 (↑↑)" fillcolor="#2E7D32" fontcolor=white]
    Free_TGFb2    [label="Free TGF-β2 (↑)" fillcolor="#388E3C" fontcolor=white]
    TGFBR2        [label="TGF-β Receptor II\n(ligand-binding)" fillcolor="#81C784"]
    TGFBR1        [label="TGF-β Receptor I\n(ALK5 — kinase)" fillcolor="#81C784"]
    SMAD2         [label="SMAD2 (R-SMAD)" fillcolor="#C8E6C9"]
    SMAD3         [label="SMAD3 (R-SMAD)" fillcolor="#C8E6C9"]
    pSMAD2_3      [label="p-SMAD2/3 (active)" fillcolor="#2E7D32" fontcolor=white]
    SMAD4         [label="SMAD4 (Co-SMAD)" fillcolor="#A5D6A7"]
    SMAD7         [label="SMAD7 (I-SMAD,\nneg. feedback)" fillcolor="#C8E6C9"]
    SMAD_complex  [label="SMAD2/3·SMAD4\nNuclear Complex" fillcolor="#388E3C" fontcolor=white]
    TGFb_targets  [label="TGF-β Target Genes\n(PAI-1, CTGF, COL, MMP)" fillcolor="#A5D6A7"]
    Noncanon_TGFb [label="Non-canonical TGF-β\n(TAK1-p38/JNK)" fillcolor="#C8E6C9"]
    BMP4          [label="BMP4 (TGF-β superfamily\ncounter-regulator)" fillcolor="#E8F5E9"]
  }

  // ─────────────────────────────────────────────────────────────────────
  // CLUSTER 3 — MAPK / ERK Pathway
  // ─────────────────────────────────────────────────────────────────────
  subgraph cluster_mapk {
    label="③ MAPK / ERK Pathway"
    style=filled fillcolor="#E3F2FD" color="#1565C0" fontname="Helvetica-Bold" fontsize=10

    RAS_GTP   [label="RAS-GTP\n(activated)" fillcolor="#90CAF9"]
    RAF       [label="RAF Kinase" fillcolor="#90CAF9"]
    MEK1_2    [label="MEK1/2" fillcolor="#90CAF9"]
    pERK1_2   [label="p-ERK1/2 (↑↑)" fillcolor="#1565C0" fontcolor=white]
    p38_MAPK  [label="p38-MAPK" fillcolor="#90CAF9"]
    JNK       [label="JNK\n(c-Jun N-terminal kinase)" fillcolor="#90CAF9"]
    PI3K      [label="PI3-Kinase" fillcolor="#BBDEFB"]
    AKT       [label="AKT / PKB" fillcolor="#BBDEFB"]
    mTOR_sig  [label="mTOR Signalling" fillcolor="#BBDEFB"]
    ERK_targets[label="ERK Target Genes\n(MMP, CCND1, ELK1)" fillcolor="#90CAF9"]
    TAK1      [label="TAK1 (TGF-β-activated\nkinase 1)" fillcolor="#BBDEFB"]
    ROCK      [label="ROCK1/2\n(Rho-associated kinase)" fillcolor="#BBDEFB"]
  }

  // ─────────────────────────────────────────────────────────────────────
  // CLUSTER 4 — ECM Remodelling & MMP Biology
  // ─────────────────────────────────────────────────────────────────────
  subgraph cluster_ecm {
    label="④ ECM Remodelling"
    style=filled fillcolor="#FCE4EC" color="#880E4F" fontname="Helvetica-Bold" fontsize=10

    MMP2       [label="MMP-2\n(Gelatinase A)" fillcolor="#F48FB1"]
    MMP9       [label="MMP-9\n(Gelatinase B)" fillcolor="#F48FB1"]
    MMP13      [label="MMP-13\n(Collagenase 3)" fillcolor="#F48FB1"]
    TIMP1      [label="TIMP-1\n(inhibitor)" fillcolor="#F8BBD0"]
    TIMP2      [label="TIMP-2\n(inhibitor)" fillcolor="#F8BBD0"]
    Elastin_deg[label="Elastin Degradation (↑)" fillcolor="#E91E63" fontcolor=white]
    Col_frag   [label="Collagen Fragmentation" fillcolor="#F48FB1"]
    Proteoglycan[label="Proteoglycan Loss\n(versican, decorin)" fillcolor="#F8BBD0"]
    Fibronectin [label="Fibronectin\n(remodelled)" fillcolor="#F8BBD0"]
    CTGF       [label="CTGF / CCN2\n(fibrotic mediator)" fillcolor="#F48FB1"]
    PAI1       [label="PAI-1\n(plasminogen act. inh.)" fillcolor="#F8BBD0"]
    Fibrosis   [label="Medial Fibrosis\n(cumulative)" fillcolor="#C2185B" fontcolor=white]
  }

  // ─────────────────────────────────────────────────────────────────────
  // CLUSTER 5 — Vascular Smooth Muscle Cell Biology
  // ─────────────────────────────────────────────────────────────────────
  subgraph cluster_vsmc {
    label="⑤ Vascular Smooth Muscle Cells"
    style=filled fillcolor="#F3E5F5" color="#4A148C" fontname="Helvetica-Bold" fontsize=10

    VSMC_diff   [label="VSMC Differentiation\n(contractile phenotype)" fillcolor="#CE93D8"]
    VSMC_synth  [label="VSMC Synthetic\nPhenotype Switch" fillcolor="#AB47BC" fontcolor=white]
    VSMC_prolif [label="VSMC Proliferation (↑)" fillcolor="#CE93D8"]
    VSMC_apopt  [label="VSMC Apoptosis (↑↑)" fillcolor="#9C27B0" fontcolor=white]
    Oxidative   [label="Oxidative Stress\n(ROS, NOX4)" fillcolor="#CE93D8"]
    NADPH_Ox    [label="NADPH Oxidase 4\n(NOX4)" fillcolor="#E1BEE7"]
    NF_kB       [label="NF-κB Pathway\n(pro-inflammatory)" fillcolor="#CE93D8"]
    Macrophage  [label="Macrophage Infiltration\n(media)" fillcolor="#E1BEE7"]
    Inflammation[label="Medial Inflammation" fillcolor="#AB47BC" fontcolor=white]
    Angiotensin2[label="Angiotensin II\n(local RAAS)" fillcolor="#E1BEE7"]
    AT1R        [label="AT1 Receptor\n(on VSMC)" fillcolor="#CE93D8"]
  }

  // ─────────────────────────────────────────────────────────────────────
  // CLUSTER 6 — Aortic Pathology
  // ─────────────────────────────────────────────────────────────────────
  subgraph cluster_aorta {
    label="⑥ Aortic Pathology"
    style=filled fillcolor="#EFEBE9" color="#3E2723" fontname="Helvetica-Bold" fontsize=10

    Media_degen    [label="Aortic Media\nDegeneration" fillcolor="#BCAAA4"]
    Elastic_frag   [label="Elastic Lamellae\nFragmentation" fillcolor="#A1887F"]
    Cystic_necrosis[label="Medial Cystic Necrosis\n(mucoid pooling)" fillcolor="#8D6E63" fontcolor=white]
    Aortic_root    [label="Aortic Root\n(main site of dilation)" fillcolor="#5D4037" fontcolor=white]
    Valsalva_sinus [label="Sinuses of Valsalva" fillcolor="#795548" fontcolor=white]
    STJ            [label="Sinotubular Junction\n(STJ)" fillcolor="#8D6E63"]
    Ascending_Ao   [label="Ascending Aorta" fillcolor="#BCAAA4"]
    Aortic_arch    [label="Aortic Arch" fillcolor="#BCAAA4"]
    Descend_Ao     [label="Descending Aorta" fillcolor="#D7CCC8"]
    Ao_diameter    [label="Aortic Root Diameter (↑)\n[Z-score / mm]" fillcolor="#5D4037" fontcolor=white]
    Wall_stress    [label="Aortic Wall Stress (↑)\n[Laplace: T=Pr/2h]" fillcolor="#6D4C41" fontcolor=white]
    Wall_thickness [label="Aortic Wall Thickness\n(initially normal, ↓ later)" fillcolor="#BCAAA4"]
    Ao_compliance  [label="Aortic Compliance (↓)\n[stiffness ↑]" fillcolor="#795548" fontcolor=white]
  }

  // ─────────────────────────────────────────────────────────────────────
  // CLUSTER 7 — Cardiac Manifestations & Haemodynamics
  // ─────────────────────────────────────────────────────────────────────
  subgraph cluster_cardiac {
    label="⑦ Cardiac Manifestations & Haemodynamics"
    style=filled fillcolor="#FFEBEE" color="#B71C1C" fontname="Helvetica-Bold" fontsize=10

    AR             [label="Aortic Regurgitation\n(AR grade 0→4)" fillcolor="#EF9A9A"]
    MVP            [label="Mitral Valve Prolapse\n(MVP)" fillcolor="#EF9A9A"]
    MR             [label="Mitral Regurgitation\n(MR)" fillcolor="#EF9A9A"]
    TV_abnorm      [label="Tricuspid Valve\nAbnormality" fillcolor="#FFCDD2"]
    LV_vol_overload[label="LV Volume Overload" fillcolor="#E57373"]
    LV_dilation    [label="LV Dilation" fillcolor="#E53935" fontcolor=white]
    LV_hypertrophy [label="LV Eccentric\nHypertrophy" fillcolor="#EF9A9A"]
    Heart_failure  [label="Heart Failure\n(late stage)" fillcolor="#B71C1C" fontcolor=white]
    Dissect_A      [label="Type A Aortic Dissection\n(Stanford — surgical emergency)" fillcolor="#B71C1C" fontcolor=white]
    Dissect_B      [label="Type B Aortic Dissection\n(medical / endovascular)" fillcolor="#C62828" fontcolor=white]
    Ao_rupture     [label="Aortic Rupture\n(catastrophic)" fillcolor="#7F0000" fontcolor=white]
    Bradyarrhythmia[label="Bradyarrhythmia\n(drug AE)" fillcolor="#FFCDD2"]
  }

  // ─────────────────────────────────────────────────────────────────────
  // CLUSTER 8 — Haemodynamic Parameters
  // ─────────────────────────────────────────────────────────────────────
  subgraph cluster_hemo {
    label="⑧ Haemodynamic Parameters"
    style=filled fillcolor="#E0F2F1" color="#004D40" fontname="Helvetica-Bold" fontsize=10

    HR             [label="Heart Rate (HR)\n[bpm]" fillcolor="#80CBC4"]
    SBP            [label="Systolic BP\n[mmHg]" fillcolor="#80CBC4"]
    DBP            [label="Diastolic BP\n[mmHg]" fillcolor="#80CBC4"]
    dPdt_max       [label="dP/dt_max (↑ → risk)\n[mmHg/s]" fillcolor="#00897B" fontcolor=white]
    PWV            [label="Pulse Wave Velocity\n[m/s]" fillcolor="#80CBC4"]
    MAP            [label="Mean Arterial Pressure\n[mmHg]" fillcolor="#80CBC4"]
    SV             [label="Stroke Volume [mL]" fillcolor="#B2DFDB"]
    CO             [label="Cardiac Output [L/min]" fillcolor="#B2DFDB"]
    SVR            [label="Systemic Vascular\nResistance" fillcolor="#B2DFDB"]
    PP             [label="Pulse Pressure [mmHg]\n(dilation marker)" fillcolor="#80CBC4"]
  }

  // ─────────────────────────────────────────────────────────────────────
  // CLUSTER 9 — Skeletal System
  // ─────────────────────────────────────────────────────────────────────
  subgraph cluster_skeletal {
    label="⑨ Skeletal System"
    style=filled fillcolor="#E8EAF6" color="#283593" fontname="Helvetica-Bold" fontsize=10

    Tall_stature   [label="Tall Stature\n(disproportionate)" fillcolor="#9FA8DA"]
    Dolico         [label="Dolichostenomelia\n(long, slender limbs)" fillcolor="#9FA8DA"]
    Arm_span       [label="Arm Span > Height\n(>1.05 ratio)" fillcolor="#7986CB"]
    UL_ratio       [label="Upper/Lower Segment\nRatio (<0.85)" fillcolor="#7986CB"]
    Arachno        [label="Arachnodactyly\n(Walker-Murdoch+)" fillcolor="#9FA8DA"]
    Steinberg_sign [label="Steinberg Sign\n(thumb protrusion)" fillcolor="#C5CAE9"]
    Pectus_exc     [label="Pectus Excavatum\n(concave chest)" fillcolor="#9FA8DA"]
    Pectus_car     [label="Pectus Carinatum\n(convex chest)" fillcolor="#9FA8DA"]
    Scoliosis      [label="Scoliosis\n(≥20 degrees)" fillcolor="#7986CB"]
    Kyphosis       [label="Kyphosis / Spondylolisthesis" fillcolor="#C5CAE9"]
    Pes_planus     [label="Pes Planus\n(flat foot)" fillcolor="#9FA8DA"]
    Protrusio_ac   [label="Protrusio Acetabuli" fillcolor="#C5CAE9"]
    Hypermobility  [label="Joint Hypermobility\n(Beighton score ≥5)" fillcolor="#9FA8DA"]
    Reduced_elbow  [label="Reduced Elbow Extension\n(<170°)" fillcolor="#C5CAE9"]
  }

  // ─────────────────────────────────────────────────────────────────────
  // CLUSTER 10 — Ocular System
  // ─────────────────────────────────────────────────────────────────────
  subgraph cluster_ocular {
    label="⑩ Ocular System"
    style=filled fillcolor="#FFFDE7" color="#F57F17" fontname="Helvetica-Bold" fontsize=10

    Ectopia_lentis [label="Ectopia Lentis\n(lens dislocation, 60-70%)" fillcolor="#FFF176"]
    Zonular_fibers [label="Zonular Fibers\n(ciliary, FBN1-rich, disrupted)" fillcolor="#FFF9C4"]
    Myopia         [label="Axial Myopia\n(>6 diopters MFS risk)" fillcolor="#FFF176"]
    Astigmatism    [label="Astigmatism" fillcolor="#FFF9C4"]
    Retinal_detach [label="Retinal Detachment\n(vitreous detachment risk)" fillcolor="#F9A825" fontcolor=white]
    Corneal_flat   [label="Corneal Flattening" fillcolor="#FFF9C4"]
    Iris_hypoplasia[label="Iris Hypoplasia / Miosis" fillcolor="#FFF9C4"]
    Glaucoma       [label="Glaucoma\n(secondary)" fillcolor="#F57F17" fontcolor=white]
    Strabismus     [label="Strabismus" fillcolor="#FFF9C4"]
    Cataract       [label="Early Cataract\n(posterior subcapsular)" fillcolor="#FFF9C4"]
  }

  // ─────────────────────────────────────────────────────────────────────
  // CLUSTER 11 — Other Systemic Features
  // ─────────────────────────────────────────────────────────────────────
  subgraph cluster_other {
    label="⑪ Other Systemic Features"
    style=filled fillcolor="#F1F8E9" color="#33691E" fontname="Helvetica-Bold" fontsize=10

    Dural_ectasia  [label="Dural Ectasia\n(lumbosacral, 60-90%)" fillcolor="#AED581"]
    Nerve_root     [label="Nerve Root Sleeve\nCysts" fillcolor="#C5E1A5"]
    Meningocele    [label="Anterior Meningocele\n(rare)" fillcolor="#DCEDC8"]
    Pneumothorax   [label="Spontaneous Pneumothorax\n(apical bullae)" fillcolor="#AED581"]
    Emphysema_like [label="Emphysema-like Changes\n(upper lobes)" fillcolor="#C5E1A5"]
    Striae         [label="Striae Distensae\n(skin, shoulder/thigh)" fillcolor="#AED581"]
    Hernia_ab      [label="Abdominal / Inguinal\nHernia" fillcolor="#C5E1A5"]
    Sleep_apnea    [label="Sleep Apnoea\n(craniofacial + airway)" fillcolor="#AED581"]
    Facial         [label="Facial Features\n(dolichocephaly, malar flat)" fillcolor="#C5E1A5"]
    High_arch      [label="High-Arched Palate\n(dental crowding)" fillcolor="#DCEDC8"]
  }

  // ─────────────────────────────────────────────────────────────────────
  // CLUSTER 12 — Drug PK
  // ─────────────────────────────────────────────────────────────────────
  subgraph cluster_pk {
    label="⑫ Drug Pharmacokinetics"
    style=filled fillcolor="#E8F5E9" color="#1B5E20" fontname="Helvetica-Bold" fontsize=10

    Atenolol_dose  [label="Atenolol 50-100mg QD\n(β1-selective blocker)" fillcolor="#A5D6A7" shape=parallelogram]
    Atenolol_GI    [label="Atenolol GI Absorption\n(F≈50%)" fillcolor="#C8E6C9"]
    Atenolol_C1    [label="Atenolol Central (C1)\nVc=67L, CL=10.8L/h" fillcolor="#81C784"]
    Atenolol_C2    [label="Atenolol Peripheral (C2)\nVp=64L, Q=15L/h" fillcolor="#81C784"]
    Propranolol_dose[label="Propranolol 40-80mg BID\n(non-selective β-blocker)" fillcolor="#A5D6A7" shape=parallelogram]
    Propranolol_C1 [label="Propranolol Central (C1)\nF=36%, CL=50L/h" fillcolor="#81C784"]
    Losartan_dose  [label="Losartan 50-100mg QD\n(ARB)" fillcolor="#A5D6A7" shape=parallelogram]
    Losartan_GI    [label="Losartan GI\n(F≈33%)" fillcolor="#C8E6C9"]
    Losartan_C1    [label="Losartan Central (C1)\nCL=55L/h, Vc=34L" fillcolor="#81C784"]
    EXP3174        [label="EXP-3174\n(active metabolite,\nIC50=4nM AT1R)" fillcolor="#388E3C" fontcolor=white]
    Perindopril    [label="Perindopril 4-8mg QD\n(ACE inhibitor)" fillcolor="#A5D6A7" shape=parallelogram]
    Irbesartan     [label="Irbesartan 150-300mg QD\n(ARB — AIMS trial)" fillcolor="#A5D6A7" shape=parallelogram]
    Amlodipine     [label="Amlodipine 5-10mg QD\n(CCB — caution MFS)" fillcolor="#FFCDD2" shape=parallelogram]
  }

  // ─────────────────────────────────────────────────────────────────────
  // CLUSTER 13 — Drug PD & Mechanisms
  // ─────────────────────────────────────────────────────────────────────
  subgraph cluster_pd {
    label="⑬ Drug Pharmacodynamics & Mechanisms"
    style=filled fillcolor="#EDE7F6" color="#4527A0" fontname="Helvetica-Bold" fontsize=10

    Beta1_block    [label="β1 Receptor Blockade\n(negative chrono/inotropy)" fillcolor="#B39DDB"]
    Neg_chrono     [label="Negative Chronotropy\n(HR↓)" fillcolor="#9575CD"]
    Neg_inot       [label="Negative Inotropy\n(contractility↓)" fillcolor="#9575CD"]
    dPdt_red       [label="dP/dt_max Reduction\n(aortic stress↓)" fillcolor="#7E57C2" fontcolor=white]
    AT1_block      [label="AT1 Receptor Blockade\n(losartan/EXP-3174)" fillcolor="#B39DDB"]
    RAAS_inhib     [label="RAAS Inhibition\n(Ang II signalling↓)" fillcolor="#9575CD"]
    TGFb_inhib     [label="TGF-β Signalling\nInhibition (via ARB)" fillcolor="#7E57C2" fontcolor=white]
    pSMAD_red      [label="p-SMAD2/3 Reduction" fillcolor="#9575CD"]
    pERK_red       [label="p-ERK1/2 Reduction" fillcolor="#9575CD"]
    MMP_inhib      [label="MMP-2/9 Reduction\n(ARB+β-blocker)" fillcolor="#B39DDB"]
    Wall_stress_red[label="Aortic Wall Stress\nReduction (combined)" fillcolor="#7E57C2" fontcolor=white]
    Prophylactic_sx[label="Prophylactic Surgery\n(≥50mm or rapid growth)" fillcolor="#4527A0" fontcolor=white shape=diamond]
  }

  // ─────────────────────────────────────────────────────────────────────
  // CLUSTER 14 — Clinical Endpoints & Biomarkers
  // ─────────────────────────────────────────────────────────────────────
  subgraph cluster_endpoints {
    label="⑭ Clinical Endpoints & Biomarkers"
    style=filled fillcolor="#FFF8E1" color="#E65100" fontname="Helvetica-Bold" fontsize=10

    Ao_Zscore      [label="Aortic Root Z-score\n(key paediatric metric)" fillcolor="#FFE082"]
    Ao_abs_mm      [label="Aortic Root Diameter\n[absolute, mm]" fillcolor="#FFE082"]
    Annual_growth  [label="Annual Dilation Rate\n[mm/year; target <0.5]" fillcolor="#FFD54F"]
    Surg_thresh    [label="Surgical Threshold\n(≥50mm; ≥45mm + risk)" fillcolor="#FF6F00" fontcolor=white]
    AR_grade       [label="AR Grade (0-4)\n(echocardiography)" fillcolor="#FFE082"]
    Dissection_risk[label="Dissection Risk\n(probability/year)" fillcolor="#E65100" fontcolor=white]
    Ghent_score    [label="Revised Ghent\nNosology Score" fillcolor="#FFE082"]
    Systemic_score [label="Systemic Score\n(skeletal+ocular+dura)" fillcolor="#FFE082"]
    TGFb_plasma    [label="Plasma TGF-β1/2\n(biomarker, ↑ MFS)" fillcolor="#FFD54F"]
    MMP9_plasma    [label="Plasma MMP-9\n(biomarker)" fillcolor="#FFD54F"]
    Fibrillin_frag [label="Fibrillin-1 Fragments\n(neopeptides)" fillcolor="#FFD54F"]
    NT_proBNP      [label="NT-proBNP\n(cardiac stress marker)" fillcolor="#FFD54F"]
    LVEF           [label="LVEF (%)\n(echo endpoint)" fillcolor="#FFE082"]
    Exercise_tol   [label="Exercise Tolerance\n(6MWT / VO₂max)" fillcolor="#FFE082"]
    QOL            [label="QoL Score\n(SF-36 / EQ-5D)" fillcolor="#FFE082"]
  }

  // ═══════════════════════════════════════════════════════════════════
  // EDGES — Genetic to Molecular
  // ═══════════════════════════════════════════════════════════════════
  FBN1_gene        -> FBN1_mut         [label="germline mutation\n(3000+ variants)" color="#E65100"]
  FBN1_mut         -> FBN1_haplo       [color="#E65100"]
  FBN1_mut         -> FBN1_dom_neg     [color="#E65100"]
  FBN1_haplo       -> FBN1_protein     [label="50% normal protein" color="#E65100"]
  FBN1_dom_neg     -> FBN1_protein     [label="disrupted assembly" color="#E65100"]
  FBN1_protein     -> Microfibril_net  [label="↓ microfibril\nintegrity" color="#E65100"]
  Microfibril_net  -> ECM_scaffold     [color="#8D6E63"]
  FBN1_protein     -> LTBP1            [label="sequesters via\nfibrillin" style=dashed color="#4CAF50"]
  FBN1_protein     -> LTBP3            [style=dashed color="#4CAF50"]
  LTBP1            -> LLCB             [color="#4CAF50"]
  LTBP3            -> LLCB             [color="#4CAF50"]
  LAP              -> LLCB             [color="#4CAF50"]

  // Microfibril disruption -> TGF-β release
  Microfibril_net  -> LTGF_complex     [label="↓ sequestration → release" color="#2E7D32" style=dashed]
  LLCB             -> LTGF_complex     [color="#4CAF50"]
  FBN2             -> Microfibril_net  [label="partial rescue" color="#A5D6A7" style=dashed]

  // TGF-β canonical SMAD signalling
  LTGF_complex     -> Free_TGFb1       [label="proteolytic activation\n(MMPs, plasmin)" color="#2E7D32"]
  LTGF_complex     -> Free_TGFb2       [color="#2E7D32"]
  Free_TGFb1       -> TGFBR2           [color="#2E7D32"]
  Free_TGFb2       -> TGFBR2           [color="#2E7D32"]
  TGFBR2           -> TGFBR1           [label="trans-phosphorylation" color="#2E7D32"]
  TGFBR1           -> SMAD2            [label="phosphorylation" color="#2E7D32"]
  TGFBR1           -> SMAD3            [label="phosphorylation" color="#2E7D32"]
  SMAD2            -> pSMAD2_3         [color="#1B5E20"]
  SMAD3            -> pSMAD2_3         [color="#1B5E20"]
  pSMAD2_3         -> SMAD_complex     [label="+ SMAD4" color="#1B5E20"]
  SMAD4            -> SMAD_complex     [color="#1B5E20"]
  SMAD_complex     -> TGFb_targets     [label="nuclear transcription" color="#1B5E20"]
  SMAD7            -> TGFBR1           [label="negative feedback\n(ubiquitin-mediated)" style=dashed color="#F44336" arrowhead=tee]

  // Non-canonical TGF-β
  TGFBR1           -> TAK1             [color="#388E3C"]
  TAK1             -> p38_MAPK         [color="#388E3C"]
  TAK1             -> JNK              [color="#388E3C"]
  TGFBR1           -> Noncanon_TGFb   [color="#388E3C"]
  BMP4             -> SMAD2            [label="counter-reg" style=dashed color="#9E9E9E" arrowhead=tee]

  // MAPK/ERK from TGF-βR cross-talk
  TGFBR2           -> RAS_GTP          [label="Shc adaptor" color="#1565C0"]
  RAS_GTP          -> RAF              [color="#1565C0"]
  RAF              -> MEK1_2           [color="#1565C0"]
  MEK1_2           -> pERK1_2          [color="#1565C0"]
  pERK1_2          -> ERK_targets      [color="#1565C0"]
  p38_MAPK         -> ERK_targets      [color="#5C6BC0" style=dashed]
  JNK              -> ERK_targets      [color="#5C6BC0" style=dashed]
  PI3K             -> AKT              [color="#7986CB"]
  AKT              -> mTOR_sig         [color="#7986CB"]
  TGFBR1           -> PI3K             [style=dashed color="#7986CB"]
  ROCK             -> VSMC_synth       [color="#9C27B0"]

  // ECM remodelling
  TGFb_targets     -> MMP2             [label="TGF-β→MMP2↑" color="#880E4F"]
  TGFb_targets     -> MMP9             [color="#880E4F"]
  TGFb_targets     -> MMP13            [color="#880E4F"]
  TGFb_targets     -> CTGF             [color="#880E4F"]
  TGFb_targets     -> PAI1             [color="#880E4F"]
  ERK_targets      -> MMP9             [color="#1565C0"]
  MMP2             -> Elastin_deg      [color="#E91E63"]
  MMP9             -> Elastin_deg      [color="#E91E63"]
  MMP2             -> Col_frag         [color="#880E4F"]
  MMP13            -> Col_frag         [color="#880E4F"]
  TIMP1            -> MMP9             [label="inhibit" arrowhead=tee style=dashed color="#4CAF50"]
  TIMP2            -> MMP2             [label="inhibit" arrowhead=tee style=dashed color="#4CAF50"]
  Elastin_deg      -> Fibrosis         [color="#C2185B"]
  Col_frag         -> Fibrosis         [color="#C2185B"]
  Proteoglycan     -> Fibrosis         [color="#C2185B"]
  CTGF             -> Fibrosis         [color="#C2185B"]

  // VSMC biology
  pERK1_2          -> VSMC_prolif      [color="#9C27B0"]
  pSMAD2_3         -> VSMC_apopt       [label="pro-apoptotic" color="#7B1FA2"]
  VSMC_diff        -> VSMC_synth       [label="phenotype switch\n(TGF-β driven)" color="#9C27B0"]
  NADPH_Ox         -> Oxidative        [color="#AB47BC"]
  Angiotensin2     -> AT1R             [color="#AB47BC"]
  AT1R             -> NADPH_Ox         [color="#7B1FA2"]
  AT1R             -> NF_kB            [color="#7B1FA2"]
  AT1R             -> Free_TGFb1       [label="Ang-II potentiates\nTGF-β release" color="#7B1FA2"]
  NF_kB            -> Macrophage       [color="#9C27B0"]
  NF_kB            -> Inflammation     [color="#9C27B0"]
  Macrophage       -> MMP9             [color="#880E4F"]
  Oxidative        -> VSMC_apopt       [color="#9C27B0"]
  Inflammation     -> VSMC_apopt       [color="#9C27B0"]
  VSMC_apopt       -> Media_degen      [color="#5D4037"]

  // Aortic pathology
  Fibrosis         -> Media_degen      [color="#5D4037"]
  Elastin_deg      -> Elastic_frag     [color="#A1887F"]
  Elastic_frag     -> Cystic_necrosis  [color="#8D6E63"]
  Media_degen      -> Aortic_root      [label="preferential\nroot dilation" color="#5D4037"]
  Media_degen      -> Valsalva_sinus   [color="#5D4037"]
  Media_degen      -> STJ              [color="#8D6E63"]
  Media_degen      -> Ascending_Ao     [color="#8D6E63"]
  Media_degen      -> Aortic_arch      [color="#8D6E63" style=dashed]
  Media_degen      -> Descend_Ao       [color="#BCAAA4" style=dashed]
  Aortic_root      -> Ao_diameter      [color="#5D4037"]
  Ao_diameter      -> Wall_stress      [label="Laplace: T=Pr/2h" color="#6D4C41"]
  Wall_stress      -> Ao_compliance    [label="stiffness↑" color="#795548"]
  Wall_stress      -> Dissect_A        [label="critical stress\n→ intimal tear" color="#B71C1C"]
  Wall_stress      -> Dissect_B        [color="#C62828"]
  Ao_compliance    -> PWV              [label="PWV↑ as stiff↑" color="#004D40"]

  // Cardiac
  Aortic_root      -> AR               [label="root dilation\n→ leaflet coaptation↓" color="#B71C1C"]
  AR               -> LV_vol_overload  [color="#E53935"]
  MVP              -> MR               [color="#EF9A9A"]
  MR               -> LV_vol_overload  [color="#EF9A9A"]
  LV_vol_overload  -> LV_dilation      [color="#E53935"]
  LV_dilation      -> LV_hypertrophy   [label="eccentric" color="#EF9A9A"]
  LV_dilation      -> Heart_failure    [label="decompensation" color="#B71C1C"]
  Dissect_A        -> Ao_rupture       [label="haemopericardium\n→ tamponade" color="#7F0000"]

  // Haemodynamics
  HR               -> dPdt_max         [color="#00897B"]
  SBP              -> dPdt_max         [color="#00897B"]
  MAP              -> Wall_stress      [color="#00897B"]
  SBP              -> Wall_stress      [color="#006064"]
  CO               -> SBP              [color="#004D40" style=dashed]
  SVR              -> MAP              [color="#004D40"]

  // Skeletal pathogenesis (FBN1 → bone/joint)
  FBN1_protein     -> Tall_stature     [label="GH/IGF axis\n& periosteal signalling" color="#283593" style=dashed]
  ECM_scaffold     -> Scoliosis        [label="paraspinal ECM" color="#5C6BC0"]
  ECM_scaffold     -> Hypermobility    [label="ligament laxity" color="#5C6BC0"]
  Microfibril_net  -> Arachno          [style=dashed color="#283593"]
  Microfibril_net  -> Pectus_exc       [style=dashed color="#283593"]

  // Ocular pathogenesis
  FBN1_protein     -> Zonular_fibers   [label="FBN1 in zonules\n→ ectopia lentis" color="#F57F17"]
  Zonular_fibers   -> Ectopia_lentis   [color="#F57F17"]
  Zonular_fibers   -> Myopia           [color="#F9A825" style=dashed]
  Ectopia_lentis   -> Glaucoma         [label="mechanical IOP↑" color="#E65100"]
  Myopia           -> Retinal_detach   [color="#F57F17" style=dashed]

  // Dural & other
  ECM_scaffold     -> Dural_ectasia    [color="#558B2F"]
  Dural_ectasia    -> Nerve_root       [color="#558B2F"]
  ECM_scaffold     -> Pneumothorax     [color="#558B2F" style=dashed]
  ECM_scaffold     -> Hernia_ab        [color="#558B2F" style=dashed]
  FBN1_protein     -> Striae           [style=dashed color="#A5D6A7"]

  // ═══════════════════════════════════════════════════════════════════
  // EDGES — Drug PK
  // ═══════════════════════════════════════════════════════════════════
  Atenolol_dose    -> Atenolol_GI      [color="#1B5E20"]
  Atenolol_GI      -> Atenolol_C1      [color="#1B5E20"]
  Atenolol_C1      -> Atenolol_C2      [label="Q=15L/h" color="#1B5E20"]
  Propranolol_dose -> Propranolol_C1   [label="F=36%,\nCYP1A2/2D6" color="#1B5E20"]
  Losartan_dose    -> Losartan_GI      [color="#1B5E20"]
  Losartan_GI      -> Losartan_C1      [label="F=33%" color="#1B5E20"]
  Losartan_C1      -> EXP3174          [label="CYP2C9 (15%)\n→ active met." color="#2E7D32"]

  // ═══════════════════════════════════════════════════════════════════
  // EDGES — Drug PD
  // ═══════════════════════════════════════════════════════════════════
  Atenolol_C1      -> Beta1_block      [label="Ki≈0.5nM β1R" color="#4527A0"]
  Propranolol_C1   -> Beta1_block      [label="non-selective\nβR block" color="#4527A0"]
  Beta1_block      -> Neg_chrono       [color="#7E57C2"]
  Beta1_block      -> Neg_inot         [color="#7E57C2"]
  Neg_chrono       -> HR               [label="HR↓ target\n<70 bpm" arrowhead=tee color="#4527A0"]
  Neg_inot         -> dPdt_max         [label="dP/dt_max↓" arrowhead=tee color="#4527A0"]
  dPdt_max         -> Wall_stress      [arrowhead=tee color="#4527A0"]
  dPdt_red         -> Ao_diameter      [label="slows growth\n↓ rate" arrowhead=tee color="#4527A0"]

  EXP3174          -> AT1_block        [label="high-affinity\n(IC50=4nM)" color="#7E57C2"]
  Perindopril      -> RAAS_inhib       [color="#7E57C2"]
  Irbesartan       -> AT1_block        [color="#7E57C2"]
  AT1_block        -> RAAS_inhib       [color="#6A1B9A"]
  RAAS_inhib       -> Angiotensin2     [arrowhead=tee color="#4527A0"]
  RAAS_inhib       -> TGFb_inhib       [label="Ang-II/TGF-β\ncross-talk" color="#6A1B9A"]
  TGFb_inhib       -> pSMAD2_3         [arrowhead=tee color="#4527A0"]
  TGFb_inhib       -> pERK1_2          [arrowhead=tee color="#4527A0"]
  pSMAD_red        -> MMP2             [arrowhead=tee color="#4527A0"]
  pERK_red         -> MMP9             [arrowhead=tee color="#4527A0"]
  MMP_inhib        -> Elastin_deg      [arrowhead=tee color="#4527A0"]
  Wall_stress_red  -> Annual_growth    [arrowhead=tee label="combined\ntherapy" color="#7E57C2"]
  RAAS_inhib       -> SBP              [arrowhead=tee color="#4527A0"]
  RAAS_inhib       -> MAP              [arrowhead=tee color="#4527A0"]

  // ═══════════════════════════════════════════════════════════════════
  // EDGES — Clinical Endpoints
  // ═══════════════════════════════════════════════════════════════════
  Ao_diameter      -> Ao_Zscore        [color="#E65100"]
  Ao_diameter      -> Ao_abs_mm        [color="#E65100"]
  Ao_diameter      -> Annual_growth    [label="Δ/year" color="#E65100"]
  Annual_growth    -> Surg_thresh      [label="≥50mm triggers\nconsultation" color="#E65100"]
  AR               -> AR_grade         [color="#E65100"]
  AR_grade         -> LV_dilation      [color="#E53935"]
  Dissect_A        -> Dissection_risk  [color="#B71C1C"]
  Dissect_B        -> Dissection_risk  [color="#C62828"]
  Ghent_score      -> Systemic_score   [color="#E65100"]
  Free_TGFb1       -> TGFb_plasma      [color="#757575"]
  Free_TGFb2       -> TGFb_plasma      [color="#757575"]
  MMP9             -> MMP9_plasma      [color="#757575"]
  FBN1_protein     -> Fibrillin_frag   [label="proteolytic\ncleaving" color="#757575"]
  LV_dilation      -> NT_proBNP        [label="myocardial\nstress" color="#757575"]
  AR               -> LVEF             [color="#757575"]
  Heart_failure    -> QOL              [color="#757575"]
  Scoliosis        -> QOL              [color="#757575"]
  Dural_ectasia    -> QOL              [color="#558B2F"]
  Surg_thresh      -> Prophylactic_sx  [label="elective repair\n(Bentall / David)" color="#4527A0"]
  Prophylactic_sx  -> Dissection_risk  [arrowhead=tee label="surgery\nreduces risk" color="#4527A0"]
