digraph BehcetDiseaseQSP {
  graph [rankdir=LR, bgcolor="#1a1a2e", fontname="Helvetica",
         fontcolor="white", fontsize=12,
         label="Behcet's Disease (BD) — QSP Mechanistic Map v1.0\n(HLA-B51 · Neutrophil Hyperactivation · Th1/Th17 · Vasculitis · Multi-organ)\n2026-06-17",
         labelloc=t, labeljust=c, splines=true, overlap=false];
  node [shape=box, style="filled,rounded", fontname="Helvetica", fontsize=8,
        fontcolor="white", margin="0.15,0.08"];
  edge [fontname="Helvetica", fontsize=7, color="#888888", arrowsize=0.7];

  /* ========== SUBGRAPH 1: Genetic & Environmental Triggers ========== */
  subgraph cluster_genetics {
    label="Genetic & Environmental Factors";
    style=filled; color="#0d3b66"; fontcolor="white"; penwidth=2;

    HLAB51     [label="HLA-B51\n(Primary Risk Allele)",         fillcolor="#e63946"];
    ERAP1      [label="ERAP1 Polymorphism\n(Antigen Processing)", fillcolor="#e63946"];
    IL10_poly  [label="IL-10 Gene\nPolymorphism (-1082G/A)",    fillcolor="#e63946"];
    TNFSF4     [label="TNFSF4/OX40L\nVariants",                fillcolor="#c1121f"];
    STAT4_gene [label="STAT4 / IRF8\nVariants",                 fillcolor="#c1121f"];
    CCR1_gene  [label="CCR1/CCR3\nHaplotype",                   fillcolor="#c1121f"];
    microbiome [label="Gut Microbiome\nDysbiosis",              fillcolor="#457b9d"];
    oral_micro [label="Oral Microbiome\nAlterations (S. sanguinis)", fillcolor="#457b9d"];
    strep      [label="Streptococcus spp.\nEpitope Mimicry",    fillcolor="#457b9d"];
    HSP60      [label="Heat Shock Protein 60/65\nMolecular Mimicry", fillcolor="#a8dadc", fontcolor="black"];
    HSP70      [label="Heat Shock Protein 70\nCross-reactive Ag", fillcolor="#a8dadc", fontcolor="black"];
    env_stress [label="Environmental Stress /\nTrauma / Infection", fillcolor="#457b9d"];
    geography  [label="Silk Road Geography\n(Middle East / East Asia)", fillcolor="#1d3557"];
  }

  /* ========== SUBGRAPH 2: Innate Immunity ========== */
  subgraph cluster_innate {
    label="Innate Immunity";
    style=filled; color="#1b4332"; fontcolor="white"; penwidth=2;

    neutrophil [label="Neutrophils\n(Hyperactivated)",           fillcolor="#52b788"];
    NET        [label="NETs\n(Neutrophil Extracellular Traps)",  fillcolor="#52b788"];
    ROS        [label="Reactive Oxygen\nSpecies (ROS)",          fillcolor="#40916c"];
    MPO        [label="Myeloperoxidase\n(MPO)",                  fillcolor="#40916c"];
    NE         [label="Neutrophil Elastase\n(NE)",               fillcolor="#40916c"];
    monocyte   [label="Monocytes\n(Classical CD14++)",           fillcolor="#74c69d", fontcolor="black"];
    macrophage [label="Macrophages\nM1 Polarized",               fillcolor="#74c69d", fontcolor="black"];
    DC         [label="Myeloid Dendritic\nCells (mDC)",          fillcolor="#74c69d", fontcolor="black"];
    NK         [label="NK Cells\n(CD56bright)",                  fillcolor="#95d5b2", fontcolor="black"];
    mast       [label="Mast Cells\n(Degranulation)",             fillcolor="#95d5b2", fontcolor="black"];
    TLR2       [label="TLR2 / TLR4\nSignaling",                  fillcolor="#b7e4c7", fontcolor="black"];
    NLRP3      [label="NLRP3\nInflammasome",                     fillcolor="#b7e4c7", fontcolor="black"];
    casp1      [label="Caspase-1\nActivation",                   fillcolor="#d8f3dc", fontcolor="black"];
    NOD2       [label="NOD1/2\nSignaling",                       fillcolor="#d8f3dc", fontcolor="black"];
    ER_stress  [label="ER Stress\n(UPR Activation)",             fillcolor="#d8f3dc", fontcolor="black"];
    PAMP       [label="PAMPs / DAMPs\n(Pathogen/Danger Signals)", fillcolor="#1b4332"];
    cGAS_STING [label="cGAS-STING\nInnate DNA Sensing",          fillcolor="#b7e4c7", fontcolor="black"];
  }

  /* ========== SUBGRAPH 3: Adaptive Immunity ========== */
  subgraph cluster_adaptive {
    label="Adaptive Immunity";
    style=filled; color="#3d1c02"; fontcolor="white"; penwidth=2;

    Th1        [label="Th1 Cells\n(CD4+ IFN-γ+)",              fillcolor="#c77dff"];
    Th17       [label="Th17 Cells\n(CD4+ IL-17A+)",            fillcolor="#c77dff"];
    Th22       [label="Th22 Cells\n(CD4+ IL-22+)",             fillcolor="#c77dff"];
    CD8T       [label="CD8+ Cytotoxic\nT Cells (CTL)",         fillcolor="#9d4edd"];
    Treg       [label="Regulatory T Cells\n(Treg, FoxP3+)",    fillcolor="#9d4edd"];
    Tfh        [label="Follicular Helper\nT Cells (Tfh)",      fillcolor="#9d4edd"];
    Bnaive     [label="Naïve B Cells",                          fillcolor="#7b2d8b"];
    Bmemory    [label="Memory B Cells",                         fillcolor="#7b2d8b"];
    plasma     [label="Plasma Cells\n(Ab Secretion)",          fillcolor="#6a0572"];
    IgG_ab     [label="IgG Antibodies\n(Anti-endothelial AECA)", fillcolor="#6a0572"];
    IgA_ab     [label="IgA Antibodies\n(Mucosal Immunity)",    fillcolor="#6a0572"];
    gdT        [label="γδ T Cells\n(IL-17A producing)",        fillcolor="#9d4edd"];
    NKT        [label="NKT Cells\n(CD1d restricted)",          fillcolor="#9d4edd"];
    iLC3       [label="ILC3\n(IL-22 / IL-17 producing)",       fillcolor="#7b2d8b"];
  }

  /* ========== SUBGRAPH 4: Cytokine Network ========== */
  subgraph cluster_cytokines {
    label="Cytokine Network";
    style=filled; color="#370617"; fontcolor="white"; penwidth=2;

    TNFA   [label="TNF-α\n(Central Mediator)",       fillcolor="#f48c06"];
    IL1B   [label="IL-1β\n(Inflammasome Product)",   fillcolor="#f48c06"];
    IL6    [label="IL-6\n(Pleiotropic Cytokine)",    fillcolor="#f48c06"];
    IL8    [label="IL-8 / CXCL8\n(Neutrophil Chemokine)", fillcolor="#e85d04"];
    IL17A  [label="IL-17A\n(Th17 Effector Cytokine)", fillcolor="#e85d04"];
    IL17F  [label="IL-17F\n(Th17 Co-effector)",      fillcolor="#e85d04"];
    IL21   [label="IL-21\n(B Cell Support)",         fillcolor="#e85d04"];
    IL22   [label="IL-22\n(Epithelial Repair/Damage)", fillcolor="#e85d04"];
    IL23   [label="IL-23\n(Th17 Maintenance)",       fillcolor="#dc2f02"];
    IL12   [label="IL-12\n(Th1 Polarization)",       fillcolor="#dc2f02"];
    IFNG   [label="IFN-γ\n(Th1/CD8 Effector)",       fillcolor="#dc2f02"];
    IL10   [label="IL-10\n(Anti-inflammatory)",      fillcolor="#2dc653"];
    TGFB   [label="TGF-β\n(Tolerogenic/Fibrotic)",   fillcolor="#2dc653"];
    VEGF   [label="VEGF\n(Angiogenesis / Permeability)", fillcolor="#70e000", fontcolor="black"];
    MCP1   [label="MCP-1 / CCL2\n(Monocyte Chemokine)", fillcolor="#dc2f02"];
    RANTES [label="RANTES / CCL5\n(T Cell Chemokine)", fillcolor="#dc2f02"];
    GMCSF  [label="GM-CSF\n(Myeloid Survival Factor)", fillcolor="#9d0208"];
    IL18   [label="IL-18\n(Inflammasome Product / IFN-γ inducer)", fillcolor="#9d0208"];
    IL33   [label="IL-33\n(Alarmin, ST2 ligand)",    fillcolor="#9d0208"];
    CXCL10 [label="CXCL10 / IP-10\n(Th1 Chemoattractant)", fillcolor="#dc2f02"];
  }

  /* ========== SUBGRAPH 5: Intracellular Signaling ========== */
  subgraph cluster_signaling {
    label="Intracellular Signaling Pathways";
    style=filled; color="#03045e"; fontcolor="white"; penwidth=2;

    NFkB     [label="NF-κB\nActivation (p65/p50)",    fillcolor="#0077b6"];
    JAKSTAT  [label="JAK1/2 — STAT\nCascade",          fillcolor="#0077b6"];
    STAT3    [label="STAT3\n(IL-6 / IL-10 effector)",  fillcolor="#00b4d8"];
    STAT4    [label="STAT4\n(IL-12 / IFN-γ effector)", fillcolor="#00b4d8"];
    STAT1    [label="STAT1\n(IFN-γ effector)",         fillcolor="#00b4d8"];
    RORgt    [label="RORγt\n(Th17 Master TF)",         fillcolor="#0096c7"];
    Tbet     [label="T-bet\n(Th1 Master TF)",          fillcolor="#0096c7"];
    MAPK     [label="MAPK / ERK\nSignaling Cascade",   fillcolor="#0096c7"];
    p38      [label="p38 MAPK\n(Stress/Inflammation)", fillcolor="#0096c7"];
    PI3KAKT  [label="PI3K / AKT\nSurvival Pathway",   fillcolor="#48cae4", fontcolor="black"];
    mTOR     [label="mTORC1\n(Metabolic Regulation)", fillcolor="#48cae4", fontcolor="black"];
    Notch    [label="Notch Signaling\n(T cell fate)",  fillcolor="#48cae4", fontcolor="black"];
    PDE4     [label="PDE4\n(cAMP Hydrolysis)",        fillcolor="#90e0ef", fontcolor="black"];
    cAMP     [label="cAMP\n(Anti-inflammatory Relay)", fillcolor="#90e0ef", fontcolor="black"];
  }

  /* ========== SUBGRAPH 6: Vascular Pathology ========== */
  subgraph cluster_vascular {
    label="Vascular Pathology & Thrombosis";
    style=filled; color="#560bad"; fontcolor="white"; penwidth=2;

    EC_act   [label="Endothelial Cell\nActivation",           fillcolor="#7b2ff7"];
    ICAM1    [label="ICAM-1\nUpregulation",                   fillcolor="#7b2ff7"];
    VCAM1    [label="VCAM-1\nUpregulation",                   fillcolor="#7b2ff7"];
    Esel     [label="E-selectin\nExpression",                 fillcolor="#7b2ff7"];
    coag     [label="Coagulation Cascade\nActivation (TF pathway)", fillcolor="#9b5de5"];
    thrombin [label="Thrombin\nGeneration (IIa)",             fillcolor="#9b5de5"];
    fibrin   [label="Fibrin Clot\nDeposition",                fillcolor="#9b5de5"];
    platelet [label="Platelet Activation\n(GP IIb/IIIa)",     fillcolor="#9b5de5"];
    vt       [label="Venous\nThrombosis",                     fillcolor="#f15bb5"];
    at       [label="Arterial\nThrombosis",                   fillcolor="#f15bb5"];
    aneurysm [label="Pulmonary / Systemic\nArterial Aneurysm", fillcolor="#f15bb5"];
    vasculitis_v [label="Vasculitis\n(Vessel Wall Inflammation)", fillcolor="#f15bb5"];
    NO_dec   [label="Nitric Oxide\n↓ Production (eNOS↓)",    fillcolor="#9b5de5"];
    PGI2     [label="Prostacyclin (PGI2)\n↓ Anti-thrombotic", fillcolor="#9b5de5"];
    PAI1     [label="PAI-1\n↑ Fibrinolysis Inhibition",      fillcolor="#9b5de5"];
    vWF      [label="von Willebrand Factor\n↑ (Endothelial Damage)", fillcolor="#7b2ff7"];
    TF       [label="Tissue Factor\nExpression (endothelial)", fillcolor="#7b2ff7"];
  }

  /* ========== SUBGRAPH 7: Organ Manifestations ========== */
  subgraph cluster_organs {
    label="Organ & Tissue Manifestations";
    style=filled; color="#2d4739"; fontcolor="white"; penwidth=2;

    oral_ul  [label="Oral Aphthous Ulcers\n(Major symptom, >95%)",    fillcolor="#40916c"];
    gen_ul   [label="Genital Ulcers\n(Scrotum/Labial, scarring)",     fillcolor="#40916c"];
    uv_ant   [label="Anterior Uveitis\n(Non-granulomatous)",          fillcolor="#52b788"];
    uv_post  [label="Posterior Uveitis\n(Vitritis / Retinitis)",      fillcolor="#52b788"];
    ret_vas  [label="Retinal Vasculitis\n(Occlusive)",                fillcolor="#52b788"];
    vis_loss [label="Vision Loss\n(Blindness risk 25%)",              fillcolor="#74c69d", fontcolor="black"];
    skin_pf  [label="Pseudofolliculitis\n(Papulopustular lesions)",   fillcolor="#74c69d", fontcolor="black"];
    EN       [label="Erythema Nodosum\n(Panniculitis)",               fillcolor="#74c69d", fontcolor="black"];
    pathergy [label="Pathergy Reaction\n(Needlestick test +)",        fillcolor="#74c69d", fontcolor="black"];
    GI_ul    [label="GI Ulcers\n(Ileocecal / Deep punched-out)",      fillcolor="#95d5b2", fontcolor="black"];
    neuro    [label="Neuro-Behcet\n(Parenchymal / Cerebral Vein Thromb)", fillcolor="#95d5b2", fontcolor="black"];
    arthritis_o [label="Arthritis\n(Asymmetric, non-destructive)",    fillcolor="#95d5b2", fontcolor="black"];
    epidid   [label="Epididymo-\nOrchitis",                           fillcolor="#b7e4c7", fontcolor="black"];
    budd     [label="Budd-Chiari\nSyndrome",                          fillcolor="#b7e4c7", fontcolor="black"];
    pul_inf  [label="Pulmonary\nInfarction",                          fillcolor="#b7e4c7", fontcolor="black"];
  }

  /* ========== SUBGRAPH 8: Drug PK Compartments ========== */
  subgraph cluster_pk {
    label="Drug Pharmacokinetics";
    style=filled; color="#1c1c1c"; fontcolor="white"; penwidth=2;

    colch_dose   [label="Colchicine\nDose (oral, 0.5-1 mg/day)", fillcolor="#e9c46a", shape=diamond, fontcolor="black"];
    colch_gut    [label="Colchicine\nGut (A1)",                   fillcolor="#f4a261", fontcolor="black"];
    colch_C      [label="Colchicine\nCentral Cp",                 fillcolor="#e76f51"];
    colch_T      [label="Colchicine\nTissue (V2)",                fillcolor="#e76f51"];

    pred_dose    [label="Prednisolone\nDose (oral, 0.5-1 mg/kg)", fillcolor="#e9c46a", shape=diamond, fontcolor="black"];
    pred_C       [label="Prednisolone\nCentral Cp",               fillcolor="#2a9d8f"];
    pred_T       [label="Prednisolone\nTissue",                   fillcolor="#2a9d8f"];

    aza_dose     [label="Azathioprine\nDose (oral, 2.5 mg/kg)",   fillcolor="#e9c46a", shape=diamond, fontcolor="black"];
    aza_C        [label="Azathioprine → 6-TG\nCentral",           fillcolor="#264653"];

    atnf_dose    [label="Adalimumab\n(SC 40 mg Q2W)",             fillcolor="#e9c46a", shape=diamond, fontcolor="black"];
    atnf_C       [label="Adalimumab\nCentral Cp",                 fillcolor="#457b9d"];
    atnf_P       [label="Adalimumab\nPeripheral",                 fillcolor="#1d3557"];

    aprem_dose   [label="Apremilast\n(oral 30 mg BID)",           fillcolor="#e9c46a", shape=diamond, fontcolor="black"];
    aprem_C      [label="Apremilast\nCentral Cp",                 fillcolor="#a8dadc", fontcolor="black"];

    canaki_dose  [label="Canakinumab\n(SC 150 mg Q8W)",           fillcolor="#e9c46a", shape=diamond, fontcolor="black"];
    canaki_C     [label="Canakinumab\nCentral Cp",                fillcolor="#e63946"];
    canaki_P     [label="Canakinumab\nPeripheral",                fillcolor="#c1121f"];

    cyclo_dose   [label="Cyclophosphamide\n(IV pulse)",           fillcolor="#e9c46a", shape=diamond, fontcolor="black"];
    cyclo_C      [label="Cyclophosphamide\nCentral (active form)", fillcolor="#6a4c93"];

    thal_dose    [label="Thalidomide\n(oral 100-300 mg/day)",     fillcolor="#e9c46a", shape=diamond, fontcolor="black"];
    thal_C       [label="Thalidomide\nCentral Cp",                fillcolor="#8338ec"];
  }

  /* ========== SUBGRAPH 9: Drug PD Mechanisms ========== */
  subgraph cluster_pd {
    label="Drug Pharmacodynamics (Mechanisms of Action)";
    style=filled; color="#33001b"; fontcolor="white"; penwidth=2;

    colch_moa  [label="Colchicine MOA:\n• Tubulin polymerization↓\n• Neutrophil chemotaxis↓\n• NLRP3 assembly↓",  fillcolor="#ff6b6b"];
    pred_moa   [label="Glucocorticoid MOA:\n• NF-κB inhibition\n• AP-1 inhibition\n• Broad cytokine↓",            fillcolor="#ffa07a", fontcolor="black"];
    aza_moa    [label="Azathioprine MOA:\n• 6-TG → DNA damage\n• T/B cell proliferation↓\n• Purine synthesis↓",  fillcolor="#ff8c00", fontcolor="black"];
    atnf_moa   [label="Anti-TNF MOA:\n• TNF-α neutralization\n• TNFR1/R2 blockade\n• Treg induction",            fillcolor="#ffd700", fontcolor="black"];
    aprem_moa  [label="Apremilast MOA:\n• PDE4 inhibition\n• cAMP↑\n• TNF-α↓, IL-17↓, IL-10↑",                  fillcolor="#adff2f", fontcolor="black"];
    canaki_moa [label="Canakinumab MOA:\n• IL-1β neutralization\n• NLRP3 pathway blockade",                       fillcolor="#00fa9a", fontcolor="black"];
    cyclo_moa  [label="Cyclophosphamide MOA:\n• DNA alkylation\n• B/T cell depletion\n• Immunosuppression",       fillcolor="#00bfff", fontcolor="black"];
    thal_moa   [label="Thalidomide MOA:\n• TNF-α mRNA destabilization\n• IMiD immunomodulation\n• Th1↓",          fillcolor="#9370db"];
    tociliz_moa [label="Tocilizumab MOA:\n• IL-6R blockade\n• STAT3 inhibition",                                  fillcolor="#ff9f1c", fontcolor="black"];
  }

  /* ========== SUBGRAPH 10: Clinical Endpoints & Biomarkers ========== */
  subgraph cluster_endpoints {
    label="Clinical Endpoints & Biomarkers";
    style=filled; color="#0a0908"; fontcolor="white"; penwidth=2;

    BDCAF     [label="BDCAF Score\n(Behcet's Disease Activity Index)",  fillcolor="#fbbf24", shape=hexagon, fontcolor="black"];
    oral_freq [label="Oral Ulcer\nFrequency (per month)",               fillcolor="#f59e0b", shape=hexagon, fontcolor="black"];
    gen_freq  [label="Genital Ulcer\nFrequency (per month)",            fillcolor="#f59e0b", shape=hexagon, fontcolor="black"];
    VA        [label="Visual Acuity\n(LogMAR / Snellen)",               fillcolor="#f59e0b", shape=hexagon, fontcolor="black"];
    ocular_sc [label="Ocular\nInflammation Score",                      fillcolor="#d97706", shape=hexagon, fontcolor="black"];
    ESR_CRP   [label="ESR / CRP\n(Acute Phase Reactants)",              fillcolor="#d97706", shape=hexagon, fontcolor="black"];
    QoL       [label="Quality of Life\n(SF-36 / BDQ)",                 fillcolor="#b45309", shape=hexagon, fontcolor="white"];
    relapse   [label="Relapse Rate\n(Flares/Year)",                     fillcolor="#b45309", shape=hexagon, fontcolor="white"];
    remission [label="Time to\nComplete Remission",                     fillcolor="#92400e", shape=hexagon, fontcolor="white"];
    skin_sc   [label="Skin Activity\nScore",                            fillcolor="#92400e", shape=hexagon, fontcolor="white"];
    neuro_sc  [label="Neurological\nFunctional Score",                  fillcolor="#78350f", shape=hexagon, fontcolor="white"];
    vasc_ev   [label="Vascular Event\nRate (Thrombosis/Aneurysm)",      fillcolor="#78350f", shape=hexagon, fontcolor="white"];
    IL6_bio   [label="Serum IL-6\n(Biomarker)",                         fillcolor="#451e03", shape=hexagon, fontcolor="white"];
    TNFA_bio  [label="Serum TNF-α\n(Biomarker)",                        fillcolor="#451e03", shape=hexagon, fontcolor="white"];
    SAA       [label="Serum Amyloid A\n(SAA, Biomarker)",               fillcolor="#451e03", shape=hexagon, fontcolor="white"];
  }

  /* ============================================================
     EDGES — Genetic / Environmental → Innate
  ============================================================ */
  HLAB51     -> neutrophil  [color="#e63946", label="HLA-B51↑\nneutrophil priming"];
  HLAB51     -> CD8T        [color="#e63946"];
  ERAP1      -> HLAB51      [color="#c1121f", label="antigen\ntrimming"];
  IL10_poly  -> IL10        [color="#c1121f", label="↓IL-10\nproduction", style=dashed];
  TNFSF4     -> TNFA        [color="#c1121f", label="↑TNF-α"];
  STAT4_gene -> STAT4       [color="#c1121f"];
  microbiome -> PAMP        [color="#457b9d"];
  oral_micro -> strep       [color="#457b9d"];
  strep      -> HSP60       [color="#457b9d", label="epitope\nmimicry"];
  HSP60      -> CD8T        [color="#a8dadc", label="cross-reactive"];
  HSP70      -> Th1         [color="#a8dadc", label="cross-reactive"];
  env_stress -> ER_stress   [color="#457b9d"];
  ER_stress  -> NLRP3       [color="#b7e4c7"];
  PAMP       -> TLR2        [color="#1b4332"];
  PAMP       -> NOD2        [color="#1b4332"];

  /* ============================================================
     Innate Immune Signaling
  ============================================================ */
  TLR2       -> NFkB        [color="#95d5b2", label="MyD88\nsignaling"];
  TLR2       -> MAPK        [color="#95d5b2"];
  NOD2       -> NFkB        [color="#b7e4c7"];
  NLRP3      -> casp1       [color="#95d5b2", label="ASC\nassembly"];
  casp1      -> IL1B        [color="#95d5b2", label="pro→mature\nIL-1β cleavage"];
  casp1      -> IL18        [color="#95d5b2", label="pro→mature\nIL-18 cleavage"];
  cGAS_STING -> NFkB        [color="#48cae4"];
  cGAS_STING -> IFNG        [color="#48cae4", label="type I IFN"];
  neutrophil -> ROS         [color="#52b788"];
  neutrophil -> NET         [color="#52b788", label="NETosis"];
  neutrophil -> MPO         [color="#40916c"];
  neutrophil -> NE          [color="#40916c"];
  neutrophil -> IL8         [color="#52b788", label="autocrine"];
  neutrophil -> TNFA        [color="#52b788", label="release"];
  MPO        -> ROS         [color="#40916c"];
  ROS        -> EC_act      [color="#40916c", label="oxidative\ndamage"];
  NET        -> coag        [color="#52b788", label="activates\ncoagulation"];
  NET        -> EC_act      [color="#52b788", label="damages\nendothelium"];
  NE         -> EC_act      [color="#40916c"];
  monocyte   -> TNFA        [color="#74c69d", label="major\nsource"];
  monocyte   -> IL1B        [color="#74c69d"];
  monocyte   -> IL6         [color="#74c69d"];
  monocyte   -> IL12        [color="#74c69d"];
  monocyte   -> IL23        [color="#74c69d"];
  macrophage -> TNFA        [color="#74c69d"];
  macrophage -> IL1B        [color="#74c69d"];
  macrophage -> IL12        [color="#74c69d"];
  macrophage -> ROS         [color="#74c69d"];
  macrophage -> GMCSF       [color="#74c69d"];
  DC         -> IL12        [color="#74c69d", label="DC→Th1\npriming"];
  DC         -> IL23        [color="#74c69d", label="DC→Th17\npriming"];
  DC         -> Th1         [color="#74c69d", label="antigen\npresentation"];
  DC         -> Th17        [color="#74c69d"];
  NK         -> IFNG        [color="#95d5b2", label="early IFN-γ"];
  mast       -> TNFA        [color="#95d5b2"];
  mast       -> IL1B        [color="#95d5b2"];
  IL18       -> NK          [color="#9d0208", label="NK activation"];
  IL18       -> Th1         [color="#9d0208", label="IFN-γ↑"];
  IL33       -> mast        [color="#9d0208", label="degranulation"];

  /* ============================================================
     Signaling Pathways
  ============================================================ */
  NFkB    -> TNFA     [color="#0077b6", label="transcription"];
  NFkB    -> IL6      [color="#0077b6", label="transcription"];
  NFkB    -> IL8      [color="#0077b6", label="transcription"];
  NFkB    -> IL1B     [color="#0077b6", label="transcription"];
  NFkB    -> ICAM1    [color="#0077b6"];
  NFkB    -> VCAM1    [color="#0077b6"];
  NFkB    -> Esel     [color="#0077b6"];
  NFkB    -> GMCSF    [color="#0077b6"];
  IL6     -> JAKSTAT  [color="#f48c06"];
  IL6     -> STAT3    [color="#f48c06"];
  IL12    -> STAT4    [color="#f48c06"];
  IFNG    -> STAT1    [color="#dc2f02"];
  STAT3   -> RORgt    [color="#00b4d8", label="→Th17"];
  STAT4   -> Tbet     [color="#00b4d8", label="→Th1"];
  STAT1   -> Tbet     [color="#00b4d8"];
  RORgt   -> Th17     [color="#0096c7", label="master TF\npolarization"];
  Tbet    -> Th1      [color="#0096c7", label="master TF\npolarization"];
  MAPK    -> TNFA     [color="#0096c7", label="mRNA\nstabilization"];
  p38     -> TNFA     [color="#0096c7", label="↑secretion"];
  p38     -> IL6      [color="#0096c7"];
  PI3KAKT -> mTOR     [color="#48cae4"];
  mTOR    -> Th17     [color="#48cae4", label="↑expansion"];
  Notch   -> Th17     [color="#48cae4"];
  Notch   -> Th1      [color="#48cae4"];
  PDE4    -> cAMP     [color="#90e0ef", label="hydrolyze\ncAMP↓", style=dashed, fontcolor="#90e0ef"];

  /* ============================================================
     Adaptive Immunity — Cytokine Production
  ============================================================ */
  Th1  -> IFNG    [color="#c77dff", label="primary\nsource"];
