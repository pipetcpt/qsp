digraph AcutePancreatitis_QSP {
  graph [rankdir=LR, splines=true, overlap=false, fontname="Helvetica", fontsize=11, nodesep=0.35, ranksep=0.55, bgcolor="white", label="Acute Pancreatitis (AP) QSP Model — Trypsin Activation → Acinar Necrosis → SIRS → MODS\nAtlanta 2012 / Revised severity · Fluid resuscitation · NSAID·Octreotide·Nafamostat·Ulinastatin · Antibiotics", labelloc=t, fontsize=14];
  node  [shape=box, style="rounded,filled", fontname="Helvetica", fontsize=10, color="#333333"];
  edge  [color="#555555", arrowsize=0.7, fontname="Helvetica", fontsize=9];

  // ============================================================
  // CLUSTER 1 — ETIOLOGY & RISK FACTORS
  // ============================================================
  subgraph cluster_etiology {
    label="① Etiology & Triggers (TIGAR-O)";
    style="rounded,filled"; fillcolor="#FFF1E6"; color="#E67E22";
    eti_gallstones    [label="Gallstones\nCBD obstruction\n40–70%", fillcolor="#FCD9B6"];
    eti_alcohol       [label="Chronic alcohol\nEtOH metabolites\n25–35%", fillcolor="#FCD9B6"];
    eti_htg           [label="Hypertriglyceridemia\nTG >1000 mg/dL\n2–10%", fillcolor="#FCD9B6"];
    eti_ercp          [label="Post-ERCP\nPEP 3–10%", fillcolor="#FCD9B6"];
    eti_drugs         [label="Drug-induced\nAZA·6-MP·DDI·GLP-1·valproate", fillcolor="#FCD9B6"];
    eti_trauma        [label="Blunt/penetrating\ntrauma", fillcolor="#FCD9B6"];
    eti_hypercalcemia [label="Hypercalcemia\nHPT·malignancy", fillcolor="#FCD9B6"];
    eti_ipmn          [label="IPMN / pancreatic\nductal obstruction", fillcolor="#FCD9B6"];
    eti_autoimmune    [label="Autoimmune (AIP)\nIgG4", fillcolor="#FCD9B6"];
    eti_idiopathic    [label="Idiopathic\n10–15%", fillcolor="#FCD9B6"];
    eti_genetic       [label="Hereditary\nPRSS1·SPINK1·CFTR·CTRC·CASR·CLDN2", fillcolor="#FCD9B6"];
    eti_viral         [label="Mumps · CMV · HIV\nCoxsackie", fillcolor="#FCD9B6"];
  }

  // ============================================================
  // CLUSTER 2 — INITIAL ACINAR CELL INJURY
  // ============================================================
  subgraph cluster_acinar_init {
    label="② Acinar Cell Injury Initiation";
    style="rounded,filled"; fillcolor="#FDEBD0"; color="#D68910";
    ac_acinar         [label="Pancreatic\nacinar cell", fillcolor="#FAD7A0"];
    ac_camp           [label="↑ cytosolic Ca²⁺\nsustained plateau", fillcolor="#FAD7A0"];
    ac_serca          [label="SERCA pump\noverload", fillcolor="#FAD7A0"];
    ac_ipr            [label="IP3R · RyR\nstore release", fillcolor="#FAD7A0"];
    ac_orai           [label="STIM1·ORAI1\nSOCE channel", fillcolor="#FAD7A0"];
    ac_mito           [label="Mitochondrial\ndysfunction\nΔΨm collapse", fillcolor="#FAD7A0"];
    ac_atp            [label="↓ ATP\nbioenergetic failure", fillcolor="#FAD7A0"];
    ac_ros            [label="Mitochondrial ROS\n(O2⁻ · H2O2)", fillcolor="#FAD7A0"];
    ac_mptp           [label="MPTP opening\n(cyclophilin-D)", fillcolor="#FAD7A0"];
    ac_er             [label="ER stress · UPR\nPERK·IRE1·ATF6", fillcolor="#FAD7A0"];
    ac_autophagy      [label="Impaired autophagy\nLAMP-2 ↓ · LC3-II ↑", fillcolor="#FAD7A0"];
    ac_zymogen        [label="Zymogen / lysosome\nco-localization", fillcolor="#FAD7A0"];
  }

  // ============================================================
  // CLUSTER 3 — INTRACELLULAR TRYPSIN ACTIVATION
  // ============================================================
  subgraph cluster_trypsin {
    label="③ Premature Trypsinogen Activation";
    style="rounded,filled"; fillcolor="#FADBD8"; color="#C0392B";
    tr_trypsinogen    [label="Trypsinogen\n(zymogen)", fillcolor="#F5B7B1"];
    tr_cathb          [label="Cathepsin B\nactivator", fillcolor="#F5B7B1"];
    tr_trypsin        [label="Active trypsin\nintracellular", fillcolor="#F5B7B1"];
    tr_spink1         [label="SPINK1 / PSTI\ntrypsin inhibitor", fillcolor="#F5B7B1"];
    tr_ctrc           [label="CTRC\ntrypsin degradation", fillcolor="#F5B7B1"];
    tr_chymo          [label="Chymotrypsinogen\n→ Chymotrypsin", fillcolor="#F5B7B1"];
    tr_elastase       [label="Pro-elastase\n→ Elastase", fillcolor="#F5B7B1"];
    tr_pla2           [label="Pro-phospholipase A2\n→ PLA2", fillcolor="#F5B7B1"];
    tr_carbox         [label="Procarboxypeptidase\n→ CPA", fillcolor="#F5B7B1"];
    tr_autodigest     [label="Auto-digestion\nof acinar cell", fillcolor="#F5B7B1"];
    tr_par2           [label="PAR-2 receptor\n(trypsin signal)", fillcolor="#F5B7B1"];
  }

  // ============================================================
  // CLUSTER 4 — INFLAMMATORY SIGNALING (NF-κB / Inflammasome)
  // ============================================================
  subgraph cluster_inflam {
    label="④ Inflammatory Signaling";
    style="rounded,filled"; fillcolor="#F8D7DA"; color="#A93226";
    in_nfkb           [label="NF-κB\np65/p50", fillcolor="#F1948A"];
    in_ap1            [label="AP-1\nc-Jun/c-Fos", fillcolor="#F1948A"];
    in_jnk            [label="JNK / p38 MAPK", fillcolor="#F1948A"];
    in_tlr4           [label="TLR4 (DAMP / LPS)", fillcolor="#F1948A"];
    in_myd88          [label="MyD88·IRAK", fillcolor="#F1948A"];
    in_nlrp3          [label="NLRP3 inflammasome\nASC · pro-caspase-1", fillcolor="#F1948A"];
    in_casp1          [label="Caspase-1", fillcolor="#F1948A"];
    in_gsdmd          [label="Gasdermin-D\npyroptosis pore", fillcolor="#F1948A"];
    in_il1b           [label="IL-1β\n(pro→mature)", fillcolor="#F1948A"];
    in_il18           [label="IL-18", fillcolor="#F1948A"];
    in_tnf            [label="TNF-α", fillcolor="#F1948A"];
    in_il6            [label="IL-6\n(severity marker)", fillcolor="#F1948A"];
    in_il8            [label="IL-8 / CXCL8\nneutrophil chemoattractant", fillcolor="#F1948A"];
    in_mcp1           [label="MCP-1 / CCL2", fillcolor="#F1948A"];
    in_paf            [label="PAF\nplatelet-activating", fillcolor="#F1948A"];
    in_hmgb1          [label="HMGB1\nDAMP (late mediator)", fillcolor="#F1948A"];
  }

  // ============================================================
  // CLUSTER 5 — INNATE IMMUNE CELLS
  // ============================================================
  subgraph cluster_innate {
    label="⑤ Innate Immune Effectors";
    style="rounded,filled"; fillcolor="#FCF3CF"; color="#B7950B";
    im_neutro         [label="Neutrophils\ninfiltration", fillcolor="#F9E79F"];
    im_nets           [label="NETs\n(citH3·MPO·DNA)", fillcolor="#F9E79F"];
    im_mpo            [label="MPO\nhypochlorite", fillcolor="#F9E79F"];
    im_macro          [label="Macrophages\nM1 (pro-inflam) ↑", fillcolor="#F9E79F"];
    im_m2             [label="M2 (resolution)\nlate phase", fillcolor="#F9E79F"];
    im_damps          [label="DAMPs\nATP · mtDNA · HMGB1", fillcolor="#F9E79F"];
    im_complement     [label="Complement\nC3a · C5a", fillcolor="#F9E79F"];
    im_kallikrein     [label="Kallikrein-kinin\nBradykinin", fillcolor="#F9E79F"];
    im_resolvins      [label="Resolvins · LXA4\npro-resolution", fillcolor="#F9E79F"];
  }

  // ============================================================
  // CLUSTER 6 — ACINAR DEATH MODES
  // ============================================================
  subgraph cluster_death {
    label="⑥ Acinar Cell Death Modes";
    style="rounded,filled"; fillcolor="#E8DAEF"; color="#7D3C98";
    de_apoptosis      [label="Apoptosis\ncaspase-3/8/9\n(mild AP)", fillcolor="#D2B4DE"];
    de_necroptosis    [label="Necroptosis\nRIPK1·RIPK3·MLKL", fillcolor="#D2B4DE"];
    de_pyroptosis     [label="Pyroptosis\nGSDMD pore", fillcolor="#D2B4DE"];
    de_ferroptosis    [label="Ferroptosis\nGPX4·Fe²⁺·LPO", fillcolor="#D2B4DE"];
    de_necrosis       [label="Coagulative\nnecrosis\n(severe AP)", fillcolor="#D2B4DE"];
    de_fatnecrosis    [label="Peripancreatic\nfat necrosis\n(saponification)", fillcolor="#D2B4DE"];
    de_calcium_soap   [label="Calcium soap\nhypocalcemia", fillcolor="#D2B4DE"];
  }

  // ============================================================
  // CLUSTER 7 — MICROCIRCULATION & VASCULAR
  // ============================================================
  subgraph cluster_vasc {
    label="⑦ Microcirculatory & Vascular Injury";
    style="rounded,filled"; fillcolor="#FADBD8"; color="#E74C3C";
    va_endo           [label="Endothelial\ndysfunction", fillcolor="#F5B7B1"];
    va_perm           [label="Capillary leak\n↑ permeability", fillcolor="#F5B7B1"];
    va_icam           [label="ICAM-1 · VCAM-1\nE-selectin", fillcolor="#F5B7B1"];
    va_thrombin       [label="Thrombin · Factor V\nmicrothrombi", fillcolor="#F5B7B1"];
    va_dic            [label="DIC (severe)\nD-dimer ↑", fillcolor="#F5B7B1"];
    va_ischemia       [label="Pancreatic\nischemia-reperfusion", fillcolor="#F5B7B1"];
    va_no             [label="NO · iNOS\nvasodilation", fillcolor="#F5B7B1"];
    va_et1            [label="Endothelin-1\nvasoconstriction", fillcolor="#F5B7B1"];
    va_glycocalyx     [label="Glycocalyx\nshedding (syndecan-1)", fillcolor="#F5B7B1"];
  }

  // ============================================================
  // CLUSTER 8 — LOCAL COMPLICATIONS (Atlanta 2012)
  // ============================================================
  subgraph cluster_local {
    label="⑧ Local Complications (Atlanta 2012)";
    style="rounded,filled"; fillcolor="#D6EAF8"; color="#2874A6";
    lo_apfc           [label="Acute peripancreatic\nfluid collection (APFC)\n<4 wk", fillcolor="#AED6F1"];
    lo_pseudocyst     [label="Pancreatic\npseudocyst\n>4 wk", fillcolor="#AED6F1"];
    lo_anc            [label="Acute necrotic\ncollection (ANC)", fillcolor="#AED6F1"];
    lo_won            [label="Walled-off\nnecrosis (WON)\n>4 wk", fillcolor="#AED6F1"];
    lo_infected       [label="Infected necrosis\n(gas in CT)", fillcolor="#AED6F1"];
    lo_gd_thrombosis  [label="Splenic / portal\nvein thrombosis", fillcolor="#AED6F1"];
    lo_pseudoaneurysm [label="Pseudoaneurysm\nGDA / splenic", fillcolor="#AED6F1"];
    lo_colonic        [label="Colonic necrosis\n/ fistula", fillcolor="#AED6F1"];
  }

  // ============================================================
  // CLUSTER 9 — GUT & BACTERIAL TRANSLOCATION
  // ============================================================
  subgraph cluster_gut {
    label="⑨ Gut Barrier / Bacterial Translocation";
    style="rounded,filled"; fillcolor="#FDF2E9"; color="#BA4A00";
    gu_barrier        [label="Gut barrier\nintegrity loss", fillcolor="#FAD7A0"];
    gu_zo1            [label="ZO-1 · claudin\n↓ tight junction", fillcolor="#FAD7A0"];
    gu_microbiome     [label="Dysbiosis\n(Enterobacteriaceae ↑)", fillcolor="#FAD7A0"];
    gu_translocation  [label="Bacterial\ntranslocation", fillcolor="#FAD7A0"];
    gu_lps            [label="Plasma LPS\nendotoxemia", fillcolor="#FAD7A0"];
    gu_ileus          [label="Paralytic ileus\nGI dysmotility", fillcolor="#FAD7A0"];
    gu_iah            [label="Intra-abdominal\nhypertension (IAH)", fillcolor="#FAD7A0"];
    gu_acs            [label="Abdominal compartment\nsyndrome (ACS)\nIAP >20 mmHg", fillcolor="#FAD7A0"];
  }

  // ============================================================
  // CLUSTER 10 — SIRS / SEPSIS / MODS
  // ============================================================
  subgraph cluster_mods {
    label="⑩ SIRS / Sepsis / Multi-Organ Dysfunction";
    style="rounded,filled"; fillcolor="#FADBD8"; color="#922B21";
    mo_sirs           [label="SIRS\n(≥2 criteria)", fillcolor="#F5B7B1"];
    mo_sepsis         [label="Sepsis / septic\nshock (late)", fillcolor="#F5B7B1"];
    mo_ards           [label="ARDS\n(P/F <300)\nPLA2 surfactant", fillcolor="#F5B7B1"];
    mo_aki            [label="AKI\n(KDIGO Cr ↑)\nhypoperfusion", fillcolor="#F5B7B1"];
    mo_hepatic        [label="Hepatic dysfunction\n↑ bilirubin · AST", fillcolor="#F5B7B1"];
    mo_cns            [label="CNS\nencephalopathy", fillcolor="#F5B7B1"];
    mo_shock          [label="Distributive shock\nMAP <65", fillcolor="#F5B7B1"];
    mo_lactate        [label="↑ Lactate\nhypoperfusion", fillcolor="#F5B7B1"];
    mo_sofa           [label="SOFA score\n(0–24)", fillcolor="#F5B7B1"];
    mo_mods           [label="MODS\nmulti-organ failure", fillcolor="#F5B7B1"];
  }

  // ============================================================
  // CLUSTER 11 — PAIN PATHWAY
  // ============================================================
  subgraph cluster_pain {
    label="⑪ Pain Pathway";
    style="rounded,filled"; fillcolor="#FCF3CF"; color="#9A7D0A";
    pa_visceral       [label="Visceral nociceptor\n(splanchnic)", fillcolor="#F9E79F"];
    pa_trpv1          [label="TRPV1 · TRPA1", fillcolor="#F9E79F"];
    pa_pge2           [label="PGE2 / COX-2\nperipheral sensitization", fillcolor="#F9E79F"];
    pa_substanceP     [label="Substance P · NK-1R\nneurogenic inflam", fillcolor="#F9E79F"];
    pa_cgrp           [label="CGRP\nneuropeptide", fillcolor="#F9E79F"];
    pa_spinal         [label="Spinal dorsal horn\ncentral sensitization", fillcolor="#F9E79F"];
    pa_opioid_R       [label="μ-opioid receptor", fillcolor="#F9E79F"];
    pa_vas            [label="VAS pain 0–10\nclinical endpoint", fillcolor="#F9E79F"];
  }

  // ============================================================
  // CLUSTER 12 — DRUG PK/PD
  // ============================================================
  subgraph cluster_drugs {
    label="⑫ Therapeutics — PK/PD";
    style="rounded,filled"; fillcolor="#D5F5E3"; color="#196F3D";
    dr_fluid_LR       [label="Lactated Ringer's\n5–10 mL/kg/h goal\nWATERFALL · ICU-style", fillcolor="#A9DFBF"];
    dr_fluid_NS       [label="Normal saline\n(less favored)\nhyperchloremic acidosis", fillcolor="#A9DFBF"];
    dr_nsaid_indo     [label="Indomethacin 100 mg PR\nrectal · pre-ERCP\nPEP prophylaxis", fillcolor="#A9DFBF"];
    dr_nsaid_diclo    [label="Diclofenac 100 mg PR\nalternative", fillcolor="#A9DFBF"];
    dr_octreotide     [label="Octreotide 100 µg SC q8h\nor 50 µg/h IV\nSSTR2 agonist", fillcolor="#A9DFBF"];
    dr_gabexate       [label="Gabexate mesilate\n2400 mg/d IV\nserine protease inhibitor", fillcolor="#A9DFBF"];
    dr_nafamostat     [label="Nafamostat mesilate\n20–40 mg/d IV\nbroad protease inhib", fillcolor="#A9DFBF"];
    dr_ulinastatin    [label="Ulinastatin\n200 000 U IV q8h\nurinary trypsin inhibitor", fillcolor="#A9DFBF"];
    dr_atb_meropenem  [label="Meropenem 1 g IV q8h\ninfected necrosis only", fillcolor="#A9DFBF"];
    dr_atb_cipro      [label="Ciprofloxacin + metro\nalt regimen", fillcolor="#A9DFBF"];
    dr_opioid_fent    [label="Fentanyl PCA\nμ-OR analgesia", fillcolor="#A9DFBF"];
    dr_opioid_morph   [label="Morphine\n(may ↑ Oddi)", fillcolor="#A9DFBF"];
    dr_ppi            [label="PPI (esomeprazole)\nstress ulcer prophylaxis", fillcolor="#A9DFBF"];
    dr_apheresis      [label="Plasmapheresis / insulin\nfor severe HTG-AP", fillcolor="#A9DFBF"];
    dr_ercp_emergent  [label="Emergent ERCP\ncholangitis · CBD stone", fillcolor="#A9DFBF"];
    dr_drainage       [label="Step-up drainage\nPCD → endoscopic\n(PANTER · TENSION)", fillcolor="#A9DFBF"];
    dr_nutrition      [label="Early enteral nutrition\nNJ tube · gut-protect", fillcolor="#A9DFBF"];
    dr_pirfenidone    [label="Investigational\nanti-fibrotic", fillcolor="#A9DFBF"];
    dr_anakinra       [label="Anakinra (IL-1Ra)\nEXP RCT", fillcolor="#A9DFBF"];
  }

  // ============================================================
  // CLUSTER 13 — CLINICAL ENDPOINTS & SEVERITY
  // ============================================================
  subgraph cluster_clinical {
    label="⑬ Clinical Endpoints & Severity Scores";
    style="rounded,filled"; fillcolor="#D6EAF8"; color="#1B4F72";
    cl_lipase         [label="Serum lipase\n>3× ULN", fillcolor="#85C1E9"];
    cl_amylase        [label="Serum amylase", fillcolor="#85C1E9"];
    cl_crp            [label="CRP\n>150 mg/L @ 48 h", fillcolor="#85C1E9"];
    cl_apache         [label="APACHE-II\n≥8 severe", fillcolor="#85C1E9"];
    cl_bisap          [label="BISAP\n≥3 severe", fillcolor="#85C1E9"];
    cl_ranson         [label="Ranson score\n≥3 severe", fillcolor="#85C1E9"];
    cl_ctsi           [label="CT severity index\n(Balthazar)", fillcolor="#85C1E9"];
    cl_atlanta_mild   [label="Mild AP\n(no organ failure)", fillcolor="#85C1E9"];
    cl_atlanta_mod    [label="Moderately severe\n(transient OF)", fillcolor="#85C1E9"];
    cl_atlanta_sev    [label="Severe AP\n(persistent OF >48 h)", fillcolor="#85C1E9"];
    cl_mortality      [label="Mortality\n(severe AP 15–30%)", fillcolor="#85C1E9"];
    cl_los            [label="Length of stay", fillcolor="#85C1E9"];
    cl_recurrence     [label="Recurrent AP\n→ chronic AP", fillcolor="#85C1E9"];
    cl_diabetes       [label="Post-AP DM\n(islet loss)", fillcolor="#85C1E9"];
  }

  // ============================================================
  // CLUSTER 14 — LATE / RECOVERY
  // ============================================================
  subgraph cluster_recovery {
    label="⑭ Recovery / CARS / Long-term";
    style="rounded,filled"; fillcolor="#E8F8F5"; color="#117864";
    re_cars           [label="CARS\ncompensatory anti-inflam", fillcolor="#A2D9CE"];
    re_il10           [label="IL-10 ↑", fillcolor="#A2D9CE"];
    re_tgfb           [label="TGF-β ↑\nfibrosis", fillcolor="#A2D9CE"];
    re_treg           [label="Treg expansion", fillcolor="#A2D9CE"];
    re_immunosuppress [label="Late immunosuppression\n→ secondary infection", fillcolor="#A2D9CE"];
    re_exocrine       [label="Exocrine insufficiency\n(post-severe AP)", fillcolor="#A2D9CE"];
    re_endocrine      [label="Endocrine\ninsufficiency / DM", fillcolor="#A2D9CE"];
    re_regeneration   [label="Acinar / ductal\nregeneration (ADM)", fillcolor="#A2D9CE"];
  }

  // ============================================================
  // EDGES — ETIOLOGY → ACINAR INJURY
  // ============================================================
  eti_gallstones    -> ac_acinar [label="duct obstruction"];
  eti_alcohol       -> ac_acinar [label="FAEE · acetaldehyde"];
  eti_alcohol       -> ac_er;
  eti_htg           -> ac_acinar [label="FFA lipotoxicity"];
  eti_ercp          -> ac_acinar [label="ductal hypertension"];
  eti_drugs         -> ac_acinar;
  eti_trauma        -> ac_acinar;
  eti_hypercalcemia -> ac_camp [label="↑Ca²⁺ load"];
  eti_ipmn          -> ac_acinar;
  eti_autoimmune    -> in_nfkb;
  eti_idiopathic    -> ac_acinar [style=dotted];
  eti_genetic       -> tr_spink1 [label="SPINK1 ↓"];
  eti_genetic       -> tr_ctrc   [label="CTRC ↓"];
  eti_viral         -> ac_acinar;

  // ACINAR INJURY → TRYPSIN
  ac_acinar  -> ac_camp;
  ac_camp    -> ac_ipr;
  ac_camp    -> ac_orai;
  ac_camp    -> ac_serca [label="overload"];
  ac_camp    -> ac_mito;
  ac_mito    -> ac_atp;
  ac_mito    -> ac_ros;
  ac_mito    -> ac_mptp;
  ac_ros     -> ac_er;
  ac_atp     -> ac_autophagy [label="↓"];
  ac_autophagy -> ac_zymogen;
  ac_zymogen -> tr_trypsinogen;
  ac_zymogen -> tr_cathb;
  tr_cathb   -> tr_trypsin [label="activates"];
  tr_trypsinogen -> tr_trypsin;
  tr_spink1  -> tr_trypsin [label="inhibits", color="blue", style=dashed];
  tr_ctrc    -> tr_trypsin [label="degrades", color="blue", style=dashed];
  tr_trypsin -> tr_chymo;
  tr_trypsin -> tr_elastase;
  tr_trypsin -> tr_pla2;
  tr_trypsin -> tr_carbox;
  tr_trypsin -> tr_par2;
  tr_trypsin -> tr_autodigest;
  tr_chymo   -> tr_autodigest;
  tr_elastase-> tr_autodigest;
  tr_pla2    -> tr_autodigest;
  tr_pla2    -> mo_ards [label="surfactant", color="red"];

  // AUTODIGEST → DEATH MODES
  tr_autodigest -> de_apoptosis;
  tr_autodigest -> de_necrosis;
  tr_autodigest -> de_fatnecrosis;
  ac_mptp -> de_necroptosis;
  ac_mptp -> de_necrosis;
  in_casp1 -> in_gsdmd;
  in_gsdmd -> de_pyroptosis;
  ac_ros   -> de_ferroptosis;
  de_fatnecrosis -> de_calcium_soap;
  de_calcium_soap -> cl_atlanta_sev [label="↓Ca²⁺", style=dashed];

  // INFLAMMATORY CASCADE
  ac_acinar -> in_nfkb [label="early"];
  ac_acinar -> in_ap1;
  ac_acinar -> in_jnk;
  tr_par2   -> in_nfkb;
  im_damps  -> in_tlr4;
  in_tlr4   -> in_myd88;
  in_myd88  -> in_nfkb;
  in_nfkb   -> in_il1b;
  in_nfkb   -> in_tnf;
  in_nfkb   -> in_il6;
  in_nfkb   -> in_il8;
  in_nfkb   -> in_mcp1;
  in_nfkb   -> in_paf;
  in_ap1    -> in_nlrp3;
  in_nlrp3  -> in_casp1;
  in_casp1  -> in_il1b [label="cleaves"];
  in_casp1  -> in_il18;
  in_il1b   -> in_il6;
  in_tnf    -> va_endo;
  in_il6    -> cl_crp [label="hepatic"];
  in_il8    -> im_neutro;
  in_mcp1   -> im_macro;
  in_paf    -> va_perm;
  in_hmgb1  -> in_tlr4 [label="late"];

  // INNATE IMMUNE EFFECTORS
  im_neutro -> im_nets;
  im_neutro -> im_mpo;
  im_macro  -> im_damps;
  im_macro  -> in_tnf;
  im_macro  -> in_il6;
  im_complement -> im_neutro;
  im_kallikrein -> va_perm;
  im_resolvins  -> im_m2 [color="blue"];
  im_m2        -> re_regeneration [color="blue"];

  // VASCULAR
  in_tnf -> va_icam;
  va_icam -> im_neutro [label="adhesion"];
  va_endo -> va_perm;
  va_endo -> va_thrombin;
  va_thrombin -> va_dic;
  va_perm -> va_ischemia;
  va_ischemia -> de_necrosis;
  va_no -> mo_shock;
  va_et1 -> va_ischemia;
  va_glycocalyx -> va_perm;

  // LOCAL COMPLICATIONS
  de_necrosis -> lo_apfc;
  lo_apfc -> lo_pseudocyst;
  de_necrosis -> lo_anc;
  lo_anc -> lo_won;
  lo_anc -> lo_infected [label="bacteria"];
  lo_won -> lo_infected;
  va_thrombin -> lo_gd_thrombosis;
  lo_won -> lo_pseudoaneurysm;
  lo_won -> lo_colonic;

  // GUT TRANSLOCATION
  va_perm -> gu_barrier;
  in_tnf -> gu_barrier;
  gu_barrier -> gu_zo1 [label="↓"];
  gu_zo1 -> gu_translocation;
  gu_microbiome -> gu_translocation;
  gu_translocation -> gu_lps;
  gu_lps -> in_tlr4 [color="red"];
  gu_lps -> lo_infected;
  va_perm -> gu_ileus;
  gu_ileus -> gu_iah;
  gu_iah -> gu_acs;
  gu_acs -> mo_aki;
  gu_acs -> mo_ards;

  // SIRS → MODS
  in_il1b -> mo_sirs;
  in_il6 -> mo_sirs;
  in_tnf -> mo_sirs;
  mo_sirs -> mo_sepsis;
  lo_infected -> mo_sepsis;
  va_perm -> mo_shock;
  mo_shock -> mo_lactate;
  mo_sirs -> mo_ards;
  mo_sirs -> mo_aki;
  mo_sirs -> mo_hepatic;
  mo_sirs -> mo_cns;
  mo_ards -> mo_sofa;
  mo_aki -> mo_sofa;
  mo_hepatic -> mo_sofa;
  mo_cns -> mo_sofa;
  mo_sofa -> mo_mods;
  mo_mods -> cl_atlanta_sev;
  mo_mods -> cl_mortality;

  // PAIN
  tr_autodigest -> pa_visceral;
  in_il1b -> pa_visceral;
  pa_visceral -> pa_pge2;
  pa_visceral -> pa_trpv1;
  pa_visceral -> pa_substanceP;
  pa_visceral -> pa_cgrp;
  pa_substanceP -> pa_spinal;
  pa_pge2 -> pa_spinal;
  pa_spinal -> pa_vas;
  pa_opioid_R -> pa_spinal [label="inhibits", color="blue", style=dashed];

  // CLINICAL ENDPOINTS
  tr_trypsin -> cl_lipase [label="↑"];
  tr_trypsin -> cl_amylase;
  cl_lipase -> cl_atlanta_mild [label="diagnosis"];
  cl_crp -> cl_apache;
  mo_sofa -> cl_apache;
  mo_sofa -> cl_bisap;
  mo_sofa -> cl_ranson;
  de_necrosis -> cl_ctsi;
  cl_apache -> cl_atlanta_mod;
  cl_apache -> cl_atlanta_sev;
  cl_atlanta_sev -> cl_mortality;
  cl_atlanta_sev -> cl_los;
  cl_atlanta_mod -> cl_los;
  cl_atlanta_mild -> cl_recurrence;
  cl_atlanta_sev -> cl_diabetes;

  // LATE / RECOVERY
  in_il10  -> re_cars;
  re_treg  -> re_cars;
  re_tgfb  -> re_cars;
  re_cars  -> re_immunosuppress;
  re_immunosuppress -> mo_sepsis [label="late infection", color="red"];
  de_necrosis -> re_exocrine;
  de_necrosis -> re_endocrine;
  re_endocrine -> cl_diabetes;
  re_regeneration -> re_exocrine [label="restores", color="blue", style=dashed];

  // DRUG INTERVENTIONS (blue dashed = inhibits, green dashed = supports)
  dr_fluid_LR   -> va_perm        [label="↓ hypovolemia", color="blue", style=dashed];
  dr_fluid_LR   -> va_ischemia    [label="↑ perfusion", color="blue", style=dashed];
  dr_fluid_LR   -> mo_aki         [label="prevents", color="blue", style=dashed];
  dr_fluid_NS   -> va_perm        [color="blue", style=dashed];
  dr_nsaid_indo -> in_nfkb        [label="↓ NF-κB", color="blue", style=dashed];
  dr_nsaid_indo -> pa_pge2        [label="COX-2 ↓", color="blue", style=dashed];
  dr_nsaid_indo -> cl_atlanta_mild [label="PEP prevention", color="blue", style=dashed];
  dr_nsaid_diclo-> pa_pge2        [color="blue", style=dashed];
  dr_octreotide -> tr_trypsin     [label="↓ secretion", color="blue", style=dashed];
  dr_octreotide -> in_tnf         [color="blue", style=dashed];
  dr_gabexate   -> tr_trypsin     [label="inhibits", color="blue", style=dashed];
  dr_gabexate   -> tr_chymo       [color="blue", style=dashed];
  dr_gabexate   -> tr_elastase    [color="blue", style=dashed];
  dr_nafamostat -> tr_trypsin     [color="blue", style=dashed];
  dr_nafamostat -> in_nfkb        [color="blue", style=dashed];
  dr_ulinastatin -> tr_trypsin    [color="blue", style=dashed];
  dr_ulinastatin -> im_neutro     [label="↓ elastase", color="blue", style=dashed];
  dr_atb_meropenem -> lo_infected [label="↓ infection", color="blue", style=dashed];
  dr_atb_cipro  -> lo_infected    [color="blue", style=dashed];
  dr_opioid_fent-> pa_opioid_R    [color="blue", style=dashed];
  dr_opioid_morph-> pa_opioid_R   [color="blue", style=dashed];
  dr_ppi        -> ac_acinar      [style=dotted];
  dr_apheresis  -> eti_htg        [label="↓ TG", color="blue", style=dashed];
  dr_ercp_emergent -> eti_gallstones [label="extract stone", color="blue", style=dashed];
  dr_drainage   -> lo_won         [color="blue", style=dashed];
  dr_drainage   -> lo_infected    [color="blue", style=dashed];
  dr_nutrition  -> gu_barrier     [label="EN protects", color="darkgreen", style=dashed];
  dr_nutrition  -> gu_translocation [color="darkgreen", style=dashed];
  dr_anakinra   -> in_il1b        [label="IL-1Ra", color="blue", style=dashed];
}
