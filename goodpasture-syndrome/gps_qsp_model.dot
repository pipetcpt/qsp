digraph GPS_QSP {
    rankdir=LR;
    compound=true;
    splines=curved;
    graph [fontname="Helvetica", fontsize=11, bgcolor="#F8F8F8", nodesep=0.4, ranksep=0.8];
    node  [fontname="Helvetica", fontsize=9, style="filled,rounded", shape=box, margin="0.15,0.08"];
    edge  [fontname="Helvetica", fontsize=8, arrowsize=0.7];

    /* =====================================================
       CLUSTER 1 - Genetic / Environmental Risk Factors
       ===================================================== */
    subgraph cluster_genetics {
        label="Genetic and Environmental Risk";
        style=filled; fillcolor="#FFF3E0"; color="#E65100"; penwidth=2;
        fontname="Helvetica-Bold"; fontsize=12;

        HLA_DR15         [label="HLA-DR15\n(highest risk allele)", shape=diamond, fillcolor="#FF7043"];
        HLA_DR7          [label="HLA-DR7\n(risk allele)", shape=diamond, fillcolor="#FF8A65"];
        HLA_DR1          [label="HLA-DR1\n(protective allele)", shape=diamond, fillcolor="#A5D6A7"];
        PTPN22           [label="PTPN22\npolymorphism", shape=diamond, fillcolor="#FF8A65"];
        smoking_exp      [label="Cigarette\nSmoking", shape=ellipse, fillcolor="#FFCC80"];
        hydrocarbon_exp  [label="Hydrocarbon\nExposure", shape=ellipse, fillcolor="#FFCC80"];
        silica_dust      [label="Silica Dust\nInhalation", shape=ellipse, fillcolor="#FFCC80"];
        viral_infection  [label="Viral Infection\n(lung epithelium)", shape=ellipse, fillcolor="#FFAB40"];
        lung_injury_trig [label="Lung Injury\nTrigger", shape=octagon, fillcolor="#FF7043"];
        genetic_suscept  [label="Genetic\nSusceptibility", shape=hexagon, fillcolor="#FF5722"];
    }

    /* =====================================================
       CLUSTER 2 - Goodpasture Antigen (Collagen IV NC1)
       ===================================================== */
    subgraph cluster_antigen {
        label="Goodpasture Antigen - Collagen IV a3 NC1";
        style=filled; fillcolor="#FCE4EC"; color="#880E4F"; penwidth=2;
        fontname="Helvetica-Bold"; fontsize=12;

        COL4A3_NC1       [label="a3(IV)NC1\nGoodpasture Domain", shape=box3d, fillcolor="#E91E63"];
        alpha3_EA        [label="a3 Epitope EA\n(immunodominant)", shape=box3d, fillcolor="#F06292"];
        alpha3_EB        [label="a3 Epitope EB\n(immunodominant)", shape=box3d, fillcolor="#F06292"];
        COL4A5           [label="a5(IV)NC1\n(cross-reactive)", shape=box3d, fillcolor="#F48FB1"];
        GBM_structure    [label="Glomerular\nBasement Membrane", shape=cylinder, fillcolor="#AD1457"];
        ABM_structure    [label="Alveolar\nBasement Membrane", shape=cylinder, fillcolor="#AD1457"];
        cryptic_epitope  [label="Cryptic\nEpitope Exposure", shape=oval, fillcolor="#EC407A"];
        epitope_spread   [label="Epitope\nSpreading", shape=oval, fillcolor="#FF4081"];
        NC1_hexamer      [label="NC1 Hexamer\nDissociation", shape=oval, fillcolor="#E91E63"];
        sulfilimine_bond [label="Sulfilimine Bond\nDisruption", shape=oval, fillcolor="#F8BBD0"];
    }

    /* =====================================================
       CLUSTER 3 - B cell / Autoantibody Production
       ===================================================== */
    subgraph cluster_bcell {
        label="B Cell Compartment and Autoantibody Production";
        style=filled; fillcolor="#E8EAF6"; color="#1A237E"; penwidth=2;
        fontname="Helvetica-Bold"; fontsize=12;

        naive_B          [label="Naive\nB Cell", shape=ellipse, fillcolor="#9FA8DA"];
        activated_B      [label="Activated\nB Cell", shape=ellipse, fillcolor="#7986CB"];
        germinal_center  [label="Germinal Center\nReaction", shape=diamond, fillcolor="#5C6BC0"];
        Tfh_cells        [label="T Follicular\nHelper (Tfh)", shape=ellipse, fillcolor="#3949AB"];
        plasma_cells     [label="Long-lived\nPlasma Cell", shape=box, fillcolor="#1A237E", fontcolor="white"];
        memory_B         [label="Memory\nB Cell", shape=ellipse, fillcolor="#3F51B5"];
        IgG1_antiGBM     [label="Anti-GBM IgG1\n(complement-fixing)", shape=box, fillcolor="#FF1744", fontcolor="white"];
        IgG4_antiGBM     [label="Anti-GBM IgG4\n(non-complement)", shape=box, fillcolor="#FF6D00"];
        anti_GBM_titer   [label="Anti-GBM\nAntibody Titer", shape=note, fillcolor="#FF5252"];
        ANA_negative     [label="ANA\nNegative", shape=oval, fillcolor="#A5D6A7"];
        ANCA_overlap     [label="ANCA Overlap\n(MPO-ANCA+)", shape=hexagon, fillcolor="#FF8A80"];
    }

    /* =====================================================
       CLUSTER 4 - Complement Activation
       ===================================================== */
    subgraph cluster_complement {
        label="Complement System Activation";
        style=filled; fillcolor="#E0F7FA"; color="#006064"; penwidth=2;
        fontname="Helvetica-Bold"; fontsize=12;

        C1q              [label="C1q\n(pattern recognition)", shape=ellipse, fillcolor="#80DEEA"];
        C1r_C1s          [label="C1r/C1s\n(serine proteases)", shape=ellipse, fillcolor="#80DEEA"];
        C4b2a            [label="C3 Convertase\nC4b2a (classical)", shape=diamond, fillcolor="#26C6DA"];
        C3               [label="C3\n(central complement)", shape=ellipse, fillcolor="#00BCD4"];
        C3b              [label="C3b\n(opsonin)", shape=ellipse, fillcolor="#00ACC1"];
        C3a              [label="C3a\n(anaphylatoxin)", shape=ellipse, fillcolor="#FF8A65"];
        C5               [label="C5\n(terminal pathway)", shape=ellipse, fillcolor="#0097A7"];
        C5a              [label="C5a\n(potent anaphylatoxin)", shape=octagon, fillcolor="#FF5722", fontcolor="white"];
        C5b              [label="C5b\n(MAC seed)", shape=ellipse, fillcolor="#00838F"];
        MAC_C5b9         [label="MAC C5b-9\n(membrane attack)", shape=box, fillcolor="#C62828", fontcolor="white"];
        Factor_H         [label="Factor H\n(decay accelerating)", shape=ellipse, fillcolor="#69F0AE"];
        Factor_B         [label="Factor B\n(alternative)", shape=ellipse, fillcolor="#4DB6AC"];
        Factor_D         [label="Factor D\n(alt. pathway)", shape=ellipse, fillcolor="#4DB6AC"];
        Properdin        [label="Properdin P\n(stabilizer)", shape=ellipse, fillcolor="#FF8A65"];
        CD59             [label="CD59\n(MAC inhibitor)", shape=ellipse, fillcolor="#69F0AE"];
        CR1              [label="CR1\n(C3b receptor)", shape=ellipse, fillcolor="#80CBC4"];
        MBL_MASP         [label="MBL/MASP\n(lectin pathway)", shape=ellipse, fillcolor="#B2EBF2"];
        C5aR1            [label="C5aR1\n(receptor on neutrophils)", shape=box, fillcolor="#FF7043"];
    }

    /* =====================================================
       CLUSTER 5 - Immune Mediators and Effector Cells
       ===================================================== */
    subgraph cluster_mediators {
        label="Immune Mediators and Effector Cells";
        style=filled; fillcolor="#FFF8E1"; color="#F57F17"; penwidth=2;
        fontname="Helvetica-Bold"; fontsize=12;

        neutrophil_renal [label="Neutrophil\n(glomerular)", shape=ellipse, fillcolor="#FF6F00"];
        MPO_activity     [label="Myeloperoxidase\n(MPO)", shape=box, fillcolor="#FF8F00"];
        elastase         [label="Neutrophil\nElastase", shape=box, fillcolor="#FFA000"];
        ROS              [label="Reactive Oxygen\nSpecies (ROS)", shape=octagon, fillcolor="#E53935", fontcolor="white"];
        IL_1b            [label="IL-1b\n(pro-inflammatory)", shape=ellipse, fillcolor="#FF5252"];
        IL_6             [label="IL-6\n(pleiotropic)", shape=ellipse, fillcolor="#FF5252"];
        TNF_alpha        [label="TNF-a\n(pro-inflammatory)", shape=ellipse, fillcolor="#FF1744", fontcolor="white"];
        CXCL8            [label="CXCL8/IL-8\n(neutrophil chemo)", shape=ellipse, fillcolor="#FF6D00"];
        MCP1             [label="MCP-1/CCL2\n(monocyte chemo)", shape=ellipse, fillcolor="#FF6D00"];
        FcgammaRIII      [label="FcgRIII\n(CD16 on neutrophils)", shape=box, fillcolor="#FF8A65"];
        NF_kB            [label="NF-kB\n(transcription factor)", shape=diamond, fillcolor="#D32F2F", fontcolor="white"];
        monocyte_macro   [label="Monocyte/\nMacrophage", shape=ellipse, fillcolor="#FF8F00"];
        T_cell_CD4       [label="CD4+ T Cell\n(helper)", shape=ellipse, fillcolor="#7B1FA2", fontcolor="white"];
        T_cell_CD8       [label="CD8+ T Cell\n(cytotoxic)", shape=ellipse, fillcolor="#6A1B9A", fontcolor="white"];
        Treg_cell        [label="T Regulatory\nCell (Treg)", shape=ellipse, fillcolor="#388E3C", fontcolor="white"];
        NET_formation    [label="NET\nFormation", shape=octagon, fillcolor="#BF360C", fontcolor="white"];
        IFN_gamma        [label="IFN-g\n(macrophage activation)", shape=ellipse, fillcolor="#E53935"];
    }

    /* =====================================================
       CLUSTER 6 - Renal Pathology
       ===================================================== */
    subgraph cluster_renal {
        label="Renal Pathology - RPGN";
        style=filled; fillcolor="#FFEBEE"; color="#B71C1C"; penwidth=2;
        fontname="Helvetica-Bold"; fontsize=12;

        GBM_dep_IgG      [label="Linear IgG\nDeposition on GBM", shape=box, fillcolor="#EF5350"];
        GBM_disruption   [label="GBM\nDisruption", shape=box, fillcolor="#E53935"];
        crescent_form    [label="Crescent\nFormation", shape=box3d, fillcolor="#C62828", fontcolor="white"];
        parietal_epi     [label="Parietal Epithelial\nCell Proliferation", shape=ellipse, fillcolor="#D32F2F", fontcolor="white"];
        fibrin_dep       [label="Fibrin\nDeposition", shape=box, fillcolor="#E57373"];
        podocyte_injury  [label="Podocyte\nInjury", shape=ellipse, fillcolor="#EF9A9A"];
        tubular_injury   [label="Tubular\nInjury", shape=ellipse, fillcolor="#EF9A9A"];
        bowman_space     [label="Bowman Space\nObliteration", shape=box, fillcolor="#C62828", fontcolor="white"];
        RPGN             [label="RPGN\n(Rapidly Progressive GN)", shape=octagon, fillcolor="#B71C1C", fontcolor="white"];
        GFR_compartment  [label="GFR\n(mL/min/1.73m2)", shape=note, fillcolor="#FF8A80"];
        proteinuria      [label="Proteinuria\n(g/day)", shape=note, fillcolor="#FF8A80"];
        hematuria        [label="Hematuria\n(RBC casts)", shape=note, fillcolor="#FF8A80"];
        dialysis_risk    [label="Dialysis\nRequirement", shape=box, fillcolor="#B71C1C", fontcolor="white"];
        renal_fibrosis   [label="Renal\nFibrosis/Sclerosis", shape=box, fillcolor="#D32F2F", fontcolor="white"];
        TGF_beta_renal   [label="TGF-b\n(fibrogenic)", shape=ellipse, fillcolor="#FF7043"];
        glom_necrosis    [label="Glomerular\nNecrosis", shape=box, fillcolor="#B71C1C", fontcolor="white"];
    }

    /* =====================================================
       CLUSTER 7 - Pulmonary Pathology
       ===================================================== */
    subgraph cluster_pulmonary {
        label="Pulmonary Pathology - DAH";
        style=filled; fillcolor="#F1F8E9"; color="#1B5E20"; penwidth=2;
        fontname="Helvetica-Bold"; fontsize=12;

        ABM_IgG_linear   [label="Linear IgG\nDeposition on ABM", shape=box, fillcolor="#E53935"];
        alv_cap_damage   [label="Alveolar-Capillary\nBarrier Damage", shape=box, fillcolor="#FF5722"];
        DAH              [label="Diffuse Alveolar\nHemorrhage (DAH)", shape=octagon, fillcolor="#C62828", fontcolor="white"];
        type2_pneumo     [label="Type II\nPneumocyte Injury", shape=ellipse, fillcolor="#FF7043"];
        alv_macro        [label="Alveolar\nMacrophage", shape=ellipse, fillcolor="#FF8F00"];
        hemosiderin_mac  [label="Hemosiderin-laden\nMacrophage", shape=ellipse, fillcolor="#795548", fontcolor="white"];
        BAL_blood        [label="BAL\nBlood-tinged", shape=note, fillcolor="#EF9A9A"];
        resp_failure     [label="Respiratory\nFailure", shape=octagon, fillcolor="#B71C1C", fontcolor="white"];
        pulm_fibrosis    [label="Pulmonary\nFibrosis", shape=box, fillcolor="#6D4C41", fontcolor="white"];
        DLCO_compartment [label="DLCO\n(percent predicted)", shape=note, fillcolor="#EF9A9A"];
        PaO2             [label="PaO2\n(mmHg)", shape=note, fillcolor="#EF9A9A"];
        hemoptysis       [label="Hemoptysis\n(clinical sign)", shape=box, fillcolor="#D32F2F", fontcolor="white"];
        neutrophil_lung  [label="Neutrophil\n(alveolar)", shape=ellipse, fillcolor="#FF6F00"];
        surfactant_loss  [label="Surfactant\nDepletion", shape=box, fillcolor="#FF7043"];
    }

    /* =====================================================
       CLUSTER 8 - Drug PK Compartments
       ===================================================== */
    subgraph cluster_pk {
        label="Drug PK Compartments";
        style=filled; fillcolor="#E8F5E9"; color="#2E7D32"; penwidth=2;
        fontname="Helvetica-Bold"; fontsize=12;

        plex_session     [label="Plasmapheresis\nSession (7x)", shape=box, fillcolor="#1565C0", fontcolor="white"];
        plex_volume      [label="Plasma Volume\nExchanged", shape=note, fillcolor="#42A5F5"];
        CY_dose          [label="Cyclophosphamide\nDose (oral/IV)", shape=box, fillcolor="#6A1B9A", fontcolor="white"];
        CY_central       [label="CY Central\nCompartment", shape=ellipse, fillcolor="#AB47BC"];
        CY_metabolite    [label="4-OH-CY\n(active metabolite)", shape=ellipse, fillcolor="#7B1FA2", fontcolor="white"];
        PRED_dose        [label="Prednisolone\nDose (mg/day)", shape=box, fillcolor="#E65100", fontcolor="white"];
        PRED_central     [label="PRED Central\nCompartment", shape=ellipse, fillcolor="#FFA726"];
        RTX_dose         [label="Rituximab\nDose (375 mg/m2)", shape=box, fillcolor="#0D47A1", fontcolor="white"];
        RTX_central      [label="RTX Central\nCompartment", shape=ellipse, fillcolor="#42A5F5"];
        RTX_peripheral   [label="RTX Peripheral\nCompartment", shape=ellipse, fillcolor="#90CAF9"];
        AVA_dose         [label="Avacopan\nDose (30 mg BID)", shape=box, fillcolor="#004D40", fontcolor="white"];
        AVA_central      [label="Avacopan Central\nCompartment", shape=ellipse, fillcolor="#26A69A"];
    }

    /* =====================================================
       CLUSTER 9 - Drug Targets and PD
       ===================================================== */
    subgraph cluster_pd {
        label="Drug Targets and Pharmacodynamics";
        style=filled; fillcolor="#F3E5F5"; color="#4A148C"; penwidth=2;
        fontname="Helvetica-Bold"; fontsize=12;

        IgG_removal_plex [label="IgG Removal\n(plasmapheresis)", shape=box, fillcolor="#1565C0", fontcolor="white"];
        B_dep_RTX        [label="B Cell Depletion\n(rituximab/CD20)", shape=box, fillcolor="#0D47A1", fontcolor="white"];
        alkylation_CY    [label="DNA Alkylation\n(cyclophosphamide)", shape=box, fillcolor="#6A1B9A", fontcolor="white"];
        C5aR_block_AVA   [label="C5aR1 Blockade\n(avacopan)", shape=box, fillcolor="#004D40", fontcolor="white"];
        GR_act_PRED      [label="GR Activation\n(prednisolone)", shape=box, fillcolor="#E65100", fontcolor="white"];
        plasma_cell_supp [label="Plasma Cell\nSuppression", shape=box, fillcolor="#7B1FA2", fontcolor="white"];
        anti_GBM_norm    [label="Anti-GBM Ab\nNormalization", shape=box, fillcolor="#388E3C", fontcolor="white"];
        immunogenicity   [label="Drug\nImmunogenicity", shape=box, fillcolor="#FF8A80"];
        clinical_resp    [label="Clinical\nResponse", shape=hexagon, fillcolor="#43A047", fontcolor="white"];
        loss_of_resp     [label="Loss of\nResponse", shape=hexagon, fillcolor="#E53935", fontcolor="white"];
        NK_cell_ADCC     [label="NK Cell ADCC\n(rituximab mechanism)", shape=ellipse, fillcolor="#1565C0", fontcolor="white"];
        CD20_target      [label="CD20 Antigen\n(B cell surface)", shape=ellipse, fillcolor="#42A5F5"];
    }

    /* =====================================================
       CLUSTER 10 - Clinical Endpoints
       ===================================================== */
    subgraph cluster_endpoints {
        label="Clinical Endpoints and Outcomes";
        style=filled; fillcolor="#E8EAF6"; color="#283593"; penwidth=2;
        fontname="Helvetica-Bold"; fontsize=12;

        anti_GBM_serum   [label="Serum Anti-GBM\nAntibody (ELISA)", shape=note, fillcolor="#EF9A9A"];
        serum_creatinine [label="Serum Creatinine\n(mg/dL)", shape=note, fillcolor="#EF9A9A"];
        GFR_trend        [label="GFR Trajectory\n(CKD-EPI)", shape=note, fillcolor="#FFCC02"];
        proteinuria_24h  [label="24h Proteinuria\n(g/24h)", shape=note, fillcolor="#EF9A9A"];
        DLCO_percent     [label="DLCO\n(percent predicted)", shape=note, fillcolor="#EF9A9A"];
        dialysis_dep     [label="Dialysis\nDependency", shape=octagon, fillcolor="#B71C1C", fontcolor="white"];
        pulm_remission   [label="Pulmonary\nRemission", shape=hexagon, fillcolor="#43A047", fontcolor="white"];
        renal_remission  [label="Renal\nRemission", shape=hexagon, fillcolor="#43A047", fontcolor="white"];
        one_yr_survival  [label="1-Year\nSurvival (%)", shape=hexagon, fillcolor="#2E7D32", fontcolor="white"];
        disease_relapse  [label="Disease\nRelapse", shape=octagon, fillcolor="#E53935", fontcolor="white"];
        BVAS_score       [label="BVAS Score\n(vasculitis activity)", shape=note, fillcolor="#FF8A80"];
        ESRD_risk        [label="ESRD\nRisk (%)", shape=note, fillcolor="#EF9A9A"];
    }

    /* =====================================================
       EDGES - Genetic risk to Antigen exposure
       ===================================================== */
    HLA_DR15         -> genetic_suscept  [label="highest risk", color="#E65100", penwidth=2];
    HLA_DR7          -> genetic_suscept  [label="risk allele", color="#E65100"];
    HLA_DR1          -> genetic_suscept  [label="protective", color="#43A047", style=dashed];
    PTPN22           -> genetic_suscept  [label="T cell dysreg", color="#E65100"];
    smoking_exp      -> lung_injury_trig [label="oxidant damage", color="#BF360C", penwidth=2];
    hydrocarbon_exp  -> lung_injury_trig [label="membrane disruption", color="#BF360C"];
    silica_dust      -> lung_injury_trig [label="epithelial injury", color="#BF360C"];
    viral_infection  -> lung_injury_trig [label="barrier breach", color="#BF360C"];
    lung_injury_trig -> cryptic_epitope  [label="exposes NC1", color="#880E4F", penwidth=2];
    genetic_suscept  -> T_cell_CD4      [label="antigen presentation MHC-II", color="#7B1FA2"];
    smoking_exp      -> sulfilimine_bond [label="oxidation", color="#BF360C"];

    /* =====================================================
       EDGES - Antigen Compartment Internal
       ===================================================== */
    COL4A3_NC1       -> alpha3_EA        [label="contains EA", color="#880E4F"];
    COL4A3_NC1       -> alpha3_EB        [label="contains EB", color="#880E4F"];
    NC1_hexamer      -> cryptic_epitope  [label="dissociation exposes", color="#E91E63", penwidth=2];
    sulfilimine_bond -> NC1_hexamer      [label="disruption", color="#C2185B"];
    cryptic_epitope  -> alpha3_EA        [label="epitope release", color="#E91E63"];
    alpha3_EA        -> epitope_spread   [label="initial response", color="#880E4F"];
    epitope_spread   -> alpha3_EB        [label="broadens to EB", color="#880E4F"];
    COL4A3_NC1       -> GBM_structure   [label="constituent of", color="#6A1B9A"];
    COL4A3_NC1       -> ABM_structure   [label="constituent of", color="#6A1B9A"];
    COL4A5           -> epitope_spread  [label="cross-reactive", color="#E91E63", style=dashed];

    /* =====================================================
       EDGES - Antigen to B cell activation
       ===================================================== */
    alpha3_EA        -> naive_B          [label="BCR engagement", color="#1A237E", penwidth=2];
    alpha3_EB        -> naive_B          [label="BCR engagement", color="#1A237E"];
    T_cell_CD4       -> Tfh_cells        [label="differentiation", color="#7B1FA2"];
    naive_B          -> activated_B      [label="activation", color="#3F51B5"];
    activated_B      -> germinal_center  [label="GC entry", color="#3F51B5"];
    Tfh_cells        -> germinal_center  [label="IL-21 help", color="#7B1FA2", penwidth=2];
    germinal_center  -> plasma_cells     [label="differentiation", color="#1A237E", penwidth=2];
    germinal_center  -> memory_B         [label="memory formation", color="#3F51B5"];
    plasma_cells     -> IgG1_antiGBM    [label="IgG1 secretion", color="#E53935", penwidth=2];
    plasma_cells     -> IgG4_antiGBM    [label="IgG4 secretion", color="#FF6D00"];
    IgG1_antiGBM     -> anti_GBM_titer  [label="contributes to", color="#E53935"];
    IgG4_antiGBM     -> anti_GBM_titer  [label="contributes to", color="#FF6D00"];
    memory_B         -> plasma_cells    [label="relapse reactivation", color="#E53935", style=dashed];

    /* =====================================================
       EDGES - Anti-GBM to Renal deposition
       ===================================================== */
    IgG1_antiGBM     -> GBM_dep_IgG    [label="linear IgG binding", color="#C62828", penwidth=3];
    anti_GBM_titer   -> GBM_dep_IgG    [label="titer-dependent", color="#C62828", penwidth=2];
    GBM_dep_IgG      -> FcgammaRIII    [label="Fc recruits neutrophils", color="#E53935", penwidth=2];
    FcgammaRIII      -> neutrophil_renal [label="activation via FcgRIII", color="#FF6F00", penwidth=2];
    neutrophil_renal -> MPO_activity    [label="degranulation", color="#FF8F00"];
    neutrophil_renal -> elastase        [label="degranulation", color="#FF8F00"];
    neutrophil_renal -> ROS             [label="oxidative burst", color="#E53935", penwidth=2];
    neutrophil_renal -> NET_formation   [label="NET release", color="#BF360C"];
    NET_formation    -> GBM_disruption  [label="GBM degradation", color="#B71C1C"];
    MPO_activity     -> ROS             [label="H2O2 to HOCl", color="#E53935"];
    elastase         -> GBM_disruption  [label="proteolysis", color="#B71C1C", penwidth=2];
    ROS              -> GBM_disruption  [label="oxidative damage", color="#B71C1C", penwidth=2];

    /* =====================================================
       EDGES - Complement classical pathway
       ===================================================== */
    IgG1_antiGBM     -> C1q             [label="IgG-C1q binding", color="#006064", penwidth=2];
    C1q              -> C1r_C1s         [label="activates", color="#006064"];
    C1r_C1s          -> C4b2a           [label="cleaves C4 C2", color="#006064"];
    C4b2a            -> C3              [label="C3 convertase", color="#00838F", penwidth=2];
    C3               -> C3b             [label="cleavage", color="#00838F", penwidth=2];
    C3               -> C3a             [label="cleavage", color="#FF5722", penwidth=2];
    C3b              -> C5              [label="C5 convertase", color="#00838F", penwidth=2];
    C5               -> C5a             [label="cleavage to C5a", color="#FF5722", penwidth=3];
    C5               -> C5b             [label="cleavage to C5b", color="#006064"];
    C5b              -> MAC_C5b9        [label="C5b-9 assembly", color="#C62828", penwidth=2];
    MBL_MASP         -> C4b2a           [label="lectin pathway", color="#006064", style=dashed];
    Factor_B         -> C3              [label="alt. pathway convertase", color="#006064", style=dashed];
    Factor_D         -> Factor_B        [label="cleaves Bb", color="#006064", style=dashed];
    Properdin        -> C3b             [label="stabilises alt. convertase", color="#FF8A65"];
    Factor_H         -> C3b             [label="decay acceleration (protective)", color="#43A047", arrowhead=tee, style=dashed];
    CD59             -> MAC_C5b9        [label="inhibits MAC (protective)", color="#43A047", arrowhead=tee, style=dashed];
    CR1              -> C3b             [label="phagocytosis", color="#80CBC4"];
    C5a              -> C5aR1           [label="ligand-receptor", color="#FF5722", penwidth=3];

    /* =====================================================
       EDGES - C5a/C5aR to Mediators to Tissue damage
       ===================================================== */
    C5aR1            -> neutrophil_renal [label="C5aR1-mediated\nrecruitment", color="#FF5722", penwidth=3];
    C5a              -> CXCL8           [label="upregulates", color="#FF6D00"];
    C5a              -> NF_kB           [label="activates", color="#D32F2F"];
    C5a              -> monocyte_macro  [label="recruits", color="#FF8F00"];
    C3a              -> neutrophil_renal [label="chemoattractant", color="#FF6D00"];
    MAC_C5b9         -> podocyte_injury  [label="podocyte lysis", color="#C62828", penwidth=2];
    MAC_C5b9         -> tubular_injury   [label="tubular lysis", color="#C62828"];
    NF_kB            -> IL_1b           [label="transcription", color="#D32F2F", penwidth=2];
    NF_kB            -> IL_6            [label="transcription", color="#D32F2F"];
    NF_kB            -> TNF_alpha       [label="transcription", color="#D32F2F"];
    NF_kB            -> CXCL8          [label="transcription", color="#D32F2F"];
    IL_1b            -> neutrophil_renal [label="priming", color="#FF6F00"];
    IL_6             -> plasma_cells    [label="survival factor", color="#3F51B5", style=dashed];
    TNF_alpha        -> NF_kB           [label="positive feedback", color="#D32F2F", style=dashed];
    CXCL8            -> neutrophil_renal [label="chemotaxis", color="#FF6F00", penwidth=2];
    MCP1             -> monocyte_macro  [label="chemotaxis", color="#FF8F00"];
    monocyte_macro   -> IL_1b          [label="secretes", color="#FF5252"];
    monocyte_macro   -> MCP1           [label="secretes", color="#FF6D00"];
    T_cell_CD4       -> IFN_gamma       [label="secretes", color="#E53935"];
    IFN_gamma        -> monocyte_macro  [label="activation", color="#7B1FA2"];
    T_cell_CD8       -> GBM_disruption  [label="cytotoxic T cells", color="#6A1B9A"];
    Treg_cell        -> T_cell_CD4     [label="suppression (protective)", color="#388E3C", arrowhead=tee, style=dashed];
    Treg_cell        -> NF_kB          [label="IL-10 inhibition (protective)", color="#388E3C", arrowhead=tee, style=dashed];

    /* =====================================================
       EDGES - Renal pathology cascade
       ===================================================== */
    GBM_dep_IgG      -> GBM_disruption  [label="structural compromise", color="#C62828", penwidth=2];
    GBM_disruption   -> parietal_epi    [label="signals PEC proliferation", color="#D32F2F", penwidth=2];
    GBM_disruption   -> bowman_space    [label="protein leak", color="#D32F2F"];
    parietal_epi     -> crescent_form   [label="PEC into Bowman space", color="#C62828", penwidth=3];
    fibrin_dep       -> crescent_form   [label="fibrin scaffold", color="#C62828", penwidth=2];
    IL_1b            -> fibrin_dep      [label="coagulation activation", color="#E57373"];
    crescent_form    -> bowman_space    [label="obliterates", color="#B71C1C"];
    bowman_space     -> RPGN            [label="severe nephron loss", color="#B71C1C", penwidth=3];
    podocyte_injury  -> proteinuria     [label="slit diaphragm loss", color="#FF8A65"];
    GBM_disruption   -> hematuria       [label="RBC leak", color="#E53935"];
    RPGN             -> GFR_compartment [label="GFR decline", color="#B71C1C", penwidth=3];
    RPGN             -> dialysis_risk   [label="if GFR below 10", color="#B71C1C", penwidth=2];
    GFR_compartment  -> dialysis_risk   [label="threshold", color="#B71C1C", style=dashed];
    TGF_beta_renal   -> renal_fibrosis  [label="profibrotic", color="#BF360C"];
    GBM_disruption   -> TGF_beta_renal  [label="fibrogenic stimulus", color="#FF5722"];
    renal_fibrosis   -> GFR_compartment [label="nephron loss", color="#B71C1C"];
    glom_necrosis    -> crescent_form   [label="necrosis drives crescent", color="#B71C1C"];
    GBM_disruption   -> glom_necrosis   [label="fibrinoid necrosis", color="#C62828"];
    tubular_injury   -> GFR_compartment [label="tubular dysfunction", color="#E53935"];

    /* =====================================================
       EDGES - Pulmonary pathology cascade
       ===================================================== */
    IgG1_antiGBM     -> ABM_IgG_linear  [label="linear IgG on ABM", color="#C62828", penwidth=2];
    ABM_IgG_linear   -> alv_cap_damage  [label="complement and neutrophil", color="#E53935", penwidth=2];
    lung_injury_trig -> alv_cap_damage  [label="environmental trigger", color="#BF360C", penwidth=2];
    ABM_IgG_linear   -> neutrophil_lung [label="Fc receptor activation", color="#FF6F00"];
    neutrophil_lung  -> ROS             [label="oxidative burst", color="#E53935"];
    alv_cap_damage   -> DAH             [label="barrier failure", color="#C62828", penwidth=3];
    alv_cap_damage   -> type2_pneumo   [label="type II injury", color="#FF5722"];
    type2_pneumo     -> surfactant_loss [label="surfactant deficiency", color="#FF7043"];
    surfactant_loss  -> resp_failure    [label="atelectasis", color="#B71C1C"];
    DAH              -> hemoptysis      [label="blood in airways", color="#C62828", penwidth=2];
    DAH              -> alv_macro       [label="macrophage recruitment", color="#FF8F00"];
    alv_macro        -> hemosiderin_mac [label="iron loading", color="#795548"];
    DAH              -> BAL_blood       [label="BAL finding", color="#EF9A9A"];
    DAH              -> DLCO_compartment [label="gas transfer drop", color="#C62828", penwidth=2];
    DLCO_compartment -> resp_failure    [label="severe DLCO drop", color="#B71C1C", penwidth=2];
    PaO2             -> resp_failure    [label="hypoxemia", color="#B71C1C"];
    alv_cap_damage   -> PaO2           [label="V/Q mismatch", color="#E53935"];
    pulm_fibrosis    -> DLCO_compartment [label="fibrosis drop DLCO", color="#795548"];
    alv_cap_damage   -> pulm_fibrosis  [label="TGF-b mechanism", color="#FF5722", style=dashed];
    C5a              -> neutrophil_lung  [label="lung neutrophil recruitment", color="#FF5722"];

    /* =====================================================
       EDGES - Drug PK
       ===================================================== */
    plex_session     -> plex_volume     [label="1-1.5x plasma volume", color="#1565C0"];
    CY_dose          -> CY_central      [label="absorption", color="#6A1B9A"];
    CY_central       -> CY_metabolite   [label="CYP2B6/3A4 activation", color="#7B1FA2", penwidth=2];
    PRED_dose        -> PRED_central    [label="absorption F=0.82", color="#E65100"];
    RTX_dose         -> RTX_central     [label="IV infusion", color="#1565C0"];
    RTX_central      -> RTX_peripheral  [label="distribution", color="#1565C0"];
    AVA_dose         -> AVA_central     [label="oral absorption", color="#004D40"];

    /* =====================================================
       EDGES - Drug PD (mechanism of action)
       ===================================================== */
    plex_volume      -> IgG_removal_plex [label="IgG cleared from plasma", color="#1565C0", penwidth=3];
    IgG_removal_plex -> anti_GBM_titer  [label="rapid titer drop", color="#1565C0", penwidth=3, arrowhead=tee];
    RTX_central      -> CD20_target      [label="binds CD20", color="#0D47A1", penwidth=2];
    CD20_target      -> B_dep_RTX        [label="opsonisation", color="#0D47A1", penwidth=2];
    RTX_central      -> NK_cell_ADCC     [label="ADCC", color="#1565C0"];
    NK_cell_ADCC     -> B_dep_RTX        [label="NK kills B cells", color="#1565C0"];
    B_dep_RTX        -> activated_B      [label="depletes B cells", color="#0D47A1", penwidth=3, arrowhead=tee];
    B_dep_RTX        -> plasma_cell_supp [label="indirect suppression", color="#7B1FA2"];
    CY_metabolite    -> alkylation_CY    [label="DNA crosslinking", color="#6A1B9A", penwidth=2];
    alkylation_CY    -> plasma_cells     [label="cytotoxic kill", color="#6A1B9A", penwidth=2, arrowhead=tee];
    alkylation_CY    -> T_cell_CD4      [label="lymphodepletion", color="#6A1B9A", arrowhead=tee];
    AVA_central      -> C5aR_block_AVA  [label="C5aR1 occupancy", color="#004D40", penwidth=3];
    C5aR_block_AVA   -> C5aR1           [label="competitive block", color="#004D40", penwidth=3, arrowhead=tee];
    C5aR_block_AVA   -> neutrophil_renal [label="drop recruitment", color="#26A69A", arrowhead=tee];
    PRED_central     -> GR_act_PRED     [label="receptor binding", color="#E65100", penwidth=2];
    GR_act_PRED      -> NF_kB           [label="transrepression", color="#E65100", penwidth=2, arrowhead=tee];
    GR_act_PRED      -> IL_1b           [label="drop expression", color="#E65100", arrowhead=tee];
    GR_act_PRED      -> IL_6            [label="drop expression", color="#E65100", arrowhead=tee];
    plasma_cell_supp -> anti_GBM_norm   [label="drop Ab production", color="#388E3C", penwidth=2];
    IgG_removal_plex -> anti_GBM_norm   [label="acute clearance", color="#388E3C"];
    anti_GBM_norm    -> clinical_resp   [label="serological remission", color="#43A047", penwidth=3];
    immunogenicity   -> loss_of_resp    [label="neutralizing Ab vs drug", color="#E53935"];
    RTX_central      -> immunogenicity  [label="HACA formation", color="#FF8A65", style=dashed];

    /* =====================================================
       EDGES to Clinical endpoints
       ===================================================== */
    anti_GBM_titer   -> anti_GBM_serum  [label="measured as", color="#E53935"];
    GFR_compartment  -> serum_creatinine [label="inverse relationship", color="#B71C1C"];
    GFR_compartment  -> GFR_trend       [label="longitudinal tracking", color="#FF8A65"];
    proteinuria      -> proteinuria_24h  [label="quantified", color="#E53935"];
    DLCO_compartment -> DLCO_percent    [label="measured", color="#C62828"];
    dialysis_risk    -> dialysis_dep    [label="outcome", color="#B71C1C", penwidth=3];
    resp_failure     -> pulm_remission  [label="when resolved", color="#43A047", style=dashed];
    clinical_resp    -> renal_remission [label="renal endpoint", color="#43A047", penwidth=2];
    clinical_resp    -> pulm_remission  [label="pulm endpoint", color="#43A047", penwidth=2];
    renal_remission  -> one_yr_survival [label="survival benefit", color="#2E7D32", penwidth=2];
    pulm_remission   -> one_yr_survival [label="survival benefit", color="#2E7D32"];
    dialysis_dep     -> one_yr_survival [label="drop survival", color="#B71C1C", style=dashed];
    disease_relapse  -> anti_GBM_titer  [label="Ab re-rises", color="#E53935", style=dashed];
    memory_B         -> disease_relapse [label="reactivation", color="#E53935"];
    dialysis_dep     -> ESRD_risk       [label="defines ESRD", color="#B71C1C"];
    BVAS_score       -> clinical_resp   [label="disease activity measure", color="#FF8A65"];
    GFR_trend        -> ESRD_risk       [label="GFR below 15 ESRD risk", color="#B71C1C"];
    hematuria        -> serum_creatinine [label="nephritic syndrome", color="#E53935"];
    ANCA_overlap     -> neutrophil_renal [label="ANCA neutrophil priming", color="#FF6F00"];
    ANCA_overlap     -> BVAS_score      [label="ANCA-GN features", color="#FF8A65"];
    one_yr_survival  -> clinical_resp   [label="overall outcome", color="#43A047", style=dashed];
}
