        SMAD7 -> SMAD23 [label="inhibits"]
        HSC_ACTIVE -> TGF_BETA [label="autocrine\nloop"]
        HSC_ACTIVE -> PDGFR
        PDGF -> PDGFR [label="proliferation\nsignal"]
        PDGFR -> HSC_ACTIVE [label="→proliferation"]
        HSC_ACTIVE -> COL1A1
        HSC_ACTIVE -> COL3A1
        HSC_ACTIVE -> COL4A1
        HSC_ACTIVE -> MMP2 [label="secretes"]
        HSC_ACTIVE -> MMP9
        HSC_ACTIVE -> TIMP1
        HSC_ACTIVE -> TIMP2
        HSC_ACTIVE -> LOXL2
        HSC_ACTIVE -> CONNECTIVE_TF
        HSC_ACTIVE -> ALPHA_SMA
        CONNECTIVE_TF -> COL1A1 [label="amplifies"]
        LOXL2 -> COL1A1 [label="crosslinking\nstabilizes"]
        TIMP1 -> MMP2 [label="inhibits"]
        TIMP2 -> MMP9 [label="inhibits"]
        COL1A1 -> ECM
        COL3A1 -> ECM
        COL4A1 -> ECM
        ECM -> MMP2 [label="partial\nremodeling"]
        ECM -> MMP9
