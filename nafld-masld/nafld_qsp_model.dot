digraph NAFLD_QSP_Model {
    // =====================================================================
    // NAFLD/MASLD QSP Mechanistic Map
    // Non-Alcoholic Fatty Liver Disease / Metabolic-Associated Steatotic Liver Disease
    // =====================================================================
    graph [
        rankdir=LR
        fontname="Helvetica"
        fontsize=11
        label="NAFLD/MASLD Quantitative Systems Pharmacology Model\n(Non-Alcoholic Fatty Liver Disease / Metabolic-Associated Steatotic Liver Disease)"
        labelloc=t
        labeljust=c
        overlap=false
        splines=true
        bgcolor="#f9f9f9"
        pad=0.5
    ]
    node [fontname="Helvetica" fontsize=9 style=filled]
    edge [fontname="Helvetica" fontsize=8]

    // =========================================================
    // SUBGRAPH 1: Adipose Tissue & Systemic Insulin Resistance
    // =========================================================
    subgraph cluster_adipose {
        label="Adipose Tissue & Insulin Resistance"
        style=filled
        fillcolor="#FFF3E0"
        color="#E65100"
        fontcolor="#E65100"
        fontsize=12

        ADIPOSE_TG       [label="Adipocyte TG\nStores" shape=ellipse fillcolor="#FFCC80"]
        ADIPOSE_LIPO     [label="Lipolysis\n(HSL/ATGL)" shape=box fillcolor="#FFB74D"]
        FFA_PLASMA       [label="Plasma FFA\n(NEFA)" shape=ellipse fillcolor="#FF8A65"]
        GLYCEROL         [label="Glycerol\n(gluconeogenesis)" shape=ellipse fillcolor="#FFAB40"]
        INS_RESISTANCE   [label="Insulin\nResistance" shape=diamond fillcolor="#FF7043"]
        HYPERINSULIN     [label="Hyperinsulinemia" shape=ellipse fillcolor="#FF8C42"]
        ADIPONECTIN      [label="Adiponectin↓\n(anti-inflam)" shape=ellipse fillcolor="#A5D6A7"]
        LEPTIN           [label="Leptin↑\n(pro-inflam)" shape=ellipse fillcolor="#EF9A9A"]
        RESISTIN         [label="Resistin↑\n(IR promoter)" shape=ellipse fillcolor="#EF9A9A"]
        VISFATIN         [label="Visfatin/NAMPT↑" shape=ellipse fillcolor="#EF9A9A"]
        TNF_ADIPOSE      [label="TNF-α\n(adipose)" shape=ellipse fillcolor="#EF5350"]
        IL6_ADIPOSE      [label="IL-6\n(adipose)" shape=ellipse fillcolor="#EF5350"]
        ADIPOSE_INFLAM   [label="Adipose Tissue\nInflammation (ATM)" shape=box fillcolor="#FFCDD2"]
        CERAMIDE         [label="Ceramide↑\n(lipotoxic)" shape=ellipse fillcolor="#B71C1C" fontcolor="white"]

        ADIPOSE_TG -> ADIPOSE_LIPO [label="catecholamines\nglucagon"]
        ADIPOSE_LIPO -> FFA_PLASMA [label="flux ↑↑"]
        ADIPOSE_LIPO -> GLYCEROL
        INS_RESISTANCE -> ADIPOSE_LIPO [label="disinhibition"]
        HYPERINSULIN -> INS_RESISTANCE [label="receptor\ndownregulation"]
        ADIPOSE_INFLAM -> ADIPONECTIN [label="suppresses"]
        ADIPOSE_INFLAM -> LEPTIN
        ADIPOSE_INFLAM -> RESISTIN
        ADIPOSE_INFLAM -> TNF_ADIPOSE
        ADIPOSE_INFLAM -> IL6_ADIPOSE
        TNF_ADIPOSE -> INS_RESISTANCE [label="IRS-1 serine\nphosphorylation"]
        LEPTIN -> INS_RESISTANCE
        CERAMIDE -> INS_RESISTANCE [label="PKC/PP2A\npathway"]
        FFA_PLASMA -> CERAMIDE [label="de novo synthesis"]
    }

    // =========================================================
    // SUBGRAPH 2: Pancreas & Glucose Homeostasis
    // =========================================================
    subgraph cluster_pancreas {
        label="Pancreas & Glucose Homeostasis"
        style=filled
        fillcolor="#E8F5E9"
        color="#2E7D32"
        fontcolor="#2E7D32"
        fontsize=12

        BETA_CELL       [label="Pancreatic β-cell\nFunction" shape=ellipse fillcolor="#A5D6A7"]
        INSULIN_SECR    [label="Insulin\nSecretion" shape=box fillcolor="#66BB6A"]
        PLASMA_INSULIN  [label="Plasma\nInsulin" shape=ellipse fillcolor="#43A047"]
        PLASMA_GLUCOSE  [label="Plasma\nGlucose" shape=ellipse fillcolor="#81C784"]
        GLUCAGON        [label="Glucagon\n(α-cell)" shape=ellipse fillcolor="#C8E6C9"]
        GLP1            [label="GLP-1\n(L-cell)" shape=ellipse fillcolor="#A5D6A7"]
        HOMA_IR         [label="HOMA-IR\n(clinical)" shape=parallelogram fillcolor="#E8F5E9"]
        HBA1C           [label="HbA1c\n(endpoint)" shape=parallelogram fillcolor="#C8E6C9"]

        PLASMA_GLUCOSE -> INSULIN_SECR [label="glucose-stimulated"]
        BETA_CELL -> INSULIN_SECR
        INSULIN_SECR -> PLASMA_INSULIN
        PLASMA_INSULIN -> PLASMA_GLUCOSE [label="uptake↑\nproduction↓"]
        GLP1 -> INSULIN_SECR [label="incretin\neffect"]
        GLUCAGON -> PLASMA_GLUCOSE [label="HGP↑"]
        PLASMA_INSULIN -> GLUCAGON [label="suppresses"]
        PLASMA_GLUCOSE -> HOMA_IR
        PLASMA_INSULIN -> HOMA_IR
        PLASMA_GLUCOSE -> HBA1C
    }

    // =========================================================
    // SUBGRAPH 3: Hepatic Lipid Metabolism
    // =========================================================
    subgraph cluster_liver_lipid {
        label="Hepatic Lipid Metabolism (Steatosis)"
        style=filled
        fillcolor="#E3F2FD"
        color="#1565C0"
        fontcolor="#1565C0"
        fontsize=12

        LIVER_FFA_UPTAKE [label="Hepatic FFA\nUptake (CD36/FATP)" shape=box fillcolor="#90CAF9"]
        DNL              [label="De Novo\nLipogenesis (DNL)" shape=box fillcolor="#42A5F5"]
        CHREB_SREBP1c    [label="ChREBP/\nSREBP-1c↑" shape=diamond fillcolor="#1E88E5" fontcolor="white"]
        ACC              [label="ACC\n(DNL rate-limiting)" shape=box fillcolor="#1976D2" fontcolor="white"]
        FAS              [label="FAS\n(fatty acid synthase)" shape=box fillcolor="#1565C0" fontcolor="white"]
        MALONYL_COA      [label="Malonyl-CoA↑\n(CPT-1 inhibitor)" shape=ellipse fillcolor="#90CAF9"]
        LIVER_TAG        [label="Hepatic TAG\n(triglycerides)" shape=ellipse fillcolor="#64B5F6"]
        LIVER_DAG        [label="Hepatic DAG\n(diacylglycerol)" shape=ellipse fillcolor="#42A5F5"]
        LIVER_FFA        [label="Hepatic FFA\n(lipotoxic pool)" shape=ellipse fillcolor="#2196F3"]
        VLDL_ASSEM       [label="VLDL Assembly\n& Secretion" shape=box fillcolor="#1E88E5" fontcolor="white"]
        APOB             [label="ApoB-100\n(VLDL scaffold)" shape=ellipse fillcolor="#1976D2" fontcolor="white"]
        VLDL_PLASMA      [label="Plasma VLDL\n(hypertriglycerid.)" shape=ellipse fillcolor="#90CAF9"]
        BETA_OXID        [label="Mitochondrial\nβ-Oxidation" shape=box fillcolor="#BBDEFB"]
        CPT1             [label="CPT-1\n(FA transport)" shape=box fillcolor="#90CAF9"]
        PEROX_OXID       [label="Peroxisomal\nOxidation (ACOX)" shape=box fillcolor="#BBDEFB"]
        MICR_OXID        [label="Microsomal\nω-Oxidation (CYP2E1)" shape=box fillcolor="#90CAF9"]
        STEATOSIS_SCORE  [label="Steatosis Score\n(NAS component)" shape=parallelogram fillcolor="#E3F2FD"]
        LXR              [label="LXR-α\n(nuclear receptor)" shape=diamond fillcolor="#1565C0" fontcolor="white"]
        PPAR_ALPHA       [label="PPAR-α\n(FA oxidation)" shape=diamond fillcolor="#1E88E5" fontcolor="white"]
        PPAR_DELTA       [label="PPAR-δ\n(mitochondrial)" shape=diamond fillcolor="#1E88E5" fontcolor="white"]

        FFA_PLASMA -> LIVER_FFA_UPTAKE [label="~60% of hepatic\nFFA source"]
        LIVER_FFA_UPTAKE -> LIVER_FFA
        CHREB_SREBP1c -> DNL [label="transcriptional\nactivation"]
        CHREB_SREBP1c -> ACC
        CHREB_SREBP1c -> FAS
        PLASMA_GLUCOSE -> CHREB_SREBP1c [label="ChREBP"]
        PLASMA_INSULIN -> CHREB_SREBP1c [label="SREBP-1c\nvia mTORC1"]
        DNL -> LIVER_FFA [label="~25% source"]
        ACC -> MALONYL_COA
        MALONYL_COA -> CPT1 [label="inhibits"]
        FAS -> LIVER_FFA
        LIVER_FFA -> LIVER_TAG [label="esterification"]
        LIVER_FFA -> LIVER_DAG [label="incomplete\nesterification"]
        LIVER_DAG -> INS_RESISTANCE [label="PKC-ε\nIRS-2↓"]
        LIVER_TAG -> VLDL_ASSEM [label="MTTP-dependent"]
        APOB -> VLDL_ASSEM
        VLDL_ASSEM -> VLDL_PLASMA
        CPT1 -> BETA_OXID [label="enabled when\nMalonyl-CoA↓"]
        LIVER_FFA -> BETA_OXID
        LIVER_FFA -> PEROX_OXID [label="overflow"]
        LIVER_FFA -> MICR_OXID [label="overflow\n→ ROS"]
        BETA_OXID -> LIVER_TAG [label="reduces"]
        LIVER_TAG -> STEATOSIS_SCORE
        LXR -> CHREB_SREBP1c [label="activates"]
        PPAR_ALPHA -> BETA_OXID [label="transcriptional↑"]
        PPAR_ALPHA -> CPT1 [label="↑"]
        PPAR_DELTA -> BETA_OXID [label="↑"]
    }

    // =========================================================
    // SUBGRAPH 4: Mitochondrial Dysfunction & Oxidative Stress
    // =========================================================
    subgraph cluster_oxstress {
        label="Mitochondrial Dysfunction & Oxidative Stress"
        style=filled
        fillcolor="#FCE4EC"
        color="#880E4F"
        fontcolor="#880E4F"
        fontsize=12

        MITO_ETC        [label="Mitochondrial ETC\n(Complex I-IV)" shape=box fillcolor="#F48FB1"]
        ROS             [label="ROS\n(superoxide, H2O2)" shape=ellipse fillcolor="#E91E63" fontcolor="white"]
        RNS             [label="RNS\n(peroxynitrite)" shape=ellipse fillcolor="#C2185B" fontcolor="white"]
        SOD             [label="SOD\n(antioxidant)" shape=box fillcolor="#F8BBD0"]
        GSH             [label="GSH Pool\n(glutathione)" shape=box fillcolor="#F8BBD0"]
        GPX             [label="GPx\n(glutathione peroxidase)" shape=box fillcolor="#F8BBD0"]
        CAT             [label="Catalase" shape=box fillcolor="#F8BBD0"]
        NRF2            [label="Nrf2\n(antioxidant TF)" shape=diamond fillcolor="#AD1457" fontcolor="white"]
        KEAP1           [label="Keap1\n(Nrf2 suppressor)" shape=box fillcolor="#F48FB1"]
        LIPID_PEROX     [label="Lipid Peroxidation\n(4-HNE, MDA)" shape=ellipse fillcolor="#E91E63" fontcolor="white"]
        ER_STRESS       [label="ER Stress\n(UPR)" shape=box fillcolor="#F48FB1"]
        PERK            [label="PERK\n(UPR branch)" shape=box fillcolor="#EF9A9A"]
        IRE1            [label="IRE1α\n(UPR branch)" shape=box fillcolor="#EF9A9A"]
        ATF6            [label="ATF6\n(UPR branch)" shape=box fillcolor="#EF9A9A"]
        JNK_ER          [label="JNK\n(ER stress→inflam)" shape=ellipse fillcolor="#C2185B" fontcolor="white"]
        CHOP            [label="CHOP/DDIT3\n(apoptotic TF)" shape=ellipse fillcolor="#880E4F" fontcolor="white"]
        MITO_PERMEAB    [label="Mitochondrial\nPermeability Transition" shape=box fillcolor="#F06292"]
        CYTC            [label="Cytochrome c\n(apoptosis signal)" shape=ellipse fillcolor="#E91E63" fontcolor="white"]
        MITO_BIOGEN     [label="Mitochondrial\nBiogenesis (PGC-1α)" shape=box fillcolor="#F8BBD0"]

        BETA_OXID -> MITO_ETC [label="NADH/FADH2\ngeneration"]
        MITO_ETC -> ROS [label="electron leak\n(overflow)"]
        PEROX_OXID -> ROS [label="H2O2 generation"]
        MICR_OXID -> ROS [label="CYP2E1\nuncoupling"]
        ROS -> SOD [label="substrate"]
        SOD -> GSH [label="H2O2→"]
        GPX -> GSH [label="uses/depletes"]
        CAT -> ROS [label="scavenges H2O2"]
        ROS -> KEAP1 [label="oxidizes\n→Nrf2 release"]
        KEAP1 -> NRF2 [label="ubiquitinates\n(suppresses)"]
        NRF2 -> SOD [label="↑ transcription"]
        NRF2 -> GSH [label="GCL↑"]
        NRF2 -> GPX
        NRF2 -> CAT
        ROS -> LIPID_PEROX [label="initiates"]
        LIPID_PEROX -> ER_STRESS [label="membrane\ndamage"]
        RNS -> LIPID_PEROX
        LIVER_FFA -> ER_STRESS [label="lipotoxicity\nFFA overload"]
        ER_STRESS -> PERK
        ER_STRESS -> IRE1
        ER_STRESS -> ATF6
        IRE1 -> JNK_ER [label="via TRAF2"]
        PERK -> CHOP [label="eIF2α→ATF4→"]
        CHOP -> MITO_PERMEAB [label="Bcl-2↓"]
        MITO_PERMEAB -> CYTC [label="releases"]
        ROS -> MITO_ETC [label="damage\n(vicious cycle)"]
        ROS -> MITO_BIOGEN [label="inhibits PGC-1α"]
        MITO_BIOGEN -> MITO_ETC [label="maintains capacity"]
    }

    // =========================================================
    // SUBGRAPH 5: Hepatic Inflammation (MASH)
    // =========================================================
    subgraph cluster_inflam {
        label="Hepatic Inflammation — MASH (Metabolic-Associated Steatohepatitis)"
        style=filled
        fillcolor="#FFF8E1"
        color="#E65100"
        fontcolor="#E65100"
        fontsize=12

        KUPFFER         [label="Kupffer Cell\n(M1/M2 phenotype)" shape=box fillcolor="#FFB300"]
        KUPFFER_ACT     [label="Kupffer Activation\nTLR4/TLR9 signaling" shape=box fillcolor="#FF8F00"]
        NLRP3           [label="NLRP3\nInflammasome" shape=box fillcolor="#E65100" fontcolor="white"]
        NFKB            [label="NF-κB\n(master inflam TF)" shape=diamond fillcolor="#BF360C" fontcolor="white"]
        TNF_ALPHA       [label="TNF-α\n(hepatotoxic)" shape=ellipse fillcolor="#E53935" fontcolor="white"]
        IL1B            [label="IL-1β\n(inflammasome)" shape=ellipse fillcolor="#E53935" fontcolor="white"]
        IL6_LIVER       [label="IL-6\n(hepatokine)" shape=ellipse fillcolor="#E53935" fontcolor="white"]
        IL8             [label="IL-8/CXCL8\n(neutrophil chemo)" shape=ellipse fillcolor="#EF9A9A"]
        MCP1            [label="MCP-1/CCL2\n(monocyte recruit)" shape=ellipse fillcolor="#EF9A9A"]
        NEUTROPHIL      [label="Neutrophil\nInfiltration" shape=box fillcolor="#FFCC02"]
        MONOCYTE        [label="Monocyte\nRecruitment" shape=box fillcolor="#FFB300"]
        INFLAMMATORY_MΦ [label="Inflammatory\nMacrophages" shape=box fillcolor="#E65100" fontcolor="white"]
        IFN_GAMMA       [label="IFN-γ\n(adaptive)" shape=ellipse fillcolor="#EF9A9A"]
        TH1_CD4         [label="CD4+ Th1\n(hepatic)" shape=box fillcolor="#FFCC80"]
        TH17_CD4        [label="CD4+ Th17\n(hepatic)" shape=box fillcolor="#FFCC80"]
        TREG            [label="Treg\n(anti-inflam)" shape=box fillcolor="#A5D6A7"]
        NKT             [label="NKT Cell\n(iNKT)" shape=box fillcolor="#FFCC80"]
        LPS             [label="LPS\n(gut-derived)" shape=ellipse fillcolor="#8D6E63"]
        DAMPs           [label="DAMPs\n(HMGB1, mtDNA)" shape=ellipse fillcolor="#BF360C" fontcolor="white"]
        ASK1            [label="ASK1\n(MAP3K5)" shape=box fillcolor="#E65100" fontcolor="white"]
        P38_MAPK        [label="p38 MAPK\n(stress kinase)" shape=ellipse fillcolor="#F4511E" fontcolor="white"]
        JNK             [label="JNK1/2\n(inflam kinase)" shape=ellipse fillcolor="#F4511E" fontcolor="white"]
        INFLAM_SCORE    [label="Lobular Inflammation\n(NAS component)" shape=parallelogram fillcolor="#FFF8E1"]
        CRP             [label="hsCRP\n(clinical marker)" shape=parallelogram fillcolor="#FFF3E0"]
        ALT_MARKER      [label="ALT\n(hepatocyte injury)" shape=parallelogram fillcolor="#FFE0B2"]
        AST_MARKER      [label="AST\n(hepatocyte injury)" shape=parallelogram fillcolor="#FFE0B2"]

        LPS -> KUPFFER_ACT [label="TLR4 signaling"]
        DAMPs -> KUPFFER_ACT [label="TLR9/TLR2"]
        LIPID_PEROX -> DAMPs [label="4-HNE→"]
        ROS -> DAMPs
        KUPFFER_ACT -> KUPFFER
        KUPFFER -> NFKB [label="activates"]
        KUPFFER -> NLRP3 [label="activates"]
        NLRP3 -> IL1B [label="caspase-1\ncleavage"]
        NFKB -> TNF_ALPHA
        NFKB -> IL6_LIVER
        NFKB -> IL8
        NFKB -> MCP1
        TNF_ALPHA -> NFKB [label="amplification\nloop"]
        IL8 -> NEUTROPHIL [label="recruitment"]
        MCP1 -> MONOCYTE [label="CCR2"]
        MONOCYTE -> INFLAMMATORY_MΦ [label="differentiation"]
        INFLAMMATORY_MΦ -> TNF_ALPHA
        INFLAMMATORY_MΦ -> IL1B
        INFLAMMATORY_MΦ -> IL6_LIVER
        ROS -> ASK1 [label="Trx1 release"]
        ASK1 -> JNK [label="phosphorylation"]
        ASK1 -> P38_MAPK
        JNK -> NFKB
        JNK -> HEPATOCYTE_APOPT [label="→apoptosis"]
        JNK_ER -> JNK [label="converge"]
        TH1_CD4 -> IFN_GAMMA
        IFN_GAMMA -> KUPFFER [label="M1 polarization"]
        NKT -> KUPFFER [label="FasL/TRAIL"]
        TREG -> KUPFFER [label="IL-10 M2\npolarization"]
        TNF_ALPHA -> ALT_MARKER [label="hepatocyte lysis"]
        IL1B -> ALT_MARKER
        KUPFFER -> CRP [label="via IL-6→\nliver APR"]
        IL6_LIVER -> CRP
        TNF_ALPHA -> INFLAM_SCORE
        IL1B -> INFLAM_SCORE
        NEUTROPHIL -> INFLAM_SCORE
    }

    // =========================================================
    // SUBGRAPH 6: Hepatocyte Death (Ballooning)
    // =========================================================
    subgraph cluster_hepatocyte_death {
        label="Hepatocyte Death — Ballooning & Apoptosis"
        style=filled
        fillcolor="#EFEBE9"
        color="#4E342E"
        fontcolor="#4E342E"
        fontsize=12

        HEPATOCYTE_APOPT [label="Hepatocyte\nApoptosis" shape=box fillcolor="#8D6E63"]
        HEPATOCYTE_NECROP [label="Hepatocyte\nNecroptosis/Pyroptosis" shape=box fillcolor="#6D4C41"]
        BALLOONING       [label="Hepatocyte\nBallooning" shape=ellipse fillcolor="#A1887F"]
        CASPASE3         [label="Caspase-3\n(executioner)" shape=box fillcolor="#795548" fontcolor="white"]
        CASPASE8         [label="Caspase-8\n(extrinsic)" shape=box fillcolor="#795548" fontcolor="white"]
        BCL2_FAM         [label="BCL-2 Family\n(pro-survival)" shape=box fillcolor="#A5D6A7"]
        BAX_BAK          [label="BAX/BAK\n(pro-apoptotic)" shape=box fillcolor="#EF5350"]
        CYTOKERATIN18    [label="CK-18\n(apoptosis biomarker)" shape=parallelogram fillcolor="#EFEBE9"]
        MLKL             [label="MLKL\n(necroptosis exec.)" shape=box fillcolor="#6D4C41" fontcolor="white"]
        RIPK3            [label="RIPK3\n(necrosome)" shape=box fillcolor="#5D4037" fontcolor="white"]
        FAS_FASL         [label="Fas/FasL\n(death receptor)" shape=box fillcolor="#EF5350"]
        TRAIL            [label="TRAIL/DR5\n(death receptor)" shape=box fillcolor="#EF5350"]
        BALLOON_SCORE    [label="Ballooning Score\n(NAS component)" shape=parallelogram fillcolor="#EFEBE9"]
        NAS_SCORE        [label="NAS Score\n(0–8 total)" shape=parallelogram fillcolor="#4E342E" fontcolor="white"]

        CYTC -> CASPASE3 [label="intrinsic\napoptosome"]
        CASPASE8 -> CASPASE3
        FAS_FASL -> CASPASE8 [label="DISC formation"]
        TRAIL -> CASPASE8
        BAX_BAK -> MITO_PERMEAB
        BCL2_FAM -> BAX_BAK [label="sequesters"]
        CHOP -> BAX_BAK [label="↑ expression"]
        JNK -> BCL2_FAM [label="phosphorylation\n→inactivation"]
        CASPASE3 -> BALLOONING [label="cytoskeletal\ndamage"]
        TNF_ALPHA -> FAS_FASL
        CASPASE3 -> CYTOKERATIN18
        CASPASE3 -> HEPATOCYTE_APOPT
        MLKL -> HEPATOCYTE_NECROP
        RIPK3 -> MLKL
        TNF_ALPHA -> RIPK3 [label="when caspase-8\nblocked"]
        HEPATOCYTE_APOPT -> DAMPs [label="release"]
        HEPATOCYTE_NECROP -> DAMPs
        BALLOONING -> BALLOON_SCORE
        STEATOSIS_SCORE -> NAS_SCORE [label="0-3"]
        INFLAM_SCORE -> NAS_SCORE [label="0-3"]
        BALLOON_SCORE -> NAS_SCORE [label="0-2"]
    }

    // =========================================================
    // SUBGRAPH 7: Hepatic Fibrosis
    // =========================================================
    subgraph cluster_fibrosis {
        label="Hepatic Stellate Cell Activation & Fibrogenesis"
        style=filled
        fillcolor="#E8EAF6"
        color="#283593"
        fontcolor="#283593"
        fontsize=12

        HSC_QUIES       [label="Quiescent HSC\n(Lipocyte)" shape=ellipse fillcolor="#C5CAE9"]
        HSC_ACTIVE      [label="Activated HSC\n(Myofibroblast)" shape=box fillcolor="#3949AB" fontcolor="white"]
        TGF_BETA        [label="TGF-β1\n(master fibrotic)" shape=diamond fillcolor="#1A237E" fontcolor="white"]
        SMAD23          [label="SMAD2/3\n(TGF-β downstream)" shape=box fillcolor="#283593" fontcolor="white"]
        SMAD7           [label="SMAD7\n(inhibitory)" shape=box fillcolor="#7986CB"]
        PDGF            [label="PDGF-BB\n(HSC proliferation)" shape=ellipse fillcolor="#5C6BC0" fontcolor="white"]
        PDGFR           [label="PDGFR-β\n(on HSC)" shape=box fillcolor="#3F51B5" fontcolor="white"]
        CONNECTIVE_TF   [label="CTGF/CCN2\n(fibrosis amplifier)" shape=ellipse fillcolor="#3949AB" fontcolor="white"]
        ALPHA_SMA       [label="α-SMA\n(activation marker)" shape=parallelogram fillcolor="#5C6BC0" fontcolor="white"]
        COL1A1          [label="Type I Collagen\n(COL1A1/A2)" shape=box fillcolor="#1A237E" fontcolor="white"]
        COL3A1          [label="Type III Collagen\n(COL3A1)" shape=box fillcolor="#283593" fontcolor="white"]
        COL4A1          [label="Type IV Collagen\n(basement membrane)" shape=box fillcolor="#3949AB" fontcolor="white"]
        MMP2            [label="MMP-2\n(collagen remodel)" shape=box fillcolor="#7986CB"]
        MMP9            [label="MMP-9\n(matrix degr.)" shape=box fillcolor="#7986CB"]
        TIMP1           [label="TIMP-1\n(MMP inhibitor)" shape=box fillcolor="#3949AB" fontcolor="white"]
        TIMP2           [label="TIMP-2\n(MMP inhibitor)" shape=box fillcolor="#3949AB" fontcolor="white"]
        LOXL2           [label="LOXL2\n(collagen crosslink)" shape=box fillcolor="#283593" fontcolor="white"]
        ECM             [label="ECM Accumulation\n(net fibrosis)" shape=ellipse fillcolor="#1A237E" fontcolor="white"]
        ANGII           [label="Angiotensin II\n(portal)" shape=ellipse fillcolor="#E8EAF6"]
        ENDOTHELIN1     [label="Endothelin-1\n(HSC contraction)" shape=ellipse fillcolor="#C5CAE9"]
        PORTAL_PRESSURE [label="Portal Hypertension\n(↑ sinusoidal R)" shape=parallelogram fillcolor="#283593" fontcolor="white"]
        FIBROSIS_STAGE  [label="Fibrosis Stage\n(F0–F4, Metavir)" shape=parallelogram fillcolor="#1A237E" fontcolor="white"]
        LIVER_STIFF     [label="Liver Stiffness\n(FibroScan kPa)" shape=parallelogram fillcolor="#283593" fontcolor="white"]
        ELF_SCORE       [label="ELF Score\n(non-invasive)" shape=parallelogram fillcolor="#7986CB"]
        FIB4            [label="FIB-4 Index\n(ALT/AST/platelets)" shape=parallelogram fillcolor="#7986CB"]
        HEDGEHOG        [label="Hedgehog/Gli\n(Shh→Gli2)" shape=diamond fillcolor="#7986CB"]
        WNT_BETA_CAT    [label="Wnt/β-catenin\n(fibrosis TF)" shape=diamond fillcolor="#7986CB"]
        YAP_TAZ         [label="YAP/TAZ\n(mechanosensor)" shape=diamond fillcolor="#5C6BC0" fontcolor="white"]

        HSC_QUIES -> HSC_ACTIVE [label="activation by\nTGF-β, ROS"]
        TGF_BETA -> HSC_ACTIVE [label="key driver"]
        TGF_BETA -> SMAD23 [label="canonical\npathway"]
