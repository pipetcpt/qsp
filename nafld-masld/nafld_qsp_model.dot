        GUT_MICROBIOME  [label="Gut Microbiome\nDysbiosis" shape=box fillcolor="#81C784"]
        MUCOSAL_BARRIER [label="Intestinal\nBarrier (tight junctions)" shape=box fillcolor="#A5D6A7"]
        LPS_GUT         [label="LPS/Endotoxin\n(Gram- bacteria)" shape=ellipse fillcolor="#4CAF50" fontcolor="white"]
        BACTERIAL_TRANS [label="Bacterial\nTranslocation" shape=box fillcolor="#388E3C" fontcolor="white"]
        SCFA            [label="Short-Chain FA\n(butyrate, propionate)" shape=ellipse fillcolor="#81C784"]
        TMAO            [label="TMAO\n(trimethylamine oxide)" shape=ellipse fillcolor="#EF9A9A"]
        BILE_ACIDS_GUT  [label="Gut Bile Acids\n(primary/secondary)" shape=ellipse fillcolor="#FFF59D"]
        FXR_GUT         [label="FXR\n(gut enterocyte)" shape=diamond fillcolor="#2E7D32" fontcolor="white"]
        FGF19           [label="FGF-19\n(gut→liver signal)" shape=ellipse fillcolor="#66BB6A"]
        PORTAL_LPS      [label="Portal Vein LPS\n(CD14/MD-2 complex)" shape=ellipse fillcolor="#C62828" fontcolor="white"]
        TLR4_KUPFFER    [label="TLR4 on Kupffer\n(LPS receptor)" shape=box fillcolor="#FF7043"]
        BILE_ACIDS_LIVER [label="Hepatic Bile Acids\n(CDCA, CA, DCA)" shape=ellipse fillcolor="#FFF176"]
        FXR_LIVER       [label="FXR\n(nuclear receptor)" shape=diamond fillcolor="#1B5E20" fontcolor="white"]
        SHP             [label="SHP\n(FXR downstream)" shape=box fillcolor="#388E3C" fontcolor="white"]
        CYP7A1          [label="CYP7A1\n(BA synthesis)" shape=box fillcolor="#2E7D32" fontcolor="white"]
        FGFR4           [label="FGFR4\n(hepatic FGF19R)" shape=box fillcolor="#66BB6A"]
        NTCP            [label="NTCP\n(BA uptake)" shape=box fillcolor="#81C784"]

        GUT_MICROBIOME -> MUCOSAL_BARRIER [label="dysbiosis\ndamages"]
