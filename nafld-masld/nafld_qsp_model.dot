        // ASK1 Inhibitor
        SELONSERTIB     [label="Selonsertib\n(ASK1 inhibitor)" shape=box fillcolor="#7B1FA2" style="filled,bold" fontcolor="white"]

        // CCR2/5 Antagonist
        CENICRIVIROC    [label="Cenicriviroc\n(CCR2/CCR5 antag)" shape=box fillcolor="#9C27B0" style="filled,bold" fontcolor="white"]

        // GLP-1 RAs
        SEMAGLUTIDE     [label="Semaglutide\n(GLP-1 RA)" shape=box fillcolor="#E040FB" style="filled,bold" fontcolor="white"]
        LIRAGLUTIDE     [label="Liraglutide\n(GLP-1 RA)" shape=box fillcolor="#EA80FC" style="filled,bold"]

        // SGLT2 inhibitors
        EMPAGLIFLOZIN   [label="Empagliflozin\n(SGLT2i)" shape=box fillcolor="#CE93D8" style="filled,bold"]
        DAPAGLIFLOZIN   [label="Dapagliflozin\n(SGLT2i)" shape=box fillcolor="#CE93D8" style="filled,bold"]

        // Statins
        STATIN          [label="Statins\n(HMG-CoA-R inhib)" shape=box fillcolor="#BA68C8" style="filled,bold"]

        // Combination
        SEMA_OCA_COMBO  [label="Sema+OCA\n(combination)" shape=box fillcolor="#6A1B9A" style="filled,bold" fontcolor="white"]

        // Pioglitazone
        PIOGLITAZONE    [label="Pioglitazone\n(PPARγ agonist)" shape=box fillcolor="#CE93D8" style="filled,bold"]

        // Vitamin E
        VIT_E           [label="Vitamin E\n(antioxidant)" shape=box fillcolor="#E1BEE7" style="filled,bold"]

        // Drug → Target connections
        OCA -> FXR_LIVER [label="potent\nagonist"]
        OCA -> FXR_GUT [label="agonist"]
        TROPIFEXOR -> FXR_LIVER [label="agonist"]
        RESMETIROM -> THRB_RECEPT [label="selective\nagonist"]
        THRB_RECEPT -> DNL [label="↓ SREBP-1c"]
        THRB_RECEPT -> BETA_OXID [label="↑ PGC-1α"]
        THRB_RECEPT -> LXR [label="↓ LXR→DNL"]
        ELAFIBRANOR -> PPAR_ALPHA [label="agonist"]
        ELAFIBRANOR -> PPAR_DELTA [label="agonist"]
        LANIFIBRANOR -> PPAR_ALPHA [label="pan-PPAR"]
        LANIFIBRANOR -> PPAR_DELTA
        LANIFIBRANOR -> PIOGLITAZONE [label="shares PPARγ\ntarget"]
        SELADELPAR -> PPAR_DELTA [label="selective\nagonist"]
        FIRSOCOSTAT -> ACC [label="inhibits\n→DNL↓"]
        SELONSERTIB -> ASK1 [label="inhibits\nASK1"]
        CENICRIVIROC -> MCP1 [label="CCR2 block\n→recruitment↓"]
        CENICRIVIROC -> INFLAMMATORY_MΦ [label="CCR5 block"]
        SEMAGLUTIDE -> GLP1 [label="GLP-1R\nagonist"]
        LIRAGLUTIDE -> GLP1 [label="GLP-1R\nagonist"]
        EMPAGLIFLOZIN -> PLASMA_GLUCOSE [label="SGLT2i\nglucosuria"]
        DAPAGLIFLOZIN -> PLASMA_GLUCOSE [label="SGLT2i"]
        STATIN -> LXR [label="↓ cholesterol\n→LXR less active"]
        PIOGLITAZONE -> INS_RESISTANCE [label="PPARγ→\nIR↓"]
        VIT_E -> ROS [label="scavenges"]
