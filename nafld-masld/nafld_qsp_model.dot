    OCA -> TGF_BETA [label="FXR→SHP→\nTGF-β↓" color="#6A1B9A" style=bold]
    SEMAGLUTIDE -> LIVER_TAG [label="↓ steatosis\n(NASH)" color="#9C27B0" style=bold]
    CENICRIVIROC -> FIBROSIS_STAGE [label="anti-fibrotic\n(CENTAUR)" color="#9C27B0"]
    PIOGLITAZONE -> KUPFFER [label="M2 polarization\nPPARγ" color="#9C27B0"]
    PIOGLITAZONE -> HSC_ACTIVE [label="PPARγ\nHSC inhibit" color="#9C27B0"]

    // Clinical biomarker → Disease stage
    ALT_MARKER -> MASLD_STAGE [label="screening\nbiomarker"]
    AST_MARKER -> MASLD_STAGE
    LIVER_STIFF -> FIBROSIS_STAGE [label="FibroScan\nkPa→stage"]
