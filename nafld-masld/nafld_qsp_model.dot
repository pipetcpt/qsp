        LPS_GUT -> PORTAL_LPS
        PORTAL_LPS -> TLR4_KUPFFER [label="activates"]
        TLR4_KUPFFER -> KUPFFER_ACT
        BILE_ACIDS_LIVER -> FXR_LIVER [label="activates"]
        FXR_LIVER -> SHP [label="→"]
        SHP -> CYP7A1 [label="negative\nfeedback"]
        FXR_LIVER -> TGF_BETA [label="suppresses\n(protective)"]
        SCFA -> MUCOSAL_BARRIER [label="butyrate\ntight junctions"]
        SCFA -> ADIPONECTIN [label="GPR41/43\n→ adipokine"]
        TMAO -> INS_RESISTANCE [label="worsens"]
        TMAO -> KUPFFER_ACT [label="pro-inflam"]
        FXR_LIVER -> VLDL_ASSEM [label="ApoB↓"]
        BILE_ACIDS_LIVER -> NTCP [label="NTCP-mediated\nreuptake"]
        NTCP -> BILE_ACIDS_LIVER
        ADIPOSE_INFLAM -> GUT_MICROBIOME [label="systemic inflam\n→dysbiosis"]
    }

    // =========================================================
