        ROS -> HSC_ACTIVE [label="direct\nactivation"]
        LIPID_PEROX -> TGF_BETA [label="4-HNE→TGF-β↑"]
        ANGII -> HSC_ACTIVE [label="AT1R\nmediated"]
        ENDOTHELIN1 -> HSC_ACTIVE [label="contractile\nactivation"]
        HEDGEHOG -> HSC_ACTIVE [label="Gli2 TF"]
