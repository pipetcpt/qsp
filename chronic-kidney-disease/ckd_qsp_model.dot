digraph CKD_QSP_Model {
    graph [
        label="Chronic Kidney Disease (CKD)\nQuantitative Systems Pharmacology Model\n\nRAAS · Inflammation · Fibrosis · CKD-MBD · Anemia · Cardiovascular · Drug PK/PD"
        labelloc=t
        fontsize=22
        fontname="Helvetica-Bold"
        rankdir=LR
        splines=ortho
        nodesep=0.4
        ranksep=1.0
        bgcolor="#F8F9FA"
        pad=0.8
    ]
    node [fontname="Helvetica" fontsize=9 style="filled,rounded" shape=box]
    edge [fontname="Helvetica" fontsize=7 arrowsize=0.6]

    /* ─────────────────────────────────────────────
       CLUSTER 1: CKD Pathophysiology
    ───────────────────────────────────────────── */
    subgraph cluster_ckd_path {
        label="CKD Pathophysiology" fontsize=13 fontname="Helvetica-Bold"
        style=filled fillcolor="#EBF5FB" color="#2980B9" penwidth=2

        Initial_Kidney_Injury [label="Initial Kidney\nInjury" fillcolor="#D6EAF8"]
        Diabetic_Nephropathy  [label="Diabetic\nNephropathy" fillcolor="#AED6F1"]
        Hypertensive_Nephrosclerosis [label="Hypertensive\nNephrosclerosis" fillcolor="#AED6F1"]
        Glomerulonephritis    [label="Glomerulo-\nnephritis" fillcolor="#AED6F1"]
        IgAN_CKD              [label="IgA\nNephropathy" fillcolor="#AED6F1"]
        Hyperfiltration       [label="Hyper-\nfiltration" fillcolor="#D6EAF8"]
        Glomerular_Hypertension [label="Glomerular\nHypertension" fillcolor="#D6EAF8"]
        Podocyte_Injury       [label="Podocyte\nInjury & Loss" fillcolor="#85C1E9"]
        Mesangial_Expansion   [label="Mesangial\nExpansion" fillcolor="#85C1E9"]
        Glomerulosclerosis    [label="Glomerulo-\nsclerosis" fillcolor="#5DADE2"]
        Tubular_Injury        [label="Tubular\nInjury" fillcolor="#85C1E9"]
        Tubular_Atrophy       [label="Tubular\nAtrophy" fillcolor="#5DADE2"]
        Nephron_Loss          [label="Nephron\nLoss" fillcolor="#3498DB" fontcolor=white]
        eGFR_Decline          [label="eGFR\nDecline" fillcolor="#2980B9" fontcolor=white]
        CKD_Stage             [label="CKD Stage\n(G1→G5)" fillcolor="#1A5276" fontcolor=white]
        ESKD                  [label="ESKD /\nRRT" fillcolor="#0D2137" fontcolor=white]
        Compensatory_Hypertrophy [label="Compensatory\nNephron Hypertrophy" fillcolor="#D6EAF8"]
        GFB_Disruption        [label="GFB\nDisruption" fillcolor="#85C1E9"]
        Proteinuria           [label="Proteinuria\nUACR" fillcolor="#5DADE2"]
    }

    /* ─────────────────────────────────────────────
       CLUSTER 2: RAAS (Renin-Angiotensin-Aldosterone System)
    ───────────────────────────────────────────── */
    subgraph cluster_raas {
        label="RAAS & Hemodynamics" fontsize=13 fontname="Helvetica-Bold"
        style=filled fillcolor="#EBF8F2" color="#27AE60" penwidth=2

        Angiotensinogen       [label="Angiotensino-\ngen (liver)" fillcolor="#D5F5E3"]
        Renin                 [label="Renin\n(JG cells)" fillcolor="#A9DFBF"]
        Angiotensin_I         [label="Angiotensin I" fillcolor="#A9DFBF"]
        ACE                   [label="ACE\n(endothelium)" fillcolor="#7DCEA0"]
        Angiotensin_II        [label="Angiotensin II" fillcolor="#52BE80" fontcolor=white]
        AT1R                  [label="AT1R\n(vasoconstriction)" fillcolor="#27AE60" fontcolor=white]
        AT2R                  [label="AT2R\n(vasoprotective)" fillcolor="#82E0AA"]
        ACE2                  [label="ACE2\n(counter-RAAS)" fillcolor="#A9DFBF"]
        Angiotensin_1_7       [label="Angiotensin\n1-7" fillcolor="#A9DFBF"]
        Mas_Receptor          [label="Mas Receptor\n(protective)" fillcolor="#82E0AA"]
        Aldosterone           [label="Aldosterone\n(adrenal gland)" fillcolor="#52BE80" fontcolor=white]
        MR_Kidney             [label="MR\n(kidney)" fillcolor="#27AE60" fontcolor=white]
        MR_Heart              [label="MR\n(heart)" fillcolor="#27AE60" fontcolor=white]
        Sodium_Retention      [label="Na+ Retention\nVolume Overload" fillcolor="#7DCEA0"]
        BP_Increase           [label="↑ Blood\nPressure" fillcolor="#52BE80" fontcolor=white]
        SGLT2_Transporter     [label="SGLT2\nTransporter (PCT)" fillcolor="#D5F5E3"]
        Tubuloglomerular_Feedback [label="Tubuloglomerular\nFeedback" fillcolor="#A9DFBF"]
        Macula_Densa          [label="Macula Densa\n(NaCl sensor)" fillcolor="#D5F5E3"]
    }

    /* ─────────────────────────────────────────────
       CLUSTER 3: Inflammation & Immune Activation
    ───────────────────────────────────────────── */
    subgraph cluster_inflammation {
        label="Inflammation & Immune Activation" fontsize=13 fontname="Helvetica-Bold"
        style=filled fillcolor="#FEF9E7" color="#F39C12" penwidth=2

        Pattern_Recognition   [label="PRR / TLR\nActivation" fillcolor="#FDEBD0"]
        DAMPs                 [label="DAMPs\n(HMGB1, etc.)" fillcolor="#FDEBD0"]
        NF_kB                 [label="NF-κB\nPathway" fillcolor="#FAD7A0"]
        Macrophage_M1         [label="M1 Macro-\nphage" fillcolor="#F8C471"]
        Macrophage_M2         [label="M2 Macro-\nphage" fillcolor="#F8C471"]
        Th1_Cell              [label="Th1 Cell\n(IFN-γ)" fillcolor="#F5B041"]
        Th17_Cell             [label="Th17 Cell\n(IL-17)" fillcolor="#F5B041"]
        Treg_Cell             [label="Treg Cell\n(IL-10)" fillcolor="#F0D9B5"]
        Dendritic_Cell        [label="Dendritic\nCell" fillcolor="#FAD7A0"]
        Mast_Cell             [label="Mast Cell\n(histamine)" fillcolor="#FAD7A0"]
        IL1_beta              [label="IL-1β" fillcolor="#F39C12" fontcolor=white]
        IL6_CKD               [label="IL-6" fillcolor="#F39C12" fontcolor=white]
        TNF_alpha             [label="TNF-α" fillcolor="#F39C12" fontcolor=white]
        IL10                  [label="IL-10\n(anti-inflam)" fillcolor="#FAD7A0"]
        IL17                  [label="IL-17" fillcolor="#E67E22" fontcolor=white]
        MCP1                  [label="MCP-1\n(CCL2)" fillcolor="#F5B041"]
        ICAM1                 [label="ICAM-1\nVCAM-1" fillcolor="#FAD7A0"]
        Complement_C3         [label="Complement\nC3/C5" fillcolor="#FAD7A0"]
        Oxidative_Stress      [label="Oxidative\nStress" fillcolor="#E59866"]
        ROS                   [label="ROS\nNADPH-Ox" fillcolor="#E59866"]
        NLRP3                 [label="NLRP3\nInflammasome" fillcolor="#E67E22" fontcolor=white]
    }

    /* ─────────────────────────────────────────────
       CLUSTER 4: Fibrosis Cascade
    ───────────────────────────────────────────── */
    subgraph cluster_fibrosis {
        label="Renal Fibrosis Cascade" fontsize=13 fontname="Helvetica-Bold"
        style=filled fillcolor="#F5EEF8" color="#8E44AD" penwidth=2

        TGF_beta1             [label="TGF-β1" fillcolor="#D7BDE2"]
        Smad2_3               [label="Smad2/3\n(canonical)" fillcolor="#C39BD3"]
        Smad7                 [label="Smad7\n(inhibitory)" fillcolor="#D7BDE2"]
        Smad4                 [label="Smad4" fillcolor="#C39BD3"]
        EMT                   [label="EMT\nEpithelial→Mesenchymal" fillcolor="#A569BD"]
        Myofibroblast         [label="Myofibroblast\nActivation" fillcolor="#8E44AD" fontcolor=white]
        Fibroblast_Prolif     [label="Fibroblast\nProliferation" fillcolor="#A569BD"]
        Collagen_I            [label="Collagen I/III\nDeposition" fillcolor="#7D3C98" fontcolor=white]
        Fibronectin           [label="Fibronectin\nLaminin" fillcolor="#9B59B6" fontcolor=white]
        CTGF                  [label="CTGF\n(CCN2)" fillcolor="#C39BD3"]
        PDGF                  [label="PDGF\n(fibroblast mitogen)" fillcolor="#D7BDE2"]
        MMP_Activity          [label="MMP Activity\n(MMP-2, 9)" fillcolor="#D7BDE2"]
        TIMP1                 [label="TIMP-1/2\n(MMP inhibitor)" fillcolor="#E8DAEF"]
        ECM_Accumulation      [label="ECM\nAccumulation" fillcolor="#6C3483" fontcolor=white]
        Wnt_beta_catenin      [label="Wnt/β-catenin\nPathway" fillcolor="#C39BD3"]
        mTOR_Path             [label="mTOR\nPathway" fillcolor="#D7BDE2"]
        Interstitial_Fibrosis [label="Interstitial\nFibrosis" fillcolor="#6C3483" fontcolor=white]
    }

    /* ─────────────────────────────────────────────
       CLUSTER 5: CKD-Mineral Bone Disease
    ───────────────────────────────────────────── */
    subgraph cluster_mbd {
        label="CKD-Mineral & Bone Disease (CKD-MBD)" fontsize=13 fontname="Helvetica-Bold"
        style=filled fillcolor="#FDEDEC" color="#C0392B" penwidth=2

        FGF23                 [label="FGF-23\n(osteocytes)" fillcolor="#FADBD8"]
        Klotho                [label="α-Klotho\n(co-receptor)" fillcolor="#F1948A"]
        Phosphate_Serum       [label="Serum\nPhosphate ↑" fillcolor="#F1948A"]
        Calcium_Serum         [label="Serum\nCalcium ↓" fillcolor="#FADBD8"]
        Calcitriol            [label="Calcitriol\n(1,25(OH)2D3)" fillcolor="#FADBD8"]
        Calcidiol             [label="Calcidiol\n(25(OH)D3)" fillcolor="#FADBD8"]
        CYP27B1               [label="CYP27B1\n(kidney 1α-OHase)" fillcolor="#FADBD8"]
        VDR                   [label="VDR\n(Vitamin D Receptor)" fillcolor="#F5B7B1"]
        PTH                   [label="PTH\n(parathyroid)" fillcolor="#E74C3C" fontcolor=white]
        CaSR                  [label="CaSR\n(Ca-sensing R)" fillcolor="#FADBD8"]
        PTG_Hyperplasia       [label="Parathyroid\nGland Hyperplasia" fillcolor="#C0392B" fontcolor=white]
        RANK                  [label="RANK\n(osteoclast)" fillcolor="#F1948A"]
        RANKL                 [label="RANKL\n(osteoblast)" fillcolor="#EC7063"]
        OPG                   [label="OPG\n(decoy receptor)" fillcolor="#FADBD8"]
        Osteoblast            [label="Osteoblast\n(bone formation)" fillcolor="#F5B7B1"]
        Osteoclast            [label="Osteoclast\n(bone resorption)" fillcolor="#EC7063"]
        BMD_CKD               [label="Bone Mineral\nDensity ↓" fillcolor="#C0392B" fontcolor=white]
        Vascular_Calcification [label="Vascular\nCalcification" fillcolor="#922B21" fontcolor=white]
        Uremic_Toxins         [label="Uremic\nToxins" fillcolor="#FADBD8"]
    }

    /* ─────────────────────────────────────────────
       CLUSTER 6: Anemia of CKD
    ───────────────────────────────────────────── */
    subgraph cluster_anemia {
        label="Anemia of CKD" fontsize=13 fontname="Helvetica-Bold"
        style=filled fillcolor="#E8F8F5" color="#1ABC9C" penwidth=2

        EPO_Production        [label="EPO Production\n(peritubular cells)" fillcolor="#D1F2EB"]
        Endogenous_EPO        [label="Endogenous EPO\n(plasma)" fillcolor="#A3E4D7"]
        EPOR                  [label="EPO Receptor\n(BFU-E, CFU-E)" fillcolor="#76D7C4"]
        Erythroid_Progenitors [label="Erythroid\nProgenitors (BM)" fillcolor="#76D7C4"]
        Reticulocytes         [label="Reticulocytes\n(BM→blood)" fillcolor="#45B39D"]
        Hemoglobin            [label="Hemoglobin\n(g/dL)" fillcolor="#1ABC9C" fontcolor=white]
        HIF1a                 [label="HIF-1α\nHIF-2α" fillcolor="#D1F2EB"]
        PHD_Enzyme            [label="PHD1/2/3\n(prolyl hydroxylase)" fillcolor="#A3E4D7"]
        VHL_Protein           [label="VHL Protein\n(HIF degradation)" fillcolor="#D1F2EB"]
        Iron_Stores           [label="Iron Stores\n(ferritin)" fillcolor="#A3E4D7"]
        Serum_Iron            [label="Serum Iron\nTFSAT" fillcolor="#76D7C4"]
        Hepcidin              [label="Hepcidin\n(liver)" fillcolor="#45B39D"]
        Ferroportin           [label="Ferroportin\n(iron export)" fillcolor="#A3E4D7"]
        Iron_Absorption       [label="Intestinal\nIron Absorption" fillcolor="#D1F2EB"]
        RBC_Lifespan          [label="RBC Lifespan ↓\n(uremia)" fillcolor="#76D7C4"]
        Erythropoiesis        [label="Erythropoiesis\n(BM output)" fillcolor="#45B39D"]
    }

    /* ─────────────────────────────────────────────
       CLUSTER 7: Cardiovascular Complications
    ───────────────────────────────────────────── */
    subgraph cluster_cv {
        label="Cardiovascular Complications" fontsize=13 fontname="Helvetica-Bold"
        style=filled fillcolor="#EBF5FB" color="#2C3E50" penwidth=2

        Endothelial_Dysfunction [label="Endothelial\nDysfunction" fillcolor="#BFC9CA"]
        eNOS                  [label="eNOS Activity ↓" fillcolor="#ABB2B9"]
        Nitric_Oxide          [label="Nitric Oxide ↓\n(NO)" fillcolor="#909497"]
        ADMA                  [label="ADMA\n(eNOS inhibitor)" fillcolor="#808B96"]
        LVH                   [label="LVH\nLeft Ventricular\nHypertrophy" fillcolor="#717D7E" fontcolor=white]
        Cardiac_Fibrosis_CV   [label="Cardiac\nFibrosis" fillcolor="#616A6B" fontcolor=white]
        Arterial_Stiffness    [label="Arterial\nStiffness" fillcolor="#717D7E" fontcolor=white]
        Atherosclerosis       [label="Athero-\nsclerosis" fillcolor="#616A6B" fontcolor=white]
        Volume_Overload       [label="Volume\nOverload" fillcolor="#808B96" fontcolor=white]
        Sympathetic_Activation [label="Sympathetic\nActivation" fillcolor="#ABB2B9"]
        CV_Events             [label="CV Events\n(MI, Stroke, HF)" fillcolor="#2C3E50" fontcolor=white]
        Cardiac_Output        [label="Cardiac\nOutput" fillcolor="#909497"]
        Mortality_CKD         [label="CV Mortality\n(CKD)" fillcolor="#1C2833" fontcolor=white]
    }

    /* ─────────────────────────────────────────────
       CLUSTER 8: Drug Pharmacokinetics
    ───────────────────────────────────────────── */
    subgraph cluster_drug_pk {
        label="Drug Pharmacokinetics" fontsize=13 fontname="Helvetica-Bold"
        style=filled fillcolor="#FDF2E9" color="#E67E22" penwidth=2

        /* ACE Inhibitors */
        Ramipril_PO           [label="Ramipril\n(oral)" fillcolor="#FAE5D3"]
        Ramipril_C1           [label="Ramipril\nCentral" fillcolor="#F0B27A"]
        Ramiprilat_Active     [label="Ramiprilat\n(active)" fillcolor="#E59866"]

        /* ARBs */
        Losartan_PO           [label="Losartan\n(oral)" fillcolor="#FAE5D3"]
        Losartan_C1           [label="Losartan\nCentral" fillcolor="#F0B27A"]
        EXP3174_Active        [label="EXP-3174\n(active metabolite)" fillcolor="#E59866"]

        /* nsMRA */
        Finerenone_PO         [label="Finerenone\n(oral)" fillcolor="#FAE5D3"]
        Finerenone_C1         [label="Finerenone\nCentral" fillcolor="#F0B27A"]
        Finerenone_C2         [label="Finerenone\nPeripheral" fillcolor="#E59866"]

        /* SGLT2 inhibitors */
        Dapagliflozin_PO      [label="Dapagliflozin\n(oral)" fillcolor="#FAE5D3"]
        Dapagliflozin_C1      [label="Dapagliflozin\nCentral" fillcolor="#F0B27A"]
        Empagliflozin_PO      [label="Empagliflozin\n(oral)" fillcolor="#FAE5D3"]
        Empagliflozin_C1      [label="Empagliflozin\nCentral" fillcolor="#F0B27A"]

        /* ESAs */
        Epoetin_alfa_SC       [label="Epoetin-α\n(SC/IV)" fillcolor="#FAE5D3"]
        Epoetin_C1            [label="Epoetin\nPlasma" fillcolor="#F0B27A"]
        Darbepoetin_SC        [label="Darbepoetin\n(SC)" fillcolor="#FAE5D3"]
        Darbepoetin_C1        [label="Darbepoetin\nPlasma" fillcolor="#F0B27A"]

        /* HIF-PHI */
        Roxadustat_PO         [label="Roxadustat\n(oral, HIF-PHI)" fillcolor="#FAE5D3"]
        Roxadustat_C1         [label="Roxadustat\nCentral" fillcolor="#F0B27A"]

        /* Phosphate binders */
        Sevelamer_GI          [label="Sevelamer\n(GI binding)" fillcolor="#FAE5D3"]

        /* Calcimimetics */
        Cinacalcet_PO         [label="Cinacalcet\n(oral)" fillcolor="#FAE5D3"]
        Cinacalcet_C1         [label="Cinacalcet\nCentral" fillcolor="#F0B27A"]
    }

    /* ─────────────────────────────────────────────
       CLUSTER 9: Drug Pharmacodynamics
    ───────────────────────────────────────────── */
    subgraph cluster_drug_pd {
        label="Drug Pharmacodynamics & Targets" fontsize=13 fontname="Helvetica-Bold"
        style=filled fillcolor="#F9F9F9" color="#7F8C8D" penwidth=2

        ACEi_Effect           [label="ACEi Effect\n↓Ang II, ↓Aldosterone" fillcolor="#D5DBDB"]
        ARB_Effect            [label="ARB Effect\n↓AT1R Blockade" fillcolor="#D5DBDB"]
        MRA_Effect            [label="MRA/nsMRA Effect\n↓MR Activation" fillcolor="#D5DBDB"]
        SGLT2i_Effect         [label="SGLT2i Effect\n↓Glucose/Na Reabsorption" fillcolor="#D5DBDB"]
        ESA_Effect            [label="ESA Effect\n↑EPOR Stimulation" fillcolor="#D5DBDB"]
        HIF_PHI_Effect        [label="HIF-PHI Effect\n↓PHD → ↑HIF → ↑EPO" fillcolor="#D5DBDB"]
        Phosphate_Bind_Effect [label="Phosphate Binder\n↓GI Phosphate Absorption" fillcolor="#D5DBDB"]
        Calcimimetic_Effect   [label="Calcimimetic Effect\n↑CaSR sensitivity → ↓PTH" fillcolor="#D5DBDB"]
        UACR_Reduction        [label="UACR\nReduction" fillcolor="#BFC9CA"]
        eGFR_Preservation     [label="eGFR\nPreservation" fillcolor="#BFC9CA"]
        BP_Reduction          [label="BP\nReduction" fillcolor="#BFC9CA"]
        Hb_Increase           [label="Hb\nIncrease" fillcolor="#BFC9CA"]
        PTH_Suppression       [label="PTH\nSuppression" fillcolor="#BFC9CA"]
    }

    /* ─────────────────────────────────────────────
       CLUSTER 10: Clinical Endpoints & Biomarkers
    ───────────────────────────────────────────── */
    subgraph cluster_endpoints {
        label="Clinical Endpoints & Biomarkers" fontsize=13 fontname="Helvetica-Bold"
        style=filled fillcolor="#FDFEFE" color="#17202A" penwidth=2

        eGFR_Endpoint         [label="eGFR\n(mL/min/1.73m²)" fillcolor="#D5D8DC"]
        CKD_Stage_Out         [label="CKD Stage\nG1–G5" fillcolor="#AEB6BF"]
        Creatinine            [label="Serum Creatinine\n(mg/dL)" fillcolor="#D5D8DC"]
        Cystatin_C            [label="Cystatin C\n(biomarker)" fillcolor="#D5D8DC"]
        UACR_Endpoint         [label="UACR\n(mg/g Cr)" fillcolor="#AEB6BF"]
        Proteinuria_Out       [label="24h Proteinuria\n(g/day)" fillcolor="#D5D8DC"]
        BP_Endpoint           [label="Blood Pressure\n(mmHg)" fillcolor="#AEB6BF"]
        Hb_Endpoint           [label="Hemoglobin\n(g/dL)" fillcolor="#AEB6BF"]
        PTH_Endpoint          [label="Intact PTH\n(pg/mL)" fillcolor="#D5D8DC"]
        Phosphate_Endpoint    [label="Serum Phosphate\n(mg/dL)" fillcolor="#D5D8DC"]
        FGF23_Endpoint        [label="FGF-23\n(pg/mL)" fillcolor="#D5D8DC"]
        CRP_ESR               [label="CRP / ESR\n(inflammation)" fillcolor="#D5D8DC"]
        Kidney_Volume         [label="Kidney\nVolume (ADPKD)" fillcolor="#D5D8DC"]
        Composite_Endpoint    [label="Composite Renal\nEndpoint (≥40% eGFR↓/ESKD)" fillcolor="#808B96" fontcolor=white]
        MACE                  [label="MACE\n(3-point)" fillcolor="#808B96" fontcolor=white]
        Dialysis_RRT          [label="Dialysis /\nRRT Initiation" fillcolor="#17202A" fontcolor=white]
        Transplant            [label="Kidney\nTransplant" fillcolor="#17202A" fontcolor=white]
    }

    /* ═══════════════════════════════════════════
       EDGES — CKD Pathophysiology
    ══════════════════════════════════════════= */
    Diabetic_Nephropathy  -> Initial_Kidney_Injury [color="#2980B9"]
    Hypertensive_Nephrosclerosis -> Initial_Kidney_Injury [color="#2980B9"]
    Glomerulonephritis    -> Initial_Kidney_Injury [color="#2980B9"]
    IgAN_CKD              -> Initial_Kidney_Injury [color="#2980B9"]
    Initial_Kidney_Injury -> Hyperfiltration [color="#2980B9"]
    Initial_Kidney_Injury -> Glomerular_Hypertension [color="#2980B9"]
    Hyperfiltration       -> Podocyte_Injury [color="#2980B9"]
    Hyperfiltration       -> Mesangial_Expansion [color="#2980B9"]
    Glomerular_Hypertension -> Podocyte_Injury [color="#C0392B"]
    Podocyte_Injury       -> GFB_Disruption [color="#C0392B"]
    GFB_Disruption        -> Proteinuria [color="#C0392B"]
    Mesangial_Expansion   -> Glomerulosclerosis [color="#8E44AD"]
    Podocyte_Injury       -> Glomerulosclerosis [color="#8E44AD"]
    Glomerulosclerosis    -> Nephron_Loss [color="#8E44AD" penwidth=2]
    Tubular_Injury        -> Tubular_Atrophy [color="#8E44AD"]
    Tubular_Atrophy       -> Nephron_Loss [color="#8E44AD"]
    Nephron_Loss          -> eGFR_Decline [color="#1A5276" penwidth=2]
    Nephron_Loss          -> Compensatory_Hypertrophy [color="#2980B9"]
    Compensatory_Hypertrophy -> Hyperfiltration [color="#2980B9"]
    eGFR_Decline          -> CKD_Stage [color="#1A5276" penwidth=2]
    CKD_Stage             -> ESKD [color="#0D2137" penwidth=2]
    Proteinuria           -> Tubular_Injury [color="#E74C3C"]
    Proteinuria           -> Nephron_Loss [color="#E74C3C" style=dashed]

    /* RAAS → CKD Pathophysiology */
    Angiotensinogen       -> Angiotensin_I [label="renin" color="#27AE60"]
    Renin                 -> Angiotensin_I [color="#27AE60" penwidth=2]
    Angiotensin_I         -> Angiotensin_II [label="ACE" color="#27AE60" penwidth=2]
    ACE                   -> Angiotensin_II [color="#27AE60"]
    Angiotensin_II        -> AT1R [color="#27AE60" penwidth=2]
    Angiotensin_II        -> AT2R [color="#82E0AA"]
    Angiotensin_II        -> ACE2 [label="cleaves" color="#27AE60"]
    ACE2                  -> Angiotensin_1_7 [color="#82E0AA"]
    Angiotensin_1_7       -> Mas_Receptor [color="#82E0AA"]
    AT1R                  -> Aldosterone [color="#E67E22" penwidth=2]
    AT1R                  -> BP_Increase [color="#E67E22"]
    AT1R                  -> Glomerular_Hypertension [color="#C0392B" penwidth=2]
    Aldosterone           -> MR_Kidney [color="#27AE60" penwidth=2]
    Aldosterone           -> MR_Heart [color="#27AE60"]
    MR_Kidney             -> Sodium_Retention [color="#27AE60"]
    Sodium_Retention      -> BP_Increase [color="#E67E22"]
    SGLT2_Transporter     -> Sodium_Retention [color="#27AE60" label="Na/Glc reabs."]
    Macula_Densa          -> Renin [label="low NaCl\n→↑renin" color="#27AE60"]
    Tubuloglomerular_Feedback -> Glomerular_Hypertension [color="#C0392B"]

    /* RAAS → Inflammation */
    AT1R                  -> NF_kB [color="#F39C12"]
    AT1R                  -> Oxidative_Stress [color="#E59866"]
    Aldosterone           -> NF_kB [color="#F39C12"]

    /* RAAS → Fibrosis */
    AT1R                  -> TGF_beta1 [color="#8E44AD" penwidth=2]
    Aldosterone           -> TGF_beta1 [color="#8E44AD"]
    Angiotensin_II        -> CTGF [color="#8E44AD"]

    /* Inflammation pathway */
    Initial_Kidney_Injury -> DAMPs [color="#F39C12"]
    DAMPs                 -> Pattern_Recognition [color="#F39C12"]
    Pattern_Recognition   -> NF_kB [color="#F39C12" penwidth=2]
    NF_kB                 -> IL1_beta [color="#E67E22"]
    NF_kB                 -> IL6_CKD [color="#E67E22"]
    NF_kB                 -> TNF_alpha [color="#E67E22"]
    NF_kB                 -> MCP1 [color="#F39C12"]
    NF_kB                 -> ICAM1 [color="#F39C12"]
    MCP1                  -> Macrophage_M1 [color="#F39C12" penwidth=2]
    Macrophage_M1         -> IL1_beta [color="#E67E22"]
    Macrophage_M1         -> TNF_alpha [color="#E67E22"]
    Macrophage_M1         -> ROS [color="#E59866"]
    Macrophage_M1         -> TGF_beta1 [color="#8E44AD"]
    Macrophage_M2         -> TGF_beta1 [color="#8E44AD" penwidth=2]
    Macrophage_M2         -> IL10 [color="#82E0AA"]
    Th1_Cell              -> TNF_alpha [color="#E67E22"]
    Th17_Cell             -> IL17 [color="#E67E22"]
    Treg_Cell             -> IL10 [color="#82E0AA"]
    IL6_CKD               -> Th17_Cell [color="#E67E22"]
    Dendritic_Cell        -> Th1_Cell [color="#F39C12"]
    Dendritic_Cell        -> Th17_Cell [color="#F39C12"]
    Complement_C3         -> NF_kB [color="#F39C12"]
    Oxidative_Stress      -> NF_kB [color="#F39C12"]
    ROS                   -> Oxidative_Stress [color="#E59866"]
    NLRP3                 -> IL1_beta [color="#E67E22" penwidth=2]
    Uremic_Toxins         -> NLRP3 [color="#E67E22"]
    Uremic_Toxins         -> Oxidative_Stress [color="#E59866"]

    /* Inflammation → CKD Pathophysiology */
    TNF_alpha             -> Podocyte_Injury [color="#C0392B"]
    IL1_beta              -> Glomerulosclerosis [color="#C0392B"]
    IL6_CKD               -> Mesangial_Expansion [color="#C0392B"]
    IL17                  -> Tubular_Injury [color="#C0392B"]

    /* Fibrosis pathway */
    TGF_beta1             -> Smad2_3 [color="#8E44AD" penwidth=2]
    TGF_beta1             -> Smad7 [color="#82E0AA" label="neg. fb"]
    Smad2_3               -> Smad4 [color="#8E44AD"]
    Smad4                 -> EMT [color="#8E44AD"]
    Smad4                 -> Collagen_I [color="#8E44AD" penwidth=2]
    EMT                   -> Myofibroblast [color="#8E44AD"]
    Myofibroblast         -> Collagen_I [color="#7D3C98" penwidth=2]
    Myofibroblast         -> Fibronectin [color="#9B59B6"]
    PDGF                  -> Fibroblast_Prolif [color="#8E44AD"]
    Fibroblast_Prolif     -> Myofibroblast [color="#8E44AD"]
    CTGF                  -> ECM_Accumulation [color="#8E44AD"]
    Collagen_I            -> ECM_Accumulation [color="#7D3C98" penwidth=2]
    Fibronectin           -> ECM_Accumulation [color="#9B59B6"]
    TIMP1                 -> MMP_Activity [label="inhibits" color="#82E0AA" style=dashed]
    MMP_Activity          -> ECM_Accumulation [label="limits" color="#82E0AA" arrowhead=tee]
    Wnt_beta_catenin      -> Fibroblast_Prolif [color="#8E44AD"]
    mTOR_Path             -> Myofibroblast [color="#8E44AD"]
    ECM_Accumulation      -> Interstitial_Fibrosis [color="#6C3483" penwidth=2]
    Interstitial_Fibrosis -> Tubular_Atrophy [color="#6C3483" penwidth=2]
    Interstitial_Fibrosis -> Nephron_Loss [color="#6C3483" penwidth=2]

    /* Inflammation → Fibrosis */
    IL1_beta              -> TGF_beta1 [color="#8E44AD"]
    TNF_alpha             -> TGF_beta1 [color="#8E44AD"]
    IL17                  -> TGF_beta1 [color="#8E44AD"]

    /* CKD-MBD */
    eGFR_Decline          -> Phosphate_Serum [label="↓excretion" color="#C0392B" penwidth=2]
    eGFR_Decline          -> CYP27B1 [label="↓activity" color="#C0392B"]
    eGFR_Decline          -> Klotho [label="↓expression" color="#C0392B"]
    CYP27B1               -> Calcitriol [label="1α-hydroxylation" color="#C0392B"]
    Calcidiol             -> CYP27B1 [color="#FADBD8"]
    Calcitriol            -> VDR [color="#C0392B"]
    VDR                   -> PTH [label="suppresses" color="#82E0AA" arrowhead=tee]
    VDR                   -> FGF23 [label="suppresses" color="#82E0AA" arrowhead=tee]
    Phosphate_Serum       -> FGF23 [color="#C0392B" penwidth=2]
    Phosphate_Serum       -> PTH [color="#C0392B"]
    FGF23                 -> Klotho [label="co-receptor" color="#E74C3C"]
    FGF23                 -> CYP27B1 [label="inhibits" color="#E74C3C" arrowhead=tee]
    FGF23                 -> PTH [label="suppresses" color="#82E0AA" arrowhead=tee]
    Klotho                -> FGF23 [label="signaling\namplifies" color="#E74C3C"]
    Calcium_Serum         -> CaSR [color="#FADBD8"]
    CaSR                  -> PTH [label="low Ca→↑PTH" color="#E74C3C"]
    PTH                   -> Osteoclast [color="#E74C3C" penwidth=2]
    PTH                   -> Osteoblast [color="#E74C3C" style=dashed]
    PTH                   -> CYP27B1 [color="#E74C3C"]
    PTH                   -> Calcium_Serum [label="↑resorption" color="#E74C3C"]
    PTH                   -> Phosphate_Serum [label="↑excretion" color="#82E0AA" arrowhead=tee]
    PTH                   -> Vascular_Calcification [color="#922B21"]
    Osteoblast            -> RANKL [color="#EC7063"]
    Osteoblast            -> OPG [color="#FADBD8"]
    RANKL                 -> RANK [color="#E74C3C"]
    OPG                   -> RANKL [label="decoy" color="#82E0AA" arrowhead=tee]
    RANK                  -> Osteoclast [color="#E74C3C" penwidth=2]
    Osteoclast            -> BMD_CKD [color="#C0392B"]
    Phosphate_Serum       -> Vascular_Calcification [color="#922B21" penwidth=2]
    Calcium_Serum         -> Vascular_Calcification [color="#922B21"]
    PTG_Hyperplasia       -> PTH [color="#C0392B" penwidth=2]
    PTH                   -> PTG_Hyperplasia [label="chronic\nstimulus" color="#E74C3C"]
    Uremic_Toxins         -> Vascular_Calcification [color="#922B21"]
    eGFR_Decline          -> Uremic_Toxins [color="#922B21"]

    /* Anemia of CKD */
    eGFR_Decline          -> EPO_Production [label="↓peritubular\ncells" color="#1ABC9C" penwidth=2]
    EPO_Production        -> Endogenous_EPO [color="#1ABC9C"]
    HIF1a                 -> EPO_Production [color="#1ABC9C" penwidth=2]
    PHD_Enzyme            -> HIF1a [label="hydroxylates\n(degrades)" color="#E74C3C" arrowhead=tee]
    VHL_Protein           -> HIF1a [label="degrades" color="#E74C3C" arrowhead=tee]
    Endogenous_EPO        -> EPOR [color="#1ABC9C" penwidth=2]
    EPOR                  -> Erythroid_Progenitors [color="#1ABC9C"]
    Erythroid_Progenitors -> Reticulocytes [color="#1ABC9C"]
    Reticulocytes         -> Hemoglobin [color="#1ABC9C" penwidth=2]
    Hemoglobin            -> Erythropoiesis [color="#1ABC9C"]
    Iron_Stores           -> Erythroid_Progenitors [label="iron for\nheme synth" color="#45B39D"]
    Serum_Iron            -> Erythroid_Progenitors [color="#45B39D"]
    Hepcidin              -> Ferroportin [label="degrades" color="#E74C3C" arrowhead=tee]
    Ferroportin           -> Serum_Iron [label="exports iron" color="#45B39D"]
    Iron_Absorption       -> Iron_Stores [color="#45B39D"]
    Ferroportin           -> Iron_Absorption [color="#45B39D"]
    IL6_CKD               -> Hepcidin [color="#E74C3C" penwidth=2 label="↑hepcidin"]
    Hepcidin              -> Iron_Stores [label="sequesters" color="#E74C3C"]
    RBC_Lifespan          -> Hemoglobin [label="↓RBC\nsurvival" color="#E74C3C"]
    Uremic_Toxins         -> RBC_Lifespan [color="#E74C3C"]
    Hemoglobin            -> PHD_Enzyme [label="O2 sensor" color="#1ABC9C"]

    /* Cardiovascular Complications */
    Endothelial_Dysfunction -> eNOS [label="↓" color="#2C3E50"]
    eNOS                  -> Nitric_Oxide [color="#2C3E50"]
    ADMA                  -> eNOS [label="inhibits" color="#2C3E50" arrowhead=tee]
    Uremic_Toxins         -> ADMA [color="#2C3E50"]
    Uremic_Toxins         -> Endothelial_Dysfunction [color="#2C3E50"]
    Oxidative_Stress      -> Endothelial_Dysfunction [color="#2C3E50"]
    BP_Increase           -> LVH [color="#2C3E50" penwidth=2]
    BP_Increase           -> Atherosclerosis [color="#2C3E50"]
    Volume_Overload       -> LVH [color="#2C3E50"]
    MR_Heart              -> Cardiac_Fibrosis_CV [color="#2C3E50"]
    Aldosterone           -> LVH [color="#2C3E50"]
    Aldosterone           -> Cardiac_Fibrosis_CV [color="#2C3E50"]
    Sodium_Retention      -> Volume_Overload [color="#2C3E50"]
    Vascular_Calcification -> Arterial_Stiffness [color="#2C3E50" penwidth=2]
    Atherosclerosis       -> CV_Events [color="#2C3E50" penwidth=2]
    LVH                   -> CV_Events [color="#2C3E50"]
    Cardiac_Fibrosis_CV   -> CV_Events [color="#2C3E50"]
    Sympathetic_Activation -> BP_Increase [color="#2C3E50"]
    Sympathetic_Activation -> Renin [label="↑renin\nrelease" color="#27AE60"]
    Anemia_CKD_ep         -> Cardiac_Output [color="#2C3E50"]
    Cardiac_Output        -> LVH [color="#2C3E50"]
    CV_Events             -> Mortality_CKD [color="#2C3E50" penwidth=2]

    /* Anemia node in CV cluster */
    Hemoglobin            -> Anemia_CKD_ep [label="low Hb" color="#E74C3C"]
    Anemia_CKD_ep [label="Anemia of CKD\n(low Hb)" fillcolor="#717D7E" fontcolor=white]

    /* ═══════════════════════════════════════════
       DRUG PK pathways
    ══════════════════════════════════════════= */
    Ramipril_PO           -> Ramipril_C1 [label="absorption" color="#E67E22"]
    Ramipril_C1           -> Ramiprilat_Active [label="hepatic\nactivation" color="#E67E22"]
    Losartan_PO           -> Losartan_C1 [label="absorption" color="#E67E22"]
    Losartan_C1           -> EXP3174_Active [label="CYP2C9\nmetab." color="#E67E22"]
    Finerenone_PO         -> Finerenone_C1 [label="absorption\nF=44%" color="#E67E22"]
    Finerenone_C1         -> Finerenone_C2 [label="distribution" color="#E67E22"]
    Dapagliflozin_PO      -> Dapagliflozin_C1 [label="absorption\nF=78%" color="#E67E22"]
    Empagliflozin_PO      -> Empagliflozin_C1 [label="absorption\nF=86%" color="#E67E22"]
    Epoetin_alfa_SC       -> Epoetin_C1 [label="SC ka\n0.016/h" color="#E67E22"]
    Darbepoetin_SC        -> Darbepoetin_C1 [label="SC ka\n0.011/h" color="#E67E22"]
    Roxadustat_PO         -> Roxadustat_C1 [label="absorption\nF=88%" color="#E67E22"]

    /* ═══════════════════════════════════════════
       DRUG PD pathways (PK → target)
    ══════════════════════════════════════════= */
    Ramiprilat_Active     -> ACEi_Effect [color="#D5DBDB" penwidth=2]
    EXP3174_Active        -> ARB_Effect [color="#D5DBDB" penwidth=2]
    Finerenone_C1         -> MRA_Effect [color="#D5DBDB" penwidth=2]
    Dapagliflozin_C1      -> SGLT2i_Effect [color="#D5DBDB" penwidth=2]
    Empagliflozin_C1      -> SGLT2i_Effect [color="#D5DBDB"]
    Epoetin_C1            -> ESA_Effect [color="#D5DBDB" penwidth=2]
    Darbepoetin_C1        -> ESA_Effect [color="#D5DBDB"]
    Roxadustat_C1         -> HIF_PHI_Effect [color="#D5DBDB" penwidth=2]
    Sevelamer_GI          -> Phosphate_Bind_Effect [color="#D5DBDB"]
    Cinacalcet_C1         -> Calcimimetic_Effect [color="#D5DBDB" penwidth=2]

    /* Drug PD → biological targets */
    ACEi_Effect           -> ACE [label="inhibits ACE" color="#27AE60" arrowhead=tee style=dashed]
    ACEi_Effect           -> Angiotensin_II [label="↓Ang II" color="#27AE60" arrowhead=tee style=dashed]
    ACEi_Effect           -> UACR_Reduction [color="#808B96"]
    ACEi_Effect           -> BP_Reduction [color="#808B96"]
    ARB_Effect            -> AT1R [label="blocks AT1R" color="#27AE60" arrowhead=tee style=dashed]
    ARB_Effect            -> UACR_Reduction [color="#808B96"]
    ARB_Effect            -> BP_Reduction [color="#808B96"]
    MRA_Effect            -> MR_Kidney [label="blocks MR" color="#27AE60" arrowhead=tee style=dashed]
    MRA_Effect            -> MR_Heart [label="blocks MR" color="#27AE60" arrowhead=tee style=dashed]
    MRA_Effect            -> Cardiac_Fibrosis_CV [label="↓" color="#82E0AA" arrowhead=tee style=dashed]
    MRA_Effect            -> UACR_Reduction [color="#808B96"]
    MRA_Effect            -> TGF_beta1 [label="↓" color="#82E0AA" arrowhead=tee style=dashed]
    SGLT2i_Effect         -> SGLT2_Transporter [label="inhibits" color="#27AE60" arrowhead=tee style=dashed]
    SGLT2i_Effect         -> Macula_Densa [label="↑NaCl →\n↓TGF" color="#27AE60" style=dashed]
    SGLT2i_Effect         -> eGFR_Preservation [color="#808B96"]
    SGLT2i_Effect         -> UACR_Reduction [color="#808B96"]
    SGLT2i_Effect         -> BP_Reduction [color="#808B96"]
    SGLT2i_Effect         -> HIF1a [label="↑HIF-1α" color="#1ABC9C" style=dashed]
    ESA_Effect            -> EPOR [label="mimics EPO" color="#1ABC9C" style=dashed]
    ESA_Effect            -> Hb_Increase [color="#808B96"]
    HIF_PHI_Effect        -> PHD_Enzyme [label="inhibits PHD" color="#1ABC9C" arrowhead=tee style=dashed]
    HIF_PHI_Effect        -> HIF1a [label="↑HIF-1α" color="#1ABC9C" style=dashed]
    HIF_PHI_Effect        -> Hb_Increase [color="#808B96"]
    Phosphate_Bind_Effect -> Phosphate_Serum [label="↓absorption" color="#C0392B" arrowhead=tee style=dashed]
    Calcimimetic_Effect   -> CaSR [label="↑sensitivity" color="#C0392B" style=dashed]
    Calcimimetic_Effect   -> PTH_Suppression [color="#808B96"]

    /* PD outcomes → Clinical Endpoints */
    UACR_Reduction        -> UACR_Endpoint [color="#AEB6BF"]
    eGFR_Preservation     -> eGFR_Endpoint [color="#AEB6BF"]
    BP_Reduction          -> BP_Endpoint [color="#AEB6BF"]
    Hb_Increase           -> Hb_Endpoint [color="#AEB6BF"]
    PTH_Suppression       -> PTH_Endpoint [color="#AEB6BF"]

    /* CKD pathology → Clinical Endpoints */
    eGFR_Decline          -> eGFR_Endpoint [color="#1A5276" penwidth=2]
    eGFR_Decline          -> Creatinine [color="#1A5276"]
    eGFR_Decline          -> Cystatin_C [color="#1A5276"]
    eGFR_Endpoint         -> CKD_Stage_Out [color="#AEB6BF" penwidth=2]
    Proteinuria           -> UACR_Endpoint [color="#C0392B"]
    Proteinuria           -> Proteinuria_Out [color="#C0392B"]
    BP_Increase           -> BP_Endpoint [color="#2C3E50"]
    Hemoglobin            -> Hb_Endpoint [color="#1ABC9C"]
    PTH                   -> PTH_Endpoint [color="#C0392B"]
    Phosphate_Serum       -> Phosphate_Endpoint [color="#C0392B"]
    FGF23                 -> FGF23_Endpoint [color="#C0392B"]
    IL6_CKD               -> CRP_ESR [color="#F39C12"]
    CKD_Stage_Out         -> Composite_Endpoint [color="#808B96" penwidth=2]
    ESKD                  -> Composite_Endpoint [color="#2C3E50" penwidth=2]
    CV_Events             -> MACE [color="#2C3E50" penwidth=2]
    ESKD                  -> Dialysis_RRT [color="#17202A" penwidth=2]
    Transplant            -> eGFR_Endpoint [label="post-Tx\neGFR" color="#82E0AA"]
    Dialysis_RRT          -> Transplant [color="#17202A" style=dashed]

    /* Cinacalcet PK */
    Cinacalcet_PO         -> Cinacalcet_C1 [label="absorption" color="#E67E22"]
}
