digraph JIA_QSP {
    graph [fontname="Helvetica" fontsize=10 compound=true bgcolor="#FAFAFA"
           rankdir=LR splines=ortho nodesep=0.5 ranksep=1.4
           label="Juvenile Idiopathic Arthritis (JIA)\nQuantitative Systems Pharmacology Model"
           labelloc=t fontsize=16 fontcolor="#1A237E"]
    node [fontname="Helvetica" fontsize=8 style="filled,rounded" shape=box]
    edge [fontname="Helvetica" fontsize=7 arrowsize=0.7]

    // ─────────────────────────────────────────────────────────────────────
    // Cluster 1: Genetic Risk & Environmental Triggers
    // ─────────────────────────────────────────────────────────────────────
    subgraph cluster_trigger {
        label="Genetic Risk & Environmental Triggers" style=filled fillcolor="#FFF3E0"
        color="#E65100" penwidth=2 fontsize=11 fontname="Helvetica-Bold"
        node [fillcolor="#FFE0B2"]
        GeneticRisk   [label="Genetic Risk\n(HLA-DR, PTPN22,\nSTAT4, IL2RA, TNFAIP3)"]
        HLA_B27       [label="HLA-B27\n(ERA subtype)"]
        HLA_DR4       [label="HLA-DR4/DQ8\n(RF+ polyarticular)"]
        Microbiome    [label="Gut Microbiome\nDysbiosis"]
        Infection     [label="Microbial Trigger\n(viral/bacterial)"]
        EnvStress     [label="Environmental\nStress / Trauma"]
        PAMP          [label="PAMPs / DAMPs"]
        TLR_signal    [label="TLR2/4/9\nSignaling"]
        NLRP3_trigger [label="NLRP3\nInflammasome Priming"]
        Complement    [label="Complement\nSystem (C3a, C5a)"]
        Autoantigen   [label="Self-Antigens\n(CII, CCP, HSP60)"]
        MastCell      [label="Mast Cell\nDegranulation"]
    }

    // ─────────────────────────────────────────────────────────────────────
    // Cluster 2: Innate Immune Activation
    // ─────────────────────────────────────────────────────────────────────
    subgraph cluster_innate {
        label="Innate Immune Activation" style=filled fillcolor="#FBE9E7"
        color="#BF360C" penwidth=2 fontsize=11 fontname="Helvetica-Bold"
        node [fillcolor="#FFCCBC"]
        Neutrophil    [label="Neutrophil\nRecruitment/NETosis"]
        Monocyte      [label="Monocyte\nActivation"]
        Macro_M1      [label="M1 Macrophage\n(synovial lining)"]
        NK_cell       [label="NK Cell\n(IFN-γ production)"]
        DC            [label="Dendritic Cell\n(Antigen Presenting)"]
        MHC_II        [label="MHC Class II\nAntigen Presentation"]
        NLRP3_active  [label="NLRP3\nInflammasome (active)"]
        Caspase1      [label="Caspase-1\nActivation"]
        NETs          [label="NETs\n(citrullination)"]
        CXCL8         [label="CXCL8/IL-8\n(Neutrophil chemotaxis)"]
        CCL2          [label="CCL2/MCP-1\n(Monocyte chemotaxis)"]
        CCL5          [label="CCL5/RANTES\n(T cell chemotaxis)"]
        S100A8        [label="S100A8/A9\n(MRP8/14, alarm)"]
    }

    // ─────────────────────────────────────────────────────────────────────
    // Cluster 3: Adaptive Immune System – T Cells
    // ─────────────────────────────────────────────────────────────────────
    subgraph cluster_tcell {
        label="Adaptive Immunity – T Cell Subsets" style=filled fillcolor="#E8F5E9"
        color="#1B5E20" penwidth=2 fontsize=11 fontname="Helvetica-Bold"
        node [fillcolor="#C8E6C9"]
        NaiveT        [label="Naïve CD4+\nT Cell"]
        Th0           [label="Th0\nPrecursor"]
        Th1           [label="Th1 Cell\n(IFN-γ, TNF-α)"]
        Th17          [label="Th17 Cell\n(IL-17A, IL-17F)"]
        Th2           [label="Th2 Cell\n(IL-4, IL-13)"]
        Treg          [label="Regulatory T Cell\n(FoxP3+, IL-10)"]
        Tfh           [label="T Follicular\nHelper (Tfh)"]
        CD8_T         [label="CD8+ Cytotoxic\nT Cell"]
        MemoryT       [label="Memory T Cell\n(TRM, Tcm)"]
        Tbet          [label="T-bet\n(Th1 master TF)"]
        RORgt         [label="RORγt\n(Th17 master TF)"]
        FoxP3         [label="FoxP3\n(Treg master TF)"]
        TCR_signal    [label="TCR/CD3\nSignaling Complex"]
        CD28_costim   [label="CD28\nCostimulation"]
        JAK_STAT      [label="JAK1/2/3-STAT1/3/5\nSignaling Cascade"]
    }

    // ─────────────────────────────────────────────────────────────────────
    // Cluster 4: Cytokine Network
    // ─────────────────────────────────────────────────────────────────────
    subgraph cluster_cytokine {
        label="Key Cytokine Network" style=filled fillcolor="#E3F2FD"
        color="#0D47A1" penwidth=2 fontsize=11 fontname="Helvetica-Bold"
        node [fillcolor="#BBDEFB"]
        TNFa          [label="TNF-α\n(Master proinflam.)"]
        IL1b          [label="IL-1β\n(Inflammasome)"]
        IL6           [label="IL-6\n(Acute-phase, Th17)"]
        IL17          [label="IL-17A/F\n(Neutrophil recruit)"]
        IL12_23       [label="IL-12 / IL-23\n(Th1/Th17 polarize)"]
        IL18          [label="IL-18\n(sJIA/MAS key)"]
        IL10          [label="IL-10\n(Anti-inflam, Treg)"]
        TGFB          [label="TGF-β\n(Treg induction)"]
        IL2           [label="IL-2\n(T cell growth)"]
        IFNg          [label="IFN-γ\n(Macro activate)"]
        IL21          [label="IL-21\n(B cell/Tfh)"]
        IL4           [label="IL-4\n(Th2, B cell)"]
        IL22          [label="IL-22\n(Mucosal defense)"]
        IL15          [label="IL-15\n(NK/T activation)"]
        GM_CSF        [label="GM-CSF\n(Myeloid survival)"]
        IL1Ra         [label="IL-1Ra\n(Natural IL-1 inhib)"]
    }

    // ─────────────────────────────────────────────────────────────────────
    // Cluster 5: B Cells & Autoantibodies
    // ─────────────────────────────────────────────────────────────────────
    subgraph cluster_bcell {
        label="B Cells & Autoantibodies" style=filled fillcolor="#FCE4EC"
        color="#880E4F" penwidth=2 fontsize=11 fontname="Helvetica-Bold"
        node [fillcolor="#F8BBD9"]
        NaiveB        [label="Naïve B Cell"]
        GC_reaction   [label="Germinal Center\nReaction"]
        PlasmaCell    [label="Plasma Cell\n(Ig-secreting)"]
        MemoryB       [label="Memory B Cell"]
        RF_Ab         [label="Rheumatoid Factor\n(IgM-RF)"]
        AntiCCP       [label="Anti-CCP Ab\n(ACPA, RF+ subtype)"]
        ANA_Ab        [label="ANA\n(oligoarticular)"]
        IgG_complex   [label="IgG Immune\nComplexes"]
        FcgR          [label="FcγR Activation\n(macrophage)"]
        BAFF          [label="BAFF/BLyS\n(B cell survival)"]
        APRIL         [label="APRIL\n(plasma cell survival)"]
    }

    // ─────────────────────────────────────────────────────────────────────
    // Cluster 6: Synovial Pathology & Pannus
    // ─────────────────────────────────────────────────────────────────────
    subgraph cluster_synovium {
        label="Synovial Inflammation & Pannus Formation" style=filled fillcolor="#EDE7F6"
        color="#4A148C" penwidth=2 fontsize=11 fontname="Helvetica-Bold"
        node [fillcolor="#D1C4E9"]
        FLS           [label="Fibroblast-Like\nSynoviocytes (FLS)"]
        SynoHyperplasia [label="Synovial\nHyperplasia"]
        Pannus        [label="Pannus Tissue\n(invasive)"]
        VEGF          [label="VEGF\n(Angiogenesis)"]
        Angiogenesis  [label="Neovascularization\n(pannus feeding)"]
        NF_kB         [label="NF-κB\nActivation"]
        AP1           [label="AP-1 / c-Jun\nSignaling"]
        COX2          [label="COX-2\nUpregulation"]
        PGE2          [label="Prostaglandin E2\n(pain, fever)"]
        iNOS          [label="iNOS\n(Nitric oxide)"]
        MMP1          [label="MMP-1/3\n(Collagenase)"]
        MMP13         [label="MMP-13\n(Stromelysin-3)"]
        ADAMTS4       [label="ADAMTS-4/5\n(Aggrecanase)"]
        Cathepsins    [label="Cathepsin B/D/K\n(Lysosomal prot.)"]
        Hyaluronan    [label="Synovial Fluid\nHyaluronan Loss"]
        Resistin      [label="Resistin\n(Adipokine inflam.)"]
    }

    // ─────────────────────────────────────────────────────────────────────
    // Cluster 7: Bone & Cartilage Destruction
    // ─────────────────────────────────────────────────────────────────────
    subgraph cluster_bone {
        label="Bone Erosion & Cartilage Degradation" style=filled fillcolor="#FFF9C4"
        color="#F57F17" penwidth=2 fontsize=11 fontname="Helvetica-Bold"
        node [fillcolor="#FFF9C4"]
        RANKL         [label="RANKL\n(OPG ligand, osteoclast act.)"]
        OPG           [label="Osteoprotegerin\n(Decoy receptor, -)"]
        MCSF          [label="M-CSF\n(Osteoclast precursor)"]
        Osteoclast    [label="Osteoclast\nActivation/Fusion"]
        Osteoblast    [label="Osteoblast\n(Bone formation)"]
        Wnt_path      [label="Wnt/β-catenin\n(Bone formation+)"]
        Sclerostin    [label="Sclerostin\n(Wnt inhibitor)"]
        DKK1          [label="DKK-1\n(Wnt inhib, TNF-driven)"]
        Bone_erosion  [label="Periarticular\nBone Erosion"]
        Periostitis   [label="Periostitis\n(ERA subtype)"]
        Cartilage_deg [label="Articular Cartilage\nDegradation"]
        Chondrocyte   [label="Chondrocyte\nApoptosis/Dediff"]
        Aggrecan      [label="Aggrecan\nLoss (ADAMTS)"]
        CollagenII    [label="Type II Collagen\nDegradation (MMP13)"]
        JSN           [label="Joint Space\nNarrowing (JSN)"]
        Growth_plate  [label="Growth Plate\nDamage (peds)"]
        BMD_loss      [label="Periarticular\nBMD Loss"]
        LLD           [label="Leg Length\nDiscrepancy"]
    }

    // ─────────────────────────────────────────────────────────────────────
    // Cluster 8: sJIA-Specific Pathways & MAS
    // ─────────────────────────────────────────────────────────────────────
    subgraph cluster_sjia {
        label="Systemic JIA (sJIA) & Macrophage Activation Syndrome (MAS)" style=filled fillcolor="#F3E5F5"
        color="#6A1B9A" penwidth=2 fontsize=11 fontname="Helvetica-Bold"
        node [fillcolor="#E1BEE7"]
        sJIA_fever    [label="Quotidian Fever\n(sJIA hallmark ≥2wk)"]
        sJIA_rash     [label="Evanescent Salmon\nMaculopapular Rash"]
        Serositis     [label="Serositis\n(Pericarditis/Pleuritis)"]
        MAS           [label="Macrophage Activation\nSyndrome (MAS)"]
        IL18_high     [label="Extreme IL-18\nElevation (MAS trigger)"]
        Hyperferritin [label="Hyperferritinemia\n(MAS marker >500 ng/mL)"]
        Hemophago     [label="Hemophagocytosis\n(Bone marrow)"]
        NK_dysfn      [label="NK Cell Dysfunction\n(Perforin deficiency)"]
        Perforin_def  [label="Perforin/PRF1\nMutation Risk"]
        IFNg_excess   [label="IFN-γ Excess\n(MAS amplifier)"]
        NLRP3_sjia    [label="NLRP3 Gain-of-Fn\n(sJIA subset)"]
        IL1_loop      [label="IL-1 Autoinflam-\nmatory Loop (sJIA)"]
        Macrophage_act [label="Macrophage\nUnrestrained Activation"]
        Cytokine_storm [label="Cytokine Storm\n(sJIA-MAS)"]
        PAP           [label="Pulm. Alveolar\nProteinosis (PAP, TMEM173)"]
    }

    // ─────────────────────────────────────────────────────────────────────
    // Cluster 9: Biologic Drug PK
    // ─────────────────────────────────────────────────────────────────────
    subgraph cluster_biopk {
        label="Biologic Drug Pharmacokinetics" style=filled fillcolor="#E0F7FA"
        color="#006064" penwidth=2 fontsize=11 fontname="Helvetica-Bold"
        node [fillcolor="#B2EBF2"]
        ETA_depot     [label="Etanercept SC Depot\n(Enbrel® 25/50 mg)"]
        ETA_central   [label="Etanercept Central\nV₁=6.5 L, t½=70h"]
        ETA_periph    [label="Etanercept\nPeripheral"]
        ADA_depot     [label="Adalimumab SC Depot\n(Humira® 20/40 mg)"]
        ADA_central   [label="Adalimumab Central\nV₁=7.5 L, t½=14d"]
        TCZ_depot     [label="Tocilizumab SC Depot\n(Actemra® 162 mg)"]
        TCZ_central   [label="Tocilizumab Central\nV₁=4.8 L, t½=~11d"]
        CANA_depot    [label="Canakinumab SC Depot\n(Ilaris® 4 mg/kg)"]
        CANA_central  [label="Canakinumab Central\nV₁=6.8 L, t½=26d"]
        ABA_IV        [label="Abatacept IV\n(Orencia® 10 mg/kg)"]
        ABA_central   [label="Abatacept Central\nV₁=9.7 L, t½=13d"]
        ANA_SC        [label="Anakinra SC\n(Kineret® 1-2 mg/kg)"]
        FcRn_recycle  [label="FcRn-mediated IgG\nRecycling (t½ extend)"]
        ADA_Ab        [label="Anti-Drug Antibodies\n(ADA, immunogenicity)"]
    }

    // ─────────────────────────────────────────────────────────────────────
    // Cluster 10: Small-Molecule & Conventional Drug PK
    // ─────────────────────────────────────────────────────────────────────
    subgraph cluster_smpk {
        label="Small Molecule & Conventional Drug PK" style=filled fillcolor="#E8EAF6"
        color="#283593" penwidth=2 fontsize=11 fontname="Helvetica-Bold"
        node [fillcolor="#C5CAE9"]
        MTX_oral      [label="MTX Oral/SC\n(Reumoflex® 10-25 mg/wk)"]
        MTX_central   [label="MTX Central\nVd=0.8 L/kg"]
        MTX_periph    [label="MTX Peripheral\n(tissue binding)"]
        MTX_poly      [label="MTX-Polyglutamates\n(intracellular, active)"]
        NSAID_oral    [label="NSAID Oral\n(Naproxen/Ibuprofen)"]
        NSAID_central [label="NSAID Central\n(COX-1/2 inhib)"]
        GC_oral       [label="Prednisolone Oral\n(0.5-2 mg/kg/d)"]
        GC_central    [label="Prednisolone Central\nt½=3h, GR binding"]
        GC_GR         [label="Glucocorticoid\nReceptor Complex"]
        JAKi_oral     [label="Baricitinib Oral\n(JAK1/2, 2-4 mg/d)"]
        JAKi_central  [label="Baricitinib Central\nVd=76 L, t½=12h"]
        TOFi_oral     [label="Tofacitinib Oral\n(JAK1/3, 5 mg BID)"]
        TOFi_central  [label="Tofacitinib Central\nVd=87 L, t½=3.2h"]
        DHFR_inhib    [label="DHFR Inhibition\n(MTX MoA)"]
        AICAR_accum   [label="AICAR Accumulation\n(→Adenosine↑)"]
    }

    // ─────────────────────────────────────────────────────────────────────
    // Cluster 11: Drug Pharmacodynamics & Targets
    // ─────────────────────────────────────────────────────────────────────
    subgraph cluster_pd {
        label="Drug Pharmacodynamics & Mechanisms of Action" style=filled fillcolor="#EFEBE9"
        color="#3E2723" penwidth=2 fontsize=11 fontname="Helvetica-Bold"
        node [fillcolor="#D7CCC8"]
        TNF_inhib     [label="TNF-α Inhibition\n(ETA/ADA block free TNF)"]
        IL6R_block    [label="IL-6R Blockade\n(TCZ: mIL-6R + sIL-6R)"]
        IL1b_block    [label="IL-1β Blockade\n(Canakinumab/Anakinra)"]
        CD80_block    [label="CD80/86 Blockade\n(Abatacept CTLA4-Ig)"]
        Costim_block  [label="T Cell Costimulation\nBlocked → Anergy"]
        JAK_block     [label="JAK1/2/3 Blockade\n(Tofacitinib/Baricitinib)"]
        STAT_inhib    [label="STAT1/3/5 Phospho-\nlation Blocked"]
        Adenosine_ef  [label="Adenosine ↑\n(MTX anti-inflam)"]
        GC_transrep   [label="GC Transrepression\n(NF-κB/AP-1 inhib)"]
        NF_kB_inhib   [label="NF-κB\nInhibition"]
        COX_inhib     [label="COX-1/2\nInhibition"]
        Emax_PD       [label="Emax Drug-Effect\nModel (Hill eq)"]
        TMDD_PK       [label="Target-Mediated Drug\nDisposition (TMDD)"]
        Tolerance_PD  [label="Drug Tolerance /\nTachyphylaxis"]
    }

    // ─────────────────────────────────────────────────────────────────────
    // Cluster 12: Clinical Endpoints & Biomarkers
    // ─────────────────────────────────────────────────────────────────────
    subgraph cluster_endpoints {
        label="Clinical Endpoints & Biomarkers" style=filled fillcolor="#E8F5E9"
        color="#1B5E20" penwidth=2 fontsize=11 fontname="Helvetica-Bold"
        node [fillcolor="#A5D6A7"]
        ACR_Ped       [label="ACR Pedi 30/50/70/90\n(% improvement)"]
        JADAS27       [label="JADAS-27\n(0–57 composite)"]
        cJADAS10      [label="cJADAS-10\n(clinical, 0–30)"]
        CHAQ          [label="CHAQ/HAQ-DI\n(Functional ability)"]
        PGA_score     [label="Physician Global\nAssessment (0–10 VAS)"]
        PtGA_score    [label="Patient/Parent\nGlobal Assessment (VAS)"]
        AJC           [label="Active Joint Count\n(AJC, 0–27/71)"]
        LJC           [label="Limited ROM\nJoint Count (LJC)"]
        CRP_marker    [label="CRP\n(mg/L, acute phase)"]
        ESR_marker    [label="ESR\n(mm/h)"]
        Ferritin_lab  [label="Serum Ferritin\n(sJIA/MAS marker)"]
        S100_marker   [label="S100A8/A9\n(MRP8/14 serum)"]
        RF_marker     [label="Rheumatoid Factor\n(RF+ subtype)"]
        AntiCCP_lab   [label="Anti-CCP Ab\n(ACPA serum)"]
        ANA_lab       [label="ANA Titer\n(uveitis risk)"]
        IGF1_lab      [label="IGF-1\n(Growth marker)"]
        GrowthVel     [label="Growth Velocity\n(cm/yr, Ht-SDS)"]
        Uveitis_act   [label="Anterior Uveitis\nActivity (SUN grading)"]
        WBC           [label="WBC / Diff\n(MAS: pancytopenia)"]
        Remission_JIA [label="Clinical Inactive\nDisease (Wallace)"]
        JADAS_remis   [label="JADAS ≤1.0\n(Remission threshold)"]
    }

    // ─────────────────────────────────────────────────────────────────────
    // Cluster 13: Complications & Growth
    // ─────────────────────────────────────────────────────────────────────
    subgraph cluster_compl {
        label="Complications, Extra-articular & Safety" style=filled fillcolor="#FFF8E1"
        color="#E65100" penwidth=2 fontsize=11 fontname="Helvetica-Bold"
        node [fillcolor="#FFECB3"]
        Uveitis       [label="Chronic Anterior\nUveitis (ANA+ risk)"]
        Band_kerato   [label="Band Keratopathy\n(chronic uveitis)"]
        GrowthRetard  [label="Growth Retardation\n(steroid + disease)"]
        GH_suppress   [label="GH Axis\nSuppression (GC)"]
        Osteoporosis  [label="Osteoporosis/\nOsteopenia"]
        SAA_amyloid   [label="Secondary Amyloidosis\n(SAA, rare, sJIA)"]
        MTX_pneumo    [label="MTX Pneumonitis\n(rare toxicity)"]
        Hepatotox     [label="Hepatotoxicity\n(MTX, NSAIDs, AST↑)"]
        Infect_risk   [label="Infection Risk\n(biologic + GC)"]
        TB_react      [label="TB Reactivation\n(TNFi, screen IGRA)"]
        Herpes_react  [label="Herpes Reactivation\n(JAKi, VZV/HZV)"]
        CardioRisk    [label="Subclinical CVD\n(chronic inflam)"]
        IVIG_SE       [label="IVIG Side Effects\n(headache, hemolysis)"]
        Macrophage_SE [label="GC Side Effects\n(Cushingoid, AVBN)"]
        JointSurgery  [label="Joint Surgery\n(arthroplasty rare peds)"]
    }

    // =================================================================
    // EDGES
    // =================================================================

    // Triggers → Innate
    GeneticRisk   -> TLR_signal [label="susceptibility"]
    GeneticRisk   -> NLRP3_trigger [label="predispose"]
    HLA_DR4       -> Autoantigen [label="HLA binding"]
    HLA_B27       -> Monocyte [label="innate act."]
    Microbiome    -> PAMP
    Infection     -> PAMP
    EnvStress     -> PAMP
    PAMP          -> TLR_signal
    PAMP          -> Complement
    TLR_signal    -> NLRP3_trigger [label="priming"]
    TLR_signal    -> Monocyte [label="activate"]
    TLR_signal    -> Neutrophil [label="activate"]
    NLRP3_trigger -> NLRP3_active
    Complement    -> CXCL8 [label="C5a→"]
    MastCell      -> CXCL8 [label="histamine+"]
    Autoantigen   -> MHC_II [label="processing"]

    // Innate immune
    NLRP3_active  -> Caspase1 [label="oligomers"]
    Caspase1      -> IL1b [label="cleave pro-IL-1β"]
    Caspase1      -> IL18 [label="cleave pro-IL-18"]
    Neutrophil    -> NETs [label="NETosis"]
    NETs          -> Autoantigen [label="citrullination"]
    NETs          -> NLRP3_active [label="DAMP→"]
    Monocyte      -> Macro_M1 [label="differentiate"]
    Macro_M1      -> TNFa [label="secrete"]
    Macro_M1      -> IL1b [label="secrete"]
    Macro_M1      -> IL6 [label="secrete"]
    Macro_M1      -> IL18 [label="secrete"]
    Macro_M1      -> CXCL8
    Macro_M1      -> CCL2
    NK_cell       -> IFNg [label="produce"]
    DC            -> MHC_II [label="present"]
    S100A8        -> TLR_signal [label="alarm re-trigger"]
    CXCL8         -> Neutrophil [label="recruit↑"]
    CCL2          -> Monocyte [label="recruit↑"]
    CCL5          -> MemoryT [label="recruit↑"]

    // T cell activation & differentiation
    MHC_II        -> NaiveT [label="TCR engagement"]
    NaiveT        -> TCR_signal
    TCR_signal    -> CD28_costim [label="require"]
    CD28_costim   -> Th0 [label="full activation"]
    Th0           -> Th1 [label="IL-12 + T-bet"]
    Th0           -> Th17 [label="TGF-β + IL-6\n+ IL-23"]
    Th0           -> Th2 [label="IL-4"]
    Th0           -> Treg [label="TGF-β + IL-2"]
    Th0           -> Tfh [label="IL-6 + IL-21"]
    IL12_23       -> Th1 [label="+"]
    IL12_23       -> Th17 [label="IL-23 →"]
    TGFB          -> Treg [label="+"]
    IL6           -> Th17 [label="+"]
    IL6           -> Treg [label="- (suppress)" color=red]
    IL2           -> Treg [label="+"]
    Th1           -> Tbet
    Th17          -> RORgt
    Treg          -> FoxP3
    Th1           -> IFNg [label="produce"]
    Th17          -> IL17 [label="produce"]
    Th17          -> IL22 [label="produce"]
    IFNg          -> JAK_STAT [label="JAK1/2"]
    IL6           -> JAK_STAT [label="JAK1/2"]
    IL17          -> JAK_STAT [label="JAK3"]
    IL2           -> JAK_STAT [label="JAK1/3"]
    JAK_STAT      -> MemoryT [label="differentiate"]

    // B cell & autoantibody
    Tfh           -> GC_reaction [label="T-B help"]
    NaiveB        -> GC_reaction
    IL21          -> GC_reaction [label="+"]
    BAFF          -> NaiveB [label="survival"]
    APRIL         -> PlasmaCell [label="survival"]
    GC_reaction   -> PlasmaCell [label="affinity mat."]
    GC_reaction   -> MemoryB
    PlasmaCell    -> RF_Ab [label="RF+ pJIA"]
    PlasmaCell    -> AntiCCP [label="RF+ pJIA"]
    PlasmaCell    -> ANA_Ab [label="oligo JIA"]
    ANA_Ab        -> FcgR [label="IC deposit"]
    RF_Ab         -> IgG_complex
    IgG_complex   -> FcgR [label="activate"]
    FcgR          -> Macro_M1 [label="amplify"]

    // Cytokine cross-talk
    TNFa          -> IL6 [label="+"]
    TNFa          -> IL1b [label="+"]
    IL1b          -> TNFa [label="+"]
    IL1b          -> IL6 [label="+"]
    IL6           -> IL1Ra [label="negative\nfeedback"]
    IL10          -> TNFa [label="- anti-inflam" color=red]
    IL10          -> IL1b [label="-" color=red]
    Treg          -> IL10 [label="produce"]
    Treg          -> TGFB [label="produce"]
    GM_CSF        -> Macro_M1 [label="survival"]
    IL15          -> NK_cell [label="+"]

    // Synovial pathology
    TNFa          -> FLS [label="activate"]
    IL1b          -> FLS [label="activate"]
    IL6           -> FLS [label="activate"]
    IL17          -> FLS [label="+"]
    IFNg          -> Macro_M1 [label="M1 polarize"]
    FLS           -> NF_kB [label="signal"]
    FLS           -> AP1 [label="signal"]
