digraph PTSD_QSP {
  rankdir=LR;
  compound=true;
  fontname="Helvetica";
  fontsize=22;
  labelloc="t";
  label="Post-Traumatic Stress Disorder (PTSD) QSP Mechanistic Map\nHPA Axis/Locus Coeruleus Dysregulation · Amygdala-Hippocampus-vmPFC Fear Circuit · Extinction Neuroplasticity · SSRI/Prazosin/Ketamine/MDMA-Assisted Psychotherapy PK/PD";
  node [style=filled, fontname="Helvetica", fontsize=11, shape=box, margin="0.12,0.06"];
  edge [fontname="Helvetica", fontsize=9, color="#555555"];

  /* ============ CLUSTER 1: RISK & RESILIENCE FACTORS ============ */
  subgraph cluster_rf {
    label="1. 위험요인/유전-환경 상호작용 (Trauma Exposure, Risk & Resilience Factors)";
    style=filled; color="#FBEEE6"; fontsize=13;
    RF1  [label="전투/파병 트라우마\n노출 (Combat exposure)", fillcolor="#F6DDCC"];
    RF2  [label="성폭력/대인폭력\n트라우마 (Sexual assault,\ninterpersonal violence)", fillcolor="#F0C9A0"];
    RF3  [label="교통사고/자연재해\n트라우마", fillcolor="#EAB574"];
    RF4  [label="아동기 학대/방임\n(Early-life maltreatment)", fillcolor="#E5A14B"];
    RF5  [label="트라우마 용량\n(중증도·기간·반복성)", fillcolor="#D68910"];
    RF6  [label="주변외상성 해리\n(Peritraumatic dissociation)", fillcolor="#B9770E"];
    RF7  [label="FKBP5 유전자 x\n아동기 트라우마 상호작용", fillcolor="#9C640C"];
    RF8  [label="5-HTTLPR 단축형\n대립유전자 (SERT 다형성)", fillcolor="#7E5109"];
    RF9  [label="사회적 지지 결핍/\n외상 후 고립", fillcolor="#935116"];
    RF10 [label="회복탄력성 인자\n(NPY, BDNF Val66Met,\n과거 극복경험)", fillcolor="#6E2C00"];
    RF1 -> RF5; RF2 -> RF5; RF3 -> RF5; RF4 -> RF7; RF7 -> RF5;
  }

  /* ============ CLUSTER 2: ACUTE STRESS RESPONSE & FEAR ACQUISITION ============ */
  subgraph cluster_fa {
    label="2. 급성 스트레스 반응 및 공포 습득 (Acute Stress Response & Fear Acquisition)";
    style=filled; color="#FDEDEC"; fontsize=13;
    FA1 [label="무조건 외상성 자극\n(위협/부상)", fillcolor="#FADBD8"];
    FA2 [label="기저외측 편도체(BLA)\n위협탐지 및 CS-US 연합", fillcolor="#F5B7B1"];
    FA3 [label="노르아드레날린 매개\n기억 고착 (LC->BLA,\nCahill/McGaugh)", fillcolor="#F1948A"];
    FA4 [label="급성 코르티솔 급증에\n의한 기억 강화", fillcolor="#EC7063"];
    FA5 [label="중심핵 편도체(CeA)\n공포 출력 (동결/경악)", fillcolor="#E74C3C", fontcolor=white];
    FA6 [label="급성 스트레스\n장애(ASD, <1개월)", fillcolor="#CB4335", fontcolor=white];
    FA7 [label="주변외상성 해리 ->\n맥락 부호화 장애(해마)", fillcolor="#A93226", fontcolor=white];
    FA8 [label="공포기억 과잉일반화\n(Overgeneralization)", fillcolor="#922B21", fontcolor=white];
    RF5 -> FA1; RF6 -> FA7; RF8 -> FA2; RF9 -> FA6; RF10 -> FA6 [style=dashed, color="#196F3D", label="protective"];
    FA1 -> FA2; FA2 -> FA3; FA2 -> FA5; FA3 -> FA4; FA4 -> FA8; FA5 -> FA6; FA7 -> FA8;
  }

  /* ============ CLUSTER 3: HPA AXIS DYSREGULATION ============ */
  subgraph cluster_hp {
    label="3. HPA 축 조절이상 (HPA Axis Dysregulation)";
    style=filled; color="#FEF5E7"; fontsize=13;
    HP1 [label="시상하부 PVN\nCRH 신경세포 활성화", fillcolor="#FCF3CF"];
    HP2 [label="전엽뇌하수체\nACTH 분비", fillcolor="#F9E79F"];
    HP3 [label="부신 코르티솔\n합성/분비", fillcolor="#F7DC6F"];
    HP4 [label="증강된 당질코르티코이드\n수용체(GR) 음성 되먹임", fillcolor="#F4D03F"];
    HP5 [label="역설적 저/정상\n기저 코르티솔\n(Yehuda 가설)", fillcolor="#F1C40F"];
    HP6 [label="둔화된 기상시\n코르티솔반응(CAR)", fillcolor="#D4AC0D"];
    HP7 [label="FKBP5 프로모터\n탈메틸화 -> GR\n공동샤페론 조절이상", fillcolor="#B7950B"];
    HP8 [label="염류코르티코이드\n수용체(MR) 긴장도", fillcolor="#9A7D0A"];
    HP9 [label="덱사메타손 억제검사\n과억제 반응", fillcolor="#7D6608"];
    RF7 -> HP7; FA4 -> HP1; HP1 -> HP2; HP2 -> HP3; HP3 -> HP4; HP4 -> HP5; HP7 -> HP4;
    HP5 -> HP6; HP4 -> HP9; HP3 -> HP8;
  }

  /* ============ CLUSTER 4: LOCUS COERULEUS-NOREPINEPHRINE HYPERAROUSAL ============ */
  subgraph cluster_ne {
    label="4. 청반-노르아드레날린 과각성 (Locus Coeruleus-Noradrenergic Hyperarousal)";
    style=filled; color="#FEF9E7"; fontsize=13;
    NE1 [label="청반(LC) 긴장성/\n일시성 발화", fillcolor="#FCF3CF"];
    NE2 [label="노르에피네프린 방출\n(피질·편도체·해마)", fillcolor="#F9E79F"];
    NE3 [label="알파1 아드레날린\n수용체 신호(각성/악몽)", fillcolor="#F7DC6F"];
    NE4 [label="알파2 자가수용체\n(시냅스전 되먹임)", fillcolor="#F4D03F"];
    NE5 [label="베타 아드레날린\n수용체 신호(말초 교감)", fillcolor="#F1C40F"];
    NE6 [label="안정시 심박수 증가/\nHRV 저하", fillcolor="#D4AC0D"];
    NE7 [label="과도한 청각\n경악반사", fillcolor="#B7950B"];
    NE8 [label="REM수면 중 교감\n급증 -> 악몽", fillcolor="#9A7D0A"];
    NE9 [label="편도체 CRH-LC\n양성 되먹임 루프", fillcolor="#7D6608"];
    HP1 -> NE9; NE9 -> NE1; NE1 -> NE2; NE2 -> NE3; NE2 -> NE4; NE2 -> NE5;
    NE5 -> NE6; NE3 -> NE7; NE3 -> NE8;
  }

  /* ============ CLUSTER 5: AMYGDALA-HIPPOCAMPUS-VMPFC CIRCUIT DYSFUNCTION ============ */
  subgraph cluster_ci {
    label="5. 편도체-해마-내측전전두엽 회로 기능장애 (Amygdala-Hippocampus-vmPFC Circuit Dysfunction)";
    style=filled; color="#F4ECF7"; fontsize=13;
    CI1  [label="BLA/CeA 외상단서에\n대한 과반응성", fillcolor="#E8DAEF"];
    CI2  [label="복내측전전두엽(vmPFC)\n저활성 (하향억제 실패)", fillcolor="#D7BDE2"];
    CI3  [label="배측 전측대상피질\n(dACC) 과활성", fillcolor="#C39BD3"];
    CI4  [label="해마 부피 감소\n(당질코르티코이드\n매개 위축)", fillcolor="#AF7AC5", fontcolor=white];
    CI5  [label="치아이랑(dentate\ngyrus) 신경생성\n억제", fillcolor="#9B59B6", fontcolor=white];
    CI6  [label="맥락 공포 구별\n장애(해마 의존)", fillcolor="#8E44AD", fontcolor=white];
    CI7  [label="공포회로 글루타메이트/\nNMDA 수용체 신호", fillcolor="#7D3C98", fontcolor=white];
    CI8  [label="vmPFC-편도체 기능적\n연결성 저하", fillcolor="#6C3483", fontcolor=white];
    CI9  [label="뇌섬엽(insula)\n과활성(내수용 위협처리)", fillcolor="#5B2C6F", fontcolor=white];
    CI10 [label="기본모드망/해리\n하위유형 회로", fillcolor="#4A235A", fontcolor=white];
    FA5 -> CI1; HP4 -> CI4; NE2 -> CI1; CI1 -> CI2 [style=dashed, color="#C0392B", label="inhibits(fails)"];
    CI2 -> CI8; CI1 -> CI8; CI4 -> CI5; CI4 -> CI6; CI1 -> CI3; CI1 -> CI9; FA7 -> CI10; CI7 -> CI1;
  }

  /* ============ CLUSTER 6: FEAR MEMORY & EXTINCTION NEUROPLASTICITY ============ */
  subgraph cluster_fe {
    label="6. 공포기억 습득/소거 신경가소성 (Fear Memory & Extinction Neuroplasticity)";
    style=filled; color="#FDF2F8"; fontsize=13;
    FE1 [label="공포기억 고착\n(BLA 시냅스 강화)", fillcolor="#FADCE5"];
    FE2 [label="회상시 공포기억\n재고착(Reconsolidation)", fillcolor="#F5B7C7"];
    FE3 [label="소거학습(vmPFC\n주도 억제성 기억)", fillcolor="#EE85A3"];
    FE4 [label="소거기억 회상/재현\n결함", fillcolor="#E65883"];
    FE5 [label="BDNF-TrkB 신호\n(시냅스 가소성)", fillcolor="#D63A6C"];
    FE6 [label="mTOR 경로 활성화\n(급속 시냅스형성)", fillcolor="#C13560"];
    FE7 [label="맥락의존적 소거\n재발(Renewal/Relapse)", fillcolor="#A93266"];
    FE8 [label="NMDA수용체 의존\n장기강화(LTP)", fillcolor="#8E2A57"];
    FE9 [label="공포-소거 균형\n(경쟁 기억흔적 강도)", fillcolor="#78214A"];
    FA8 -> FE1; CI7 -> FE1; CI7 -> FE8; FE1 -> FE2; CI2 -> FE3; FE3 -> FE4; FE5 -> FE6;
    FE3 -> FE9; FE1 -> FE9 [style=dashed, color="#C0392B"]; FE4 -> FE7; FE9 -> CI1 [style=dashed, color="#196F3D", label="dampens"];
  }

  /* ============ CLUSTER 7: NEUROINFLAMMATION & OXIDATIVE STRESS ============ */
  subgraph cluster_ni {
    label="7. 신경염증 및 산화스트레스 (Neuroinflammation & Oxidative Stress)";
    style=filled; color="#EAFAF1"; fontsize=13;
    NI1 [label="말초 IL-6 상승", fillcolor="#D5F5E3"];
    NI2 [label="TNF-alpha 상승", fillcolor="#ABEBC6"];
    NI3 [label="C-반응성단백(CRP)\n상승", fillcolor="#82E0AA"];
    NI4 [label="미세아교세포\n활성화(신경염증 프라이밍)", fillcolor="#58D68D"];
    NI5 [label="키뉴레닌 경로 이행\n(신경독성 퀴놀린산)", fillcolor="#2ECC71", fontcolor=white];
    NI6 [label="산화스트레스/\n미토콘드리아 기능장애", fillcolor="#28B463", fontcolor=white];
    NI7 [label="장-뇌 축\n미생물군 불균형", fillcolor="#1E8449", fontcolor=white];
    HP3 -> NI1 [style=dashed]; NI1 -> NI2; NI1 -> NI3; NI2 -> NI4; NI4 -> NI5; NI5 -> CI4 [style=dashed, color="#C0392B", label="accelerates atrophy"];
    NI6 -> NI4; NI7 -> NI1;
  }

  /* ============ CLUSTER 8: DSM-5 SYMPTOM CLUSTERS ============ */
  subgraph cluster_sx {
    label="8. DSM-5 증상 클러스터 B-E (Symptom Clusters)";
    style=filled; color="#EBEDEF"; fontsize=13;
    SX1 [label="클러스터B: 침습적\n기억/플래시백", fillcolor="#D5D8DC"];
    SX2 [label="클러스터B: 외상관련\n악몽", fillcolor="#AEB6BF"];
    SX3 [label="클러스터C: 외상단서\n회피행동", fillcolor="#909497"];
    SX4 [label="클러스터D: 부정적\n신념/왜곡된 자기비난", fillcolor="#717D7E"];
    SX5 [label="클러스터D: 무쾌감증/\n감정마비", fillcolor="#616A6B"];
    SX6 [label="클러스터E: 과각성/\n경계심", fillcolor="#4D5656"];
    SX7 [label="클러스터E: 과민성/\n분노폭발", fillcolor="#424949", fontcolor=white];
    SX8 [label="해리 하위유형\n(이인증/비현실감)", fillcolor="#212F3C", fontcolor=white];
    FE1 -> SX1; NE8 -> SX2; CI2 -> SX3 [style=dashed]; CI8 -> SX4; CI2 -> SX5 [style=dashed]; NE7 -> SX6; NE6 -> SX6; NE5 -> SX7; CI10 -> SX8;
  }

  /* ============ CLUSTER 9: SLEEP DISTURBANCE ============ */
  subgraph cluster_sl {
    label="9. 수면장애 (Sleep Disturbance)";
    style=filled; color="#EBF5FB"; fontsize=13;
    SL1 [label="REM수면 분절화", fillcolor="#D6EAF8"];
    SL2 [label="악몽 빈도/강도", fillcolor="#AED6F1"];
    SL3 [label="수면개시/유지\n불면증", fillcolor="#85C1E9"];
    SL4 [label="서파수면 감소\n(기억고착 결함)", fillcolor="#5DADE2"];
    SL5 [label="낮 시간 피로 ->\n과각성 악화 되먹임", fillcolor="#3498DB", fontcolor=white];
    SL6 [label="동반 수면무호흡증\n(양방향 상호작용)", fillcolor="#2874A6", fontcolor=white];
    NE8 -> SL1; SL1 -> SL2; SL2 -> SL3; SL1 -> SL4; SL4 -> FE6 [style=dashed, color="#C0392B", label="impairs consolidation"];
    SL3 -> SL5; SL5 -> NE1 [style=dashed, color="#C0392B"]; SL6 -> SL1;
  }

  /* ============ CLUSTER 10: COMORBIDITIES & FUNCTIONAL OUTCOMES ============ */
  subgraph cluster_cm {
    label="10. 동반질환 및 기능적 결과 (Comorbidities & Functional Outcomes)";
    style=filled; color="#E8F8F5"; fontsize=13;
    CM1 [label="주요우울장애\n동반", fillcolor="#D0ECE7"];
    CM2 [label="알코올/물질사용장애\n(자가치료)", fillcolor="#A2D9CE"];
    CM3 [label="자살사고/행동\n위험", fillcolor="#73C6B6"];
    CM4 [label="만성통증 증후군", fillcolor="#45B39D"];
    CM5 [label="심혈관 위험\n(고혈압·관상동맥질환)", fillcolor="#17A589"];
    CM6 [label="직업적/사회적\n기능장애", fillcolor="#148F77"];
    CM7 [label="관계/가족\n기능이상", fillcolor="#117864"];
    CM8 [label="건강관련 삶의질\n저하", fillcolor="#0E6251"];
    SX5 -> CM1; SX3 -> CM2 [style=dashed]; CM1 -> CM3; NE6 -> CM5; CM4 -> CM1 [style=dashed];
    SX3 -> CM6; SX7 -> CM7; CM6 -> CM8; CM7 -> CM8; CM1 -> CM8;
  }

  /* ============ CLUSTER 11: SSRI (SERTRALINE/PAROXETINE) PK/PD ============ */
  subgraph cluster_ss {
    label="11. SSRI (Sertraline/Paroxetine) PK/PD";
    style=filled; color="#EBF5FB"; fontsize=13;
    SS1 [label="Sertraline 경구\n흡수(위장관 데포)", fillcolor="#D6EAF8"];
    SS2 [label="Sertraline 혈장\n(CYP2C19/2B6/2D6\n대사)", fillcolor="#AED6F1"];
    SS3 [label="Paroxetine 경구\n흡수(위장관 데포)", fillcolor="#85C1E9"];
    SS4 [label="Paroxetine 혈장\n(CYP2D6, 자가억제)", fillcolor="#5DADE2"];
    SS5 [label="세로토닌수송체\n(SERT) 점유율", fillcolor="#3498DB", fontcolor=white];
    SS6 [label="하류 5-HT1A/5-HT2A\n적응성 신호", fillcolor="#2E86C1", fontcolor=white];
    SS7 [label="지연된 발현\n(수용체 하향조절,\n~2-4주)", fillcolor="#21618C", fontcolor=white];
    SS8 [label="편도체 반응성\n둔화(SSRI 효과)", fillcolor="#1B4F72", fontcolor=white];
    SS9 [label="위장/성기능 부작용\n부담(중단 요인)", fillcolor="#154360", fontcolor=white];
    SS1 -> SS2; SS3 -> SS4; SS2 -> SS5; SS4 -> SS5; SS5 -> SS6; SS6 -> SS7; SS7 -> SS8; SS8 -> CI1 [style=dashed, color="#196F3D", label="dampens"]; SS2 -> SS9 [style=dashed];
  }

  /* ============ CLUSTER 12: PRAZOSIN PK/PD ============ */
  subgraph cluster_pz {
    label="12. Prazosin (알파1 차단제) PK/PD";
    style=filled; color="#F9EBEA"; fontsize=13;
    PZ1 [label="Prazosin 경구\n흡수(위장관 데포)", fillcolor="#F2D7D5"];
    PZ2 [label="Prazosin 혈장\n(간 CYP3A4 대사)", fillcolor="#E6B0AA"];
    PZ3 [label="중추 알파1\n아드레날린수용체 차단", fillcolor="#D98880"];
    PZ4 [label="악몽 빈도/강도\n감소", fillcolor="#CD6155"];
    PZ5 [label="REM 수면\n정상화", fillcolor="#B03A2E"];
    PZ6 [label="기립성 저혈압\n위험(첫용량 효과)", fillcolor="#943126"];
    PZ7 [label="혈압 저하\n(말초 알파1 차단)", fillcolor="#78281F"];
    PZ1 -> PZ2; PZ2 -> PZ3; PZ3 -> NE3 [style=dashed, color="#196F3D", label="blocks"]; PZ3 -> PZ4; PZ4 -> PZ5; PZ5 -> SL2 [style=dashed, color="#196F3D"];
    PZ2 -> PZ6 [style=dashed]; PZ2 -> PZ7 [style=dashed];
  }

  /* ============ CLUSTER 13: KETAMINE/ESKETAMINE PK/PD ============ */
  subgraph cluster_kt {
    label="13. Ketamine/Esketamine PK/PD";
    style=filled; color="#D1F2EB"; fontsize=13;
    KT1 [label="IV 케타민/비강내\n에스케타민 투여", fillcolor="#A3E4D7"];
    KT2 [label="혈장 케타민/\n노르케타민 구획", fillcolor="#76D7C4"];
    KT3 [label="NMDA수용체 급성\n차단(글루타메이트 급증)", fillcolor="#48C9B0"];
    KT4 [label="AMPA수용체\n신호 증가", fillcolor="#17A589"];
    KT5 [label="mTOR매개 급속\n시냅스형성(효과구획/\n생체상)", fillcolor="#148F77"];
    KT6 [label="급속 소거학습\n촉진", fillcolor="#117864"];
    KT7 [label="일시적 해리/\n정신병유사 부작용", fillcolor="#0E6251"];
    KT8 [label="남용 위험/\n의존성", fillcolor="#0B5345"];
    KT1 -> KT2; KT2 -> KT3; KT3 -> KT4; KT3 -> KT5; KT5 -> KT6; KT6 -> FE3 [style=dashed, color="#196F3D", label="accelerates"]; KT2 -> KT7 [style=dashed]; KT1 -> KT8 [style=dashed];
  }

  /* ============ CLUSTER 14: MDMA-ASSISTED & TRAUMA-FOCUSED PSYCHOTHERAPY ============ */
  subgraph cluster_mp {
    label="14. MDMA 보조 심리치료 및 외상중심 심리치료 (MDMA-Assisted & Trauma-Focused Psychotherapy)";
    style=filled; color="#EBDEF0"; fontsize=13;
    MP1 [label="MDMA 경구 투여\n(세션 기반)", fillcolor="#D7BDE2"];
    MP2 [label="혈장 MDMA 구획\n(CYP2D6 포화대사)", fillcolor="#C39BD3"];
    MP3 [label="세로토닌/도파민/\n노르에피네프린\n방출작용", fillcolor="#AF7AC5", fontcolor=white];
    MP4 [label="옥시토신/프로락틴\n급증(친사회/신뢰효과)", fillcolor="#9B59B6", fontcolor=white];
    MP5 [label="공포소거 촉진창\n(처리세션 중 편도체\n반응성 감소)", fillcolor="#8E44AD", fontcolor=white];
    MP6 [label="지속노출치료(PE)\n세션 용량", fillcolor="#7D3C98", fontcolor=white];
    MP7 [label="인지처리치료(CPT)\n세션 용량", fillcolor="#6C3483", fontcolor=white];
    MP8 [label="EMDR 세션 용량", fillcolor="#5B2C6F", fontcolor=white];
    MP9 [label="누적 외상중심\n심리치료 용량\n(비약물 구동인자)", fillcolor="#4A235A", fontcolor=white];
    MP1 -> MP2; MP2 -> MP3; MP2 -> MP4; MP3 -> MP5; MP4 -> MP5; MP5 -> FE3 [style=dashed, color="#196F3D", label="facilitates"];
    MP6 -> MP9; MP7 -> MP9; MP8 -> MP9; MP9 -> FE3 [style=dashed, color="#196F3D"]; MP9 -> CI2 [style=dashed, color="#196F3D", label="strengthens"];
  }

  /* ============ CLUSTER 15: CLINICAL ASSESSMENT, BIOMARKERS & ENDPOINTS ============ */
  subgraph cluster_ce {
    label="15. 임상 평가/바이오마커/엔드포인트 (Clinical Assessment, Biomarkers & Endpoints)";
    style=filled; color="#FEF9E7"; fontsize=13;
    CE1  [label="CAPS-5 총점\n(임상가평정)", fillcolor="#FCF3CF"];
    CE2  [label="PCL-5 자가보고\n점수", fillcolor="#F9E79F"];
    CE3  [label="관해 기준\n(CAPS-5<=20 유지)", fillcolor="#F7DC6F"];
    CE4  [label="치료반응\n(CAPS-5 10점 이상 감소)", fillcolor="#F4D03F"];
    CE5  [label="추적소실/치료중단", fillcolor="#F1C40F"];
    CE6  [label="기상시 코르티솔반응\n바이오마커", fillcolor="#D4AC0D"];
    CE7  [label="심박변이도(HRV)\n바이오마커", fillcolor="#B7950B"];
    CE8  [label="공포증폭경악\n습관화 바이오마커", fillcolor="#9A7D0A"];
    CE9  [label="fMRI 편도체 반응성\n바이오마커(연구용)", fillcolor="#7D6608"];
    CE10 [label="전반적 기능/장애\n점수(WHODAS)", fillcolor="#6E5100"];
    SX1 -> CE1; SX2 -> CE1; SX3 -> CE1; SX4 -> CE1; SX5 -> CE1; SX6 -> CE1; SX7 -> CE1;
    CE1 -> CE2; CE1 -> CE3; CE1 -> CE4; SS9 -> CE5 [style=dashed]; HP6 -> CE6; NE6 -> CE7; NE7 -> CE8;
    CI1 -> CE9; CM6 -> CE10; CM8 -> CE10;
  }
}
