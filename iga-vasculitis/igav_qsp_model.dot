digraph IgA_Vasculitis_QSP {
  graph [
    fontname="Helvetica",
    fontsize=11,
    label="IgA Vasculitis (Henoch-Schönlein Purpura) — QSP Mechanistic Map",
    labelloc=t,
    labeljust=c,
    rankdir=TB,
    bgcolor="#f8f9fa",
    splines=ortho,
    nodesep=0.45,
    ranksep=0.7,
    compound=true
  ];
  node [fontname="Helvetica", fontsize=8, style=filled];
  edge [fontname="Helvetica", fontsize=7, arrowsize=0.7];

  // ============================================================
  // CLUSTER 1: IgA1 PRODUCTION & GLYCOSYLATION DEFECT
  // ============================================================
  subgraph cluster_iga_production {
    label="IgA1 Production & Galactose-Deficient IgA1 (Gd-IgA1)";
    style=filled;
    fillcolor="#fff0f0";
    color="#cc0000";
    fontsize=10;
    fontcolor="#cc0000";

    // Cells
    BCell       [label="B Cell (IgA+)", shape=ellipse, fillcolor="#ffcccc"];
    PlasmaCell  [label="Plasma Cell\n(IgA-secreting)", shape=ellipse, fillcolor="#ffcccc"];
    Th2Cell     [label="Th2 Cell", shape=ellipse, fillcolor="#ffdddd"];
    Tfh         [label="T Follicular\nHelper (Tfh)", shape=ellipse, fillcolor="#ffdddd"];
    pDC         [label="Plasmacytoid\nDendritic Cell", shape=ellipse, fillcolor="#ffdddd"];
    ILC2        [label="ILC2", shape=ellipse, fillcolor="#ffdddd"];

    // Molecules / Cytokines
    APRIL       [label="APRIL", shape=box, fillcolor="#ffaaaa"];
    BAFF        [label="BAFF", shape=box, fillcolor="#ffaaaa"];
    IL4         [label="IL-4", shape=box, fillcolor="#ffaaaa"];
    IL5         [label="IL-5", shape=box, fillcolor="#ffaaaa"];
    IL6         [label="IL-6", shape=box, fillcolor="#ffaaaa"];
    IL10        [label="IL-10", shape=box, fillcolor="#ffaaaa"];
    IL13        [label="IL-13", shape=box, fillcolor="#ffaaaa"];
    TGFb_B      [label="TGF-β\n(B cell class switch)", shape=box, fillcolor="#ffaaaa"];

    // Glycosylation enzymes & IgA forms
    C1GalT1     [label="C1GalT1\n(Cosmc chaperone)", shape=box, fillcolor="#ff8888"];
    ST6GalNAc   [label="ST6GalNAc-II\n(sialylation)", shape=box, fillcolor="#ff8888"];
    IgA1_normal [label="Normal IgA1\n(galactosylated)", shape=box, fillcolor="#ffd0d0"];
    GdIgA1      [label="Gd-IgA1\n(galactose-deficient IgA1)", shape=box, fillcolor="#ff4444", fontcolor="white"];
    PolyIgA1    [label="Polymeric IgA1", shape=box, fillcolor="#ffd0d0"];
    SecIgA      [label="Secretory IgA\n(sIgA)", shape=box, fillcolor="#ffd0d0"];

    // Mucosal triggers
    MucosalInfection [label="Mucosal Infection\n(URT / GI pathogens)", shape=diamond, fillcolor="#ff9999"];
    IgACSR           [label="IgA Class-Switch\nRecombination", shape=box, fillcolor="#ffbbbb"];
    ToleranceBreak   [label="Tolerance\nBreakdown", shape=diamond, fillcolor="#ff9999"];

    // Edges within cluster
    MucosalInfection -> BCell [label="antigen\nstimulation"];
    MucosalInfection -> pDC [label="TLR activation"];
    pDC -> BAFF [label="produces"];
    pDC -> APRIL [label="produces"];
    ILC2 -> IL4; ILC2 -> IL13;
    Th2Cell -> IL4; Th2Cell -> IL5; Th2Cell -> IL13;
    Tfh -> IL6; Tfh -> IL10;
    BAFF -> BCell [label="survival\nsignal"];
    APRIL -> BCell [label="IgA CSR"];
    IL4 -> IgACSR; TGFb_B -> IgACSR;
    IL6 -> PlasmaCell [label="differentiation"];
    BCell -> IgACSR;
    IgACSR -> PlasmaCell;
    ToleranceBreak -> BCell [label="auto-reactive\nclone expansion"];

    // Glycosylation pathway
    PlasmaCell -> C1GalT1 [label="expresses\n(reduced)"];
    C1GalT1 -> IgA1_normal [label="adds Gal\n(normal)"];
    PlasmaCell -> ST6GalNAc [label="expresses\n(increased)"];
    ST6GalNAc -> GdIgA1 [label="premature\nsialylation → Gal deficiency"];
    PlasmaCell -> GdIgA1 [label="secretes\n(>50% abnormal)"];
    PlasmaCell -> IgA1_normal;
    IgA1_normal -> PolyIgA1;
    GdIgA1 -> PolyIgA1;
    PolyIgA1 -> SecIgA [label="+ pIgR\ntransport"];
  }

  // ============================================================
  // CLUSTER 2: IMMUNE COMPLEX FORMATION
  // ============================================================
  subgraph cluster_immune_complex {
    label="Immune Complex Formation & Autoantibodies";
    style=filled;
    fillcolor="#fff5e6";
    color="#cc6600";
    fontsize=10;
    fontcolor="#cc6600";

    AntiGdIgG   [label="Anti-Gd-IgA1 IgG\nautoantibody", shape=box, fillcolor="#ffcc88"];
    AntiGdIgA1  [label="Anti-Gd-IgA1 IgA1\nautoantibody", shape=box, fillcolor="#ffcc88"];
    IgG_BCR     [label="IgG B Cell\n(auto-reactive)", shape=ellipse, fillcolor="#ffd8aa"];
    IC_large    [label="Large IgA1-IgG\nImmune Complexes (LIC)", shape=box, fillcolor="#ff8800", fontcolor="white"];
    IC_small    [label="Small Immune\nComplexes", shape=box, fillcolor="#ffbb44"];
    ASGPR       [label="Asialoglycoprotein\nReceptor (ASGPR)\n– hepatic clearance", shape=box, fillcolor="#ffe0bb"];
    FcaRI       [label="FcαRI (CD89)\n– myeloid cells", shape=box, fillcolor="#ffe0bb"];
    IC_deposit  [label="Circulating IC\nDeposition", shape=diamond, fillcolor="#ff8800", fontcolor="white"];
    Galectin3   [label="Galectin-3BP\n(Gd-IgA1 ligand)", shape=box, fillcolor="#ffcc88"];
    TransGlu    [label="Transglutaminase 2\n(TG2) auto-Ag", shape=box, fillcolor="#ffcc88"];

    GdIgA1 -> IC_large [label="binds anti-Gd-IgA1 IgG"];
    GdIgA1 -> AntiGdIgG [label="self-antigen"];
    IgG_BCR -> AntiGdIgG [label="secretes"];
    AntiGdIgG -> IC_large;
    AntiGdIgA1 -> IC_large;
    GdIgA1 -> IC_small;
    IC_large -> IC_deposit [label="escapes\nclearance"];
    IC_small -> IC_deposit;
    ASGPR -> GdIgA1 [label="impaired\nclearance", style=dashed, color="#cc6600"];
    FcaRI -> IC_large [label="binds\n(Fc-alpha)"];
    Galectin3 -> GdIgA1 [label="binds exposed\nGalNAc"];
    TransGlu -> AntiGdIgG [label="cross-reactive\nepitope"];
  }

  // ============================================================
  // CLUSTER 3: COMPLEMENT ACTIVATION
  // ============================================================
  subgraph cluster_complement {
    label="Complement Activation (Lectin & Alternative Pathways)";
    style=filled;
    fillcolor="#f0f8ff";
    color="#003399";
    fontsize=10;
    fontcolor="#003399";

    MBL         [label="MBL\n(Mannose-Binding Lectin)", shape=box, fillcolor="#aaccff"];
    Ficolin1    [label="Ficolin-1/2/3", shape=box, fillcolor="#aaccff"];
    MASP1       [label="MASP-1", shape=box, fillcolor="#aaccff"];
    MASP2       [label="MASP-2", shape=box, fillcolor="#aaccff"];
    C4          [label="C4", shape=box, fillcolor="#aaccff"];
    C2          [label="C2", shape=box, fillcolor="#aaccff"];
    C3          [label="C3", shape=box, fillcolor="#aaddff"];
    C3b         [label="C3b\n(opsonin)", shape=box, fillcolor="#88aaff"];
    C3a         [label="C3a\n(anaphylatoxin)", shape=box, fillcolor="#88aaff"];
    C5          [label="C5", shape=box, fillcolor="#aaddff"];
    C5a         [label="C5a\n(anaphylatoxin)", shape=box, fillcolor="#4488ff", fontcolor="white"];
    C5b         [label="C5b", shape=box, fillcolor="#88aaff"];
    MAC         [label="MAC\n(C5b-9)", shape=box, fillcolor="#0044cc", fontcolor="white"];
    sC5b9       [label="soluble C5b-9\n(sC5b-9)", shape=box, fillcolor="#4488ff", fontcolor="white"];
    AltPath     [label="Alternative\nPathway C3 convertase\n(C3bBb)", shape=box, fillcolor="#aaccff"];
    Properdin   [label="Properdin\n(Factor P)", shape=box, fillcolor="#aaccff"];
    FactorB     [label="Factor B", shape=box, fillcolor="#aaccff"];
    FactorD     [label="Factor D", shape=box, fillcolor="#aaccff"];
    CD46        [label="CD46\n(complement\nregulator)", shape=box, fillcolor="#ccddff"];
    CFH         [label="Complement\nFactor H (CFH)", shape=box, fillcolor="#ccddff"];
    CRP         [label="C-Reactive\nProtein (CRP)", shape=box, fillcolor="#ccddff"];

    IC_deposit -> MBL [label="GdIgA1 activates\nlectin pathway"];
    IC_deposit -> Ficolin1;
    MBL -> MASP1; MBL -> MASP2;
    Ficolin1 -> MASP1; Ficolin1 -> MASP2;
    MASP1 -> C4; MASP2 -> C4;
    C4 -> C2 [label="C4b+C2"];
    C2 -> C3 [label="C3 convertase\n(C4b2a)"];
    C3 -> C3b; C3 -> C3a;
    C3b -> AltPath [label="amplification\nloop"];
    FactorB -> AltPath; FactorD -> AltPath; Properdin -> AltPath;
    AltPath -> C3b [label="amplifies"];
    C3b -> C5 [label="C5 convertase\n(C3b2Bb)"];
    C5 -> C5a; C5 -> C5b;
    C5b -> MAC [label="+ C6-C9"];
    MAC -> sC5b9 [label="fluid-phase\nrelease"];
    CFH -> AltPath [label="inhibits", style=dashed, color="#003399"];
    CD46 -> C3b [label="cofactor\ndegradation", style=dashed, color="#003399"];
    CRP -> IC_deposit [label="facilitates\ncomplement"];
  }

  // ============================================================
  // CLUSTER 4: VASCULAR INFLAMMATION
  // ============================================================
  subgraph cluster_vascular {
    label="Vascular Inflammation & Leukocyte Recruitment";
    style=filled;
    fillcolor="#fff8e0";
    color="#cc8800";
    fontsize=10;
    fontcolor="#cc8800";

    Endothelium  [label="Vascular\nEndothelium", shape=ellipse, fillcolor="#ffe066"];
    VCAM1        [label="VCAM-1", shape=box, fillcolor="#ffdd44"];
    ICAM1        [label="ICAM-1", shape=box, fillcolor="#ffdd44"];
    Esel         [label="E-Selectin", shape=box, fillcolor="#ffdd44"];
    Psel         [label="P-Selectin", shape=box, fillcolor="#ffdd44"];
    VWF          [label="vWF\n(von Willebrand\nFactor)", shape=box, fillcolor="#ffdd44"];
    Neutrophil   [label="Neutrophil", shape=ellipse, fillcolor="#ffcc00"];
    Monocyte     [label="Monocyte /\nMacrophage", shape=ellipse, fillcolor="#ffcc00"];
    NETosis      [label="NETosis\n(neutrophil traps)", shape=box, fillcolor="#ff9900"];
    ROS          [label="ROS / Oxidative\nStress", shape=box, fillcolor="#ff9900"];
    NEut_Elast   [label="Neutrophil\nElastase", shape=box, fillcolor="#ff9900"];
    MMP9         [label="MMP-9", shape=box, fillcolor="#ff9900"];
    TNFa         [label="TNF-α", shape=box, fillcolor="#ff9900"];
    IL1b         [label="IL-1β", shape=box, fillcolor="#ff9900"];
    IL8          [label="IL-8\n(CXCL8)", shape=box, fillcolor="#ff9900"];
    NFkB_V       [label="NF-κB\n(endothelium)", shape=box, fillcolor="#ffbb00"];
    LukocVas     [label="Leukocytoclastic\nVasculitis", shape=diamond, fillcolor="#cc8800", fontcolor="white"];
    PermeabInc   [label="Vascular\nPermeability ↑", shape=diamond, fillcolor="#cc8800", fontcolor="white"];
    Fibrin_dep   [label="Fibrin\nDeposition", shape=box, fillcolor="#ffcc66"];
    PAI1         [label="PAI-1\n(thrombosis risk)", shape=box, fillcolor="#ffcc66"];

    C5a -> Neutrophil [label="chemoattract"];
    C5a -> Monocyte [label="chemoattract"];
    C3a -> Endothelium [label="activates"];
    MAC -> Endothelium [label="sublytic\nactivation"];
    IC_deposit -> Endothelium [label="deposits\nin vessel wall"];
    TNFa -> Endothelium [label="activates"];
    IL1b -> Endothelium [label="activates"];
    Endothelium -> NFkB_V [label="activates"];
    NFkB_V -> VCAM1; NFkB_V -> ICAM1; NFkB_V -> Esel; NFkB_V -> IL8;
    Endothelium -> Psel [label="Weibel-Palade\nbody exocytosis"];
    Endothelium -> VWF;
    VCAM1 -> Neutrophil [label="adhesion"];
    ICAM1 -> Neutrophil [label="firm adhesion"];
    Esel -> Neutrophil [label="rolling"];
    VCAM1 -> Monocyte [label="adhesion"];
    IL8 -> Neutrophil [label="chemoattract"];
    Neutrophil -> NETosis;
    Neutrophil -> ROS;
    Neutrophil -> NEut_Elast;
    Neutrophil -> MMP9;
    Neutrophil -> TNFa; Neutrophil -> IL1b;
    Monocyte -> TNFa; Monocyte -> IL1b;
    NETosis -> LukocVas;
    ROS -> PermeabInc;
    NEut_Elast -> PermeabInc;
    MMP9 -> PermeabInc;
    PermeabInc -> Fibrin_dep;
    Fibrin_dep -> PAI1;
    LukocVas -> PermeabInc;
  }

  // ============================================================
  // CLUSTER 5: RENAL PATHOLOGY
  // ============================================================
  subgraph cluster_renal {
    label="Renal Pathology (IgAV Nephritis)";
    style=filled;
    fillcolor="#f0fff0";
    color="#006600";
    fontsize=10;
    fontcolor="#006600";

    Mesangium    [label="Mesangial Cell", shape=ellipse, fillcolor="#88ff88"];
    MesDep       [label="Mesangial IgA\nDeposition", shape=box, fillcolor="#44cc44", fontcolor="white"];
    MesProli     [label="Mesangial Cell\nProliferation", shape=diamond, fillcolor="#44cc44", fontcolor="white"];
    MesMatrix    [label="Mesangial\nMatrix Expansion", shape=diamond, fillcolor="#44cc44", fontcolor="white"];
    PDGF_R       [label="PDGF-B\n(proliferation signal)", shape=box, fillcolor="#88ff88"];
    TGFb_R       [label="TGF-β1\n(renal fibrosis)", shape=box, fillcolor="#88ff88"];
    CTGF         [label="CTGF / CCN2", shape=box, fillcolor="#88ff88"];
    Podocyte     [label="Podocyte", shape=ellipse, fillcolor="#66cc66"];
    SynaptoP     [label="Synaptopodin", shape=box, fillcolor="#aaffaa"];
    Nephrin      [label="Nephrin\n(slit diaphragm)", shape=box, fillcolor="#aaffaa"];
    Podocin      [label="Podocin", shape=box, fillcolor="#aaffaa"];
    PodInjury    [label="Podocyte\nInjury / Effacement", shape=diamond, fillcolor="#006600", fontcolor="white"];
    Proteinuria  [label="Proteinuria", shape=diamond, fillcolor="#006600", fontcolor="white"];
    Hematuria    [label="Hematuria\n(micro/macro)", shape=diamond, fillcolor="#006600", fontcolor="white"];
    Crescent     [label="Crescent\nFormation", shape=diamond, fillcolor="#006600", fontcolor="white"];
    FSGS_prog    [label="FSGS\nProgression", shape=diamond, fillcolor="#003300", fontcolor="white"];
    GBM_dmg      [label="Glomerular\nBasement Membrane\nDamage", shape=box, fillcolor="#88cc88"];
    TubuloInt    [label="Tubulointerstitial\nInflammation", shape=box, fillcolor="#88cc88"];
    Fibrosis_R   [label="Renal\nFibrosis", shape=diamond, fillcolor="#005500", fontcolor="white"];
    eGFR_dec     [label="eGFR\nDecline", shape=diamond, fillcolor="#003300", fontcolor="white"];
    CKD_prog     [label="CKD\nProgression", shape=diamond, fillcolor="#002200", fontcolor="white"];
    Ang2_R       [label="Angiotensin II\n(renal)", shape=box, fillcolor="#aaffaa"];
    RAAS_R       [label="RAAS\nActivation", shape=box, fillcolor="#aaffaa"];
    GlomHTN      [label="Glomerular\nHypertension", shape=diamond, fillcolor="#006600", fontcolor="white"];
    IgA_FcaR     [label="FcαR on\nMesangial Cells", shape=box, fillcolor="#88ff88"];
    NF_kB_M      [label="NF-κB\n(mesangium)", shape=box, fillcolor="#88ff88"];
    IL6_R        [label="IL-6\n(renal)", shape=box, fillcolor="#88ff88"];
    MCP1         [label="MCP-1\n(CCL2)", shape=box, fillcolor="#88ff88"];
    CXC13        [label="CXCL13\n(B cell chemoattract)", shape=box, fillcolor="#88ff88"];
    Nephro_Inflam [label="Nephritis\nActivity Score", shape=diamond, fillcolor="#009900", fontcolor="white"];

    IC_deposit -> MesDep [label="IgA-IC mesangial\ndeposition"];
    MesDep -> Mesangium [label="activates"];
    Mesangium -> IgA_FcaR [label="expresses FcαR"];
    IgA_FcaR -> NF_kB_M [label="IC binding\nactivates"];
    NF_kB_M -> PDGF_R; NF_kB_M -> TGFb_R; NF_kB_M -> IL6_R; NF_kB_M -> MCP1;
    PDGF_R -> MesProli [label="drives"];
    TGFb_R -> MesMatrix [label="drives"];
    MesMatrix -> CTGF;
    CTGF -> Fibrosis_R;
    TGFb_R -> Fibrosis_R;
    MesProli -> Nephro_Inflam;
    MesDep -> Hematuria [label="disrupts GFB"];
    GBM_dmg -> Hematuria;
    GBM_dmg -> Proteinuria;
    PodInjury -> Proteinuria [label="slit-diaphragm\nloss"];
    Nephrin -> Podocyte [label="structural"];
    Podocin -> Podocyte [label="structural"];
    SynaptoP -> Podocyte [label="structural"];
    C5a -> Podocyte [label="injures"];
    MAC -> Podocyte [label="injures"];
    TGFb_R -> PodInjury;
    Mesangium -> GBM_dmg [label="matrix\naccumulation"];
    MCP1 -> TubuloInt [label="monocyte\nrecruitment"];
    IL6_R -> Crescent [label="parietal\nepithelial cell"];
    Crescent -> FSGS_prog;
    TubuloInt -> Fibrosis_R;
    Proteinuria -> CKD_prog;
    Fibrosis_R -> eGFR_dec;
    FSGS_prog -> eGFR_dec;
    eGFR_dec -> CKD_prog;
    RAAS_R -> Ang2_R;
    Ang2_R -> GlomHTN;
    Ang2_R -> TGFb_R [label="activates\nfibrosis"];
    GlomHTN -> Proteinuria;
    GlomHTN -> eGFR_dec;
    CXC13 -> TubuloInt;
    Nephro_Inflam -> MesProli;
    Nephro_Inflam -> Hematuria;
    Nephro_Inflam -> Proteinuria;
  }

  // ============================================================
  // CLUSTER 6: SKIN MANIFESTATIONS
  // ============================================================
  subgraph cluster_skin {
    label="Skin Manifestations (Palpable Purpura)";
    style=filled;
    fillcolor="#fff0ff";
    color="#660066";
    fontsize=10;
    fontcolor="#660066";

    DermalVessel [label="Dermal\nPost-capillary Venule", shape=ellipse, fillcolor="#ffccff"];
    IgA_Skin     [label="IgA Deposits\nin Dermal Vessels", shape=box, fillcolor="#cc44cc", fontcolor="white"];
    C3_Skin      [label="C3 in Dermis", shape=box, fillcolor="#dd88dd"];
    Leuko_skin   [label="Leukocytoclastic\nVasculitis (LCV)\n– skin", shape=diamond, fillcolor="#660066", fontcolor="white"];
    Purpura      [label="Palpable\nPurpura", shape=diamond, fillcolor="#660066", fontcolor="white"];
    Petechiae    [label="Petechiae", shape=diamond, fillcolor="#880088", fontcolor="white"];
    Urticaria    [label="Urticaria /\nAngioedema", shape=diamond, fillcolor="#880088", fontcolor="white"];
    Necrosis_S   [label="Skin Necrosis\n(severe)", shape=diamond, fillcolor="#440044", fontcolor="white"];
    Neutro_skin  [label="Neutrophil\nInfiltration\n(dermis)", shape=ellipse, fillcolor="#ffaaff"];
    MastCell     [label="Mast Cell\nDegranulation", shape=ellipse, fillcolor="#ffaaff"];
    Histamine    [label="Histamine", shape=box, fillcolor="#ffaaff"];
    IgE_skin     [label="IgE\n(atopic co-factor)", shape=box, fillcolor="#ffaaff"];

    IC_deposit -> DermalVessel [label="IgA-IC\ndeposition"];
    DermalVessel -> IgA_Skin;
    IgA_Skin -> C3_Skin [label="complement\nactivation"];
    C3_Skin -> Neutro_skin [label="C3a/C5a\nrecruitment"];
    Neutro_skin -> Leuko_skin;
    Leuko_skin -> Purpura;
    Leuko_skin -> Petechiae;
    PermeabInc -> Urticaria;
    MastCell -> Histamine;
    IgE_skin -> MastCell [label="triggers"];
    Histamine -> Urticaria;
    Leuko_skin -> Necrosis_S [label="severe\nischemia"];
    LukocVas -> Leuko_skin [label="shared\nmechanism"];
  }

  // ============================================================
  // CLUSTER 7: GI & JOINT MANIFESTATIONS
  // ============================================================
  subgraph cluster_gi_joint {
    label="GI & Joint Manifestations";
    style=filled;
    fillcolor="#f0f8f0";
    color="#007700";
    fontsize=10;
    fontcolor="#007700";

    GI_Vessel    [label="GI Mucosal\nVessels", shape=ellipse, fillcolor="#99ddaa"];
    GI_IgA_dep   [label="IgA Deposits\n(GI mucosa)", shape=box, fillcolor="#44bb66", fontcolor="white"];
    GI_Edema     [label="GI Wall\nEdema", shape=diamond, fillcolor="#007700", fontcolor="white"];
    AbdPain      [label="Abdominal\nPain / Cramps", shape=diamond, fillcolor="#007700", fontcolor="white"];
    GI_Bleed     [label="GI Bleeding", shape=diamond, fillcolor="#005500", fontcolor="white"];
    Intussus     [label="Intussusception\n(rare, pediatric)", shape=diamond, fillcolor="#005500", fontcolor="white"];
    GI_Ischemia  [label="Bowel\nIschemia", shape=diamond, fillcolor="#004400", fontcolor="white"];
    Nausea_Vom   [label="Nausea /\nVomiting", shape=diamond, fillcolor="#007700", fontcolor="white"];

    // Joint
    Synovium     [label="Synovium", shape=ellipse, fillcolor="#99ddaa"];
    IgA_Joint    [label="IgA / IC\nDeposition (joint)", shape=box, fillcolor="#44bb66", fontcolor="white"];
    Synovitis    [label="Synovitis", shape=diamond, fillcolor="#007700", fontcolor="white"];
    Arthralgia   [label="Arthralgia /\nArthritis", shape=diamond, fillcolor="#007700", fontcolor="white"];
    JtSwelling   [label="Joint Swelling\n(knee/ankle)", shape=diamond, fillcolor="#007700", fontcolor="white"];
    IL17_J       [label="IL-17\n(joint inflammation)", shape=box, fillcolor="#99ddaa"];
    Th17Cell     [label="Th17 Cell", shape=ellipse, fillcolor="#bbeecc"];

    IC_deposit -> GI_Vessel [label="mucosal\ndeposition"];
    GI_Vessel -> GI_IgA_dep;
    GI_IgA_dep -> GI_Edema;
    GI_Edema -> AbdPain;
    GI_Edema -> Nausea_Vom;
    GI_IgA_dep -> GI_Bleed [label="vessel wall\nrupture"];
    GI_Bleed -> Intussus [label="lead point"];
    GI_Edema -> GI_Ischemia;
    GI_Ischemia -> GI_Bleed;

    IC_deposit -> Synovium [label="joint\ndeposition"];
    Synovium -> IgA_Joint;
    Th17Cell -> IL17_J;
    IL17_J -> Synovitis;
    IgA_Joint -> Synovitis;
    Synovitis -> Arthralgia;
    Synovitis -> JtSwelling;
  }

  // ============================================================
  // CLUSTER 8: CLINICAL ENDPOINTS
  // ============================================================
  subgraph cluster_endpoints {
    label="Clinical Endpoints & Disease Severity";
    style=filled;
    fillcolor="#f5f5f5";
    color="#333333";
    fontsize=10;
    fontcolor="#333333";

    HSP_score    [label="HSP\nDisease Score\n(PVAS / BVAS)", shape=diamond, fillcolor="#666666", fontcolor="white"];
    Purpura_EP   [label="Purpura\nEndpoint", shape=diamond, fillcolor="#884488", fontcolor="white"];
    Nephritis_EP [label="Nephritis\nEndpoint\n(ISKDC grade)", shape=diamond, fillcolor="#226622", fontcolor="white"];
    eGFR_EP      [label="eGFR\n(mL/min/1.73m²)", shape=diamond, fillcolor="#114411", fontcolor="white"];
    Proteinuria_EP[label="Proteinuria\n(g/day)", shape=diamond, fillcolor="#226622", fontcolor="white"];
    CKD_Stage    [label="CKD Stage\n(1–5)", shape=diamond, fillcolor="#002200", fontcolor="white"];
    ESRD_risk    [label="ESRD\nRisk", shape=diamond, fillcolor="#000000", fontcolor="white"];
    GI_EP        [label="GI\nEndpoint", shape=diamond, fillcolor="#336633", fontcolor="white"];
    Joint_EP     [label="Joint\nEndpoint", shape=diamond, fillcolor="#336633", fontcolor="white"];
    Recurrence   [label="Disease\nRecurrence", shape=diamond, fillcolor="#555555", fontcolor="white"];
    QoL          [label="Quality of\nLife (QoL)", shape=diamond, fillcolor="#555555", fontcolor="white"];
    IgA_serum    [label="Serum IgA\nLevel", shape=diamond, fillcolor="#888888", fontcolor="white"];
    GdIgA1_serum [label="Serum Gd-IgA1\nLevel (biomarker)", shape=diamond, fillcolor="#888888", fontcolor="white"];

    Purpura -> Purpura_EP;
    Leuko_skin -> Purpura_EP;
    Nephro_Inflam -> Nephritis_EP;
    eGFR_dec -> eGFR_EP;
    Proteinuria -> Proteinuria_EP;
    CKD_prog -> CKD_Stage;
    CKD_Stage -> ESRD_risk;
    AbdPain -> GI_EP; GI_Bleed -> GI_EP;
    Arthralgia -> Joint_EP;
    Purpura_EP -> HSP_score;
    Nephritis_EP -> HSP_score;
    GI_EP -> HSP_score;
    Joint_EP -> HSP_score;
    HSP_score -> QoL;
    HSP_score -> Recurrence;
    GdIgA1 -> GdIgA1_serum;
    PolyIgA1 -> IgA_serum;
    eGFR_EP -> CKD_Stage;
    Proteinuria_EP -> CKD_Stage;
  }

  // ============================================================
  // CLUSTER 9: DRUG PK COMPARTMENTS
  // ============================================================
  subgraph cluster_pk {
    label="Drug PK Compartments";
    style=filled;
    fillcolor="#e8f4fd";
    color="#003377";
    fontsize=10;
    fontcolor="#003377";

    // Corticosteroids (Prednisolone)
    Pred_Gut  [label="Prednisolone\nGut (Fabs)", shape=hexagon, fillcolor="#aaddff"];
    Pred_C    [label="Prednisolone\nCentral (Vc)", shape=hexagon, fillcolor="#77bbff"];
    Pred_P    [label="Prednisolone\nPeripheral (Vp)", shape=hexagon, fillcolor="#55aaff"];
    Pred_T    [label="Prednisolone\nTissue (receptor)", shape=hexagon, fillcolor="#3399ff"];

    // MMF / MPA
    MMF_Gut   [label="MMF → MPA\nGut (Fabs)", shape=hexagon, fillcolor="#aaddff"];
    MPA_C     [label="MPA\nCentral (Vc)", shape=hexagon, fillcolor="#77bbff"];
    MPA_P     [label="MPA\nPeripheral (Vp)", shape=hexagon, fillcolor="#55aaff"];
    MPAG      [label="MPAG\n(inactive metabolite)", shape=hexagon, fillcolor="#aaddff"];

    // Azathioprine / 6-MP
    AZA_Gut   [label="Azathioprine\nGut (Fabs)", shape=hexagon, fillcolor="#aaddff"];
    SMP_C     [label="6-MP / 6-TGN\nCentral", shape=hexagon, fillcolor="#77bbff"];
    TPMT_enz  [label="TPMT Enzyme\n(metabolism)", shape=box, fillcolor="#ccddff"];

    // Rituximab
    RTX_C     [label="Rituximab\nCentral (Vc)", shape=hexagon, fillcolor="#77bbff"];
    RTX_P     [label="Rituximab\nPeripheral (Vp)", shape=hexagon, fillcolor="#55aaff"];
    RTX_depot [label="Rituximab\nLymph Node Depot", shape=hexagon, fillcolor="#3399ff"];

    // Sparsentan (dual AT1/ET receptor antagonist)
    Spar_Gut  [label="Sparsentan\nGut (Fabs)", shape=hexagon, fillcolor="#aaddff"];
    Spar_C    [label="Sparsentan\nCentral (Vc)", shape=hexagon, fillcolor="#77bbff"];
    Spar_P    [label="Sparsentan\nPeripheral (Vp)", shape=hexagon, fillcolor="#55aaff"];

    // SGLT2 inhibitor (dapagliflozin)
    SGLT2i_C  [label="SGLT2i\nCentral (Vc)", shape=hexagon, fillcolor="#77bbff"];
    SGLT2i_P  [label="SGLT2i\nPeripheral (Vp)", shape=hexagon, fillcolor="#55aaff"];

    // ACEi (ramipril)
    ACEi_C    [label="ACEi/ARB\nCentral (Vc)", shape=hexagon, fillcolor="#77bbff"];
    ACEi_P    [label="ACEi/ARB\nPeripheral (Vp)", shape=hexagon, fillcolor="#55aaff"];

    // PK transitions
    Pred_Gut -> Pred_C [label="ka (absorption)"];
    Pred_C -> Pred_P [label="kcp"];
    Pred_P -> Pred_C [label="kpc"];
    Pred_C -> Pred_T [label="receptor\ndistribution"];

    MMF_Gut -> MPA_C [label="ka + hydrolysis"];
    MPA_C -> MPA_P [label="kcp"];
    MPA_P -> MPA_C [label="kpc"];
    MPA_C -> MPAG [label="glucuronidation\n(UGT1A9)"];

    AZA_Gut -> SMP_C [label="ka + conversion\nto 6-TGN"];
    SMP_C -> TPMT_enz [label="inactivation"];

    RTX_C -> RTX_P [label="kcp"];
    RTX_P -> RTX_C [label="kpc"];
    RTX_C -> RTX_depot [label="lymph node\nsequestration"];

    Spar_Gut -> Spar_C [label="ka"];
    Spar_C -> Spar_P [label="kcp"];
    Spar_P -> Spar_C [label="kpc"];

    SGLT2i_C -> SGLT2i_P [label="kcp"];
    SGLT2i_P -> SGLT2i_C [label="kpc"];

    ACEi_C -> ACEi_P [label="kcp"];
    ACEi_P -> ACEi_C [label="kpc"];
  }

  // ============================================================
  // CLUSTER 10: THERAPEUTIC TARGETS & PD EFFECTS
  // ============================================================
  subgraph cluster_therapeutics {
    label="Therapeutic Targets & Pharmacodynamic Effects";
    style=filled;
    fillcolor="#eaf4ea";
    color="#004400";
    fontsize=10;
    fontcolor="#004400";

    // Corticosteroids
    GR_recept    [label="Glucocorticoid\nReceptor (GR)", shape=box, fillcolor="#aaffaa"];
    GRE          [label="GRE\n(gene transactivation)", shape=box, fillcolor="#aaffaa"];
    Pred_antiInf [label="Anti-inflammatory\nEffect (Pred)", shape=box, fillcolor="#44cc44", fontcolor="white"];
    Pred_immuno  [label="Immunosuppression\n(Pred)", shape=box, fillcolor="#44cc44", fontcolor="white"];

    // MMF / MPA
    IMPDH        [label="IMPDH\n(inosine monophosphate\ndehydrogenase)", shape=box, fillcolor="#aaffaa"];
    GMP_synth    [label="Guanosine\nSynthesis ↓", shape=box, fillcolor="#aaffaa"];
    Lympho_supp  [label="Lymphocyte\nProliferation ↓", shape=box, fillcolor="#44cc44", fontcolor="white"];

    // Azathioprine
    DNA_inh      [label="DNA Synthesis\nInhibition (6-TGN)", shape=box, fillcolor="#aaffaa"];
    Lympho_AZA   [label="T/B cell\nSuppression (AZA)", shape=box, fillcolor="#44cc44", fontcolor="white"];

    // Rituximab
    CD20_B       [label="CD20 on\nB Cells", shape=box, fillcolor="#aaffaa"];
    ADCC_RTX     [label="ADCC / CDC\n(B cell depletion)", shape=box, fillcolor="#44cc44", fontcolor="white"];
    BcellDep     [label="B Cell\nDepletion", shape=box, fillcolor="#44cc44", fontcolor="white"];
    IgA_Red      [label="IgA / Gd-IgA1\nReduction", shape=box, fillcolor="#44cc44", fontcolor="white"];

    // Sparsentan
    AT1R_block   [label="AT1R\nBlockade (Sparsentan)", shape=box, fillcolor="#aaffaa"];
    ETaR_block   [label="ETa Receptor\nBlockade (Sparsentan)", shape=box, fillcolor="#aaffaa"];
    Ang2_block   [label="Angiotensin II\nSignaling ↓", shape=box, fillcolor="#44cc44", fontcolor="white"];
    ET1_block    [label="Endothelin-1\nSignaling ↓", shape=box, fillcolor="#44cc44", fontcolor="white"];
    Spar_PD      [label="Proteinuria ↓\nGFR Preservation\n(Sparsentan)", shape=box, fillcolor="#006600", fontcolor="white"];

    // SGLT2i
    SGLT2        [label="SGLT2\n(proximal tubule)", shape=box, fillcolor="#aaffaa"];
    TubuGluc     [label="Tubular\nGlucose Reabsorption ↓", shape=box, fillcolor="#aaffaa"];
    TGF_SGLT2    [label="Tubuloglomerular\nFeedback ↑", shape=box, fillcolor="#aaffaa"];
    SGLT2i_PD    [label="Intraglomerular\nPressure ↓\nProteinuria ↓", shape=box, fillcolor="#006600", fontcolor="white"];
    SGLT2i_anti  [label="Anti-inflammatory\n& Anti-fibrotic\nEffect (SGLT2i)", shape=box, fillcolor="#006600", fontcolor="white"];

    // ACEi/ARB
    ACE_enz      [label="ACE\n(angiotensin\nconverting enzyme)", shape=box, fillcolor="#aaffaa"];
    Bradykinin   [label="Bradykinin ↑\n(ACEi)", shape=box, fillcolor="#aaffaa"];
    ACEi_PD      [label="RAAS Blockade\nGlomerular Protection", shape=box, fillcolor="#006600", fontcolor="white"];

    // IgA Protease (investigational)
    IgAprotease  [label="IgA Protease\n(recombinant)\n– investigational", shape=hexagon, fillcolor="#004400", fontcolor="white"];
    IgA_cleave   [label="Circulating IgA\nCleavage", shape=box, fillcolor="#aaffaa"];

    // Anti-BAFF / Anti-APRIL therapies
    Blisibimod   [label="Blisibimod\n(anti-BAFF/APRIL)", shape=hexagon, fillcolor="#004400", fontcolor="white"];
    Atacicept    [label="Atacicept\n(TACI-Fc, anti-BAFF+APRIL)", shape=hexagon, fillcolor="#004400", fontcolor="white"];

    // Complement inhibitors
    Avacopan     [label="Avacopan\n(C5aR antagonist)", shape=hexagon, fillcolor="#004400", fontcolor="white"];
    Ravulizumab  [label="Ravulizumab\n(anti-C5)", shape=hexagon, fillcolor="#004400", fontcolor="white"];

    // PD connections
    Pred_T -> GR_recept [label="binds"];
    GR_recept -> GRE [label="nuclear\ntranslocation"];
    GRE -> Pred_antiInf; GRE -> Pred_immuno;
    Pred_antiInf -> TNFa [label="inhibits", style=dashed, color="#006600"];
    Pred_antiInf -> IL1b [label="inhibits", style=dashed, color="#006600"];
    Pred_antiInf -> IL6 [label="inhibits", style=dashed, color="#006600"];
    Pred_immuno -> BCell [label="suppresses", style=dashed, color="#006600"];
    Pred_immuno -> Neutrophil [label="reduces\nmigration", style=dashed, color="#006600"];

    MPA_C -> IMPDH [label="inhibits"];
    IMPDH -> GMP_synth;
    GMP_synth -> Lympho_supp;
    Lympho_supp -> BCell [label="suppresses", style=dashed, color="#006600"];
    Lympho_supp -> Th2Cell [label="suppresses", style=dashed, color="#006600"];

    SMP_C -> DNA_inh [label="6-TGN\nincorporation"];
    DNA_inh -> Lympho_AZA;
    Lympho_AZA -> PlasmaCell [label="suppresses", style=dashed, color="#006600"];

    RTX_C -> CD20_B [label="binds\n(anti-CD20)"];
    CD20_B -> ADCC_RTX;
    ADCC_RTX -> BcellDep;
    BcellDep -> IgA_Red;
    IgA_Red -> GdIgA1 [label="reduces", style=dashed, color="#006600"];
    IgA_Red -> IC_large [label="reduces IC", style=dashed, color="#006600"];

    Spar_C -> AT1R_block; Spar_C -> ETaR_block;
    AT1R_block -> Ang2_block;
    ETaR_block -> ET1_block;
    Ang2_block -> Spar_PD; ET1_block -> Spar_PD;
    Spar_PD -> Proteinuria [label="reduces", style=dashed, color="#006600"];
    Spar_PD -> GlomHTN [label="reduces", style=dashed, color="#006600"];

    SGLT2i_C -> SGLT2 [label="inhibits"];
    SGLT2 -> TubuGluc;
    TubuGluc -> TGF_SGLT2;
    TGF_SGLT2 -> SGLT2i_PD;
    SGLT2i_C -> SGLT2i_anti [label="NF-κB\ninhibition"];
    SGLT2i_PD -> eGFR_dec [label="attenuates", style=dashed, color="#006600"];
    SGLT2i_anti -> TGFb_R [label="inhibits", style=dashed, color="#006600"];
    SGLT2i_anti -> Fibrosis_R [label="attenuates", style=dashed, color="#006600"];

    ACEi_C -> ACE_enz [label="inhibits"];
    ACE_enz -> RAAS_R [label="blocked →\nRAAS ↓"];
    ACE_enz -> Bradykinin;
    RAAS_R -> ACEi_PD [label="blocked"];
    ACEi_PD -> Ang2_R [label="reduces", style=dashed, color="#006600"];
    ACEi_PD -> Proteinuria [label="reduces", style=dashed, color="#006600"];
    ACEi_PD -> GlomHTN [label="reduces", style=dashed, color="#006600"];

    IgAprotease -> IgA_cleave;
    IgA_cleave -> GdIgA1 [label="degrades", style=dashed, color="#006600"];
    IgA_cleave -> IC_large [label="disrupts", style=dashed, color="#006600"];

    Blisibimod -> BAFF [label="neutralizes", style=dashed, color="#006600"];
    Blisibimod -> APRIL [label="neutralizes", style=dashed, color="#006600"];
    Atacicept -> BAFF [label="neutralizes", style=dashed, color="#006600"];
    Atacicept -> APRIL [label="neutralizes", style=dashed, color="#006600"];
    Blisibimod -> BCell [label="reduces\nsurvival", style=dashed, color="#006600"];

    Avacopan -> C5a [label="blocks C5aR", style=dashed, color="#006600"];
    Ravulizumab -> C5 [label="blocks C5\ncleavage", style=dashed, color="#006600"];
    Avacopan -> Neutrophil [label="reduces\nrecruitment", style=dashed, color="#006600"];
    Ravulizumab -> MAC [label="prevents\nformation", style=dashed, color="#006600"];
  }

  // ============================================================
  // INTER-CLUSTER EDGES (key connections between clusters)
  // ============================================================

  // IgA production → Immune complex
  GdIgA1 -> AntiGdIgG [label="autoantigen\n(triggers auto-Ab)"];
  GdIgA1 -> IC_large [lhead=cluster_immune_complex, label="forms IC"];

  // Immune complex → Complement
  IC_deposit -> MBL [ltail=cluster_immune_complex, label="lectin\nactivation"];

  // Complement → Vascular
  C5a -> Neutrophil [ltail=cluster_complement];
  C3a -> Endothelium [ltail=cluster_complement];
  MAC -> Endothelium [ltail=cluster_complement, label="sublytic\nMAC"];

  // Complement → Renal
  C5a -> Mesangium [ltail=cluster_complement, label="mesangial\nactivation"];
  sC5b9 -> MesDep [ltail=cluster_complement, label="amplifies\nmesangial injury"];

  // Vascular → Renal
  Monocyte -> MCP1 [ltail=cluster_vascular, label="renal\ninfiltration"];

  // Vascular → Skin
  LukocVas -> Leuko_skin [ltail=cluster_vascular, label="dermal LCV"];

  // Renal → Endpoints
  eGFR_dec -> eGFR_EP [ltail=cluster_renal];
  Proteinuria -> Proteinuria_EP [ltail=cluster_renal];
  CKD_prog -> CKD_Stage [ltail=cluster_renal];

  // Skin → Endpoints
  Purpura -> Purpura_EP [ltail=cluster_skin];

  // GI/Joint → Endpoints
  AbdPain -> GI_EP [ltail=cluster_gi_joint];
  Arthralgia -> Joint_EP [ltail=cluster_gi_joint];

  // PK → PD (drug delivery to effect site)
  Pred_T -> GR_recept [ltail=cluster_pk];
  MPA_C -> IMPDH [ltail=cluster_pk];
  SMP_C -> DNA_inh [ltail=cluster_pk];
  RTX_C -> CD20_B [ltail=cluster_pk];
  Spar_C -> AT1R_block [ltail=cluster_pk];
  SGLT2i_C -> SGLT2 [ltail=cluster_pk];
  ACEi_C -> ACE_enz [ltail=cluster_pk];

  // Therapeutics effect on disease
  Pred_antiInf -> IC_large [lhead=cluster_immune_complex, label="reduces IC\nformation", style=dashed, color="#006600"];
  BcellDep -> GdIgA1 [lhead=cluster_iga_production, label="B cell\ndepletion → IgA↓", style=dashed, color="#006600"];
  Lympho_supp -> PlasmaCell [lhead=cluster_iga_production, label="MMF →\nplasma cell↓", style=dashed, color="#006600"];
  Avacopan -> C5a [lhead=cluster_complement, style=dashed, color="#006600"];
  Ravulizumab -> C5 [lhead=cluster_complement, style=dashed, color="#006600"];
  SGLT2i_PD -> Proteinuria_EP [lhead=cluster_endpoints, style=dashed, color="#006600"];
  Spar_PD -> Proteinuria_EP [lhead=cluster_endpoints, style=dashed, color="#006600"];
  ACEi_PD -> eGFR_EP [lhead=cluster_endpoints, label="renoprotection", style=dashed, color="#006600"];
}
