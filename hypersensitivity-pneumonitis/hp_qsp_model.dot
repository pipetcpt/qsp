digraph HypersensitivityPneumonitis {
    graph [
        label="Hypersensitivity Pneumonitis (HP) — QSP Mechanistic Map\nAntigen-Driven Immune-Fibrotic Cascade & Pharmacological Targets"
        labelloc=t fontsize=20 fontname="Helvetica-Bold"
        bgcolor="#F8F9FA"
        nodesep=0.4 ranksep=0.8
        pad=0.6 splines=true
    ]
    node [fontname="Helvetica" fontsize=10 style="filled,rounded" shape=box]
    edge [fontname="Helvetica" fontsize=9]

    /* ═══════════════════════════════════════════════════════════ */
    /* CLUSTER 1: ANTIGEN EXPOSURE                                */
    /* ═══════════════════════════════════════════════════════════ */
    subgraph cluster_antigen {
        label="① Antigen Exposure & Lung Deposition"
        style=filled fillcolor="#EBF5FB" color="#2471A3" penwidth=2
        fontname="Helvetica-Bold" fontsize=12

        A_inh     [label="Inhaled Organic Antigen\n(Mold/Bird Protein/\nFarmer's Dust)" fillcolor="#AED6F1"]
        A_dep     [label="Alveolar Deposition\n(Particles <5 μm)" fillcolor="#AED6F1"]
        A_sol     [label="Soluble Antigen\n(BAL Fluid)" fillcolor="#85C1E9"]
        A_part    [label="Particulate Antigen\n(Cell Wall Fragments)" fillcolor="#85C1E9"]
        A_clear   [label="Mucociliary Clearance" fillcolor="#D6EAF8"]
        A_persist [label="Antigen Persistence\n(Repeated Exposure)" fillcolor="#F1948A"]

        A_inh -> A_dep
        A_dep -> A_sol [label="solubilization"]
        A_dep -> A_part [label="phagocytosis"]
        A_dep -> A_clear [label="clearance"]
        A_persist -> A_dep [label="re-exposure\n↑amplitude" color="red"]
    }

    /* ═══════════════════════════════════════════════════════════ */
    /* CLUSTER 2: INNATE IMMUNITY                                 */
    /* ═══════════════════════════════════════════════════════════ */
    subgraph cluster_innate {
        label="② Innate Immune Activation"
        style=filled fillcolor="#E9F7EF" color="#117A65" penwidth=2
        fontname="Helvetica-Bold" fontsize=12

        AM0      [label="Resting Alveolar\nMacrophage (M0)" fillcolor="#A9DFBF"]
        AM_act   [label="Activated Macrophage\n(M1 Phenotype)" fillcolor="#27AE60" fontcolor=white]
        AM_M2    [label="Alternative Macrophage\n(M2/Pro-fibrotic)" fillcolor="#1E8449" fontcolor=white]
        DC_imm   [label="Immature\nDendritic Cell" fillcolor="#A9DFBF"]
        DC_mat   [label="Mature Dendritic Cell\n(mDC)" fillcolor="#239B56" fontcolor=white]
        Neut     [label="Neutrophil Influx\n(Early Response)" fillcolor="#D5F5E3"]
        NK_cell  [label="NK Cell\nActivation" fillcolor="#D5F5E3"]
        TLR2     [label="TLR2/TLR6\n(β-glucan / PAMP)" fillcolor="#FDEBD0"]
        TLR4     [label="TLR4\n(LPS / Endotoxin)" fillcolor="#FDEBD0"]
        TLR9     [label="TLR9\n(CpG DNA)" fillcolor="#FDEBD0"]
        NLRP3    [label="NLRP3 Inflammasome\n(Crystal/Particle)" fillcolor="#FDEBD0"]
        NFkB     [label="NF-κB\nActivation" fillcolor="#E74C3C" fontcolor=white]
        MAPK_inn [label="MAPK/ERK\nSignaling" fillcolor="#E74C3C" fontcolor=white]

        TLR2 -> NFkB
        TLR4 -> NFkB
        TLR9 -> NFkB
        NLRP3 -> NFkB [label="IL-1β\nprocessing"]
        NFkB -> AM_act [label="M1 polarization"]
        NFkB -> MAPK_inn [label="co-activation"]
        AM0 -> AM_act [label="antigen\nstimulation"]
        AM_act -> AM_M2 [label="IL-10/TGF-β\nswitch" color="#8E44AD"]
        AM0 -> DC_imm [label="common\nprecursor"]
        DC_imm -> DC_mat [label="antigen\nuptake/maturation"]
        AM_act -> NK_cell [label="IL-12/IL-18"]
        AM_act -> Neut [label="CXCL8\nchemotaxis"]
    }

    /* ═══════════════════════════════════════════════════════════ */
    /* CLUSTER 3: CYTOKINE NETWORK                               */
    /* ═══════════════════════════════════════════════════════════ */
    subgraph cluster_cytokines {
        label="③ Cytokine / Chemokine Network"
        style=filled fillcolor="#FEF9E7" color="#B7950B" penwidth=2
        fontname="Helvetica-Bold" fontsize=12

        TNFa   [label="TNF-α\n↑Inflammation" fillcolor="#F39C12" fontcolor=white]
        IL1b   [label="IL-1β\n↑Vascular Perm." fillcolor="#F39C12" fontcolor=white]
        IL6    [label="IL-6\n↑Th17 / Acute Phase" fillcolor="#E67E22" fontcolor=white]
        IL12   [label="IL-12\n↑Th1 Polarization" fillcolor="#F1C40F"]
        IL18   [label="IL-18\n↑IFN-γ Production" fillcolor="#F1C40F"]
        IL17A  [label="IL-17A\n↑Neutrophil/Fibrosis" fillcolor="#E74C3C" fontcolor=white]
        IL10   [label="IL-10\n↓Inflammation\n(Regulatory)" fillcolor="#27AE60" fontcolor=white]
        IL13   [label="IL-13\n↑M2/Fibrosis" fillcolor="#E74C3C" fontcolor=white]
        IL33   [label="IL-33 / ST2\n↑Type 2 Response" fillcolor="#FDEBD0"]
        IFNg   [label="IFN-γ\n↑Th1 / Macrophage" fillcolor="#2471A3" fontcolor=white]
        TGFb1  [label="TGF-β1\nKey Pro-fibrotic\nMediator" fillcolor="#8E44AD" fontcolor=white]
        PDGF   [label="PDGF-AB/BB\n↑Fibroblast Prolif." fillcolor="#A569BD"]
        FGF2   [label="FGF-2\n↑Fibroblast Survival" fillcolor="#A569BD"]
        CXCL10 [label="CXCL10 / IP-10\n↑T Cell Chemotaxis" fillcolor="#AED6F1"]
        CXCL8  [label="CXCL8 / IL-8\n↑Neutrophil Recruit." fillcolor="#AED6F1"]
        CCL2   [label="CCL2 / MCP-1\n↑Monocyte Recruit." fillcolor="#AED6F1"]
        CCL18  [label="CCL18\nPro-fibrotic Marker" fillcolor="#F1948A"]
        MMP7   [label="MMP-7\nMatrix Remodeling" fillcolor="#FADBD8"]
        TIMP1  [label="TIMP-1\nMatrix Preservation" fillcolor="#FADBD8"]
        KL6    [label="KL-6 / MUC1\n(Biomarker, Fibrosis)" fillcolor="#F9E79F"]
        SPD    [label="SP-D / SP-A\nInnate Lung Defense" fillcolor="#D6EAF8"]

        AM_act -> TNFa
        AM_act -> IL1b
        AM_act -> IL6
        AM_act -> IL12
        AM_act -> IL18
        AM_act -> CXCL8
        AM_act -> CCL2
        AM_act -> TGFb1
        AM_M2 -> TGFb1
        AM_M2 -> IL10
        AM_M2 -> CCL18
        NFkB -> TNFa
        NFkB -> IL1b
        NFkB -> IL6
        IL12 -> IFNg
        IL18 -> IFNg
        IFNg -> AM_act [label="M1 amplification"]
        TGFb1 -> PDGF [label="↑expression"]
        PDGF -> FGF2
        IL6 -> IL17A [label="Th17 diff."]
        IL17A -> CXCL8
        IL17A -> CCL2
        IL13 -> TGFb1
        IL33 -> IL13 [label="ILC2 activation"]
        MMP7 -> TIMP1 [label="ECM balance"]
        CXCL10 -> CCL2 [label="gradient"]
    }

    /* ═══════════════════════════════════════════════════════════ */
    /* CLUSTER 4: ADAPTIVE T CELL IMMUNITY                       */
    /* ═══════════════════════════════════════════════════════════ */
    subgraph cluster_adaptive {
        label="④ Adaptive Immunity — T Cell & B Cell Compartment"
        style=filled fillcolor="#EAF2FF" color="#1A5276" penwidth=2
        fontname="Helvetica-Bold" fontsize=12

        mDC_LN   [label="mDC → Draining\nLymph Node" fillcolor="#AED6F1"]
        MHCII    [label="MHC-II / CD80-CD86\nCostimulation" fillcolor="#D6EAF8"]
        T_naive  [label="Naive CD4+ T Cell" fillcolor="#AED6F1"]
        T_Th1    [label="Th1 Cell\n(IFN-γ⁺ TNF-α⁺)" fillcolor="#2471A3" fontcolor=white]
        T_Th17   [label="Th17 Cell\n(IL-17A⁺ IL-22⁺)" fillcolor="#2980B9" fontcolor=white]
        T_Treg   [label="Regulatory T Cell\n(FOXP3⁺ IL-10⁺)" fillcolor="#27AE60" fontcolor=white]
        T_CD8    [label="CD8⁺ Cytotoxic\nT Cell" fillcolor="#1A5276" fontcolor=white]
        T_mem    [label="CD4⁺ Memory T Cell\n(Long-lived)" fillcolor="#7FB3D3"]
        T_exh    [label="Exhausted T Cell\n(PD-1⁺ TIM-3⁺)" fillcolor="#D6EAF8"]
        T_Tfh    [label="T Follicular Helper\n(CXCR5⁺ IL-21⁺)" fillcolor="#AED6F1"]
        B_naive  [label="Naive B Cell" fillcolor="#D5D8DC"]
        B_GC     [label="Germinal Center\nB Cell" fillcolor="#BFC9CA"]
        Plasma   [label="Plasma Cell\n(IgG / IgA)" fillcolor="#979A9A"]
        IgG_sp   [label="Specific IgG\n(Serum Precipitins)" fillcolor="#F5CBA7"]
        IC_form  [label="Immune Complex\nFormation" fillcolor="#E74C3C" fontcolor=white]

        DC_mat -> mDC_LN
        mDC_LN -> MHCII
        MHCII -> T_naive
        T_naive -> T_Th1 [label="IL-12 IFN-γ" color="#2471A3"]
        T_naive -> T_Th17 [label="IL-6 TGF-β" color="#E67E22"]
        T_naive -> T_Treg [label="TGF-β IL-10" color="#27AE60"]
        T_Th1 -> T_CD8
        T_Th1 -> T_mem
        T_mem -> T_Th1 [label="rapid re-stim." color="red"]
        T_Th1 -> T_exh [label="chronic stim."]
        T_Treg -> T_Th1 [label="suppress" style=dashed color="#27AE60"]
        T_Treg -> T_Th17 [label="suppress" style=dashed color="#27AE60"]
        T_Tfh -> B_GC [label="IL-21"]
        B_naive -> B_GC
        B_GC -> Plasma
        Plasma -> IgG_sp
        IgG_sp -> IC_form [label="Ag binding"]
        IC_form -> AM_act [label="FcγR activation"]
        T_Th1 -> T_Tfh
    }

    /* ═══════════════════════════════════════════════════════════ */
    /* CLUSTER 5: GRANULOMA FORMATION                            */
    /* ═══════════════════════════════════════════════════════════ */
    subgraph cluster_granuloma {
        label="⑤ Granuloma Formation (Acute / Subacute HP)"
        style=filled fillcolor="#FEF5E7" color="#CA6F1E" penwidth=2
        fontname="Helvetica-Bold" fontsize=12

        Gran_init [label="Granuloma Initiation\n(Macrophage Aggregation)" fillcolor="#F0B27A"]
        Epith     [label="Epithelioid\nMacrophage" fillcolor="#E59866"]
        Giant     [label="Multinucleated\nGiant Cell" fillcolor="#DC7633"]
        Gran_mat  [label="Non-caseating\nGranuloma (Mature)" fillcolor="#CA6F1E" fontcolor=white]
        Lymph_inf [label="Lymphocyte Cuffing\n(CD4⁺ T cells)" fillcolor="#AED6F1"]
        Gran_res  [label="Granuloma Resolution\n(With Ag Elimination)" fillcolor="#27AE60" fontcolor=white]
        Gran_fib  [label="Granuloma → Fibrosis\n(Chronic Persistence)" fillcolor="#922B21" fontcolor=white]

        AM_act -> Gran_init [label="aggregation"]
        Gran_init -> Epith [label="fusion"]
        Epith -> Giant
        Giant -> Gran_mat
        Gran_mat -> Gran_res [label="Ag eliminated"]
        Gran_mat -> Gran_fib [label="chronic" color="red"]
        IL10 -> Gran_res [label="resolution ↑" color="#27AE60"]
        TGFb1 -> Gran_fib [label="fibrosis transition"]
    }

    /* ═══════════════════════════════════════════════════════════ */
    /* CLUSTER 6: FIBROSIS CASCADE                               */
    /* ═══════════════════════════════════════════════════════════ */
    subgraph cluster_fibrosis {
        label="⑥ Pulmonary Fibrosis Cascade (Chronic HP → UIP)"
        style=filled fillcolor="#FDEDEC" color="#922B21" penwidth=2
        fontname="Helvetica-Bold" fontsize=12

        AEC2_inj  [label="AEC2 Injury\n(Surfactant Dysfunction)" fillcolor="#FDEBD0"]
        ER_stress [label="ER Stress / UPR\nActivation" fillcolor="#F9E79F"]
        Senesc    [label="AEC2 Senescence\n(p21/p53 SASP)" fillcolor="#FAD7A0"]
        Fibro_r   [label="Resting Lung\nFibroblast" fillcolor="#FDFEFE"]
        Fibro_act [label="Activated\nFibroblast" fillcolor="#F1948A"]
        Myofib    [label="Myofibroblast\n(α-SMA⁺)" fillcolor="#E74C3C" fontcolor=white]
        EMT       [label="Epithelial-Mesenchymal\nTransition (EMT)" fillcolor="#C0392B" fontcolor=white]
        Col1      [label="Collagen I/III\nDeposition ↑" fillcolor="#922B21" fontcolor=white]
        Fibronectin [label="Fibronectin\nMatrix Assembly" fillcolor="#F5B7B1"]
        ECM_cross [label="ECM Cross-linking\n(LOX enzyme)" fillcolor="#FADBD8"]
        Scar      [label="Irreversible\nScar Formation" fillcolor="#641E16" fontcolor=white]
        ROS_ox    [label="ROS / Oxidative\nStress ↑" fillcolor="#F8C471"]

        TGFb1 -> Fibro_r [label="activation"]
        PDGF -> Fibro_r [label="proliferation"]
        Fibro_r -> Fibro_act
        Fibro_act -> Myofib [label="α-SMA↑"]
        AEC2_inj -> EMT [label="TGF-β"]
        EMT -> Myofib
        ER_stress -> AEC2_inj
        Senesc -> TGFb1 [label="SASP"]
        ROS_ox -> AEC2_inj
        ROS_ox -> Senesc [label="p53 pathway"]
        AM_M2 -> ROS_ox [label="NOX2"]
        Neut -> ROS_ox [label="burst"]
        Myofib -> Col1
        Myofib -> Fibronectin
        Col1 -> ECM_cross [label="LOX"]
        Fibronectin -> ECM_cross
        ECM_cross -> Scar [label="stiffness"]
        TIMP1 -> Col1 [label="stabilize"]
        MMP7 -> ECM_cross [label="remodel"]
        CCL18 -> Fibro_act [label="direct"]
        Gran_fib -> Fibro_act [label="recruit"]
        FGF2 -> Fibro_act [label="survival"]
    }

    /* ═══════════════════════════════════════════════════════════ */
    /* CLUSTER 7: LUNG PATHOPHYSIOLOGY                           */
    /* ═══════════════════════════════════════════════════════════ */
    subgraph cluster_pathophys {
        label="⑦ Pulmonary Pathophysiology & Function"
        style=filled fillcolor="#EBF5FB" color="#154360" penwidth=2
        fontname="Helvetica-Bold" fontsize=12

        Alv_wall  [label="Alveolar Wall\nThickening" fillcolor="#AED6F1"]
        Bronch_inf [label="Peribronchiolar\nInflammation" fillcolor="#85C1E9"]
        Interst   [label="Interstitial\nEdema/Exudate" fillcolor="#2E86C1" fontcolor=white]
        BAL_lymph [label="BAL Lymphocytosis\n>20% (Diagnostic)" fillcolor="#D6EAF8"]
        GGO       [label="Ground-Glass\nOpacity (HRCT)" fillcolor="#D6EAF8"]
        UIP_pat   [label="UIP Pattern\n(Reticulation)" fillcolor="#1A5276" fontcolor=white]
        NSIP_pat  [label="NSIP-like Pattern\n(Subacute HP)" fillcolor="#2471A3" fontcolor=white]
        Traction  [label="Traction\nBronchiectasis" fillcolor="#AED6F1"]
        Honey     [label="Honeycombing\n(Late Stage)" fillcolor="#5D6D7E" fontcolor=white]
        FVC_c     [label="FVC (% Predicted)\n↓ Restriction" fillcolor="#F1C40F"]
        DLCO_c    [label="DLCO (% Predicted)\n↓ Diffusion" fillcolor="#F1C40F"]
        TLC_c     [label="TLC\n↓ Restrictive" fillcolor="#F1C40F"]
        PaO2_c    [label="PaO2 / SpO2\n↓ Hypoxemia" fillcolor="#E74C3C" fontcolor=white]
        VQ_mism   [label="V/Q Mismatch\n↑ Dead Space" fillcolor="#F5CBA7"]
        Pulm_HTN  [label="Pulmonary Hypertension\n(Secondary Complication)" fillcolor="#922B21" fontcolor=white]
        RV_fail   [label="Right Ventricular Failure\n(Cor Pulmonale, Late)" fillcolor="#C0392B" fontcolor=white]

        Alv_wall -> FVC_c [label="↓"]
        Alv_wall -> DLCO_c [label="↓"]
        Scar -> Alv_wall
        Col1 -> Alv_wall
        Gran_mat -> Bronch_inf
        Interst -> Alv_wall
        GGO -> NSIP_pat [label="subacute"]
        UIP_pat -> Traction
        Traction -> Honey [label="late"]
        FVC_c -> TLC_c
        Alv_wall -> VQ_mism
        VQ_mism -> PaO2_c
        Honey -> Pulm_HTN [label="vascular\nremodeling"]
        Pulm_HTN -> RV_fail
    }

    /* ═══════════════════════════════════════════════════════════ */
    /* CLUSTER 8: DRUG PK                                        */
    /* ═══════════════════════════════════════════════════════════ */
    subgraph cluster_pk {
        label="⑧ Drug Pharmacokinetics (PK)"
        style=filled fillcolor="#F4ECF7" color="#6C3483" penwidth=2
        fontname="Helvetica-Bold" fontsize=12

        /* Prednisolone */
        PDN_gut  [label="Prednisolone\nOral (F=82%)" fillcolor="#D7BDE2"]
        PDN_cent [label="Prednisolone\nCentral Compt." fillcolor="#A569BD"]
        PDN_lung [label="Prednisolone\nLung Tissue" fillcolor="#7D3C98" fontcolor=white]
        GR_pdn   [label="GR Binding\n(Nuclear Transloc.)" fillcolor="#D2B4DE"]

        /* MMF */
        MMF_gut  [label="MMF\n(F=94%)" fillcolor="#D2B4DE"]
        MPA_c    [label="MPA\n(Active Metabolite)" fillcolor="#A569BD"]
        IMPDH_i  [label="IMPDH Inhibition\n↓Guanosine\n(IC50=0.24 μg/mL)" fillcolor="#7D3C98" fontcolor=white]

        /* Azathioprine */
        AZA_gut  [label="Azathioprine\nOral" fillcolor="#D7BDE2"]
        MP6_c    [label="6-MP → 6-TGN\n(Active Thiopurine)" fillcolor="#A569BD"]
        TPMT_m   [label="TPMT Methylation\n(Inactivation)" fillcolor="#E8DAEF"]

        /* Nintedanib */
        Nint_gut [label="Nintedanib\nOral (F=4.7%)" fillcolor="#D7BDE2"]
        Nint_c   [label="Nintedanib\nCentral Compt." fillcolor="#A569BD"]
        Nint_met [label="Nintedanib\nMetabolites (CYP3A4)" fillcolor="#E8DAEF"]

        /* NAC */
        NAC_o    [label="N-Acetylcysteine\nOral" fillcolor="#D5F5E3"]
        NAC_c    [label="NAC\nCirculating" fillcolor="#A9DFBF"]
        GSH_syn  [label="Glutathione\nSynthesis ↑" fillcolor="#27AE60" fontcolor=white]

        PDN_gut -> PDN_cent [label="ka=1.5/h\nVd=0.51 L/kg"]
        PDN_cent -> PDN_lung
        PDN_cent -> GR_pdn [label="free fraction\n10-25%"]
        MMF_gut -> MPA_c [label="ka=2.0/h\nCL=16 L/h"]
        MPA_c -> IMPDH_i
        AZA_gut -> MP6_c [label="xanthine\noxidase"]
        MP6_c -> TPMT_m [label="inactivation"]
        Nint_gut -> Nint_c [label="Pgp efflux\nka=0.8/h"]
        Nint_c -> Nint_met [label="CYP3A4\nest. cleavage"]
        NAC_o -> NAC_c [label="F=10%"]
        NAC_c -> GSH_syn [label="cysteine\nprecursor"]
    }

    /* ═══════════════════════════════════════════════════════════ */
    /* CLUSTER 9: DRUG PD                                        */
    /* ═══════════════════════════════════════════════════════════ */
    subgraph cluster_pd {
        label="⑨ Drug Pharmacodynamics (PD) — Mechanistic Targets"
        style=filled fillcolor="#EAFAF1" color="#1E8449" penwidth=2
        fontname="Helvetica-Bold" fontsize=12

        /* GC effects */
        GR_trans  [label="GR Transactivation\n(Anti-inflam Genes)" fillcolor="#A9DFBF"]
        GR_repress [label="GR Transrepression\n↓NF-κB / AP-1" fillcolor="#27AE60" fontcolor=white]
        Lip_A1    [label="Annexin A1 ↑\n(Lipocortin-1)" fillcolor="#D5F5E3"]
        PLA2_i    [label="PLA2 Inhibition\n↓Arachidonate" fillcolor="#D5F5E3"]

        /* Immunosuppressive */
        T_prol_i  [label="T Cell Proliferation\n↓ (MMF/AZA)" fillcolor="#AED6F1"]
        B_prol_i  [label="B Cell Proliferation\n↓ (MMF/AZA)" fillcolor="#AED6F1"]
        Cyt_inh   [label="Cytokine Synthesis\n↓ (GC)" fillcolor="#D6EAF8"]

        /* Antifibrotic */
        PDGFR_i   [label="PDGFR Inhibition\n↓Fibroblast Prolif." fillcolor="#F9E79F"]
        FGFR_i    [label="FGFR Inhibition\n↓Fibroblast Survival" fillcolor="#F9E79F"]
        VEGFR_i   [label="VEGFR Inhibition\n↓Angiogenesis" fillcolor="#F9E79F"]
        PI3K_i    [label="PI3K/Akt Inhibition\n↓Myofibroblast" fillcolor="#F0B27A"]
        MAPK_i    [label="MAPK Inhibition\n↓Migration" fillcolor="#F0B27A"]

        /* Antioxidant */
        ROS_scav  [label="ROS Scavenging\n(NAC/GSH)" fillcolor="#A9DFBF"]
        Nrf2_act  [label="Nrf2 Activation\n↑Antioxidant" fillcolor="#52BE80" fontcolor=white]

        /* Avoidance */
        Ant_avoid [label="Antigen Avoidance\n(Primary Intervention\n— Most Effective)" fillcolor="#F8C471"]

        GR_pdn -> GR_trans
        GR_pdn -> GR_repress
        GR_trans -> Lip_A1
        Lip_A1 -> PLA2_i
        IMPDH_i -> T_prol_i
        IMPDH_i -> B_prol_i
        MP6_c -> T_prol_i
        GR_repress -> Cyt_inh
        Nint_c -> PDGFR_i
        Nint_c -> FGFR_i
        Nint_c -> VEGFR_i
        PDGFR_i -> PI3K_i
        PDGFR_i -> MAPK_i
        GSH_syn -> ROS_scav
        NAC_c -> Nrf2_act
    }

    /* ═══════════════════════════════════════════════════════════ */
    /* CLUSTER 10: CLINICAL ENDPOINTS                            */
    /* ═══════════════════════════════════════════════════════════ */
    subgraph cluster_clinical {
        label="⑩ Clinical Endpoints & Biomarkers"
        style=filled fillcolor="#FEF9E7" color="#7D6608" penwidth=2
        fontname="Helvetica-Bold" fontsize=12

        /* Symptoms */
        Dyspnea  [label="Dyspnea\n(mMRC / Borg)" fillcolor="#E74C3C" fontcolor=white]
        Cough    [label="Chronic Cough\n(LCQ Score)" fillcolor="#F39C12" fontcolor=white]
        FatSym   [label="Fatigue / Malaise\n(SGRQ)" fillcolor="#FAD7A0"]
        Fever    [label="Fever / Flu-like\n(Acute HP, 4–8h)" fillcolor="#FAD7A0"]

        /* Functional */
        Ex_cap   [label="Exercise Capacity\n(6MWT, meters)" fillcolor="#2471A3" fontcolor=white]
        SGRQ_t   [label="SGRQ Total Score\n(QoL Index)" fillcolor="#1A5276" fontcolor=white]
        Prog_phen [label="Progressive HP\n(FVC decline >10%/yr)" fillcolor="#922B21" fontcolor=white]

        /* Serum biomarkers */
        KL6_ser  [label="Serum KL-6\n(>500 U/mL = active)" fillcolor="#F9E79F"]
        SPD_ser  [label="Serum SP-D\n(>110 ng/mL)" fillcolor="#F9E79F"]
        Precip   [label="Specific IgG\n(Serum Precipitins)" fillcolor="#F5CBA7"]
        CRP_s    [label="CRP / ESR\n(Acute Inflammation)" fillcolor="#FAD7A0"]
        LDH_s    [label="LDH\n(Lung Injury)" fillcolor="#FAD7A0"]

        /* BAL */
        BAL_l    [label="BAL Lymphocytosis\n>20% (Diagnostic)" fillcolor="#D6EAF8"]
        BAL_n    [label="BAL Neutrophilia\n(Fibrotic HP)" fillcolor="#D6EAF8"]
        CD4_8    [label="BAL CD4:CD8 Ratio\n↓ (Th1-enriched)" fillcolor="#AED6F1"]

        /* Imaging */
        HRCT_sc  [label="HRCT Fibrosis Score\n(% Reticulation)" fillcolor="#85C1E9"]

        /* Outcomes */
        Mortal   [label="All-cause Mortality\n(5-yr Survival)" fillcolor="#641E16" fontcolor=white]
        Transplant [label="Lung Transplant\nListing" fillcolor="#7B241C" fontcolor=white]

        FVC_c -> Dyspnea
        DLCO_c -> Dyspnea
        PaO2_c -> Dyspnea [label="hypoxemia"]
        FVC_c -> Ex_cap
        DLCO_c -> Ex_cap
        FVC_c -> SGRQ_t
        Dyspnea -> SGRQ_t
        Cough -> SGRQ_t
        FatSym -> SGRQ_t
        FVC_c -> Prog_phen [label="≥10%/yr"]
        KL6 -> KL6_ser
        SPD -> SPD_ser
        IgG_sp -> Precip
        TNFa -> CRP_s
        IL6 -> CRP_s
        AEC2_inj -> LDH_s
        BAL_lymph -> BAL_l
        Neut -> BAL_n
        UIP_pat -> HRCT_sc
        Prog_phen -> Mortal
        Pulm_HTN -> Mortal [label="poor prog."]
        RV_fail -> Mortal
        Prog_phen -> Transplant
    }

    /* ═══════════════════════════════════════════════════════════ */
    /* INTER-CLUSTER EDGES (outside all subgraphs)               */
    /* ═══════════════════════════════════════════════════════════ */

    /* Antigen → Innate */
    A_dep -> AM0 [label="particle\nphagocytosis" color="#117A65" penwidth=1.5]
    A_part -> TLR2 [label="PAMP" color="#117A65"]
    A_part -> TLR4 [color="#117A65"]
    A_sol -> TLR9 [color="#117A65"]
    A_part -> NLRP3 [color="#117A65"]
    A_dep -> Neut [label="chemotaxis" color="#117A65"]
    A_sol -> DC_imm [label="macropinocytosis" color="#117A65"]

    /* Innate → Cytokines */
    AM_act -> IL12 [color="#B7950B" penwidth=1.5]
    AM_act -> IL1b [color="#B7950B" penwidth=1.5]
    NFkB -> IL6 [color="#B7950B" penwidth=1.5]

    /* Cytokines → Adaptive */
    IL12 -> T_naive [label="Th1 polariz." color="#1A5276" penwidth=1.5]
    IL6 -> T_Th17 [color="#1A5276"]
    IFNg -> AM_act [color="#117A65" penwidth=1.5]

    /* Adaptive → Cytokines feedback */
    T_Th1 -> IFNg [color="#B7950B" penwidth=1.5]
    T_Th1 -> TNFa [color="#B7950B"]
    T_Th17 -> IL17A [color="#B7950B"]
    T_Treg -> IL10 [color="#B7950B"]

    /* T Cell → Granuloma */
    T_Th1 -> Gran_init [label="IFN-γ recruit." color="#CA6F1E" penwidth=1.5]
    T_Th1 -> Lymph_inf [color="#CA6F1E"]

    /* Cytokines → Fibrosis */
    TGFb1 -> Fibro_r [color="#922B21" penwidth=2]
    IL13 -> Myofib [color="#922B21"]
    CCL18 -> Fibro_act [color="#922B21"]

    /* Fibrosis → Pathophysiology */
    Col1 -> Alv_wall [color="#154360" penwidth=2]
    Myofib -> Interst [color="#154360"]
    Scar -> UIP_pat [color="#154360" penwidth=2]
    Gran_mat -> GGO [color="#154360"]

    /* Pathophysiology → Clinical */
    FVC_c -> Dyspnea [color="#7D6608" penwidth=2]
    DLCO_c -> Ex_cap [color="#7D6608" penwidth=1.5]
    UIP_pat -> HRCT_sc [color="#7D6608"]
    BAL_lymph -> BAL_l [color="#7D6608"]

    /* T Cell / B Cell → BAL */
    T_CD8 -> CD4_8 [color="#7D6608"]

    /* PD → Pathway inhibitions */
    GR_repress -> NFkB [label="↓NF-κB" style=dashed color="#6C3483" penwidth=1.5]
    GR_repress -> IL6 [label="↓" style=dashed color="#6C3483"]
    GR_repress -> TNFa [label="↓" style=dashed color="#6C3483"]
    Cyt_inh -> T_Th1 [label="↓Th1" style=dashed color="#6C3483"]
    T_prol_i -> T_Th17 [label="↓" style=dashed color="#6C3483"]
    B_prol_i -> Plasma [label="↓Ab" style=dashed color="#6C3483"]
    PDGFR_i -> PDGF [label="block" style=dashed color="#6C3483" penwidth=1.5]
    FGFR_i -> FGF2 [label="block" style=dashed color="#6C3483"]
    PI3K_i -> Myofib [label="↓α-SMA" style=dashed color="#6C3483"]
    MAPK_i -> Fibro_act [label="↓migr." style=dashed color="#6C3483"]
    ROS_scav -> ROS_ox [label="↓" style=dashed color="#27AE60"]
    Nrf2_act -> ROS_ox [label="↓" style=dashed color="#27AE60"]
    Ant_avoid -> A_persist [label="↓exposure" style=dashed color="#E67E22" penwidth=2]
    PLA2_i -> TNFa [label="↓" style=dashed color="#6C3483"]
}
