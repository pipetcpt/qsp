digraph SarcoidosisQSP {

    graph [
        rankdir=LR,
        bgcolor="#FAFAFA",
        label="Sarcoidosis QSP Mechanistic Map",
        fontsize=20,
        labelloc=t,
        fontname="Helvetica",
        splines=ortho,
        nodesep=0.25,
        ranksep=0.6
    ]

    node [fontname="Helvetica", fontsize=8, style="filled,rounded", shape=box]
    edge [fontname="Helvetica", fontsize=7]

    // =========================================================
    // CLUSTER 1: Trigger / Antigen
    // =========================================================
    subgraph cluster_trigger {
        label="Trigger / Antigen"
        style=filled
        fillcolor="#FFF8DC"
        color="#8B4513"
        fontname="Helvetica"
        fontsize=11
        fontcolor="#8B4513"

        Unknown_Antigen         [label="Unknown Antigen", fillcolor="#FFE8A0"]
        Mycobacterial_Ag        [label="Mycobacterial Ag\n(mKatG/ESAT6)", fillcolor="#FFE8A0"]
        Propionibacterium_Ag    [label="Propionibacterium Ag", fillcolor="#FFE8A0"]
        Organic_Dust            [label="Organic Dust", fillcolor="#FFE8A0"]
        Inorganic_Particles     [label="Inorganic Particles\n(Beryllium/Silica)", fillcolor="#FFE8A0"]
        Vimentin_Self_Ag        [label="Vimentin Self-Ag", fillcolor="#FFDAA0"]
        HSP70_Self_Ag           [label="HSP70 Self-Ag", fillcolor="#FFDAA0"]
        Genetic_Susceptibility  [label="Genetic Susceptibility\n(HLA-DRB1/BTNL2)", fillcolor="#F5C585"]
    }

    // =========================================================
    // CLUSTER 2: Innate Immune Response
    // =========================================================
    subgraph cluster_innate {
        label="Innate Immune Response"
        style=filled
        fillcolor="#FFFACD"
        color="#B8860B"
        fontname="Helvetica"
        fontsize=11
        fontcolor="#B8860B"

        Alveolar_Macrophage     [label="Alveolar Macrophage", fillcolor="#FFEEA0"]
        Dendritic_Cell          [label="Dendritic Cell", fillcolor="#FFEEA0"]
        Blood_Monocyte          [label="Blood Monocyte", fillcolor="#FFEEA0"]
        TLR2                    [label="TLR2", fillcolor="#FFD870"]
        TLR4                    [label="TLR4", fillcolor="#FFD870"]
        TLR9                    [label="TLR9", fillcolor="#FFD870"]
        NOD2_Receptor           [label="NOD2 Receptor", fillcolor="#FFD870"]
        NLRP3_Inflammasome      [label="NLRP3 Inflammasome", fillcolor="#FFD870"]
        Pattern_Recognition     [label="Pattern Recognition", fillcolor="#FFEEA0"]
        Phagocytosis_Processing [label="Phagocytosis &\nAg Processing", fillcolor="#FFEEA0"]
        ROS_Production          [label="ROS Production", fillcolor="#FFD870"]
        Antigen_Presentation    [label="Antigen Presentation", fillcolor="#FFEEA0"]
        MHC_II_Expression       [label="MHC II Expression", fillcolor="#FFEEA0"]
        HLA_DRB1_Restriction    [label="HLA-DRB1\nRestriction", fillcolor="#F5C830"]
        M1_Polarization         [label="M1 Polarization", fillcolor="#FFD870"]
    }

    // =========================================================
    // CLUSTER 3: Adaptive Immune Response
    // =========================================================
    subgraph cluster_adaptive {
        label="Adaptive Immune Response"
        style=filled
        fillcolor="#F0FFF0"
        color="#006400"
        fontname="Helvetica"
        fontsize=11
        fontcolor="#006400"

        Naive_CD4_T_Cell        [label="Naive CD4+ T Cell", fillcolor="#BDFFC0"]
        Th1_Cell                [label="Th1 Cell", fillcolor="#90EE90"]
        Th17_Cell               [label="Th17 Cell", fillcolor="#90EE90"]
        Treg_Cell               [label="Treg Cell", fillcolor="#90EE90"]
        CD8_T_Cell              [label="CD8+ T Cell", fillcolor="#90EE90"]
        B_Cell                  [label="B Cell", fillcolor="#BDFFC0"]
        Plasma_Cell             [label="Plasma Cell", fillcolor="#BDFFC0"]
        TCR_Activation          [label="TCR Activation", fillcolor="#90EE90"]
        CD28_Costimulation      [label="CD28 Costimulation", fillcolor="#90EE90"]
        CTLA4_Checkpoint        [label="CTLA4 Checkpoint", fillcolor="#A8D8A8"]
        IL2_JAK_Signaling       [label="IL-2/JAK Signaling", fillcolor="#90EE90"]
        T_Cell_Proliferation    [label="T Cell Proliferation", fillcolor="#90EE90"]
        T_Cell_Memory           [label="T Cell Memory", fillcolor="#BDFFC0"]
        Th1_Treg_Imbalance      [label="Th1/Treg Imbalance", fillcolor="#FFB3B3"]
    }

    // =========================================================
    // CLUSTER 4: Cytokine / Chemokine Network
    // =========================================================
    subgraph cluster_cytokine {
        label="Cytokine / Chemokine Network"
        style=filled
        fillcolor="#FFF0F0"
        color="#8B0000"
        fontname="Helvetica"
        fontsize=11
        fontcolor="#8B0000"

        TNF_alpha       [label="TNF-alpha", fillcolor="#FFB3B3"]
        IL12_p70        [label="IL-12 p70", fillcolor="#FFB3B3"]
        IL18            [label="IL-18", fillcolor="#FFB3B3"]
        IFN_gamma       [label="IFN-gamma", fillcolor="#FFB3B3"]
        IL6             [label="IL-6", fillcolor="#FFB3B3"]
        IL17A           [label="IL-17A", fillcolor="#FFB3B3"]
        IL2             [label="IL-2", fillcolor="#FFB3B3"]
        IL10            [label="IL-10", fillcolor="#FFD0D0"]
        TGF_beta1       [label="TGF-beta1", fillcolor="#FFD0D0"]
        CCL2_MCP1       [label="CCL2 / MCP-1", fillcolor="#FFC8A0"]
        CXCL10_IP10     [label="CXCL10 / IP-10", fillcolor="#FFC8A0"]
        CXCL9_MIG       [label="CXCL9 / MIG", fillcolor="#FFC8A0"]
        IL1_beta        [label="IL-1 beta", fillcolor="#FFB3B3"]
        IL23            [label="IL-23", fillcolor="#FFB3B3"]
        GM_CSF          [label="GM-CSF", fillcolor="#FFB3B3"]
        Osteopontin     [label="Osteopontin", fillcolor="#FFC8A0"]
        VEGF            [label="VEGF", fillcolor="#FFC8A0"]
    }

    // =========================================================
    // CLUSTER 5: Granuloma Formation & Metabolism
    // =========================================================
    subgraph cluster_granuloma {
        label="Granuloma Formation & Metabolism"
        style=filled
        fillcolor="#F8F0FF"
        color="#800080"
        fontname="Helvetica"
        fontsize=11
        fontcolor="#800080"

        Epithelioid_Macrophage      [label="Epithelioid Macrophage", fillcolor="#DDA0DD"]
        Langhans_Giant_Cell         [label="Langhans Giant Cell", fillcolor="#DDA0DD"]
        Lymphocyte_Mantle           [label="Lymphocyte Mantle", fillcolor="#DDA0DD"]
        NonCaseating_Granuloma      [label="Non-Caseating Granuloma", fillcolor="#C080C0", fontsize=9, fontcolor="white"]
        Granuloma_Resolution        [label="Granuloma Resolution", fillcolor="#DDA0DD"]
        Fibroblast_Activation       [label="Fibroblast Activation", fillcolor="#DDA0DD"]
        Collagen_Deposition         [label="Collagen Deposition", fillcolor="#DDA0DD"]
        ACE_Production              [label="ACE Production", fillcolor="#DDA0DD"]
        Lysozyme_Production         [label="Lysozyme Production", fillcolor="#DDA0DD"]
        CYP27B1_1alphaHydroxylase   [label="CYP27B1\n1-alpha-Hydroxylase", fillcolor="#DDA0DD"]
        Calcitriol_Synthesis        [label="Calcitriol Synthesis\n(1,25-OH2-D3)", fillcolor="#C080C0"]
        MMP_Production              [label="MMP Production", fillcolor="#DDA0DD"]
        sIL2R_Release               [label="sIL-2R Release", fillcolor="#DDA0DD"]
    }

    // =========================================================
    // CLUSTER 6: Pulmonary System
    // =========================================================
    subgraph cluster_pulmonary {
        label="Pulmonary System"
        style=filled
        fillcolor="#E6F0FF"
        color="#0000CD"
        fontname="Helvetica"
        fontsize=11
        fontcolor="#0000CD"

        Pulmonary_Infiltrates           [label="Pulmonary Infiltrates", fillcolor="#B0C8F8"]
        Perilymphatic_Nodules           [label="Perilymphatic Nodules", fillcolor="#B0C8F8"]
        Mediastinal_Lymphadenopathy     [label="Mediastinal\nLymphadenopathy", fillcolor="#B0C8F8"]
        Bilateral_Hilar_LAD_StageI      [label="Bilateral Hilar LAD\n(Stage I)", fillcolor="#90B0F0"]
        Parenchymal_Involvement_StageII_III [label="Parenchymal Involvement\n(Stage II-III)", fillcolor="#90B0F0"]
        Pulmonary_Fibrosis_StageIV      [label="Pulmonary Fibrosis\n(Stage IV)", fillcolor="#6090D8", fontcolor="white"]
        FVC_Decline_pct                 [label="FVC Decline (%)", fillcolor="#B0C8F8"]
        DLCO_Decline_pct                [label="DLCO Decline (%)", fillcolor="#B0C8F8"]
        FEV1_FVC_Restriction            [label="FEV1/FVC Restriction", fillcolor="#B0C8F8"]
        BAL_CD4_CD8_Ratio               [label="BAL CD4/CD8 Ratio", fillcolor="#B0C8F8"]
    }

    // =========================================================
    // CLUSTER 7: Extrapulmonary Organs
    // =========================================================
    subgraph cluster_extrapulmonary {
        label="Extrapulmonary Organs"
        style=filled
        fillcolor="#FFF5EE"
        color="#FF4500"
        fontname="Helvetica"
        fontsize=11
        fontcolor="#FF4500"

        Cardiac_Granuloma               [label="Cardiac Granuloma", fillcolor="#FFBB88"]
        Arrhythmia_Conduction_Block     [label="Arrhythmia /\nConduction Block", fillcolor="#FFBB88"]
        Complete_AV_Block               [label="Complete AV Block", fillcolor="#FF9960"]
        SCD_Risk                        [label="SCD Risk", fillcolor="#FF7744", fontcolor="white"]
        Neurosarcoidosis                [label="Neurosarcoidosis", fillcolor="#FFBB88"]
        Cranial_Nerve_Palsy_VII         [label="Cranial Nerve Palsy\n(VII)", fillcolor="#FFBB88"]
        Leptomeningeal_Involvement      [label="Leptomeningeal\nInvolvement", fillcolor="#FFBB88"]
        Hepatic_Granuloma               [label="Hepatic Granuloma", fillcolor="#FFBB88"]
        Elevated_LFT                    [label="Elevated LFT", fillcolor="#FFBB88"]
        Anterior_Uveitis                [label="Anterior Uveitis", fillcolor="#FFBB88"]
        Posterior_Uveitis               [label="Posterior Uveitis", fillcolor="#FFBB88"]
        Erythema_Nodosum                [label="Erythema Nodosum", fillcolor="#FFBB88"]
        Lupus_Pernio                    [label="Lupus Pernio", fillcolor="#FFBB88"]
        Splenomegaly                    [label="Splenomegaly", fillcolor="#FFBB88"]
    }

    // =========================================================
    // CLUSTER 8: Calcium Metabolism
    // =========================================================
    subgraph cluster_calcium {
        label="Calcium Metabolism"
        style=filled
        fillcolor="#FAEBD7"
        color="#8B4513"
        fontname="Helvetica"
        fontsize=11
        fontcolor="#8B4513"

        Vitamin_D25_OH                  [label="Vitamin D (25-OH)", fillcolor="#F5DEB3"]
        Calcitriol_Serum_Elevated       [label="Calcitriol Serum\nElevated", fillcolor="#F5DEB3"]
        Hypercalcemia                   [label="Hypercalcemia", fillcolor="#DEB887"]
        Hypercalciuria                  [label="Hypercalciuria", fillcolor="#DEB887"]
        Nephrocalcinosis_Renal_Stones   [label="Nephrocalcinosis /\nRenal Stones", fillcolor="#C4975A"]
        PTH_Suppression                 [label="PTH Suppression", fillcolor="#F5DEB3"]
        GI_Calcium_Absorption_Increased [label="GI Calcium Absorption\nIncreased", fillcolor="#F5DEB3"]
        Bone_Resorption_Increased       [label="Bone Resorption\nIncreased", fillcolor="#DEB887"]
    }

    // =========================================================
    // CLUSTER 9: Clinical Biomarkers
    // =========================================================
    subgraph cluster_biomarkers {
        label="Clinical Biomarkers"
        style=filled
        fillcolor="#F0F8F8"
        color="#2F4F4F"
        fontname="Helvetica"
        fontsize=11
        fontcolor="#2F4F4F"

        Serum_ACE_Biomarker         [label="Serum ACE\n(Biomarker)", fillcolor="#B0D8D8"]
        sIL2R_Serum_Biomarker       [label="sIL-2R Serum\n(Biomarker)", fillcolor="#B0D8D8"]
        Lysozyme_Serum_Biomarker    [label="Lysozyme Serum\n(Biomarker)", fillcolor="#B0D8D8"]
        CRP_ESR                     [label="CRP / ESR", fillcolor="#B0D8D8"]
        LDH_Serum                   [label="LDH Serum", fillcolor="#B0D8D8"]
        Serum_Calcium_Level         [label="Serum Calcium\nLevel", fillcolor="#B0D8D8"]
        Urine_Calcium_24h           [label="Urine Calcium 24h", fillcolor="#B0D8D8"]
        Ferritin_Level              [label="Ferritin Level", fillcolor="#B0D8D8"]
        Chitotriosidase_Activity    [label="Chitotriosidase\nActivity", fillcolor="#B0D8D8"]
        CC16_Clara_Cell_Protein     [label="CC16 Clara Cell\nProtein", fillcolor="#B0D8D8"]
    }

    // =========================================================
    // CLUSTER 10: Drug Pharmacokinetics
    // =========================================================
    subgraph cluster_pk {
        label="Drug Pharmacokinetics"
        style=filled
        fillcolor="#ECFFE6"
        color="#006400"
        fontname="Helvetica"
        fontsize=11
        fontcolor="#006400"

        // Prednisone PK
        Prednisone_Oral_Dose            [label="Prednisone Oral\nDose", fillcolor="#90EE90"]
        Pred_GI_Absorption_F85pct       [label="GI Absorption\n(F=85%)", fillcolor="#90EE90"]
        Prednisone_Plasma_Central       [label="Prednisone\nPlasma (Central)", fillcolor="#90EE90"]
        Hepatic_Conversion_Prednisolone [label="Hepatic Conversion\n→ Prednisolone", fillcolor="#90EE90"]
        Prednisolone_Active_t12_2h      [label="Prednisolone Active\n(t1/2=2h)", fillcolor="#60C860"]
        Prednisolone_Tissue_Distribution[label="Prednisolone\nTissue Distribution", fillcolor="#90EE90"]

        // MTX PK
        MTX_Oral_Dose_7_20mgwk         [label="MTX Oral Dose\n(7-20mg/wk)", fillcolor="#90EE90"]
        MTX_Plasma_t12_8h              [label="MTX Plasma\n(t1/2=8h)", fillcolor="#90EE90"]
        MTX_Tissue_Distribution        [label="MTX Tissue\nDistribution", fillcolor="#90EE90"]
        MTX_Polyglutamates_Cellular    [label="MTX Polyglutamates\n(Cellular)", fillcolor="#60C860"]

        // AZA PK
        AZA_Oral_Dose_1_3mgkgd         [label="AZA Oral Dose\n(1-3mg/kg/d)", fillcolor="#90EE90"]
        AZA_Plasma_t12_5h              [label="AZA Plasma\n(t1/2=5h)", fillcolor="#90EE90"]
        TGN_6_Erythrocytes_Active      [label="6-TGN Erythrocytes\n(Active)", fillcolor="#60C860"]

        // HCQ PK
        HCQ_Oral_Dose_200_400mgd       [label="HCQ Oral Dose\n(200-400mg/d)", fillcolor="#90EE90"]
        HCQ_Plasma_t12_50d             [label="HCQ Plasma\n(t1/2=50d)", fillcolor="#90EE90"]
        HCQ_Lysosomal_Accumulation     [label="HCQ Lysosomal\nAccumulation", fillcolor="#60C860"]

        // IFX PK
        IFX_Infusion_Dose              [label="IFX Infusion Dose\n(3-5mg/kg)", fillcolor="#90EE90"]
        IFX_Central_Vc_t12_14d         [label="IFX Central Vc\n(t1/2=14d)", fillcolor="#60C860"]
        IFX_Peripheral_Vp              [label="IFX Peripheral Vp\n(Distribution)", fillcolor="#90EE90"]
    }

    // =========================================================
    // CLUSTER 11: Drug Pharmacodynamics / MoA
    // =========================================================
    subgraph cluster_pd {
        label="Drug Pharmacodynamics / MoA"
        style=filled
        fillcolor="#FFF8F8"
        color="#8B0000"
        fontname="Helvetica"
        fontsize=11
        fontcolor="#8B0000"

        // Corticosteroid MoA
        GR_Binding_Prednisone       [label="GR Binding\n(Prednisone/Prednisolone)", fillcolor="#FFB3B3"]
        NF_kB_Inhibition            [label="NF-kB Inhibition", fillcolor="#FF8888"]
        AP1_Inhibition              [label="AP-1 Inhibition", fillcolor="#FF8888"]
        GRE_Transactivation         [label="GRE Transactivation\n(Anti-inflammatory genes)", fillcolor="#FFB3B3"]

        // MTX MoA
        DHFR_Inhibition_MTX         [label="DHFR Inhibition\n(MTX)", fillcolor="#FFB3B3"]
        AICAR_Transformylase_Inhib  [label="AICAR Transformylase\nInhibition", fillcolor="#FFB3B3"]
        Adenosine_Pathway_MTX       [label="Adenosine Pathway\n(MTX)", fillcolor="#FFB3B3"]

        // AZA MoA
        Purine_Synthesis_Inhib_AZA  [label="Purine Synthesis\nInhibition (AZA)", fillcolor="#FFB3B3"]

        // HCQ MoA
        TLR_Endosomal_Inhib_HCQ     [label="TLR Endosomal\nInhibition (HCQ)", fillcolor="#FFB3B3"]

        // Anti-TNF MoA
        TNF_alpha_Neutralization_IFX [label="TNF-alpha Neutralization\n(Infliximab)", fillcolor="#FF8888"]

        // JAK/STAT
        JAK1_2_Inhibition_Ruxo      [label="JAK1/2 Inhibition\n(Ruxolitinib)", fillcolor="#FFB3B3"]
        STAT1_3_Inhibition          [label="STAT1/3 Inhibition", fillcolor="#FFB3B3"]

        // Common downstream PD
        PGE2_Suppression            [label="PGE2 Suppression", fillcolor="#FFB3B3"]
        Lymphocyte_Suppression      [label="Lymphocyte\nSuppression", fillcolor="#FF8888"]
        Granuloma_Regression        [label="Granuloma Regression", fillcolor="#FF6666", fontcolor="white"]
    }

    // =========================================================
    // CLUSTER 12: Clinical Endpoints
    // =========================================================
    subgraph cluster_endpoints {
        label="Clinical Endpoints"
        style=filled
        fillcolor="#F5F0FF"
        color="#4B0082"
        fontname="Helvetica"
        fontsize=11
        fontcolor="#4B0082"

        Scadding_Stage_0_IV             [label="Scadding Stage\n(0-IV)", fillcolor="#C8A8E8"]
        KL6_Pulmonary_Marker            [label="KL-6 Pulmonary\nMarker", fillcolor="#C8A8E8"]
        Dyspnea_mMRC_Score              [label="Dyspnea mMRC Score", fillcolor="#C8A8E8"]
        SGRQ_QoL_Score                  [label="SGRQ QoL Score", fillcolor="#C8A8E8"]
        Extrapulmonary_Organ_Score      [label="Extrapulmonary\nOrgan Score", fillcolor="#C8A8E8"]
        Kings_Sarcoidosis_QSC           [label="King's Sarcoidosis\nQSC", fillcolor="#C8A8E8"]
        Spontaneous_Remission_70pct     [label="Spontaneous Remission\n(~70%)", fillcolor="#A880D0"]
        Chronic_Progressive_Disease_30pct [label="Chronic Progressive\nDisease (~30%)", fillcolor="#A880D0"]
        Treatment_Response_Steroid      [label="Treatment Response\n(Steroid)", fillcolor="#C8A8E8"]
        Mortality_Risk_Respiratory_Cardiac [label="Mortality Risk\n(Respiratory/Cardiac)", fillcolor="#8050B0", fontcolor="white"]
    }

    // =========================================================
    // EDGES: Cluster 1 → Cluster 2 (Triggers → Innate)
    // =========================================================
    Unknown_Antigen         -> Pattern_Recognition [color="#8B4513"]
    Mycobacterial_Ag        -> Pattern_Recognition [color="#8B4513"]
    Mycobacterial_Ag        -> TLR2 [color="#8B4513"]
    Mycobacterial_Ag        -> TLR9 [color="#8B4513"]
    Propionibacterium_Ag    -> Pattern_Recognition [color="#8B4513"]
    Propionibacterium_Ag    -> TLR2 [color="#8B4513"]
    Organic_Dust            -> TLR4 [color="#8B4513"]
    Inorganic_Particles     -> NLRP3_Inflammasome [color="#8B4513"]
    Inorganic_Particles     -> ROS_Production [color="#8B4513"]
    Vimentin_Self_Ag        -> Pattern_Recognition [color="#8B4513"]
    Vimentin_Self_Ag        -> Alveolar_Macrophage [color="#8B4513"]
    HSP70_Self_Ag           -> Pattern_Recognition [color="#8B4513"]
    HSP70_Self_Ag           -> TLR4 [color="#8B4513"]
    Genetic_Susceptibility  -> HLA_DRB1_Restriction [color="#8B4513", style=dashed]
    Genetic_Susceptibility  -> Alveolar_Macrophage [color="#8B4513", style=dashed]
    Genetic_Susceptibility  -> TCR_Activation [color="#8B4513", style=dashed]

    // =========================================================
    // EDGES: Within Cluster 2 (Innate)
    // =========================================================
    TLR2    -> Pattern_Recognition
    TLR4    -> Pattern_Recognition
    TLR9    -> Pattern_Recognition
    NOD2_Receptor       -> Pattern_Recognition
    NOD2_Receptor       -> NLRP3_Inflammasome
    NLRP3_Inflammasome  -> IL1_beta
    Pattern_Recognition -> Phagocytosis_Processing
    Pattern_Recognition -> ROS_Production
    Blood_Monocyte      -> Alveolar_Macrophage
    Blood_Monocyte      -> Dendritic_Cell
    Alveolar_Macrophage -> Phagocytosis_Processing
    Alveolar_Macrophage -> Antigen_Presentation
    Alveolar_Macrophage -> MHC_II_Expression
    Alveolar_Macrophage -> M1_Polarization
    Dendritic_Cell      -> Antigen_Presentation
    Dendritic_Cell      -> MHC_II_Expression
    Phagocytosis_Processing -> Antigen_Presentation
    Antigen_Presentation    -> HLA_DRB1_Restriction
    HLA_DRB1_Restriction    -> MHC_II_Expression
    MHC_II_Expression       -> TCR_Activation

    // =========================================================
    // EDGES: Innate → Cytokines
    // =========================================================
    Alveolar_Macrophage -> TNF_alpha  [color="#B8860B"]
    Alveolar_Macrophage -> IL12_p70   [color="#B8860B"]
    Alveolar_Macrophage -> IL6        [color="#B8860B"]
    Alveolar_Macrophage -> IL1_beta   [color="#B8860B"]
    Alveolar_Macrophage -> GM_CSF     [color="#B8860B"]
    Alveolar_Macrophage -> CCL2_MCP1  [color="#B8860B"]
    Alveolar_Macrophage -> CXCL10_IP10 [color="#B8860B"]
    Alveolar_Macrophage -> Osteopontin [color="#B8860B"]
    Dendritic_Cell      -> IL12_p70   [color="#B8860B"]
    Dendritic_Cell      -> IL18       [color="#B8860B"]
    Dendritic_Cell      -> IL23       [color="#B8860B"]
    M1_Polarization     -> TNF_alpha  [color="#B8860B"]
    M1_Polarization     -> IL1_beta   [color="#B8860B"]
    M1_Polarization     -> CXCL9_MIG  [color="#B8860B"]
    ROS_Production      -> NLRP3_Inflammasome [color="#B8860B"]

    // =========================================================
    // EDGES: Innate → Adaptive
    // =========================================================
    Antigen_Presentation -> TCR_Activation  [color="#006400", penwidth=2]
    MHC_II_Expression    -> TCR_Activation
    TCR_Activation       -> CD28_Costimulation
    TCR_Activation       -> Naive_CD4_T_Cell
    CD28_Costimulation   -> T_Cell_Proliferation
    CD28_Costimulation   -> Th1_Cell
    CTLA4_Checkpoint     -> T_Cell_Proliferation [arrowhead=tee, color=red, style=dashed]

    // =========================================================
    // EDGES: Cytokines → Adaptive (Th differentiation)
    // =========================================================
    IL12_p70 -> Th1_Cell    [color="#8B0000", penwidth=2]
    IL18     -> Th1_Cell
    IL23     -> Th17_Cell
    IL6      -> Th17_Cell
    TGF_beta1 -> Treg_Cell  [color="#006400"]
    IL10     -> Treg_Cell   [color="#006400"]
    IL2      -> T_Cell_Proliferation
    IL2      -> IL2_JAK_Signaling

    // =========================================================
    // EDGES: Within Cluster 3 (Adaptive)
    // =========================================================
    Naive_CD4_T_Cell     -> Th1_Cell
    Naive_CD4_T_Cell     -> Th17_Cell
    Naive_CD4_T_Cell     -> Treg_Cell
    Th1_Cell             -> IFN_gamma  [color="#006400", penwidth=2]
    Th17_Cell            -> IL17A
    Treg_Cell            -> IL10       [color="#006400"]
    Treg_Cell            -> TGF_beta1  [color="#006400"]
    T_Cell_Proliferation -> T_Cell_Memory
    T_Cell_Proliferation -> CD8_T_Cell
    IL2_JAK_Signaling    -> T_Cell_Proliferation
    B_Cell               -> Plasma_Cell
    T_Cell_Proliferation -> B_Cell
    Th1_Cell             -> Th1_Treg_Imbalance [color="#8B0000"]
    Treg_Cell            -> Th1_Treg_Imbalance [arrowhead=tee, color=red, style=dashed]

    // =========================================================
    // EDGES: Adaptive → Cytokines (feedback)
    // =========================================================
    Th1_Cell  -> TNF_alpha   [color="#006400"]
    Th1_Cell  -> IL2         [color="#006400"]
    Th17_Cell -> IL17A
    IFN_gamma -> M1_Polarization [color="#8B0000", penwidth=2]
    IFN_gamma -> CXCL9_MIG
    IFN_gamma -> CXCL10_IP10

    // =========================================================
    // EDGES: Cytokines → Granuloma
    // =========================================================
    TNF_alpha   -> Epithelioid_Macrophage   [color="#800080", penwidth=2]
    IFN_gamma   -> Epithelioid_Macrophage   [color="#800080", penwidth=2]
    CCL2_MCP1   -> Epithelioid_Macrophage   [color="#800080"]
