digraph PHN_QSP {
    rankdir=LR;
    graph [splines=spline, overlap=false, nodesep=0.40, ranksep=0.65, fontname="Helvetica", fontsize=11, label="Postherpetic Neuralgia (PHN) — Quantitative Systems Pharmacology Map\nVZV reactivation · sensory ganglion injury · peripheral & central sensitization · multimodal pharmacology · vaccine prophylaxis", labelloc=t];
    node  [shape=box, style="rounded,filled", fontname="Helvetica", fontsize=10, color="#333333"];
    edge  [fontname="Helvetica", fontsize=8, color="#555555", arrowsize=0.7];

    // ---------------------------------------------------------------- 1. VARICELLA-ZOSTER VIROLOGY & REACTIVATION
    subgraph cluster_vzv {
        label="1. VZV virology & latency–reactivation"; style="rounded,filled"; color="#cfe8ff"; fontsize=12;
        node [fillcolor="#eaf4ff"];
        VZV_primary       [label="Primary varicella\n(childhood chickenpox)"];
        DRG_latency       [label="DRG / cranial-ganglion\nlatency (ORF63, LAT-like)"];
        CMI_VZV           [label="VZV-specific CMI\n(CD4/CD8 IFN-γ ELISpot)"];
        Immunosenescence  [label="Immunosenescence\n(age>50, T-cell exhaustion)"];
        Iatrogenic_IS     [label="Iatrogenic IS\n(steroids, JAK-i, MTX, anti-CD20)"];
        Stress_HPA        [label="Stress · UV · trauma\n(cortisol surge)"];
        VZV_react         [label="VZV reactivation\n(IE62, ORF4, ORF66)"];
        Ganglionitis      [label="Ganglionitis\n(necrosis, hemorrhage)"];
        Axonal_transport  [label="Anterograde axonal\ntransport to dermatome"];
        Cutaneous_HZ      [label="Cutaneous zoster\n(dermatomal vesicles)"];
        VZV_load          [label="VZV DNA load\n(skin & CSF qPCR)"];
        Severe_AP         [label="Severe acute pain\n(>NRS 7)"];
        Dermatome_extent  [label="Dermatomal extent\n>50 lesions"];
    }

    // ---------------------------------------------------------------- 2. NEURAL INJURY & DEGENERATION
    subgraph cluster_injury {
        label="2. Sensory neuron injury & degeneration"; style="rounded,filled"; color="#ffe4cc"; fontsize=12;
        node [fillcolor="#fff2e0"];
        Aβ_fiber       [label="Aβ low-threshold\nmechanoreceptor"];
        Aδ_fiber       [label="Aδ-fiber\n(fast pain, cold)"];
        C_fiber        [label="C-fiber\n(polymodal nociceptor)"];
        IENF_density   [label="Intraepidermal nerve\nfiber density (PGP9.5↓)"];
        Wallerian_deg  [label="Wallerian degeneration\n(SARM1, NMNAT2)"];
        Axotomy        [label="Axotomy / dieback"];
        Sprouting      [label="Aberrant\ncollateral sprouting"];
        Ganglion_atrophy [label="DRG neuron atrophy\n& satellite cell activation"];
        Demyelination  [label="Schwann cell\ndemyelination"];
        Skin_scar      [label="Dermal scar / pigment\n(allodynic patch)"];
        Mast_cell_skin [label="Skin mast-cell\ndegranulation"];
    }

    // ---------------------------------------------------------------- 3. PERIPHERAL SENSITIZATION (PNS)
    subgraph cluster_psens {
        label="3. Peripheral sensitization (nociceptor terminals)"; style="rounded,filled"; color="#ffd6d6"; fontsize=12;
        node [fillcolor="#ffeaea"];
        TRPV1        [label="TRPV1\n(capsaicin/heat/H+)"];
        TRPA1        [label="TRPA1\n(reactive electrophiles)"];
        TRPM8        [label="TRPM8\n(menthol/cold)"];
        Nav1_7       [label="NaV1.7 (SCN9A)\namplifier"];
        Nav1_8       [label="NaV1.8 (SCN10A)\nAP upstroke"];
        Nav1_9       [label="NaV1.9 (SCN11A)\npersistent INa"];
        HCN2         [label="HCN2 pacemaker\n(Ih, ectopic firing)"];
        Cav_a2d1     [label="Cav α2δ-1 / α2δ-2\n(presyn Ca²⁺ ch.)"];
        ASIC3        [label="ASIC3\n(acid-sensing)"];
        P2X3         [label="P2X3 / P2X2/3\n(ATP)"];
        TRKA         [label="TrkA (NGF)\nperipheral upregulation"];
        BDKRB1       [label="Bradykinin B1/B2"];
        EP_receptors [label="EP1-4 (PGE2)"];
        SP_release   [label="Substance P / CGRP\nneurogenic flare"];
        PIEZO2       [label="PIEZO2 (touch)\nrecruited to pain"];
    }

    // ---------------------------------------------------------------- 4. CENTRAL SENSITIZATION (CNS)
    subgraph cluster_csens {
        label="4. Spinal & supraspinal sensitization"; style="rounded,filled"; color="#e4d6ff"; fontsize=12;
        node [fillcolor="#f1e7ff"];
        DH_lamina_I_II [label="Spinal dorsal horn\nlamina I/II/V"];
        NMDA         [label="NMDA receptor\n(GluN2B, Mg²⁺ block)"];
        AMPA_KAR     [label="AMPA / kainate\n(GluA1 phospho)"];
        mGluR5       [label="mGluR5 (group I)"];
        NK1_DH       [label="NK1 (SP)"];
        Gly_DH       [label="Glycine receptor\n(α3, disinhibition)"];
        GABA_A_DH    [label="GABAA / KCC2 ↓\n(Cl⁻ disinhibition)"];
        Microglia_DH [label="Microglial activation\n(P2X4, CSF1R, BDNF)"];
        Astrocytes_DH[label="Astrocyte CXCL1\nIL-6 / D-serine"];
        DR_LTP       [label="Wind-up · LTP\n(dorsal horn)"];
        WDR_neurons  [label="WDR neurons\n(receptive field ↑)"];
        DNIC         [label="Descending facilitation\n(RVM ON-cells)"];
        Brainstem_PAG[label="PAG / LC noradrenergic\ndescending modulation"];
        Thalamic_VPL [label="Thalamic VPL\n(burst firing)"];
        S1_cortex    [label="S1 cortex\n(map reorganization)"];
        ACC_insula   [label="ACC / Insula\n(affective pain)"];
        Hippocampus  [label="Hippocampus\n(memory of pain)"];
        Default_mode [label="Default mode network\nconnectivity ↓"];
    }

    // ---------------------------------------------------------------- 5. NEUROINFLAMMATION
    subgraph cluster_neuroinflam {
        label="5. Neuroinflammation & cytokines"; style="rounded,filled"; color="#fff4b0"; fontsize=12;
        node [fillcolor="#fffac8"];
        IL1b   [label="IL-1β\n(NLRP3 / caspase-1)"];
        TNFa   [label="TNF-α (sTNF-α)\nTNFR1 on neuron"];
        IL6    [label="IL-6 / sIL-6R\n(JAK2/STAT3)"];
        CXCL1  [label="CXCL1 / CXCR2\nastro-microglia"];
        CCL2   [label="CCL2 / CCR2\nmonocyte recruit"];
        CX3CL1 [label="Fractalkine (CX3CL1)\nCX3CR1 microglia"];
        BDNF_mg[label="Microglial BDNF\n(KCC2 down-regulation)"];
        NGF    [label="NGF in skin / DRG\n(sensitization)"];
        IL10   [label="IL-10 anti-inflam.\n(macrophage polarization)"];
        Complement [label="Complement C3 / C5a\n(myelin debris clearance)"];
        IDO1   [label="IDO1 / kynurenine\n(QA → NMDA agonism)"];
    }

    // ---------------------------------------------------------------- 6. CLINICAL PHENOTYPE & ENDPOINTS
    subgraph cluster_clin {
        label="6. Clinical phenotype & endpoints"; style="rounded,filled"; color="#d6f5d6"; fontsize=12;
        node [fillcolor="#e8fbe8"];
        AHZ_pain      [label="Acute herpetic pain\n(zoster, days 0-30)"];
        Subacute      [label="Subacute zoster pain\n(30-90 d)"];
        PHN_def       [label="PHN (>90 d after rash)\nNRS ≥3"];
        NRS_pain      [label="NRS / VAS 0-10\n(weekly diary)"];
        SF_MPQ2       [label="SF-MPQ-2\nneuropathic subscale"];
        Allodynia     [label="Dynamic mechanical\nallodynia (brush)"];
        Hyperalgesia  [label="Punctate hyperalgesia\n(pinprick)"];
        Burning       [label="Burning / dysesthesia"];
        Paroxysmal    [label="Paroxysmal\nelectric-shock pains"];
        Itch          [label="Post-herpetic itch\n(face / scalp)"];
        Sleep_PSQI    [label="Sleep PSQI / ISI"];
        Mood_PHQ9     [label="PHQ-9 / HADS\ndepression-anxiety"];
        QoL_SF36      [label="SF-36 / EQ-5D"];
        Patient_PGIC  [label="PGIC ≥ much-improved"];
        Resp30_50     [label="≥30% / ≥50% NRS\nresponder rate"];
        Time_to_resp  [label="Time-to-onset of\nmeaningful analgesia"];
        QST_panel     [label="QST: WDT/CDT/MPT/CPM\n(DFNS protocol)"];
        OFR_ratio     [label="Opioid:non-opioid\nuse ratio"];
        Functional_int[label="Brief Pain Inventory\ninterference subscale"];
    }

    // ---------------------------------------------------------------- 7. ANTIVIRAL THERAPY
    subgraph cluster_antiviral {
        label="7. Antiviral & vaccine prophylaxis"; style="rounded,filled"; color="#cfe0cf"; fontsize=12;
        node [fillcolor="#e3eee3"];
        ACV     [label="Aciclovir / valaciclovir\nVZV TK → DNA pol"];
        FCV     [label="Famciclovir / penciclovir"];
        Bremzic [label="Brincidofovir / amenamevir\n(helicase-primase)"];
        Letermo [label="(experimental anti-VZV)\nhelicase-primase"];
        ZVL     [label="Zostavax\n(live attenuated)"];
        RZV     [label="Shingrix (RZV)\nVZV gE + AS01B"];
        Vaccine_eff[label="Vaccine efficacy\nHZ ↓ 97% / PHN ↓ 89%"];
        gE_CD4  [label="VZV-gE CD4+ Th1\nmemory T-cell"];
        Antibody_titer [label="Anti-gE IgG / IFN-γ"];
    }

    // ---------------------------------------------------------------- 8. SODIUM-CHANNEL / Cav / TCA PHARMACOLOGY
    subgraph cluster_pharm_nav {
        label="8. Pharmacology — channels & monoamines"; style="rounded,filled"; color="#d0e4f5"; fontsize=12;
        node [fillcolor="#e3eff8"];
        Gabapentin    [label="Gabapentin (GBP)\nα2δ-1 ligand"];
        Pregabalin    [label="Pregabalin (PGB)\nα2δ-1 ligand"];
        Mirogabalin   [label="Mirogabalin\nα2δ-1 selective"];
        Crisugabalin  [label="Crisugabalin (HSK16149)"];
        TCA_amitrip   [label="Amitriptyline (TCA)\nSERT/NET + Na+ block"];
        TCA_nortrip   [label="Nortriptyline\nNET > SERT"];
        SNRI_dulox    [label="Duloxetine (SNRI)\nNET/SERT"];
        Carbamazepine [label="Carbamazepine / OXC\nNaV1.x state-dep block"];
        Lamotrigine   [label="Lamotrigine\nNa+ block"];
        Lidocaine_5pc [label="Lidocaine 5% patch\nNaV peripheral block"];
        Vixotrig      [label="Vixotrigine (NaV1.7)"];
        Funapide      [label="Funapide / TV-45070"];
        LX9211        [label="LX9211 (AAK1)"];
        Tramadol      [label="Tramadol\n(μ + SNRI)"];
        Tapentadol    [label="Tapentadol (μ + NRI)"];
        Opioids       [label="Oxycodone / morphine\nMOR agonists"];
        Mexiletine    [label="Mexiletine (Class Ib)"];
    }

    // ---------------------------------------------------------------- 9. TOPICAL / INTERVENTIONAL
    subgraph cluster_topical {
        label="9. Topical / device / interventional"; style="rounded,filled"; color="#f5d6e6"; fontsize=12;
        node [fillcolor="#fceaf3"];
        Capsaicin_8   [label="Capsaicin 8% patch\nTRPV1 defunctionalization"];
        Capsaicin_lo  [label="Capsaicin 0.075%"];
        Lido_patch    [label="Lidocaine 5% medicated\nplaster"];
        Lido_inf      [label="IV lidocaine infusion"];
        Botox_A       [label="Onabotulinumtoxin A\n(SNAP-25 cleavage)"];
        EMLA          [label="EMLA / prilocaine"];
        TENS_PENS     [label="TENS / PENS"];
        SCS           [label="Spinal cord stim\n(8 kHz / DRG-S)"];
        DRG_pulsed    [label="Pulsed RF of DRG"];
        Intercostal_block[label="Intercostal / paravertebral\nblock + steroid"];
        Epidural_steroid [label="Epidural methylprednisolone"];
        Acupuncture   [label="Acupuncture / dry needling"];
        Ketamine_inf  [label="IV / topical ketamine\nNMDA antagonism"];
    }

    // ---------------------------------------------------------------- 10. EMERGING & NEUROIMMUNE TARGETS
    subgraph cluster_emerging {
        label="10. Emerging / disease-modifying targets"; style="rounded,filled"; color="#e0d2c2"; fontsize=12;
        node [fillcolor="#eee2d2"];
        Tanezumab    [label="Tanezumab (anti-NGF)\n(safety hold ↓)"];
        Fasinumab    [label="Fasinumab (anti-NGF)"];
        Galcanezumab [label="anti-CGRP mAbs\n(off-label exploration)"];
        AT_OXC_NEW   [label="Selective NaV1.7/1.8\n(Vertex VX-548 etc.)"];
        TRPV1_antag  [label="TRPV1 antagonists\n(SAF-312, NEO6860)"];
        P2X3_antag   [label="Gefapixant / camlipixant\nP2X3 antagonism"];
        Microglia_inhib[label="Microglial P2X4/CSF1R\ninhibitors"];
        Anti_CGRP    [label="Anti-CGRP / atogepant"];
        Cannabinoids [label="Cannabinoids (THC/CBD)\nCB1/CB2"];
        Memantine    [label="Memantine\n(NMDA antagonist)"];
        Onabot_central[label="Botulinum (central effect?\nretrograde)"];
        DRG_genetherapy[label="Gene therapy\n(HSV-IE-IL-10, hNT3)"];
    }

    // ---------------------------------------------------------------- 11. PHARMACOKINETICS (PK)
    subgraph cluster_pk {
        label="11. PK / ADME compartments"; style="rounded,filled"; color="#bcd6e6"; fontsize=12;
        node [fillcolor="#d6e6f0"];
        Oral_dose    [label="Oral / topical dose\n(input)"];
        GI_absorp    [label="GI absorption\n(Ka, F)"];
        Central_PK   [label="Central plasma (Cp)\nVc/CL"];
        Periph_PK    [label="Peripheral tissue Vp\nQ inter-compartment"];
        CNS_PK       [label="CSF / brain PK\n(P-gp, MRP)"];
        Skin_PK      [label="Dermal compartment\n(topical Css)"];
        Renal_CL     [label="Renal CL\n(CrCl dose-adjust)"];
        Hepatic_CL   [label="Hepatic CYP\n(2D6 TCA, 3A4 OXC)"];
        PPB          [label="Plasma protein\nbinding (free fraction)"];
        Lido_metab   [label="Lidocaine → MEGX → GX\n(CYP1A2/3A4)"];
        Gaba_PK      [label="Gabapentin saturable\nL-AA transporter (LAT1)"];
        Op_metab     [label="Opioid CYP2D6/3A4 / UGT"];
    }

    // ---------------------------------------------------------------- 12. SYSTEMIC SAFETY / ADVERSE EFFECTS
    subgraph cluster_safety {
        label="12. Safety & off-target organ effects"; style="rounded,filled"; color="#ffd0cf"; fontsize=12;
        node [fillcolor="#ffe5e4"];
        CNS_sedation  [label="Sedation / dizziness\n(α2δ ligand, TCA)"];
        Cardiac_QT    [label="QTc prolongation\n(TCA, methadone)"];
        Anti_chol     [label="Anticholinergic AE\n(TCA M1 block)"];
        Constipation  [label="Constipation\n(opioid μ-GI)"];
        OIH           [label="Opioid-induced\nhyperalgesia"];
        Falls         [label="Falls / fractures\n(elderly)"];
        SIADH         [label="SIADH\n(carbamazepine, SSRI)"];
        SJS_HLA       [label="SJS/TEN HLA-B*15:02\n(carbamazepine)"];
        Weight_gain   [label="Weight gain (PGB, GBP)"];
        Peripheral_edema [label="Peripheral edema\n(α2δ ligand)"];
        Renal_AE      [label="Renal dose adjust"];
        Suicidality   [label="Suicidality monitoring\n(AEDs, TCAs)"];
    }

    // ---------------------------------------------------------------- 13. PATIENT FACTORS / COVARIATES
    subgraph cluster_covar {
        label="13. Patient covariates & risk factors"; style="rounded,filled"; color="#f2e0b3"; fontsize=12;
        node [fillcolor="#faecc7"];
        Age           [label="Age (>60 → PHN risk ↑)"];
        Sex_female    [label="Female sex"];
        Diabetes      [label="Diabetes / DPN comorbid"];
        Immunosup     [label="Immunosuppression\n(HSCT, SOT, HIV)"];
        Severe_rash   [label="Severe acute rash"];
        Prodromal_pain[label="Prodromal pain"];
        Ophthalmic_HZ [label="Ophthalmic / cervical HZ"];
        Genetics      [label="Genetics: HLA, SCN9A,\nCOMT, OPRM1"];
        Frailty       [label="Frailty / CIRS-G"];
        Polypharm     [label="Polypharmacy"];
        Renal_func    [label="eGFR / CrCl"];
        Liver_func    [label="Hepatic Child-Pugh"];
    }

    // =================================================================
    // ============================ EDGES ===============================
    // =================================================================
    VZV_primary -> DRG_latency;
    DRG_latency -> VZV_react [label="reactivation"];
    Immunosenescence -> VZV_react [label="↑"];
    Iatrogenic_IS -> VZV_react [label="↑"];
    Stress_HPA -> VZV_react;
    CMI_VZV -> VZV_react [color=blue, label="–"];
    VZV_react -> Ganglionitis;
    Ganglionitis -> Axonal_transport -> Cutaneous_HZ;
    Cutaneous_HZ -> VZV_load;
    Cutaneous_HZ -> AHZ_pain;
    VZV_load -> Severe_AP;
    Severe_AP -> PHN_def [label="risk"];
    Dermatome_extent -> PHN_def [label="risk"];
    Prodromal_pain -> PHN_def [label="risk"];

    Ganglionitis -> Ganglion_atrophy;
    Ganglionitis -> Axotomy;
    Axotomy -> Wallerian_deg;
    Wallerian_deg -> Demyelination;
    Wallerian_deg -> IENF_density [color=blue];
    Axotomy -> Sprouting;
    Sprouting -> Aβ_fiber [label="touch→pain"];
    Sprouting -> Allodynia;
    Skin_scar -> Allodynia;
    Mast_cell_skin -> NGF;
    Mast_cell_skin -> Itch;

    Aδ_fiber -> DH_lamina_I_II;
    C_fiber  -> DH_lamina_I_II;
    Aβ_fiber -> DH_lamina_I_II [label="post-injury"];
    DH_lamina_I_II -> WDR_neurons;
    WDR_neurons -> DR_LTP;
    DR_LTP -> Hyperalgesia;
    DR_LTP -> Allodynia;
    NMDA -> DR_LTP;
    AMPA_KAR -> DR_LTP;
    mGluR5 -> NMDA;
    NK1_DH -> DR_LTP;
    Microglia_DH -> BDNF_mg -> GABA_A_DH [color=red, label="KCC2↓"];
    GABA_A_DH -> DR_LTP [color=red, label="disinhibition"];
    Gly_DH -> DR_LTP [color=red];
    Astrocytes_DH -> CXCL1 -> Microglia_DH;
    Astrocytes_DH -> IL6;
    CX3CL1 -> Microglia_DH;
    P2X3 -> DH_lamina_I_II;
    DH_lamina_I_II -> Thalamic_VPL -> S1_cortex;
    Thalamic_VPL -> ACC_insula;
    ACC_insula -> Mood_PHQ9;
    Hippocampus -> ACC_insula;
    Brainstem_PAG -> DH_lamina_I_II [color=blue, label="−"];
    DNIC -> DH_lamina_I_II [color=red, label="+"];
    S1_cortex -> Default_mode;

    // Peripheral sensitization
    NGF -> TRKA -> TRPV1 [label="↑"];
    NGF -> TRKA -> Nav1_8 [label="↑"];
    TRPV1 -> C_fiber;
    TRPA1 -> C_fiber;
    TRPM8 -> Aδ_fiber;
    Nav1_7 -> C_fiber [label="threshold"];
    Nav1_8 -> C_fiber [label="upstroke"];
    Nav1_9 -> C_fiber [label="persistent"];
    HCN2 -> C_fiber [label="ectopic"];
    Cav_a2d1 -> C_fiber [label="presyn"];
    ASIC3 -> C_fiber;
    P2X3 -> C_fiber;
    EP_receptors -> TRPV1;
    BDKRB1 -> TRPV1;
    SP_release -> Mast_cell_skin;
    PIEZO2 -> Aβ_fiber;

    // Neuroinflammation
    Ganglionitis -> IL1b;
    Ganglionitis -> TNFa;
    Ganglionitis -> IL6;
    Microglia_DH -> TNFa;
    Microglia_DH -> IL1b;
    Microglia_DH -> CCL2;
    IL1b -> NMDA [label="phospho"];
    TNFa -> Nav1_7 [label="↑"];
    IL6  -> NGF;
    IDO1 -> NMDA [label="QA agonist"];
    IL10 -> Microglia_DH [color=blue, label="−"];
    Complement -> Wallerian_deg;

    // Clinical
    DR_LTP -> NRS_pain;
    Allodynia -> NRS_pain;
    Hyperalgesia -> NRS_pain;
    Burning -> NRS_pain;
    Paroxysmal -> NRS_pain;
    NRS_pain -> SF_MPQ2;
    NRS_pain -> Sleep_PSQI;
    Sleep_PSQI -> Mood_PHQ9;
    Mood_PHQ9 -> QoL_SF36;
    NRS_pain -> Patient_PGIC;
    NRS_pain -> Resp30_50;
    NRS_pain -> Time_to_resp;
    Allodynia -> QST_panel;
    NRS_pain -> Functional_int;

    // Vaccine / antiviral
    ACV -> VZV_load [color=blue, label="−"];
    FCV -> VZV_load [color=blue, label="−"];
    Bremzic -> VZV_load [color=blue];
    Letermo -> VZV_load [color=blue];
    RZV -> gE_CD4 -> CMI_VZV;
    RZV -> Antibody_titer;
    ZVL -> CMI_VZV;
    Vaccine_eff -> Cutaneous_HZ [color=blue, label="−"];
    Vaccine_eff -> PHN_def [color=blue, label="−"];

    // Pharmacology mappings
    Gabapentin -> Cav_a2d1 [color=blue, label="−"];
    Pregabalin -> Cav_a2d1 [color=blue, label="−"];
    Mirogabalin -> Cav_a2d1 [color=blue, label="−"];
    Crisugabalin -> Cav_a2d1 [color=blue];
    TCA_amitrip -> NET_SERT_node [style=invis];
    TCA_amitrip -> Brainstem_PAG [color=blue, label="DNIC↑"];
    TCA_amitrip -> Nav1_7 [color=blue];
    TCA_nortrip -> Brainstem_PAG [color=blue];
    SNRI_dulox -> Brainstem_PAG [color=blue];
    Carbamazepine -> Nav1_7 [color=blue];
    Carbamazepine -> Nav1_8 [color=blue];
    Lamotrigine -> Nav1_7 [color=blue];
    Lidocaine_5pc -> Nav1_7 [color=blue, label="local"];
    Lidocaine_5pc -> Nav1_8 [color=blue, label="local"];
    Lido_inf -> Nav1_7 [color=blue];
    Vixotrig -> Nav1_7 [color=blue];
    Funapide -> Nav1_7 [color=blue];
    LX9211 -> Nav1_7 [color=blue, label="indirect"];
    Tramadol -> Brainstem_PAG [color=blue];
    Tapentadol -> Brainstem_PAG [color=blue];
    Opioids -> Brainstem_PAG [color=blue, label="μ"];
    Mexiletine -> Nav1_7 [color=blue];

    Capsaicin_8 -> TRPV1 [color=blue, label="defunctionalize"];
    Capsaicin_8 -> IENF_density [color=red, label="prune"];
    Capsaicin_lo -> TRPV1 [color=blue];
    Lido_patch -> Nav1_7 [color=blue, label="local"];
    Botox_A -> SP_release [color=blue, label="SNAP-25"];
    Botox_A -> TRPV1 [color=blue];
    EMLA -> Nav1_7 [color=blue];
    TENS_PENS -> DR_LTP [color=blue];
    SCS -> DR_LTP [color=blue];
    DRG_pulsed -> Ganglion_atrophy [color=blue];
    Intercostal_block -> Nav1_7 [color=blue];
    Epidural_steroid -> Microglia_DH [color=blue];
    Acupuncture -> DNIC [color=blue];
    Ketamine_inf -> NMDA [color=blue];

    Tanezumab -> NGF [color=blue, label="−"];
    Fasinumab -> NGF [color=blue];
    Galcanezumab -> SP_release [color=blue, label="CGRP"];
    AT_OXC_NEW -> Nav1_8 [color=blue];
    AT_OXC_NEW -> Nav1_7 [color=blue];
    TRPV1_antag -> TRPV1 [color=blue];
    P2X3_antag -> P2X3 [color=blue];
    Microglia_inhib -> Microglia_DH [color=blue];
    Anti_CGRP -> SP_release [color=blue];
    Cannabinoids -> DR_LTP [color=blue];
    Memantine -> NMDA [color=blue];
    Onabot_central -> NMDA [color=blue];
    DRG_genetherapy -> IL10;

    // PK wiring
    Oral_dose -> GI_absorp -> Central_PK -> Periph_PK;
    Central_PK -> CNS_PK;
    Central_PK -> Skin_PK;
    Central_PK -> Renal_CL;
    Central_PK -> Hepatic_CL;
    Central_PK -> PPB;
    Lido_metab -> Hepatic_CL;
    Gaba_PK -> GI_absorp [label="LAT1 sat"];
    Op_metab -> Hepatic_CL;
    Central_PK -> Gabapentin;
    Central_PK -> Pregabalin;
    Central_PK -> Mirogabalin;
