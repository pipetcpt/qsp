        IOV_params    [label="IOV Parameters\n(inter-occasion\nvariability)", fillcolor="#202020", fontcolor="white"];

        Body_weight -> GIV_dose [label="mg/kg\nnormalization"];
        Renal_func -> GIV_urine_ex [label="determines\nexcretion rate"];
        Hepatic_func -> ASGPR [label="ASGPR expression\nlevel"];
