    // ─────────────────────────────────────────────────────
    // CLUSTER 11: Population PK Variability & Covariates
    // ─────────────────────────────────────────────────────
    subgraph cluster_popPK {
        label="Population PK/PD Variability & Covariates";
        style="filled";
        color="#708090";
        fillcolor="#F5F5F5";
        fontname="Helvetica-Bold";
        fontsize=10;

        Body_weight   [label="Body Weight\n(mg/kg dose norm.)", fillcolor="#C0C0C0"];
        Renal_func    [label="Renal Function\n(eGFR determines\ngivosiran CL)", fillcolor="#A9A9A9"];
        Hepatic_func  [label="Hepatic Function\n(ASGPR expression;\nmCTP score)", fillcolor="#909090"];
        Female_sex    [label="Female Sex\n(AIP predominance\n5:1 F:M ratio)", fillcolor="#808080", fontcolor="white"];
        Age_effect    [label="Age (peak onset\n15-45 yrs;\nhormonal window)", fillcolor="#696969", fontcolor="white"];
        HMBS_genotype [label="HMBS Genotype\n(>400 pathogenic\nvariants)", fillcolor="#606060", fontcolor="white"];
        Ethnicity     [label="Ethnicity\n(Swedish/Irish\nhigher prevalence)", fillcolor="#505050", fontcolor="white"];
        CYP_variant   [label="CYP Polymorphisms\n(CYP1A2, 2C9\ninfluence triggers)", fillcolor="#404040", fontcolor="white"];
