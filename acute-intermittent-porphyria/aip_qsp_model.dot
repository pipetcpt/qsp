        HMBS_genotype -> PBGD_fxn [label="determines\nresidual activity"];
        CYP_variant -> CYP_enzymes [label="metabolizer\nstatus"];
        IIV_params -> GIV_plasma [label="varies PK\nacross patients"];
        IOV_params -> GIV_plasma [label="varies PK\nacross cycles"];
    }

    // ─────────────────────────────────────────────────────
    // Key cross-cluster edges
    // ─────────────────────────────────────────────────────
    ALAS1_cleavage -> ALAS1_prot [label="↓ enzyme\nproduction", color="#6A0DAD", style=dashed, arrowhead=tee];
