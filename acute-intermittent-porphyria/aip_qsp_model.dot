        PBGD_fxn -> HMBS_gene_test [label="genetic basis\nHMBS mutations"];
        Spot_urine -> AAR [label="triggers\nattack diagnosis"];
        Quant_urine -> ALA_norm [label="confirms\ntreatment response"];
        Quant_urine -> PBG_norm [label="confirms\ntreatment response"];
        GIV_plasma -> GIV_TDM [label="blood sample\nfor TDM"];
        GIV_TDM -> AAR [label="exposure-response\nrelationship"];
        LFT_monitor -> HCC_risk [label="HCC surveillance\n(ultrasound + AFP)"];
        Renal_monitor -> CKD_prog [label="monitors\nALA nephrotoxicity"];
