digraph DMD_QSP {
  graph [rankdir=LR, fontname="Helvetica", fontsize=11, bgcolor="#1a1a2e",
         label="Duchenne Muscular Dystrophy (DMD)\nQuantitative Systems Pharmacology Model",
         labelloc=t, labelfontsize=18, labelfontcolor="white", splines=line,
         nodesep=0.4, ranksep=0.8, pad=0.5]
  node [fontname="Helvetica", fontsize=9, style="filled,rounded", shape=box, margin="0.12,0.06"]
  edge [fontname="Helvetica", fontsize=8, arrowsize=0.7]

  /* ========== CLUSTER 1: Genetic & Molecular Basis ========== */
  subgraph cluster_genetics {
    label="1. Genetic & Molecular Basis"
    style=filled
    color="#2d4a7a"
    bgcolor="#0d1b2e"
    fontcolor="white"
    fontsize=12

    DMD_gene [label="DMD Gene\n(Xp21.2, 2.4 Mb)", fillcolor="#4a90d9", fontcolor="white"]
    Deletion_mut [label="Deletion/Duplication\n(~72% DMD pts)", fillcolor="#e74c3c", fontcolor="white"]
    Nonsense_mut [label="Nonsense Mutation\n(~13% DMD pts)", fillcolor="#c0392b", fontcolor="white"]
    Point_mut [label="Point/Other\nMutation (~15%)", fillcolor="#c0392b", fontcolor="white"]
    Pre_mRNA [label="DMD Pre-mRNA\n(79 exons)", fillcolor="#4a90d9", fontcolor="white"]
    Reading_frame [label="Reading Frame\nDisruption/Correction", fillcolor="#f39c12", fontcolor="white"]
    Dystrophin_mRNA [label="Dystrophin mRNA\n(14,000 nt, full-length)", fillcolor="#3498db", fontcolor="white"]
    Dystrophin_full [label="Full-length Dystrophin\n(427 kDa, Dp427)", fillcolor="#2ecc71", fontcolor="white"]
    Truncated_dyst [label="Truncated Dystrophin\n(BMD-like functional)", fillcolor="#f39c12", fontcolor="white"]
    No_dystrophin [label="Absent Dystrophin\n(DMD phenotype)", fillcolor="#e74c3c", fontcolor="white"]
    Dp71 [label="Dp71 Isoform\n(Brain/kidney)", fillcolor="#9b59b6", fontcolor="white"]
    Dp116 [label="Dp116 Isoform\n(Schwann cells)", fillcolor="#8e44ad", fontcolor="white"]
    Exon_target [label="Exon-Skip Target\n(ex45/51/53)", fillcolor="#9b59b6", fontcolor="white"]
    PTC_codon [label="Premature Stop Codon\n(PTC – nonsense mut)", fillcolor="#e74c3c", fontcolor="white"]
  }

  /* ========== CLUSTER 2: DAPC Complex ========== */
  subgraph cluster_dapc {
    label="2. Dystrophin-Associated Protein Complex (DAPC)"
    style=filled
    color="#7a4a2d"
    bgcolor="#2e1b0d"
    fontcolor="white"
    fontsize=12

    DAPC_intact [label="DAPC Intact\n(Normal anchor)", fillcolor="#2ecc71", fontcolor="white"]
    DAPC_disrupted [label="DAPC Disrupted\n(DMD)", fillcolor="#e74c3c", fontcolor="white"]
    Alpha_DG [label="α-Dystroglycan\n(Extracellular)", fillcolor="#e67e22", fontcolor="white"]
    Beta_DG [label="β-Dystroglycan\n(Transmembrane)", fillcolor="#e67e22", fontcolor="white"]
    Alpha_SG [label="α-Sarcoglycan\n(Secondary loss)", fillcolor="#d4ac0d", fontcolor="white"]
    Beta_SG [label="β-Sarcoglycan", fillcolor="#d4ac0d", fontcolor="white"]
    Gamma_SG [label="γ-Sarcoglycan", fillcolor="#d4ac0d", fontcolor="white"]
    Delta_SG [label="δ-Sarcoglycan", fillcolor="#d4ac0d", fontcolor="white"]
    Syntrophins [label="α1/β-Syntrophins\n(Scaffolding)", fillcolor="#27ae60", fontcolor="white"]
    Dystrobrevins [label="α/β-Dystrobrevins", fillcolor="#27ae60", fontcolor="white"]
    nNOS [label="nNOS (Dp427)\nMislocalized → fatigue", fillcolor="#8e44ad", fontcolor="white"]
    Laminin_211 [label="Laminin-211\n(ECM anchor)", fillcolor="#7f8c8d", fontcolor="white"]
    Actin_cytoskel [label="F-Actin\nCytoskeleton", fillcolor="#2980b9", fontcolor="white"]
    Utrophin [label="Utrophin (Utr-A)\nCompensatory", fillcolor="#27ae60", fontcolor="white"]
  }

  /* ========== CLUSTER 3: Sarcolemmal Damage & Ca²⁺ ========== */
  subgraph cluster_membrane {
    label="3. Sarcolemmal Damage & Calcium Dysregulation"
    style=filled
    color="#7a2d4a"
    bgcolor="#2e0d1b"
    fontcolor="white"
    fontsize=12

    Mech_stress [label="Mechanical Stress\n(Eccentric contraction)", fillcolor="#c0392b", fontcolor="white"]
    Sarcolemmal_tears [label="Sarcolemmal Tears\n(Microtears)", fillcolor="#e74c3c", fontcolor="white"]
    Ca2_influx [label="Ca²⁺ Influx\n(Pathological)", fillcolor="#e74c3c", fontcolor="white"]
    TRPC1 [label="TRPC1/6 Channels\n(Stretch-activated)", fillcolor="#c0392b", fontcolor="white"]
    TRPV2 [label="TRPV2 Channel\n(Ca²⁺ entry)", fillcolor="#c0392b", fontcolor="white"]
    Calpain1 [label="Calpain-1/2\nActivation (μ/m)", fillcolor="#e74c3c", fontcolor="white"]
    Calpain3 [label="Calpain-3 (p94)\nMuscle-specific", fillcolor="#e74c3c", fontcolor="white"]
    Mito_dysfunc [label="Mitochondrial\nDysfunction", fillcolor="#e67e22", fontcolor="white"]
    ROS_prod [label="ROS Production\nOxidative Stress", fillcolor="#f39c12", fontcolor="white"]
    ER_stress [label="ER Stress\n(UPR activation)", fillcolor="#c0392b", fontcolor="white"]
    Cytochrome_c [label="Cytochrome c\nRelease", fillcolor="#e74c3c", fontcolor="white"]
    Caspase_3 [label="Caspase-3/9\nApoptosis", fillcolor="#e74c3c", fontcolor="white"]
    Proteasome [label="Ubiquitin-Proteasome\n(Protein degradation)", fillcolor="#8e44ad", fontcolor="white"]
    Autophagy [label="Autophagy\n(LC3/p62)", fillcolor="#8e44ad", fontcolor="white"]
    Protein_degradation [label="Contractile Protein\nDegradation", fillcolor="#7f8c8d", fontcolor="white"]
  }

  /* ========== CLUSTER 4: Inflammation & Immune Response ========== */
  subgraph cluster_inflammation {
    label="4. Inflammation & Immune Response"
    style=filled
    color="#4a7a2d"
    bgcolor="#1b2e0d"
    fontcolor="white"
    fontsize=12

    DAMPs [label="DAMPs Release\n(HMGB1, HSP70)", fillcolor="#e74c3c", fontcolor="white"]
    TLR4 [label="TLR4/TLR2\nSignaling", fillcolor="#c0392b", fontcolor="white"]
    NFkB [label="NF-κB (p65/p50)\nActivation", fillcolor="#c0392b", fontcolor="white"]
    TNF_alpha [label="TNF-α\n(↑↑ in DMD)", fillcolor="#c0392b", fontcolor="white"]
    IL1_beta [label="IL-1β\nPyroptosis driver", fillcolor="#c0392b", fontcolor="white"]
    IL6 [label="IL-6\nSystemic inflammation", fillcolor="#e74c3c", fontcolor="white"]
    IL4_IL13 [label="IL-4/IL-13\nM2 polarization", fillcolor="#27ae60", fontcolor="white"]
    IL10 [label="IL-10\nAnti-inflammatory", fillcolor="#27ae60", fontcolor="white"]
    IFN_gamma [label="IFN-γ\nM1 activation", fillcolor="#f39c12", fontcolor="white"]
    NLRP3 [label="NLRP3 Inflammasome\nActivation", fillcolor="#c0392b", fontcolor="white"]
    Neutrophils [label="Neutrophils\n(Early influx, CD11b+)", fillcolor="#f39c12", fontcolor="white"]
    M1_macro [label="M1 Macrophage\n(Pro-inflammatory)", fillcolor="#e74c3c", fontcolor="white"]
    M2_macro [label="M2 Macrophage\n(Anti-inflam/Pro-fibrotic)", fillcolor="#27ae60", fontcolor="white"]
    CD4_T [label="CD4+ T Cells\n(Helper, IFN-γ)", fillcolor="#3498db", fontcolor="white"]
    CD8_T [label="CD8+ T Cells\n(Cytotoxic)", fillcolor="#2980b9", fontcolor="white"]
    Treg [label="Regulatory T Cells\n(Tregs, IL-10)", fillcolor="#27ae60", fontcolor="white"]
    Complement_C3 [label="Complement C3/MAC\nActivation", fillcolor="#e67e22", fontcolor="white"]
    MCP1 [label="MCP-1/CCL2\nMacrophage recruit", fillcolor="#f39c12", fontcolor="white"]
    iNOS [label="iNOS\n(M1 → NO→ROS)", fillcolor="#e74c3c", fontcolor="white"]
  }

  /* ========== CLUSTER 5: Muscle Fiber Cycle & Regeneration ========== */
  subgraph cluster_regen {
    label="5. Muscle Fiber Cycle & Regeneration"
    style=filled
    color="#2d7a4a"
    bgcolor="#0d2e1b"
    fontcolor="white"
    fontsize=12

    Healthy_fiber [label="Healthy Muscle Fiber\n(Type I / IIa / IIx)", fillcolor="#2ecc71", fontcolor="white"]
    Necrotic_fiber [label="Necrotic Fiber\n(Karyorrhexis, ↑CK)", fillcolor="#e74c3c", fontcolor="white"]
    Regen_fiber [label="Regenerating Fiber\n(Central nuclei)", fillcolor="#f39c12", fontcolor="white"]
    SC_quiescent [label="Satellite Cells\n(Quiescent, Pax7+)", fillcolor="#3498db", fontcolor="white"]
    SC_activated [label="Satellite Cells\n(Activated, Pax7+/MyoD+)", fillcolor="#2980b9", fontcolor="white"]
    Myoblasts [label="Myoblasts\n(Proliferating)", fillcolor="#27ae60", fontcolor="white"]
    Myotubes [label="Myotubes\n(Differentiating, Myogenin+)", fillcolor="#2ecc71", fontcolor="white"]
    Pax7 [label="Pax7\n(SC identity marker)", fillcolor="#8e44ad", fontcolor="white"]
    MyoD [label="MyoD / Myf5\n(Activation TF)", fillcolor="#8e44ad", fontcolor="white"]
    Myogenin [label="Myogenin\n(Terminal differentiation)", fillcolor="#27ae60", fontcolor="white"]
    MRF4 [label="MRF4 / MHC\n(Maturation)", fillcolor="#2ecc71", fontcolor="white"]
    SC_exhaustion [label="Satellite Cell\nExhaustion (chronic DMD)", fillcolor="#e74c3c", fontcolor="white"]
    IGF1 [label="IGF-1 / IGF-2\n(Pro-hypertrophic)", fillcolor="#27ae60", fontcolor="white"]
    mTORC1 [label="mTORC1 / S6K\n(Protein synthesis)", fillcolor="#2ecc71", fontcolor="white"]
    FGF2 [label="FGF-2/6\n(SC proliferation)", fillcolor="#3498db", fontcolor="white"]
    HGF [label="HGF / c-Met\n(SC activation)", fillcolor="#27ae60", fontcolor="white"]
    Wnt_beta [label="Wnt/β-Catenin\n(SC differentiation)", fillcolor="#8e44ad", fontcolor="white"]
    Notch_Delta [label="Notch/Delta-1\n(SC self-renewal)", fillcolor="#9b59b6", fontcolor="white"]
    Myostatin [label="Myostatin (GDF-8)\n(Muscle growth inhibitor)", fillcolor="#e74c3c", fontcolor="white"]
    ActRIIB [label="ActRIIB Signaling\n(SMAD2/3 → atrophy)", fillcolor="#c0392b", fontcolor="white"]
  }

  /* ========== CLUSTER 6: Fibrosis & ECM Remodeling ========== */
  subgraph cluster_fibrosis {
    label="6. Fibrosis & Connective Tissue Remodeling"
    style=filled
    color="#4a4a7a"
    bgcolor="#1b1b2e"
    fontcolor="white"
    fontsize=12

    TGF_beta1 [label="TGF-β1\n(Master fibrotic driver)", fillcolor="#e74c3c", fontcolor="white"]
    SMAD2_3 [label="SMAD2/3\n(Phosphorylated)", fillcolor="#c0392b", fontcolor="white"]
    SMAD7 [label="SMAD7\n(Inhibitory SMAD)", fillcolor="#27ae60", fontcolor="white"]
    CTGF [label="CTGF/CCN2\nConnective tissue GF", fillcolor="#e67e22", fontcolor="white"]
    Myofibroblasts [label="Myofibroblasts\n(αSMA+, activated)", fillcolor="#e74c3c", fontcolor="white"]
    FAPs [label="Fibro-adipogenic\nProgenitors (FAPs)", fillcolor="#f39c12", fontcolor="white"]
    Collagen_I [label="Collagen I/III\nDeposition (ECM)", fillcolor="#e74c3c", fontcolor="white"]
    Collagen_IV [label="Collagen IV\n(BM thickening)", fillcolor="#c0392b", fontcolor="white"]
    MMP9 [label="MMP-9\n(Gelatinase B, ↑DMD)", fillcolor="#f39c12", fontcolor="white"]
    MMP1_3 [label="MMP-1/3\n(Collagenase)", fillcolor="#27ae60", fontcolor="white"]
    TIMP1 [label="TIMP-1/2\n(Anti-MMP)", fillcolor="#e74c3c", fontcolor="white"]
    PDGF_BB [label="PDGF-BB\nFibroblast mitogen", fillcolor="#f39c12", fontcolor="white"]
    Adipogenesis [label="Fat Infiltration\n(Adipogenesis)", fillcolor="#f39c12", fontcolor="white"]
    Fibrosis_score [label="Fibrosis Score\n(Histological %)", fillcolor="#e74c3c", fontcolor="white"]
    Endomysial_fib [label="Endomysial Fibrosis\n(% cross-sectional area)", fillcolor="#c0392b", fontcolor="white"]
    ECM_stiffness [label="ECM Stiffness\n(kPa, MRE)", fillcolor="#7f8c8d", fontcolor="white"]
  }

  /* ========== CLUSTER 7: Cardiac & Respiratory ========== */
  subgraph cluster_organs {
    label="7. Cardiac, Respiratory & Systemic Involvement"
    style=filled
    color="#7a2d7a"
    bgcolor="#2e0d2e"
    fontcolor="white"
    fontsize=12

    Cardiac_dyst_def [label="Cardiac Dystrophin\nDeficiency", fillcolor="#e74c3c", fontcolor="white"]
    DCM [label="Dilated Cardiomyopathy\n(DCM – ≥10yr onset)", fillcolor="#e74c3c", fontcolor="white"]
    LVEF [label="LVEF (%)\n(EF↓ <55% = DCM)", fillcolor="#c0392b", fontcolor="white"]
    LVIDd [label="LVIDd (mm)\n(LV dilation)", fillcolor="#c0392b", fontcolor="white"]
    Cardiac_fibrosis [label="Late Gadolinium\nEnhancement (LGE/CMR)", fillcolor="#c0392b", fontcolor="white"]
    BNP [label="NT-proBNP\n(Cardiac biomarker)", fillcolor="#f39c12", fontcolor="white"]
    RAAS [label="RAAS Activation\n(ACEi/ARB target)", fillcolor="#e67e22", fontcolor="white"]
    Cardiac_arrhythmia [label="Arrhythmia Risk\n(Sinus tach, Q-waves)", fillcolor="#e74c3c", fontcolor="white"]

    Resp_muscles [label="Respiratory Muscle\nWeakness (Diaphragm)", fillcolor="#e74c3c", fontcolor="white"]
    FVC_pct [label="FVC% Predicted\n(→ 30% threshold)", fillcolor="#c0392b", fontcolor="white"]
    FEV1_pct [label="FEV1% Predicted", fillcolor="#c0392b", fontcolor="white"]
    PCF [label="Peak Cough Flow\n(L/min, <270 → assist)", fillcolor="#e67e22", fontcolor="white"]
    NIV [label="NIV / Ventilator\nDependence", fillcolor="#e74c3c", fontcolor="white"]

    Bone_density [label="Bone Mineral Density\n(Z-score ↓, fracture risk)", fillcolor="#f39c12", fontcolor="white"]
    Scoliosis [label="Scoliosis\n(Cobb angle > 20°)", fillcolor="#e67e22", fontcolor="white"]
    Cognitive_fn [label="Cognitive Function\n(IQ ↓, ASD risk – Dp71↓)", fillcolor="#3498db", fontcolor="white"]
    GI_motility [label="GI Dysmotility\n(Smooth muscle)", fillcolor="#7f8c8d", fontcolor="white"]
  }

  /* ========== CLUSTER 8: Drug Pharmacokinetics ========== */
  subgraph cluster_pk {
    label="8. Drug Pharmacokinetics"
    style=filled
    color="#2d4a7a"
    bgcolor="#0d1b3e"
    fontcolor="white"
    fontsize=12

    Eteplirsen_dose [label="Eteplirsen\n30 mg/kg/wk IV\n(Ex51 skip – EXONDYS 51)", fillcolor="#9b59b6", fontcolor="white", shape=diamond]
    Ete_C1 [label="Eteplirsen\nCentral (Cp, µg/mL)", fillcolor="#8e44ad", fontcolor="white"]
    Ete_C2 [label="Eteplirsen\nPeripheral (Ct)", fillcolor="#7d3c98", fontcolor="white"]
    Ete_muscle [label="Eteplirsen\nMuscle (pmol/g)", fillcolor="#6c3483", fontcolor="white"]

    Casimersen_dose [label="Casimersen\n30 mg/kg/wk IV\n(Ex45 skip – AMONDYS 45)", fillcolor="#e74c3c", fontcolor="white", shape=diamond]
    Cas_C [label="Casimersen\nPlasma (µg/mL)", fillcolor="#c0392b", fontcolor="white"]
    Cas_muscle [label="Casimersen\nMuscle tissue", fillcolor="#a93226", fontcolor="white"]

    Golodirsen_dose [label="Golodirsen\n30 mg/kg/wk IV\n(Ex53 skip – VYONDYS 53)", fillcolor="#f39c12", fontcolor="white", shape=diamond]
    Gol_C [label="Golodirsen\nPlasma (µg/mL)", fillcolor="#e67e22", fontcolor="white"]

    DFZ_dose [label="Deflazacort\n0.9 mg/kg/day PO\n(EMFLAZA)", fillcolor="#27ae60", fontcolor="white", shape=diamond]
    DFZ_gut [label="Deflazacort\nGI (ka oral)", fillcolor="#2ecc71", fontcolor="white"]
    DFZ_plasma [label="Deflazacort\nPlasma → 21-DFZ", fillcolor="#d4ac0d", fontcolor="white"]
    Active_DFZ [label="21-desacetyl-DFZ\n(Active metabolite)", fillcolor="#d4ac0d", fontcolor="white"]

    Pred_dose [label="Prednisone\n0.75 mg/kg/day PO", fillcolor="#3498db", fontcolor="white", shape=diamond]
    Prednisolone [label="Prednisolone\n(Active, hepatic)", fillcolor="#2980b9", fontcolor="white"]

    Vamo_dose [label="Vamorolone\n6 mg/kg/day PO\n(AGAMREE)", fillcolor="#e67e22", fontcolor="white", shape=diamond]
    Vamo_plasma [label="Vamorolone\nPlasma (µg/mL)", fillcolor="#d4ac0d", fontcolor="white"]

    Elevidys_dose [label="Delandistrogene\nmoxeparvovec 1×10¹⁴vg/kg IV\n(Elevidys – GENE THERAPY)", fillcolor="#2ecc71", fontcolor="white", shape=diamond]
    AAV_vector [label="AAVrh74.MHCK7\nVector distribution", fillcolor="#27ae60", fontcolor="white"]
    Mini_dystrophin [label="Micro-dystrophin\n(Dp-micro, 138kDa)", fillcolor="#2ecc71", fontcolor="white"]

    Givinostat_dose [label="Givinostat\n10 mg/kg/day PO\n(HDAC inhibitor)", fillcolor="#9b59b6", fontcolor="white", shape=diamond]
    Givinostat_plasma [label="Givinostat\nPlasma (nM)", fillcolor="#8e44ad", fontcolor="white"]

    Ataluren_dose [label="Ataluren\n40 mg/kg/day PO\n(PTC124 – nonsense mut)", fillcolor="#f39c12", fontcolor="white", shape=diamond]
    Ataluren_plasma [label="Ataluren\nPlasma (µg/mL)", fillcolor="#e67e22", fontcolor="white"]
  }

  /* ========== CLUSTER 9: Drug Pharmacodynamics ========== */
  subgraph cluster_pd {
    label="9. Drug Pharmacodynamics & Mechanisms of Action"
    style=filled
    color="#4a7a2d"
    bgcolor="#1b3e0d"
    fontcolor="white"
    fontsize=12

    Exon_skip_eff [label="Exon-Skipping\nEfficiency (%)", fillcolor="#27ae60", fontcolor="white"]
    Dyst_restore [label="Dystrophin Restoration\n(% of Normal)", fillcolor="#2ecc71", fontcolor="white"]
    Dyst_threshold [label="Dystrophin Threshold\n(>3%~15% → functional)", fillcolor="#f39c12", fontcolor="white"]
    RT_PCR_skip [label="Exon-Skipped mRNA\n(RT-PCR %)", fillcolor="#27ae60", fontcolor="white"]

    GR_bind [label="Glucocorticoid\nReceptor (GR) Binding", fillcolor="#3498db", fontcolor="white"]
    GR_translocate [label="GR Nuclear\nTranslocation (GRα)", fillcolor="#2980b9", fontcolor="white"]
    GRE_activation [label="GRE Transactivation\n(Anti-inflammatory genes)", fillcolor="#27ae60", fontcolor="white"]
    nGRE_repression [label="nGRE Transrepression\n(↓AP-1/NF-κB)", fillcolor="#27ae60", fontcolor="white"]
    Steroid_SE [label="Steroid Side Effects\n(Bone, growth, BMI, glucose)", fillcolor="#e74c3c", fontcolor="white"]
    Vamo_dissociated [label="Vamorolone Dissociated\nGR (↓SE vs DFZ)", fillcolor="#27ae60", fontcolor="white"]

    HDAC_inhib [label="HDAC1/3 Inhibition\n(Histone acetylation)", fillcolor="#9b59b6", fontcolor="white"]
    Utrophin_up [label="Utrophin\nUpregulation", fillcolor="#27ae60", fontcolor="white"]
    Epigenetic_mod [label="Epigenetic Reprogramming\n(UTR-A promoter, H3K27ac)", fillcolor="#8e44ad", fontcolor="white"]
    Anti_fibrosis_GIV [label="Anti-fibrotic Effect\n(Givinostat → ↓FAP)", fillcolor="#27ae60", fontcolor="white"]

    Ataluren_PT [label="Ataluren Read-through\n(Ribosome PTC bypass)", fillcolor="#e67e22", fontcolor="white"]
    Near_full_dyst [label="Near Full-length\nDystrophin (PTC)", fillcolor="#f39c12", fontcolor="white"]

    Anti_Mstn [label="Anti-Myostatin\n(Apitegromab/SRK-015)", fillcolor="#9b59b6", fontcolor="white"]
    ActRIIB_block [label="ActRIIB Blockade\n(↓Smad2/3 atrophy)", fillcolor="#27ae60", fontcolor="white"]

    NF_inhibition [label="NF-κB Inhibition\n(GC-mediated)", fillcolor="#27ae60", fontcolor="white"]
    Membrane_stabilizer [label="Membrane Stabilization\n(CAP1/amphiphysin)", fillcolor="#27ae60", fontcolor="white"]
  }

  /* ========== CLUSTER 10: Clinical Endpoints & Biomarkers ========== */
  subgraph cluster_endpoints {
    label="10. Clinical Endpoints & Biomarkers"
    style=filled
    color="#7a7a2d"
    bgcolor="#2e2e0d"
    fontcolor="white"
    fontsize=12

    NSAA_score [label="NSAA Score\n(0–34, ambulatory)", fillcolor="#3498db", fontcolor="white"]
    SixMWD [label="6-Minute Walk\nDistance (6MWD, m)", fillcolor="#2980b9", fontcolor="white"]
    TenMWT [label="10-Meter Walk Test\n(10MWT, m/s)", fillcolor="#3498db", fontcolor="white"]
    TUG [label="Timed Up & Go\n(TUG, seconds)", fillcolor="#2980b9", fontcolor="white"]
    PUL2 [label="Performance Upper Limb\n(PUL 2.0, non-ambulatory)", fillcolor="#3498db", fontcolor="white"]

    Ambulatory_status [label="Ambulatory\nStatus (Walking)", fillcolor="#2ecc71", fontcolor="white"]
    Loss_ambulance [label="Loss of Ambulation\n(TLA, median ~12yr)", fillcolor="#e74c3c", fontcolor="white"]
    Wheelchair_dep [label="Wheelchair\nDependence", fillcolor="#e74c3c", fontcolor="white"]

    CK_serum [label="Serum CK\n(U/L, ↑↑↑ DMD → 10-100×)", fillcolor="#e67e22", fontcolor="white"]
    Dyst_IHC [label="Dystrophin IHC\n(% positive fibers)", fillcolor="#27ae60", fontcolor="white"]
    Muscle_MRI [label="Muscle MRI\n(T1 fat fraction, Dixon)", fillcolor="#f39c12", fontcolor="white"]

    Echo_LVEF_end [label="Echocardiography\nLVEF trajectory", fillcolor="#c0392b", fontcolor="white"]
    CMR_LGE [label="Cardiac MRI (CMR)\nLGE fibrosis (%)", fillcolor="#e74c3c", fontcolor="white"]

    PFT_FVC [label="Pulmonary Function\nTests (FVC, FEV1, MIP/MEP)", fillcolor="#3498db", fontcolor="white"]

    Steroid_monitor [label="Steroid Monitoring\n(Height-SDS, BMD, HbA1c)", fillcolor="#e67e22", fontcolor="white"]

    QoL_score [label="Quality of Life\n(PedsQL, INQoL, PODCI)", fillcolor="#27ae60", fontcolor="white"]

    Exacerbation [label="Respiratory\nExacerbation Rate", fillcolor="#e74c3c", fontcolor="white"]
    Mortality [label="Mortality\n(Median ~26yr unTx → >40yr tx)", fillcolor="#7f8c8d", fontcolor="white"]
  }

  /* ============================= EDGES ============================= */

  /* --- Genetics --- */
  DMD_gene -> Pre_mRNA [label="transcription", color="steelblue"]
  Deletion_mut -> DMD_gene [label="frameshift\n(reading frame)", color="#e74c3c"]
  Nonsense_mut -> DMD_gene [label="PTC", color="#c0392b"]
  Point_mut -> DMD_gene [label="splice/missense", color="#c0392b"]
  Pre_mRNA -> Dystrophin_mRNA [label="normal splicing", color="steelblue"]
  Pre_mRNA -> No_dystrophin [label="aberrant splicing/\nnonsense-mediated decay", color="#e74c3c"]
  Pre_mRNA -> Exon_target [label="ASO target site", color="#9b59b6"]
  Dystrophin_mRNA -> Dystrophin_full [label="translation", color="#2ecc71"]
  Reading_frame -> Truncated_dyst [label="restored frame\n→ BMD-like protein", color="#f39c12"]
  Deletion_mut -> PTC_codon [label="in-frame stop\n(~13%)", color="#c0392b"]
  DMD_gene -> Dp71 [label="alt. promoter\n(brain)", color="#9b59b6"]
  DMD_gene -> Dp116 [label="alt. promoter\n(Schwann)", color="#8e44ad"]

  /* --- DAPC Assembly/Disruption --- */
  Dystrophin_full -> DAPC_intact [label="anchor protein", color="#2ecc71"]
