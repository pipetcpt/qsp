digraph DMD_QSP {
    graph [
        label="Duchenne Muscular Dystrophy (DMD)\nQuantitative Systems Pharmacology Model\nDystrophin Deficiency · Membrane Pathology · Inflammation · Fibrosis · Drug PK/PD",
        fontsize=22
    fontname="Helvetica-Bold",
        bgcolor="#FAFAFA", rankdir=TB,
        nodesep=0.35, ranksep=0.55, splines=ortho,
        labelloc=t, pad=0.5
    ]
    node [fontname="Helvetica", fontsize=9, style=filled, shape=box, margin="0.1,0.05", penwidth=1.2]
    edge [fontsize=8, fontname="Helvetica", penwidth=1.0]

    /* =====================================================================
       CLUSTER 1: GENETIC BASIS
       ===================================================================== */
    subgraph cluster_genetic {
        label="1. Genetic Basis"
        bgcolor="#E8F4FD"
        color="#2980B9"
        fontsize=13
        fontcolor="#2980B9"
        style=filled

        DMD_gene        [label="DMD Gene\n(X-linked, Xp21.2\n2.4 Mb, largest human gene)", fillcolor="#AED6F1"]
        exon_structure  [label="79 Exons\n(Alternative Splicing\nIsoforms Dp427m/Dp260/Dp71)", fillcolor="#AED6F1"]
        deletion_mut    [label="Exon Deletion\n(~65% of cases)", fillcolor="#F1948A"]
        duplication_mut [label="Exon Duplication\n(~6-10% of cases)", fillcolor="#F1948A"]
        nonsense_mut    [label="Nonsense Mutation\n(~10-15% of cases)", fillcolor="#F1948A"]
        frameshift_mut  [label="Frameshift\nMutation", fillcolor="#E74C3C", fontcolor="white"]
        exon_hotspot    [label="Exon 45-55 Hotspot\n(>60% amenable to skip)", fillcolor="#FAD7A0"]
        reading_frame   [label="Reading Frame Rule\n(Out-of-frame → DMD\nIn-frame → BMD)", fillcolor="#AED6F1"]
        mRNA_truncated  [label="Unstable/Truncated\nDMD mRNA (NMD)", fillcolor="#F1948A"]
        dystrophin_abs  [label="Dystrophin Protein\nAbsent (<0.1% normal)", fillcolor="#E74C3C", fontcolor="white"]
        BMD_protein     [label="Becker MD\nTruncated Dystrophin\n(In-frame, partial function)", fillcolor="#FAD7A0"]
        mosaic_carrier  [label="Carrier/Mosaic\n(~10% girls affected)", fillcolor="#D7BDE2"]
        utrophin_gene   [label="UTRN Gene\n(Utrophin, Chr 6)", fillcolor="#A9DFBF"]
        utrophin_prot   [label="Utrophin Protein\n(395 kDa, NMJ expression)", fillcolor="#82E0AA"]
        Dp71_isoform    [label="Dp71 Isoform\n(Brain/heart dystrophin)", fillcolor="#D7BDE2"]
    }

    /* =====================================================================
       CLUSTER 2: DYSTROPHIN-ASSOCIATED PROTEIN COMPLEX (DAPC)
       ===================================================================== */
    subgraph cluster_dapc {
        label="2. Dystrophin-Associated Protein Complex (DAPC)"
        bgcolor="#EBF5FB"
        color="#1A5276"
        fontsize=13
        fontcolor="#1A5276"
        style=filled

        DAPC            [label="DAPC Complex\n(Sarcolemmal Stabilizer)", fillcolor="#AED6F1"]
        alpha_DG        [label="α-Dystroglycan\n(Extracellular, ECM binding)", fillcolor="#AED6F1"]
        beta_DG         [label="β-Dystroglycan\n(Transmembrane)", fillcolor="#AED6F1"]
        alpha_SG        [label="α-Sarcoglycan (50kDa)", fillcolor="#A9DFBF"]
        beta_SG         [label="β-Sarcoglycan (43kDa)", fillcolor="#A9DFBF"]
        gamma_SG        [label="γ-Sarcoglycan (35kDa)", fillcolor="#A9DFBF"]
        delta_SG        [label="δ-Sarcoglycan (35kDa)", fillcolor="#A9DFBF"]
        syntrophin_a1   [label="α1-Syntrophin\n(nNOS scaffold)", fillcolor="#D7BDE2"]
        syntrophin_b    [label="β1/β2-Syntrophin\n(Signaling adaptor)", fillcolor="#D7BDE2"]
        dystrobrevin    [label="α-Dystrobrevin\n(Signal transduction)", fillcolor="#D7BDE2"]
        nNOS            [label="nNOS (Neuronal NOS)\nnNOS→NO→Vasodilation", fillcolor="#F9E79F"]
        NO_prod         [label="Nitric Oxide (NO)\nVascular regulation", fillcolor="#F9E79F"]
        laminin211      [label="Laminin-211 (Merosin)\nECM anchor glycoprotein", fillcolor="#FAD7A0"]
        integrin_a7b1   [label="α7β1-Integrin\n(Parallel stabilizer)", fillcolor="#FAD7A0"]
        actin_F         [label="F-Actin Cytoskeleton\n(N-terminal anchoring)", fillcolor="#AED6F1"]
        sarcolemma      [label="Sarcolemma\n(Plasma membrane)", fillcolor="#AED6F1"]
        spectrin        [label="Spectrin/Ankyrin\nSubmembrane scaffold", fillcolor="#D7BDE2"]
    }

    /* =====================================================================
       CLUSTER 3: MEMBRANE PATHOLOGY & CALCIUM DYSREGULATION
       ===================================================================== */
    subgraph cluster_membrane {
        label="3. Membrane Pathology & Calcium Dysregulation"
        bgcolor="#FEF9E7"
        color="#B7950B"
        fontsize=13
        fontcolor="#B7950B"
        style=filled

        membrane_fragil [label="↑ Sarcolemmal Fragility\n(No dystrophin anchor)", fillcolor="#F1948A"]
        eccentric_cont  [label="Eccentric Contraction\nInjury (downhill walk)", fillcolor="#FAD7A0"]
        membrane_tears  [label="Sarcolemmal Microtears\nMicro-ruptures", fillcolor="#E74C3C", fontcolor="white"]
        TRPC_ch         [label="TRPC1/4/6 Channels\n(Stretch-Activated SAC)", fillcolor="#F9E79F"]
        TRPV2_ch        [label="TRPV2\n(Mechano-sensitive)", fillcolor="#F9E79F"]
        Ca_influx       [label="↑ Cytosolic Ca²⁺\n[Ca²⁺]i overload", fillcolor="#E74C3C", fontcolor="white"]
        SERCA_inhibit   [label="SERCA Pump Inhibition\n(↓ SR Ca²⁺ re-uptake)", fillcolor="#FAD7A0"]
        RyR_leak        [label="RyR1/RyR2 Leakage\n(Ca²⁺-induced Ca²⁺ release)", fillcolor="#FAD7A0"]
        mitoch_Ca_ol    [label="Mitochondrial\nCa²⁺ Overload", fillcolor="#F1948A"]
        calpain_act     [label="μ/m-Calpain\nActivation (↑ 10-fold)", fillcolor="#E74C3C", fontcolor="white"]
        calpastatin     [label="Calpastatin\n(Endogenous inhibitor ↓)", fillcolor="#A9DFBF"]
        cytoskel_dmg    [label="Cytoskeletal Protein\nCleavage (Desmin/Titin/Vinculin)", fillcolor="#F1948A"]
        PLA2_act        [label="Phospholipase A2\nActivation (↑ arachidonate)", fillcolor="#FAD7A0"]
        reduced_NO_sarco [label="↓ Sarcolemmal nNOS→NO\n(Displaced from DAPC)", fillcolor="#F9E79F"]
        micro_ischemia  [label="Exercise-induced\nMicrovascular Ischemia", fillcolor="#F1948A"]
        HDAC2_memb      [label="HDAC2 Activation\n(Epigenetic repressor)", fillcolor="#D7BDE2"]
        dysferlin_loss  [label="↓ Membrane Repair\n(Dysferlin pathway impaired)", fillcolor="#FAD7A0"]
    }

    /* =====================================================================
       CLUSTER 4: OXIDATIVE STRESS & CELLULAR DAMAGE
       ===================================================================== */
    subgraph cluster_damage {
        label="4. Oxidative Stress & Cellular Damage Cascade"
        bgcolor="#FDEDEC"
        color="#922B21"
        fontsize=13
        fontcolor="#922B21"
        style=filled

        ROS_gen         [label="↑ ROS Generation\n(Superoxide, H₂O₂, ·OH)", fillcolor="#E74C3C", fontcolor="white"]
        mitoch_dysfx    [label="Mitochondrial\nDysfunction", fillcolor="#F1948A"]
        ETC_impair      [label="ETC Complex I/III\nImpairment", fillcolor="#FAD7A0"]
        oxidized_lipid  [label="Lipid Peroxidation\n4-HNE, MDA ↑", fillcolor="#FAD7A0"]
        protein_oxid    [label="Protein Carbonylation\n(Oxidized proteins ↑)", fillcolor="#FAD7A0"]
        myofiber_necro  [label="Myofiber Necrosis\n(Irreversible cell death)", fillcolor="#E74C3C", fontcolor="white"]
        myofiber_apo    [label="Myofiber Apoptosis\n(Caspase-mediated)", fillcolor="#E74C3C", fontcolor="white"]
        Bcl2_Bax        [label="Bcl-2↓ / Bax↑\n(Pro-apoptotic balance)", fillcolor="#D7BDE2"]
        caspase_9_3     [label="Caspase 9 → 3/7\nActivation cascade", fillcolor="#F1948A"]
        CK_release      [label="↑↑ Creatine Kinase (CK-MM)\nSerum CK ×50-100 ULN", fillcolor="#E74C3C", fontcolor="white"]
        myoglobin_rel   [label="Myoglobin Release\n(Myoglobinuria risk)", fillcolor="#FAD7A0"]
        DAMP_rel        [label="DAMP Release\nHMGB1, ATP, Uric acid, mtDNA", fillcolor="#F1948A"]
        MMP_2_9         [label="MMP-2/MMP-9\nRelease (ECM degradation)", fillcolor="#FAD7A0"]
        Nrf2_path       [label="Nrf2/ARE Pathway\n(Endogenous antioxidant)", fillcolor="#A9DFBF"]
        HO1_NQO1        [label="HO-1, NQO1, GCL\nAntioxidant enzymes ↑", fillcolor="#A9DFBF"]
        GSH_deplete     [label="↓ GSH\nGlutathione Depletion", fillcolor="#FAD7A0"]
        xanthine_ox     [label="↑ Xanthine Oxidase\n(Superoxide source)", fillcolor="#FAD7A0"]
    }

    /* =====================================================================
       CLUSTER 5: INFLAMMATORY RESPONSE
       ===================================================================== */
    subgraph cluster_inflam {
        label="5. Inflammatory Response"
        bgcolor="#F4ECF7"
        color="#7D3C98"
        fontsize=13
        fontcolor="#7D3C98"
        style=filled

        TLR4_MyD88      [label="TLR4/TLR2/MyD88\nPattern recognition", fillcolor="#D7BDE2"]
        NLRP3_inf       [label="NLRP3 Inflammasome\n(IL-1β processing)", fillcolor="#D7BDE2"]
        NFkB_act        [label="NF-κB\n(Master inflammatory TF)", fillcolor="#9B59B6", fontcolor="white"]
        AP1_MAPK        [label="AP-1/MAPK\n(JNK, p38, ERK1/2)", fillcolor="#D7BDE2"]
        TNFa            [label="TNF-α\n(Pleiotropic cytokine ↑)", fillcolor="#D7BDE2"]
        IL1b            [label="IL-1β ↑\n(Inflammasome product)", fillcolor="#D7BDE2"]
        IL6_inf         [label="IL-6 ↑\n(Acute-phase inducer)", fillcolor="#D7BDE2"]
        IL17A           [label="IL-17A ↑\n(Neutrophil activator)", fillcolor="#D7BDE2"]
        IFNg            [label="IFN-γ ↑\n(M1 polarizer)", fillcolor="#D7BDE2"]
        neutrophil      [label="Neutrophil Infiltration\n(Early, hours 1-3)", fillcolor="#FAD7A0"]
        M1_macro        [label="M1 Macrophages\n(Pro-inflammatory CD68+)", fillcolor="#E74C3C", fontcolor="white"]
        M2_macro        [label="M2 Macrophages\n(Anti-inflam/regen CD163+)", fillcolor="#82E0AA"]
        M1_M2_bal       [label="M1/M2 Balance\n(DMD: chronically M1-biased)", fillcolor="#FAD7A0"]
        CD8_T           [label="CD8+ Cytotoxic T cells\n(Perforin/Granzyme)", fillcolor="#D7BDE2"]
        CD4_Treg        [label="CD4+/Foxp3+ Tregs\n(Suppressive, depleted in DMD)", fillcolor="#A9DFBF"]
        MCP1_CCL2       [label="MCP-1/CCL2\n(Macrophage recruitment)", fillcolor="#D7BDE2"]
        CXCL10          [label="CXCL10/IP-10\n(T-cell chemotaxis)", fillcolor="#D7BDE2"]
        C3_C5           [label="Complement C3/C5\n(Membrane attack)", fillcolor="#FAD7A0"]
        PGE2_TXA2       [label="PGE₂/TXA₂\n(Prostaglandins, COX-2)", fillcolor="#D7BDE2"]
        GR_recep        [label="Glucocorticoid Receptor\n(GR-α, cytoplasmic)", fillcolor="#82E0AA"]
        STAT3_path      [label="STAT3 Pathway\n(IL-6-mediated)", fillcolor="#D7BDE2"]
        mast_cell       [label="Mast Cell\nDegranulation (↑ histamine)", fillcolor="#FAD7A0"]
    }

    /* =====================================================================
       CLUSTER 6: FIBROSIS & ECM REMODELING
       ===================================================================== */
    subgraph cluster_fibrosis {
        label="6. Fibrosis & ECM Remodeling"
        bgcolor="#FEF5E7"
        color="#A04000"
        fontsize=13
        fontcolor="#A04000"
        style=filled

        TGFb1           [label="TGF-β1\n(Master fibrogenic cytokine ↑)", fillcolor="#E59866", fontcolor="#5D4037"]
        pSmad2_3        [label="pSmad2/3\n(Canonical TGF-β signaling)", fillcolor="#F0B27A"]
        Smad7_inhib     [label="Smad7\n(Negative feedback regulator)", fillcolor="#A9DFBF"]
        CTGF_CCN2       [label="CTGF/CCN2\n(Fibrosis amplifier)", fillcolor="#E59866"]
        myofibroblast   [label="Myofibroblast\nActivation (α-SMA+)", fillcolor="#E74C3C", fontcolor="white"]
        ColI_III        [label="Collagen I/III Synthesis\n(Endomysial accumulation)", fillcolor="#F0B27A"]
        ColIV           [label="Collagen IV\n(Basement membrane thickening)", fillcolor="#F0B27A"]
        fibronectin     [label="Fibronectin\nDeposition ↑", fillcolor="#FAD7A0"]
        TIMP1_inhib     [label="TIMP-1 ↑\n(MMP-9 inhibitor)", fillcolor="#FAD7A0"]
        MMP_TIMP_ratio  [label="MMP/TIMP\nImbalance → net fibrosis", fillcolor="#FAD7A0"]
        ECM_stiff       [label="↑ ECM Stiffness\n(Mechanosensing feedback)", fillcolor="#E59866"]
        fibrosis_score  [label="Endomysial/Perimysial\nFibrosis Score ↑", fillcolor="#E74C3C", fontcolor="white"]
        FAP_cells       [label="Fibro-Adipogenic\nProgenitors (FAPs)", fillcolor="#F0B27A"]
        fat_infiltr     [label="Intramuscular Fat\nInfiltration", fillcolor="#FAD7A0"]
        pericyte_trans  [label="Pericyte→Myofibroblast\nTransition", fillcolor="#F0B27A"]
        Wnt_bcatenin    [label="Wnt/β-catenin\nSignaling ↑", fillcolor="#D7BDE2"]
        PDGFR_b         [label="PDGF/PDGFR-β\n(FAP activation)", fillcolor="#FAD7A0"]
        YAP_TAZ         [label="YAP/TAZ\nMechano-transducers", fillcolor="#D7BDE2"]
        senescent_FAP   [label="Senescent FAPs\n(SASP, p16+)", fillcolor="#FAD7A0"]
    }

    /* =====================================================================
       CLUSTER 7: MUSCLE REGENERATION & SATELLITE CELLS
       ===================================================================== */
    subgraph cluster_regen {
        label="7. Muscle Regeneration & Satellite Cells"
        bgcolor="#EAFAF1"
        color="#1E8449"
        fontsize=13
        fontcolor="#1E8449"
        style=filled

        SC_pool         [label="Muscle Satellite Cells\n(MuSC, Pax7+/Myf5-, ~3/100 fiber)", fillcolor="#82E0AA"]
        SC_quiesc       [label="SC Quiescence\n(Pax7+/MyoD-)", fillcolor="#A9DFBF"]
        SC_activ        [label="SC Activation\n(Pax7+/MyoD+)", fillcolor="#82E0AA"]
        SC_prolif       [label="SC Proliferation\n(Amplification)", fillcolor="#82E0AA"]
        myoblast        [label="Myoblast\n(Pax7-/MyoD+/Myf5+)", fillcolor="#82E0AA"]
        myogenin_expr   [label="Myogenin Expression\n(Terminal differentiation)", fillcolor="#82E0AA"]
        myotube_form    [label="Myotube Formation\n(Myoblast fusion, embryonic MHC)", fillcolor="#82E0AA"]
        new_myofiber    [label="New Myofiber\n(Central nuclei marker)", fillcolor="#A9DFBF"]
        SC_exhaustion   [label="SC Pool Exhaustion\n(Chronic demand → depletion)", fillcolor="#E74C3C", fontcolor="white"]
        telomere_short  [label="Telomere Shortening\n(Accelerated in DMD SC)", fillcolor="#FAD7A0"]
        p21_p53_sen     [label="p21/p53/p16\nReplicative Senescence", fillcolor="#FAD7A0"]
        IGF1_muscle     [label="IGF-1 (muscle)\n(Hypertrophy + SC activation)", fillcolor="#A9DFBF"]
        HGF_SC          [label="HGF\n(Primary SC activator)", fillcolor="#A9DFBF"]
        FGF2_SC         [label="FGF-2\n(SC mitogen)", fillcolor="#A9DFBF"]
        follistatin_m   [label="Follistatin\n(Myostatin antagonist ↑)", fillcolor="#A9DFBF"]
        myostatin_m     [label="Myostatin/GDF-8\n(↑ in DMD → inhibits SC)", fillcolor="#F1948A"]
        activin_A_m     [label="Activin A\n(ActRIIB ligand, regeneration ↓)", fillcolor="#F1948A"]
        utrophin_upreg  [label="Utrophin Upregulation\n(NMJ compensatory expression)", fillcolor="#82E0AA"]
        PGF_angiogen    [label="Placental Growth Factor\n(Angiogenesis, MuSC niche)", fillcolor="#A9DFBF"]
        VEGF_niche      [label="VEGF-A\n(Vascular niche repair)", fillcolor="#A9DFBF"]
    }

    /* =====================================================================
       CLUSTER 8: CORTICOSTEROID DRUGS (PK/PD)
       ===================================================================== */
    subgraph cluster_steroids {
        label="8. Drug PK/PD: Corticosteroids"
        bgcolor="#EBF5FB"
        color="#1A5276"
        fontsize=13
        fontcolor="#1A5276"
        style=filled

        deflazacort_drug [label="Deflazacort\n(Emflaza® 0.9 mg/kg/d)\n[FDA 2017, oxazoline steroid]", fillcolor="#2980B9", fontcolor="white", shape=diamond]
        prednisone_drug  [label="Prednisone\n(0.75 mg/kg/d)\n[Historical standard]", fillcolor="#2980B9", fontcolor="white", shape=diamond]
        vamorolone_drug  [label="Vamorolone (VBP15)\n(6 mg/kg/d)\n[FDA 2023, dissociative]", fillcolor="#5DADE2", fontcolor="white", shape=diamond]
        ster_depot       [label="GI Absorption Depot\n(ka = 1.2 h⁻¹, F~70%)", fillcolor="#AED6F1"]
        ster_plasma      [label="Steroid Plasma\n(Cmax ~50-200 ng/mL\nVd ~0.9-1.5 L/kg)", fillcolor="#AED6F1"]
        ster_periph      [label="Steroid Peripheral\n(Muscle/tissue distribution)", fillcolor="#AED6F1"]
        GR_binding       [label="GR Ligand Binding\n(Kd ~5-20 nM)", fillcolor="#A9DFBF"]
        GR_translocate   [label="GR Nuclear Translocation\n(HSP90 release → nucleus)", fillcolor="#A9DFBF"]
        GRE_complex      [label="GR-GRE Complex\n(Transactivation)", fillcolor="#A9DFBF"]
        anti_inflam_genes [label="Anti-inflammatory Gene\nInduction (GILZ, DUSP1, IκBα)", fillcolor="#A9DFBF"]
        NFkB_squelch     [label="NF-κB p65\nSqelching (Transrepression)", fillcolor="#A9DFBF"]
        mem_stabilize_s  [label="Membrane Stabilization\n(Annexin A1 ↑)", fillcolor="#A9DFBF"]
        ster_se          [label="Steroid Side Effects\n(Bone/weight/growth/glucose)", fillcolor="#F1948A"]
        gio_pathway      [label="GIO (Osteoblast apoptosis\nOsteoclast ↑, RANK-L ↑)", fillcolor="#FAD7A0"]
        cushingoid_s     [label="Cushingoid Features\n(↑ Adipogenesis, ↑ CRH-ACTH)", fillcolor="#FAD7A0"]
        glucose_se       [label="↑ Gluconeogenesis\nGlucose Intolerance", fillcolor="#FAD7A0"]
    }

    /* =====================================================================
       CLUSTER 9: EXON-SKIPPING & GENE THERAPY PK/PD
       ===================================================================== */
    subgraph cluster_exon_gene {
        label="9. Drug PK/PD: Exon Skipping & Gene Therapy"
        bgcolor="#E8F8F5"
        color="#0E6655"
        fontsize=13
        fontcolor="#0E6655"
        style=filled

        eteplirsen      [label="Eteplirsen (Exondys 51®)\n30 mg/kg/wk IV\n[FDA 2016, Exon 51, ~13% pts]", fillcolor="#1ABC9C", fontcolor="white", shape=diamond]
        golodirsen      [label="Golodirsen (Vyondys 53®)\n30 mg/kg/wk IV\n[FDA 2019, Exon 53, ~8% pts]", fillcolor="#1ABC9C", fontcolor="white", shape=diamond]
        viltolarsen     [label="Viltolarsen (Viltepso®)\n80 mg/kg/wk IV\n[FDA 2020, Exon 53]", fillcolor="#1ABC9C", fontcolor="white", shape=diamond]
        casimersen      [label="Casimersen (Amondys 45®)\n30 mg/kg/wk IV\n[FDA 2021, Exon 45, ~8% pts]", fillcolor="#1ABC9C", fontcolor="white", shape=diamond]
        ASO_plasma      [label="ASO Plasma PK\n(2-cmpt, CL ~200 mL/h/kg\nt½ ~28h, Vss ~300 mL/kg)", fillcolor="#A9DFBF"]
        ASO_muscle      [label="ASO Muscle Depot\n(Slow uptake, long retention\n~20-50 nM intracellular)", fillcolor="#A9DFBF"]
        splicing_mod    [label="Pre-mRNA Splicing\nModulation (exon exclusion)", fillcolor="#A9DFBF"]
        exon_skip_pct   [label="Exon Skipping Efficiency\n(5-30% of transcripts)", fillcolor="#82E0AA"]
        trunc_dys_prod  [label="Truncated Dystrophin\nProduction (Becker-like)", fillcolor="#82E0AA"]
        dys_pct_normal  [label="Dystrophin Level\n(% of Normal, target >1-4%)", fillcolor="#82E0AA"]

        elevidys_drug   [label="Delandistrogene Moxeparvovec\n(SRP-9001, Elevidys®)\nSingle IV 1.33×10¹⁴ vg/kg\n[FDA 2023, AAVrh74, 4-5yr]", fillcolor="#16A085", fontcolor="white", shape=diamond]
        AAVrh74_vect    [label="AAVrh74.MHCK7\nMicro-dystrophin Vector\n(4.4 kb micro-dys)", fillcolor="#A9DFBF"]
        vector_distribut [label="Vector Distribution\n(IV → muscle tropism\n~4-8 wk to peak)", fillcolor="#A9DFBF"]
        micro_dys_expr  [label="Micro-dystrophin\nExpression (~20-30% normal)", fillcolor="#82E0AA"]
        AAV_immune_resp [label="Anti-AAVrh74 NAb\n(Pre-existing or induced\n→ limits re-dosing)", fillcolor="#F1948A"]
        CD8_AAV         [label="CD8+ T-cell Response\nto AAV Capsid", fillcolor="#FAD7A0"]

        ataluren_drug   [label="Ataluren (Translarna®)\n40 mg/kg/d oral\n[EMA approved, ~10% pts\nnonsense mutations]", fillcolor="#27AE60", fontcolor="white", shape=diamond]
        PTC_read        [label="Stop Codon Read-through\n(Near-cognate tRNA insertion)", fillcolor="#A9DFBF"]
        full_dys_prod   [label="Full-length Dystrophin\nProduction (low level)", fillcolor="#82E0AA"]
    }

    /* =====================================================================
       CLUSTER 10: NOVEL & EMERGING THERAPIES
       ===================================================================== */
    subgraph cluster_novel {
        label="10. Emerging & Novel Therapeutic Approaches"
        bgcolor="#FDF2F8"
        color="#76448A"
        fontsize=13
        fontcolor="#76448A"
        style=filled

        givinostat_drug [label="Givinostat (Duvyzat®)\n2×5 mg/kg/d oral\n[FDA 2024, HDAC inhibitor]", fillcolor="#9B59B6", fontcolor="white", shape=diamond]
        HDAC_inhib_eff  [label="Pan-HDAC Inhibition\n(Class I+II, ICe50~10nM)", fillcolor="#D7BDE2"]
        epigenetic_regen [label="Epigenetic Reprogramming\n(H3/H4 acetylation ↑)", fillcolor="#D7BDE2"]
        FAP_to_myogenic [label="FAP → Myogenic\nRedirection", fillcolor="#A9DFBF"]

        pamrevlumab_d   [label="Pamrevlumab\n(Anti-CTGF mAb, FG-3019)\n[Phase III, Ambulatory]", fillcolor="#9B59B6", fontcolor="white", shape=diamond]

        ezutromid_d     [label="Ezutromid / SMT C1100\n(Utrophin inducer)\n[Phase II ongoing]", fillcolor="#9B59B6", fontcolor="white", shape=diamond]
        utrn_promoter   [label="Utrophin Promoter\nHerp2/ezrin Activation", fillcolor="#D7BDE2"]

        losartan_d      [label="Losartan (AT1R blocker)\nTGF-β pathway reduction\n[Adjunct therapy]", fillcolor="#9B59B6", fontcolor="white", shape=diamond]

        myostatin_inh   [label="Anti-Myostatin\n(Apitegromab/SRK-015\nACE-083)\n[Phase II]", fillcolor="#D7BDE2", shape=diamond]

        CRISPR_exon     [label="CRISPR/Cas9\nExon Excision\n(SRP-9003, Investigational)", fillcolor="#D7BDE2"]
        base_edit_dmd   [label="ABE/CBE Base Editing\nNonsense Correction\n(Investigational)", fillcolor="#D7BDE2"]
        prime_edit      [label="Prime Editing\nFrameshift Correction\n(Investigational)", fillcolor="#D7BDE2"]

        cell_therapy    [label="iPSC-derived Myoblasts\n/ CAR-Treg Therapy\n(Investigational)", fillcolor="#D7BDE2"]

        idebenone_d     [label="Idebenone (Raxone®)\n(Mitochondria-targeted\nantioxidant, respiratory)", fillcolor="#9B59B6", fontcolor="white", shape=diamond]

        follistatin_gt  [label="Follistatin (FST344)\nIntramuscular Gene Therapy\n(Phase I/II)", fillcolor="#D7BDE2", shape=diamond]
    }

    /* =====================================================================
       CLUSTER 11: CLINICAL ENDPOINTS & DISEASE PROGRESSION
       ===================================================================== */
    subgraph cluster_endpoints {
        label="11. Clinical Endpoints & Disease Progression"
