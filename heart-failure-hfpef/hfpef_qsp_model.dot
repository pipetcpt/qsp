  ICAM1         -> Monocytes [label="adhesion" color="#c94040"]
  NFkB          -> VCAM1     [color="#2e5941"]
  NFkB          -> ICAM1     [color="#2e5941"]
  NFkB          -> ET1       [color="#2e5941"]
  NO_bioavail   -> FMD       [color="#2e5941"]
  Microvascular -> CFR       [label="↓ CFR" color="#2e5941" arrowhead=tee]
