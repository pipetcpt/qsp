  PAP           -> RVP       [color="#2c5f8a"]
  CVP           -> Edema     [label="Venous hypertension" color="#1a3a5c"]

  // --- Cardiorenal ---
  CO            -> RBF       [label="↑ CO → ↑ RBF" color="#3d6b4f"]
  RAAS_effect   -> Na_reabs  [color="#3d6b4f"]
