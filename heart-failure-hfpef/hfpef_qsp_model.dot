  PAP           -> RVP       [label="RV overload" color="#2c5f8a"]
  CO            -> MAP       [label="CO × SVR" color="#2c5f8a"]
  SVR           -> MAP       [color="#2c5f8a"]
  SV            -> CO        [label="CO = SV × HR" color="#2c5f8a"]
