  SNS_effect    -> HR        [label="↑ HR" color="#2c5f8a"]
  SNS_effect    -> Renin     [label="β1 stim" color="#1a6b4a"]

  // --- Neprilysin & Natriuretic ---
  Neprilysin    -> ANP       [label="Degrades" color="#5e3579" style=dashed arrowhead=tee]
  Neprilysin    -> BNP       [label="Degrades" color="#5e3579" style=dashed arrowhead=tee]
  Neprilysin    -> CNP       [label="Degrades" color="#5e3579" style=dashed arrowhead=tee]
  ANP           -> NPR_A     [label="binds" color="#5e3579"]
  BNP           -> NPR_A     [label="binds" color="#5e3579"]
  CNP           -> NPR_B     [label="binds" color="#5e3579"]
  NPR_A         -> cGMP      [label="↑ GC-A" color="#5e3579"]
  NPR_B         -> cGMP      [label="↑ GC-B" color="#5e3579"]
