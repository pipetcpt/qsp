  LV_Fibrosis   -> E_ratio   [label="↑ stiffness → E/e'" color="#2c5f8a"]
  Collagen_ratio -> E_ratio   [color="#2c5f8a"]

  // --- Hemodynamics ---
  LVEDP         -> LAP       [label="↑ backpressure" color="#2c5f8a"]
  LAP           -> PCWP      [color="#2c5f8a"]
