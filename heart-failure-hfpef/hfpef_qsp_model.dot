  PKG           -> SERCA2a_reg [label="via PLB" color="#5e3579"]
  Oxidative_PKG -> PKG       [label="↓ Activity" color="#c94040" style=dashed arrowhead=tee]
  BNP_synthesis -> BNP       [color="#5e3579"]
  BNP_synthesis -> ANP       [color="#5e3579"]

  // --- Cardiac structural connections ---
  LV_Hypertrophy -> LV_Mass  [color="#7a5c1e"]
  LV_Hypertrophy -> LV_Wall_Thick [color="#7a5c1e"]
