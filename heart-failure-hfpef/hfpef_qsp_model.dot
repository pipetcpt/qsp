  NEP_inhib     -> BNP         [label="↑ BNP levels" color="#5e3579"]
  NEP_inhib     -> CNP         [label="↑ CNP levels" color="#5e3579"]
  AT1R_block    -> RAAS_effect [label="↓ AngII effect" arrowhead=tee color="#1a6b4a"]
  AT1R_block    -> LV_Fibrosis [label="↓ fibrosis" arrowhead=tee color="#7a5c1e"]

  // MRA effects
