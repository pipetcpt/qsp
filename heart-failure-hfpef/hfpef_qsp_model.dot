  CKD           -> GFR       [label="↓" color="#3d6b4f" arrowhead=tee]
  RVSP          -> RBF       [label="↓ (congestion)" color="#3d6b4f" arrowhead=tee]
  CVP           -> RVSP      [color="#3d6b4f"]

  // --- Metabolic ---
  Obesity       -> Epicardial_Fat [color="#7a4a1e"]
