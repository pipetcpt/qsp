  // Legend
  subgraph cluster_legend {
    label="Legend"
    fontsize=12
    style="filled,rounded"
    fillcolor="#f0f0f0"
    color="#888888"

    node [shape=plaintext fontsize=9]
    L1 [label="→  Activates / Increases"]
    L2 [label="--⊣  Inhibits / Decreases (dashed+tee)"]
