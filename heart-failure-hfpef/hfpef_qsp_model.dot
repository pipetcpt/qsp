digraph HFpEF_QSP {
  // ============================================================
  //  Heart Failure with Preserved Ejection Fraction (HFpEF)
  //  Comprehensive QSP Mechanistic Map
  //  Nodes ≥ 100 | Clusters ≥ 8
  //  Date: 2026-06-17
  // ============================================================

  graph [
    label="Heart Failure with Preserved Ejection Fraction (HFpEF)\nQuantitative Systems Pharmacology Model"
    labelloc="t"
    fontname="Helvetica"
    fontsize=22
    fontcolor="#1a1a2e"
    bgcolor="#f8f9fa"
    rankdir=TB
    splines=true
    nodesep=0.4
    ranksep=0.7
    pad=0.5
  ]

  node [fontname="Helvetica" fontsize=10 style="filled,rounded" shape=box]
  edge [fontname="Helvetica" fontsize=8 arrowsize=0.7]

  // ============================================================
  // CLUSTER 0: Patient Comorbidities & Risk Factors
  // ============================================================
  subgraph cluster_comorbidities {
    label="Comorbidities & Risk Factors"
    fontsize=14 fontcolor="#ffffff"
    style="filled,rounded"
    fillcolor="#2d3561"
    color="#2d3561"

    node [fillcolor="#a8dadc" color="#457b9d" fontcolor="#1a1a2e"]

    Obesity       [label="Obesity\n(BMI > 30)"]
    HTN           [label="Hypertension"]
    T2DM          [label="Type 2 Diabetes\n(T2DM)"]
    AF            [label="Atrial Fibrillation"]
    CKD           [label="Chronic Kidney\nDisease (CKD)"]
    OSA           [label="Obstructive Sleep\nApnea (OSA)"]
    Age           [label="Advanced Age\n(> 65 yr)"]
    Female_Sex    [label="Female Sex"]
    Dyslipidemia  [label="Dyslipidemia"]
    CAD           [label="Coronary Artery\nDisease (CAD)"]
    Sedentary     [label="Sedentary Lifestyle\n/ Deconditioning"]
    Anemia        [label="Anemia\n(Iron Deficiency)"]
  }

  // ============================================================
  // CLUSTER 1: Systemic Inflammation & Oxidative Stress
  // ============================================================
  subgraph cluster_inflammation {
    label="Systemic Inflammation & Oxidative Stress"
    fontsize=14 fontcolor="#ffffff"
    style="filled,rounded"
    fillcolor="#c94040"
    color="#c94040"

    node [fillcolor="#ffd6d6" color="#c94040" fontcolor="#1a1a2e"]

    NFkB          [label="NF-κB Activation"]
    TNFa          [label="TNF-α"]
    IL1b          [label="IL-1β"]
    IL6           [label="IL-6"]
    IL10          [label="IL-10\n(Anti-inflam)"]
    IL18          [label="IL-18"]
    IFNg          [label="IFN-γ"]
    CRP           [label="C-Reactive\nProtein (CRP)"]
    iNOS          [label="iNOS\n(inducible NOS)"]
    ROS           [label="Reactive Oxygen\nSpecies (ROS)"]
    ONOO          [label="Peroxynitrite\n(ONOO⁻)"]
    Oxidative_PKG [label="PKG Oxidation\n(Cys42)"]
    TGFb1         [label="TGF-β1"]
    MCP1          [label="MCP-1\n(CCL2)"]
    Monocytes     [label="Monocyte\nActivation"]
    NLRP3         [label="NLRP3\nInflammasome"]
    GDF15         [label="GDF-15\n(Stress marker)"]
    sST2          [label="sST2\n(IL-33 decoy)"]
    Galectin3     [label="Galectin-3\n(Fibrosis marker)"]
  }

  // ============================================================
  // CLUSTER 2: Neurohumoral Activation — RAAS & SNS
  // ============================================================
  subgraph cluster_neurohumoral {
    label="Neurohumoral Activation (RAAS / SNS)"
    fontsize=14 fontcolor="#ffffff"
    style="filled,rounded"
    fillcolor="#1a6b4a"
    color="#1a6b4a"

    node [fillcolor="#c3e6c5" color="#1a6b4a" fontcolor="#1a1a2e"]

    Renin         [label="Renin\n(JGA release)"]
    AngI          [label="Angiotensin I"]
    ACE           [label="ACE\n(lung/endothelium)"]
    AngII         [label="Angiotensin II"]
    AT1R          [label="AT1 Receptor"]
    AT2R          [label="AT2 Receptor"]
    Aldosterone   [label="Aldosterone"]
    MR            [label="Mineralocorticoid\nReceptor (MR)"]
    RAAS_effect   [label="↑ Na retention\n↑ Fibrosis\n↑ Vasoconstriction"]
    Neprilysin    [label="Neprilysin\n(NEP)"]
    NE            [label="Norepinephrine\n(NE)"]
    Epi           [label="Epinephrine"]
    beta1AR       [label="β1-Adrenergic\nReceptor"]
    SNS_effect    [label="↑ HR, ↑ Contractility\n↑ Renin, Vasoconstrict"]
    ACTH          [label="ACTH\n(Adrenal axis)"]
    Cortisol      [label="Cortisol"]
    Vasopressin   [label="AVP/Vasopressin\n(V2R mediated)"]
    AQP2          [label="Aquaporin-2\n(Water retention)"]
  }

  // ============================================================
  // CLUSTER 3: Natriuretic Peptide System & cGMP-PKG Pathway
  // ============================================================
  subgraph cluster_natriuretic {
    label="Natriuretic Peptide System & cGMP-PKG Pathway"
    fontsize=14 fontcolor="#ffffff"
    style="filled,rounded"
    fillcolor="#5e3579"
    color="#5e3579"

    node [fillcolor="#e8d5f5" color="#5e3579" fontcolor="#1a1a2e"]

    ANP           [label="ANP\n(Atrial NP)"]
    BNP           [label="BNP\n(Ventricular NP)"]
    NTproBNP      [label="NT-proBNP\n(Inactive fragment)"]
    CNP           [label="CNP\n(Endothelial NP)"]
    NPR_A         [label="NPR-A\n(GC-A receptor)"]
    NPR_B         [label="NPR-B\n(GC-B receptor)"]
    sGC           [label="sGC\n(Soluble guanylate\ncyclase)"]
    cGMP          [label="cGMP"]
    PDE5          [label="PDE5\n(cGMP hydrolysis)"]
    PDE9          [label="PDE9\n(cGMP hydrolysis)"]
    PKG           [label="PKG\n(cGMP-dependent\nprotein kinase)"]
    Titin_phos    [label="Titin\nPhosphorylation\n(↓ Stiffness)"]
    SERCA2a_reg   [label="SERCA2a\nRegulation via\nPhospholamban"]
    Troponin_I    [label="Troponin I\nPhosphorylation\n(Ca sensitivity ↓)"]
    NO_eNOS       [label="NO from\neNOS\n(endothelial)"]
    NO_nNOS       [label="NO from\nnNOS\n(neuronal)"]
  }

  // ============================================================
  // CLUSTER 4: Cardiac Structural & Mechanical Changes
  // ============================================================
  subgraph cluster_cardiac {
    label="Cardiac Structure & Myocardial Mechanics"
    fontsize=14 fontcolor="#ffffff"
    style="filled,rounded"
    fillcolor="#7a5c1e"
    color="#7a5c1e"

    node [fillcolor="#fdebd0" color="#7a5c1e" fontcolor="#1a1a2e"]

    LV_Hypertrophy  [label="LV Concentric\nHypertrophy"]
    LV_Mass         [label="LV Mass\n(g/m²)"]
    LV_Wall_Thick   [label="↑ LV Wall\nThickness"]
    LV_Fibrosis     [label="LV Interstitial\nFibrosis"]
    Collagen_I      [label="Collagen I\n(stiff)"]
    Collagen_III    [label="Collagen III\n(elastic)"]
    Collagen_ratio  [label="Collagen I/III\nRatio ↑"]
    MMP2            [label="MMP-2\n(Type IV collagenase)"]
    MMP9            [label="MMP-9\n(Gelatinase B)"]
    TIMP1           [label="TIMP-1\n(MMP inhibitor)"]
    Fibroblasts     [label="Cardiac\nFibroblasts"]
    Myofibroblasts  [label="Myofibroblasts\n(TGF-β activated)"]
    Titin_stiff     [label="Titin Isoform\nN2B ↑ (stiff)"]
    SERCA2a_expr    [label="SERCA2a\nExpression ↓"]
    PLB             [label="Phospholamban\n(PLB)"]
    RyR2            [label="RyR2\nSR Ca release"]
    NCX             [label="NCX\nNa/Ca exchanger"]
    LCC             [label="L-type Ca²⁺\nChannel"]
    Myosin_Isoform  [label="β-MHC\nIsoform Switch"]
    BNP_synthesis   [label="BNP/ANP Gene\nExpression ↑"]
  }

  // ============================================================
  // CLUSTER 5: Left Ventricular Hemodynamics & Filling
  // ============================================================
  subgraph cluster_hemodynamics {
    label="LV Hemodynamics & Filling Pressures"
    fontsize=14 fontcolor="#ffffff"
    style="filled,rounded"
    fillcolor="#2c5f8a"
    color="#2c5f8a"

    node [fillcolor="#d4e9f7" color="#2c5f8a" fontcolor="#1a1a2e"]

    LVEDP         [label="LVEDP\n(LV End-Diastolic\nPressure, mmHg)"]
    LVEDV         [label="LVEDV\n(Volume, mL)"]
    LAP           [label="Left Atrial\nPressure (LAP)"]
    PCWP          [label="Pulmonary Capillary\nWedge Pressure\n(PCWP)"]
    PAP           [label="Pulmonary Arterial\nPressure (PAP)"]
    RVP           [label="RV Pressure\n(Right Heart)"]
    CVP           [label="Central Venous\nPressure (CVP)"]
    CO            [label="Cardiac Output\n(CO, L/min)"]
    SV            [label="Stroke Volume\n(SV, mL)"]
    HR            [label="Heart Rate\n(HR, bpm)"]
    EF            [label="Ejection Fraction\n(EF ≥ 50%)"]
    E_ratio       [label="E/e' ratio\n(Diastolic dysfunct)"]
    DT            [label="Deceleration\nTime (DT)"]
    SVR           [label="Systemic Vascular\nResistance (SVR)"]
    MAP           [label="Mean Arterial\nPressure (MAP)"]
    Arterial_stiff [label="Arterial Stiffness\n(↑ PWV)"]
    Venous_return  [label="Venous Return\n(↑ w/ exercise)"]
    Frank_Starling [label="Frank-Starling\nMechanism\n(blunted)"]
  }

  // ============================================================
  // CLUSTER 6: Cardiorenal Interaction & Renal Function
  // ============================================================
  subgraph cluster_renal {
    label="Cardiorenal Interaction & Renal Function"
    fontsize=14 fontcolor="#ffffff"
    style="filled,rounded"
    fillcolor="#3d6b4f"
    color="#3d6b4f"

    node [fillcolor="#d5f0e0" color="#3d6b4f" fontcolor="#1a1a2e"]

    GFR           [label="GFR / eGFR\n(mL/min/1.73m²)"]
    SGLT2_renal   [label="SGLT2 Transporter\n(Proximal tubule)"]
    Na_reabs      [label="Tubular Na\nReabsorption"]
    Glucose_reabs [label="Tubular Glucose\nReabsorption"]
    TBG           [label="Tubuloglomerular\nFeedback (TGF)"]
    Afferent_AA   [label="Afferent Arteriole\nConstriction"]
    Efferent_AA   [label="Efferent Arteriole\nTone"]
    RBF           [label="Renal Blood Flow\n(RBF)"]
    NGAL          [label="NGAL\n(Renal injury marker)"]
    Creatinine    [label="Serum Creatinine\n(Cr, mg/dL)"]
    Aldost_renal  [label="Aldosterone\nRenal Effect\n(ENaC activation)"]
    UricAcid      [label="Uric Acid\n(↑ in HFpEF)"]
    Osmolarity    [label="Plasma\nOsmolarity"]
    Natriuresis   [label="Natriuresis\n(Na excretion ↑)"]
    Glucosuria    [label="Glucosuria\n(SGLT2i effect)"]
    RVSP          [label="Renal Venous\nCongestion"]
  }

  // ============================================================
  // CLUSTER 7: Drug PK — Four Key Treatments
  // ============================================================
  subgraph cluster_drug_pk {
    label="Drug Pharmacokinetics (PK)"
    fontsize=14 fontcolor="#ffffff"
    style="filled,rounded"
    fillcolor="#8b3a62"
    color="#8b3a62"

    node [fillcolor="#fad7e8" color="#8b3a62" fontcolor="#1a1a2e"]

    // SGLT2 inhibitor — Empagliflozin
    Empa_oral     [label="Empagliflozin\n(Oral dose)"]
    Empa_gut      [label="Empa Gut\nAbsorption"]
    Empa_central  [label="Empa Central\nCompartment\n(Cp, ng/mL)"]
    Empa_periph   [label="Empa Peripheral\nCompartment"]
    Empa_elim     [label="Empa Elimination\n(t½ ~12h)"]

    // ARNI — Sacubitril/Valsartan (LCZ696)
    Sac_oral      [label="Sacubitril/Val\n(Oral dose, LCZ696)"]
    Sacubitrilat  [label="Sacubitrilat\n(Active NEP inhib)"]
    Valsartan_C   [label="Valsartan\nCompartment\n(Cp, ng/mL)"]
    ARNI_elim     [label="Sacubitril/Val\nElimination\n(t½: Sac ~12h)"]

    // MRA — Spironolactone / Finerenone
    MRA_oral      [label="Finerenone\n(Oral dose)"]
    Canrenone     [label="Active\nMetabolite\n(Canrenone-like)"]
    MRA_central   [label="MRA Central\nCompartment\n(Cp, ng/mL)"]
    MRA_elim      [label="MRA Elimination\n(t½ ~20h)"]

    // Loop diuretic — Furosemide
    Furo_oral     [label="Furosemide\n(IV/Oral dose)"]
    Furo_central  [label="Furosemide\nPlasma\n(Cp, μg/mL)"]
    Furo_tubular  [label="Furosemide\nTubular Secretion"]
    Furo_elim     [label="Furosemide\nElimination\n(t½ ~2h)"]
  }

  // ============================================================
  // CLUSTER 8: Drug PD Mechanisms & Target Engagement
  // ============================================================
  subgraph cluster_drug_pd {
    label="Drug Pharmacodynamics & Mechanism of Action"
    fontsize=14 fontcolor="#ffffff"
    style="filled,rounded"
    fillcolor="#4a5c8a"
    color="#4a5c8a"

    node [fillcolor="#dce4f5" color="#4a5c8a" fontcolor="#1a1a2e"]

    SGLT2_inhib   [label="SGLT2 Inhibition\n(↑ Glucosuria, Na loss)"]
    SGLT2_AMPK    [label="↑ AMPK Activation\n(Metabolic effect)"]
    SGLT2_inflam  [label="↓ Inflammation\n(NF-κB, NLRP3)"]
    SGLT2_hema    [label="↑ Hematocrit\n(Erythropoiesis)"]
    SGLT2_ketone  [label="↑ Ketone Bodies\n(Alt fuel for myocardium)"]
    SGLT2_cardiac [label="Direct Cardiac Effect\n(↑ NHE1 → ↓ intracellular\nNa, ↑ mitochondria)"]
    NEP_inhib     [label="NEP Inhibition\n(↑ ANP, BNP, CNP)"]
    AT1R_block    [label="AT1R Blockade\n(↓ AngII effect)"]
    MR_block      [label="MR Blockade\n(↓ Aldosterone effect)"]
    NKCC2_inhib   [label="NKCC2 Inhibition\n(Loop of Henle,\nFurosemide)"]
    ENaC_inhib    [label="ENaC Blockade\n(↓ Na reabsorption)"]
    eNOS_enhance  [label="eNOS Enhancement\n(↑ NO, ↑ cGMP)"]
    PDE5_inhib_pd [label="PDE5 Inhibition\n(Sildenafil effect\non RV, ↑ cGMP)"]
    sGC_stim      [label="sGC Stimulation\n(Vericiguat ↑ cGMP)"]
  }

  // ============================================================
  // CLUSTER 9: Adipose Tissue & Metabolic Pathways
  // ============================================================
  subgraph cluster_metabolic {
    label="Adipose & Metabolic Pathways"
    fontsize=14 fontcolor="#ffffff"
    style="filled,rounded"
    fillcolor="#7a4a1e"
    color="#7a4a1e"

    node [fillcolor="#fdecd0" color="#7a4a1e" fontcolor="#1a1a2e"]

    Adiponectin   [label="Adiponectin\n(↓ in obesity)"]
    Leptin        [label="Leptin\n(↑ in obesity)"]
    Resistin      [label="Resistin\n(↑ Inflammation)"]
    FFA           [label="Free Fatty Acids\n(FFA, lipotoxicity)"]
    Ceramides     [label="Ceramides\n(Lipotoxic signal)"]
    Insulin_R     [label="Insulin Resistance\n(skeletal muscle)"]
    HOMA_IR       [label="HOMA-IR\n(insulin resistance\nindex)"]
    Hyperglycemia [label="Hyperglycemia\n(↑ AGE formation)"]
    AGE           [label="Advanced Glycation\nEndproducts (AGEs)"]
    RAGE          [label="RAGE Receptor\n(AGE → inflammation)"]
    Epicardial_Fat[label="Epicardial\nAdipose Tissue\n(paracrine inflam)"]
    AMPK          [label="AMPK\n(Energy sensor)"]
    mTOR          [label="mTOR\n(Cell growth)"]
    Autophagy     [label="Autophagy\n(↓ in HFpEF)"]
    Mitochondria  [label="Mitochondrial\nDysfunction\n(↓ ATP)"]
    ATP           [label="ATP Production\n(↓ in HFpEF)"]
  }

  // ============================================================
  // CLUSTER 10: Clinical Endpoints & Outcomes
  // ============================================================
  subgraph cluster_endpoints {
    label="Clinical Endpoints & Patient-Reported Outcomes"
    fontsize=14 fontcolor="#ffffff"
    style="filled,rounded"
    fillcolor="#1a3a5c"
    color="#1a3a5c"

    node [fillcolor="#d4e4f5" color="#1a3a5c" fontcolor="#1a1a2e"]

    ExerciseCap   [label="Exercise Capacity\n(Peak VO₂, mL/kg/min)"]
    SixMWT        [label="6-Minute Walk\nTest (6MWT, m)"]
    KCCQ          [label="KCCQ Score\n(Quality of Life)"]
    NYHA          [label="NYHA Functional\nClass (I-IV)"]
    HFH           [label="HF Hospitalization\n(Primary endpoint)"]
    CV_Death      [label="CV Death\n(Secondary)"]
    All_Cause     [label="All-Cause\nMortality"]
    Worsening_HF  [label="Worsening HF\n(Urgent visit)"]
    AF_risk       [label="AF Development\n/ Burden ↑"]
    Edema         [label="Peripheral\nEdema / Ascites"]
    Dyspnea       [label="Dyspnea Score\n(mMRC)"]
    Fatigue       [label="Fatigue\n/ Weakness"]
    Ortho_BP      [label="Orthostatic\nHypotension"]
  }

  // ============================================================
  // CLUSTER 11: Vascular & Endothelial Dysfunction
  // ============================================================
  subgraph cluster_vascular {
    label="Vascular & Endothelial Dysfunction"
    fontsize=14 fontcolor="#ffffff"
    style="filled,rounded"
    fillcolor="#2e5941"
    color="#2e5941"

    node [fillcolor="#ccebd5" color="#2e5941" fontcolor="#1a1a2e"]

    eNOS          [label="eNOS\n(endothelial NOS)"]
    NO_bioavail   [label="NO Bioavailability\n(↓ in HFpEF)"]
    ET1           [label="Endothelin-1\n(ET-1)"]
    ETR_A         [label="ETA Receptor\n(Vasoconstriction)"]
    Prostacyclin  [label="Prostacyclin\n(PGI₂, vasodilation)"]
    TXA2          [label="Thromboxane A₂\n(vasoconstriction)"]
    VCAM1         [label="VCAM-1\n(↑ Leukocyte adhesion)"]
    ICAM1         [label="ICAM-1\n(↑ Leukocyte adhesion)"]
    FMD           [label="Flow-Mediated\nDilatation (FMD ↓)"]
    Microvascular [label="Coronary\nMicrovascular\nDysfunction (CMD)"]
    CFR           [label="Coronary Flow\nReserve (CFR ↓)"]
    PWV           [label="Pulse Wave\nVelocity (PWV ↑)"]
    PlateletAgg   [label="Platelet\nAggregation ↑"]
    VTE_risk      [label="VTE/Thrombus\nRisk ↑"]
  }

  // ============================================================
  // CLUSTER 12: Biomarkers Panel
  // ============================================================
  subgraph cluster_biomarkers {
    label="Biomarkers Panel"
    fontsize=14 fontcolor="#ffffff"
    style="filled,rounded"
    fillcolor="#5c3d6e"
    color="#5c3d6e"

    node [fillcolor="#ead4f5" color="#5c3d6e" fontcolor="#1a1a2e"]

    BNP_level     [label="BNP\n(≥ 35 pg/mL\nfor HFpEF)"]
    NTproBNP_lv   [label="NT-proBNP\n(≥ 125 pg/mL\nfor HFpEF)"]
    TropI         [label="Troponin I\n(↑ myocardial injury)"]
    TropT         [label="Troponin T\n(hsTnT)"]
    GDF15_lv      [label="GDF-15\n(Inflammatory\nstress marker)"]
    sST2_lv       [label="sST2\n(↑ Fibrosis risk)"]
    Galectin3_lv  [label="Galectin-3\n(Fibrosis)"]
    CRP_lv        [label="hsCRP\n(Inflammation)"]
    Ferritin      [label="Ferritin / TSAT\n(Iron status)"]
    HbA1c_lv      [label="HbA1c\n(Glycemia)"]
    eGFR_lv       [label="eGFR / Creatinine\n(Renal function)"]
    UACR          [label="UACR\n(Albuminuria)"]
    HCT           [label="Hematocrit\n(↑ w/ SGLT2i)"]
    BNP_ratio     [label="BNP/NT-proBNP\nRatio\n(Neprilysin activity)"]
  }

  // ============================================================
  // EDGES — CAUSAL CONNECTIONS
  // ============================================================

  // --- Comorbidities → Inflammation ---
  Obesity       -> NFkB     [label="Adipokines" color="#c94040"]
  Obesity       -> TNFa     [color="#c94040"]
  Obesity       -> IL6      [color="#c94040"]
  HTN           -> ROS      [label="↑ NADPH ox" color="#c94040"]
  T2DM          -> AGE      [color="#7a4a1e"]
  T2DM          -> Hyperglycemia [color="#7a4a1e"]
  OSA           -> ROS      [label="Hypoxia-reperfusion" color="#c94040"]
  OSA           -> TNFa     [color="#c94040"]
  AF            -> BNP_synthesis [color="#7a5c1e"]
  Age           -> Titin_stiff   [label="Isoform shift" color="#7a5c1e"]
  Age           -> LV_Fibrosis   [color="#7a5c1e"]
  Anemia        -> Mitochondria  [label="↓ O₂ delivery" color="#7a4a1e"]
  CAD           -> Microvascular [color="#2e5941"]
  Sedentary     -> AMPK     [label="↓ activation" color="#7a4a1e" style=dashed]
  Dyslipidemia  -> FFA      [color="#7a4a1e"]
  Epicardial_Fat-> TNFa     [label="Paracrine" color="#c94040"]
  Epicardial_Fat-> IL6      [color="#c94040"]

  // --- Inflammation cascade ---
  NFkB          -> TNFa     [color="#c94040"]
  NFkB          -> IL1b     [color="#c94040"]
  NFkB          -> IL6      [color="#c94040"]
  NFkB          -> iNOS     [color="#c94040"]
  NFkB          -> MCP1     [color="#c94040"]
  TNFa          -> NFkB     [label="+ feedback" color="#c94040" style=dashed]
  TNFa          -> NLRP3    [color="#c94040"]
  IL1b          -> NLRP3    [label="Activates" color="#c94040"]
  NLRP3         -> IL18     [color="#c94040"]
  NLRP3         -> IL1b     [label="+ amplif." color="#c94040" style=dashed]
  IL6           -> CRP      [label="Hepatic synth" color="#c94040"]
  IL6           -> GDF15    [color="#c94040"]
  TNFa          -> sST2     [label="↑ shed" color="#c94040"]
  Galectin3     -> TGFb1    [label="Fibrosis" color="#c94040"]
  iNOS          -> ROS      [color="#c94040"]
  iNOS          -> ONOO     [color="#c94040"]
  ROS           -> ONOO     [label="+ NO" color="#c94040"]
  ONOO          -> Oxidative_PKG [label="Cys42 oxidation" color="#c94040"]
  ROS           -> eNOS     [label="Uncouple" color="#2e5941" style=dashed]
  MCP1          -> Monocytes [color="#c94040"]
  Monocytes     -> TGFb1    [color="#c94040"]
  TGFb1         -> Myofibroblasts [label="Activation" color="#7a5c1e"]
  TGFb1         -> Collagen_I    [color="#7a5c1e"]

  // --- RAAS pathway ---
  HTN           -> Renin     [label="JGA pressure" color="#1a6b4a"]
  Afferent_AA   -> Renin     [color="#1a6b4a"]
  Renin         -> AngI      [label="Angiotensinogen\ncleave" color="#1a6b4a"]
  AngI          -> AngII     [label="ACE" color="#1a6b4a"]
  ACE           -> AngI      [label="catalyzes" color="#1a6b4a"]
  AngII         -> AT1R      [label="binds" color="#1a6b4a"]
  AngII         -> AT2R      [label="binds (counter)" color="#1a6b4a" style=dashed]
  AT1R          -> Aldosterone [label="Adrenal stim" color="#1a6b4a"]
  AT1R          -> RAAS_effect [color="#1a6b4a"]
  AT1R          -> NFkB      [label="Signaling" color="#c94040"]
  AT2R          -> NO_eNOS   [label="Counter-reg" color="#2e5941" style=dashed]
  Aldosterone   -> MR        [color="#1a6b4a"]
  MR            -> RAAS_effect [color="#1a6b4a"]
  MR            -> LV_Fibrosis [label="↑ Fibrosis" color="#7a5c1e"]
  MR            -> Aldost_renal [color="#3d6b4f"]
  Vasopressin   -> AQP2      [color="#1a6b4a"]
  AQP2          -> Osmolarity [label="↑ water reabs" color="#3d6b4f"]

  // --- SNS ---
  NE            -> beta1AR   [color="#1a6b4a"]
