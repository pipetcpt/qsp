  Titin_stiff   -> LVEDP     [label="↑ passive stiff" color="#2c5f8a"]
  Titin_phos    -> Titin_stiff [label="↓ phosphorylation\n→ stiffer" color="#5e3579" style=dashed arrowhead=tee]
  SERCA2a_expr  -> SERCA2a_reg [color="#7a5c1e"]
  PLB           -> SERCA2a_reg [label="inhibits" color="#7a5c1e"]
