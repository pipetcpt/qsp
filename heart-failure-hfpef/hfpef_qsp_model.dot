  Natriuresis   -> Venous_return [label="↓ preload" arrowhead=tee color="#2c5f8a"]
  Glucosuria    -> Hyperglycemia [label="↓ glucose" arrowhead=tee color="#7a4a1e"]

  // ARNI effects
  Sacubitrilat  -> NEP_inhib   [label="NEP inhibition\nIC50 ~5nM"]
