digraph CRS_QSP_Model {
    graph [
        label="Cytokine Release Syndrome (CRS)\nQSP Mechanistic Map — Immunotherapy-Induced Hyperinflammation"
        fontname="Helvetica" fontsize=22 fontcolor="#1a1a2e"
        bgcolor="#f8f9fa"
        rankdir=TB
        compound=true
        splines=ortho
        nodesep=0.4
        ranksep=0.6
        pad=0.5
    ]
    node [fontname="Helvetica" fontsize=10 style="filled,rounded" shape=box penwidth=1.5]
    edge [fontname="Helvetica" fontsize=8 penwidth=1.2]

    // =========================================================
    // CLUSTER 1: Immunotherapy Trigger
    // =========================================================
    subgraph cluster_trigger {
        label="1. Immunotherapy Trigger"
        style="filled,rounded" fillcolor="#e8f4f8" color="#1a6b8a" penwidth=2
        fontsize=14 fontcolor="#1a6b8a"

        CART_CD19 [label="CD19-targeted\nCAR-T cells\n(Axicabtagene,\nTisagenlecleucel)" fillcolor="#4a90d9" fontcolor=white]
        CART_BCMA [label="BCMA-targeted\nCAR-T cells\n(Idecabtagene,\nCiltacabtagene)" fillcolor="#4a90d9" fontcolor=white]
        CART_CD22 [label="CD22/CD33\nCAR-T cells" fillcolor="#5ba3e0" fontcolor=white]
        BITE_CD3 [label="CD3×CD19\nBispecific Ab\n(Blinatumomab)" fillcolor="#6ab4e8" fontcolor=white]
        BITE_BCMA [label="BCMA×CD3\nBispecific Ab\n(Teclistamab,\nElranatamab)" fillcolor="#6ab4e8" fontcolor=white]
        TCE_CD20 [label="CD20×CD3\nBispecific Ab\n(Mosunetuzumab,\nEpcoritamab)" fillcolor="#7ac4f0" fontcolor=white]
        ICI [label="Immune Checkpoint\nInhibitors\n(PD-1/CTLA-4)" fillcolor="#89d4f8" fontcolor="#1a1a2e"]
        TUMOR_ANTIGEN [label="Tumor Antigen\nExpression Level\n(CD19, BCMA, CD20)" fillcolor="#b3e5fc" fontcolor="#1a1a2e"]
        CAR_DENSITY [label="CAR Construct\nDensity / Costimulation\n(CD28 vs 4-1BB)" fillcolor="#b3e5fc" fontcolor="#1a1a2e"]
        TUMOR_BURDEN [label="Disease Burden\n(Pre-treatment\nTumor Load)" fillcolor="#ffcc80" fontcolor="#1a1a2e"]
        INFUSION_DOSE [label="Infusion Dose\n(cells/kg)" fillcolor="#ffcc80" fontcolor="#1a1a2e"]
    }

    // =========================================================
    // CLUSTER 2: T Cell Activation & Expansion
    // =========================================================
    subgraph cluster_tcell {
        label="2. T Cell / CAR-T Activation & Expansion"
        style="filled,rounded" fillcolor="#e8f5e9" color="#2e7d32" penwidth=2
        fontsize=14 fontcolor="#2e7d32"

        CART_NAIVE [label="Naive/Resting\nCAR-T Cells (N)" fillcolor="#a5d6a7" fontcolor="#1a1a2e"]
        CART_ACT [label="Activated\nCAR-T Cells (A)\n↑ IFN-γ, IL-2,\nGM-CSF" fillcolor="#66bb6a" fontcolor=white]
        CART_EXP [label="Expanding\nCAR-T Cells (E)\n(Peak: Day 7-14)" fillcolor="#43a047" fontcolor=white]
        CART_EXH [label="Exhausted/Memory\nCAR-T Cells" fillcolor="#81c784" fontcolor="#1a1a2e"]
        TCR_SIGNAL [label="TCR/CAR\nSignaling Strength\n(antigen density)" fillcolor="#c8e6c9" fontcolor="#1a1a2e"]
        COSTIM_CD28 [label="CD28\nCostimulation\n(faster CRS onset)" fillcolor="#dcedc8" fontcolor="#1a1a2e"]
        COSTIM_41BB [label="4-1BB\nCostimulation\n(slower, milder CRS)" fillcolor="#dcedc8" fontcolor="#1a1a2e"]
        CD4_HELP [label="CD4+ T Helper\nActivation\n(IL-2, TNF-α)" fillcolor="#b2dfdb" fontcolor="#1a1a2e"]
        CD8_CTL [label="CD8+ CTL\nActivation\n(cytolysis)" fillcolor="#b2dfdb" fontcolor="#1a1a2e"]
        T_PROLIF [label="T Cell\nProliferation\n(IL-2 autocrine)" fillcolor="#a5d6a7" fontcolor="#1a1a2e"]
    }

    // =========================================================
    // CLUSTER 3: Cytokine Production — T Cell Derived
    // =========================================================
    subgraph cluster_cytokines_t {
        label="3. T Cell–Derived Cytokines"
        style="filled,rounded" fillcolor="#fff3e0" color="#e65100" penwidth=2
        fontsize=14 fontcolor="#e65100"

        IFNg [label="IFN-γ (pg/mL)\n[Normal: <5\nCRS: >1000]" fillcolor="#ff7043" fontcolor=white shape=ellipse]
        IL2 [label="IL-2 (pg/mL)\n[Normal: <10\nCRS: >200]" fillcolor="#ff8a65" fontcolor=white shape=ellipse]
        GMCSF [label="GM-CSF (pg/mL)\n[Key macrophage\nactivator]" fillcolor="#ffab40" fontcolor="#1a1a2e" shape=ellipse]
        TNFa_T [label="TNF-α (T cell)\n(pg/mL)" fillcolor="#ffca28" fontcolor="#1a1a2e" shape=ellipse]
        IL4 [label="IL-4\n(Th2 modulator)" fillcolor="#fff176" fontcolor="#1a1a2e" shape=ellipse]
        IL17 [label="IL-17\n(Th17 component)" fillcolor="#fff176" fontcolor="#1a1a2e" shape=ellipse]
        PERFORIN [label="Perforin/\nGranzyme B\n(tumor lysis)" fillcolor="#ffcc80" fontcolor="#1a1a2e" shape=ellipse]
        LTA [label="LT-α\n(Lymphotoxin-α)" fillcolor="#ffe0b2" fontcolor="#1a1a2e" shape=ellipse]
    }

    // =========================================================
    // CLUSTER 4: Macrophage/Myeloid Activation
    // =========================================================
    subgraph cluster_macrophage {
        label="4. Macrophage & Myeloid Cell Activation"
        style="filled,rounded" fillcolor="#fce4ec" color="#880e4f" penwidth=2
        fontsize=14 fontcolor="#880e4f"

        MAC_REST [label="Resting\nMacrophages/\nMonocytes" fillcolor="#f48fb1" fontcolor="#1a1a2e"]
        MAC_ACT [label="Activated\nMacrophages\n(M1 phenotype)" fillcolor="#e91e8c" fontcolor=white]
        MAC_IFNg [label="IFN-γ–Activated\nMacrophage\n(JAK-STAT1)" fillcolor="#c2185b" fontcolor=white]
        IL6_MAC [label="IL-6 (Macrophage)\n[Key CRS driver]\n(pg/mL)" fillcolor="#e91e63" fontcolor=white shape=ellipse]
        IL1B [label="IL-1β\n[NLRP3 inflammasome]\n(pg/mL)" fillcolor="#f06292" fontcolor=white shape=ellipse]
        TNFa_MAC [label="TNF-α\n(Macrophage)\n(pg/mL)" fillcolor="#f48fb1" fontcolor="#1a1a2e" shape=ellipse]
        MCP1 [label="MCP-1/CCL2\n(monocyte\nrecruitment)" fillcolor="#fce4ec" fontcolor="#1a1a2e" shape=ellipse]
        M_CSF [label="M-CSF\n(myeloid survival)" fillcolor="#fce4ec" fontcolor="#1a1a2e" shape=ellipse]
        NLRP3 [label="NLRP3\nInflammasome\nActivation" fillcolor="#ad1457" fontcolor=white]
        HEMOPHAG [label="Hemophagocytosis\n(CRS→HLH overlap)" fillcolor="#e8bfd8" fontcolor="#1a1a2e"]
    }

    // =========================================================
    // CLUSTER 5: IL-6 Signaling Network
    // =========================================================
    subgraph cluster_il6 {
        label="5. IL-6 Signaling Network"
        style="filled,rounded" fillcolor="#ede7f6" color="#4527a0" penwidth=2
        fontsize=14 fontcolor="#4527a0"

        IL6_FREE [label="Free IL-6\n(Circulating)\n(pg/mL)" fillcolor="#9c27b0" fontcolor=white shape=ellipse]
        sIL6R [label="Soluble IL-6R\n(sIL-6R)\n(ng/mL)" fillcolor="#7b1fa2" fontcolor=white shape=ellipse]
        IL6_sIL6R [label="IL-6 : sIL-6R\nComplex\n(Trans-signaling)" fillcolor="#6a1b9a" fontcolor=white shape=ellipse]
        GP130 [label="gp130\nReceptor\n(ubiquitous)" fillcolor="#ab47bc" fontcolor=white]
        JAK1 [label="JAK1\nActivation" fillcolor="#ba68c8" fontcolor=white]
        JAK2 [label="JAK2\nActivation" fillcolor="#ba68c8" fontcolor=white]
        STAT3 [label="STAT3\nPhosphorylation\n(pSTAT3)" fillcolor="#ce93d8" fontcolor="#1a1a2e"]
        SOCS3 [label="SOCS3\nNegative Feedback\n(IL-6 attenuation)" fillcolor="#e1bee7" fontcolor="#1a1a2e"]
        CRP [label="CRP\n[Acute Phase]\n(mg/L)" fillcolor="#d7ccc8" fontcolor="#1a1a2e" shape=ellipse]
        FIBRINOGEN [label="Fibrinogen\n(IL-6 driven)\n(g/L)" fillcolor="#d7ccc8" fontcolor="#1a1a2e" shape=ellipse]
        FERRITIN_CRS [label="Ferritin\n[CRS marker]\n(ng/mL)" fillcolor="#bcaaa4" fontcolor="#1a1a2e" shape=ellipse]
        IL6_HEPATO [label="Hepatocyte\nAcute Phase\nResponse" fillcolor="#e8eaf6" fontcolor="#1a1a2e"]
    }

    // =========================================================
    // CLUSTER 6: Endothelial & Vascular Response
    // =========================================================
    subgraph cluster_vascular {
        label="6. Endothelial Activation & Vascular Response"
        style="filled,rounded" fillcolor="#e0f2f1" color="#004d40" penwidth=2
        fontsize=14 fontcolor="#004d40"

        ENDO_REST [label="Resting\nEndothelium" fillcolor="#b2dfdb" fontcolor="#1a1a2e"]
        ENDO_ACT [label="Activated\nEndothelium\n(VCAM-1, E-selectin↑)" fillcolor="#26a69a" fontcolor=white]
        VWF [label="VWF\n(von Willebrand\nFactor) release" fillcolor="#4db6ac" fontcolor=white]
        ANG2 [label="Angiopoietin-2\n(vascular instability)" fillcolor="#80cbc4" fontcolor="#1a1a2e" shape=ellipse]
        VEGF [label="VEGF\n(vascular\npermeability)" fillcolor="#80cbc4" fontcolor="#1a1a2e" shape=ellipse]
        NO [label="Nitric Oxide\n(vasodilation)\n↓ SVR" fillcolor="#b2dfdb" fontcolor="#1a1a2e" shape=ellipse]
        VASC_LEAK [label="Vascular\nPermeability ↑\n(capillary leak)" fillcolor="#00897b" fontcolor=white]
        FLUID_SHIFT [label="Third-Space\nFluid Shift\n(edema formation)" fillcolor="#4caf50" fontcolor=white]
        COAGULOPATHY [label="Coagulopathy\n(DIC, fibrinolysis)" fillcolor="#ef9a9a" fontcolor="#1a1a2e"]
        THROMBOSIS [label="Microvascular\nThrombosis" fillcolor="#ef9a9a" fontcolor="#1a1a2e"]
    }

    // =========================================================
    // CLUSTER 7: CRS Clinical Manifestations & Grading
    // =========================================================
    subgraph cluster_crs_grade {
        label="7. CRS Clinical Manifestations & ASTCT Grading"
        style="filled,rounded" fillcolor="#fff8e1" color="#f57f17" penwidth=2
        fontsize=14 fontcolor="#f57f17"

        FEVER [label="Fever ≥38°C\n(Universal Grade ≥1)" fillcolor="#ffcc02" fontcolor="#1a1a2e"]
        HYPOTENSION [label="Hypotension\nIV Fluids (Grade 2)\nVasopressors (Grade 3-4)" fillcolor="#ffa726" fontcolor="#1a1a2e"]
        HYPOXIA [label="Hypoxia\nLow-flow O2 (Grade 2)\nHigh-flow/Vent (Grade 3-4)" fillcolor="#ff7043" fontcolor=white]
        CRS_G1 [label="CRS Grade 1\nFever only\n(Supportive care)" fillcolor="#a5d6a7" fontcolor="#1a1a2e"]
        CRS_G2 [label="CRS Grade 2\nFever + Hypotension\nor Hypoxia\n→ Tocilizumab" fillcolor="#fff176" fontcolor="#1a1a2e"]
        CRS_G3 [label="CRS Grade 3\nSevere Hypotension\n(>1 vasopressor)\nor High-flow O2\n→ Toci + DEX" fillcolor="#ffa726" fontcolor="#1a1a2e"]
        CRS_G4 [label="CRS Grade 4\nLife-threatening\n(Vent, ECMO)\n→ Toci + DEX\n+ Ruxolitinib/Ana" fillcolor="#f44336" fontcolor=white]
        TACHYCARDIA [label="Tachycardia\n(compensatory)" fillcolor="#ffe082" fontcolor="#1a1a2e"]
        RIGORS [label="Rigors/Chills\n(early marker)" fillcolor="#ffe082" fontcolor="#1a1a2e"]
        CYTOKINE_SCORE [label="CRS Biomarker\nScore\n(IL-6+IFN-γ+\nCRP+Ferritin)" fillcolor="#ffb300" fontcolor="#1a1a2e"]
    }

    // =========================================================
    // CLUSTER 8: ICANS (Neurotoxicity)
    // =========================================================
    subgraph cluster_icans {
        label="8. ICANS — Immune Effector Cell-Associated Neurotoxicity Syndrome"
        style="filled,rounded" fillcolor="#e8eaf6" color="#283593" penwidth=2
        fontsize=14 fontcolor="#283593"

        BBB_INTACT [label="Blood-Brain\nBarrier (Intact)" fillcolor="#c5cae9" fontcolor="#1a1a2e"]
        BBB_BREACH [label="BBB Disruption\n(cytokine-mediated)" fillcolor="#3f51b5" fontcolor=white]
        BRAIN_MACRO [label="Brain Macrophage\n(Microglial)\nActivation" fillcolor="#5c6bc0" fontcolor=white]
        IL6_CNS [label="IL-6 in CSF\n(CNS inflammation)" fillcolor="#7986cb" fontcolor=white shape=ellipse]
        CEREBRAL_EDEMA [label="Cerebral Edema\n(ADEM-like)" fillcolor="#ef5350" fontcolor=white]
        ICANS_G1 [label="ICANS Grade 1\nICE ≥7\n(Mild confusion)" fillcolor="#a5d6a7" fontcolor="#1a1a2e"]
        ICANS_G2 [label="ICANS Grade 2\nICE 3-6\n(Lethargy)" fillcolor="#fff176" fontcolor="#1a1a2e"]
        ICANS_G3 [label="ICANS Grade 3\nICE 0-2\n(Stupor, Seizure)" fillcolor="#ffa726" fontcolor="#1a1a2e"]
        ICANS_G4 [label="ICANS Grade 4\nDeep coma\nICH/Cerebral edema" fillcolor="#f44336" fontcolor=white]
        ICE_SCORE [label="ICE Score\n(Orientation, Naming,\nCommands, Writing,\nAttention 0-10)" fillcolor="#e8eaf6" fontcolor="#1a1a2e"]
    }

    // =========================================================
    // CLUSTER 9: Drug PK/PD
    // =========================================================
    subgraph cluster_pkpd {
        label="9. Drug PK/PD — CRS Management"
        style="filled,rounded" fillcolor="#f1f8e9" color="#33691e" penwidth=2
        fontsize=14 fontcolor="#33691e"

        // Tocilizumab
        TOCI_IV [label="Tocilizumab IV\n8 mg/kg (adults)\n12 mg/kg (<30kg)\nAnti-IL-6R mAb" fillcolor="#4caf50" fontcolor=white]
        TOCI_C1 [label="Tocilizumab\nCentral Cmt\n(C1, μg/mL)" fillcolor="#81c784" fontcolor="#1a1a2e"]
        TOCI_C2 [label="Tocilizumab\nPeripheral Cmt\n(C2)" fillcolor="#a5d6a7" fontcolor="#1a1a2e"]
        TOCI_PD [label="Tocilizumab PD\nIL-6R Occupancy\n→ ↓IL-6 signaling" fillcolor="#c8e6c9" fontcolor="#1a1a2e"]
        TOCI_TMDD [label="Tocilizumab\nTMDD\n(IL-6R saturation)" fillcolor="#b2dfdb" fontcolor="#1a1a2e"]

        // Siltuximab
        SILT_IV [label="Siltuximab IV\n11 mg/kg q3w\nAnti-IL-6 mAb" fillcolor="#26a69a" fontcolor=white]
        SILT_C1 [label="Siltuximab\nCentral Cmt\n(C1, μg/mL)" fillcolor="#80cbc4" fontcolor="#1a1a2e"]
        SILT_PD [label="Siltuximab PD\nDirect IL-6\nNeutralization" fillcolor="#b2dfdb" fontcolor="#1a1a2e"]

        // Dexamethasone
        DEX_IV [label="Dexamethasone IV\n10-20 mg/dose\nCorticosteroid" fillcolor="#2196f3" fontcolor=white]
        DEX_C1 [label="Dexamethasone\nCentral Cmt\n(C1, ng/mL)" fillcolor="#64b5f6" fontcolor="#1a1a2e"]
        DEX_PD [label="DEX PD\n↓ IL-6, TNF-α,\nIFN-γ production\n(GR-NF-κB)" fillcolor="#bbdefb" fontcolor="#1a1a2e"]

        // Ruxolitinib
        RUX_PO [label="Ruxolitinib PO\n10-20 mg BID\nJAK1/2 inhibitor" fillcolor="#ff9800" fontcolor=white]
        RUX_C1 [label="Ruxolitinib\nCentral Cmt\n(C1, ng/mL)" fillcolor="#ffcc80" fontcolor="#1a1a2e"]
        RUX_C2 [label="Ruxolitinib\nPeripheral Cmt" fillcolor="#ffe0b2" fontcolor="#1a1a2e"]
        RUX_PD [label="Ruxolitinib PD\nJAK1/2 inhibition\n→ ↓STAT3/STAT1\n(IC50: 3.3 nM)" fillcolor="#fff3e0" fontcolor="#1a1a2e"]

        // Anakinra
        ANA_SC [label="Anakinra SC\n2-4 mg/kg QD\nIL-1Ra" fillcolor="#9c27b0" fontcolor=white]
        ANA_C1 [label="Anakinra\nCentral Cmt\n(C1, ng/mL)" fillcolor="#ce93d8" fontcolor="#1a1a2e"]
        ANA_PD [label="Anakinra PD\nIL-1R Blockade\n→ ↓IL-1β signal" fillcolor="#e1bee7" fontcolor="#1a1a2e"]

        // Corticosteroid effects
        MEPRED_IV [label="Methylprednisolone\nIV pulse\n(ICANS)" fillcolor="#1565c0" fontcolor=white]
    }

    // =========================================================
    // CLUSTER 10: Organ Damage & Outcomes
    // =========================================================
    subgraph cluster_outcomes {
        label="10. Multi-Organ Involvement & Clinical Outcomes"
        style="filled,rounded" fillcolor="#ffebee" color="#b71c1c" penwidth=2
        fontsize=14 fontcolor="#b71c1c"

        CARDIAC [label="Cardiac Dysfunction\n(Takotsubo-like CM\nArrhythmia)" fillcolor="#ef9a9a" fontcolor="#1a1a2e"]
        HEPATIC [label="Hepatic Damage\n(↑ ALT/AST/Bili)" fillcolor="#ef9a9a" fontcolor="#1a1a2e"]
        RENAL [label="Acute Kidney Injury\n(↑ Creatinine)" fillcolor="#ef9a9a" fontcolor="#1a1a2e"]
        RESP_FAIL [label="Respiratory Failure\n(ARDS pattern)" fillcolor="#f44336" fontcolor=white]
        DIC [label="DIC/Coagulopathy\n(↓Fibrinogen,\n↓Plt, ↑PT)" fillcolor="#f44336" fontcolor=white]
        HLH_OVERLAP [label="CRS → HLH/MAS\nOverlap Syndrome\n(Ferritin >10000,\nHemophagocytosis)" fillcolor="#d32f2f" fontcolor=white]
        CYTOPENIA [label="Cytopenias\n(transient: naive lymph\ndepletion, neutropenia)" fillcolor="#ef9a9a" fontcolor="#1a1a2e"]
        SURVIVAL [label="Survival\nProbability" fillcolor="#4caf50" fontcolor=white]
        REMISSION [label="Tumor Response\n(ORR, CR rate\nin ALL/DLBCL/MM)" fillcolor="#66bb6a" fontcolor=white]
        EXPANSION_PEAK [label="CAR-T Peak\nExpansion\n(Cmax cells/μL)" fillcolor="#a5d6a7" fontcolor="#1a1a2e"]
        CRS_RESOLVE [label="CRS Resolution\n(Grade ≤1 or\nAfebrile x 24h)" fillcolor="#c8e6c9" fontcolor="#1a1a2e"]
        BRIDGING_THERAPY [label="Bridging Therapy\n(pre-infusion tumor\ndepletion)" fillcolor="#ffe0b2" fontcolor="#1a1a2e"]
    }

    // =========================================================
    // EDGES — Trigger → T Cell Activation
    // =========================================================
    CART_CD19 -> CART_NAIVE [label="infuse" color="#4a90d9"]
    CART_BCMA -> CART_NAIVE [label="infuse" color="#4a90d9"]
    CART_CD22 -> CART_NAIVE [label="infuse" color="#4a90d9"]
    BITE_CD3 -> TCR_SIGNAL [label="engage" color="#6ab4e8"]
    BITE_BCMA -> TCR_SIGNAL [label="engage" color="#6ab4e8"]
    TCE_CD20 -> TCR_SIGNAL [label="engage" color="#6ab4e8"]
    ICI -> CART_ACT [label="disinhibit" color="#89d4f8"]
    TUMOR_ANTIGEN -> TCR_SIGNAL [label="antigen\npresentation" color="#1a6b8a"]
    TUMOR_BURDEN -> CART_ACT [label="drives\nactivation" color="#e65100"]
    INFUSION_DOSE -> CART_NAIVE [label="dose" color="#e65100"]
    CAR_DENSITY -> TCR_SIGNAL [label="signal strength" color="#1a6b8a"]

    // T Cell activation network
    CART_NAIVE -> CART_ACT [label="activation\n(TCR/CAR signal)" color="#2e7d32"]
    CART_ACT -> CART_EXP [label="proliferation\n(IL-2 autocrine)" color="#2e7d32"]
    CART_EXP -> CART_EXH [label="exhaustion\n(PD-1, TIM-3↑)" color="#9e9e9e"]
    TCR_SIGNAL -> CART_ACT [color="#2e7d32"]
    COSTIM_CD28 -> CART_ACT [label="fast\nactivation" color="#43a047"]
    COSTIM_41BB -> CART_ACT [label="slower,\nmilder" color="#66bb6a" style=dashed]
    CD4_HELP -> T_PROLIF [color="#2e7d32"]
    CD8_CTL -> PERFORIN [color="#2e7d32"]
    T_PROLIF -> CART_EXP [color="#2e7d32"]

    // T Cell → Cytokines
    CART_ACT -> IFNg [label="secrete" color="#ff7043"]
    CART_ACT -> IL2 [label="secrete" color="#ff7043"]
    CART_ACT -> GMCSF [label="secrete" color="#ff7043"]
    CART_ACT -> TNFa_T [label="secrete" color="#ff7043"]
    CD4_HELP -> IL4 [color="#ff8a65"]
    CD4_HELP -> IL17 [color="#ff8a65"]
    CD8_CTL -> PERFORIN [color="#ff8a65"]
    CART_EXP -> LTA [color="#ffab40"]
    IL2 -> T_PROLIF [label="autocrine\nloop" color="#2e7d32"]

    // Cytokines → Macrophage Activation
    IFNg -> MAC_IFNg [label="M1\npolarization" color="#880e4f" penwidth=2]
    IFNg -> NLRP3 [label="prime" color="#880e4f"]
    GMCSF -> MAC_ACT [label="activate\nmyeloid" color="#c2185b" penwidth=2]
    TNFa_T -> MAC_ACT [label="activate" color="#c2185b"]
    PERFORIN -> TUMOR_ANTIGEN [label="tumor\nlysis →\nDAMPs" color="#e65100" style=dashed]

    MAC_REST -> MAC_ACT [label="activation" color="#880e4f"]
    MAC_ACT -> MAC_IFNg [label="IFN-γ\nstimulated" color="#c2185b"]
    MAC_IFNg -> IL6_MAC [label="JAK-STAT1\n→ IL-6↑↑" color="#e91e63" penwidth=2]
    MAC_IFNg -> TNFa_MAC [label="secrete" color="#c2185b"]
    MAC_IFNg -> MCP1 [label="recruit\nmonocytes" color="#ad1457"]
    MAC_ACT -> IL1B [label="NLRP3\ninflammasome" color="#f06292"]
    NLRP3 -> IL1B [label="cleave\npro-IL-1β" color="#e91e63" penwidth=2]
    MAC_ACT -> M_CSF [color="#ad1457"]
    MCP1 -> MAC_REST [label="recruit more\nmonocytes" color="#880e4f" style=dashed]
    MAC_IFNg -> HEMOPHAG [label="→ hemophago-\ncytosis (rare)" color="#ad1457" style=dashed]

    // IL-6 network
    IL6_MAC -> IL6_FREE [label="main source" color="#9c27b0" penwidth=2]
    TNFa_MAC -> IL6_FREE [label="amplify" color="#9c27b0"]
    IL6_FREE -> sIL6R [label="shed sIL-6R\n(via ADAM17)" color="#7b1fa2"]
    IL6_FREE -> IL6_sIL6R [label="complex" color="#6a1b9a"]
    sIL6R -> IL6_sIL6R [color="#6a1b9a"]
    IL6_sIL6R -> GP130 [label="trans-signaling\n(non-IL-6R cells)" color="#ab47bc" penwidth=2]
    IL6_FREE -> GP130 [label="cis-signaling\n(IL-6R+ cells)" color="#ab47bc"]
    GP130 -> JAK1 [color="#ba68c8"]
    GP130 -> JAK2 [color="#ba68c8"]
    JAK1 -> STAT3 [label="phosphorylate" color="#ce93d8"]
    JAK2 -> STAT3 [color="#ce93d8"]
    STAT3 -> IL6_MAC [label="positive\nfeedback" color="#e91e63" style=dashed]
    STAT3 -> SOCS3 [label="negative\nfeedback" color="#33691e" style=dashed]
    SOCS3 -> JAK1 [label="inhibit" color="#33691e" arrowhead=tee]
    STAT3 -> IL6_HEPATO [label="acute phase" color="#4527a0"]
    IL6_HEPATO -> CRP [label="↑ CRP\nproduction" color="#795548"]
    IL6_HEPATO -> FIBRINOGEN [label="↑ Fibrinogen" color="#795548"]
    IL6_HEPATO -> FERRITIN_CRS [label="↑ Ferritin" color="#795548"]

    // Vascular response
    IL6_FREE -> ENDO_ACT [label="endothelial\nactivation" color="#004d40" penwidth=2]
    TNFa_MAC -> ENDO_ACT [label="NF-κB" color="#004d40"]
    IFNg -> ENDO_ACT [label="activate" color="#004d40"]
    ENDO_REST -> ENDO_ACT [label="cytokine\nactivation" color="#00897b"]
    ENDO_ACT -> VWF [label="release" color="#4db6ac"]
    ENDO_ACT -> ANG2 [label="release" color="#80cbc4"]
    ENDO_ACT -> VEGF [label="upregulate" color="#80cbc4"]
    ENDO_ACT -> NO [label="iNOS↑" color="#4db6ac"]
    NO -> HYPOTENSION [label="vasodilation\n↓ SVR" color="#f57f17" penwidth=2]
    VEGF -> VASC_LEAK [label="permeability↑" color="#00897b"]
    ANG2 -> VASC_LEAK [label="destabilize" color="#00897b"]
    VASC_LEAK -> FLUID_SHIFT [label="fluid shift\nto interstitium" color="#004d40"]
    FLUID_SHIFT -> HYPOTENSION [label="↓ preload" color="#f57f17"]
    VWF -> COAGULOPATHY [label="platelet\naggregation" color="#b71c1c"]
    COAGULOPATHY -> THROMBOSIS [color="#b71c1c"]

    // CRS grading
    IL6_FREE -> FEVER [label="hypothalamic\nPGE2" color="#f57f17" penwidth=2]
    IL1B -> FEVER [label="pyrogen" color="#f57f17"]
    TNFa_MAC -> FEVER [label="pyrogen" color="#f57f17"]
    FEVER -> CRS_G1 [label="fever only" color="#a5d6a7"]
    FEVER -> CRS_G2 [label="+ fluid-responsive\nhypotension/low-O2" color="#f9a825"]
    HYPOTENSION -> CRS_G2 [color="#f9a825"]
    HYPOTENSION -> CRS_G3 [label="vasopressors\nneeded" color="#e65100"]
    HYPOXIA -> CRS_G2 [color="#f9a825"]
    HYPOXIA -> CRS_G3 [label="high-flow O2" color="#e65100"]
    HYPOXIA -> CRS_G4 [label="intubation/\nECMO" color="#f44336"]
    CRS_G3 -> CRS_G4 [label="escalation" color="#f44336" style=dashed]
    TACHYCARDIA -> CRS_G1 [style=dashed color="#f57f17"]
    RIGORS -> FEVER [color="#ffa000"]
    IL6_FREE -> CYTOKINE_SCORE [color="#f57f17"]
    IFNg -> CYTOKINE_SCORE [color="#ff7043"]
    CRP -> CYTOKINE_SCORE [color="#795548"]
    FERRITIN_CRS -> CYTOKINE_SCORE [color="#795548"]

    // ICANS
    IL6_FREE -> BBB_BREACH [label="cytokine\ncrossing BBB" color="#283593"]
    IFNg -> BBB_BREACH [label="BBB disruption" color="#283593" penwidth=2]
    TNFa_MAC -> BBB_BREACH [label="tight junction\ndisruption" color="#283593"]
    BBB_INTACT -> BBB_BREACH [label="disrupted by\ncytokines" color="#3f51b5"]
    BBB_BREACH -> BRAIN_MACRO [label="macrophage\nactivation" color="#5c6bc0"]
    BBB_BREACH -> IL6_CNS [label="IL-6 enters CNS" color="#5c6bc0"]
    IL6_CNS -> BRAIN_MACRO [label="activate" color="#5c6bc0"]
    BRAIN_MACRO -> CEREBRAL_EDEMA [label="severe\nneuroinflam" color="#ef5350"]
    BBB_BREACH -> ICANS_G1 [color="#7986cb"]
    IL6_CNS -> ICANS_G2 [label="encephalopathy" color="#5c6bc0"]
    CEREBRAL_EDEMA -> ICANS_G3 [label="stupor/seizure" color="#f44336"]
    CEREBRAL_EDEMA -> ICANS_G4 [label="coma/ICH" color="#d32f2f"]
    ICE_SCORE -> ICANS_G1 [label="ICE 7-9" color="#a5d6a7"]
    ICE_SCORE -> ICANS_G2 [label="ICE 3-6" color="#f9a825"]
    ICE_SCORE -> ICANS_G3 [label="ICE 0-2" color="#e65100"]

    // Drug PK/PD
    TOCI_IV -> TOCI_C1 [label="distribute\nt½=11-13d" color="#4caf50"]
    TOCI_C1 -> TOCI_C2 [label="peripheral\ndist." color="#81c784"]
    TOCI_C2 -> TOCI_C1 [label="redistrib." color="#81c784"]
    TOCI_C1 -> TOCI_TMDD [label="IL-6R\nbinding" color="#26a69a"]
    TOCI_TMDD -> TOCI_PD [label="receptor\noccupancy" color="#4caf50"]
    TOCI_PD -> IL6_sIL6R [label="block\ntrans-signaling" color="#4caf50" penwidth=2 arrowhead=tee]
    TOCI_PD -> GP130 [label="block\ncis-signaling" color="#4caf50" penwidth=2 arrowhead=tee]
    TOCI_PD -> STAT3 [label="↓ pSTAT3" color="#4caf50" arrowhead=tee]

    SILT_IV -> SILT_C1 [label="distribute\nt½=21d" color="#26a69a"]
    SILT_C1 -> SILT_PD [label="neutralize" color="#26a69a"]
    SILT_PD -> IL6_FREE [label="neutralize\nIL-6 directly" color="#26a69a" penwidth=2 arrowhead=tee]

    DEX_IV -> DEX_C1 [label="distribute\nt½=3.5h" color="#2196f3"]
    DEX_C1 -> DEX_PD [label="GR binding" color="#2196f3"]
    DEX_PD -> IL6_MAC [label="↓ transcription\n(NF-κB↓)" color="#2196f3" arrowhead=tee]
    DEX_PD -> TNFa_MAC [label="↓ TNF-α" color="#2196f3" arrowhead=tee]
    DEX_PD -> IFNg [label="↓ IFN-γ\nproduction" color="#2196f3" arrowhead=tee]
    DEX_PD -> MAC_ACT [label="↓ macrophage\nactivation" color="#2196f3" arrowhead=tee]
    DEX_PD -> BBB_BREACH [label="stabilize\nBBB (ICANS)" color="#1565c0" arrowhead=tee]
    MEPRED_IV -> BBB_BREACH [label="ICANS: pulse\nsteroids" color="#1565c0" arrowhead=tee]

    RUX_PO -> RUX_C1 [label="oral abs\nt½=3h" color="#ff9800"]
    RUX_C1 -> RUX_C2 [color="#ffcc80"]
    RUX_C2 -> RUX_C1 [color="#ffcc80"]
    RUX_C1 -> RUX_PD [label="JAK1/2\ninhibition" color="#ff9800"]
    RUX_PD -> JAK1 [label="inhibit\n(Km=3.3 nM)" color="#ff9800" arrowhead=tee]
    RUX_PD -> JAK2 [label="inhibit" color="#ff9800" arrowhead=tee]
    RUX_PD -> STAT3 [label="↓ pSTAT3\n(refractory CRS)" color="#ff9800" arrowhead=tee]
    RUX_PD -> MAC_IFNg [label="JAK-STAT1\ninhibition" color="#ff9800" arrowhead=tee]

    ANA_SC -> ANA_C1 [label="SC abs\nt½=4-6h" color="#9c27b0"]
    ANA_C1 -> ANA_PD [label="IL-1R\nbinding" color="#9c27b0"]
    ANA_PD -> IL1B [label="block IL-1R\n(MAS pattern)" color="#9c27b0" penwidth=2 arrowhead=tee]
    ANA_PD -> NLRP3 [label="downstream\nblockade" color="#9c27b0" arrowhead=tee]

    // Outcomes
    CRS_G3 -> CARDIAC [label="cytokine\ncardiotoxicity" color="#b71c1c"]
    CRS_G3 -> HEPATIC [label="hepatic\ninjury" color="#b71c1c"]
    CRS_G3 -> RENAL [label="AKI from\nhypoperfusion" color="#b71c1c"]
    CRS_G4 -> RESP_FAIL [label="ARDS" color="#d32f2f" penwidth=2]
    CRS_G4 -> DIC [label="coagulopathy" color="#d32f2f"]
    THROMBOSIS -> DIC [color="#b71c1c"]
    COAGULOPATHY -> DIC [color="#b71c1c"]
    CRS_G4 -> HLH_OVERLAP [label="extreme CRS →\nHLH features" color="#d32f2f" penwidth=2]
    FERRITIN_CRS -> HLH_OVERLAP [label="ferritin >10000" color="#d32f2f" style=dashed]
    CYTOPENIA -> HLH_OVERLAP [label="hemophagocytosis" color="#b71c1c" style=dashed]
    CRS_G1 -> CRS_RESOLVE [label="supportive\ncare" color="#4caf50"]
    CRS_G2 -> CRS_RESOLVE [label="tocilizumab" color="#4caf50"]
    TOCI_PD -> CRS_RESOLVE [label="IL-6 blockade\n→ resolution" color="#4caf50" penwidth=2]
    DEX_PD -> CRS_RESOLVE [label="cytokine\nsuppression" color="#2196f3"]
    CRS_RESOLVE -> SURVIVAL [color="#4caf50"]
    CART_EXP -> EXPANSION_PEAK [label="peak cells/μL\n(Day 7-14)" color="#2e7d32"]
    EXPANSION_PEAK -> REMISSION [label="tumor killing" color="#4caf50"]
    BRIDGING_THERAPY -> TUMOR_BURDEN [label="↓ tumor\nburden" color="#ff9800" arrowhead=tee]
    TUMOR_BURDEN -> EXPANSION_PEAK [label="antigen\nstimulus" color="#e65100"]
    CART_ACT -> CYTOPENIA [label="lymphodepletion\nconditioning" color="#9e9e9e" style=dashed]

    // Positive feedback loops
    IL6_FREE -> MAC_ACT [label="IL-6 → macrophage\n(amplification)" color="#880e4f" style=dashed penwidth=1.5]
    IFNg -> GMCSF [label="synergy\nloop" color="#ff7043" style=dashed]
    CART_EXP -> IFNg [label="more CAR-T\n→ more IFN-γ" color="#ff7043" penwidth=1.5]
}
