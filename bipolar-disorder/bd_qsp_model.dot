digraph BipolarDisorder_QSP {
    graph [
        label="Bipolar Disorder – Quantitative Systems Pharmacology Model\nNeurotransmitter · Signal Transduction · HPA Axis · Neuroplasticity · Drug PK/PD"
        fontname="Helvetica" fontsize=18 fontcolor="#1a1a2e"
        bgcolor="#f8f9fa"
        rankdir=LR
        nodesep=0.4 ranksep=0.8
        splines=ortho
        overlap=false
    ]
    node [fontname="Helvetica" fontsize=10 style=filled penwidth=1.5]
    edge [fontname="Helvetica" fontsize=9 penwidth=1.2]

    /* ===================================================================
       CLUSTER 1: Neurotransmitter Systems
    =================================================================== */
    subgraph cluster_NT {
        label="Neurotransmitter Systems" style=filled fillcolor="#e8f4fd"
        color="#2196F3" fontcolor="#0d47a1" fontsize=13 penwidth=2

        // Dopamine pathway
        node [fillcolor="#bbdefb" color="#1976D2"]
        DA_synth [label="TH / AADC\n(DA synthesis)"]
        DA_vesicle [label="VMAT2\n(DA vesicle storage)"]
        DA_release [label="DA Release\n(presynaptic)"]
        DA_reuptake [label="DAT\n(DA reuptake)"]
        DA_D1R [label="D1/D5 Receptor\n(Gs-coupled)"]
        DA_D2R [label="D2/D3 Receptor\n(Gi-coupled)"]
        DA_MAO [label="MAO-A/B\n(DA degradation)"]
        COMT [label="COMT\n(DA/NE catabolism)"]
        DA_synaptic [label="Synaptic DA\n[concentration]" shape=diamond]

        // Serotonin pathway
        node [fillcolor="#e1bee7" color="#7b1fa2"]
        TRP [label="Tryptophan\n(5-HT precursor)"]
        TPH2 [label="TPH2\n(5-HT synthesis)"]
        SERT [label="SERT\n(5-HT reuptake)"]
        HT_5_1A [label="5-HT1A\n(autoreceptor)"]
        HT_5_2A [label="5-HT2A\n(postsynaptic)"]
        HT_5_release [label="5-HT Release\n(presynaptic)"]
        HT_5_synaptic [label="Synaptic 5-HT\n[concentration]" shape=diamond]

        // Norepinephrine pathway
        node [fillcolor="#fff9c4" color="#f57f17"]
        NE_synth [label="DBH\n(NE synthesis)"]
        NET [label="NET\n(NE reuptake)"]
        NE_alpha2 [label="α2-Adrenoceptor\n(presynaptic)"]
        NE_beta1 [label="β1-Adrenoceptor\n(postsynaptic)"]
        NE_synaptic [label="Synaptic NE\n[concentration]" shape=diamond]

        // GABA/Glutamate
        node [fillcolor="#c8e6c9" color="#2e7d32"]
        GAD [label="GAD65/67\n(GABA synthesis)"]
        GABA_A [label="GABA-A Receptor\n(Cl⁻ channel)"]
        GABA_B [label="GABA-B Receptor\n(Gi-coupled)"]
        GABA_T [label="GABA-T\n(GABA degradation)"]
        NMDA_R [label="NMDA Receptor\n(Ca²⁺/Mg²⁺ gated)"]
        AMPA_R [label="AMPA Receptor\n(Na⁺/K⁺ channel)"]
        mGluR5 [label="mGluR5\n(Gq-coupled)"]
        Glu_release [label="Glutamate Release\n(presynaptic)"]
        Glu_synaptic [label="Synaptic Glu\n[concentration]" shape=diamond]
    }

    /* ===================================================================
       CLUSTER 2: Second Messenger & Signal Transduction
    =================================================================== */
    subgraph cluster_signaling {
        label="Signal Transduction Pathways" style=filled fillcolor="#fff3e0"
        color="#FF9800" fontcolor="#e65100" fontsize=13 penwidth=2

        node [fillcolor="#ffe0b2" color="#ef6c00"]
        AC [label="Adenylyl Cyclase\n(cAMP production)"]
        cAMP [label="cAMP\n[2nd messenger]" shape=diamond]
        PKA [label="PKA\n(cAMP-dependent kinase)"]
        PDE [label="PDE\n(cAMP degradation)"]
        CREB [label="CREB\n(transcription factor)"]
        CREB_p [label="pCREB\n(phosphorylated)"]

        node [fillcolor="#ffccbc" color="#bf360c"]
        PLC [label="PLC-β\n(IP3/DAG production)"]
        IP3 [label="IP3\n[2nd messenger]" shape=diamond]
        DAG [label="DAG\n[2nd messenger]" shape=diamond]
        PKC [label="PKC\n(serine/threonine kinase)"]
        IP3R [label="IP3 Receptor\n(ER Ca²⁺ release)"]
        ER_Ca [label="ER Ca²⁺\n[calcium store]" shape=diamond]
        Cyto_Ca [label="Cytosolic Ca²⁺\n[free]" shape=diamond]
        CaMKII [label="CaMKII\n(Ca²⁺/CaM kinase)"]

        node [fillcolor="#fce4ec" color="#880e4f"]
        GSK3B [label="GSK-3β\n(active form)" shape=hexagon]
        GSK3B_p [label="p-GSK-3β (Ser9)\n(inactive)" shape=hexagon]
        AKT [label="AKT/PKB\n(PI3K downstream)"]
        PI3K [label="PI3K\n(phosphoinositide kinase)"]
        mTOR [label="mTORC1\n(protein synthesis)" shape=hexagon]
        MAPK_ERK [label="MAPK/ERK1/2\n(proliferation/survival)"]
        MAPK_p38 [label="p38 MAPK\n(stress/inflammation)"]
        JNK [label="JNK\n(c-Jun N-terminal kinase)"]
        RAS [label="RAS/RAF\n(MAPK upstream)"]
        IMPase [label="IMPase\n(inositol recycling)"]
        Inositol [label="Free Inositol\n[intracellular]" shape=diamond]
    }

    /* ===================================================================
       CLUSTER 3: Ion Channels & Membrane Excitability
    =================================================================== */
    subgraph cluster_ion {
        label="Ion Channels & Membrane Excitability" style=filled fillcolor="#e8eaf6"
        color="#3F51B5" fontcolor="#1a237e" fontsize=13 penwidth=2

        node [fillcolor="#c5cae9" color="#283593"]
        NaV [label="Voltage-gated Na⁺ ch\n(Nav1.1/1.2/1.6)"]
        KV [label="Voltage-gated K⁺ ch\n(Kv4/Kv7)"]
        CaV_L [label="L-type Ca²⁺ ch\n(Cav1.2/CACNA1C)"]
        CaV_N [label="N-type Ca²⁺ ch\n(Cav2.2)"]
        HCN [label="HCN (Ih)\n(pacemaker current)"]
        BK_channel [label="BK Ca²⁺-activated K⁺\n(large conductance)"]
        TREK [label="TREK-1 (K2P)\n(background K⁺)"]
        Vm [label="Membrane Potential\n(mV)" shape=diamond fillcolor="#9fa8da"]
        AP_freq [label="Action Potential\nFrequency" shape=diamond]
        Neuronal_excit [label="Neuronal Excitability\nIndex" shape=diamond]
    }

    /* ===================================================================
       CLUSTER 4: HPA Axis & Circadian Rhythms
    =================================================================== */
    subgraph cluster_HPA_circ {
        label="HPA Axis & Circadian Rhythms" style=filled fillcolor="#f3e5f5"
        color="#9C27B0" fontcolor="#4a148c" fontsize=13 penwidth=2

        node [fillcolor="#e1bee7" color="#6a1b9a"]
        // HPA axis
        CRH [label="CRH\n(hypothalamus)"]
        ACTH [label="ACTH\n(anterior pituitary)"]
        Cortisol [label="Cortisol\n[plasma]" shape=diamond]
        GR [label="GR\n(glucocorticoid receptor)"]
        GR_activated [label="GR-GC complex\n(transcriptionally active)"]
        HPA_feedback [label="Negative Feedback\n(hippocampus/PFC)"]

        // Circadian clock
        node [fillcolor="#ce93d8" color="#4a148c"]
        CLOCK [label="CLOCK/BMAL1\n(E-box transcription)"]
        PER1 [label="PER1/PER2\n(period genes)"]
        CRY [label="CRY1/CRY2\n(cryptochrome)"]
        REV_ERB [label="REV-ERBα\n(nuclear receptor)"]
        ROR [label="RORα/γ\n(activator)"]
        SCN [label="SCN\n(master clock)"]
        Melatonin [label="Melatonin\n(pineal)" shape=diamond]
        Sleep_pressure [label="Sleep Pressure\n(adenosine)" shape=diamond]
        Circ_phase [label="Circadian Phase\n(ZT)" shape=diamond]
    }

    /* ===================================================================
       CLUSTER 5: Neuroplasticity & Neuroprotection
    =================================================================== */
    subgraph cluster_neuroplast {
        label="Neuroplasticity & Neuroprotection" style=filled fillcolor="#e8f5e9"
        color="#4CAF50" fontcolor="#1b5e20" fontsize=13 penwidth=2

        node [fillcolor="#c8e6c9" color="#2e7d32"]
        BDNF [label="BDNF\n(Brain-derived NTF)" shape=diamond]
        proBDNF [label="proBDNF\n(precursor)"]
        TrkB [label="TrkB Receptor\n(BDNF receptor)"]
        p75NTR [label="p75NTR\n(pro-apoptotic)"]
        NGF [label="NGF\n(nerve growth factor)"]
        VEGF [label="VEGF\n(neurogenesis)"]
        FGF2 [label="FGF-2\n(neuroprotection)"]
        GDNF [label="GDNF\n(dopamine neuron survival)"]

        node [fillcolor="#a5d6a7" color="#1b5e20"]
        Neurogenesis [label="Hippocampal\nNeurogenesis Rate" shape=diamond]
        Synaptogenesis [label="Synaptogenesis\n(PSD-95, synapsin-I)"]
        Dendritic_spine [label="Dendritic Spine\nDensity" shape=diamond]
        Hippo_vol [label="Hippocampal Volume\n(relative)" shape=diamond]
        BCL2 [label="Bcl-2 / Bcl-xL\n(anti-apoptotic)"]
        BAX [label="BAX / BAD\n(pro-apoptotic)"]
        Apoptosis [label="Neuronal Apoptosis\nRate" shape=diamond]
    }

    /* ===================================================================
       CLUSTER 6: Neuroinflammation
    =================================================================== */
    subgraph cluster_inflam {
        label="Neuroinflammation" style=filled fillcolor="#fce4ec"
        color="#E91E63" fontcolor="#880e4f" fontsize=13 penwidth=2

        node [fillcolor="#f8bbd0" color="#c2185b"]
        Microglia_rest [label="Microglia\n(resting M2)"]
        Microglia_act [label="Microglia\n(activated M1)"]
        Astrocyte [label="Astrocyte\nActivation"]
        NFkB [label="NF-κB\n(transcription factor)"]
        IL6 [label="IL-6\n[plasma]" shape=diamond]
        IL1B [label="IL-1β\n(inflammasome)"]
        TNFa [label="TNF-α\n[plasma]" shape=diamond]
        IL10 [label="IL-10\n(anti-inflammatory)"]
        IL18 [label="IL-18\n(NLRP3 product)"]
        NLRP3 [label="NLRP3\nInflammasome"]
        CRP [label="hsCRP\n[biomarker]" shape=diamond]
        COX2 [label="COX-2\n(PGE2 production)"]
        PGE2 [label="PGE2\n(neuro-inflammation)"]
        IDO [label="IDO-1\n(Trp degradation)"]
        Kynurenine [label="Kynurenine\nPathway" shape=diamond]
        QUIN [label="Quinolinic acid\n(excitotoxin)"]
        ROS [label="Reactive Oxygen\nSpecies (ROS)" shape=diamond]
        Oxidative_stress [label="Oxidative Stress\nIndex" shape=diamond]
    }

    /* ===================================================================
       CLUSTER 7: Drug Mechanisms of Action
    =================================================================== */
    subgraph cluster_drug_MOA {
        label="Drug Mechanisms of Action" style=filled fillcolor="#e0f2f1"
        color="#009688" fontcolor="#004d40" fontsize=13 penwidth=2

        node [fillcolor="#b2dfdb" color="#00695c"]
        // Lithium
        Li_target_GSK [label="Lithium→\nGSK-3β Inhibition" shape=parallelogram]
        Li_target_IMPase [label="Lithium→\nIMPase Inhibition" shape=parallelogram]
        Li_target_Na [label="Lithium→\nNa⁺-K⁺-ATPase Modulation" shape=parallelogram]

        // Valproate
        VPA_Na [label="VPA→\nNa⁺ channel block" shape=parallelogram]
        VPA_GABA [label="VPA→\nGABA-T inhibition" shape=parallelogram]
        VPA_HDAC [label="VPA→\nHDAC inhibition" shape=parallelogram]
        VPA_GSK [label="VPA→\nGSK-3β inhibition" shape=parallelogram]

        // Lamotrigine
        LTG_Na [label="LTG→\nNa⁺ channel block\n(use-dependent)" shape=parallelogram]
        LTG_Ca [label="LTG→\nCa²⁺ channel block\n(N/P/Q-type)" shape=parallelogram]
        LTG_Glu [label="LTG→\nGlu release↓" shape=parallelogram]

        // Quetiapine
        QTP_D2 [label="QTP→\nD2R antagonism" shape=parallelogram]
        QTP_5HT2A [label="QTP→\n5-HT2A antagonism" shape=parallelogram]
        QTP_H1 [label="QTP→\nH1 antagonism\n(sedation)" shape=parallelogram]
        QTP_NET [label="QTP metabolite→\nNET inhibition" shape=parallelogram]

        // Aripiprazole
        ARI_D2 [label="ARI→\nD2R partial agonism" shape=parallelogram]
        ARI_5HT1A [label="ARI→\n5-HT1A partial agonism" shape=parallelogram]
        ARI_5HT2A [label="ARI→\n5-HT2A antagonism" shape=parallelogram]
    }

    /* ===================================================================
       CLUSTER 8: Drug Pharmacokinetics
    =================================================================== */
    subgraph cluster_PK {
        label="Drug Pharmacokinetics (PK)" style=filled fillcolor="#f1f8e9"
        color="#8BC34A" fontcolor="#33691e" fontsize=13 penwidth=2

        node [fillcolor="#dcedc8" color="#558b2f"]
        // Lithium PK
        Li_gut [label="Lithium\nGut [mmol]"]
        Li_central [label="Lithium\nCentral [mmol]"]
        Li_peripheral [label="Lithium\nPeripheral [mmol]"]
        Li_conc [label="Lithium\n[mEq/L]" shape=diamond]

        // Valproate PK
        VPA_gut [label="VPA\nGut [mg]"]
        VPA_central [label="VPA\nCentral [mg]"]
        VPA_free [label="VPA Free\n[mg/L]" shape=diamond]

        // Quetiapine PK
        QTP_gut [label="Quetiapine\nGut [mg]"]
        QTP_central [label="Quetiapine\nCentral [mg]"]
        QTP_metabolite [label="Norquetiapine\n(active metabolite) [ng/mL]" shape=diamond]
        QTP_conc [label="Quetiapine\n[ng/mL]" shape=diamond]

        // Lamotrigine PK
        LTG_gut [label="Lamotrigine\nGut [mg]"]
        LTG_central [label="Lamotrigine\nCentral [mg]"]
        LTG_conc [label="Lamotrigine\n[μg/mL]" shape=diamond]
    }

    /* ===================================================================
       CLUSTER 9: Clinical Endpoints & Biomarkers
    =================================================================== */
    subgraph cluster_endpoints {
        label="Clinical Endpoints & Biomarkers" style=filled fillcolor="#fff8e1"
        color="#FFC107" fontcolor="#e65100" fontsize=13 penwidth=2

        node [fillcolor="#ffecb3" color="#f57f17"]
        YMRS [label="YMRS Score\n(mania, 0–60)" shape=diamond]
        MADRS [label="MADRS Score\n(depression, 0–60)" shape=diamond]
        HAM_D [label="HAM-D Score\n(depression, 0–52)" shape=diamond]
        CGI_BP [label="CGI-BP\n(overall severity)" shape=diamond]
        GAF [label="GAF / FAST\n(functioning)" shape=diamond]
        Episode_freq [label="Episode Frequency\n(episodes/year)" shape=diamond]
        Episode_dur [label="Episode Duration\n(weeks)" shape=diamond]
        Response [label="Clinical Response\n(≥50% score↓)" shape=diamond]
        Remission [label="Remission\n(score threshold)" shape=diamond]

        node [fillcolor="#ffe082" color="#e65100"]
        // Biomarkers
        Li_serum [label="Serum Lithium\n[mEq/L]" shape=diamond]
        VPA_serum [label="Serum VPA\n[μg/mL]" shape=diamond]
        CK_serum [label="Serum CK\n(muscle)" shape=diamond]
        Thyroid_TSH [label="TSH\n(lithium effect)" shape=diamond]
        Renal_GFR [label="eGFR\n(lithium toxicity)" shape=diamond]
        Weight_gain [label="Body Weight\nChange (kg)" shape=diamond]
        QTc_interval [label="QTc Interval\n(cardiac safety)" shape=diamond]
    }

    /* ===================================================================
       CLUSTER 10: Genetic & Epigenetic Factors
    =================================================================== */
    subgraph cluster_genetics {
        label="Genetic & Epigenetic Factors" style=filled fillcolor="#e3f2fd"
        color="#2196F3" fontcolor="#0d47a1" fontsize=13 penwidth=2

        node [fillcolor="#bbdefb" color="#1565c0"]
        CACNA1C_gene [label="CACNA1C\n(rs1006737)"]
        ANK3_gene [label="ANK3\n(rs10994336)"]
        CLOCK_gene [label="CLOCK\n(rs1801260)"]
        BDNF_Val66Met [label="BDNF Val66Met\n(rs6265)"]
        SLC6A4 [label="SLC6A4 (5-HTTLPR)\n(SERT promoter)"]
        COMT_Val158Met [label="COMT Val158Met\n(rs4680)"]
        NRXN1 [label="NRXN1\n(synaptogenesis)"]

        node [fillcolor="#90caf9" color="#0d47a1"]
        DNA_methylation [label="DNA Methylation\n(CpG islands)"]
        Histone_ac [label="Histone Acetylation\n(VPA target)"]
        miRNA_134 [label="miR-134\n(LIMK1 regulation)"]
        miRNA_132 [label="miR-132\n(MeCP2/BDNF)"]
        Chromatin_remod [label="Chromatin Remodeling\n(SWI/SNF complex)"]
        Polygenic_risk [label="Polygenic Risk Score\n(PRS-BD)" shape=diamond]
    }

    /* ===================================================================
       CLUSTER 11: Brain Regions & Circuits
    =================================================================== */
    subgraph cluster_circuits {
        label="Brain Circuits & Regions" style=filled fillcolor="#efebe9"
        color="#795548" fontcolor="#3e2723" fontsize=13 penwidth=2

        node [fillcolor="#d7ccc8" color="#4e342e"]
        PFC [label="Prefrontal Cortex\n(executive function)"]
        ACC [label="Anterior Cingulate\nCortex (emotion)"]
        Amygdala [label="Amygdala\n(fear/reward)"]
        Hippocampus [label="Hippocampus\n(memory/HPA)"]
        Striatum [label="Striatum/NAc\n(reward circuit)"]
        VTA [label="VTA\n(DA source)"]
        Raphe [label="Raphe Nuclei\n(5-HT source)"]
        LC [label="Locus Coeruleus\n(NE source)"]
        Hypothalamus [label="Hypothalamus\n(HPA/circadian)"]
        Thalamus [label="Thalamus\n(relay/gating)"]
        Cerebellum [label="Cerebellum\n(mood/timing)"]
        Insula [label="Insula\n(interoception)"]
    }

    /* ===================================================================
       CLUSTER 12: Gut-Brain Axis & Metabolic Effects
    =================================================================== */
    subgraph cluster_gutbrain {
        label="Gut-Brain Axis & Metabolic Effects" style=filled fillcolor="#f9fbe7"
        color="#AFB42B" fontcolor="#827717" fontsize=13 penwidth=2

        node [fillcolor="#f0f4c3" color="#9e9d24"]
        Gut_microbiome [label="Gut Microbiome\n(diversity index)"]
        Gut_barrier [label="Gut Barrier\n(permeability)"]
        LPS [label="LPS / Endotoxin\n(systemic)"]
        SCFA [label="Short-chain FA\n(butyrate/propionate)"]
        Vagal_nerve [label="Vagal Nerve\n(gut-brain signal)"]
        Insulin_resist [label="Insulin Resistance\n(HOMA-IR)"]
        Adiponectin [label="Adiponectin\n(metabolic)" shape=diamond]
        Leptin [label="Leptin\n(appetite/mood)" shape=diamond]
        Ghrelin [label="Ghrelin\n(hunger hormone)" shape=diamond]
        MetS_risk [label="Metabolic Syndrome\nRisk" shape=diamond]
    }

    /* ===================================================================
       EDGES — Neurotransmitter wiring
    =================================================================== */
    DA_synth -> DA_vesicle [label="storage" color="#1976D2"]
    DA_vesicle -> DA_release [label="exocytosis" color="#1976D2"]
    DA_release -> DA_synaptic [color="#1976D2"]
    DA_synaptic -> DA_D1R [label="activation" color="#1976D2"]
    DA_synaptic -> DA_D2R [label="activation" color="#1976D2"]
    DA_synaptic -> DA_reuptake [label="clearance" color="#1976D2"]
    DA_reuptake -> DA_synth [label="recycling" style=dashed color="#1976D2"]
    DA_synaptic -> DA_MAO [label="degradation" color="#1976D2"]
    COMT -> DA_MAO [style=dashed color="#1976D2"]

    TRP -> TPH2 -> HT_5_release -> HT_5_synaptic [color="#7b1fa2"]
    HT_5_synaptic -> HT_5_1A [label="autoreceptor" color="#7b1fa2"]
    HT_5_synaptic -> HT_5_2A [label="postsynaptic" color="#7b1fa2"]
    HT_5_synaptic -> SERT [label="reuptake" color="#7b1fa2"]
    HT_5_1A -> HT_5_release [label="↓ feedback" style=dashed color="#7b1fa2" arrowhead=tee]

    NE_synth -> NE_synaptic [color="#f57f17"]
    NE_synaptic -> NE_alpha2 [label="autoreceptor" color="#f57f17"]
    NE_synaptic -> NE_beta1 [color="#f57f17"]
    NE_synaptic -> NET [label="reuptake" color="#f57f17"]
    NE_alpha2 -> NE_synth [label="↓ feedback" style=dashed arrowhead=tee color="#f57f17"]

    GAD -> GABA_A [color="#2e7d32"]
    GAD -> GABA_B [color="#2e7d32"]
    GABA_A -> Neuronal_excit [label="↓ excitability" arrowhead=tee color="#2e7d32"]
    GABA_T -> GAD [label="recycled GABA" style=dashed color="#2e7d32"]
    Glu_release -> Glu_synaptic [color="#1b5e20"]
    Glu_synaptic -> NMDA_R [color="#1b5e20"]
    Glu_synaptic -> AMPA_R [color="#1b5e20"]
    Glu_synaptic -> mGluR5 [color="#1b5e20"]
    NMDA_R -> Neuronal_excit [label="↑ excitability" color="#1b5e20"]

    /* Signal transduction */
    DA_D1R -> AC [label="Gs→↑cAMP" color="#ef6c00"]
    DA_D2R -> AC [label="Gi→↓cAMP" arrowhead=tee color="#ef6c00"]
    AC -> cAMP [color="#ef6c00"]
    cAMP -> PKA [color="#ef6c00"]
    PKA -> CREB [label="phosphorylates" color="#ef6c00"]
    CREB -> CREB_p [color="#ef6c00"]
    PDE -> cAMP [label="degrades" arrowhead=tee color="#ef6c00"]

    HT_5_2A -> PLC [label="Gq" color="#bf360c"]
    mGluR5 -> PLC [label="Gq" color="#bf360c"]
    PLC -> IP3 [color="#bf360c"]
    PLC -> DAG [color="#bf360c"]
    IP3 -> IP3R [color="#bf360c"]
    IP3R -> ER_Ca [label="releases" color="#bf360c"]
    ER_Ca -> Cyto_Ca [color="#bf360c"]
    Cyto_Ca -> CaMKII [color="#bf360c"]
    DAG -> PKC [color="#bf360c"]
    IP3 -> IMPase [label="recycled by" style=dashed color="#bf360c"]
    IMPase -> Inositol [label="→ free inositol" color="#bf360c"]

    PKA -> AKT [label="cross-talk" style=dashed]
    PI3K -> AKT [color="#880e4f"]
    AKT -> GSK3B_p [label="inactivates (Ser9)" color="#880e4f"]
    AKT -> mTOR [label="activates" color="#880e4f"]
    GSK3B -> mTOR [arrowhead=tee color="#880e4f"]
    GSK3B -> CREB_p [arrowhead=tee label="↓ CREB" color="#880e4f"]
    GSK3B -> BCL2 [arrowhead=tee color="#880e4f"]
    RAS -> MAPK_ERK [color="#880e4f"]
    MAPK_ERK -> CREB_p [label="phosphorylates" color="#880e4f"]

    /* Ion channels and Vm */
    NaV -> Vm [color="#283593"]
    KV -> Vm [arrowhead=tee color="#283593"]
    CaV_L -> Cyto_Ca [label="Ca²⁺ influx" color="#283593"]
    CaV_N -> Cyto_Ca [color="#283593"]
    Vm -> AP_freq [color="#283593"]
    AP_freq -> Neuronal_excit [color="#283593"]
    HCN -> Vm [color="#283593"]
    BK_channel -> Vm [arrowhead=tee color="#283593"]

    /* HPA & Circadian */
    CRH -> ACTH [label="portal blood" color="#6a1b9a"]
    ACTH -> Cortisol [label="adrenal" color="#6a1b9a"]
    Cortisol -> GR [color="#6a1b9a"]
    GR -> GR_activated [color="#6a1b9a"]
    GR_activated -> HPA_feedback [label="↑ negative FB" color="#6a1b9a"]
    HPA_feedback -> CRH [arrowhead=tee color="#6a1b9a"]
    Cortisol -> GSK3B [label="↑ activity" color="#6a1b9a"]
    Cortisol -> BDNF [arrowhead=tee label="↓ BDNF" color="#6a1b9a"]

    CLOCK -> PER1 [label="activates" color="#4a148c"]
    CLOCK -> CRY [label="activates" color="#4a148c"]
    PER1 -> CLOCK [arrowhead=tee label="represses" style=dashed color="#4a148c"]
    CRY -> CLOCK [arrowhead=tee label="represses" style=dashed color="#4a148c"]
    CLOCK -> REV_ERB [color="#4a148c"]
