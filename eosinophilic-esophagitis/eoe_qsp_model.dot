digraph EoE_QSP {
  graph [
    rankdir=LR,
    fontname="Helvetica",
    fontsize=11,
    bgcolor="#FAFAFA",
    label="Eosinophilic Esophagitis (EoE) QSP Mechanistic Map\nFood Allergen Sensitization → Th2 Inflammation → Eosinophil Recruitment → Epithelial Disruption → Tissue Remodeling",
    labelloc=t,
    labeljust=c,
    splines=curved,
    nodesep=0.35,
    ranksep=0.9,
    pad=0.5
  ]
  node [shape=box, style="rounded,filled", fontname="Helvetica", fontsize=8]
  edge [fontname="Helvetica", fontsize=7, arrowsize=0.7]

  // =====================================================================
  // CLUSTER 1: Environmental Triggers & Allergens
  // =====================================================================
  subgraph cluster_triggers {
    label="Environmental Triggers & Allergens"
    style=filled; fillcolor="#FFF3E0"; color="#E65100"; penwidth=2
    fontcolor="#E65100"; fontsize=10

    FA_MILK   [label="Milk Protein\n(Casein, Whey)", fillcolor="#FFE0B2"]
    FA_WHEAT  [label="Wheat Gluten\n(Gliadin)", fillcolor="#FFE0B2"]
    FA_EGG    [label="Egg Protein\n(Ovalbumin)", fillcolor="#FFE0B2"]
    FA_SOY    [label="Soy Protein\n(Gly m)", fillcolor="#FFE0B2"]
    FA_NUTS   [label="Tree Nuts/\nPeanuts", fillcolor="#FFE0B2"]
    FA_SEAFOOD [label="Seafood\nAllergens", fillcolor="#FFE0B2"]
    AERO      [label="Aeroallergens\n(Grass/Tree Pollen)", fillcolor="#FFCC80"]
    MICR      [label="Gut/Esophageal\nMicrobiome Dysbiosis", fillcolor="#FFCC80"]
    ACID_GERD [label="Gastric Acid\n(GERD Co-morbidity)", fillcolor="#FFCC80"]
    DIET_WEST [label="Western Diet\n(Low Fiber/High Fat)", fillcolor="#FFE0B2"]
    GENETIC   [label="Genetic Susceptibility\n(TSLP, DSG1, FLG loci)", fillcolor="#FFCC80"]
    SENS      [label="Allergen\nSensitization\n(IgE-mediated)", fillcolor="#FF8C00", fontcolor="white", style="rounded,filled,bold"]
  }

  // =====================================================================
  // CLUSTER 2: Esophageal Epithelium & Barrier
  // =====================================================================
  subgraph cluster_epithelium {
    label="Esophageal Epithelium & Barrier Dysfunction"
    style=filled; fillcolor="#E8F5E9"; color="#2E7D32"; penwidth=2
    fontcolor="#2E7D32"; fontsize=10

    EPITH     [label="Esophageal Squamous\nEpithelium", fillcolor="#C8E6C9", style="rounded,filled,bold"]
    DESMOG1   [label="Desmoglein-1\n(DSG1) ↓", fillcolor="#A5D6A7"]
    FILLAG    [label="Filaggrin (FLG) ↓\n(Barrier Protein)", fillcolor="#A5D6A7"]
    INVOLUCRIN [label="Involucrin ↓\n(Cornified Envelope)", fillcolor="#A5D6A7"]
    OCCLUDIN  [label="Occludin/Claudin\n(Tight Junctions) ↓", fillcolor="#A5D6A7"]
    CALPAIN14 [label="Calpain-14\n(Protease ↑)", fillcolor="#EF9A9A"]
    DSG_CLEAVE [label="DSG1 Cleavage\n→ Barrier Disruption", fillcolor="#EF9A9A"]
    EPBAR     [label="Epithelial Barrier\nIntegrity\n(TEER ↓)", shape=diamond, fillcolor="#66BB6A", style="rounded,filled,bold"]
    SPONGE    [label="Spongiosis\n(Dilated Intercellular\nSpaces, DIS)", fillcolor="#A5D6A7"]
    ANTHIS    [label="Antigen Uptake\n& Presentation ↑", fillcolor="#81C784"]
    EOTAX3_EP [label="Eotaxin-3 (CCL26)\nEpithelial Production", fillcolor="#43A047", fontcolor="white"]
    PERIOSTIN [label="Periostin (POSTN)\nExpression ↑", fillcolor="#A5D6A7"]
    TSLP_EP   [label="TSLP Production\n(Epithelial Alarmin)", fillcolor="#81C784"]
    IL33_EP   [label="IL-33 Release\n(Epithelial Alarmin)", fillcolor="#81C784"]
    IL25_EP   [label="IL-25 (IL-17E)\nRelease", fillcolor="#A5D6A7"]
    DIL_INT_SP [label="Dilated Intercellular\nSpaces (DIS)\n(Diagnostic Feature)", fillcolor="#C8E6C9"]
    BASAL_ZONE [label="Basal Zone\nHyperplasia", fillcolor="#A5D6A7"]
    PAPILLA   [label="Elongated\nEpithelial Papillae", fillcolor="#A5D6A7"]
  }

  // =====================================================================
  // CLUSTER 3: Innate Immune System
  // =====================================================================
  subgraph cluster_innate {
    label="Innate Immune System"
    style=filled; fillcolor="#E3F2FD"; color="#1565C0"; penwidth=2
    fontcolor="#1565C0"; fontsize=10

    DC_IMMATURE [label="Immature\nDendritic Cells", fillcolor="#BBDEFB"]
    DC_MATURE  [label="Mature DCs\n(MHC-II hi, CD80/86 hi)", fillcolor="#90CAF9", style="rounded,filled,bold"]
    pDC        [label="Plasmacytoid DCs\n(pDC, IFN-α source)", fillcolor="#BBDEFB"]
    ILC2       [label="ILC2s\n(GATA3+, CRTH2+)", fillcolor="#64B5F6", style="rounded,filled,bold"]
    ILC3       [label="ILC3s\n(IL-22 source)", fillcolor="#BBDEFB"]
    NK_CELL    [label="NK Cells\n(Cytotoxicity)", fillcolor="#BBDEFB"]
    MACRO_M2   [label="M2 Macrophages\n(IL-10, TGF-β)", fillcolor="#90CAF9"]
    NEUTRO     [label="Neutrophils\n(Acute phase)", fillcolor="#BBDEFB"]
    TSLPR_ILC2 [label="TSLPR/IL-7Rα\n(TSLP Receptor)", fillcolor="#BBDEFB"]
    ST2_ILC2   [label="ST2 (IL-33R)\non ILC2", fillcolor="#BBDEFB"]
    IL17RA     [label="IL-25R (IL-17RA)\non ILC2", fillcolor="#BBDEFB"]
  }

  // =====================================================================
  // CLUSTER 4: Adaptive Immunity (T & B cells)
  // =====================================================================
  subgraph cluster_adaptive {
    label="Adaptive Immune System"
    style=filled; fillcolor="#F3E5F5"; color="#6A1B9A"; penwidth=2
    fontcolor="#6A1B9A"; fontsize=10

    NAIVE_T   [label="Naive CD4+ T Cells\n(TCR activation)", fillcolor="#E1BEE7"]
    TH2_CELL  [label="Th2 Cells\n(GATA3+, IL-4+)", fillcolor="#CE93D8", style="rounded,filled,bold"]
    TH1_CELL  [label="Th1 Cells\n(T-bet+, IFN-γ+)", fillcolor="#E1BEE7"]
    TH17_CELL [label="Th17 Cells\n(RORγt+, IL-17+)", fillcolor="#E1BEE7"]
    TREG_CELL [label="Regulatory T Cells\n(FOXP3+, IL-10+, TGF-β+)", fillcolor="#A5D6A7"]
    TFH_CELL  [label="Tfh Cells\n(CXCR5+, PD-1+, BCL-6+)", fillcolor="#CE93D8"]
    CD8_T     [label="CD8+ Cytotoxic\nT Cells", fillcolor="#E1BEE7"]
    BCELL_GC  [label="Germinal Center\nB Cells", fillcolor="#CE93D8"]
    BCELL_MEM [label="Memory B Cells\n(IgE class switch)", fillcolor="#CE93D8"]
    PLASMA_CE [label="IgE-Secreting\nPlasma Cells", fillcolor="#BA68C8", fontcolor="white"]
    IGE_TOT   [label="Total Serum IgE\n(↑ in EoE ~200-500 IU/mL)", fillcolor="#AB47BC", fontcolor="white", style="rounded,filled,bold"]
    SIGE_FOOD [label="Food-Specific IgE\n(sIgE, RAST+)", fillcolor="#AB47BC", fontcolor="white"]
    FCERI     [label="FcεRI High-Affinity\nIgE Receptor\n(Mast cells/Basophils)", fillcolor="#CE93D8"]
  }

  // =====================================================================
  // CLUSTER 5: Cytokine Network
  // =====================================================================
  subgraph cluster_cytokines {
    label="Cytokine & Chemokine Network (Th2-dominant)"
    style=filled; fillcolor="#FFFDE7"; color="#F57F17"; penwidth=2
    fontcolor="#F57F17"; fontsize=10

    TSLP_CYT  [label="TSLP\n(Thymic Stromal\nLymphopoietin)", fillcolor="#FFF176", style="rounded,filled,bold"]
    IL33_CYT  [label="IL-33\n(Alarmin)", fillcolor="#FFF176", style="rounded,filled,bold"]
    IL25_CYT  [label="IL-25 (IL-17E)\n(Alarmin)", fillcolor="#FFF176"]
    IL4_CYT   [label="IL-4\n(Th2 master)", fillcolor="#FFE082", style="rounded,filled,bold"]
    IL13_CYT  [label="IL-13\n(Key effector)", fillcolor="#FFD54F", style="rounded,filled,bold"]
    IL5_CYT   [label="IL-5\n(Eosinopoietin)", fillcolor="#FFCA28", style="rounded,filled,bold"]
    IL9_CYT   [label="IL-9\n(Mast cell growth)", fillcolor="#FFF176"]
    IL10_CYT  [label="IL-10\n(Anti-inflammatory)", fillcolor="#C8E6C9"]
    IL31_CYT  [label="IL-31\n(Pruritus/Itch)", fillcolor="#FFF176"]
    IL6_CYT   [label="IL-6\n(Acute phase)", fillcolor="#FFF9C4"]
    TGFB_CYT  [label="TGF-β\n(Profibrotic)", fillcolor="#FFF176"]
    TNF_CYT   [label="TNF-α\n(Inflammation)", fillcolor="#FFF9C4"]
    IFNG_CYT  [label="IFN-γ\n(Th1 counter)", fillcolor="#C8E6C9"]
    EOTAX1    [label="Eotaxin-1 (CCL11)\n(Systemic)", fillcolor="#FFE082"]
    EOTAX3    [label="Eotaxin-3 (CCL26)\n(KEY EoE Biomarker)", fillcolor="#FF8F00", fontcolor="white", style="rounded,filled,bold"]
    IL4R_ALPHA [label="IL-4Rα\n(Shared IL-4/IL-13\nReceptor Subunit)", shape=diamond, fillcolor="#FFB300", style="rounded,filled,bold"]
    IL13R_A1  [label="IL-13Rα1\n(IL-13 Receptor\nComplex)", fillcolor="#FFA000"]
    JAK1_SIGN [label="JAK1/JAK2\nSignaling\nActivation", fillcolor="#FF8F00"]
    STAT6_P   [label="pSTAT6\n(Phospho-STAT6)\nTranscription Factor", fillcolor="#FF6F00", fontcolor="white", style="rounded,filled,bold"]
    TSLP_TSLPR [label="TSLP→TSLPR\nSignaling Axis", fillcolor="#FFF176"]
  }

  // =====================================================================
  // CLUSTER 6: Eosinophil Biology
  // =====================================================================
  subgraph cluster_eosinophil {
    label="Eosinophil Biology & Activation"
    style=filled; fillcolor="#FFEBEE"; color="#B71C1C"; penwidth=2
    fontcolor="#B71C1C"; fontsize=10

    EOP_BM    [label="Eosinophil Progenitors\n(EoPs)\nBone Marrow", fillcolor="#FFCDD2"]
    EOS_MATURE [label="Mature Eosinophils\n(Bone Marrow)", fillcolor="#EF9A9A"]
    EOS_BL    [label="Peripheral Blood\nEosinophils\n(Normal: 100-300/µL)", fillcolor="#E57373", style="rounded,filled,bold"]
    EOS_ESO   [label="Esophageal Mucosal\nEosinophils\n(Peak eos/hpf)\nActive EoE: >15/hpf", fillcolor="#EF5350", fontcolor="white", style="rounded,filled,bold"]
    EOS_ACT   [label="Activated\nEosinophils\n(Degranulating)", fillcolor="#D32F2F", fontcolor="white"]
    MBP_GRAN  [label="Major Basic Protein\n(MBP) Release\n→ Epithelial Toxicity", fillcolor="#EF9A9A"]
    EPX_GRAN  [label="Eosinophil Peroxidase\n(EPX) → Oxidative Damage", fillcolor="#EF9A9A"]
    ECP_GRAN  [label="Eosinophil Cationic\nProtein (ECP)\n→ Neurotoxicity", fillcolor="#EF9A9A"]
    EDN_GRAN  [label="Eosinophil-Derived\nNeurotoxin (EDN)", fillcolor="#FFCDD2"]
    CCR3_EOS  [label="CCR3 Receptor\n(Eotaxin-3 Receptor)\non Eosinophils", fillcolor="#EF9A9A"]
    SIGLEC8   [label="Siglec-8\n(Inhibitory Receptor)\nTherapeutic Target", fillcolor="#FFCDD2"]
    EOS_TRAP  [label="Eosinophil Extracellular\nTraps (EETs)", fillcolor="#FFCDD2"]
    IL5RA_EOS [label="IL-5Rα\n(IL-5 Receptor\non Eosinophils)", fillcolor="#EF9A9A"]
    EOS_VEGF  [label="VEGF Release\n(Angiogenesis)", fillcolor="#FFCDD2"]
    EOS_EXOSOME [label="Exosomes\n(miRNA, lipids)", fillcolor="#FFCDD2"]
  }

  // =====================================================================
  // CLUSTER 7: Mast Cell & Basophil Axis
  // =====================================================================
  subgraph cluster_mast {
    label="Mast Cell & Basophil Activation"
    style=filled; fillcolor="#F9FBE7"; color="#827717"; penwidth=2
    fontcolor="#827717"; fontsize=10

    MAST_ESO  [label="Esophageal Mast Cells\n(↑ 20-50× in EoE)", fillcolor="#F0F4C3", style="rounded,filled,bold"]
    BASO_BL   [label="Peripheral Blood\nBasophils", fillcolor="#DCE775"]
    HIST_MC   [label="Histamine Release\n(Vasoactive)", fillcolor="#CDDC39"]
    LTC4_MC   [label="Leukotriene C4\n(LTC4) Release", fillcolor="#CDDC39"]
    PGD2_MC   [label="Prostaglandin D2\n(PGD2) Release", fillcolor="#CDDC39"]
    PAF_MC    [label="Platelet Activating\nFactor (PAF)", fillcolor="#DCE775"]
    TRYPT_MC  [label="Tryptase\n(Mast Cell Marker)", fillcolor="#DCE775"]
    SCF_KIT   [label="Stem Cell Factor\n(SCF/KIT Ligand)\n→ Mast Cell Survival", fillcolor="#F0F4C3"]
    KIT_MAST  [label="KIT Receptor\n(CD117, c-Kit)\non Mast Cells", fillcolor="#F0F4C3"]
    IL4_MC    [label="IL-4 from\nMast Cells\n(Secondary source)", fillcolor="#FFF9C4"]
    IL5_MC    [label="IL-5 from\nMast Cells", fillcolor="#FFF9C4"]
    TGFB_MC   [label="TGF-β from\nMast Cells\n→ Fibrosis", fillcolor="#F0F4C3"]
    CHYMASE   [label="Chymase\n(Serine Protease)", fillcolor="#DCE775"]
  }

  // =====================================================================
  // CLUSTER 8: Tissue Remodeling & Structural Changes
  // =====================================================================
  subgraph cluster_remodeling {
    label="Tissue Remodeling & Structural Complications"
    style=filled; fillcolor="#ECEFF1"; color="#37474F"; penwidth=2
    fontcolor="#37474F"; fontsize=10

    FIBRO_ACT [label="Activated\nFibroblasts/\nMyofibroblasts", fillcolor="#CFD8DC"]
    COLLAGEN  [label="Collagen I/III\nDeposition", fillcolor="#B0BEC5"]
    LP_FIBRO  [label="Lamina Propria\nFibrosis\n(LP Fibrosis Score)", shape=diamond, fillcolor="#90A4AE", style="rounded,filled,bold"]
    SMOOTH_HYPER [label="Smooth Muscle\nHypertrophy", fillcolor="#CFD8DC"]
    BM_THICK  [label="Basement Membrane\nThickening", fillcolor="#B0BEC5"]
    ANGIO_VEGF [label="Angiogenesis\n(↑ Vascularity)", fillcolor="#CFD8DC"]
    STRICTURE [label="Esophageal Stricture\n/Narrowing", shape=diamond, fillcolor="#546E7A", fontcolor="white", style="rounded,filled,bold"]
    MMP_FIBRO [label="MMPs\n(Remodeling\nEnzymes)", fillcolor="#B0BEC5"]
    TIMP_INHIB [label="TIMPs\n(MMP Inhibitors)", fillcolor="#CFD8DC"]
    PERIOSTIN_F [label="Periostin\n(Fibrosis Promoter)", fillcolor="#B0BEC5"]
    TGFB_FIBRO [label="TGF-β Signaling\n(SMAD2/3)", fillcolor="#90A4AE"]
    SMAD_PATH [label="SMAD2/3\nPhosphorylation\n(Fibrotic cascade)", fillcolor="#78909C", fontcolor="white"]
  }

  // =====================================================================
  // CLUSTER 9: Clinical Endpoints & Biomarkers
  // =====================================================================
  subgraph cluster_endpoints {
    label="Clinical Endpoints & Biomarkers"
    style=filled; fillcolor="#E8EAF6"; color="#283593"; penwidth=2
    fontcolor="#283593"; fontsize=10

    DYSPHAG   [label="Dysphagia Score\n(DSQ: 0-84)", shape=diamond, fillcolor="#7986CB", fontcolor="white", style="rounded,filled,bold"]
    FOOD_IMP  [label="Food Impaction\nEvents (FIE)\n(Require endoscopy)", shape=diamond, fillcolor="#5C6BC0", fontcolor="white"]
    NAUSEA_EP [label="Nausea/Vomiting\n/Regurgitation", fillcolor="#9FA8DA"]
    CHEST_PAIN [label="Chest Pain\n/Heartburn", fillcolor="#9FA8DA"]
    EREFS     [label="EoE Endoscopic\nReference Score\n(EREFS: 0-18)", shape=diamond, fillcolor="#3949AB", fontcolor="white", style="rounded,filled,bold"]
    RINGS_ENDO [label="Esophageal Rings\n(Trachealization)\nERFS: 0-3", fillcolor="#9FA8DA"]
    EXUDATE_ENDO [label="White Exudates\n(Plaques)\nERFS: 0-2", fillcolor="#9FA8DA"]
    EDEMA_ENDO [label="Mucosal Edema\n(Vascular Markings)\nERFS: 0-2", fillcolor="#9FA8DA"]
    FURROWS_ENDO [label="Longitudinal\nFurrows\nERFS: 0-2", fillcolor="#9FA8DA"]
    STRICT_ENDO [label="Stricture\n(Endoscopic)\nERFS: 0-2", fillcolor="#9FA8DA"]
    PEAK_EOS  [label="Peak Eosinophil\nCount (eos/hpf)\n[HISTOLOGIC ENDPOINT]", shape=diamond, fillcolor="#1A237E", fontcolor="white", style="rounded,filled,bold"]
    EOS_SS_SCR [label="EoE Symptom Score\n(EoE-SS: 0-10)", shape=diamond, fillcolor="#5C6BC0", fontcolor="white"]
    EOES_DX   [label="EoE Diagnosis\n(eos/hpf ≥15 +\nclinical symptoms)", shape=diamond, fillcolor="#283593", fontcolor="white", style="rounded,filled,bold"]
    HISTO_REMIS [label="Histological\nRemission\n(Peak eos/hpf <15)", shape=diamond, fillcolor="#3949AB", fontcolor="white"]
    QUAL_LIFE [label="EoE Quality of Life\n(EoE-QoL-A Score)", shape=diamond, fillcolor="#7986CB", fontcolor="white"]
    BL_EOS_BM [label="Blood Eosinophil\nAbsolute Count\n(Biomarker)", shape=diamond, fillcolor="#9FA8DA"]
    SERUM_IgE [label="Total Serum IgE\n(IU/mL, ↑ in EoE)", shape=diamond, fillcolor="#9FA8DA"]
    EOTAX3_SER [label="Serum Eotaxin-3\n(CCL26 biomarker)", shape=diamond, fillcolor="#9FA8DA"]
    TRYPT_SER [label="Serum Tryptase\n(Mast cell marker)", shape=diamond, fillcolor="#9FA8DA"]
    MBP_URINE [label="Urine MBP\n(Eosinophil activation)", shape=diamond, fillcolor="#9FA8DA"]
  }

  // =====================================================================
  // CLUSTER 10: Drug PK/PD Mechanisms
  // =====================================================================
  subgraph cluster_drugs {
    label="Drug PK/PD — Therapeutic Interventions"
    style=filled; fillcolor="#FCE4EC"; color="#880E4F"; penwidth=2
    fontcolor="#880E4F"; fontsize=10

    // PPI
    PPI_DRUG  [label="Proton Pump Inhibitors\n(Omeprazole/Esomeprazole)\nPPI-REE trial", fillcolor="#F8BBD0"]
    PPI_CONC  [label="PPI\n[Esophageal/Systemic]", fillcolor="#F48FB1"]

    // Swallowed Corticosteroid
    SWALLOW_CS [label="Swallowed Corticosteroids\n(Budesonide OD tablet/\nViscous susp., Fluticasone)\nFirst-line therapy", fillcolor="#F8BBD0", style="rounded,filled,bold"]
    BUD_ESO_C  [label="Budesonide\n[Esophageal]\nCmax ~30-80 ng/mL", fillcolor="#F48FB1"]
    BUD_SYS_C  [label="Budesonide\n[Systemic]\n(Adrenal suppression risk)", fillcolor="#F48FB1"]
    GR_SIGNAL  [label="Glucocorticoid Receptor\n(GR) Activation\n→ Anti-inflammatory gene\ntranscription", fillcolor="#E91E8C", fontcolor="white"]

    // Dupilumab
    DUPILUMAB  [label="DUPILUMAB\n(Dupixent®)\nAnti-IL-4Rα mAb\n300mg SC q2w\nFDA approved 2022", fillcolor="#AD1457", fontcolor="white", style="rounded,filled,bold"]
    DUP_SC_D   [label="Dupilumab\n[SC Depot]", fillcolor="#F48FB1"]
    DUP_CENT   [label="Dupilumab\n[Central]\nCss,trough ~60-90 µg/mL", fillcolor="#F48FB1"]
    DUP_PERIPH [label="Dupilumab\n[Peripheral]", fillcolor="#F48FB1"]
    DUP_IL4RA  [label="Dupilumab-IL-4Rα\nComplex\n(Blocks IL-4 & IL-13)", fillcolor="#880E4F", fontcolor="white", style="rounded,filled,bold"]

    // Mepolizumab
    MEPO_DRUG  [label="MEPOLIZUMAB\n(Nucala®)\nAnti-IL-5 mAb\n300mg SC q4w\n(EoE Phase 2)", fillcolor="#AD1457", fontcolor="white"]
    MEPO_SC_D  [label="Mepolizumab\n[SC Depot]", fillcolor="#F48FB1"]
    MEPO_CENT  [label="Mepolizumab\n[Central]\nCss,trough ~30 µg/mL", fillcolor="#F48FB1"]
    MEPO_IL5C  [label="Mepolizumab-IL-5\nComplex", fillcolor="#880E4F", fontcolor="white"]

    // Cendakimab
    CENDA_DRUG [label="CENDAKIMAB\n(RPC4046)\nAnti-IL-13 (oral)\n160mg QD\nPhase 3 CACTUS trial", fillcolor="#AD1457", fontcolor="white"]
    CENDA_GUT_C [label="Cendakimab\n[GI Absorption]", fillcolor="#F48FB1"]
    CENDA_CENT [label="Cendakimab\n[Central]\nCmax ~0.5-1 µg/mL", fillcolor="#F48FB1"]
    CENDA_IL13C [label="Cendakimab-IL-13\nComplex", fillcolor="#880E4F", fontcolor="white"]

    // Benralizumab
    BENRA_DRUG [label="BENRALIZUMAB\n(Fasenra®)\nAnti-IL-5Rα mAb\n30mg SC q4w\n(MESSINA Phase 3)", fillcolor="#AD1457", fontcolor="white"]
    IL5RA_BLOCK [label="IL-5Rα Blockade\n(ADCC-mediated\nEosinophil Depletion)", fillcolor="#880E4F", fontcolor="white"]

    // Dietary
    DIETARY_EL [label="Dietary Elimination\nSFED (6-food)\nOne-Food (milk)\nElemental Formula", fillcolor="#F8BBD0", style="rounded,filled,bold"]
    DIETARY_EFF [label="Allergen Avoidance\n→ Antigen Removal", fillcolor="#F48FB1"]

    // Dilation
    DILATION   [label="Esophageal Dilation\n(Symptomatic stricture)", fillcolor="#F8BBD0"]
  }

  // =====================================================================
  // EDGES — Trigger Pathways
  // =====================================================================

  FA_MILK -> SENS   [label="primary trigger\n(most common)", color="#E65100"]
  FA_WHEAT -> SENS  [label="2nd most common", color="#E65100"]
  FA_EGG -> SENS    [label="trigger food", color="#E65100"]
  FA_SOY -> SENS    [label="trigger food", color="#E65100"]
  FA_NUTS -> SENS   [label="trigger food", color="#E65100"]
  FA_SEAFOOD -> SENS [label="trigger food", color="#E65100"]
  AERO -> SENS      [label="cross-reactivity\n(seasonal EoE)", color="#E65100"]
  GENETIC -> EPITH  [label="DSG1/FLG\nvariants weaken\nbarrier", color="#E65100"]
  GENETIC -> TSLP_EP [label="TSLP locus\npolymorphism", color="#E65100"]
  DIET_WEST -> MICR [label="modulates", color="#E65100"]
  MICR -> EPBAR     [label="dysbiosis\n↓ barrier\nfunction", color="#7B1FA2"]
  ACID_GERD -> EPBAR [label="acid disrupts\nepithelial\njunctions", color="#E65100"]
  FA_MILK -> EPITH  [label="luminal\ncontact", color="#E65100"]
  FA_WHEAT -> EPITH [label="luminal\ncontact", color="#E65100"]

  // =====================================================================
  // EDGES — Epithelial Barrier
  // =====================================================================

  EPITH -> TSLP_EP  [label="damage/IL-13\nstress", color="#2E7D32"]
  EPITH -> IL33_EP  [label="damage-\nassociated\nAlarmin", color="#2E7D32"]
  EPITH -> IL25_EP  [label="Th2\ninducing", color="#2E7D32"]
  TSLP_EP -> TSLP_CYT [label="secreted into\nlumen/lamina\npropria", color="#2E7D32"]
  IL33_EP -> IL33_CYT [label="released", color="#2E7D32"]
  IL25_EP -> IL25_CYT [label="released", color="#2E7D32"]
  IL13_CYT -> CALPAIN14 [label="induces\nCalpain-14\nexpression", color="#F57F17", style=bold]
  CALPAIN14 -> DSG_CLEAVE [label="protease\ncleaves DSG1", color="#2E7D32"]
  DSG_CLEAVE -> DESMOG1 [label="→ ↓ DSG1\nprotein", color="#2E7D32"]
  IL13_CYT -> DESMOG1 [label="IL-13 represses\nDSG1 transcription", color="#F57F17"]
  IL13_CYT -> FILLAG   [label="represses\nfilaggrin\n(FLG)", color="#F57F17"]
  IL4_CYT -> FILLAG    [label="represses\nFLG", color="#F57F17"]
  IL13_CYT -> OCCLUDIN [label="disrupts\ntight junctions", color="#F57F17"]
  DESMOG1 -> EPBAR  [label="DSG1 ↓\ncompromises\nbarrier", color="#2E7D32"]
