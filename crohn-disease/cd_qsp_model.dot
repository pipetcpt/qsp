digraph crohn_disease_qsp {
  graph [
    label="Crohn's Disease — QSP Mechanistic Map\nMucosal Immunity · Cytokine Network · Drug PK/PD · Clinical Endpoints"
    fontname="Helvetica" fontsize=20 labelloc="t" labeljust="c"
    rankdir=LR bgcolor="#F8F9FA"
    nodesep=0.25 ranksep=0.7
    splines=true
  ]
  node [fontname="Helvetica" fontsize=8 style="filled,rounded" shape=box margin="0.06,0.04"]
  edge [fontname="Helvetica" fontsize=7 arrowsize=0.55]

  // ============================================================
  // CLUSTER 1 — Luminal Environment & Microbiome
  // ============================================================
  subgraph cluster_microbiome {
    label="Luminal Environment & Microbiome"
    style=filled fillcolor="#E8F5E9" color="#2E7D32" penwidth=2.5

    Microbiota     [label="Gut Microbiota\n(Commensal)" fillcolor="#A5D6A7"]
    Dysbiosis      [label="Dysbiosis\n↑Proteobacteria\n↓Firmicutes" fillcolor="#EF9A9A"]
    SCFA           [label="SCFAs\nButyrate/Propionate" fillcolor="#C8E6C9"]
    LPS            [label="LPS / PAMPs" fillcolor="#FFCDD2"]
    Flagellin      [label="Flagellin\nPeptidoglycans" fillcolor="#FFCDD2"]
    MucusLayer     [label="Mucus Layer\nMUC2, MUC5B" fillcolor="#B2DFDB"]
    SecIgA         [label="Secretory IgA\n(luminal)" fillcolor="#DCEDC8"]
    BileAcids      [label="Bile Acids\n(primary/secondary)" fillcolor="#FFF9C4"]
    AntigenLoad    [label="Luminal\nAntigen Load" fillcolor="#FFCCBC"]
    FMT            [label="FMT\n(therapeutic)" fillcolor="#B3E5FC" shape=diamond]
  }

  // ============================================================
  // CLUSTER 2 — Epithelial Barrier
  // ============================================================
  subgraph cluster_epithelium {
    label="Epithelial Barrier & Mucosal Interface"
    style=filled fillcolor="#E3F2FD" color="#1565C0" penwidth=2.5

    Enterocyte     [label="Enterocyte (IEC)" fillcolor="#90CAF9"]
    GobletCell     [label="Goblet Cell\nMUC2 secretion" fillcolor="#64B5F6"]
    PanethCell     [label="Paneth Cell\nDefensins, RegIIIγ" fillcolor="#42A5F5"]
    TuftCell       [label="Tuft Cell\nIL-25 secretion" fillcolor="#90CAF9"]
    MCell          [label="M-Cell\n(antigen sampling)" fillcolor="#BBDEFB"]
    TJ             [label="Tight Junctions\nClaudin, Occludin,\nZO-1" fillcolor="#E1F5FE"]
    BarrierFn      [label="Barrier Function\n(↓permeability)" fillcolor="#B3E5FC"]
    MLCK           [label="MLCK\n(myosin light chain\nkinase)" fillcolor="#81D4FA"]
    EpiApoptosis   [label="Epithelial\nApoptosis" fillcolor="#FFCDD2"]
    CryptAbscess   [label="Crypt Abscess" fillcolor="#EF9A9A"]
    EpiRestitution [label="Epithelial\nRestitution" fillcolor="#C8E6C9"]
    NOD2_Epi       [label="NOD2\n(epithelial)" fillcolor="#B39DDB"]
  }

  // ============================================================
  // CLUSTER 3 — Innate Immunity
  // ============================================================
  subgraph cluster_innate {
    label="Innate Immune Response"
    style=filled fillcolor="#FFF8E1" color="#F57F17" penwidth=2.5

    Macrophage_M1  [label="Macrophage M1\n(pro-inflam)" fillcolor="#FFB300"]
    Macrophage_M2  [label="Macrophage M2\n(anti-inflam)" fillcolor="#FFE082"]
    DC             [label="Dendritic Cell\nCD103+, CD11b+" fillcolor="#FFCC02"]
    Neutrophil     [label="Neutrophil\n(mucosal)" fillcolor="#FFD54F"]
    Eosinophil     [label="Eosinophil" fillcolor="#FFE57F"]
    NK             [label="NK Cell" fillcolor="#FFA726"]
    ILC1           [label="ILC1\n(IFN-γ producer)" fillcolor="#FF8F00"]
    ILC3           [label="ILC3\n(IL-22 producer)" fillcolor="#FFA000"]
    NETs           [label="Neutrophil\nExtracellular\nTraps (NETs)" fillcolor="#EF6C00"]
    TLR2_4         [label="TLR2/TLR4\n(PRR)" fillcolor="#F4511E"]
    TLR9           [label="TLR9\n(CpG DNA)" fillcolor="#F4511E"]
    NOD2_Mac       [label="NOD2\n(macrophage)" fillcolor="#E64A19"]
    NLRP3          [label="NLRP3\nInflammasome" fillcolor="#BF360C" fontcolor=white]
    Complement     [label="Complement\nC3, C5a" fillcolor="#FFAB40"]
    MastCell       [label="Mast Cell\n(histamine)" fillcolor="#FF6D00"]
  }

  // ============================================================
  // CLUSTER 4 — Adaptive Immunity (T Cells)
  // ============================================================
  subgraph cluster_tcells {
    label="Adaptive Immunity — T Cells"
    style=filled fillcolor="#FCE4EC" color="#880E4F" penwidth=2.5

    NaiveT         [label="Naïve T Cell\n(CD4+)" fillcolor="#F48FB1"]
    Th1            [label="Th1 Cell\n(IFN-γ, TNFα)" fillcolor="#E91E63"]
    Th17           [label="Th17 Cell\n(IL-17A, IL-17F)" fillcolor="#C2185B"]
    Th2            [label="Th2 Cell\n(IL-4, IL-13)" fillcolor="#F06292"]
    Th9            [label="Th9 Cell\n(IL-9)" fillcolor="#EC407A"]
    Treg           [label="Treg (FoxP3+)\n(regulatory)" fillcolor="#FFDDE6"]
    CD8T           [label="Cytotoxic T Cell\n(CD8+ CTL)" fillcolor="#AD1457"]
    iTreg          [label="Induced Treg\n(pTreg)" fillcolor="#F8BBD0"]
    MemoryT        [label="Memory T Cell\n(CD45RO+)" fillcolor="#F48FB1"]
    TCRact         [label="TCR Activation\n(CD28 co-stim)" fillcolor="#E91E63"]
    JAK_STAT       [label="JAK1/2–STAT\n1/3/4/6 signaling" fillcolor="#C62828" fontcolor=white]
    RORC           [label="RORγt\n(Th17 master TF)" fillcolor="#B71C1C" fontcolor=white]
    Tbet           [label="T-bet\n(Th1 master TF)" fillcolor="#B71C1C" fontcolor=white]
    IL2_T          [label="IL-2\n(T cell growth)" fillcolor="#F8BBD0"]
    Th17_mem       [label="Memory Th17\n(long-lived)" fillcolor="#E91E63"]
  }

  // ============================================================
  // CLUSTER 5 — Adaptive Immunity (B Cells)
  // ============================================================
  subgraph cluster_bcells {
    label="Adaptive Immunity — B Cells"
    style=filled fillcolor="#EDE7F6" color="#4527A0" penwidth=2.5

    BCell          [label="Naïve B Cell" fillcolor="#CE93D8"]
    GC             [label="Germinal Center" fillcolor="#BA68C8"]
    PlasmaCell     [label="Plasma Cell\nIgG, IgA" fillcolor="#9C27B0" fontcolor=white]
    MemBCell       [label="Memory B Cell" fillcolor="#D1C4E9"]
    pANCA          [label="pANCA\n(marker in CD/UC)" fillcolor="#EF9A9A"]
    AutoAb_IgG     [label="IgG Autoantibodies\nanti-CD, anti-CBir1" fillcolor="#CE93D8"]
    MucIgA         [label="Mucosal IgA\n(luminal protection)" fillcolor="#B39DDB"]
    BCell_act      [label="B Cell Activation\nCD40L–CD40" fillcolor="#9575CD"]
  }

  // ============================================================
  // CLUSTER 6 — Cytokine & Chemokine Network
  // ============================================================
  subgraph cluster_cytokines {
    label="Cytokine & Chemokine Network"
    style=filled fillcolor="#E8EAF6" color="#283593" penwidth=2.5

    TNFa     [label="TNF-α\n(master driver)" fillcolor="#EF5350" fontcolor=white]
    IL1b     [label="IL-1β\n(inflammasome)" fillcolor="#E53935" fontcolor=white]
    IL6      [label="IL-6\n(acute phase)" fillcolor="#EF9A9A"]
    IL12     [label="IL-12\n(Th1 polarize)" fillcolor="#7986CB"]
    IL23     [label="IL-23\n(Th17 maintain)" fillcolor="#5C6BC0"]
    IL17A    [label="IL-17A\n(neutrophil recruit)" fillcolor="#42A5F5"]
    IL17F    [label="IL-17F\n(barrier function)" fillcolor="#64B5F6"]
    IL21     [label="IL-21\n(Th17 amplify)" fillcolor="#7E57C2"]
    IL10     [label="IL-10\n(anti-inflammatory)" fillcolor="#66BB6A"]
    IL22     [label="IL-22\n(epithelial repair)" fillcolor="#81C784"]
    TGFb     [label="TGF-β\n(fibrosis/Treg)" fillcolor="#A5D6A7"]
    IFNg     [label="IFN-γ\n(M1 activation)" fillcolor="#FF7043"]
    IL4      [label="IL-4\n(Th2/B cell)" fillcolor="#FFCA28"]
    IL13     [label="IL-13\n(mucus/fibrosis)" fillcolor="#FFA726"]
    IL18     [label="IL-18\n(IFN-γ inducer)" fillcolor="#FF7043"]
    IL33     [label="IL-33\n(alarmin)" fillcolor="#FFAB40"]
    CXCL8    [label="CXCL8 / IL-8\n(neutrophil chemo)" fillcolor="#90CAF9"]
    CCL2     [label="CCL2 / MCP-1\n(monocyte recruit)" fillcolor="#80DEEA"]
    CXCL10   [label="CXCL10 / IP-10\n(Th1 chemokine)" fillcolor="#80CBC4"]
    NF_kB    [label="NF-κB\n(master inflam TF)" fillcolor="#D32F2F" fontcolor=white]
  }

  // ============================================================
  // CLUSTER 7 — Tissue Remodeling & Fibrosis
  // ============================================================
  subgraph cluster_remodeling {
    label="Tissue Remodeling & Fibrosis"
    style=filled fillcolor="#FBE9E7" color="#BF360C" penwidth=2.5

    Fibroblast     [label="Intestinal\nMyofibroblast" fillcolor="#FFCCBC"]
    Fibrocyte      [label="Circulating\nFibrocyte" fillcolor="#FFAB91"]
    CollagenI      [label="Collagen I/III\nDeposition" fillcolor="#FF8A65"]
    MMP3           [label="MMP-3\n(stromelysin)" fillcolor="#FF7043"]
    MMP9           [label="MMP-9\n(gelatinase B)" fillcolor="#FF5722"]
    TIMP1          [label="TIMP-1\n(MMP inhibitor)" fillcolor="#FFCCBC"]
    Stricture      [label="Intestinal Stricture\n(fibrotic)" fillcolor="#BF360C" fontcolor=white]
    Granuloma      [label="Non-caseating\nGranuloma" fillcolor="#D84315" fontcolor=white]
    Angiogenesis   [label="Angiogenesis\n(VEGF, FGF2)" fillcolor="#FF7043"]
    VEGF           [label="VEGF\n(vascular permea-\nbility)" fillcolor="#EF5350"]
  }

  // ============================================================
  // CLUSTER 8 — Drug PK/PD
  // ============================================================
  subgraph cluster_drugs {
    label="Drug Pharmacokinetics & Pharmacodynamics"
    style=filled fillcolor="#F3E5F5" color="#6A1B9A" penwidth=2.5

    IFX            [label="Infliximab (IFX)\nChimeric mAb anti-TNF\n5 mg/kg IV q0,2,6w →q8w" fillcolor="#CE93D8" shape=diamond]
    IFX_C1         [label="IFX Central Cpt\n(Vc=4.0 L)" fillcolor="#BA68C8"]
    IFX_C2         [label="IFX Peripheral Cpt\n(Vp=3.5 L)" fillcolor="#CE93D8"]
    ADA            [label="Adalimumab (ADA)\nHuman mAb anti-TNF\n160/80/40 mg SC" fillcolor="#9C27B0" shape=diamond fontcolor=white]
    ADA_depot      [label="ADA SC Depot\n(ka=0.38/day)" fillcolor="#AB47BC"]
    ATI            [label="Anti-Drug\nAntibodies (ATI)" fillcolor="#EF9A9A"]

    UST            [label="Ustekinumab (UST)\nAnti-IL-12/23 p40\n6 mg/kg IV → 90 mg SC" fillcolor="#7E57C2" shape=diamond fontcolor=white]
    UST_C1         [label="UST Central Cpt\n(Vc=3.5 L)" fillcolor="#9575CD"]
    UST_C2         [label="UST Peripheral Cpt\n(Vp=7.3 L)" fillcolor="#D1C4E9"]
    RISA           [label="Risankizumab\nAnti-IL-23 p19\n600 mg IV → 360 mg SC" fillcolor="#7986CB" shape=diamond]

    VDZ            [label="Vedolizumab (VDZ)\nAnti-α4β7 integrin\n300 mg IV q0,2,6w→q8w" fillcolor="#5C6BC0" shape=diamond fontcolor=white]
    VDZ_C1         [label="VDZ Central Cpt\n(Vc=3.3 L)" fillcolor="#7986CB"]
    a4b7_RO        [label="α4β7 Integrin\nReceptor Occupancy" fillcolor="#9FA8DA"]

    AZA_6TGN       [label="Azathioprine (AZA)\n2.5 mg/kg/day oral" fillcolor="#4DB6AC" shape=diamond]
    TGN            [label="6-TGN Active\nMetabolite\n(RBC pool)" fillcolor="#26A69A"]

    UPA            [label="Upadacitinib (UPA)\nJAK1 inhibitor\n45 mg/day oral" fillcolor="#26C6DA" shape=diamond]
    UPA_C          [label="UPA Central Cpt\n(V=85 L)" fillcolor="#00BCD4"]

    PRED           [label="Prednisone\n40 mg/day oral\n→ taper" fillcolor="#FFA726" shape=diamond]
    PRED_C         [label="Prednisone Cpt\n(V=45 L, t½~4h)" fillcolor="#FFB300"]

    BUDE           [label="Budesonide MMX\n9 mg/day oral\n(topical steroid)" fillcolor="#FF8F00" shape=diamond]
    MESA           [label="Mesalamine\n(5-ASA)\n4g/day oral" fillcolor="#66BB6A" shape=diamond]
    MTX            [label="Methotrexate\n25 mg/week SC" fillcolor="#A5D6A7" shape=diamond]
  }

  // ============================================================
  // CLUSTER 9 — Clinical Endpoints & Biomarkers
  // ============================================================
  subgraph cluster_clinical {
    label="Clinical Endpoints & Biomarkers"
    style=filled fillcolor="#E0F2F1" color="#004D40" penwidth=2.5

    CDAI           [label="CDAI\n(Disease Activity\nIndex, 0–600)" fillcolor="#26A69A"]
    HBI            [label="Harvey-Bradshaw\nIndex (HBI)" fillcolor="#4DB6AC"]
    SES_CD         [label="SES-CD\n(Endoscopic Score\n0–56)" fillcolor="#80CBC4"]
    CDEIS          [label="CDEIS\n(0–44)" fillcolor="#B2EBF2"]
    FCalprotectin  [label="Fecal Calprotectin\n(FC, μg/g stool)" fillcolor="#A5D6A7"]
    CRP_lab        [label="CRP (mg/L)" fillcolor="#FFCDD2"]
    ESR_lab        [label="ESR (mm/h)" fillcolor="#FFE0B2"]
    IBD_Q          [label="IBDQ\n(Quality of Life)" fillcolor="#B2EBF2"]
    Remission      [label="Clinical Remission\n(CDAI < 150)" fillcolor="#00897B" fontcolor=white]
    Response       [label="Clinical Response\n(ΔCDAI ≥ 100)" fillcolor="#00ACC1" fontcolor=white]
    MucHeal        [label="Mucosal Healing\n(SES-CD = 0–2)" fillcolor="#00BCD4" fontcolor=white]
    DeepRem        [label="Deep Remission\n(clinical +\nendoscopic)" fillcolor="#006064" fontcolor=white]
    Hospitalization [label="Hospitalization" fillcolor="#FF7043"]
    Surgery_risk   [label="Surgery\n(bowel resection)" fillcolor="#E64A19" fontcolor=white]
  }

  // ============================================================
  // CLUSTER 10 — Systemic & Extraintestinal Manifestations
  // ============================================================
  subgraph cluster_systemic {
    label="Systemic & Extraintestinal Manifestations"
    style=filled fillcolor="#ECEFF1" color="#37474F" penwidth=2.5

    Anemia         [label="Anemia\n(iron / B12 def.)" fillcolor="#CFD8DC"]
    Malnutrition   [label="Malnutrition\n(↓BMI, weight loss)" fillcolor="#ECEFF1"]
    BMD_loss       [label="Bone Loss\n(↓BMD, ↑fracture)" fillcolor="#B0BEC5"]
    PSC_liver      [label="Hepatic Manif.\n(PSC, steatosis)" fillcolor="#90A4AE"]
    Skin_EIM       [label="Skin Manif.\nErythema nodosum\nPyoderma" fillcolor="#78909C"]
    Eye_EIM        [label="Eye Manif.\nUveitis, Episcleritis" fillcolor="#607D8B"]
    Joint_EIM      [label="Peripheral Arthritis\n(enteropathic)" fillcolor="#546E7A"]
    Thrombo        [label="VTE Risk\n(DVT, PE)" fillcolor="#EF9A9A"]
    Growth_fail    [label="Growth Failure\n(pediatric CD)" fillcolor="#FFCCBC"]
    MucosalInflam  [label="Mucosal\nInflammation\nScore (0–100)" fillcolor="#EF5350" fontcolor=white]
  }

  // ============================================================
  // EDGES — Microbiome → Epithelium
  // ============================================================
  Dysbiosis      -> LPS          [label="release" color="#C62828"]
  Dysbiosis      -> Flagellin    [label="shed"]
  Microbiota     -> SCFA         [label="ferment"]
  SCFA           -> BarrierFn    [label="↑ fortify" color="#2E7D32"]
  SCFA           -> Treg         [label="↑ induce" color="#2E7D32"]
  SCFA           -> Enterocyte   [label="trophic"]
  LPS            -> TLR2_4       [label="activate"]
  Flagellin      -> TLR2_4       [label="activate"]
  AntigenLoad    -> MCell        [label="sample via"]
  Dysbiosis      -> AntigenLoad  [label="↑"]
  MucusLayer     -> BarrierFn    [label="component of"]
  MCell          -> DC           [label="present antigen\nto lamina propria"]
  BileAcids      -> Microbiota   [label="modulate"]
  FMT            -> Microbiota   [label="restore" color="#2E7D32"]
  FMT            -> Dysbiosis    [label="↓ correct" color="#2E7D32"]
  SecIgA         -> Microbiota   [label="coat/regulate"]
  MucIgA         -> SecIgA       [label="transport→"]

  // ============================================================
  // EDGES — Epithelium
  // ============================================================
  NOD2_Epi       -> Enterocyte   [label="sense MDP"]
  PanethCell     -> MucusLayer   [label="defensins →"]
  TuftCell       -> IL33         [label="secrete"]
  TJ             -> BarrierFn    [label="seal paracellular\ngap"]
  EpiApoptosis   -> BarrierFn    [label="↓ impair" color="#C62828"]
  TNFa           -> MLCK         [label="activate" color="#C62828"]
  MLCK           -> TJ           [label="↓ phosphorylate" color="#C62828"]
  MLCK           -> BarrierFn    [label="↓ impair" color="#C62828"]
  BarrierFn      -> AntigenLoad  [label="↓ loss of barrier\n→ ↑ antigen flux" color="#C62828"]
  IL22           -> Enterocyte   [label="STAT3 repair" color="#2E7D32"]
  IL22           -> BarrierFn    [label="↑ tight junctions" color="#2E7D32"]
  IL22           -> EpiRestitution [label="promote" color="#2E7D32"]
  CD8T           -> EpiApoptosis [label="cytotoxicity"]
  GobletCell     -> MucusLayer   [label="secrete MUC2"]

  // ============================================================
  // EDGES — PRR / Innate Activation
  // ============================================================
  TLR2_4         -> NF_kB        [label="activate" color="#C62828"]
  TLR9           -> IL12         [label="induce via IFN-β"]
  NOD2_Mac       -> NLRP3        [label="prime/activate"]
  NLRP3          -> IL1b         [label="process/release" color="#C62828"]
  NLRP3          -> IL18         [label="process/release"]
  TLR2_4         -> TNFa         [label="via NF-κB" color="#C62828"]
  TLR2_4         -> IL6          [label="via NF-κB"]
  NF_kB          -> TNFa         [label="transcribe" color="#C62828"]
  NF_kB          -> IL6          [label="transcribe"]
  NF_kB          -> CXCL8        [label="transcribe"]
  NF_kB          -> MMP9         [label="transcribe"]
  TNFa           -> NF_kB        [label="amplify loop" color="#C62828"]
  IL1b           -> NF_kB        [label="activate" color="#C62828"]
  Macrophage_M1  -> TNFa         [label="secrete" color="#C62828"]
  Macrophage_M1  -> IL1b         [label="secrete" color="#C62828"]
  Macrophage_M1  -> IL6          [label="secrete"]
  Macrophage_M1  -> IL12         [label="secrete (Th1↑)"]
  Macrophage_M1  -> IL23         [label="secrete (Th17↑)"]
  Macrophage_M1  -> CXCL8        [label="secrete"]
  Macrophage_M1  -> CCL2         [label="secrete"]
  IFNg           -> Macrophage_M1 [label="M1 activation" color="#C62828"]
  IL4            -> Macrophage_M2 [label="polarize M2" color="#2E7D32"]
  IL10           -> Macrophage_M2 [label="promote M2" color="#2E7D32"]
  Macrophage_M2  -> IL10         [label="secrete" color="#2E7D32"]
  Macrophage_M2  -> TGFb         [label="secrete"]
  Macrophage_M1  -> Granuloma    [label="form epithelioid"]
  Granuloma      -> IL12         [label="additional source"]
  DC             -> IL12         [label="Th1 polarize"]
  DC             -> IL23         [label="Th17 polarize"]
  DC             -> NaiveT       [label="prime via MHC-II\n+ costim (CD80/86)"]
  CXCL8          -> Neutrophil   [label="recruit/activate"]
  IL17A          -> CXCL8        [label="↑ induce" color="#C62828"]
  Neutrophil     -> NETs         [label="form NETosis"]
  Neutrophil     -> MMP9         [label="release"]
  Neutrophil     -> TNFa         [label="secrete" color="#C62828"]
  Neutrophil     -> CryptAbscess [label="fill crypts"]
  NETs           -> TNFa         [label="activate endothelium"]
  Complement     -> Neutrophil   [label="C5a: chemo-attract"]
  Complement     -> Macrophage_M1 [label="C3b: opsonize"]
  ILC1           -> IFNg         [label="secrete"]
  ILC3           -> IL22         [label="secrete"]
  ILC3           -> IL17A        [label="co-produce"]
  IL23           -> ILC3         [label="activate/maintain" color="#C62828"]
  MastCell       -> IL6          [label="secrete"]
  MastCell       -> TNFa         [label="secrete"]
  IL33           -> MastCell     [label="activate"]
  IL33           -> ILC1         [label="co-activate"]
  CCL2           -> Macrophage_M1 [label="recruit monocytes"]

  // ============================================================
  // EDGES — T Cell Differentiation
  // ============================================================
  TCRact         -> Th1          [label="IL-12 → T-bet"]
  TCRact         -> Th17         [label="IL-23+TGFβ\n→ RORγt"]
  TCRact         -> Treg         [label="TGFβ+IL-2\n→ FoxP3"]
  TCRact         -> Th2          [label="IL-4 → GATA3"]
  IL12           -> Tbet         [label="upregulate"]
  Tbet           -> Th1          [label="master commit"]
  IL23           -> RORC         [label="upregulate"]
  RORC           -> Th17         [label="master commit"]
  Th1            -> IFNg         [label="secrete" color="#C62828"]
  Th1            -> TNFa         [label="co-secrete" color="#C62828"]
  Th17           -> IL17A        [label="key secrete" color="#C62828"]
  Th17           -> IL17F        [label="secrete"]
  Th17           -> IL21         [label="autocrine loop"]
  IL21           -> Th17         [label="amplify" color="#C62828"]
  Th17           -> Th17_mem     [label="differentiate"]
  Th17_mem       -> Th17         [label="reactivate on\nantigen re-encounter"]
  Treg           -> IL10         [label="secrete" color="#2E7D32"]
  Treg           -> TGFb         [label="secrete" color="#2E7D32"]
  IL10           -> Th17         [label="↓ suppress" color="#2E7D32"]
  IL10           -> TNFa         [label="↓ suppress" color="#2E7D32"]
  IL10           -> Macrophage_M1 [label="↓ deactivate" color="#2E7D32"]
  TGFb           -> Treg         [label="↑ expand" color="#2E7D32"]
  TGFb           -> Th17         [label="co-driver\n(+ IL-6)" style=dashed]
  IL2_T          -> Treg         [label="↑ expansion" color="#2E7D32"]
  JAK_STAT       -> TCRact       [label="amplify cytokine\ndownstream signaling"]
  IL6            -> JAK_STAT     [label="activate via gp130"]
  IL12           -> JAK_STAT     [label="STAT4 pathway"]
  IL23           -> JAK_STAT     [label="STAT3 pathway"]
  MemoryT        -> Th1          [label="reactivate"]
  MemoryT        -> Th17         [label="reactivate"]
  CXCL10         -> Th1          [label="recruit (CXCR3+)"]
  Th2            -> IL4          [label="amplify autocrine"]
  Th2            -> IL13         [label="secrete"]

  // ============================================================
  // EDGES — B Cells
  // ============================================================
  DC             -> BCell        [label="activate"]
  BCell          -> BCell_act    [label="via CD40L-CD40"]
  BCell_act      -> GC           [label="somatic\nhypermutation"]
  GC             -> PlasmaCell   [label="differentiate"]
  GC             -> MemBCell     [label="differentiate"]
  PlasmaCell     -> MucIgA       [label="secrete polymeric IgA"]
  PlasmaCell     -> AutoAb_IgG   [label="secrete"]
  PlasmaCell     -> pANCA        [label="some cases"]

  // ============================================================
  // EDGES — Cytokine Cross-regulation
  // ============================================================
  IL6            -> CRP_lab      [label="hepatic synthesis" color="#C62828"]
  IL17A          -> Fibroblast   [label="activate" color="#C62828"]
  IL17A          -> Enterocyte   [label="↑ antimicrobials\nβ-defensin, S100A8"]
  IL13           -> Fibroblast   [label="pro-fibrotic"]
  IL18           -> IFNg         [label="co-stimulate" color="#C62828"]
  IL4            -> BCell        [label="Ig class switch"]
  IL4            -> IL13         [label="co-produced"]

  // ============================================================
  // EDGES — Tissue Remodeling
  // ============================================================
  TNFa           -> Fibroblast   [label="activate" color="#C62828"]
  TGFb           -> Fibroblast   [label="myofibroblast\ndifferentiation"]
  TGFb           -> CollagenI    [label="↑ transcription" color="#C62828"]
  Fibroblast     -> CollagenI    [label="secrete" color="#C62828"]
  Fibroblast     -> MMP3         [label="release"]
  Fibroblast     -> TIMP1        [label="release"]
  TNFa           -> MMP9         [label="upregulate" color="#C62828"]
  MMP9           -> CollagenI    [label="degrade (limited)"]
  TIMP1          -> MMP9         [label="inhibit" color="#2E7D32"]
  CollagenI      -> Stricture    [label="excess leads to"]
  Fibrocyte      -> Fibroblast   [label="circulating →\ntissue resident"]
  VEGF           -> Angiogenesis [label="key mediator"]
  IL6            -> VEGF         [label="upregulate"]
  TNFa           -> Angiogenesis [label="promote"]
  TGFb           -> VEGF         [label="induce"]

  // ============================================================
  // EDGES — Drug PK
  // ============================================================
  IFX            -> IFX_C1       [label="IV infusion\n(bolus/Rinf)"]
  IFX_C1         -> IFX_C2       [label="distribute\n(k12=0.35/day)"]
  IFX_C2         -> IFX_C1       [label="return\n(k21=0.40/day)"]
  IFX_C1         -> TNFa         [label="neutralize\n(Kd~0.1 nM)" color="#6A1B9A"]
  ATI            -> IFX_C1       [label="↑ accelerate\nclearance" color="#C62828"]
  IFX_C1         -> ATI          [label="immunogenic\n→ ADA formation" style=dashed color="#C62828"]

  ADA            -> ADA_depot    [label="SC inject\n(40 mg q2w)"]
  ADA_depot      -> TNFa         [label="absorb → central\n→ neutralize" color="#6A1B9A"]

  UST            -> UST_C1       [label="IV induction\nthen SC 90 mg q8w"]
  UST_C1         -> UST_C2       [label="distribute"]
  UST_C2         -> UST_C1       [label="return"]
  UST_C1         -> IL12         [label="block p40 subunit" color="#6A1B9A"]
  UST_C1         -> IL23         [label="block p40 subunit" color="#6A1B9A"]

  RISA           -> IL23         [label="block p19 selectively" color="#6A1B9A"]

  VDZ            -> VDZ_C1       [label="IV infusion"]
  VDZ_C1         -> a4b7_RO      [label="block integrin" color="#6A1B9A"]
  a4b7_RO        -> Th1          [label="↓ gut homing\n(gut-selective)" color="#6A1B9A"]
  a4b7_RO        -> Th17         [label="↓ gut homing" color="#6A1B9A"]

  AZA_6TGN       -> TGN          [label="TPMT / HGPRT\nmetabolism"]
  TGN            -> TCRact       [label="↓ purine synth\n(anti-proliferative)" color="#6A1B9A"]
  TGN            -> TNFa         [label="↓ NF-κB\ntranscription" color="#6A1B9A"]

  UPA            -> UPA_C        [label="oral (F=0.79)"]
  UPA_C          -> JAK_STAT     [label="inhibit JAK1\n(Emax 75%)" color="#6A1B9A"]

  PRED           -> PRED_C       [label="oral (F~0.8)"]
  PRED_C         -> NF_kB        [label="↓ block (GR\ncomplex)" color="#6A1B9A"]
  PRED_C         -> TNFa         [label="↓ transcription" color="#6A1B9A"]
  PRED_C         -> IL6          [label="↓ suppress" color="#6A1B9A"]
  PRED_C         -> BMD_loss     [label="↑ (side effect)\nosteoclast ↑" color="#C62828"]

  BUDE           -> TNFa         [label="↓ local\nsuppression" color="#6A1B9A"]
  MESA           -> NF_kB        [label="weak inhibit\n(5-ASA limited\nefficacy in CD)" color="#6A1B9A" style=dashed]
  MTX            -> TCRact       [label="↓ folate antag\n(anti-proliferative)" color="#6A1B9A"]
  MTX            -> TNFa         [label="↓ reduce\nvia adenosine" color="#6A1B9A"]

  // ============================================================
  // EDGES — Mucosal Inflammation & Clinical Endpoints
  // ============================================================
  TNFa           -> MucosalInflam [label="drive" color="#C62828"]
  IL17A          -> MucosalInflam [label="drive" color="#C62828"]
  IFNg           -> MucosalInflam [label="drive" color="#C62828"]
  IL1b           -> MucosalInflam [label="contribute" color="#C62828"]
  Neutrophil     -> MucosalInflam [label="tissue damage"]
  IL10           -> MucosalInflam [label="↓ dampen" color="#2E7D32"]
  Treg           -> MucosalInflam [label="↓ suppress" color="#2E7D32"]
  BarrierFn      -> MucosalInflam [label="↓ loss of barrier\n→ ↑ inflam" color="#C62828"]
  MucosalInflam  -> CRP_lab       [label="systemic reflect"]
  MucosalInflam  -> FCalprotectin [label="luminal reflect"]
  MucosalInflam  -> CDAI          [label="component"]
  MucosalInflam  -> SES_CD        [label="endoscopic"]
  MucosalInflam  -> HBI           [label="component"]
  CRP_lab        -> CDAI          [label="contribute"]
  FCalprotectin  -> MucHeal       [label="FC < 150\n→ predict"]
  SES_CD         -> MucHeal       [label="SES-CD ≤ 2"]
  CDAI           -> Remission     [label="CDAI < 150"]
  CDAI           -> Response      [label="ΔCDAI ≥ 100"]
  MucHeal        -> DeepRem       [label="+ clinical remission"]
  Remission      -> DeepRem       [label="+ mucosal healing"]
  CDAI           -> IBD_Q         [label="inversely correlate"]
  IBD_Q          -> DeepRem       [label="patient-reported\noutcome component"]

  // ============================================================
  // EDGES — Systemic Complications
  // ============================================================
  MucosalInflam  -> Anemia        [label="chronic disease\nanemia (hepcidin↑)"]
  IL6            -> Anemia        [label="hepcidin induction"]
  MucosalInflam  -> Malnutrition  [label="↑ catabolism\n↓ absorption"]
  TNFa           -> Malnutrition  [label="anorexia / cachexia"]
  IL6            -> BMD_loss      [label="RANKL ↑, OPG ↓" color="#C62828"]
  TNFa           -> BMD_loss      [label="↑ RANKL:OPG\nratio" color="#C62828"]
  Malnutrition   -> BMD_loss      [label="↓ Ca/VitD\n↓ IGF-1"]
  MucosalInflam  -> Skin_EIM      [label="EIM: skin"]
  MucosalInflam  -> Eye_EIM       [label="EIM: ocular"]
  MucosalInflam  -> Joint_EIM     [label="EIM: peripheral\narthritis"]
  MucosalInflam  -> PSC_liver     [label="PSC association\n(shared immunopathol)"]
  Anemia         -> IBD_Q         [label="impair QoL"]
  Joint_EIM      -> IBD_Q         [label="impair QoL"]
  TNFa           -> Thrombo       [label="endothelial\nactivation"]
  IL6            -> Thrombo       [label="↑ fibrinogen\n↑ Factor VIII"]
  Malnutrition   -> Growth_fail   [label="↓ IGF-1"]
  IL6            -> Growth_fail   [label="GH resistance"]
  Stricture      -> Surgery_risk  [label="indication"]
  MucosalInflam  -> Hospitalization [label="drives"]
  Hospitalization -> Surgery_risk [label="escalate to OR"]
  ESR_lab        -> CDAI          [label="not included\nbut correlates"]
}
