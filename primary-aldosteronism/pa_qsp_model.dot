digraph PrimaryAldosteronism_QSP {
  graph [
    label="Primary Aldosteronism (Conn's Syndrome) — QSP Mechanistic Map\nRAAS · Adrenal Steroidogenesis · Renal Tubule · Cardiovascular · Drug PK/PD"
    fontsize=22 fontname="Helvetica" labelloc=t
    rankdir=TB bgcolor="#F8F9FA"
    compound=true splines=ortho nodesep=0.45 ranksep=0.7
  ]
  node [fontname="Helvetica" fontsize=10 style=filled shape=box]
  edge [fontname="Helvetica" fontsize=9]

  /* ===================== CLUSTER 1: RAAS CASCADE ===================== */
  subgraph cluster_raas {
    label="Renin-Angiotensin-Aldosterone System (RAAS)" style=filled
    fillcolor="#EBF5FB" color="#2980B9" penwidth=2
    fontsize=14 fontname="Helvetica-Bold"

    angiotensinogen [label="Angiotensinogen\n(AGT, liver)" fillcolor="#AED6F1"]
    renin [label="Renin\n(Kidney JGA)" fillcolor="#5DADE2" shape=ellipse]
    renin_substrate [label="Ang I\n(Angiotensin I)" fillcolor="#85C1E9"]
    ACE [label="ACE\n(Angiotensin\nConverting Enzyme)" fillcolor="#3498DB" shape=ellipse]
    ACE2 [label="ACE2\n(Counter-regulatory)" fillcolor="#85C1E9" shape=ellipse]
    AT1R [label="AT1 Receptor\n(AGTR1)" fillcolor="#2980B9"]
    AT2R [label="AT2 Receptor\n(AGTR2)" fillcolor="#AED6F1"]
    AngII [label="Angiotensin II\n(Ang II)" fillcolor="#1A5276" fontcolor=white shape=ellipse]
    Ang_1_7 [label="Angiotensin 1-7\n(Vasodilatory)" fillcolor="#D6EAF8"]
    MasR [label="Mas Receptor\n(Vasodilation)" fillcolor="#AED6F1"]
    bradykinin [label="Bradykinin\n(ACE substrate)" fillcolor="#AED6F1"]
    chymase [label="Chymase\n(ACE-independent\nAng II)" fillcolor="#85C1E9" shape=ellipse]
    ARR [label="ARR\n(Aldosterone:Renin\nRatio)" fillcolor="#D6EAF8" shape=diamond]
  }

  /* ===================== CLUSTER 2: ADRENAL GLAND ===================== */
  subgraph cluster_adrenal {
    label="Adrenal Gland — Cortex" style=filled
    fillcolor="#FEF5E7" color="#E67E22" penwidth=2
    fontsize=14 fontname="Helvetica-Bold"

    zona_glomerulosa [label="Zona Glomerulosa\n(ZG)" fillcolor="#FAD7A0"]
    zona_fasciculata [label="Zona Fasciculata\n(ZF, cortisol)" fillcolor="#FAE5D3"]
    zona_reticularis [label="Zona Reticularis\n(ZR, DHEA)" fillcolor="#FAE5D3"]
    cholesterol_adrenal [label="Cholesterol\n(Adrenal)" fillcolor="#F8C471"]
    StAR_adrenal [label="StAR Protein\n(Rate-limiting)" fillcolor="#F0B27A" shape=ellipse]
    CYP11A1 [label="CYP11A1\n(Pregnenolone\nsynthase)" fillcolor="#E59866" shape=ellipse]
    pregnenolone [label="Pregnenolone" fillcolor="#FAD7A0"]
    CYP21A2 [label="CYP21A2\n(21-hydroxylase)" fillcolor="#E59866" shape=ellipse]
    CYP11B1 [label="CYP11B1\n(11β-hydroxylase)" fillcolor="#CA6F1E" shape=ellipse]
    CYP11B2 [label="CYP11B2\n(Aldosterone\nSynthase)" fillcolor="#BA4A00" shape=ellipse]
    progesterone_adrenal [label="Progesterone" fillcolor="#FAD7A0"]
    deoxycorticosterone [label="11-Deoxy-\ncorticosterone (DOC)" fillcolor="#F5CBA7"]
    corticosterone [label="Corticosterone\n(B)" fillcolor="#F5CBA7"]
    aldosterone_adrenal [label="Aldosterone\n(Adrenal secretion)" fillcolor="#E67E22" shape=ellipse]
    cortisol [label="Cortisol\n(ZF product)" fillcolor="#FAD7A0" shape=ellipse]
    APA [label="Adrenal Aldosterone-\nProducing Adenoma\n(APA, ~35%)" fillcolor="#E74C3C" fontcolor=white]
    BAH [label="Bilateral Adrenal\nHyperplasia (BAH,\n~60%)" fillcolor="#C0392B" fontcolor=white]
    KCNJ5_mut [label="KCNJ5 Mutation\n(~40% APA)\nK+/Na+ selectivity loss" fillcolor="#F1948A"]
    CACNA1D_mut [label="CACNA1D Mutation\n(~9% APA)\nCa²⁺ channel gain-of-function" fillcolor="#F1948A"]
    ATP1A1_mut [label="ATP1A1/ATP2B3\nMutation\n(~7% APA each)" fillcolor="#F1948A"]
    Ca2plus_adrenal [label="Intracellular Ca²⁺\n(ZG signaling)" fillcolor="#FAD7A0" shape=ellipse]
    PKC_adrenal [label="PKC/MAPK\nSignaling" fillcolor="#FAD7A0"]
    CYP11B2_upregulation [label="CYP11B2 Up-\nregulation\n(Autonomous)" fillcolor="#E74C3C" shape=ellipse]
  }

  /* ===================== CLUSTER 3: RENAL TUBULE ===================== */
  subgraph cluster_renal {
    label="Renal Collecting Duct — Aldosterone Signaling" style=filled
    fillcolor="#EAFAF1" color="#27AE60" penwidth=2
    fontsize=14 fontname="Helvetica-Bold"

    principal_cell [label="Principal Cell\n(Na+ absorption,\nK+ secretion)" fillcolor="#82E0AA"]
    intercalated_cell [label="Intercalated Cell\n(H+ secretion,\nHCO3- reabsorption)" fillcolor="#A9DFBF"]
    MR_cytoplasm [label="Mineralocorticoid\nReceptor (MR)\n(Cytoplasm, +HSP90)" fillcolor="#27AE60"]
    Aldo_MR_complex [label="Aldosterone-MR\nComplex\n(Nuclear, active)" fillcolor="#1E8449" fontcolor=white]
    SGK1 [label="SGK1\n(Serum/Glucocorticoid-\nRegulated Kinase 1)" fillcolor="#27AE60" shape=ellipse]
    Nedd4_2 [label="Nedd4-2\n(Ubiquitin ligase;\nSGK1 phosphorylates)" fillcolor="#2ECC71"]
    ENaC_alpha [label="αENaC Subunit\n(Rate-limiting,\nupregulated by Aldo)" fillcolor="#A9DFBF"]
    ENaC_beta [label="βENaC Subunit" fillcolor="#A9DFBF"]
    ENaC_gamma [label="γENaC Subunit" fillcolor="#A9DFBF"]
    ENaC_channel [label="ENaC\n(Epithelial Na+\nChannel)" fillcolor="#1E8449" fontcolor=white]
    ROMK [label="ROMK (KCNJ1)\n(K+ Secretion\nChannel)" fillcolor="#27AE60"]
    NaK_ATPase [label="Na+/K+-ATPase\n(Basolateral,\nATP1A1)" fillcolor="#229954"]
    H_ATPase [label="V-type H+-ATPase\n(Intercalated cells)" fillcolor="#2ECC71"]
    NKCC2 [label="NKCC2\n(Loop of Henle,\nNa+/K+/2Cl-)" fillcolor="#A9DFBF"]
    NHE3 [label="NHE3\n(Na+/H+ Exchanger\nProximal tubule)" fillcolor="#A9DFBF"]
    GFR [label="GFR\n(Glomerular\nFiltration Rate)" fillcolor="#82E0AA" shape=diamond]
    renal_K_excretion [label="Urinary K+\nExcretion\n(↑ in PA)" fillcolor="#27AE60" shape=diamond]
    renal_Na_retention [label="Na+ Retention\n(Volume expansion)" fillcolor="#1ABC9C"]
    renal_H_excretion [label="H+ Excretion\n(→ Metabolic\nAlkalosis)" fillcolor="#A9DFBF"]
    TGF_renin [label="Tubuloglomerular\nFeedback →\nRenin↓ (PA)" fillcolor="#52BE80"]
  }

  /* ===================== CLUSTER 4: CARDIOVASCULAR ===================== */
  subgraph cluster_cardio {
    label="Cardiovascular System" style=filled
    fillcolor="#FDF2F8" color="#8E44AD" penwidth=2
    fontsize=14 fontname="Helvetica-Bold"

    cardiac_output [label="Cardiac Output\n(CO = HR × SV)" fillcolor="#D7BDE2" shape=ellipse]
    HR [label="Heart Rate" fillcolor="#D7BDE2"]
    stroke_volume [label="Stroke Volume" fillcolor="#D7BDE2"]
    preload [label="Preload\n(Ventricular\nFilling Volume)" fillcolor="#C39BD3"]
    afterload [label="Afterload\n(Peripheral\nResistance)" fillcolor="#C39BD3"]
    TPR [label="Total Peripheral\nResistance (TPR)" fillcolor="#9B59B6" shape=ellipse]
    MAP [label="Mean Arterial\nPressure (MAP)\n= CO × TPR" fillcolor="#6C3483" fontcolor=white shape=ellipse]
    SBP [label="Systolic BP\n(Clinical measure)" fillcolor="#A569BD" shape=diamond]
    DBP [label="Diastolic BP" fillcolor="#A569BD" shape=diamond]
    endothelium [label="Vascular\nEndothelium\n(NO·ET-1·PGI2)" fillcolor="#D7BDE2"]
    NO_production [label="Nitric Oxide\n(NO) ↓ in PA" fillcolor="#BB8FCE"]
    ET1 [label="Endothelin-1\n(ET-1) ↑" fillcolor="#9B59B6"]
    VSMC [label="Vascular Smooth\nMuscle Cells\n(VSMC, hypertrophy)" fillcolor="#C39BD3"]
    sympathetic_ns [label="Sympathetic\nNervous System\n(↑ in PA)" fillcolor="#D7BDE2"]
    RAAS_cardiac [label="RAAS Activation\n→ Cardiac MR" fillcolor="#A569BD"]
    baroreceptor [label="Baroreceptor\nReflex\n(blunted in PA)" fillcolor="#D2B4DE"]
  }

  /* ===================== CLUSTER 5: ION HOMEOSTASIS ===================== */
  subgraph cluster_ions {
    label="Ion Homeostasis & Volume Regulation" style=filled
    fillcolor="#FDEDEC" color="#E74C3C" penwidth=2
    fontsize=14 fontname="Helvetica-Bold"

    plasma_Na [label="Plasma Na+\n(136–145 mEq/L)" fillcolor="#FADBD8" shape=ellipse]
    plasma_K [label="Plasma K+\n(↓ <3.5 mEq/L in PA)" fillcolor="#E74C3C" fontcolor=white shape=ellipse]
    plasma_Cl [label="Plasma Cl-" fillcolor="#F1948A"]
    plasma_HCO3 [label="Plasma HCO3-\n(↑ Metabolic alkalosis)" fillcolor="#F1948A"]
    plasma_volume [label="Plasma Volume\n(↑ → Edema)" fillcolor="#FADBD8" shape=ellipse]
    ECF_volume [label="Extracellular\nFluid Volume\n(↑ → Hypertension)" fillcolor="#F5B7B1"]
    pH_blood [label="Blood pH\n(Metabolic alkalosis\npH > 7.45)" fillcolor="#F1948A" shape=diamond]
    aldosterone_plasma [label="Aldosterone\n(Plasma)\n(PAC, ng/dL)" fillcolor="#E67E22" shape=ellipse]
    renin_plasma [label="Renin Activity\n(PRA, ng/mL/h)\n(↓ in PA)" fillcolor="#5DADE2" shape=ellipse]
    spironolactone_escape [label="Aldosterone\nEscape Effect\n(chronic)" fillcolor="#FDFEFE" style=dashed]
    Mg_hypomagnesemia [label="Hypo-\nmagnesemia\n(ENaC mediated)" fillcolor="#FADBD8"]
  }

  /* ===================== CLUSTER 6: TARGET ORGAN DAMAGE ===================== */
  subgraph cluster_tod {
    label="Target Organ Damage (TOD)" style=filled
    fillcolor="#FDFEFE" color="#566573" penwidth=2
    fontsize=14 fontname="Helvetica-Bold"

    cardiac_MR [label="Cardiac\nMineralocorticoid\nReceptor (MR)" fillcolor="#BDC3C7"]
    cardiac_fibrosis [label="Cardiac Fibrosis\n(Collagen↑)" fillcolor="#95A5A6" shape=diamond]
    LVH [label="Left Ventricular\nHypertrophy (LVH)" fillcolor="#717D7E" fontcolor=white shape=diamond]
    myocardial_macrophage [label="Cardiac Macrophage\n(MR activation)" fillcolor="#95A5A6"]
    IL1_cardiac [label="IL-1β/TNF-α\n(Cardiac inflammation)" fillcolor="#7F8C8D"]
    TGF_beta_cardiac [label="TGF-β1\n(Profibrotic)" fillcolor="#7F8C8D" shape=ellipse]
    collagen_I_III [label="Collagen I/III\n(Cardiac matrix)" fillcolor="#95A5A6"]
    galectin3 [label="Galectin-3\n(Fibrosis biomarker)" fillcolor="#BDC3C7"]
    PAI1 [label="PAI-1\n(Thrombosis risk)" fillcolor="#BDC3C7"]
    VCAM1 [label="VCAM-1/ICAM-1\n(Endothelial activation)" fillcolor="#95A5A6"]
    oxidative_stress_PA [label="Oxidative Stress\n(NAD(P)H oxidase↑)" fillcolor="#BDC3C7"]
    renal_fibrosis [label="Renal Fibrosis\n(MR-mediated)" fillcolor="#95A5A6" shape=diamond]
    atrial_fibrillation [label="Atrial Fibrillation\nRisk (↑ in PA)" fillcolor="#7F8C8D" shape=diamond]
    arrhythmia_risk [label="Arrhythmia Risk\n(Hypokalemia-driven)" fillcolor="#7F8C8D" shape=diamond]
    stroke_risk [label="Stroke Risk\n(↑ vs. essential HT)" fillcolor="#566573" fontcolor=white shape=diamond]
    MI_risk [label="MI Risk\n(Excess vs. essential HT)" fillcolor="#566573" fontcolor=white shape=diamond]
  }

  /* ===================== CLUSTER 7: DRUG PK ===================== */
  subgraph cluster_pk {
    label="Drug Pharmacokinetics (PK)" style=filled
    fillcolor="#E8F8F5" color="#1ABC9C" penwidth=2
    fontsize=14 fontname="Helvetica-Bold"

    spiro_dose [label="Spironolactone\nDose (mg/day)" fillcolor="#76D7C4"]
    spiro_gut [label="Spironolactone\nGut Absorption\n(F~72%)" fillcolor="#45B39D"]
    spiro_plasma [label="Spironolactone\nPlasma (ng/mL)" fillcolor="#1ABC9C"]
    canrenone [label="Canrenone\n(Active metabolite\nT½~20h)" fillcolor="#17A589"]
    spiro_liver [label="Spironolactone\nHepatic Metabolism\nCYP3A4" fillcolor="#45B39D"]

    eple_dose [label="Eplerenone\nDose (mg BID)" fillcolor="#76D7C4"]
    eple_plasma [label="Eplerenone\nPlasma (ng/mL)\nT½=4-6h, CYP3A4" fillcolor="#1ABC9C"]

    fine_dose [label="Finerenone\nDose (mg/day)" fillcolor="#76D7C4"]
    fine_plasma [label="Finerenone\nPlasma (ng/mL)\nT½=3h, CYP3A4" fillcolor="#1ABC9C"]

    acei_dose [label="ACE Inhibitor\nDose (ramipril mg)" fillcolor="#76D7C4"]
    acei_plasma [label="ACEi Plasma\n(ng/mL)" fillcolor="#1ABC9C"]

    ccb_dose [label="CCB Dose\n(amlodipine mg)" fillcolor="#76D7C4"]
    ccb_plasma [label="CCB Plasma\n(ng/mL)\nT½=35-50h" fillcolor="#1ABC9C"]

    adrenalectomy [label="Adrenalectomy\n(Laparoscopic,\nAPA only)" fillcolor="#E74C3C" fontcolor=white shape=ellipse]
  }

  /* ===================== CLUSTER 8: DRUG PD ===================== */
  subgraph cluster_pd {
    label="Drug Pharmacodynamics (PD)" style=filled
    fillcolor="#EBF5FB" color="#2980B9" penwidth=2
    fontsize=14 fontname="Helvetica-Bold"

    spiro_MR_block [label="Spironolactone\n→ MR Blockade\n(IC50~0.5nM)" fillcolor="#AED6F1"]
    spiro_AR_block [label="Spironolactone\n→ AR Blockade\n(Gynecomastia)" fillcolor="#F1948A"]
    spiro_PR_block [label="Spironolactone\n→ PR Agonism" fillcolor="#F5CBA7"]
    spiro_Na_excretion [label="Spiro → Na+\nExcretion↑" fillcolor="#AED6F1"]
    spiro_K_retention [label="Spiro → K+\nRetention↑" fillcolor="#AED6F1"]

    eple_MR_block [label="Eplerenone\n→ MR Blockade\n(IC50~1nM, selective)" fillcolor="#85C1E9"]
    fine_MR_block [label="Finerenone\n→ MR Blockade\n(Non-steroidal, Kd=0.4nM)" fillcolor="#5DADE2"]
    fine_cardiac_protect [label="Finerenone\n→ Cardiac/Renal\nProtection" fillcolor="#5DADE2"]

    acei_ACE_block [label="ACEi → ACE\nInhibition" fillcolor="#A9CCE3"]
    acei_Ang2_reduce [label="ACEi → Ang II↓\n→ Aldo (partial↓)" fillcolor="#A9CCE3"]
    acei_bradykinin_up [label="ACEi → Bradykinin↑\n→ Cough" fillcolor="#F5CBA7"]

    ccb_VGCC [label="CCB → L-type\nCa²⁺ Channel Block" fillcolor="#AED6F1"]
    ccb_VSMC_relax [label="CCB → VSMC\nRelaxation → TPR↓" fillcolor="#AED6F1"]
    ccb_adrenal_Ca [label="CCB → Adrenal\nCa²⁺ → Aldo↓ (minor)" fillcolor="#AED6F1"]

    surgery_aldo_cure [label="Adrenalectomy\n→ Autonomous Aldo↓\n→ Renin Recovery" fillcolor="#E74C3C" fontcolor=white]
    surgery_BP_norm [label="Adrenalectomy\n→ BP Normalisation\n(40-50%)" fillcolor="#E74C3C" fontcolor=white]
    surgery_K_norm [label="Adrenalectomy\n→ K+ Normalisation\n(~100%)" fillcolor="#E74C3C" fontcolor=white]
  }

  /* ===================== CLUSTER 9: DIAGNOSTICS ===================== */
  subgraph cluster_diag {
    label="Diagnostic & Biomarkers" style=filled
    fillcolor="#F9F9F9" color="#7F8C8D" penwidth=2
    fontsize=14 fontname="Helvetica-Bold"

    PAC [label="PAC\n(Plasma Aldosterone\nConcentration)" fillcolor="#D5D8DC" shape=diamond]
    PRA [label="PRA\n(Plasma Renin\nActivity)" fillcolor="#D5D8DC" shape=diamond]
    ARR_diag [label="ARR > 30\n(Screening test,\nng/dL per ng/mL/h)" fillcolor="#ABB2B9" shape=diamond]
    saline_test [label="Saline Infusion\nTest (SIT)\n(Confirmatory)" fillcolor="#D5D8DC"]
    fludro_test [label="Fludrocortisone\nSuppression Test\n(FST)" fillcolor="#D5D8DC"]
    captopril_test [label="Captopril\nChallenge Test" fillcolor="#D5D8DC"]
    CT_adrenal [label="CT Adrenal\n(APA vs BAH,\nlimited sensitivity)" fillcolor="#BDC3C7"]
    AVS [label="Adrenal Vein\nSampling (AVS)\n(Gold standard)" fillcolor="#95A5A6"]
    lateralization [label="Lateralization\nIndex > 4\n(APA diagnosis)" fillcolor="#717D7E" fontcolor=white]
    serum_K_diag [label="Serum K+\n(<3.5 mEq/L in 30%)" fillcolor="#D5D8DC" shape=diamond]
    urine_K_diag [label="Urine K+/Cr Ratio\n(24h K+ >30 mEq)" fillcolor="#D5D8DC" shape=diamond]
    urine_metanephrine [label="Urine\nMetanephrines\n(Pheo exclusion)" fillcolor="#D5D8DC"]
    serum_cortisol [label="Serum Cortisol\n(Rules out CS)" fillcolor="#D5D8DC" shape=diamond]
  }

  /* ===================== CLUSTER 10: CLINICAL ENDPOINTS ===================== */
  subgraph cluster_endpoints {
    label="Clinical Endpoints & Phenotype" style=filled
    fillcolor="#EAF2FF" color="#3498DB" penwidth=2
    fontsize=14 fontname="Helvetica-Bold"

    hypertension_clin [label="Resistant\nHypertension\n(Clinical)" fillcolor="#AED6F1" shape=diamond]
    hypokalemia_clin [label="Hypokalemia\n(<3.5 mEq/L)" fillcolor="#85C1E9" shape=diamond]
    metabolic_alkalosis [label="Metabolic Alkalosis\n(HCO3- >26 mEq/L)" fillcolor="#AED6F1" shape=diamond]
    muscle_weakness [label="Muscle Weakness/\nCramps\n(K+ depletion)" fillcolor="#5DADE2" shape=diamond]
    polyuria [label="Polyuria/\nPolydipsia\n(Nephrogenic DI)" fillcolor="#3498DB" fontcolor=white shape=diamond]
    fatigue_PA [label="Fatigue\n(K+ depletion,\nbp elevation)" fillcolor="#AED6F1" shape=diamond]
    headache_PA [label="Headache\n(Hypertension)" fillcolor="#AED6F1" shape=diamond]
    MACE [label="Major Adverse\nCV Events (MACE)\n(↑ excess risk)" fillcolor="#1A5276" fontcolor=white shape=diamond]
    biochemical_cure [label="Biochemical Cure\n(ARR normalisation)" fillcolor="#27AE60" fontcolor=white shape=diamond]
    clinical_cure [label="Clinical Cure\n(BP + K+ normal)" fillcolor="#27AE60" fontcolor=white shape=diamond]
  }

  /* ===================== RAAS CASCADE ===================== */
  angiotensinogen -> renin [label="substrate\n(cleaved by renin)" color="#2980B9"]
  renin -> renin_substrate [label="produces\nAng I" color="#2980B9" style=bold]
  renin_substrate -> ACE [label="substrate" color="#2980B9"]
  ACE -> AngII [label="converts\nAng I→II" color="#2980B9" style=bold]
  ACE2 -> Ang_1_7 [label="cleaves\nAng I/II" color="#27AE60"]
  AngII -> Ang_1_7 [label="ACE2\nconverts" color="#27AE60"]
  Ang_1_7 -> MasR [label="activates\n(counter-reg.)" color="#27AE60"]
  MasR -> NO_production [label="vasodilatory\neffect" color="#27AE60"]
  AngII -> AT1R [label="binds\n(primary)" color="#2980B9" style=bold]
  AngII -> AT2R [label="counter-\nregulatory" color="#AED6F1"]
  AT1R -> zona_glomerulosa [label="stimulates\nCa²⁺↑" color="#E67E22"]
  AT1R -> VSMC [label="vasoconstriction\nVSMC growth" color="#9B59B6"]
  AT1R -> sympathetic_ns [label="activates\ncentral" color="#9B59B6"]
  chymase -> AngII [label="alternative\nAng II source" color="#5DADE2" style=dashed]
  bradykinin -> ACE [label="degraded by ACE\n(→ACEi→cough)" color="#5DADE2"]
  aldosterone_plasma -> renin [label="Na+ retention\n→ pressure →\nrenin↓ (PA)" color="#C0392B" arrowhead=tee style=bold]
  aldosterone_plasma -> ARR [label="numerator" color="#E67E22"]
  renin_plasma -> ARR [label="denominator\n(↓ in PA)" color="#3498DB"]
  ARR -> ARR_diag [label="≥30 →\nscreening +" color="#7F8C8D" style=dashed]

  /* ===================== ADRENAL STEROIDOGENESIS ===================== */
  cholesterol_adrenal -> StAR_adrenal [label="transported\n(rate-limiting)" color="#E67E22"]
  StAR_adrenal -> CYP11A1 [label="enables" color="#E67E22"]
  CYP11A1 -> pregnenolone [label="synthesizes\n(P450scc)" color="#E67E22"]
  pregnenolone -> progesterone_adrenal [label="3β-HSD2" color="#E67E22"]
  progesterone_adrenal -> CYP21A2 [label="substrate" color="#E67E22"]
  CYP21A2 -> deoxycorticosterone [label="produces\nDOC" color="#E67E22"]
  deoxycorticosterone -> CYP11B1 [label="substrate" color="#E67E22"]
  CYP11B1 -> corticosterone [label="produces" color="#E67E22"]
  corticosterone -> CYP11B2 [label="substrate\n(ZG only)" color="#BA4A00"]
  CYP11B2 -> aldosterone_adrenal [label="produces\n(aldosterone\nsynthase)" color="#BA4A00" style=bold]

  zona_glomerulosa -> CYP11B2 [label="exclusively\nexpresses" color="#E67E22"]
  Ca2plus_adrenal -> CYP11B2 [label="activates via\nCaMKII" color="#E67E22"]
  Ca2plus_adrenal -> PKC_adrenal [label="activates" color="#E67E22"]
  PKC_adrenal -> CYP11B2 [label="upregulates" color="#E67E22"]

  APA -> CYP11B2_upregulation [label="autonomous\nCYP11B2 expression" color="#E74C3C" style=bold]
  BAH -> CYP11B2_upregulation [label="bilateral\nCYP11B2 excess" color="#C0392B" style=bold]
  KCNJ5_mut -> Ca2plus_adrenal [label="Na+ influx→\ndepolarization→\nCa²⁺↑" color="#E74C3C"]
  CACNA1D_mut -> Ca2plus_adrenal [label="constitutive\nCa²⁺ entry" color="#E74C3C"]
  ATP1A1_mut -> Ca2plus_adrenal [label="H+/Na+ influx\n→ depolarization" color="#E74C3C"]
  CYP11B2_upregulation -> aldosterone_adrenal [label="excess\nsecretion" color="#E74C3C" style=bold]
  aldosterone_adrenal -> aldosterone_plasma [label="secreted to\ncirculation" color="#E67E22"]

  AngII -> zona_glomerulosa [label="physiologic\nstimulus" color="#2980B9"]

  /* ===================== RENAL TUBULE SIGNALING ===================== */
  aldosterone_plasma -> MR_cytoplasm [label="diffuses into\ncell, binds MR" color="#27AE60" style=bold]
  MR_cytoplasm -> Aldo_MR_complex [label="nuclear\ntranslocation" color="#27AE60"]
  Aldo_MR_complex -> SGK1 [label="transcribes\nSGK1" color="#27AE60"]
  Aldo_MR_complex -> ENaC_alpha [label="upregulates\nαENaC" color="#27AE60" style=bold]
  SGK1 -> Nedd4_2 [label="phosphorylates\n(inhibits)" color="#27AE60"]
  Nedd4_2 -> ENaC_channel [label="ubiquitinates\n(degradation)" color="#C0392B" arrowhead=tee]
  ENaC_alpha -> ENaC_channel [label="assembles" color="#27AE60"]
  ENaC_beta -> ENaC_channel [label="assembles" color="#27AE60"]
  ENaC_gamma -> ENaC_channel [label="assembles" color="#27AE60"]
  ENaC_channel -> renal_Na_retention [label="Na+ absorption\n↑↑ in PA" color="#27AE60" style=bold]
  ENaC_channel -> ROMK [label="electrochemical\ngradient drives K+" color="#27AE60"]
  ROMK -> renal_K_excretion [label="K+ secretion\n↑ → hypokalemia" color="#E74C3C" style=bold]
  NaK_ATPase -> renal_Na_retention [label="basolateral\ntransport" color="#27AE60"]
  Aldo_MR_complex -> NaK_ATPase [label="upregulates\nα1 subunit" color="#27AE60"]
  H_ATPase -> renal_H_excretion [label="H+ secretion\n→ alkalosis" color="#27AE60"]
  renal_Na_retention -> plasma_Na [label="raises" color="#3498DB"]
  renal_Na_retention -> plasma_volume [label="expands" color="#3498DB"]
  renal_K_excretion -> plasma_K [label="depletes" color="#E74C3C"]
  renal_H_excretion -> plasma_HCO3 [label="raises HCO3-\n→ alkalosis" color="#27AE60"]
  GFR -> ARR_diag [label="false-negative\nif CKD" color="#566573" style=dashed]
  TGF_renin -> renin [label="pressure-\nnatriuresis →\nrenin↓" color="#C0392B" arrowhead=tee]

  /* ===================== CARDIOVASCULAR CONNECTIONS ===================== */
  plasma_volume -> preload [label="increases" color="#9B59B6"]
  preload -> stroke_volume [label="Frank-Starling" color="#9B59B6"]
  stroke_volume -> cardiac_output [label="defines" color="#9B59B6"]
  HR -> cardiac_output [label="defines" color="#9B59B6"]
  cardiac_output -> MAP [label="CO × TPR" color="#6C3483" style=bold]
  TPR -> MAP [label="CO × TPR" color="#6C3483" style=bold]
  AT1R -> TPR [label="vasoconstriction\n↑ TPR" color="#8E44AD"]
  VSMC -> TPR [label="tone →\nresistance" color="#8E44AD"]
  NO_production -> VSMC [label="relaxes" color="#27AE60" arrowhead=tee]
  ET1 -> VSMC [label="constricts" color="#E74C3C"]
  sympathetic_ns -> HR [label="increases" color="#9B59B6"]
  sympathetic_ns -> TPR [label="increases" color="#9B59B6"]
  baroreceptor -> sympathetic_ns [label="blunted\nresponse" color="#7F8C8D" style=dashed]
  aldosterone_plasma -> endothelium [label="direct MR\nactivation" color="#E67E22"]
  endothelium -> NO_production [label="eNOS activity\n(reduced by aldo)" color="#27AE60"]
  endothelium -> ET1 [label="secretes" color="#E74C3C"]
  MAP -> SBP [label="correlates" color="#9B59B6" style=dashed]
  MAP -> DBP [label="correlates" color="#9B59B6" style=dashed]
  plasma_K -> arrhythmia_risk [label="K<3.0→\nQTc↑, VT risk" color="#E74C3C"]

  /* ===================== TARGET ORGAN DAMAGE ===================== */
  aldosterone_plasma -> cardiac_MR [label="activates\ncardiac MR" color="#E67E22"]
  cardiac_MR -> TGF_beta_cardiac [label="induces" color="#7F8C8D"]
  cardiac_MR -> myocardial_macrophage [label="activates" color="#7F8C8D"]
  TGF_beta_cardiac -> collagen_I_III [label="induces\ncollagen synthesis" color="#7F8C8D"]
  collagen_I_III -> cardiac_fibrosis [label="deposits" color="#566573"]
  cardiac_fibrosis -> LVH [label="contributes\n(excess over HT)" color="#566573"]
  myocardial_macrophage -> IL1_cardiac [label="secretes" color="#7F8C8D"]
  oxidative_stress_PA -> VCAM1 [label="activates" color="#566573"]
  VCAM1 -> myocardial_macrophage [label="recruits" color="#566573"]
  aldosterone_plasma -> PAI1 [label="induces\nPAI-1" color="#E67E22"]
  LVH -> atrial_fibrillation [label="structural\nsubstrate" color="#566573"]
  cardiac_fibrosis -> atrial_fibrillation [label="arrhythmogenic\nsubstrate" color="#566573"]
  atrial_fibrillation -> stroke_risk [label="cardioembolic\nrisk" color="#566573"]
  LVH -> MACE [label="major risk factor" color="#E74C3C"]
  MAP -> LVH [label="pressure\noverload" color="#9B59B6"]
  aldosterone_plasma -> renal_fibrosis [label="direct\nrenal MR" color="#E67E22"]
  galectin3 -> cardiac_fibrosis [label="biomarker\nof fibrosis" color="#BDC3C7" style=dashed]

  /* ===================== CLINICAL ENDPOINTS ===================== */
  MAP -> hypertension_clin [label="elevated →\nresistant HT" color="#9B59B6"]
  plasma_K -> hypokalemia_clin [label="<3.5 mEq/L" color="#E74C3C"]
  plasma_HCO3 -> metabolic_alkalosis [label=">26 mEq/L" color="#27AE60"]
  hypokalemia_clin -> muscle_weakness [label="causes" color="#3498DB"]
  hypokalemia_clin -> polyuria [label="nephrogenic DI\n(K+ depletion)" color="#3498DB"]
  hypertension_clin -> headache_PA [label="symptom" color="#3498DB"]
  MACE -> MI_risk [label="excess MI\nvs essential HT" color="#E74C3C"]
  MACE -> stroke_risk [label="excess stroke" color="#E74C3C"]

  /* ===================== DIAGNOSTICS ===================== */
  aldosterone_plasma -> PAC [label="measured" color="#7F8C8D" style=dashed]
  renin_plasma -> PRA [label="measured" color="#7F8C8D" style=dashed]
  PAC -> ARR_diag [label="numerator" color="#E67E22" style=dashed]
  PRA -> ARR_diag [label="denominator" color="#3498DB" style=dashed]
  saline_test -> PAC [label="post-infusion\nPAC >10 ng/dL" color="#7F8C8D" style=dashed]
  fludro_test -> PAC [label="nonsuppressed\naldo" color="#7F8C8D" style=dashed]
  CT_adrenal -> AVS [label="CT negative/\nequivocal → AVS" color="#566573"]
  AVS -> lateralization [label="computes" color="#566573"]
  lateralization -> APA [label="confirms\nAPA subtype" color="#566573" style=dashed]

  /* ===================== DRUG PK ===================== */
  spiro_dose -> spiro_gut [label="oral, F~72%" color="#1ABC9C"]
  spiro_gut -> spiro_plasma [label="absorbed" color="#1ABC9C"]
  spiro_plasma -> spiro_liver [label="hepatic\nmetabolism" color="#1ABC9C"]
  spiro_liver -> canrenone [label="active\nmetabolite\n(T½~20h)" color="#1ABC9C"]

  eple_dose -> eple_plasma [label="oral F~69%\nCYP3A4" color="#1ABC9C"]
  fine_dose -> fine_plasma [label="oral F~44%\nCYP3A4" color="#1ABC9C"]
  acei_dose -> acei_plasma [label="oral, prodrug\nramiprilat" color="#1ABC9C"]
  ccb_dose -> ccb_plasma [label="oral F~64%\nT½=35-50h" color="#1ABC9C"]

  /* ===================== DRUG PD ===================== */
  spiro_plasma -> spiro_MR_block [label="MR\nantagonism" color="#2980B9"]
  canrenone -> spiro_MR_block [label="active\nmetabolite" color="#2980B9"]
  spiro_plasma -> spiro_AR_block [label="off-target\nAR binding" color="#E74C3C"]
  spiro_plasma -> spiro_PR_block [label="off-target\nPR agonism" color="#F39C12"]
  spiro_MR_block -> MR_cytoplasm [label="competitive\nblockade" color="#C0392B" arrowhead=tee]
  spiro_MR_block -> spiro_Na_excretion [label="ENaC↓ →\nNa+ lost" color="#27AE60"]
  spiro_MR_block -> spiro_K_retention [label="ROMK↓ →\nK+ retained" color="#27AE60"]
  spiro_Na_excretion -> plasma_Na [label="reduces\nhypervolemia" color="#27AE60" arrowhead=tee style=dashed]
  spiro_K_retention -> plasma_K [label="normalises" color="#27AE60"]
  spiro_MR_block -> MAP [label="BP reduction\n~20 mmHg" color="#27AE60" arrowhead=tee]

  eple_plasma -> eple_MR_block [label="selective\nMR antagonism" color="#2980B9"]
  eple_MR_block -> MR_cytoplasm [label="competitive\nblockade" color="#C0392B" arrowhead=tee]
  fine_plasma -> fine_MR_block [label="non-steroidal\nhigh-affinity MR" color="#2980B9"]
  fine_MR_block -> cardiac_MR [label="blocks cardiac\nMR signaling" color="#27AE60" arrowhead=tee]
  fine_MR_block -> fine_cardiac_protect [label="anti-fibrotic\nprotection" color="#27AE60"]
  fine_cardiac_protect -> cardiac_fibrosis [label="reduces" color="#27AE60" arrowhead=tee]

  acei_plasma -> acei_ACE_block [label="ACE\ninhibition" color="#2980B9"]
  acei_ACE_block -> AngII [label="reduces\nAng II" color="#27AE60" arrowhead=tee]
  acei_ACE_block -> bradykinin [label="bradykinin\naccumulation" color="#F39C12"]
  acei_Ang2_reduce -> aldosterone_plasma [label="partial↓\n(incomplete in PA)" color="#27AE60" arrowhead=tee style=dashed]
  acei_bradykinin_up -> bradykinin [label="↑ bradykinin\n→ cough/AE" color="#F39C12"]

  ccb_plasma -> ccb_VGCC [label="Ca²⁺ channel\nblockade" color="#2980B9"]
  ccb_VGCC -> ccb_VSMC_relax [label="vasodilation" color="#27AE60"]
  ccb_VSMC_relax -> TPR [label="TPR↓\n→ BP↓" color="#27AE60" arrowhead=tee]
  ccb_VGCC -> ccb_adrenal_Ca [label="minor aldo\nsuppression" color="#27AE60" style=dashed]

  adrenalectomy -> APA [label="removes\ntumour" color="#E74C3C"]
  adrenalectomy -> surgery_aldo_cure [label="cures\nautonomous Aldo" color="#E74C3C"]
  surgery_aldo_cure -> aldosterone_plasma [label="normalises\nAldosterone" color="#27AE60" arrowhead=tee]
  surgery_aldo_cure -> renin [label="renin\nrecovery" color="#27AE60"]
  surgery_aldo_cure -> biochemical_cure [label="ARR\nnormalisation" color="#27AE60"]
  surgery_BP_norm -> hypertension_clin [label="BP cure 40-50%" color="#27AE60" arrowhead=tee style=dashed]
  surgery_K_norm -> hypokalemia_clin [label="K+ cure ~100%" color="#27AE60" arrowhead=tee]

  /* Diagnostic connections */
  serum_K_diag -> hypokalemia_clin [label="confirms" color="#566573" style=dashed]
  urine_K_diag -> renal_K_excretion [label="quantifies" color="#566573" style=dashed]
  serum_cortisol -> zona_fasciculata [label="rules out\nCS/pheo" color="#566573" style=dashed]

  biochemical_cure -> clinical_cure [label="prerequisite" color="#27AE60"]
}
