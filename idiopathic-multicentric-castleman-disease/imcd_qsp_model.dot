// Idiopathic Multicentric Castleman Disease (iMCD) QSP Mechanistic Map
// IL-6-driven lymphoproliferative cytokine storm; siltuximab / tocilizumab / sirolimus / rituximab
// 14 clusters, 150+ nodes, drug PK/PD + immunopathology + organ effects + clinical endpoints
digraph iMCD_QSP {
    graph [rankdir=LR, splines=true, overlap=false, nodesep=0.30, ranksep=0.45,
           fontname="Helvetica", fontsize=10, label="Idiopathic Multicentric Castleman Disease (iMCD) — QSP Mechanistic Map\nIL-6 cytokine storm · siltuximab · tocilizumab · sirolimus · rituximab · anakinra · ruxolitinib", labelloc=t];
    node  [fontname="Helvetica", fontsize=9, style="filled,rounded", shape=box, color="#888888"];
    edge  [fontname="Helvetica", fontsize=8, color="#555555"];

    // ============ 1. Genetic / Triggering Factors ============
    subgraph cluster_genetics {
        label="① Genetic & Trigger Factors";
        style="rounded,filled"; fillcolor="#f4ecf7";
        HHV8_neg     [label="HHV-8 NEGATIVE\n(distinguishes iMCD\nfrom MCD-HHV8/KSHV)", fillcolor="#e8daef"];
        IL6_germline [label="IL6 / IL6R / STAT3\ngermline variants\n(suspected)", fillcolor="#e8daef"];
        Somatic_var  [label="Somatic clonal\nvariants (NF-kB, PIK3CA)\nMason 2018 Cell Rep", fillcolor="#e8daef"];
        Autoantigen  [label="Putative\nautoantigen drive\n(TAFRO subtype)", fillcolor="#e8daef"];
        Infection_T  [label="Viral / bacterial\ntrigger (unknown)", fillcolor="#e8daef"];
        HHV8_neg -> Somatic_var [style=dashed];
        IL6_germline -> StromalLN [color="#888888"];
        Autoantigen -> Plasmablast [color="#888888"];
        Infection_T -> Monocyte [color="#888888"];
    }

    // ============ 2. Lymph Node Histopathology ============
    subgraph cluster_LN {
        label="② Lymph Node Pathology (hyperplastic GC, plasmacytic, mixed)";
        style="rounded,filled"; fillcolor="#fef9e7";
        LN_Cortex      [label="LN Cortex\nfollicular hyperplasia", fillcolor="#fcf3cf"];
        LN_GC          [label="Germinal Center\n(atretic / regressed\nin hyaline-vascular,\nhyperplastic in plasma)", fillcolor="#fcf3cf"];
        LN_Mantle      [label="Onion-skin mantle\nzone hyperplasia", fillcolor="#fcf3cf"];
        Interfollicular[label="Interfollicular\nsheets of plasmablasts\n(IgA/IgG/IgM)", fillcolor="#fcf3cf"];
        FDC            [label="FDC dysplasia\n(CD21+/CD23+)", fillcolor="#fcf3cf"];
        HEV            [label="Penetrating HEVs\nradially into GC", fillcolor="#fcf3cf"];
        Hyaline        [label="Hyalinized vessel\n(lollipop sign)", fillcolor="#fcf3cf"];
        StromalLN      [label="LN stromal IL-6\nsource (FRC, FDC)", fillcolor="#fcf3cf"];
        LN_Cortex -> LN_GC -> LN_Mantle -> Interfollicular;
        LN_GC -> FDC; LN_GC -> HEV; LN_GC -> Hyaline;
        StromalLN -> IL6_LN;
    }

    // ============ 3. Cellular Players ============
    subgraph cluster_cells {
        label="③ Cellular Players";
        style="rounded,filled"; fillcolor="#fef5e7";
        Plasmablast [label="Plasmablast\n(CD20- CD138+ IgM/A/G)", fillcolor="#fad7a0"];
        Bnaive      [label="Naive B cell", fillcolor="#fad7a0"];
        Bmem        [label="Memory B cell\n(CD20+)", fillcolor="#fad7a0"];
        Tfh         [label="Tfh / Tfr\n(CXCR5+ ICOS+ Bcl6+)", fillcolor="#fad7a0"];
        Th17        [label="Th17 / Th1\n(IL-17 IFN-γ)", fillcolor="#fad7a0"];
        Treg        [label="FOXP3 Treg\n(may be insufficient)", fillcolor="#fad7a0"];
        Monocyte    [label="Monocyte / Macrophage\nIL-6 source", fillcolor="#fad7a0"];
        DC          [label="Dendritic cell\n(plasmacytoid pDC)", fillcolor="#fad7a0"];
        Neutrophil  [label="Neutrophil\n(TAFRO: elevated)", fillcolor="#fad7a0"];
        Tcyto       [label="CD8 effector T", fillcolor="#fad7a0"];
        Monocyte -> IL6_LN;
        Tfh -> Plasmablast [label="IL-21", color="#1f77b4"];
        Bnaive -> Bmem -> Plasmablast;
        DC -> Tfh;
    }

    // ============ 4. Master Cytokine Axis — IL-6 ============
    subgraph cluster_IL6 {
        label="④ IL-6 / sIL-6R / gp130 Cytokine Storm (master driver)";
        style="rounded,filled"; fillcolor="#fadbd8";
        IL6_LN     [label="IL-6 (LN germ.\ncenter + stromal)\n50–500 pg/mL", fillcolor="#f1948a"];
        IL6_sys    [label="Systemic IL-6\n(serum > 7 pg/mL)", fillcolor="#f1948a"];
        sIL6R      [label="Soluble IL-6R\n(trans-signaling)", fillcolor="#f1948a"];
        gp130      [label="gp130 (IL6ST)\nshared receptor", fillcolor="#f1948a"];
        JAK1_2     [label="JAK1 / JAK2 / TYK2", fillcolor="#f1948a"];
        STAT3      [label="STAT3 phospho /\ndimerization / nuclear", fillcolor="#f1948a"];
        SOCS3      [label="SOCS3 negative FB", fillcolor="#f1948a"];
        IL6_LN -> IL6_sys [label="spill"];
        IL6_sys -> gp130 [label="cis (mIL6R+)"];
        IL6_sys -> sIL6R -> gp130 [label="trans (cells lacking mIL6R)"];
        gp130 -> JAK1_2 -> STAT3 -> SOCS3 [style=dashed, label="−FB"];
        STAT3 -> Plasmablast [label="proliferation\n+survival", color="#c0392b"];
        STAT3 -> HepAcute    [label="acute phase", color="#c0392b"];
        STAT3 -> VEGF_axis   [label="HIF-1α / VEGF", color="#c0392b"];
        STAT3 -> Anemia      [label="hepcidin↑", color="#c0392b"];
    }

    // ============ 5. Other Inflammatory Cytokines ============
    subgraph cluster_cytokines2 {
        label="⑤ Secondary Cytokines & TAFRO Subtype";
        style="rounded,filled"; fillcolor="#fef9e7";
        IL1b      [label="IL-1β\n(NLRP3 inflammasome)", fillcolor="#fcf3cf"];
        TNFa      [label="TNF-α", fillcolor="#fcf3cf"];
        IL10      [label="IL-10 (regulatory\nbut elevated)", fillcolor="#fcf3cf"];
        IFNg      [label="IFN-γ", fillcolor="#fcf3cf"];
        IL18      [label="IL-18\n(macrophage activation)", fillcolor="#fcf3cf"];
        IL2       [label="sIL-2Rα\n(activated T)", fillcolor="#fcf3cf"];
        VEGF_axis [label="VEGF / VEGF-A\n(angiogenesis,\nedema, effusions)", fillcolor="#fcf3cf"];
        CXCL13    [label="CXCL13\n(Tfh chemokine)", fillcolor="#fcf3cf"];
        TAFRO_subtype [label="TAFRO subtype:\nThrombocytopenia\nAnasarca · Fever\nReticulin fibrosis\nOrganomegaly", fillcolor="#f5b7b1"];
        VEGF_axis -> TAFRO_subtype;
        IL18 -> TAFRO_subtype;
        IL1b -> NLRP3_path;
        IL6_sys -> VEGF_axis;
    }

    // ============ 6. PI3K / mTOR & NF-kB ============
    subgraph cluster_mTOR {
        label="⑥ PI3K-AKT-mTOR & NF-κB (sirolimus target)";
        style="rounded,filled"; fillcolor="#e8f8f5";
        PI3K   [label="PI3K (p110δ)", fillcolor="#a3e4d7"];
        AKT    [label="AKT (Ser473)", fillcolor="#a3e4d7"];
        mTORC1 [label="mTORC1 (Raptor)\nphospho-S6K1 / 4EBP1", fillcolor="#a3e4d7"];
        mTORC2 [label="mTORC2 (Rictor)", fillcolor="#a3e4d7"];
        TFH_mTOR_ON [label="TAFRO Tfh\nmTORC1 hyperactive\nFajgenbaum 2019 JCI", fillcolor="#a3e4d7"];
        NFkB   [label="NF-κB canonical\np65/p50", fillcolor="#a3e4d7"];
        NFkB_nc [label="NF-κB non-canonical\nRelB/p52", fillcolor="#a3e4d7"];
        PI3K -> AKT -> mTORC1 -> TFH_mTOR_ON;
        AKT -> mTORC2;
        TNFa -> NFkB -> IL6_LN [color="#c0392b"];
        NFkB_nc -> StromalLN;
    }

    // ============ 7. NLRP3 / Inflammasome ============
    subgraph cluster_NLRP3 {
        label="⑦ NLRP3 / Caspase-1 (anakinra target)";
        style="rounded,filled"; fillcolor="#fdebd0";
        NLRP3_path [label="NLRP3 inflammasome\nassembly", fillcolor="#f8c471"];
        ASC        [label="ASC speck", fillcolor="#f8c471"];
        Casp1      [label="Caspase-1\n(IL-1β maturation)", fillcolor="#f8c471"];
        GSDMD      [label="GSDMD-N\n(pyroptosis)", fillcolor="#f8c471"];
        IL18_prod  [label="pro-IL-18 → IL-18", fillcolor="#f8c471"];
        NLRP3_path -> ASC -> Casp1 -> IL1b;
        Casp1 -> GSDMD;
        Casp1 -> IL18_prod -> IL18;
    }

    // ============ 8. Acute-Phase & Hepatic ============
    subgraph cluster_hep {
        label="⑧ Hepatic Acute-Phase Response (STAT3)";
        style="rounded,filled"; fillcolor="#e8f6f3";
        HepAcute [label="Hepatocyte\nSTAT3 nuclear", fillcolor="#a2d9ce"];
        CRP      [label="CRP\n(>5–250 mg/L)", fillcolor="#a2d9ce"];
        SAA      [label="SAA (amyloid A)", fillcolor="#a2d9ce"];
        Fibrinogen [label="Fibrinogen ↑", fillcolor="#a2d9ce"];
        Albumin  [label="Albumin ↓\n(neg APR)", fillcolor="#a2d9ce"];
        Hepcidin [label="Hepcidin\n(BMP/SMAD + STAT3)", fillcolor="#a2d9ce"];
        Ferritin [label="Ferritin ↑↑", fillcolor="#a2d9ce"];
        IGF1_dec [label="IGF-1 ↓", fillcolor="#a2d9ce"];
        HepAcute -> CRP; HepAcute -> SAA; HepAcute -> Fibrinogen;
        HepAcute -> Albumin [arrowhead=tee];
        HepAcute -> Hepcidin -> Anemia;
        HepAcute -> Ferritin;
        HepAcute -> IGF1_dec [arrowhead=tee];
    }

    // ============ 9. Hematologic / Anemia / Cytopenias ============
    subgraph cluster_heme {
        label="⑨ Hematologic Manifestations";
        style="rounded,filled"; fillcolor="#eaeded";
        Hepcidin_act [label="Hepcidin → ferroportin\ninternalization", fillcolor="#d5dbdb"];
        IronRetention [label="Macrophage Fe sequestered", fillcolor="#d5dbdb"];
        Anemia [label="Anemia of inflammation\nHb < 10 g/dL", fillcolor="#d5dbdb"];
        Platelet [label="Platelet count\n(thrombocytopenia\nin TAFRO; ↑ in non-TAFRO)", fillcolor="#d5dbdb"];
        WBC      [label="Leukocytosis / leukopenia", fillcolor="#d5dbdb"];
        PolyHGGlob [label="Polyclonal\nhypergammaglobulinemia\n(IgG > 3 g/dL)", fillcolor="#d5dbdb"];
        BM_retic [label="BM reticulin fibrosis\n(TAFRO)", fillcolor="#d5dbdb"];
        Hepcidin -> Hepcidin_act -> IronRetention -> Anemia;
        Plasmablast -> PolyHGGlob;
        TAFRO_subtype -> Platelet [arrowhead=tee];
        TAFRO_subtype -> BM_retic;
    }

    // ============ 10. Organ-System Effects ============
    subgraph cluster_organ {
        label="⑩ Multi-Organ Effects";
        style="rounded,filled"; fillcolor="#fef9e7";
        LN_enlarge [label="Generalized\nlymphadenopathy\n(≥2 stations, ≥1 cm)", fillcolor="#fdebd0"];
        Spleen     [label="Splenomegaly", fillcolor="#fdebd0"];
        Hepatomeg  [label="Hepatomegaly", fillcolor="#fdebd0"];
        Renal      [label="Renal:\nTMA / AA-amyloid /\nFSGS / interstitial", fillcolor="#fdebd0"];
        Lung       [label="Lung: LIP, GGO,\npleural effusion", fillcolor="#fdebd0"];
        Skin       [label="Skin: rash, edema,\ncherry hemangiomas", fillcolor="#fdebd0"];
        CNS        [label="CNS: fatigue, mood,\nrare meningitis", fillcolor="#fdebd0"];
        GI         [label="GI: ascites, edema", fillcolor="#fdebd0"];
        Endocrine  [label="Endocrine:\nadrenal insuff, DM", fillcolor="#fdebd0"];
        Anasarca   [label="Anasarca / 3rd-space\nfluid (TAFRO)", fillcolor="#fdebd0"];
        LN_enlarge -> Spleen; LN_enlarge -> Hepatomeg;
        VEGF_axis -> Anasarca;
        VEGF_axis -> Lung;
        IL6_sys -> Renal;
        TAFRO_subtype -> Anasarca;
        IL6_sys -> Endocrine;
    }

    // ============ 11. Drug PK Compartments ============
    subgraph cluster_PK {
        label="⑪ Drug PK Compartments (IV / SC / PO)";
        style="rounded,filled"; fillcolor="#d6eaf8";
        SILT_central  [label="Siltuximab Vc\n(11 mg/kg IV q3w)", fillcolor="#aed6f1"];
        SILT_perif    [label="Siltuximab Vp", fillcolor="#aed6f1"];
        TOCZ_central  [label="Tocilizumab Vc\n(8 mg/kg IV q2-4w\nor 162 mg SC)", fillcolor="#aed6f1"];
        TOCZ_perif    [label="Tocilizumab Vp", fillcolor="#aed6f1"];
        SAT_central   [label="Satralizumab Vc\n(off-label)", fillcolor="#aed6f1"];
        SIRO_central  [label="Sirolimus C\n(target 6–14 ng/mL)", fillcolor="#aed6f1"];
        SIRO_perif    [label="Sirolimus tissue", fillcolor="#aed6f1"];
        RTX_central   [label="Rituximab Vc\n(375 mg/m² IV)", fillcolor="#aed6f1"];
        RTX_perif     [label="Rituximab Vp", fillcolor="#aed6f1"];
        ANA_central   [label="Anakinra (100 mg SC)", fillcolor="#aed6f1"];
        RUX_central   [label="Ruxolitinib (PO BID)", fillcolor="#aed6f1"];
        BORT_central  [label="Bortezomib", fillcolor="#aed6f1"];
        CHOP_doxo     [label="CHOP – doxorubicin", fillcolor="#aed6f1"];
        CHOP_cyclo    [label="CHOP – cyclophosphamide", fillcolor="#aed6f1"];
        Pred          [label="Prednisone PO\n0.5–1 mg/kg", fillcolor="#aed6f1"];
        Tha           [label="Thalidomide PO\n(TAFRO salvage)", fillcolor="#aed6f1"];
        SILT_central -> SILT_perif [dir=both];
        TOCZ_central -> TOCZ_perif [dir=both];
        SIRO_central -> SIRO_perif [dir=both];
        RTX_central  -> RTX_perif  [dir=both];
    }

    // ============ 12. Drug Targets & MoA ============
    subgraph cluster_MoA {
        label="⑫ Drug Mechanism of Action";
        style="rounded,filled"; fillcolor="#d1f2eb";
        Silt_bind     [label="Siltuximab :\nbinds IL-6 directly\nKd ≈ 1 pM", fillcolor="#76d7c4"];
        Tocz_bind     [label="Tocilizumab :\nblocks IL-6R\n(both m and s)", fillcolor="#76d7c4"];
        Sirol_mTOR    [label="Sirolimus :\nFKBP12 → mTORC1 inh", fillcolor="#76d7c4"];
        RTX_CD20      [label="Rituximab :\nCD20 (B cell, not plasma)", fillcolor="#76d7c4"];
        ANA_IL1R      [label="Anakinra :\nIL-1Rα antagonist", fillcolor="#76d7c4"];
        RUX_JAK       [label="Ruxolitinib :\nJAK1/2 inhibitor", fillcolor="#76d7c4"];
        BORT_prot     [label="Bortezomib :\n26S proteasome\n(plasma cell)", fillcolor="#76d7c4"];
        CHOP_DNA      [label="CHOP : DNA / microtubule\ncytotoxicity", fillcolor="#76d7c4"];
        Pred_GR       [label="Prednisone :\nGR → NF-κB inh", fillcolor="#76d7c4"];
        Tha_TNF       [label="Thalidomide :\ncereblon, TNF↓, anti-angiogenic", fillcolor="#76d7c4"];
        SILT_central -> Silt_bind -> IL6_sys [arrowhead=tee, color="#27ae60"];
        TOCZ_central -> Tocz_bind -> gp130   [arrowhead=tee, color="#27ae60"];
        SIRO_central -> Sirol_mTOR -> mTORC1 [arrowhead=tee, color="#27ae60"];
        RTX_central  -> RTX_CD20   -> Bmem   [arrowhead=tee, color="#27ae60"];
        ANA_central  -> ANA_IL1R   -> IL1b   [arrowhead=tee, color="#27ae60"];
        RUX_central  -> RUX_JAK    -> JAK1_2 [arrowhead=tee, color="#27ae60"];
        BORT_central -> BORT_prot  -> Plasmablast [arrowhead=tee, color="#27ae60"];
        CHOP_doxo    -> CHOP_DNA   -> Plasmablast [arrowhead=tee, color="#27ae60"];
        CHOP_cyclo   -> CHOP_DNA;
        Pred         -> Pred_GR    -> NFkB   [arrowhead=tee, color="#27ae60"];
        Tha          -> Tha_TNF    -> TNFa   [arrowhead=tee, color="#27ae60"];
        Tha_TNF      -> VEGF_axis  [arrowhead=tee, color="#27ae60"];
    }

    // ============ 13. Clinical Endpoints (CDCN / NCCN response) ============
    subgraph cluster_endpoints {
        label="⑬ Clinical Endpoints (CDCN diagnostic / response)";
        style="rounded,filled"; fillcolor="#f5b7b1";
        CDCN_dx   [label="CDCN diagnostic\n(Fajgenbaum 2017 Blood):\n2 major + ≥2 minor\n+ lymphadenopathy +\nLN histology", fillcolor="#e74c3c", fontcolor="white"];
        Major1    [label="MAJOR: Castleman\nlymphadenopathy", fillcolor="#ec7063", fontcolor="white"];
        Major2    [label="MAJOR: LN histology\n(hyperplastic GC,\nplasmacytic, mixed)", fillcolor="#ec7063", fontcolor="white"];
        Minor_L   [label="LAB minor: CRP↑, ESR↑,\nIL-6↑, Hb↓, plt↑/↓,\nIgG↑↑, albumin↓", fillcolor="#ec7063", fontcolor="white"];
        Minor_C   [label="CLINICAL minor:\nfever, fatigue, weight loss,\nhepato/splenomeg,\nedema/effusion, eruptive\nhemangiomas, lymphocytic\ninterstitial pneumonitis", fillcolor="#ec7063", fontcolor="white"];
        Response  [label="CDCN Response (van Rhee 2018):\nDR (durable) / PR / SD / PD\n+ B-symptom + CRP + Hb +\nLN size composite", fillcolor="#ec7063", fontcolor="white"];
        OS_PFS    [label="OS / PFS / EFS\n5-yr OS ~65–90%\n(depends on subtype)", fillcolor="#ec7063", fontcolor="white"];
        TAFRO_severity [label="TAFRO severity\n(Iwaki 2016)", fillcolor="#ec7063", fontcolor="white"];
        CDCN_dx -> Major1; CDCN_dx -> Major2; CDCN_dx -> Minor_L; CDCN_dx -> Minor_C;
        CRP -> Minor_L; Anemia -> Minor_L; PolyHGGlob -> Minor_L; Albumin -> Minor_L;
        LN_enlarge -> Major1;
        IL6_sys -> Response [arrowhead=tee, label="treatment\nresponse"];
    }

    // ============ 14. Safety / Adverse Events ============
    subgraph cluster_safety {
        label="⑭ Safety / Adverse Events";
        style="rounded,filled"; fillcolor="#fdfefe";
        Inf_risk      [label="Infection risk\n(siltuximab,\ntocilizumab, RTX)", fillcolor="#fcf3cf"];
        Neutropenia   [label="Neutropenia\n(siltuximab IL-6 block\n→ neutrophil margination)", fillcolor="#fcf3cf"];
        HypoIgG       [label="HypoIgG (RTX,\nbortezomib)", fillcolor="#fcf3cf"];
        Lipid         [label="Lipid abnormalities,\nstomatitis (sirolimus)", fillcolor="#fcf3cf"];
        Hepatic_AE    [label="ALT↑ (siltuximab,\ntocilizumab)", fillcolor="#fcf3cf"];
        GI_perf       [label="GI perforation\n(tocilizumab)", fillcolor="#fcf3cf"];
        IRR           [label="Infusion reaction", fillcolor="#fcf3cf"];
        PMN_periph    [label="Peripheral neuropathy\n(bortezomib, thalidomide)", fillcolor="#fcf3cf"];
        CHF           [label="Anthracycline-CHF\n(CHOP cumulative dose)", fillcolor="#fcf3cf"];
        SILT_central -> Inf_risk; TOCZ_central -> Inf_risk;
        SILT_central -> Neutropenia; TOCZ_central -> Hepatic_AE;
        RTX_central -> HypoIgG; BORT_central -> PMN_periph;
        Tha -> PMN_periph; CHOP_doxo -> CHF;
        SIRO_central -> Lipid; TOCZ_central -> GI_perf;
        SILT_central -> IRR;
    }

    // ===== Inter-cluster mechanistic edges =====
    Plasmablast -> IL6_LN [label="autocrine", color="#c0392b"];
    Plasmablast -> PolyHGGlob;
    Tfh -> IL6_LN [color="#c0392b"];
    Monocyte -> IL1b;
    Monocyte -> TNFa;
    DC -> IL18;
    NLRP3_path -> TAFRO_subtype;

    IL6_sys -> Tfh [label="differentiation", color="#c0392b"];
    IL6_sys -> Th17;

    // Treatment outcome edges
    Silt_bind   -> CRP        [arrowhead=tee, color="#27ae60"];
    Silt_bind   -> Anemia     [arrowhead=tee, color="#27ae60"];
    Silt_bind   -> LN_enlarge [arrowhead=tee, color="#27ae60"];
    Tocz_bind   -> CRP        [arrowhead=tee, color="#27ae60"];
    Sirol_mTOR  -> TAFRO_subtype [arrowhead=tee, color="#27ae60"];
    Sirol_mTOR  -> Plasmablast [arrowhead=tee, color="#27ae60"];

    // ===== Annotation node =====
    Legend [label="Color legend:\nred = activation/disease driver\ngreen = drug effect (inhibit/promote)\n— Solid = experimentally validated\n- - Dashed = inferred/hypothesized\nQSP map © CCR · CDCN 2017 criteria", shape=note, fillcolor="#fef9e7"];
}
