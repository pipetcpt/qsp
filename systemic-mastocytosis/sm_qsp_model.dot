digraph SystemicMastocytosis {
    graph [
        label="Systemic Mastocytosis (SM) – Comprehensive QSP Mechanistic Map\nKIT D816V · Mast Cell Biology · Mediator Release · Organ Involvement · Drug PK/PD"
        labelloc=t fontsize=22 fontname="Helvetica-Bold"
        bgcolor="#F8F9FA" rankdir=TB splines=ortho nodesep=0.5 ranksep=0.8
        pad=0.5
    ]
    node [fontname="Helvetica" fontsize=10 style="filled,rounded" shape=box]
    edge [fontsize=9 fontname="Helvetica"]

    // ──────────────────────────────────────────────────────────────
    // CLUSTER 1 – Genetic & Molecular Background
    // ──────────────────────────────────────────────────────────────
    subgraph cluster_genetics {
        label="1. Genetic & Molecular Background" style=filled
        fillcolor="#FFF3E0" color="#E65100" fontsize=13 fontname="Helvetica-Bold"

        KIT_WT   [label="KIT (WT)\nSCF receptor\nCD117" fillcolor="#FFE0B2"]
        KIT_D816V [label="KIT D816V\nGain-of-function\nmutation" fillcolor="#FF6F00" fontcolor=white]
        SCF      [label="SCF\n(Stem Cell Factor)\nKIT ligand" fillcolor="#FFB74D"]
        TET2     [label="TET2\nCo-mutation\nepigenetic" fillcolor="#FFCC02"]
        SRSF2    [label="SRSF2\nSplicing\nmutation" fillcolor="#FFCC02"]
        ASXL1    [label="ASXL1\nChromatin\nregulation" fillcolor="#FFCC02"]
        JAK2     [label="JAK2 V617F\nCo-mutation (rare)\nMPN overlap" fillcolor="#FFE082"]
        RUNX1    [label="RUNX1\nMast cell\ntranscription" fillcolor="#FFE0B2"]
        KIT_AUTO [label="KIT Autophosphorylation\n(constitutive, ligand-independent)" fillcolor="#FF8F00"]
    }

    // ──────────────────────────────────────────────────────────────
    // CLUSTER 2 – KIT D816V Signaling Cascades
    // ──────────────────────────────────────────────────────────────
    subgraph cluster_signaling {
        label="2. KIT D816V Signaling Cascades" style=filled
        fillcolor="#FCE4EC" color="#880E4F" fontsize=13 fontname="Helvetica-Bold"

        PI3K     [label="PI3K\n(p110/p85)" fillcolor="#F48FB1"]
        PIP3     [label="PIP3\nlipid second\nmessenger" fillcolor="#F48FB1"]
        AKT      [label="AKT / PKB\nSer473 phospho" fillcolor="#E91E63" fontcolor=white]
        mTORC1   [label="mTORC1\nprotein synthesis\nautophagy" fillcolor="#C2185B" fontcolor=white]
        mTORC2   [label="mTORC2\nAKT activation" fillcolor="#AD1457" fontcolor=white]
        PTEN     [label="PTEN\nPI3K suppressor\n(tumor suppressor)" fillcolor="#F8BBD9"]
        RAS      [label="RAS (KRAS/NRAS)\nGTPase oncogene" fillcolor="#F06292"]
        RAF      [label="RAF / BRAF\nkinase cascade" fillcolor="#EC407A"]
        MEK      [label="MEK1/2\nMAP2K" fillcolor="#E91E63" fontcolor=white]
        ERK      [label="ERK1/2\nMAPK signaling" fillcolor="#C2185B" fontcolor=white]
        JAK1_2   [label="JAK1/JAK2\nSTAT activation" fillcolor="#F48FB1"]
        STAT3    [label="STAT3\ntranscription\nfactor" fillcolor="#E91E63" fontcolor=white]
        STAT5    [label="STAT5\nanti-apoptosis\nproliferation" fillcolor="#AD1457" fontcolor=white]
        SRC      [label="SRC kinase\nYES/FYN" fillcolor="#F8BBD9"]
        LYN      [label="LYN kinase\nIgE-receptor\ncoupling" fillcolor="#F8BBD9"]
        BTK      [label="BTK\nB-cell kinase in MC" fillcolor="#F48FB1"]
        NF_kB    [label="NF-κB\nIKK complex\nsurvival genes" fillcolor="#E91E63" fontcolor=white]
        BCL2     [label="BCL-2/BCL-xL\nanti-apoptosis\noverexpressed" fillcolor="#C2185B" fontcolor=white]
        MCL1     [label="MCL-1\nanti-apoptosis" fillcolor="#AD1457" fontcolor=white]
    }

    // ──────────────────────────────────────────────────────────────
    // CLUSTER 3 – Mast Cell Biology & Differentiation
    // ──────────────────────────────────────────────────────────────
    subgraph cluster_mc_biology {
        label="3. Mast Cell Biology & Differentiation" style=filled
        fillcolor="#E8F5E9" color="#1B5E20" fontsize=13 fontname="Helvetica-Bold"

        HSC      [label="Hematopoietic\nStem Cell (HSC)" fillcolor="#A5D6A7"]
        CMP      [label="Common Myeloid\nProgenitor (CMP)" fillcolor="#81C784"]
        MCP      [label="Mast Cell\nProgenitor (MCP)\nCD34+/CD117+" fillcolor="#66BB6A"]
        PMC      [label="Progenitor MC\n(circulating)" fillcolor="#4CAF50" fontcolor=white]
        IMC      [label="Immature MC\nCD117+/CD25-" fillcolor="#43A047" fontcolor=white]
        MC_tis   [label="Tissue Mast Cell\nCD117+/CD25+\n(atypical: SM)" fillcolor="#388E3C" fontcolor=white]
        MC_act   [label="Activated MC\nDegranulating" fillcolor="#2E7D32" fontcolor=white]
        MC_apo   [label="MC Apoptosis\n(reduced in SM)" fillcolor="#C8E6C9"]
        TPSAB1   [label="Tryptase gene\nTPSAB1\nSM diagnostic" fillcolor="#A5D6A7"]
        KIT_exp  [label="KIT Overexpression\nCD117 staining\nhistology" fillcolor="#81C784"]
        FcεRI    [label="FcεRI\nIgE receptor\nhigh affinity" fillcolor="#66BB6A"]
        IgE      [label="IgE\nAllergen-specific\nSensitization" fillcolor="#A5D6A7"]
        Ag       [label="Allergen/\nAntigen trigger\ncross-linking" fillcolor="#C8E6C9"]
        MC_ENTR  [label="MC Entrapped\nin BM niches" fillcolor="#4CAF50" fontcolor=white]
    }

    // ──────────────────────────────────────────────────────────────
    // CLUSTER 4 – Mast Cell Mediator Release
    // ──────────────────────────────────────────────────────────────
    subgraph cluster_mediators {
        label="4. Mast Cell Mediator Release" style=filled
        fillcolor="#E3F2FD" color="#0D47A1" fontsize=13 fontname="Helvetica-Bold"

        // Preformed mediators
        Hist     [label="Histamine\npreformed granule\npruritus, GI, vasc." fillcolor="#BBDEFB"]
        Trypt    [label="Tryptase (α/β)\nserum biomarker\ndiagnostic >20 ng/mL" fillcolor="#64B5F6"]
        Chymase  [label="Chymase\nangiotensin\nconversion" fillcolor="#90CAF9"]
        Heparin  [label="Heparin\nanticoagulant\nfibrinolysis" fillcolor="#BBDEFB"]
        Cath_G   [label="Cathepsin G\nprotease\ninflammation" fillcolor="#90CAF9"]
        // Newly synthesized
        PGD2     [label="PGD2\nProstaglandin D2\nflushing, hypotension" fillcolor="#42A5F5"]
        LTC4     [label="LTC4/LTD4\nLeukotrienes\nbronchoconstriction" fillcolor="#1E88E5" fontcolor=white]
        PAF      [label="PAF\nPlatelet-activating\nfactor" fillcolor="#1565C0" fontcolor=white]
        TXA2     [label="TXA2\nThromboxane A2\nplatelet aggregation" fillcolor="#64B5F6"]
        // Cytokines
        TNFa_MC  [label="TNF-α (MC)\nshock, tissue\ndamage" fillcolor="#1E88E5" fontcolor=white]
        IL4_MC   [label="IL-4 (MC)\nTh2 polarization\nIgE class switch" fillcolor="#42A5F5"]
        IL5_MC   [label="IL-5 (MC)\neosinophil\nrecruitment" fillcolor="#64B5F6"]
        IL6_MC   [label="IL-6 (MC)\nacute phase\nosteoporosis" fillcolor="#1565C0" fontcolor=white]
        IL13_MC  [label="IL-13 (MC)\nfibrosis, IgE\nswitch" fillcolor="#42A5F5"]
        IL33_MC  [label="IL-33\nST2 receptor\nMC activation" fillcolor="#BBDEFB"]
        VEGF_MC  [label="VEGF (MC)\nangiogenesis\norgan infiltration" fillcolor="#90CAF9"]
        TGFb_MC  [label="TGF-β (MC)\nfibrosis, bone\nremodeling" fillcolor="#64B5F6"]
        SCF_auto [label="SCF (autocrine)\nMC survival\namplification" fillcolor="#BBDEFB"]
    }

    // ──────────────────────────────────────────────────────────────
    // CLUSTER 5 – Bone Marrow Compartment
    // ──────────────────────────────────────────────────────────────
    subgraph cluster_bone_marrow {
        label="5. Bone Marrow Compartment" style=filled
        fillcolor="#F3E5F5" color="#4A148C" fontsize=13 fontname="Helvetica-Bold"

        BM_inf   [label="BM MC Infiltration\n≥25% MC aggregates\nSM criterion" fillcolor="#CE93D8"]
        BM_fib   [label="BM Fibrosis\nreticulin grade\nadvanced SM" fillcolor="#BA68C8"]
        Cyto     [label="Cytopenias\nanemia, neutropenia\nthrombocytopenia" fillcolor="#AB47BC"]
        Blast    [label="Blast cells\n>5% → MC leukemia\n>20% → AML/MCA" fillcolor="#8E24AA" fontcolor=white]
        Eos_BM   [label="Eosinophilia\nMC-derived IL-5\nassociated" fillcolor="#CE93D8"]
        BM_niche [label="BM Stromal Niche\nSCF, fibronectin\nIL-3, IL-6 support" fillcolor="#E1BEE7"]
        CD25_pos [label="CD25 (IL-2Rα)\nexpression on MC\nSM criterion" fillcolor="#CE93D8"]
        CD2_pos  [label="CD2 expression\nSM criterion\naberrant" fillcolor="#BA68C8"]
        KIT_hist [label="KIT D816V\nhistology/PCR\nSM criterion" fillcolor="#7B1FA2" fontcolor=white]
    }

    // ──────────────────────────────────────────────────────────────
    // CLUSTER 6 – Organ Involvement
    // ──────────────────────────────────────────────────────────────
    subgraph cluster_organs {
        label="6. Organ Involvement (C-Findings)" style=filled
        fillcolor="#FFF9C4" color="#F57F17" fontsize=13 fontname="Helvetica-Bold"

        Skin     [label="Skin (UP/MPCM)\nUrticaria Pigmentosa\nDarier sign" fillcolor="#FFF176"]
        Liver    [label="Liver Infiltration\nhepatomegaly\nALP elevation" fillcolor="#FFEE58"]
        Spleen   [label="Splenomegaly\nhypersplenism\nportal HTN" fillcolor="#FDD835"]
        GI_tract [label="GI Involvement\nmalabsorption, diarrhea\nnausea/vomiting" fillcolor="#FBC02D" fontcolor=white]
        Bone_dis [label="Bone Disease\nosteolysis/sclerosis\npathologic fractures" fillcolor="#F9A825" fontcolor=white]
        CNS_MC   [label="CNS Manifestations\ncognitive, headache\nanxiety/depression" fillcolor="#FFCA28"]
        Lymph    [label="Lymphadenopathy\nLN infiltration\nadvanced SM" fillcolor="#FFF176"]
        Portal   [label="Portal Hypertension\nascites, varices\nadvanced SM" fillcolor="#FF8F00" fontcolor=white]
        C_find   [label="C-Findings\n(organ damage)\nadvanced SM criteria" fillcolor="#E65100" fontcolor=white]
    }

    // ──────────────────────────────────────────────────────────────
    // CLUSTER 7 – Disease Classification & Clinical Endpoints
    // ──────────────────────────────────────────────────────────────
    subgraph cluster_classification {
        label="7. WHO Classification & Clinical Endpoints" style=filled
        fillcolor="#ECEFF1" color="#263238" fontsize=13 fontname="Helvetica-Bold"

        CM       [label="Cutaneous\nMastocytosis (CM)\nchildren, skin only" fillcolor="#B0BEC5"]
        ISM      [label="Indolent SM (ISM)\n≥1 SM criterion, no C\nnormal life expectancy" fillcolor="#78909C"]
        SSM      [label="Smoldering SM (SSM)\nB-findings, no C\nBM MC ≥30%" fillcolor="#607D8B" fontcolor=white]
        ASM      [label="Aggressive SM (ASM)\nC-findings present\norgan damage" fillcolor="#455A64" fontcolor=white]
        SM_AHNMD [label="SM-AHN\n(SM+Heme Neoplasm)\nworst prognosis" fillcolor="#263238" fontcolor=white]
        MCL      [label="MC Leukemia (MCL)\n>20% MC in BM\ncirculating MC" fillcolor="#000000" fontcolor=white]
        Trypt_ep [label="Serum Tryptase\n>20 ng/mL criterion\nmonitor response" fillcolor="#90A4AE"]
        Sym_score[label="Symptom Score\nMISS/MSAF-10\nflushing, pruritus" fillcolor="#B0BEC5"]
        ORR      [label="Overall Response\nRate (ORR)\nCR + PR + CI" fillcolor="#78909C"]
        PFS_OS   [label="PFS / OS\nAdvanced SM endpoint\nclinical trials" fillcolor="#607D8B" fontcolor=white]
        QoL      [label="Quality of Life\npatient-reported\nSF-36, DLQI" fillcolor="#90A4AE"]
    }

    // ──────────────────────────────────────────────────────────────
    // CLUSTER 8 – Drug PK/PD – Midostaurin
    // ──────────────────────────────────────────────────────────────
    subgraph cluster_midostaurin {
        label="8. Drug PK/PD – Midostaurin (PKC412, Rydapt®)" style=filled
        fillcolor="#E8EAF6" color="#1A237E" fontsize=13 fontname="Helvetica-Bold"

        MIDO_gut  [label="Midostaurin\nGut (oral)\n100 mg BID" fillcolor="#C5CAE9"]
        MIDO_cent [label="Midostaurin\nCentral (plasma)\nCmax ~1500 ng/mL" fillcolor="#9FA8DA"]
        MIDO_peri [label="Midostaurin\nPeripheral\nVd ~95 L/kg" fillcolor="#7986CB"]
        CGP52421  [label="CGP52421\nActive metabolite\nt½ ~500 h" fillcolor="#5C6BC0" fontcolor=white]
        CGP62221  [label="CGP62221\nActive metabolite\nt½ ~100 h" fillcolor="#3949AB" fontcolor=white]
        MIDO_met  [label="CYP3A4\nMidostaurin\nmetabolism" fillcolor="#C5CAE9"]
        MIDO_KIT  [label="KIT D816V\nIC50 ~230 nM\ninhibition" fillcolor="#1A237E" fontcolor=white]
        MIDO_PKC  [label="PKC inhibition\nbroad kinase\nprofile" fillcolor="#3F51B5" fontcolor=white]
        MIDO_FLT3 [label="FLT3 inhibition\nAML co-treatment\noff-target" fillcolor="#5C6BC0" fontcolor=white]
        MIDO_PDGFR[label="PDGFR inhibition\nfibrosis pathway\noff-target" fillcolor="#7986CB"]
        MIDO_eff  [label="Midostaurin\nEfficacy\n45% ORR (CPKC412D2201)" fillcolor="#1A237E" fontcolor=white]
    }

    // ──────────────────────────────────────────────────────────────
    // CLUSTER 9 – Drug PK/PD – Avapritinib
    // ──────────────────────────────────────────────────────────────
    subgraph cluster_avapritinib {
        label="9. Drug PK/PD – Avapritinib (BLU-285, Ayvakit®)" style=filled
        fillcolor="#E0F2F1" color="#004D40" fontsize=13 fontname="Helvetica-Bold"

        AVA_gut   [label="Avapritinib\nGut (oral)\n25–300 mg QD" fillcolor="#B2DFDB"]
        AVA_cent  [label="Avapritinib\nCentral (plasma)\nCmax ~280 ng/mL" fillcolor="#80CBC4"]
        AVA_peri  [label="Avapritinib\nPeripheral tissue\nVd ~1560 L" fillcolor="#4DB6AC"]
        AVA_CYP   [label="CYP3A4\nAvapritinib\nmetabolism" fillcolor="#B2DFDB"]
        AVA_brain [label="CNS penetration\nICH risk\nplatelet reduction" fillcolor="#00897B" fontcolor=white]
        AVA_KIT   [label="KIT D816V\nIC50 ~0.27 nM\n(>>selective)" fillcolor="#004D40" fontcolor=white]
        AVA_PDGFRA[label="PDGFRA D842V\ncross-selectivity\nGIST indication" fillcolor="#00796B" fontcolor=white]
        AVA_trypt [label="Serum Tryptase\nreduction\n>50% at 6mo" fillcolor="#26A69A"]
        AVA_BM    [label="BM MC burden\nreduction\n>50% at 6mo" fillcolor="#00897B" fontcolor=white]
        AVA_eff   [label="Avapritinib\nEfficacy ISM\n35% ORR (PIONEER)" fillcolor="#004D40" fontcolor=white]
        AVA_eff2  [label="Avapritinib\nAdvanced SM\n75% ORR (PATHFINDER)" fillcolor="#00695C" fontcolor=white]
    }

    // ──────────────────────────────────────────────────────────────
    // CLUSTER 10 – Other Treatments
    // ──────────────────────────────────────────────────────────────
    subgraph cluster_other_tx {
        label="10. Other Treatments & Supportive Therapy" style=filled
        fillcolor="#FBE9E7" color="#BF360C" fontsize=13 fontname="Helvetica-Bold"

        Imatinib  [label="Imatinib\nKIT WT only\n400 mg QD" fillcolor="#FFAB91"]
        Cladrib   [label="Cladribine\n(2-CdA) cytotoxic\nreduces MC burden" fillcolor="#FF7043"]
        IFNa      [label="IFN-α / PEG-IFNa\nantiproliferative\nISM/SSM" fillcolor="#FF5722" fontcolor=white]
        Omalizumab[label="Omalizumab\nanti-IgE\nanaphylaxis prev." fillcolor="#FFAB91"]
        H1_block  [label="H1-Antihistamines\npruritus, flushing\nloratadine, cetirizine" fillcolor="#FF8A65"]
        H2_block  [label="H2-Antihistamines\nGI acid reduction\nfamotidine, ranitidine" fillcolor="#FFAB91"]
        Cromolyn  [label="Cromolyn sodium\nGI symptoms\nMC stabilizer" fillcolor="#FF7043"]
        Aspirin   [label="Aspirin low-dose\nPGD2 reduction\nflushing prevention" fillcolor="#FF8A65"]
        EpiPen    [label="Epinephrine\nAnaphylaxis Rx\nself-inject" fillcolor="#BF360C" fontcolor=white]
        Steroids  [label="Corticosteroids\nascites, malabsorption\nshort-course" fillcolor="#FF5722" fontcolor=white]
        BMT       [label="Allo-SCT\nadvanced SM / MCL\ncurative intent" fillcolor="#BF360C" fontcolor=white]
        Venetoclax[label="Venetoclax\nBCL-2 inhibitor\nnew combinations" fillcolor="#E64A19" fontcolor=white]
        Brentuximab[label="Brentuximab-\nvedotin\nCD30+ MCL" fillcolor="#FFAB91"]
    }

    // ──────────────────────────────────────────────────────────────
    // CLUSTER 11 – Anaphylaxis & Acute Mediator Release
    // ──────────────────────────────────────────────────────────────
    subgraph cluster_anaphylaxis {
        label="11. Anaphylaxis & Acute Mediator Release Syndrome" style=filled
        fillcolor="#FFF8E1" color="#FF6F00" fontsize=13 fontname="Helvetica-Bold"

        AMRS     [label="Acute Mediator\nRelease Syndrome\n(AMRS)" fillcolor="#FFD54F"]
        Anaphyl  [label="Anaphylaxis\n>50% ISM patients\nhymenoptera trigger" fillcolor="#FFCA28"]
        Flush    [label="Flushing\nPGD2, histamine\nmost common sx" fillcolor="#FFB300"]
        Hypo_BP  [label="Hypotension\nhistamine H1/H2\nvasodilation" fillcolor="#FF8F00" fontcolor=white]
        Broncho  [label="Bronchoconstriction\nLTC4/LTD4\nhypoxia" fillcolor="#E65100" fontcolor=white]
        GI_acute [label="GI Cramping\nnausea/vomiting\ndiarrhea" fillcolor="#FFD54F"]
        Venom    [label="Venom Allergy\nHymenoptera\nmajor trigger" fillcolor="#FFB300"]
        Drug_trig[label="Drug Triggers\nNSAIDs, opioids\niodinated dye" fillcolor="#FFCA28"]
        VIT      [label="Venom\nImmunotherapy\nSM toleration" fillcolor="#FFD54F"]
    }

    // ──────────────────────────────────────────────────────────────
    // CLUSTER 12 – Bone Disease Pathway
    // ──────────────────────────────────────────────────────────────
    subgraph cluster_bone {
        label="12. Bone Disease in SM" style=filled
        fillcolor="#FFFDE7" color="#827717" fontsize=13 fontname="Helvetica-Bold"

        OC       [label="Osteoclast\nactivation\nRANKL/RANK" fillcolor="#FFF9C4"]
        OB       [label="Osteoblast\nsuppression\nWnt inhibition" fillcolor="#FFF176"]
        RANKL    [label="RANKL\nMC-derived\nosteoclast activation" fillcolor="#FFEE58"]
        OPG      [label="OPG\nRANKL decoy\nreduced in SM" fillcolor="#FDD835"]
        BMD      [label="BMD Reduction\nosteoporosis\nvertebral fractures" fillcolor="#F9A825" fontcolor=white]
        Osteo    [label="Osteolytic lesions\nbone pain\nadvanced SM" fillcolor="#F57F17" fontcolor=white]
        Sclero   [label="Osteosclerosis\ndiffuse pattern\nISM/SSM" fillcolor="#E65100" fontcolor=white]
        Bisphos  [label="Bisphosphonates\nzoledronate\nfracture prevention" fillcolor="#FFF9C4"]
        Denosumab[label="Denosumab\nRANKL inhibitor\nSM bone disease" fillcolor="#FFF176"]
    }

    // ──────────────────────────────────────────────────────────────
    // EDGES – Genetic Background → Signaling
    // ──────────────────────────────────────────────────────────────
    KIT_WT -> KIT_AUTO [label="SCF-dependent" color="#E65100"]
    KIT_D816V -> KIT_AUTO [label="constitutive\n(no SCF needed)" color="#BF360C" penwidth=2]
    SCF -> KIT_WT [label="ligand binding" color="#FF6F00"]
    TET2 -> KIT_D816V [label="co-mutation\naggravates" color="#795548" style=dashed]
    SRSF2 -> KIT_D816V [label="co-mutation" color="#795548" style=dashed]
    ASXL1 -> KIT_D816V [label="co-mutation" color="#795548" style=dashed]
    JAK2 -> JAK1_2 [label="JAK-STAT\noverlap" color="#9C27B0" style=dashed]
    RUNX1 -> MC_tis [label="MC transcription" color="#2196F3"]

    // ──────────────────────────────────────────────────────────────
    // EDGES – Signaling Cascades
    // ──────────────────────────────────────────────────────────────
    KIT_AUTO -> PI3K [label="direct binding\np85 SH2" color="#C2185B" penwidth=2]
    KIT_AUTO -> RAS [label="GRB2/SOS\ncomplex" color="#C2185B" penwidth=2]
    KIT_AUTO -> JAK1_2 [label="JAK\nactivation" color="#C2185B"]
    KIT_AUTO -> SRC [label="SRC family\nkinases" color="#C2185B"]
    PI3K -> PIP3 [label="PIP2→PIP3" color="#880E4F"]
    PTEN -> PIP3 [label="dephosphorylates\n(inhibits)" color="#880E4F" style=dashed arrowhead=tee]
    PIP3 -> AKT [label="PH domain\nrecruitment" color="#880E4F"]
    mTORC2 -> AKT [label="Ser473\nphospho" color="#880E4F"]
    AKT -> mTORC1 [label="S6K1\n4E-BP1" color="#880E4F" penwidth=2]
    AKT -> NF_kB [label="IKK\nactivation" color="#880E4F"]
    AKT -> BCL2 [label="anti-apoptosis\nupregulation" color="#880E4F"]
    AKT -> MCL1 [label="stabilization" color="#880E4F"]
    RAS -> RAF [label="KRAS-RAF\nbinding" color="#E91E63"]
    RAF -> MEK [label="MEK1/2\nphospho" color="#E91E63"]
    MEK -> ERK [label="ERK1/2\nphospho" color="#E91E63"]
    ERK -> NF_kB [label="p65 Ser276\nphospho" color="#E91E63"]
    JAK1_2 -> STAT3 [label="Tyr705\nphospho" color="#880E4F"]
    JAK1_2 -> STAT5 [label="Tyr694\nphospho" color="#880E4F"]
    STAT3 -> BCL2 [label="transcription\ninduction" color="#880E4F"]
    STAT3 -> VEGF_MC [label="VEGF\ntranscription" color="#880E4F"]
    STAT5 -> MCL1 [label="transcription\ninduction" color="#880E4F"]
    LYN -> PI3K [label="FcεRI\ncoupling" color="#E91E63"]
    BTK -> PI3K [label="BTK-PI3K" color="#E91E63"]
    NF_kB -> TNFa_MC [label="cytokine\ntranscription" color="#880E4F"]
    NF_kB -> IL6_MC [label="cytokine\ntranscription" color="#880E4F"]
    SRC -> LYN [label="LYN\nactivation" color="#E91E63"]

    // ──────────────────────────────────────────────────────────────
    // EDGES – Mast Cell Differentiation
    // ──────────────────────────────────────────────────────────────
    HSC -> CMP [label="myeloid\ncommitment" color="#2E7D32"]
    CMP -> MCP [label="MC\nlineage" color="#2E7D32"]
    MCP -> PMC [label="egress\nto blood" color="#2E7D32"]
    PMC -> IMC [label="tissue\nhoming" color="#2E7D32"]
    IMC -> MC_tis [label="tissue\nmaturation" color="#1B5E20" penwidth=2]
    KIT_D816V -> MC_tis [label="clonal\nexpansion\n×10-100" color="#BF360C" penwidth=3]
    BCL2 -> MC_apo [label="inhibits\napoptosis" color="#C2185B" arrowhead=tee]
    MCL1 -> MC_apo [label="inhibits\napoptosis" color="#C2185B" arrowhead=tee]
    MC_tis -> MC_act [label="IgE+Ag or\ndirect KIT" color="#2E7D32"]
    FcεRI -> MC_act [label="IgE cross-\nlinking" color="#2E7D32"]
    IgE -> FcεRI [label="high-affinity\nbinding" color="#2E7D32"]
    Ag -> FcεRI [label="allergen\ncross-link" color="#2E7D32" style=dashed]
    MC_tis -> MC_ENTR [label="BM niche\nretention" color="#2E7D32"]
    KIT_D816V -> TPSAB1 [label="tryptase\noverexpression" color="#BF360C"]
    KIT_D816V -> KIT_exp [label="CD117\noverexpression" color="#BF360C"]

    // ──────────────────────────────────────────────────────────────
    // EDGES – Mediator Release
    // ──────────────────────────────────────────────────────────────
    MC_act -> Hist [label="degranulation\n<30 sec" color="#0D47A1" penwidth=2]
    MC_act -> Trypt [label="degranulation" color="#0D47A1" penwidth=2]
    MC_act -> Chymase [label="degranulation" color="#0D47A1"]
    MC_act -> Heparin [label="degranulation" color="#0D47A1"]
    MC_act -> Cath_G [label="degranulation" color="#0D47A1"]
    MC_act -> PGD2 [label="COX-1\nsynthesis (min)" color="#1565C0"]
    MC_act -> LTC4 [label="5-LOX pathway\n(min)" color="#1565C0"]
    MC_act -> PAF [label="immediate\nsynthesis" color="#1565C0"]
    MC_act -> TXA2 [label="COX pathway" color="#1565C0"]
    MC_act -> TNFa_MC [label="pre-stored +\nde novo" color="#0D47A1"]
    MC_act -> IL4_MC [label="cytokine\nrelease (h)" color="#0D47A1"]
    MC_act -> IL5_MC [label="cytokine\nrelease" color="#0D47A1"]
    MC_act -> IL6_MC [label="cytokine\nrelease" color="#0D47A1"]
    MC_act -> IL13_MC [label="cytokine\nrelease" color="#0D47A1"]
    MC_act -> VEGF_MC [label="angiogenesis\nfactor" color="#0D47A1"]
    MC_act -> TGFb_MC [label="fibrosis\nfactor" color="#0D47A1"]
    IL33_MC -> FcεRI [label="ST2 receptor\nMC priming" color="#1565C0"]
    SCF_auto -> KIT_WT [label="autocrine\nloop" color="#1565C0" style=dashed]
    MC_tis -> SCF_auto [label="MC produces\nSCF" color="#2E7D32"]

    // ──────────────────────────────────────────────────────────────
    // EDGES – Bone Marrow
    // ──────────────────────────────────────────────────────────────
    MC_ENTR -> BM_inf [label="dense\naggregates" color="#4A148C" penwidth=2]
    TGFb_MC -> BM_fib [label="fibroblast\nactivation" color="#4A148C"]
    BM_fib -> Cyto [label="BM failure" color="#4A148C"]
    BM_inf -> Blast [label="advanced SM\nprogression" color="#4A148C"]
    IL5_MC -> Eos_BM [label="eosinophilia" color="#4A148C"]
    BM_niche -> MC_ENTR [label="IL-6, SCF\nsupport" color="#4A148C"]
    KIT_D816V -> CD25_pos [label="aberrant\nexpression" color="#BF360C"]
    KIT_D816V -> CD2_pos [label="aberrant\nexpression" color="#BF360C"]
    KIT_D816V -> KIT_hist [label="detected by\nPCR/sequencing" color="#BF360C"]

    // ──────────────────────────────────────────────────────────────
    // EDGES – Organ Involvement
    // ──────────────────────────────────────────────────────────────
    MC_tis -> Skin [label="urticaria\npigmentosa" color="#F57F17" penwidth=2]
    MC_tis -> Liver [label="perivascular\ninfiltration" color="#F57F17"]
    MC_tis -> Spleen [label="red pulp\ninfiltration" color="#F57F17"]
    MC_tis -> GI_tract [label="mucosal\ninfiltration" color="#F57F17"]
    MC_tis -> Bone_dis [label="peritrabecular\nnidus" color="#F57F17"]
    MC_tis -> CNS_MC [label="neuroinflammation" color="#F57F17"]
    MC_tis -> Lymph [label="nodal\ninfiltration" color="#F57F17"]
    VEGF_MC -> Liver [label="angiogenesis\n+ fibrosis" color="#0D47A1"]
    TGFb_MC -> Liver [label="hepatic\nfibrosis" color="#0D47A1"]
    Spleen -> Portal [label="portal flow\nincrease" color="#F57F17"]
    Liver -> Portal [label="hepatic\nHTN" color="#F57F17"]
    Liver -> C_find [label="liver C-finding\nALP ×2.5, bilirubin" color="#F57F17"]
    Spleen -> C_find [label="spleen C-finding\n>45% BM replaced" color="#F57F17"]
    Bone_dis -> C_find [label="bone C-finding\nosteolysis" color="#F57F17"]
    Cyto -> C_find [label="cytopenia\nC-finding" color="#4A148C"]

    // ──────────────────────────────────────────────────────────────
    // EDGES – Classification
    // ──────────────────────────────────────────────────────────────
    BM_inf -> ISM [label="1 major+1 minor\nor 3 minor criteria" color="#37474F"]
    BM_inf -> SSM [label="B-findings\nBM MC ≥30%" color="#37474F"]
    C_find -> ASM [label="organ damage" color="#37474F" penwidth=2]
    C_find -> SM_AHNMD [label="+ heme\nneoplasm" color="#37474F"]
    Blast -> MCL [label=">20% BM MC" color="#37474F"]
    Blast -> SM_AHNMD [label=">20% blasts\n→ AML-MCA" color="#37474F"]
    Trypt -> Trypt_ep [label="serum level\n>20 ng/mL" color="#263238"]
    MC_act -> Sym_score [label="mediator\nsymptoms" color="#263238"]
    ISM -> QoL [label="chronic\nburden" color="#263238"]
    ASM -> ORR [label="treatment\nresponse" color="#263238"]
    ASM -> PFS_OS [label="survival\nendpoint" color="#263238"]
    MCL -> PFS_OS [label="poor\nprognosis" color="#263238"]

    // ──────────────────────────────────────────────────────────────
    // EDGES – Anaphylaxis
    // ──────────────────────────────────────────────────────────────
    Hist -> AMRS [label="H1/H2\nreceptors" color="#FF6F00" penwidth=2]
    PGD2 -> AMRS [label="DP1/DP2\nreceptors" color="#FF6F00"]
    LTC4 -> AMRS [label="CysLT\nreceptors" color="#FF6F00"]
    PAF -> AMRS [label="PAF\nreceptor" color="#FF6F00"]
    AMRS -> Anaphyl [label="systemic" color="#BF360C" penwidth=2]
    Anaphyl -> Flush [label="flush\ncomponent" color="#BF360C"]
    Anaphyl -> Hypo_BP [label="hypotension" color="#BF360C"]
    Anaphyl -> Broncho [label="bronchoconstriction" color="#BF360C"]
    Anaphyl -> GI_acute [label="GI cramps" color="#BF360C"]
    Venom -> Anaphyl [label="most common\ntrigger in SM" color="#FF6F00"]
    Drug_trig -> AMRS [label="NSAID/opioid\ntrigger" color="#FF6F00" style=dashed]
    VIT -> Venom [label="desensitization\n↓ IgE" color="#4CAF50" arrowhead=tee]
    EpiPen -> Hypo_BP [label="reversal\nepinephrine" color="#4CAF50" arrowhead=tee]

    // ──────────────────────────────────────────────────────────────
    // EDGES – Bone Disease
    // ──────────────────────────────────────────────────────────────
    IL6_MC -> OC [label="RANKL-independent\nosteoclast activ." color="#827717"]
    TGFb_MC -> OC [label="osteoclast\nstimulation" color="#827717"]
    PGD2 -> OC [label="DP1 receptor\nbone resorption" color="#827717"]
    MC_act -> RANKL [label="MC expresses\nRANKL" color="#827717"]
    RANKL -> OC [label="RANK binding\nosteoclast activ." color="#827717" penwidth=2]
    OPG -> RANKL [label="decoy\nreceptor" color="#827717" arrowhead=tee style=dashed]
    OC -> BMD [label="bone\nresorption" color="#827717"]
    IL6_MC -> OB [label="Wnt\ninhibition" color="#827717" arrowhead=tee]
    OB -> BMD [label="bone\nformation" color="#827717"]
    BMD -> Osteo [label="severe loss\n>-2.5 SD" color="#827717"]
    BMD -> Sclero [label="ISM sclerotic\npattern" color="#827717" style=dashed]
    Bisphos -> OC [label="inhibits\nosteoclasts" color="#4CAF50" arrowhead=tee]
    Denosumab -> RANKL [label="RANKL\ninhibition" color="#4CAF50" arrowhead=tee]

    // ──────────────────────────────────────────────────────────────
    // EDGES – Midostaurin PK/PD
    // ──────────────────────────────────────────────────────────────
    MIDO_gut -> MIDO_cent [label="ka=0.5 h-1\nF=85%" color="#1A237E" penwidth=2]
    MIDO_cent -> MIDO_peri [label="kcp\nVd~95 L/kg" color="#1A237E"]
    MIDO_peri -> MIDO_cent [label="kpc" color="#1A237E"]
    MIDO_cent -> MIDO_met [label="CYP3A4\nVmax/Km" color="#1A237E"]
    MIDO_met -> CGP52421 [label="major\nmetabolite" color="#1A237E"]
    MIDO_met -> CGP62221 [label="minor\nmetabolite" color="#1A237E"]
    MIDO_cent -> MIDO_KIT [label="KIT D816V\ncompetitive inhib." color="#3F51B5" penwidth=2]
    MIDO_cent -> MIDO_PKC [label="PKC family\ninhibition" color="#3F51B5"]
    MIDO_cent -> MIDO_FLT3 [label="FLT3 off-target" color="#3F51B5" style=dashed]
    MIDO_cent -> MIDO_PDGFR [label="PDGFR off-target" color="#3F51B5" style=dashed]
    MIDO_KIT -> KIT_AUTO [label="competitive\nKIT inhibition" color="#1A237E" penwidth=2 arrowhead=tee]
    MIDO_KIT -> Trypt_ep [label="tryptase\nreduction" color="#1A237E"]
    MIDO_KIT -> MIDO_eff [label="ORR 45%\nAdvanced SM" color="#1A237E"]

    // ──────────────────────────────────────────────────────────────
    // EDGES – Avapritinib PK/PD
    // ──────────────────────────────────────────────────────────────
    AVA_gut -> AVA_cent [label="ka=0.4 h-1\nF=73%" color="#004D40" penwidth=2]
    AVA_cent -> AVA_peri [label="kcp\nVd~1560 L" color="#004D40"]
    AVA_peri -> AVA_cent [label="kpc" color="#004D40"]
    AVA_cent -> AVA_CYP [label="CYP3A4/2C9\nelimination" color="#004D40"]
    AVA_cent -> AVA_brain [label="BBB\npenetration" color="#004D40" style=dashed]
    AVA_cent -> AVA_KIT [label="KIT D816V\nIC50=0.27 nM" color="#00695C" penwidth=3]
    AVA_cent -> AVA_PDGFRA [label="PDGFRA\ncross-target" color="#00695C" style=dashed]
    AVA_KIT -> KIT_AUTO [label="highly selective\nKIT D816V inhib." color="#004D40" penwidth=3 arrowhead=tee]
    AVA_KIT -> AVA_trypt [label="tryptase\n>50% reduction" color="#004D40" penwidth=2]
    AVA_KIT -> AVA_BM [label="BM MC\nreduction" color="#004D40" penwidth=2]
    AVA_KIT -> AVA_eff [label="ISM: 35% ORR\n(PIONEER)" color="#004D40"]
    AVA_KIT -> AVA_eff2 [label="Advanced SM\n75% ORR" color="#004D40"]

    // ──────────────────────────────────────────────────────────────
    // EDGES – Other Treatments
    // ──────────────────────────────────────────────────────────────
    Imatinib -> KIT_WT [label="WT KIT only\nD816V resistant" color="#BF360C" arrowhead=tee]
    Cladrib -> MC_tis [label="cytotoxic\napoptosis" color="#BF360C" arrowhead=tee]
    IFNa -> KIT_D816V [label="anti-proliferative\ncell cycle arrest" color="#BF360C" arrowhead=tee style=dashed]
    Omalizumab -> IgE [label="anti-IgE\nFc binding" color="#4CAF50" arrowhead=tee]
    H1_block -> Hist [label="H1 antagonist" color="#4CAF50" arrowhead=tee]
    H2_block -> Hist [label="H2 antagonist\ngastric" color="#4CAF50" arrowhead=tee]
    Cromolyn -> MC_act [label="MC stabilizer\nprevents degran." color="#4CAF50" arrowhead=tee]
    Aspirin -> PGD2 [label="COX-1\ninhibition" color="#4CAF50" arrowhead=tee]
    Steroids -> IL4_MC [label="cytokine\nsuppression" color="#4CAF50" arrowhead=tee]
    Venetoclax -> BCL2 [label="BCL-2\ninhibition" color="#4CAF50" arrowhead=tee]
    BMT -> HSC [label="donor HSC\nreplacement" color="#4CAF50"]
}
