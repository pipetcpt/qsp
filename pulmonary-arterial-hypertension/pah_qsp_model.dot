digraph PAH_QSP_Model {
    // Global graph attributes
    graph [
        rankdir=LR,
        fontname="Helvetica",
        fontsize=11,
        bgcolor="#FAFAFA",
        splines=curved,
        overlap=false,
        nodesep=0.35,
        ranksep=0.7,
        label="Quantitative Systems Pharmacology Model\nPulmonary Arterial Hypertension (PAH)\n© 2026 — Mechanistic Map (>100 nodes)",
        labelloc=t,
        labeljust=c,
        fontsize=14
    ]
    node [fontname="Helvetica", fontsize=9, style="filled,rounded", shape=box, margin="0.12,0.06"]
    edge [fontname="Helvetica", fontsize=8, arrowsize=0.7]

    // =====================================================================
    // CLUSTER 1: DRUG PK COMPARTMENTS
    // =====================================================================
    subgraph cluster_drugs {
        label="Drug PK / Administration"
        style="filled,rounded"
        color="#C8A2C8"
        fillcolor="#F5EEFF"
        fontsize=12
        fontcolor="#4B006E"

        node [fillcolor="#DDA0DD", color="#9B4F96"]

        ERA_gut [label="ERA\nGut (oral)"]
        ERA_central [label="ERA\nPlasma"]
        ERA_peripheral [label="ERA\nPeripheral"]
        ERA_effect [label="ERA\nEffect Site\n(lung tissue)"]

        PDE5i_gut [label="PDE5i\nGut (oral)"]
        PDE5i_central [label="PDE5i\nPlasma"]
        PDE5i_effect [label="PDE5i\nEffect Site"]

        sGC_gut [label="sGC Stimulator\nGut (oral)"]
        sGC_central [label="sGC Stimulator\nPlasma"]
        sGC_effect [label="sGC Stimulator\nEffect Site"]

        PGI2_iv [label="Prostacyclin\nIV/SC Depot"]
        PGI2_central [label="Prostacyclin\nPlasma"]
        PGI2_effect [label="Prostacyclin\nEffect Site"]

        CYP3A4 [label="CYP3A4\n(hepatic metabolism)"]
        CYP2C9 [label="CYP2C9\n(hepatic metabolism)"]
    }

    // =====================================================================
    // CLUSTER 2: ENDOTHELIN PATHWAY (Vasoconstriction)
    // =====================================================================
    subgraph cluster_endothelin {
        label="Endothelin-1 Pathway (Vasoconstriction)"
        style="filled,rounded"
        color="#CC3300"
        fillcolor="#FFF0EE"
        fontsize=12
        fontcolor="#8B0000"

        node [fillcolor="#FFAAAA", color="#CC3300"]

        Hypoxia [label="Hypoxia\n(↓O₂ tension)"]
        Shear_stress [label="Shear Stress\n(mechanical)"]
        ET1_gene [label="ET-1 Gene\n(EDN1)"]
        Pre_proET1 [label="Pre-proET-1\n(precursor)"]
        BigET1 [label="Big ET-1\n(inactive)"]
        ECE1 [label="ECE-1\n(endothelin-converting enzyme)"]
        ET1 [label="ET-1\n(active ligand)", shape=ellipse, fillcolor="#FF5555"]
        ETA_r [label="ETA Receptor\n(on PASMC/fibroblast)"]
        ETB_r_EC [label="ETB Receptor\n(on EC → vasodilate)"]
        ETB_r_SMC [label="ETB Receptor\n(on PASMC → constrict)"]
        Gq_protein [label="Gq Protein\nActivation"]
        PLC [label="PLC\n(phospholipase C)"]
        IP3 [label="IP3\n(inositol trisphosphate)"]
        DAG [label="DAG\n(diacylglycerol)"]
        PKC [label="PKC\n(protein kinase C)"]
        Ca2_release [label="Ca²⁺ Release\n(ER store)"]
        Ca2_influx [label="Ca²⁺ Influx\n(TRPC channels)"]
        Ca2_i [label="[Ca²⁺]ᵢ\n(intracellular)"]
        MLCK [label="MLCK\n(myosin light chain kinase)"]
        MLC_p [label="p-MLC\n(phosphorylated)"]
        ROCK1 [label="ROCK1/2\n(Rho kinase)"]
        RhoA [label="RhoA\n(GTPase)"]
        MLCP_inh [label="MLCP Inhibition\n(CPI-17, MYPT1)"]
        Vasoconstriction [label="VASOCONSTRICTION\n↑ PVR", shape=diamond, fillcolor="#CC0000", fontcolor=white]
    }

    // =====================================================================
    // CLUSTER 3: NITRIC OXIDE / cGMP PATHWAY (Vasodilation)
    // =====================================================================
    subgraph cluster_NO_cGMP {
        label="NO-cGMP-PKG Pathway (Vasodilation)"
        style="filled,rounded"
        color="#006633"
        fillcolor="#EEFFEE"
        fontsize=12
        fontcolor="#003300"

        node [fillcolor="#AAFFCC", color="#006633"]

        eNOS [label="eNOS\n(endothelial NOS)"]
        L_Arginine [label="L-Arginine\n(substrate)"]
        Tetrahydrobiopterin [label="BH4\n(eNOS cofactor)"]
        NO [label="NO\n(nitric oxide)", shape=ellipse, fillcolor="#55CC77"]
        sGC_enzyme [label="sGC\n(soluble guanylate cyclase)"]
        GTP [label="GTP → cGMP"]
        cGMP [label="cGMP", shape=ellipse, fillcolor="#55CC77"]
        PDE5 [label="PDE5\n(phosphodiesterase 5)"]
        PKG [label="PKG\n(cGMP-dependent PK)"]
        MLCP_act [label="MLCP Activation\n(dephosphorylation)"]
        Kv_open [label="Kv Channel Opening\n(K+ efflux)"]
        Membrane_hyperpol [label="Membrane\nHyperpolarization"]
        Vasodilation_NO [label="VASODILATION\n↓ PVR", shape=diamond, fillcolor="#006633", fontcolor=white]
        iNOS [label="iNOS\n(inflammatory)"]
        ONOO [label="Peroxynitrite\n(ONOO⁻)"]
        NOS_uncoupling [label="eNOS\nUncoupling"]
    }

    // =====================================================================
    // CLUSTER 4: PROSTACYCLIN PATHWAY
    // =====================================================================
    subgraph cluster_prostacyclin {
        label="Prostacyclin (PGI2) Pathway"
        style="filled,rounded"
        color="#0044CC"
        fillcolor="#EEF4FF"
        fontsize=12
        fontcolor="#002288"

        node [fillcolor="#AAC8FF", color="#0044CC"]

        Arachidonic_acid [label="Arachidonic Acid\n(phospholipid precursor)"]
        COX1_2 [label="COX-1/COX-2\n(cyclooxygenase)"]
        PGH2 [label="PGH2\n(prostaglandin H2)"]
        PGIS [label="PGIS\n(prostacyclin synthase)"]
        PGI2 [label="PGI2\n(prostacyclin)", shape=ellipse, fillcolor="#5588FF"]
        IP_receptor [label="IP Receptor\n(prostacyclin receptor)"]
        Gs_protein [label="Gs Protein\nActivation"]
        Adenylyl_cyclase [label="Adenylyl Cyclase\n(AC)"]
        cAMP [label="cAMP", shape=ellipse, fillcolor="#5588FF"]
        PKA [label="PKA\n(cAMP-dependent PK)"]
        MLCP_cAMP [label="MLCP Activation\n(via PKA)"]
        Vasodilation_PGI2 [label="VASODILATION\n↓ PVR", shape=diamond, fillcolor="#0044CC", fontcolor=white]
        TXA2 [label="TXA2\n(thromboxane A2)"]
        Platelet_agg [label="Platelet\nAggregation"]
        Thrombosis [label="In-situ\nThrombosis"]
    }

    // =====================================================================
    // CLUSTER 5: GROWTH FACTOR SIGNALING & REMODELING
    // =====================================================================
    subgraph cluster_growth {
        label="Growth Factors & Vascular Remodeling"
        style="filled,rounded"
        color="#FF8800"
        fillcolor="#FFF8EE"
        fontsize=12
        fontcolor="#7A3B00"

        node [fillcolor="#FFD08C", color="#FF8800"]

        BMPR2 [label="BMPR2\n(bone morphogen. receptor 2)\n[mutation in hPAH]", fillcolor="#FF6600", fontcolor=white]
        ALK1 [label="ALK1\n(ACVRL1)"]
        ALK2 [label="ALK2\n(ACVR1)"]
        BMP9 [label="BMP9\n(GDF2 ligand)"]
        SMAD158 [label="SMAD1/5/8\n(BMP-downstream)"]
        ID1 [label="ID1/ID2/ID3\n(inhibitor of differentiation)"]
        BMPR2_loss [label="BMPR2\nSignal Loss\n(loss-of-function)", fillcolor="#CC4400", fontcolor=white]
        TGFb1 [label="TGF-β1"]
        TGFBR1 [label="TGF-βRI\n(ALK5)"]
        TGFBR2 [label="TGF-βRII"]
        SMAD23 [label="SMAD2/3\n(TGF-β downstream)"]
        SMAD4 [label="SMAD4\n(co-SMAD)"]
        SMAD67 [label="SMAD6/7\n(inhibitory)"]
        PDGF [label="PDGF-BB\n(platelet-derived GF)"]
        PDGFR_b [label="PDGFR-β"]
        VEGF [label="VEGF-A\n(vascular endothelial GF)"]
        VEGFR2 [label="VEGFR2\n(KDR/FLK1)"]
        FGF2 [label="FGF-2\n(basic FGF)"]
        FGFR1 [label="FGFR1"]
        EGF [label="EGF/HB-EGF"]
        EGFR [label="EGFR\n(ErbB1)"]
        MAPK_ERK [label="RAS-MEK-ERK1/2\n(MAPK cascade)"]
        PI3K_AKT [label="PI3K-AKT\n(survival pathway)"]
        mTOR [label="mTOR\n(complex 1&2)"]
        S6K [label="S6K / 4EBP1\n(protein synthesis)"]
        STAT3 [label="STAT3\n(transcription factor)"]
        JAK2 [label="JAK1/2\n(kinase)"]
        Apoptosis_resist [label="Apoptosis\nResistance", fillcolor="#CC4400", fontcolor=white]
        PASMC_prolif [label="PASMC\nProliferation", fillcolor="#CC4400", fontcolor=white]
        EC_dysfunc [label="EC\nDysfunction", fillcolor="#CC4400", fontcolor=white]
        Collagen_syn [label="Collagen I/III\nSynthesis"]
        MMP2 [label="MMP-2\n(gelatinase A)"]
        MMP9 [label="MMP-9\n(gelatinase B)"]
        TIMP1 [label="TIMP-1\n(MMP inhibitor)"]
        ECM_remodel [label="ECM\nRemodeling", fillcolor="#CC4400", fontcolor=white]
        Elastin_deg [label="Elastin\nDegradation"]
        Fibronectin [label="Fibronectin\nAccumulation"]
    }

    // =====================================================================
    // CLUSTER 6: INFLAMMATION & IMMUNE
    // =====================================================================
    subgraph cluster_immune {
        label="Inflammation & Immune Dysregulation"
        style="filled,rounded"
        color="#AA0088"
        fillcolor="#FFEEFD"
        fontsize=12
        fontcolor="#5C0048"

        node [fillcolor="#FFBBF0", color="#AA0088"]

        Th1_cell [label="Th1 Cells\n(IFN-γ, TNF-α)"]
        Th2_cell [label="Th2 Cells\n(IL-4, IL-13)"]
        Th17_cell [label="Th17 Cells\n(IL-17A)"]
        Treg_cell [label="Treg Cells\n(IL-10, TGF-β)"]
        CD8_T [label="CD8+ T cells\n(cytotoxic)"]
        B_cell [label="B Cells\n(autoAb)"]
        Macrophage_M1 [label="M1 Macrophage\n(pro-inflam)"]
        Macrophage_M2 [label="M2 Macrophage\n(pro-fibrotic)"]
        Mast_cell [label="Mast Cells\n(degranulation)"]
        NK_cell [label="NK Cells"]
        Dendritic_cell [label="Dendritic Cells\n(APC)"]
        IL6 [label="IL-6", shape=ellipse, fillcolor="#FF88DD"]
        IL1b [label="IL-1β", shape=ellipse, fillcolor="#FF88DD"]
        TNFa [label="TNF-α", shape=ellipse, fillcolor="#FF88DD"]
        IL4 [label="IL-4", shape=ellipse, fillcolor="#FF88DD"]
        IL13 [label="IL-13", shape=ellipse, fillcolor="#FF88DD"]
        IL17A [label="IL-17A", shape=ellipse, fillcolor="#FF88DD"]
        IL10 [label="IL-10\n(anti-inflam)", shape=ellipse, fillcolor="#AAFFDD"]
        NFkB [label="NF-κB\n(transcription factor)"]
        Inflammation_loop [label="Perivascular\nInflammation\n(plexiform lesion)", fillcolor="#880066", fontcolor=white]
    }

    // =====================================================================
    // CLUSTER 7: METABOLISM & HYPOXIA
    // =====================================================================
    subgraph cluster_metabolism {
        label="Metabolic Reprogramming & Hypoxia Sensing"
        style="filled,rounded"
        color="#996600"
        fillcolor="#FFFBEE"
        fontsize=12
        fontcolor="#5C3D00"

        node [fillcolor="#FFE88A", color="#996600"]

        HIF1a [label="HIF-1α\n(hypoxia-inducible factor)"]
        HIF2a [label="HIF-2α\n(EPAS1)"]
        VHL [label="VHL\n(pVHL E3 ligase)\n→ HIF degradation"]
        PHD [label="PHD1/2/3\n(prolyl hydroxylase)"]
        PDK1 [label="PDK1\n(pyruvate DH kinase)"]
        PDH [label="PDH\n(pyruvate DH complex)"]
        Warburg [label="Aerobic Glycolysis\n(Warburg Effect)", fillcolor="#CC9900", fontcolor=white]
        Mitochondria [label="Mitochondrial\nDysfunction\n(fission↑, fusion↓)"]
        DRP1 [label="DRP1\n(mitochondrial fission)"]
        OPA1 [label="OPA1\n(fusion GTPase)"]
        ROS [label="ROS\n(reactive oxygen species)"]
        NOX4 [label="NOX4\n(NADPH oxidase)"]
        SOD2 [label="SOD2\n(Mn-superoxide dismutase)"]
        Kv15 [label="Kv1.5\n(voltage-gated K⁺ channel)\n[↓ in PAH]"]
        TRPC6 [label="TRPC3/6\n(transient receptor potential)"]
        Store_operated [label="SOC Entry\n(store-operated Ca²⁺)"]
        Survivin [label="Survivin\n(anti-apoptotic)"]
        Bcl2 [label="Bcl-2/Bcl-XL\n(anti-apoptotic)"]
        p53 [label="p53\n(apoptosis regulator)"]
        Epigenetics [label="Epigenetic\nRemodeling\n(HDAC, DNMT)"]
    }

    // =====================================================================
    // CLUSTER 8: CELL TYPES & STRUCTURAL CHANGES
    // =====================================================================
    subgraph cluster_cells {
        label="Pulmonary Vascular Cells & Structural Remodeling"
        style="filled,rounded"
        color="#336699"
        fillcolor="#EEF5FF"
        fontsize=12
        fontcolor="#002244"

        node [fillcolor="#99BBEE", color="#336699"]

        PAEC [label="Pulmonary Artery EC\n(PAEC)"]
        PASMC [label="Pulmonary Artery SMC\n(PASMC)"]
        Adventitial_FB [label="Adventitial\nFibroblast"]
        Pericyte [label="Pericyte\n(mural cell)"]
        Myofibroblast [label="Myofibroblast\n(α-SMA+)"]
        Intima_thick [label="Intimal\nThickening", fillcolor="#2255AA", fontcolor=white]
        Media_thick [label="Medial\nHypertrophy", fillcolor="#2255AA", fontcolor=white]
        Adventitia_remodel [label="Adventitial\nRemodeling", fillcolor="#2255AA", fontcolor=white]
        Plexiform_lesion [label="Plexiform\nLesion\n(end-stage)", fillcolor="#001166", fontcolor=white]
        Neointima [label="Neointima\nFormation"]
        EndMT [label="EndMT\n(endo-mesenchymal\ntransition)"]
        EMT [label="EMT\n(epithelial-mesenchymal)"]
    }

    // =====================================================================
    // CLUSTER 9: RIGHT HEART & HEMODYNAMICS
    // =====================================================================
    subgraph cluster_RV {
        label="Right Heart & Hemodynamic Model"
        style="filled,rounded"
        color="#884400"
        fillcolor="#FFF5EE"
        fontsize=12
        fontcolor="#5C2200"

        node [fillcolor="#FFCCAA", color="#884400"]

        PVR [label="PVR\n(pulmonary vascular\nresistance)", shape=ellipse, fillcolor="#FF8844"]
        mPAP [label="mPAP\n(mean pulmonary\nartery pressure)", shape=ellipse, fillcolor="#FF8844"]
        CO [label="CO\n(cardiac output)", shape=ellipse, fillcolor="#FF8844"]
        CI [label="CI\n(cardiac index)"]
        RAP [label="RAP\n(right atrial\npressure)"]
        RVEDP [label="RVEDP\n(RV end-diastolic\npressure)"]
        RVEF [label="RVEF\n(RV ejection fraction)"]
        Ea [label="Ea\n(arterial elastance)"]
        Ees [label="Ees\n(RV end-systolic\nelastance)"]
        Ventriculo_coupling [label="RV-PA Coupling\n(Ees/Ea ratio)"]
        RV_hypertrophy [label="RV Hypertrophy\n(adaptive → maladaptive)"]
        RV_failure [label="RIGHT VENTRICULAR\nFAILURE", shape=diamond, fillcolor="#883300", fontcolor=white]
        TR [label="Tricuspid\nRegurgitation"]
        IVS_bowing [label="IVS\nLeftward Bowing\n(D-shaped LV)"]
        LV_underfill [label="LV Underfilling\n(↓ preload)"]
        Frank_Starling [label="Frank-Starling\nMechanism"]
        BNP [label="BNP/NT-proBNP\n(cardiac biomarker)", shape=ellipse, fillcolor="#FFAA77"]
        Troponin_I [label="hs-Troponin I\n(myocardial injury)"]
        TAPSE [label="TAPSE\n(RV function echo)"]
        RAA_system [label="RAAS\n(neurohormonal\nactivation)"]
        Aldosterone [label="Aldosterone\n(Na+ retention)"]
        SNS_act [label="SNS\nActivation\n(catecholamines)"]
    }

    // =====================================================================
    // CLUSTER 10: CLINICAL ENDPOINTS & BIOMARKERS
    // =====================================================================
    subgraph cluster_endpoints {
        label="Clinical Endpoints & Biomarkers"
        style="filled,rounded"
        color="#2A5F2A"
        fillcolor="#EEFFEE"
        fontsize=12
        fontcolor="#0A3A0A"

        node [fillcolor="#88EE88", color="#2A5F2A"]

        SixMWD [label="6-Minute Walk\nDistance (6MWD)", shape=ellipse, fillcolor="#00AA00", fontcolor=white]
        WHO_FC [label="WHO Functional\nClass (I-IV)", shape=ellipse, fillcolor="#00AA00", fontcolor=white]
        TTCW [label="Time to Clinical\nWorsening (TTCW)"]
        Exercise_capacity [label="Peak VO₂\n(exercise capacity)"]
        O2_saturation [label="SpO₂\n(oxygen saturation)"]
        Dyspnea [label="Dyspnea\n(Borg scale)"]
        QOL [label="Quality of Life\n(SF-36, CAMPHOR)"]
        Survival [label="Survival\n(overall mortality)", shape=ellipse, fillcolor="#006600", fontcolor=white]
        HF_hospitalization [label="HF\nHospitalization"]
        Right_heart_cath [label="Right Heart\nCatheterization\n(diagnostic gold std)"]
        Echo_params [label="Echocardiographic\nParameters\n(TRV, TAPSE, RAA)"]
        DLCO [label="DLCO\n(diffusing capacity)"]
        VQ_scan [label="V/Q Lung Scan\n(perfusion defect)"]
        CT_PA [label="CT Pulmonary\nAngiography"]
    }

    // =====================================================================
    // EDGES: DRUG PK FLOWS
    // =====================================================================
    ERA_gut -> ERA_central [label="ka (abs)", color="#9B4F96"]
    ERA_central -> ERA_peripheral [label="k12", color="#9B4F96"]
    ERA_peripheral -> ERA_central [label="k21", color="#9B4F96"]
    ERA_central -> ERA_effect [label="ke0", color="#9B4F96"]
    ERA_central -> CYP3A4 [label="CL/F", color="#9B4F96", style=dashed]
    CYP3A4 -> ERA_central [label="elimination", style=dashed]

    PDE5i_gut -> PDE5i_central [label="ka", color="#9B4F96"]
    PDE5i_central -> PDE5i_effect [label="ke0", color="#9B4F96"]
    PDE5i_central -> CYP3A4 [label="CL/F", color="#9B4F96", style=dashed]
    PDE5i_central -> CYP2C9 [label="CL/F", color="#9B4F96", style=dashed]

    sGC_gut -> sGC_central [label="ka", color="#9B4F96"]
    sGC_central -> sGC_effect [label="ke0", color="#9B4F96"]

    PGI2_iv -> PGI2_central [label="k_abs\n(t½ ~3min)", color="#9B4F96"]
    PGI2_central -> PGI2_effect [label="ke0", color="#9B4F96"]

    // Drug PD effects
    ERA_effect -> ETA_r [label="BLOCK\n(Emax model)", color="#9B4F96", style=bold, arrowhead=tee]
    ERA_effect -> ETB_r_SMC [label="BLOCK\n(dual ERA)", color="#9B4F96", style=bold, arrowhead=tee]
    ERA_effect -> ETB_r_EC [label="partial BLOCK\n(bosentan)", color="#9B4F96", style=dashed, arrowhead=tee]
    PDE5i_effect -> PDE5 [label="INHIBIT\n(IC50 model)", color="#006633", style=bold, arrowhead=tee]
    sGC_effect -> sGC_enzyme [label="STIMULATE\n(EC50 model)", color="#006633", style=bold]
    PGI2_effect -> IP_receptor [label="ACTIVATE\n(Emax)", color="#0044CC", style=bold]

    // =====================================================================
    // EDGES: ENDOTHELIN PATHWAY
    // =====================================================================
    Hypoxia -> ET1_gene [label="HIF-1α induction", color="#CC3300"]
    Shear_stress -> ET1_gene [label="mechano-transduction", color="#CC3300"]
    TNFa -> ET1_gene [label="transcription↑", color="#CC3300"]
    IL1b -> ET1_gene [label="NF-κB mediated", color="#CC3300"]
    ET1_gene -> Pre_proET1 [color="#CC3300"]
    Pre_proET1 -> BigET1 [label="furin cleavage", color="#CC3300"]
    BigET1 -> ECE1 [color="#CC3300"]
    ECE1 -> ET1 [color="#CC3300"]
    ET1 -> ETA_r [label="Kd ~0.2 nM\n(high affinity)", color="#CC3300"]
    ET1 -> ETB_r_EC [label="vasodilatory", color="#006633"]
    ET1 -> ETB_r_SMC [label="vasoconstrictory", color="#CC3300"]
    ETA_r -> Gq_protein [color="#CC3300"]
    ETB_r_SMC -> Gq_protein [color="#CC3300"]
    Gq_protein -> PLC [color="#CC3300"]
    PLC -> IP3 [color="#CC3300"]
    PLC -> DAG [color="#CC3300"]
    IP3 -> Ca2_release [color="#CC3300"]
    DAG -> PKC [color="#CC3300"]
    PKC -> MLCK [color="#CC3300"]
    Ca2_release -> Ca2_i [color="#CC3300"]
    Ca2_influx -> Ca2_i [color="#CC3300"]
    Ca2_i -> MLCK [color="#CC3300"]
    MLCK -> MLC_p [label="phospho-MLC↑", color="#CC3300"]
    MLC_p -> Vasoconstriction [color="#CC3300", style=bold]
    ETA_r -> RhoA [label="G12/13 coupling", color="#CC3300"]
    RhoA -> ROCK1 [color="#CC3300"]
    ROCK1 -> MLCP_inh [label="MYPT1 phospho", color="#CC3300"]
    MLCP_inh -> MLC_p [label="phospho-MLC stays↑", color="#CC3300"]
    ROCK1 -> Vasoconstriction [color="#CC3300", style=bold]
    TRPC6 -> Ca2_influx [color="#CC3300"]

    ETB_r_EC -> eNOS [label="stimulate\n(via Ca2+/CaM)", color="#006633"]
    ETB_r_EC -> PGI2 [label="stimulate", color="#0044CC"]

    // =====================================================================
    // EDGES: NO-cGMP PATHWAY
    // =====================================================================
    L_Arginine -> eNOS [color="#006633"]
    Tetrahydrobiopterin -> eNOS [label="cofactor", color="#006633"]
    eNOS -> NO [label="O₂ + NADPH", color="#006633"]
    NO -> sGC_enzyme [label="activates (Fe-heme)", color="#006633"]
    sGC_enzyme -> GTP [color="#006633"]
    GTP -> cGMP [color="#006633"]
    cGMP -> PKG [color="#006633"]
    cGMP -> PDE5 [label="substrate", color="#006633"]
    PDE5 -> cGMP [label="5'-GMP\n(inactivation)", color="#CC0000", arrowhead=tee]
    PKG -> MLCP_act [label="BKCa / MLCP", color="#006633"]
    PKG -> Kv_open [color="#006633"]
    Kv_open -> Membrane_hyperpol [color="#006633"]
    Membrane_hyperpol -> Vasodilation_NO [color="#006633", style=bold]
    MLCP_act -> Vasodilation_NO [color="#006633", style=bold]

    ROS -> NOS_uncoupling [color="#AA0000"]
    NOS_uncoupling -> NO [label="↓ NO production", color="#AA0000", arrowhead=tee]
    NOS_uncoupling -> ONOO [label="O₂⁻ + NO →", color="#AA0000"]
    ONOO -> sGC_enzyme [label="oxidize/inactivate", color="#AA0000", arrowhead=tee]
    Inflammation_loop -> iNOS [label="cytokine induction", color="#AA0000"]
    iNOS -> NO [label="burst production", color="#AA0000"]
    iNOS -> ONOO [label="at high [O₂⁻]", color="#AA0000"]

    // =====================================================================
    // EDGES: PROSTACYCLIN PATHWAY
    // =====================================================================
    PAEC -> Arachidonic_acid [label="phospholipase A2", color="#0044CC"]
    Arachidonic_acid -> COX1_2 [color="#0044CC"]
    COX1_2 -> PGH2 [color="#0044CC"]
    PGH2 -> PGIS [color="#0044CC"]
    PGIS -> PGI2 [color="#0044CC"]
    PGI2 -> IP_receptor [color="#0044CC"]
    IP_receptor -> Gs_protein [color="#0044CC"]
    Gs_protein -> Adenylyl_cyclase [color="#0044CC"]
