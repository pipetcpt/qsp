digraph DPN_QSP {
  /* =========================================================
     Diabetic Peripheral Neuropathy (DPN) — QSP Mechanistic Map
     Author: Claude Code Routine (QSP Library)
     Scope:  metabolic injury → microvascular dysfunction →
             nerve fibre damage → pain & sensory loss → clinical
     ========================================================= */
  graph [rankdir=LR, splines=spline, overlap=false, fontname="Helvetica", fontsize=11, labelloc="t",
         label="Diabetic Peripheral Neuropathy — Integrated QSP Map (Metabolic · Microvascular · Neural · Pharmacological)"];
  node  [shape=box, style="rounded,filled", fontname="Helvetica", fontsize=10, color="#333333"];
  edge  [fontname="Helvetica", fontsize=9, color="#555555"];

  /* ---------- 1. Glycaemic / Systemic Driver ---------- */
  subgraph cluster_glycemia {
    label="① Glycaemic & Systemic Driver"; style="rounded,filled"; fillcolor="#FFF7E6"; color="#D4A017";
    HbA1c           [label="HbA1c (%)\n(target <7.0)", fillcolor="#FFE9A8"];
    FPG             [label="Fasting Plasma\nGlucose", fillcolor="#FFE9A8"];
    PPG             [label="Postprandial\nGlucose", fillcolor="#FFE9A8"];
    GlucVar         [label="Glycaemic\nvariability (CV)", fillcolor="#FFE9A8"];
    DM_Duration     [label="Diabetes\nduration (years)", fillcolor="#FFE9A8"];
    InsulinRes      [label="Insulin\nresistance", fillcolor="#FFE9A8"];
    Dyslipidemia    [label="Dyslipidaemia\n(TG↑, LDL↑)", fillcolor="#FFE9A8"];
    HTN             [label="Hypertension", fillcolor="#FFE9A8"];
    Smoking         [label="Smoking\n/EtOH", fillcolor="#FFE9A8"];
    B12_Def         [label="Vitamin B12\ndeficiency\n(metformin)", fillcolor="#FFE9A8"];
    Obesity         [label="Visceral\nadiposity", fillcolor="#FFE9A8"];
  }

  /* ---------- 2. Intracellular Hyperglycaemia: Four Pathways ---------- */
  subgraph cluster_metabolic {
    label="② Intracellular Hyperglycaemia — 4 Convergent Pathways"; style="rounded,filled"; fillcolor="#FFF0F0"; color="#C0392B";
    IntraGluc       [label="Intracellular\nGlucose\n(GLUT-independent)", fillcolor="#FAD7D7"];
    Polyol          [label="Polyol pathway\nGlu→Sorbitol→Fructose", fillcolor="#F5B7B1"];
    AR              [label="Aldose Reductase\n(AKR1B1)", fillcolor="#F5B7B1"];
    SorbDH          [label="Sorbitol DH", fillcolor="#F5B7B1"];
    Sorbitol        [label="Sorbitol\n(osmotic stress)", fillcolor="#F5B7B1"];
    Fructose        [label="Fructose →\nAGE precursor", fillcolor="#F5B7B1"];
    NADPH_loss      [label="NADPH↓\n(GSH↓)", fillcolor="#F5B7B1"];
    AGE_path        [label="AGE pathway\n(Maillard)", fillcolor="#F5B7B1"];
    AGEs            [label="AGEs\n(CML, pentosidine,\nMGO)", fillcolor="#F5B7B1"];
    RAGE            [label="RAGE\n(receptor)", fillcolor="#F5B7B1"];
    PKC_path        [label="PKC pathway\n(via DAG)", fillcolor="#F5B7B1"];
    DAG             [label="DAG↑", fillcolor="#F5B7B1"];
    PKCbeta         [label="PKC-β\n(ruboxistaurin target)", fillcolor="#F5B7B1"];
    Hexosamine      [label="Hexosamine\npathway", fillcolor="#F5B7B1"];
    GFAT            [label="GFAT", fillcolor="#F5B7B1"];
    OGlcNAc         [label="O-GlcNAc\nmodification", fillcolor="#F5B7B1"];
  }

  /* ---------- 3. Oxidative & Nitrosative Stress / Mitochondria ---------- */
  subgraph cluster_oxidative {
    label="③ Mitochondrial Dysfunction · Oxidative & Nitrosative Stress"; style="rounded,filled"; fillcolor="#FFF1E6"; color="#E67E22";
    MitoDysfx       [label="Mitochondrial\ndysfunction", fillcolor="#FCD8B5"];
    ETC             [label="Electron transport\nchain leak", fillcolor="#FCD8B5"];
    ROS             [label="ROS\n(superoxide, H2O2)", fillcolor="#FAD7A0"];
    NOS_un          [label="eNOS uncoupling", fillcolor="#FCD8B5"];
    Peroxynitrite   [label="ONOO⁻\n(peroxynitrite)", fillcolor="#FAD7A0"];
    NOX             [label="NADPH oxidase\n(NOX2/4)", fillcolor="#FCD8B5"];
    PARP            [label="PARP-1\nactivation", fillcolor="#FAD7A0"];
    NAD_loss        [label="NAD⁺ depletion", fillcolor="#FAD7A0"];
    GAPDH_inh       [label="GAPDH inhibition\n(O-GlcNAc)", fillcolor="#FAD7A0"];
    LipidPx         [label="Lipid\nperoxidation\n(4-HNE)", fillcolor="#FAD7A0"];
    Nrf2            [label="Nrf2 / Keap1\n(antioxidant\nresponse)", fillcolor="#FCD8B5"];
    GSH             [label="Glutathione\n(GSH)", fillcolor="#FCD8B5"];
  }

  /* ---------- 4. Microvascular & Endoneurial Compartment ---------- */
  subgraph cluster_microvasc {
    label="④ Microvascular / Endoneurial Compartment"; style="rounded,filled"; fillcolor="#E8F8F5"; color="#16A085";
    VasaNerv        [label="Vasa nervorum\nendothelium", fillcolor="#A2D9CE"];
    NO              [label="NO bioavailability↓", fillcolor="#A2D9CE"];
    ET1             [label="Endothelin-1↑", fillcolor="#A2D9CE"];
    VEGF            [label="VEGF dysregulation", fillcolor="#A2D9CE"];
    BMthick         [label="Basement membrane\nthickening", fillcolor="#A2D9CE"];
    EndoBlood       [label="Endoneurial\nblood flow↓", fillcolor="#A2D9CE"];
    EndoHypoxia     [label="Endoneurial\nhypoxia", fillcolor="#A2D9CE"];
    BNB             [label="Blood-nerve\nbarrier disruption", fillcolor="#A2D9CE"];
    Pericyte        [label="Pericyte loss", fillcolor="#A2D9CE"];
    Microthrombi    [label="Capillary\nmicrothrombi", fillcolor="#A2D9CE"];
    ACE_RAAS        [label="Local RAAS\n(AngII)", fillcolor="#A2D9CE"];
  }

  /* ---------- 5. Inflammation & Immune Components ---------- */
  subgraph cluster_inflam {
    label="⑤ Neuro-inflammation & Innate Immunity"; style="rounded,filled"; fillcolor="#F4ECF7"; color="#7D3C98";
    NFkB            [label="NF-κB", fillcolor="#D2B4DE"];
    TNFa            [label="TNF-α", fillcolor="#D2B4DE"];
    IL6             [label="IL-6", fillcolor="#D2B4DE"];
    IL1b            [label="IL-1β\n(NLRP3)", fillcolor="#D2B4DE"];
    MCP1            [label="MCP-1 / CCL2", fillcolor="#D2B4DE"];
    Macrophage      [label="Macrophage\ninfiltration", fillcolor="#D2B4DE"];
    Mast            [label="Mast cell\nactivation", fillcolor="#D2B4DE"];
    COX2            [label="COX-2 / PGE2", fillcolor="#D2B4DE"];
    SatGliaPNS      [label="Satellite glia (DRG)\nactivation", fillcolor="#D2B4DE"];
    Schwann_Inflam  [label="Schwann cell\ncytokine release", fillcolor="#D2B4DE"];
  }

  /* ---------- 6. Peripheral Nerve Structural Damage ---------- */
  subgraph cluster_nerve {
    label="⑥ Peripheral Nerve — Structural Damage"; style="rounded,filled"; fillcolor="#FDFEFE"; color="#1B4F72";
    DRG             [label="Dorsal Root\nGanglion (DRG)\nneurons", fillcolor="#D4E6F1"];
    Axon            [label="Axon\n(distal die-back)", fillcolor="#D4E6F1"];
    Cfiber          [label="C-fibres\n(small/IENFD↓)", fillcolor="#D4E6F1"];
    Adelta          [label="Aδ fibres", fillcolor="#D4E6F1"];
    Abeta           [label="Aβ fibres\n(large)", fillcolor="#D4E6F1"];
    SchwannCell     [label="Schwann cell\n(myelinating)", fillcolor="#D4E6F1"];
    Myelin          [label="Myelin sheath", fillcolor="#D4E6F1"];
    NodeRanvier     [label="Node of Ranvier\nNa+ channel cluster", fillcolor="#D4E6F1"];
    AxoTransport    [label="Axonal\ntransport (kinesin)", fillcolor="#D4E6F1"];
    NGF             [label="NGF / NT-3 / BDNF↓", fillcolor="#D4E6F1"];
    IENFD           [label="Intra-epidermal\nnerve fibre density\n(IENFD)", fillcolor="#D4E6F1"];
    NCV             [label="Nerve conduction\nvelocity (NCV)", fillcolor="#D4E6F1"];
    SUDOSCAN        [label="Sudomotor\nfunction (ESC)", fillcolor="#D4E6F1"];
    Sural_amp       [label="Sural nerve\namplitude (SNAP)", fillcolor="#D4E6F1"];
  }

  /* ---------- 7. Pain Signalling & Sensitisation ---------- */
  subgraph cluster_pain {
    label="⑦ Pain Signalling & Sensitisation"; style="rounded,filled"; fillcolor="#FEF9E7"; color="#B7950B";
    TRPV1           [label="TRPV1\n(capsaicin target)", fillcolor="#FAD7A0"];
    TRPA1           [label="TRPA1", fillcolor="#FAD7A0"];
    Nav17           [label="Nav1.7", fillcolor="#FAD7A0"];
    Nav18           [label="Nav1.8", fillcolor="#FAD7A0"];
    Nav19           [label="Nav1.9", fillcolor="#FAD7A0"];
    Kv7             [label="Kv7\n(M-current)", fillcolor="#FAD7A0"];
    Cav_a2d         [label="Cav α2δ-1\n(pregabalin target)", fillcolor="#FAD7A0"];
    EctActFire      [label="Ectopic axonal\nfiring", fillcolor="#FAD7A0"];
    PrimAff_Sens    [label="Peripheral\nsensitisation", fillcolor="#FAD7A0"];
    GluRel          [label="Glutamate release\n(dorsal horn)", fillcolor="#FAD7A0"];
    NMDA            [label="NMDA receptor", fillcolor="#FAD7A0"];
    SubP_CGRP       [label="Substance P /\nCGRP", fillcolor="#FAD7A0"];
    Microglia       [label="Microglia (P2X4,\nP2X7) activation", fillcolor="#FAD7A0"];
    Astrocyte       [label="Astrocyte\nactivation", fillcolor="#FAD7A0"];
    CentralSens     [label="Central\nsensitisation\n(dorsal horn)", fillcolor="#FAD7A0"];
    DescMod         [label="Descending\nmodulation\n(5-HT/NE)", fillcolor="#FAD7A0"];
    GABA            [label="GABA / glycine\ndisinhibition", fillcolor="#FAD7A0"];
    OpioidR         [label="μ-opioid receptor", fillcolor="#FAD7A0"];
    CortexPain      [label="Cortical pain\nperception", fillcolor="#FAD7A0"];
  }

  /* ---------- 8. Symptoms & Clinical Endpoints ---------- */
  subgraph cluster_clinical {
    label="⑧ Symptoms · Clinical Endpoints · Outcomes"; style="rounded,filled"; fillcolor="#EBF5FB"; color="#1F618D";
    Numbness        [label="Numbness\nstocking-glove"];
    Paresthesia     [label="Paresthesia\n(tingling)"];
    BurnPain        [label="Burning pain\n(NRS 0-10)"];
    Allodynia       [label="Allodynia"];
    Hyperalgesia    [label="Hyperalgesia"];
    VibLoss         [label="Vibration sense\nloss (128Hz)"];
    Monofilament    [label="10g monofilament\nloss"];
    AnkleRefl       [label="Ankle reflex\nabsent"];
    TCNS_score      [label="Toronto Clinical\nNeuropathy Score"];
    MNSI            [label="MNSI score\n(Michigan)"];
    NTSS6           [label="NTSS-6\nsymptom score"];
    BPI_DPN         [label="BPI-DPN\ninterference"];
    Sleep           [label="Sleep\ndisturbance"];
    Mood            [label="Depression /\nanxiety"];
    QoL             [label="QoL (Norfolk-QoL,\nSF-36)"];
    Falls           [label="Falls / balance↓"];
    DFU             [label="Diabetic foot\nulcer"];
    Charcot         [label="Charcot\nneuroarthropathy"];
    Amputation      [label="Lower-limb\namputation"];
    Mortality       [label="All-cause\nmortality"];
  }

  /* ---------- 9. Drug PK / PD ---------- */
  subgraph cluster_drugs {
    label="⑨ Pharmacotherapy — PK / PD"; style="rounded,filled"; fillcolor="#E8F8F5"; color="#117864";
    Pregabalin      [label="Pregabalin\n(Lyrica)\n150-600 mg/d", shape=ellipse, fillcolor="#76D7C4"];
    Gabapentin      [label="Gabapentin\n900-3600 mg/d", shape=ellipse, fillcolor="#76D7C4"];
    Duloxetine      [label="Duloxetine\n60-120 mg/d\n(SNRI)", shape=ellipse, fillcolor="#76D7C4"];
    Venlafaxine     [label="Venlafaxine XR\n75-225 mg/d", shape=ellipse, fillcolor="#76D7C4"];
    Amitriptyline   [label="Amitriptyline\n25-100 mg/d (TCA)", shape=ellipse, fillcolor="#76D7C4"];
    Nortriptyline   [label="Nortriptyline\n25-100 mg/d", shape=ellipse, fillcolor="#76D7C4"];
    Capsaicin8      [label="Capsaicin 8%\npatch (Qutenza)", shape=ellipse, fillcolor="#76D7C4"];
    LidocainePatch  [label="Lidocaine 5%\npatch", shape=ellipse, fillcolor="#76D7C4"];
    Tapentadol      [label="Tapentadol ER\n100-250 mg BID", shape=ellipse, fillcolor="#76D7C4"];
    Tramadol        [label="Tramadol\n100-400 mg/d", shape=ellipse, fillcolor="#76D7C4"];
    ALA             [label="α-Lipoic acid\n600 mg IV / oral\n(ALADIN, NATHAN)", shape=ellipse, fillcolor="#76D7C4"];
    Benfotiamine    [label="Benfotiamine\n300-600 mg/d", shape=ellipse, fillcolor="#76D7C4"];
    Epalrestat      [label="Epalrestat\n150 mg/d\n(ARI, Japan)", shape=ellipse, fillcolor="#76D7C4"];
    Ruboxistaurin   [label="Ruboxistaurin\n(PKC-β inhibitor,\nfailed Ph3)", shape=ellipse, fillcolor="#FADBD8"];
    Aminoguanidine  [label="Aminoguanidine\n(AGE inhibitor,\nfailed Ph3)", shape=ellipse, fillcolor="#FADBD8"];
    ACEi_ARB        [label="ACEi / ARB\n(microvasc.\nprotection)", shape=ellipse, fillcolor="#76D7C4"];
    Statin          [label="Statin\n(neuropathy risk?)", shape=ellipse, fillcolor="#76D7C4"];
    SGLT2i          [label="SGLT2 inhibitor\n(glycaemic +\nrenal)", shape=ellipse, fillcolor="#76D7C4"];
    GLP1            [label="GLP-1 RA\n(semaglutide etc.)", shape=ellipse, fillcolor="#76D7C4"];
    Insulin         [label="Insulin\n(intensive\nDCCT/EDIC)", shape=ellipse, fillcolor="#76D7C4"];
    Metformin       [label="Metformin\n(B12↓ risk)", shape=ellipse, fillcolor="#76D7C4"];
    SCS             [label="Spinal cord\nstimulation\n(10kHz HF, SENZA-PDN)", shape=ellipse, fillcolor="#76D7C4"];
    DRGStim         [label="DRG stimulation", shape=ellipse, fillcolor="#76D7C4"];
    BTX             [label="Botulinum toxin\n(off-label)", shape=ellipse, fillcolor="#76D7C4"];
    Exercise        [label="Aerobic +\nresistance\nexercise", shape=ellipse, fillcolor="#76D7C4"];
  }

  /* ---------- 10. Genetic / Modifier ---------- */
  subgraph cluster_genetic {
    label="⑩ Genetic & Modifier Variants"; style="rounded,filled"; fillcolor="#FBEEE6"; color="#A04000";
    AKR1B1_var     [label="AKR1B1\npromoter (Z-2)", fillcolor="#FAD7A0"];
    MTHFR          [label="MTHFR C677T", fillcolor="#FAD7A0"];
    GPX1_var       [label="GPX1 Pro198Leu", fillcolor="#FAD7A0"];
    SCN9A_var      [label="SCN9A variants\n(Nav1.7)", fillcolor="#FAD7A0"];
    APOE           [label="APOE genotype", fillcolor="#FAD7A0"];
    CYP2D6         [label="CYP2D6 (TCA,\nduloxetine, tramadol\nmetabolism)", fillcolor="#FAD7A0"];
  }

  /* ============ Edges ============ */
  /* Glycaemia drives intracellular flux */
  HbA1c -> IntraGluc [label="↑"];
  FPG -> IntraGluc;
  PPG -> IntraGluc;
  GlucVar -> IntraGluc;
  GlucVar -> ROS [label="glucose spikes"];
  DM_Duration -> IntraGluc;
  InsulinRes -> Dyslipidemia;
  InsulinRes -> Obesity;
  Dyslipidemia -> MitoDysfx;
  HTN -> VasaNerv;
  HTN -> ACE_RAAS;
  Smoking -> VasaNerv;
  Obesity -> NFkB;
  B12_Def -> Axon [label="metformin →\nMMA↑"];
  Metformin -> B12_Def [color="#117864"];

  /* Four pathways from intracellular hyperglycaemia */
  IntraGluc -> AR;
  AR -> Sorbitol;
  Sorbitol -> SorbDH -> Fructose;
  AR -> NADPH_loss;
  NADPH_loss -> GSH [label="↓"];
  Sorbitol -> Polyol;
  Polyol -> ROS;
  Fructose -> AGE_path;
  IntraGluc -> AGE_path;
  AGE_path -> AGEs;
  AGEs -> RAGE;
  RAGE -> NFkB;
  RAGE -> NOX;
  IntraGluc -> DAG;
  DAG -> PKCbeta;
  PKCbeta -> PKC_path;
  PKC_path -> NOX;
  PKC_path -> VEGF;
  PKC_path -> ET1;
  IntraGluc -> GFAT;
  GFAT -> Hexosamine -> OGlcNAc;
  OGlcNAc -> GAPDH_inh;

  /* Convergence on oxidative stress / mitochondria */
  Polyol -> MitoDysfx;
  AGEs -> MitoDysfx;
  PKC_path -> MitoDysfx;
  Hexosamine -> MitoDysfx;
  MitoDysfx -> ETC -> ROS;
  ROS -> Peroxynitrite;
  NOS_un -> Peroxynitrite;
  NOX -> ROS;
  ROS -> PARP;
  PARP -> NAD_loss;
  NAD_loss -> GAPDH_inh;
  GAPDH_inh -> AGE_path;
  GAPDH_inh -> Hexosamine;
  GAPDH_inh -> Polyol;
  ROS -> LipidPx;
  LipidPx -> Schwann_Inflam;
  ROS -> Nrf2;
  Nrf2 -> GSH;

  /* Microvascular cascade */
  ROS -> VasaNerv;
  Peroxynitrite -> VasaNerv;
  AGEs -> BMthick;
  VasaNerv -> NO;
  NO -> EndoBlood [arrowhead=tee, label="↓"];
  ET1 -> EndoBlood [arrowhead=tee];
  BMthick -> EndoBlood [arrowhead=tee];
  Pericyte -> EndoBlood [arrowhead=tee];
  Microthrombi -> EndoBlood [arrowhead=tee];
  EndoBlood -> EndoHypoxia;
  EndoHypoxia -> Axon;
  EndoHypoxia -> SchwannCell;
  ACE_RAAS -> VasaNerv;
  ACEi_ARB -> ACE_RAAS [arrowhead=tee, color="#117864"];
  BNB -> Axon;
  AGEs -> BNB;

  /* Inflammation */
  NFkB -> TNFa;
  NFkB -> IL6;
  NFkB -> IL1b;
  NFkB -> COX2;
  NFkB -> MCP1;
  MCP1 -> Macrophage;
  Macrophage -> TNFa;
  Mast -> TNFa;
  IL1b -> Schwann_Inflam;
  TNFa -> SatGliaPNS;
  Schwann_Inflam -> SchwannCell;
  COX2 -> PrimAff_Sens;

  /* Nerve structural damage */
  EndoHypoxia -> NGF;
  ROS -> NGF;
  NGF -> Axon [arrowhead=tee, label="trophic ↓"];
  NGF -> DRG [arrowhead=tee];
  ROS -> DRG;
  AGEs -> AxoTransport;
  AxoTransport -> Axon [arrowhead=tee];
  Schwann_Inflam -> Myelin;
  Myelin -> NCV;
  NodeRanvier -> NCV;
  Axon -> Cfiber;
  Axon -> Adelta;
  Axon -> Abeta;
  Cfiber -> IENFD;
  Cfiber -> SUDOSCAN;
  Abeta -> Sural_amp;
  Abeta -> NCV;
  SchwannCell -> Myelin;
  AGEs -> Myelin [arrowhead=tee];

  /* Pain transduction */
  ROS -> TRPV1;
  Cfiber -> TRPV1;
  Cfiber -> TRPA1;
  TRPV1 -> PrimAff_Sens;
  TRPA1 -> PrimAff_Sens;
  Nav17 -> EctActFire;
  Nav18 -> EctActFire;
  Nav19 -> EctActFire;
  AGEs -> Nav17 [label="upreg."];
  Cfiber -> Nav17;
  Cfiber -> Nav18;
  EctActFire -> PrimAff_Sens;
  Kv7 -> PrimAff_Sens [arrowhead=tee];
  Cav_a2d -> GluRel;
  PrimAff_Sens -> GluRel;
  GluRel -> NMDA;
  NMDA -> CentralSens;
  SubP_CGRP -> CentralSens;
  PrimAff_Sens -> SubP_CGRP;
  Microglia -> CentralSens;
  Astrocyte -> CentralSens;
  TNFa -> Microglia;
  GABA -> CentralSens [arrowhead=tee];
  DescMod -> CentralSens [arrowhead=tee];
  OpioidR -> CentralSens [arrowhead=tee];
  CentralSens -> CortexPain;

  /* Symptoms */
  Cfiber -> Numbness [arrowhead=tee];
  Abeta -> Numbness [arrowhead=tee];
  CortexPain -> BurnPain;
  CortexPain -> Paresthesia;
  CentralSens -> Allodynia;
  PrimAff_Sens -> Hyperalgesia;
  Abeta -> VibLoss [arrowhead=tee];
  Abeta -> Monofilament [arrowhead=tee];
  Abeta -> AnkleRefl [arrowhead=tee];
  IENFD -> Numbness [arrowhead=tee];
  NCV -> TCNS_score [arrowhead=tee];
  IENFD -> MNSI [arrowhead=tee];
  BurnPain -> NTSS6;
  BurnPain -> BPI_DPN;
  BurnPain -> Sleep;
  Sleep -> Mood;
  Mood -> QoL [arrowhead=tee];
  BurnPain -> QoL [arrowhead=tee];
  VibLoss -> Falls;
  Monofilament -> DFU;
  DFU -> Charcot;
  DFU -> Amputation;
  Amputation -> Mortality;
  Charcot -> Amputation;

  /* Drug PK/PD edges */
  Pregabalin -> Cav_a2d [arrowhead=tee, color="#117864"];
  Gabapentin -> Cav_a2d [arrowhead=tee, color="#117864"];
  Duloxetine -> DescMod [color="#117864", label="5-HT/NE↑"];
  Venlafaxine -> DescMod [color="#117864"];
  Amitriptyline -> DescMod [color="#117864"];
  Amitriptyline -> Nav17 [arrowhead=tee, color="#117864"];
  Nortriptyline -> DescMod [color="#117864"];
  Capsaicin8 -> TRPV1 [color="#117864", label="defunct."];
  Capsaicin8 -> Cfiber [arrowhead=tee, color="#117864", label="defunctionalisation"];
  LidocainePatch -> Nav17 [arrowhead=tee, color="#117864"];
  LidocainePatch -> Nav18 [arrowhead=tee, color="#117864"];
  Tapentadol -> OpioidR [color="#117864"];
  Tapentadol -> DescMod [color="#117864"];
  Tramadol -> OpioidR [color="#117864"];
  Tramadol -> DescMod [color="#117864"];
  ALA -> ROS [arrowhead=tee, color="#117864"];
  ALA -> GSH [color="#117864"];
  Benfotiamine -> GAPDH_inh [arrowhead=tee, color="#117864"];
  Benfotiamine -> Hexosamine [arrowhead=tee, color="#117864"];
  Benfotiamine -> Polyol [arrowhead=tee, color="#117864"];
  Epalrestat -> AR [arrowhead=tee, color="#117864"];
  Ruboxistaurin -> PKCbeta [arrowhead=tee, color="#117864"];
  Aminoguanidine -> AGE_path [arrowhead=tee, color="#117864"];
  ACEi_ARB -> VasaNerv [color="#117864", label="protect"];
  Statin -> Dyslipidemia [arrowhead=tee, color="#117864"];
  SGLT2i -> HbA1c [arrowhead=tee, color="#117864"];
  GLP1 -> HbA1c [arrowhead=tee, color="#117864"];
  GLP1 -> Obesity [arrowhead=tee, color="#117864"];
  Insulin -> HbA1c [arrowhead=tee, color="#117864"];
  Metformin -> HbA1c [arrowhead=tee, color="#117864"];
  SCS -> CentralSens [arrowhead=tee, color="#117864"];
  DRGStim -> DRG [arrowhead=tee, color="#117864"];
  BTX -> PrimAff_Sens [arrowhead=tee, color="#117864"];
  Exercise -> InsulinRes [arrowhead=tee, color="#117864"];
  Exercise -> IENFD [color="#117864", label="regrowth"];

  /* Genetics modifiers */
  AKR1B1_var -> AR;
  MTHFR -> Axon;
  GPX1_var -> ROS;
  SCN9A_var -> Nav17;
  APOE -> CortexPain;
  CYP2D6 -> Amitriptyline [arrowhead=tee, label="metab."];
  CYP2D6 -> Duloxetine [arrowhead=tee];
  CYP2D6 -> Tramadol [arrowhead=tee];

  /* Cross-cluster summary arrows */
  HbA1c -> NCV [style=dashed, label="DCCT/EDIC\n−60% incidence"];
  HbA1c -> IENFD [style=dashed];
  HbA1c -> Mortality [style=dashed];

  { rank=min; HbA1c; FPG; PPG; }
  { rank=max; Mortality; Amputation; QoL; }
}
