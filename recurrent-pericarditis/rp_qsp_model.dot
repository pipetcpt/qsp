digraph RP_QSP {
  graph [
    label="Recurrent Pericarditis — QSP Mechanistic Map\nNLRP3 Inflammasome · IL-1β Axis · Colchicine / NSAID / Corticosteroid / Anakinra / Rilonacept PK/PD"
    labelloc=t fontsize=17 fontname="Helvetica-Bold"
    rankdir=TB bgcolor="#f8f9fa" compound=true
    nodesep=0.32 ranksep=0.55 splines=ortho
  ]
  node [fontname=Helvetica fontsize=9 style="filled,rounded" shape=box]
  edge [fontname=Helvetica fontsize=8 arrowsize=0.6]

  // ============================================================
  // CLUSTER 1: Etiology / Triggers
  // ============================================================
  subgraph cluster_etiology {
    label="① 병인/Etiology" style=filled fillcolor="#fff9e6"
    fontname="Helvetica-Bold" fontsize=11 color="#d4a017"

    VIR        [label="Viral Infection\n(Coxsackievirus B, Echovirus,\nEBV, CMV, Parvovirus B19)" fillcolor="#ffe082"]
    SARS2      [label="SARS-CoV-2 /\nPost-COVID-19 Pericarditis" fillcolor="#ffe082"]
    PCIS       [label="Post-Cardiac Injury Syndrome\n(Dressler's, post-pericard.\npost-ablation)" fillcolor="#ffd54f"]
    IDIO       [label="Idiopathic\n(>50% of cases)" fillcolor="#ffe0b2"]
    AUTOI      [label="Autoinflammatory\n(CAPS, FMF, TRAPS, MKD)" fillcolor="#ffcc80"]
    AIINF      [label="Systemic Autoimmune\n(SLE, RA, SSc, Sjogren's)" fillcolor="#ffcc80"]
    DRUG_IND   [label="Drug-Induced\n(hydralazine, procainamide,\nisoniazid, checkpoint inhibitors)" fillcolor="#ffab40"]
    NEOPL      [label="Neoplastic\n(lymphoma, breast/lung mets,\nmesothelioma)" fillcolor="#ff8a65"]
    BACT       [label="Bacterial\n(TB, Staphylococcus,\nStreptococcus, pneumococcal)" fillcolor="#ff8a65"]
    TRAUMA     [label="Thoracic Trauma /\nPost-Cardiac Surgery /\nPost-TAVI" fillcolor="#ffd54f"]
  }

  // ============================================================
  // CLUSTER 2: DAMP/PAMP Recognition & Innate Sensing
  // ============================================================
  subgraph cluster_sensing {
    label="② DAMP/PAMP 인식 / Innate Sensing" style=filled fillcolor="#e8f5e9"
    fontname="Helvetica-Bold" fontsize=11 color="#2e7d32"

    DAMP       [label="DAMPs\n(HMGB1, ATP, mtDNA,\nUric acid crystals, S100)" fillcolor="#a5d6a7"]
    PAMP       [label="PAMPs\n(Viral dsRNA, ssRNA,\nLPS, CpG DNA)" fillcolor="#a5d6a7"]
    TLR3       [label="TLR3 (dsRNA)" fillcolor="#c8e6c9"]
    TLR4       [label="TLR4 (LPS, HMGB1)" fillcolor="#c8e6c9"]
    TLR7_8     [label="TLR7/8 (ssRNA)" fillcolor="#c8e6c9"]
    TLR9       [label="TLR9 (CpG DNA)" fillcolor="#c8e6c9"]
    CGAS       [label="cGAS\n(cytosolic DNA sensor)" fillcolor="#81c784"]
    STING      [label="STING\n(cGAMP → IRF3)" fillcolor="#81c784"]
    MYD88      [label="MyD88 / TRIF\n(TLR adaptors)" fillcolor="#66bb6a"]
    IRF3       [label="IRF3 / IRF7\n(IFN-β induction)" fillcolor="#66bb6a"]
    IFN_BETA   [label="IFN-β / Type I IFN\n(antiviral, pro-inflammatory)" fillcolor="#43a047"]
    NLRP3_PRIME [label="NLRP3 Priming\n(Signal 1 via NF-κB:\nNLRP3 & pro-IL-1β transcription)" fillcolor="#388e3c" fontcolor="white"]
    CRYSTAL    [label="NLRP3 Signal 2\n(ATP, crystals, K⁺ efflux,\ncholesterol, ROS)" fillcolor="#2e7d32" fontcolor="white"]
  }

  // ============================================================
  // CLUSTER 3: NLRP3 Inflammasome
  // ============================================================
  subgraph cluster_nlrp3 {
    label="③ NLRP3 인플라마솜 / NLRP3 Inflammasome" style=filled fillcolor="#e3f2fd"
    fontname="Helvetica-Bold" fontsize=11 color="#1565c0"

    NLRP3      [label="NLRP3\n(LRR+NACHT+PYD sensor)" fillcolor="#90caf9"]
    NEK7       [label="NEK7\n(K⁺ efflux sensor,\nNLRP3 activator)" fillcolor="#90caf9"]
    ASC        [label="ASC Adaptor\n(PYD-CARD bridge)" fillcolor="#64b5f6"]
    ASC_SPECK  [label="ASC Speck\n(oligomerization,\nplatform assembly)" fillcolor="#42a5f5"]
    PRO_CASP1  [label="Pro-Caspase-1" fillcolor="#42a5f5"]
    ACT_CASP1  [label="Active Caspase-1\n(p10/p20 tetramer)" fillcolor="#1e88e5" fontcolor="white"]
    PRO_IL1B   [label="Pro-IL-1β (31 kDa)" fillcolor="#1565c0" fontcolor="white"]
    IL1B_MAT   [label="Mature IL-1β (17 kDa)\n★ Central disease driver" fillcolor="#0d47a1" fontcolor="white"]
    PRO_IL18   [label="Pro-IL-18" fillcolor="#1565c0" fontcolor="white"]
    IL18_MAT   [label="Mature IL-18 (18 kDa)\n(IFN-γ inducer)" fillcolor="#0d47a1" fontcolor="white"]
    GSDMD      [label="Gasdermin D\n(plasma membrane pore)" fillcolor="#64b5f6"]
    PYROPTOSIS [label="Pyroptosis\n(inflammatory cell death)" fillcolor="#e53935" fontcolor="white"]
    ROS_MITO   [label="Mitochondrial ROS\n(Signal 2 source)" fillcolor="#b0bec5"]
    POTASSIUM  [label="K⁺ Efflux\n(NLRP3 activation signal)" fillcolor="#b0bec5"]
  }

  // ============================================================
  // CLUSTER 4: NF-κB Signaling
  // ============================================================
  subgraph cluster_nfkb {
    label="④ NF-κB 신호전달 / NF-κB Pathway" style=filled fillcolor="#fce4ec"
    fontname="Helvetica-Bold" fontsize=11 color="#880e4f"

    IL1R1      [label="IL-1R1 / IL-1RAcP\n(co-receptor complex)" fillcolor="#f48fb1"]
    IRAK1_4    [label="IRAK1/4\n(Ser/Thr kinase)" fillcolor="#f06292"]
    TRAF6      [label="TRAF6\n(E3 ubiquitin ligase)" fillcolor="#ec407a"]
    TAK1       [label="TAK1 / MAP3K7\n(IKK activator)" fillcolor="#e91e63"]
    IKK_COMPLEX [label="IKK Complex\n(IKKα/IKKβ/NEMO)" fillcolor="#d81b60"]
    IKBA       [label="IκBα\n(phospho→ubiquitin→26S proteasome)" fillcolor="#f48fb1"]
    NFKB_P65   [label="NF-κB p65/p50\n(nuclear translocation)" fillcolor="#ad1457" fontcolor="white"]
    TNF        [label="TNF-α\n(pleiotropic pro-inflammatory)" fillcolor="#880e4f" fontcolor="white"]
    IL6        [label="IL-6\n(STAT3, acute phase)" fillcolor="#880e4f" fontcolor="white"]
    CXCL8      [label="CXCL8 / IL-8\n(neutrophil chemoattractant)" fillcolor="#c62828" fontcolor="white"]
    COX2_NF    [label="COX-2\n(NF-κB target gene)" fillcolor="#b71c1c" fontcolor="white"]
    IL1B_NF    [label="IL-1β gene\n(NF-κB → NLRP3 amplification)" fillcolor="#b71c1c" fontcolor="white"]
    ICAM1      [label="ICAM-1 / VCAM-1\n(adhesion molecules)" fillcolor="#d32f2f" fontcolor="white"]
    IL10       [label="IL-10\n(anti-inflammatory counter)" fillcolor="#ef9a9a"]
  }

  // ============================================================
  // CLUSTER 5: Innate Immune Cells
  // ============================================================
  subgraph cluster_innate {
    label="⑤ 선천면역세포 / Innate Immune Cells" style=filled fillcolor="#ede7f6"
    fontname="Helvetica-Bold" fontsize=11 color="#4527a0"

    PERI_MESO  [label="Pericardial Mesothelial Cells\n(NLRP3, IL-1β expression)" fillcolor="#ce93d8"]
    MACRO_RES  [label="Resident Pericardial\nMacrophages (M0)" fillcolor="#ba68c8"]
    M1_MACRO   [label="M1 Macrophages\n(IFN-γ / LPS activated)" fillcolor="#ab47bc"]
    M2_MACRO   [label="M2 Macrophages\n(IL-4/13; tissue repair)" fillcolor="#9c27b0"]
    NEUTRO     [label="Neutrophils\n(recruited; oxidative burst)" fillcolor="#7b1fa2" fontcolor="white"]
    NEUTRO_NET [label="NETs\n(Neutrophil Extracellular Traps)" fillcolor="#6a1b9a" fontcolor="white"]
    MAST       [label="Mast Cells\n(histamine, tryptase, LTC4)" fillcolor="#ba68c8"]
    MONO_CIRC  [label="Circulating Monocytes\n(CCR2⁺, differentiate to M1)" fillcolor="#ce93d8"]
    NK_CELL    [label="NK Cells\n(IFN-γ secretion)" fillcolor="#e1bee7"]
    DC_CELL    [label="Dendritic Cells\n(antigen presentation to T cells)" fillcolor="#e1bee7"]
    COMPLEMENT [label="Complement\n(C3a, C5a anaphylatoxins)" fillcolor="#d1c4e9"]
    ILC1       [label="ILC1\n(IFN-γ, innate helper)" fillcolor="#d1c4e9"]
  }

  // ============================================================
  // CLUSTER 6: Adaptive Immunity
  // ============================================================
  subgraph cluster_adaptive {
    label="⑥ 적응면역 / Adaptive Immunity" style=filled fillcolor="#e8eaf6"
    fontname="Helvetica-Bold" fontsize=11 color="#1a237e"

    CD4_TH1    [label="CD4⁺ Th1 Cells\n(IFN-γ, TNF-α)" fillcolor="#9fa8da"]
    CD4_TH17   [label="CD4⁺ Th17 Cells\n(IL-17A, IL-17F, IL-22)" fillcolor="#9fa8da"]
    CD8_CTL    [label="CD8⁺ CTL\n(perforin, granzyme B)" fillcolor="#7986cb"]
    TREG       [label="FoxP3⁺ Tregs\n(IL-10, TGF-β, tolerance)" fillcolor="#5c6bc0"]
    B_CELL     [label="B Cells\n(germinal center reaction)" fillcolor="#3949ab"]
    PLASMA_CELL [label="Plasma Cells\n(antibody secreting)" fillcolor="#283593" fontcolor="white"]
    ANA_AB     [label="Anti-Nuclear Ab\n(ANA, anti-dsDNA)" fillcolor="#1a237e" fontcolor="white"]
    ANTI_HEART [label="Anti-Heart Ab\n(anti-myosin, anti-tropomyosin,\nanti-sarcolemmal)" fillcolor="#1a237e" fontcolor="white"]
    IC         [label="Immune Complexes\n(pericardial deposition)" fillcolor="#283593" fontcolor="white"]
    MEMORY_T   [label="Memory T Cells\n(recurrence driver)" fillcolor="#3f51b5" fontcolor="white"]
    TFH        [label="T Follicular Helper\n(BCR somatic hypermutation)" fillcolor="#5c6bc0"]
    IFN_GAMMA  [label="IFN-γ\n(M1 polarization, Th1 amplify)" fillcolor="#7986cb"]
    IL17       [label="IL-17A\n(neutrophil mobilization)" fillcolor="#7986cb"]
  }

  // ============================================================
  // CLUSTER 7: Eicosanoid / Prostanoid Pathway
  // ============================================================
  subgraph cluster_eicosanoid {
    label="⑦ 에이코사노이드 경로 / Eicosanoid Pathway" style=filled fillcolor="#f1f8e9"
    fontname="Helvetica-Bold" fontsize=11 color="#33691e"

    PLA2       [label="cPLA2α\n(arachidonic acid release)" fillcolor="#dcedc8"]
    ARACH      [label="Arachidonic Acid (20:4 n-6)" fillcolor="#c5e1a5"]
    COX1       [label="COX-1\n(constitutive; gastric/platelet)" fillcolor="#aed581"]
    COX2       [label="COX-2\n(inducible; NF-κB target)" fillcolor="#9ccc65"]
    PGH2       [label="PGH2\n(prostaglandin endoperoxide)" fillcolor="#8bc34a"]
    PGE2       [label="PGE2\n(pyrexia, pain, vasodilation)" fillcolor="#7cb342"]
    PGI2       [label="PGI2 / Prostacyclin\n(vascular protection)" fillcolor="#689f38"]
    TXA2       [label="TXA2 / Thromboxane\n(platelet aggregation)" fillcolor="#558b2f"]
    LOX5       [label="5-LOX\n(leukotriene synthesis)" fillcolor="#aed581"]
    LTB4       [label="LTB4\n(potent neutrophil chemoattractant)" fillcolor="#8bc34a"]
    LTC4D4     [label="LTC4 / LTD4 / LTE4\n(vascular permeability↑)" fillcolor="#7cb342"]
    FEVER      [label="Fever / Pyrexia\n(PGE2 on EP3-hypothalamus)" fillcolor="#dcedc8"]
  }

  // ============================================================
  // CLUSTER 8: Pericardial Pathology
  // ============================================================
  subgraph cluster_pericardial {
    label="⑧ 심낭 병리 / Pericardial Pathology" style=filled fillcolor="#fff3e0"
    fontname="Helvetica-Bold" fontsize=11 color="#e65100"

    PERI_INFLAM   [label="Pericardial Inflammation\n(mesothelial injury, friction rub)" fillcolor="#ffcc80"]
    FIBRIN_DEP    [label="Fibrin Deposition\n(thrombin-activated polymerization)" fillcolor="#ffb74d"]
    PERI_EFF      [label="Pericardial Effusion\n(mL; >250 mL clinically significant)" fillcolor="#ffa726"]
    CARDIAC_TAMP  [label="Cardiac Tamponade\n(pulsus paradoxus, Beck's triad,\nemergent pericardiocentesis)" fillcolor="#ef6c00" fontcolor="white"]
    TGF_BETA      [label="TGF-β1\n(fibrosis master regulator)" fillcolor="#ff8f00"]
    FIBRO_ACT     [label="Pericardial Fibroblast\nActivation" fillcolor="#ffa000"]
    MYOFIBRO      [label="Myofibroblasts\n(α-SMA⁺, collagen producers)" fillcolor="#ff8f00"]
    COL_DEP       [label="Collagen I / III\nDeposition (ECM remodeling)" fillcolor="#e65100" fontcolor="white"]
    PERI_THICK    [label="Pericardial Thickening\n(>4 mm by CT/CMR)" fillcolor="#bf360c" fontcolor="white"]
    CONST_PERI    [label="Constrictive Pericarditis\n(diastolic failure, equalization\nof diastolic pressures)" fillcolor="#bf360c" fontcolor="white"]
    EFFUSIVE_CONST [label="Effusive-Constrictive\nPericarditis" fillcolor="#d84315" fontcolor="white"]
    PERICARDIOSC  [label="Pericardiosclerosis\n(calcification, shell heart)" fillcolor="#6d4c41" fontcolor="white"]
    BRADYKININ    [label="Bradykinin / Kallikrein\n(pain sensitization)" fillcolor="#ffcc80"]
    SUBSTANCEP    [label="Substance P / CGRP\n(neurogenic inflammation)" fillcolor="#ffe0b2"]
  }

  // ============================================================
  // CLUSTER 9: Clinical Biomarkers
  // ============================================================
  subgraph cluster_biomarkers {
    label="⑨ 임상 바이오마커 / Clinical Biomarkers" style=filled fillcolor="#e0f7fa"
    fontname="Helvetica-Bold" fontsize=11 color="#006064"

    CRP        [label="CRP (mg/L)\n(>3mg/L high recurrence risk)" fillcolor="#80deea"]
    ESR        [label="ESR (mm/h)" fillcolor="#80deea"]
    WBC        [label="WBC Count (×10⁹/L)" fillcolor="#80deea"]
    NEUTRO_PCT [label="Neutrophil %\n(shift to left)" fillcolor="#4dd0e1"]
    TROPONIN   [label="Troponin I/T\n(myopericarditis marker)" fillcolor="#26c6da"]
    BNP_NT     [label="BNP / NT-proBNP\n(cardiac stress, tamponade)" fillcolor="#00bcd4"]
    ECG_CHANGE [label="ECG Changes\n(PR depression, concave ST↑,\nelectrical alternans)" fillcolor="#00acc1"]
    ECHO_EFF   [label="Echo: Effusion Assessment\n(rim, swinging heart, IVC)" fillcolor="#0097a7"]
    CT_THICK   [label="CT/CMR: Pericardial\nThickening & LGE Enhancement" fillcolor="#00838f"]
    PAIN_VAS   [label="Chest Pain VAS (0-10)\n(sharp, pleuritic, positional)" fillcolor="#006064" fontcolor="white"]
    PLEURITIS  [label="Pleuritis /\nPleuropericarditis Sign" fillcolor="#4dd0e1"]
    IL1B_SERUM [label="Serum IL-1β\n(elevated in autoinflammatory RP)" fillcolor="#26c6da"]
  }

  // ============================================================
  // CLUSTER 10: Colchicine PK/PD
  // ============================================================
  subgraph cluster_colchicine {
    label="⑩ 콜히친 PK/PD / Colchicine PK/PD (COPE · ICAP · CORP trials)" style=filled fillcolor="#f9fbe7"
    fontname="Helvetica-Bold" fontsize=11 color="#827717"

    COLCH_DOSE   [label="Colchicine Dose\n(0.5 mg BID ×3 months)" fillcolor="#f0f4c3" shape=component]
    COLCH_GUT    [label="Colchicine Gut\n(Ka=0.8 h⁻¹, F=45%)" fillcolor="#e6ee9c"]
    COLCH_CENT   [label="Colchicine Central\n(Vd=450 L, CL=18 L/h)" fillcolor="#dce775"]
    COLCH_PERI   [label="Colchicine Peripheral\n(deep tissue distribution)" fillcolor="#d4e157"]
    COLCH_TUBULIN [label="β-Tubulin Binding\n(Cys239 / Cys354)\n→ colchicine-binding domain" fillcolor="#c0ca33"]
    COLCH_NLRP3  [label="NLRP3 Inhibition\n(↓ASC oligomerization,\n↓microtubule-mediated assembly)" fillcolor="#afb42b"]
    COLCH_NEUTRO [label="Neutrophil Migration↓\n(cytoskeleton disruption,\nL-selectin shedding)" fillcolor="#9e9d24"]
    COLCH_L_SEL  [label="Adhesion Molecule\nShedding↓ (L-selectin, ICAM)" fillcolor="#827717" fontcolor="white"]
    COLCH_PKPD   [label="Colchicine PK/PD\n(Emax, IC50=0.5 ng/mL)\n50% recurrence reduction" fillcolor="#827717" fontcolor="white"]
  }

  // ============================================================
  // CLUSTER 11: NSAID PK/PD
  // ============================================================
  subgraph cluster_nsaid {
    label="⑪ NSAIDs PK/PD (Ibuprofen / Aspirin)" style=filled fillcolor="#fafafa"
    fontname="Helvetica-Bold" fontsize=11 color="#37474f"

    NSAID_DOSE  [label="NSAID Dose\n(Ibuprofen 600 mg TID\nor Aspirin 750 mg TID)" fillcolor="#eceff1" shape=component]
    NSAID_GUT   [label="NSAID Gut\n(Ka=1.2 h⁻¹, F=87%)" fillcolor="#cfd8dc"]
    NSAID_CENT  [label="NSAID Central\n(Vd=15 L, CL=2.5 L/h)" fillcolor="#b0bec5"]
    NSAID_COX1  [label="COX-1 Inhibition\n(IC50=5 μM ibuprofen)" fillcolor="#90a4ae"]
    NSAID_COX2  [label="COX-2 Inhibition\n(IC50=15 μM ibuprofen)" fillcolor="#78909c"]
    PGE2_REDUC  [label="PGE2 Reduction\n(↓fever, ↓pain sensitization,\n↓vascular permeability)" fillcolor="#607d8b" fontcolor="white"]
    NSAID_PAIN  [label="Analgesic Effect\n(EP1/EP2/EP3/EP4 blockade)" fillcolor="#546e7a" fontcolor="white"]
    NSAID_ADR   [label="NSAID Adverse Effects\n(GI: PGE2↓ gastric mucosa;\nRenal: PGI2↓; CV risk)" fillcolor="#455a64" fontcolor="white"]
  }

  // ============================================================
  // CLUSTER 12: Corticosteroid PK/PD
  // ============================================================
  subgraph cluster_corticosteroid {
    label="⑫ 코르티코스테로이드 PK/PD / Corticosteroid PK/PD" style=filled fillcolor="#fff8f0"
    fontname="Helvetica-Bold" fontsize=11 color="#bf360c"

    CS_DOSE      [label="Prednisone 0.5 mg/kg/d ×2-4 wk\n→ Slow Taper (≥3 months)" fillcolor="#ffe0b2" shape=component]
    CS_GUT       [label="Prednisone Gut\n(Ka=1.0 h⁻¹, F=82%)" fillcolor="#ffccbc"]
    CS_CENT      [label="Prednisone → Prednisolone\n(Vd=50 L, CL=8 L/h)" fillcolor="#ffab91"]
    CS_GR        [label="GRα (Glucocorticoid Receptor)\n(cytoplasmic, Hsp90 complex)" fillcolor="#ff8a65"]
    CS_GR_NUC    [label="GR-GC Nuclear Complex\n(DNA-binding, transrepression)" fillcolor="#f4511e"]
    CS_NFKB      [label="NF-κB Transrepression\n(GRα ↔ p65 direct interaction)" fillcolor="#e64a19"]
    CS_MKPHOS    [label="MKP-1↑\n(MAPK phosphatase anti-inflam.)" fillcolor="#bf360c" fontcolor="white"]
    CS_IL1_SUP   [label="IL-1β / TNF-α\nGene Suppression" fillcolor="#bf360c" fontcolor="white"]
    CS_TAPER     [label="Corticosteroid Taper Protocol\n(rapid taper → rebound pericarditis\nwhen CRP not normalized)" fillcolor="#8d6e63"]
    CS_ADR       [label="Steroid ADR\n(Cushing's, osteoporosis,\nhyperglycemia, infection risk)" fillcolor="#795548" fontcolor="white"]
  }

  // ============================================================
  // CLUSTER 13: Biologic Therapy PK/PD (Anakinra / Rilonacept)
  // ============================================================
  subgraph cluster_biologics {
    label="⑬ 생물학적 제제 PK/PD / IL-1 Blocker PK/PD (Anakinra · Rilonacept)" style=filled fillcolor="#e8f5e9"
    fontname="Helvetica-Bold" fontsize=11 color="#1b5e20"

    ANA_DOSE    [label="Anakinra 100 mg/d SC\n(AIRTRIP trial; IL-1Ra)" fillcolor="#e8f5e9" shape=component]
    ANA_SC      [label="Anakinra SC Depot\n(Ka=0.5 h⁻¹, F=95%)" fillcolor="#c8e6c9"]
    ANA_CENT    [label="Anakinra Central\n(Vd=6 L, CL=1.2 L/h, t½≈4-6 h)" fillcolor="#a5d6a7"]
    ANA_IL1R1   [label="IL-1R1 Competitive Blockade\n(IC50≈0.1 nM; recombinant IL-1Ra)" fillcolor="#81c784"]
    RILO_DOSE   [label="Rilonacept 320 mg SC ×1\n→ 160 mg SC qw\n(RHAPSODY; FDA 2021)" fillcolor="#e8f5e9" shape=component]
    RILO_SC     [label="Rilonacept SC Depot\n(Ka=0.04 h⁻¹, slow absorption)" fillcolor="#c8e6c9"]
    RILO_CENT   [label="Rilonacept Central\n(Vd=4 L, CL=0.015 L/h, t½≈8.6 d)" fillcolor="#a5d6a7"]
    RILO_TRAP   [label="IL-1 Trap\n(IL-1R1/IL-1RAcP fusion;\nKD<1 pM for IL-1β)" fillcolor="#66bb6a"]
    IL1_NEUTRAL [label="Circulating IL-1β/α\nNeutralization" fillcolor="#43a047"]
    BIO_EFFECT  [label="Downstream IL-1 Blockade\n(↓NLRP3 loop, ↓recurrence,\n↓CRP, ↓effusion)" fillcolor="#388e3c" fontcolor="white"]
  }

  // ============================================================
  // CLUSTER 14: Clinical Outcomes
  // ============================================================
  subgraph cluster_outcomes {
    label="⑭ 임상 결과 / Clinical Outcomes" style=filled fillcolor="#e8eaf6"
    fontname="Helvetica-Bold" fontsize=11 color="#1a237e"

    RECURRENCE    [label="Pericarditis Recurrence\n(30-50% untreated;\n15-20% w/ colchicine)" fillcolor="#9fa8da"]
    TIME_RECURR   [label="Time to First\nRecurrence (months)" fillcolor="#7986cb"]
    PERI_PAIN_CTRL [label="Pain Control Rate\n(% achieving VAS ≤1)" fillcolor="#5c6bc0" fontcolor="white"]
    EFFUSION_RESOL [label="Effusion Resolution\n(echo follow-up)" fillcolor="#3949ab" fontcolor="white"]
    CRP_NORM      [label="CRP Normalization\n(≤3 mg/L at 1 week\n= favourable prognosis)" fillcolor="#283593" fontcolor="white"]
    HOSPITALIZATION [label="Hospitalization Rate\n& Duration (days)" fillcolor="#1a237e" fontcolor="white"]
    CONST_DEV     [label="Constrictive Pericarditis\nDevelopment (<1%)" fillcolor="#0d47a1" fontcolor="white"]
    PERICARD_WIND [label="Pericardiocentesis /\nPericardial Window /\nPericardiectomy" fillcolor="#1565c0" fontcolor="white"]
    STEROID_DEPEND [label="Corticosteroid\nDependence Rate (%)" fillcolor="#1976d2" fontcolor="white"]
    QOL           [label="Quality of Life\n(SF-36, MDHAQ, EQ-5D)" fillcolor="#1e88e5" fontcolor="white"]
    MORTALITY     [label="Mortality\n(rare; mainly tamponade)" fillcolor="#e53935" fontcolor="white"]
    WORK_IMPAIR   [label="Work Impairment &\nActivity Limitation" fillcolor="#42a5f5"]
  }

  // ============================================================
  // INTER-CLUSTER EDGES
  // ============================================================

  // --- Etiology → Sensing ---
  VIR -> PAMP [label="viral PAMPs" color="#558b2f"]
  VIR -> DAMP [label="cell damage" color="#558b2f"]
  SARS2 -> PAMP [color="#558b2f"]
  SARS2 -> DAMP [color="#558b2f"]
  PCIS -> DAMP [label="cardiac DAMPs\n(HMGB1, myosin)" color="#558b2f"]
  TRAUMA -> DAMP [color="#558b2f"]
  BACT -> PAMP [color="#558b2f"]
  AUTOI -> NLRP3 [label="IL-1β/NLRP3 loop\n(autoinflammatory)" color="#1565c0" style=dashed]
