digraph AS_QSP_Model {
    rankdir=TB;
    graph [fontname="Helvetica", fontsize=11, splines=true, overlap=false,
           label="Calcific Aortic Valve Stenosis (CAVD)\nComprehensive QSP Mechanistic Map\nIncluding Valve Calcification · LV Remodeling · Hemodynamics · Drug PK/PD",
           labelloc=t, labeljust=c, bgcolor="#F8F9FA"];
    node [fontname="Helvetica", fontsize=9, style=filled, margin="0.1,0.05"];
    edge [fontname="Helvetica", fontsize=8, arrowsize=0.7];

    // ============================================================
    // SUBGRAPH 1: Risk Factors & Initiating Stimuli
    // ============================================================
    subgraph cluster_risk {
        label="Risk Factors & Initiating Stimuli";
        style=filled; fillcolor="#FFF3E0"; color="#E65100"; penwidth=2;
        fontsize=10; fontcolor="#E65100";

        RF_age [label="Age (>65y)\nSenescence", shape=ellipse, fillcolor="#FFCC80"];
        RF_male [label="Male Sex\n(Testosterone)", shape=ellipse, fillcolor="#FFCC80"];
        RF_smoking [label="Smoking\nOxidative Stress", shape=ellipse, fillcolor="#FFCC80"];
        RF_HTN [label="Hypertension\nMechanical Stress", shape=ellipse, fillcolor="#FFCC80"];
        RF_chol [label="Hypercholesterolemia\nLDL/oxLDL", shape=ellipse, fillcolor="#FFCC80"];
        RF_DM [label="Diabetes Mellitus\nAGEs / Insulin-R", shape=ellipse, fillcolor="#FFCC80"];
        RF_CKD [label="Chronic Kidney Disease\nPhosphate Retention", shape=ellipse, fillcolor="#FFCC80"];
        RF_bicuspid [label="Bicuspid Aortic Valve\n(BAV) Congenital", shape=diamond, fillcolor="#FFB74D"];
        RF_genetics [label="Genetic Risk\n(NOTCH1, LPA locus)", shape=diamond, fillcolor="#FFB74D"];
        RF_LPA [label="Lipoprotein(a) [Lp(a)]\nOxidized Phospholipids", shape=ellipse, fillcolor="#FF8F00"];
        RF_obesity [label="Obesity\n(Metabolic Syndrome)", shape=ellipse, fillcolor="#FFCC80"];
        RF_calcium [label="Calcium/Phosphate\nDisequilibrium", shape=ellipse, fillcolor="#FFCC80"];
    }

    // ============================================================
    // SUBGRAPH 2: Valve Endothelium & Initiating Lesion
    // ============================================================
    subgraph cluster_endothelium {
        label="Valve Endothelium & Initiating Injury";
        style=filled; fillcolor="#E8F5E9"; color="#2E7D32"; penwidth=2;
        fontsize=10; fontcolor="#2E7D32";

        VEC_injury [label="VEC Injury\nEndothelial Dysfunction", shape=box, fillcolor="#A5D6A7"];
        oxLDL_infiltration [label="oxLDL Infiltration\nSub-Endothelial", shape=box, fillcolor="#A5D6A7"];
        lipoprotein_deposition [label="Lipoprotein Deposition\n(Lp(a), ApoB)", shape=box, fillcolor="#A5D6A7"];
        shear_stress [label="Low/Turbulent\nShear Stress", shape=ellipse, fillcolor="#C8E6C9"];
        VEC_activation [label="VEC Activation\n(NF-κB, ICAM-1, VCAM-1)", shape=box, fillcolor="#81C784"];
        eNOS_down [label="↓ eNOS / ↓ NO\nProduction", shape=box, fillcolor="#A5D6A7"];
        ROS_production [label="ROS / Oxidative Stress\n(NADPH oxidase, LOX-1)", shape=box, fillcolor="#A5D6A7"];
        BMP_signaling [label="BMP-2/4 Signaling\n(Osteogenic Induction)", shape=box, fillcolor="#66BB6A"];
        NOTCH1_loss [label="NOTCH1 Signaling\nLoss of Function", shape=box, fillcolor="#66BB6A"];
        TGFb_activation [label="TGF-β1 Activation\nFibrogenic Signaling", shape=box, fillcolor="#81C784"];
    }

    // ============================================================
    // SUBGRAPH 3: Inflammation & Immune Pathways
    // ============================================================
    subgraph cluster_inflammation {
        label="Inflammation & Immune Pathways";
        style=filled; fillcolor="#FFEBEE"; color="#C62828"; penwidth=2;
        fontsize=10; fontcolor="#C62828";

        macrophage_infiltration [label="Macrophage Infiltration\n(M1 polarization)", shape=box, fillcolor="#FFCDD2"];
        monocyte_recruit [label="Monocyte Recruitment\n(MCP-1, CCR2)", shape=box, fillcolor="#FFCDD2"];
        Tcell_infiltration [label="T-cell Infiltration\n(CD4+, CD8+)", shape=box, fillcolor="#FFCDD2"];
        mast_cells [label="Mast Cell Activation\n(Chymase, Tryptase)", shape=box, fillcolor="#FFCDD2"];
        foam_cells [label="Foam Cell Formation\n(Lipid-laden Macrophage)", shape=box, fillcolor="#EF9A9A"];
        IL1b [label="IL-1β Secretion\n(Inflammasome/NLRP3)", shape=ellipse, fillcolor="#EF9A9A"];
        IL6 [label="IL-6 ↑\n(Acute Phase)", shape=ellipse, fillcolor="#EF9A9A"];
        TNFa [label="TNF-α\n(Proinflammatory)", shape=ellipse, fillcolor="#EF9A9A"];
        IL8 [label="IL-8 / CXCL8\n(Neutrophil Chemoattract)", shape=ellipse, fillcolor="#FFCDD2"];
        CRP [label="CRP / hsCRP\n(Acute Phase Protein)", shape=ellipse, fillcolor="#EF9A9A"];
        MMPs [label="MMP-2/-9\n(Matrix Degradation)", shape=box, fillcolor="#FFCDD2"];
        cathepsins [label="Cathepsin B/D/K\n(Elastin Degradation)", shape=box, fillcolor="#FFCDD2"];
        complement [label="Complement Activation\n(C3, C5b-9)", shape=box, fillcolor="#FFCDD2"];
    }

    // ============================================================
    // SUBGRAPH 4: Valve Interstitial Cell Osteogenic Transformation
    // ============================================================
    subgraph cluster_VIC {
        label="Valve Interstitial Cell (VIC) Osteogenic Transformation";
        style=filled; fillcolor="#E3F2FD"; color="#1565C0"; penwidth=2;
        fontsize=10; fontcolor="#1565C0";

        VIC_quiescent [label="Quiescent VIC\n(fibroblast-like)", shape=box, fillcolor="#BBDEFB"];
        VIC_myofibroblast [label="Activated Myofibroblast\nVIC (aVIC)", shape=box, fillcolor="#90CAF9"];
        VIC_osteoblast [label="Osteoblast-like VIC\n(OblVIC)", shape=box, fillcolor="#64B5F6"];
        RANKL_expr [label="RANKL Expression\n(VIC-derived)", shape=ellipse, fillcolor="#90CAF9"];
        OPG_expr [label="OPG Expression\n(Protective)", shape=ellipse, fillcolor="#BBDEFB"];
        RANKL_OPG_ratio [label="RANKL/OPG Ratio\n(Key Driver)", shape=diamond, fillcolor="#42A5F5"];
        Runx2_expr [label="Runx2/Cbfa1\n(Master Osteogenic TF)", shape=ellipse, fillcolor="#64B5F6"];
        Osterix_expr [label="Osterix (Sp7)\n(Osteoblast Diff.)", shape=ellipse, fillcolor="#90CAF9"];
        Wnt_Lrp5 [label="Wnt/β-catenin/LRP5\nPathway Activation", shape=box, fillcolor="#64B5F6"];
        ALP_expr [label="Alkaline Phosphatase (ALP)\n(Matrix Mineralization)", shape=ellipse, fillcolor="#42A5F5"];
        osteocalcin [label="Osteocalcin (OCN)\n(Osteogenic Marker)", shape=ellipse, fillcolor="#90CAF9"];
        osteopontin [label="Osteopontin (OPN)\n(Calcification Regulator)", shape=ellipse, fillcolor="#90CAF9"];
        MGP [label="Matrix Gla Protein (MGP)\n(Anti-calcification)", shape=ellipse, fillcolor="#BBDEFB"];
        fetuin_A [label="Fetuin-A\n(Circulating Inhibitor)", shape=ellipse, fillcolor="#BBDEFB"];
        inorganic_phosphate [label="Inorganic Phosphate (Pi)\n(Pit1/Pit2 Transporter)", shape=ellipse, fillcolor="#42A5F5"];
        annexins [label="Annexins / Matrix Vesicles\n(Nucleation Sites)", shape=box, fillcolor="#64B5F6"];
    }

    // ============================================================
    // SUBGRAPH 5: Valve Calcification Progression
    // ============================================================
    subgraph cluster_calcification {
        label="Valve Calcification Progression";
        style=filled; fillcolor="#F3E5F5"; color="#6A1B9A"; penwidth=2;
        fontsize=10; fontcolor="#6A1B9A";

        early_lesion [label="Early Lesion\n(Lipid, Inflammation)", shape=box, fillcolor="#E1BEE7"];
        fibrosis_nodule [label="Fibrous Thickening\n(Collagen Deposition)", shape=box, fillcolor="#CE93D8"];
        microcalc [label="Microcalcification\n(Hydroxyapatite Seeds)", shape=box, fillcolor="#BA68C8"];
        macrocalc [label="Macrocalcification\n(Leaflet Stiffening)", shape=box, fillcolor="#AB47BC"];
        calcium_score [label="Valve Calcium Score\n(CT Agatston/AU)", shape=diamond, fillcolor="#9C27B0"];
        AVA_reduction [label="↓ Aortic Valve Area\n(AVA, cm²)", shape=diamond, fillcolor="#7B1FA2"];
        leaflet_mobility [label="↓ Leaflet Mobility\n(Calcification Score)", shape=box, fillcolor="#CE93D8"];
        valve_sclerosis [label="Aortic Sclerosis\nAS precursor", shape=box, fillcolor="#E1BEE7"];
    }

    // ============================================================
    // SUBGRAPH 6: Hemodynamic Consequences
    // ============================================================
    subgraph cluster_hemodynamics {
        label="Hemodynamic Consequences";
        style=filled; fillcolor="#FFF8E1"; color="#F57F17"; penwidth=2;
        fontsize=10; fontcolor="#F57F17";

        mean_gradient [label="Mean Pressure Gradient\n(ΔP, mmHg)", shape=diamond, fillcolor="#FFE082"];
        peak_velocity [label="Peak Aortic Velocity\n(Vmax, m/s)", shape=diamond, fillcolor="#FFD54F"];
        stroke_volume [label="Stroke Volume (SV)\n(mL/beat)", shape=diamond, fillcolor="#FFE082"];
        cardiac_output [label="Cardiac Output (CO)\n(L/min)", shape=diamond, fillcolor="#FFD54F"];
        SVR [label="Systemic Vascular Resistance\n(SVR, dyn·s/cm⁵)", shape=ellipse, fillcolor="#FFE082"];
        afterload_increase [label="↑ LV Afterload\n(Wall Stress)", shape=box, fillcolor="#FFB300"];
        pulse_pressure [label="Pulse Pressure\n(↓ in severe AS)", shape=ellipse, fillcolor="#FFE082"];
        LVSP [label="LV Systolic Pressure\n(LVSP, mmHg)", shape=ellipse, fillcolor="#FFB300"];
        valvuloarterial_impedance [label="Valvuloarterial Impedance\n(Zva)", shape=ellipse, fillcolor="#FFE082"];
        energy_loss [label="Energy Loss Coefficient\n(ELCo, cm²)", shape=ellipse, fillcolor="#FFE082"];
        continuity_eq [label="Continuity Equation\n(AVA = LVOT × VTI_LVOT/VTI_AV)", shape=box, fillcolor="#FFD54F"];
    }

    // ============================================================
    // SUBGRAPH 7: LV Remodeling & Adaptive/Maladaptive Changes
    // ============================================================
    subgraph cluster_LV {
        label="LV Remodeling (Adaptive → Maladaptive)";
        style=filled; fillcolor="#E8EAF6"; color="#283593"; penwidth=2;
        fontsize=10; fontcolor="#283593";

        LV_hypertrophy [label="Concentric LV Hypertrophy\n(LV Mass Index ↑)", shape=box, fillcolor="#C5CAE9"];
        cardiomyocyte_hypertrophy [label="Cardiomyocyte Hypertrophy\n(Volume, Length ↑)", shape=box, fillcolor="#9FA8DA"];
        LV_fibrosis [label="Myocardial Fibrosis\n(Collagen I/III Ratio)", shape=box, fillcolor="#9FA8DA"];
        interstitial_fibrosis [label="Interstitial Fibrosis\n(Diffuse)", shape=box, fillcolor="#C5CAE9"];
        replacement_fibrosis [label="Replacement Fibrosis\n(Post-necrotic)", shape=box, fillcolor="#9FA8DA"];
        LVEDP_rise [label="↑ LVEDP\n(Diastolic Dysfunction)", shape=ellipse, fillcolor="#7986CB"];
        LVEF [label="LVEF (%)\nSystolic Function", shape=diamond, fillcolor="#5C6BC0"];
        LV_EDV [label="LV End-Diastolic Volume\n(EDV, mL)", shape=ellipse, fillcolor="#9FA8DA"];
        LV_ESV [label="LV End-Systolic Volume\n(ESV, mL)", shape=ellipse, fillcolor="#9FA8DA"];
        LVOT_velocity [label="LVOT Velocity\n(m/s, Doppler)", shape=ellipse, fillcolor="#C5CAE9"];
        E_A_ratio [label="E/A Ratio\n(Diastolic Grade)", shape=ellipse, fillcolor="#C5CAE9"];
        GLS [label="Global Longitudinal Strain\n(GLS, %)", shape=ellipse, fillcolor="#9FA8DA"];
        coronary_flow [label="Coronary Flow Reserve\n(CFR ↓ in severe AS)", shape=ellipse, fillcolor="#9FA8DA"];
        RAAS_cardiac [label="Cardiac RAAS Activation\n(ACE, Ang-II, AT1R)", shape=box, fillcolor="#7986CB"];
        sympathetic_act [label="Sympathetic Activation\n(NE ↑, β1-AR)", shape=box, fillcolor="#9FA8DA"];
    }

    // ============================================================
    // SUBGRAPH 8: Biomarkers & Clinical Endpoints
    // ============================================================
    subgraph cluster_biomarkers {
        label="Biomarkers & Clinical Endpoints";
        style=filled; fillcolor="#E0F7FA"; color="#00695C"; penwidth=2;
        fontsize=10; fontcolor="#00695C";

        BNP [label="BNP / NT-proBNP\n(Neurohormonal Marker)", shape=ellipse, fillcolor="#B2EBF2"];
        Troponin [label="Troponin T/I (hs)\n(Myocardial Injury)", shape=ellipse, fillcolor="#B2EBF2"];
        GDF15 [label="GDF-15\n(Stress Marker)", shape=ellipse, fillcolor="#B2EBF2"];
        Galectin3 [label="Galectin-3\n(Fibrosis Marker)", shape=ellipse, fillcolor="#B2EBF2"];
        PICP_PIIINP [label="PICP / PIIINP\n(Collagen Synthesis)", shape=ellipse, fillcolor="#B2EBF2"];
        CICP [label="CITP\n(Collagen Degradation)", shape=ellipse, fillcolor="#B2EBF2"];
        OPG_serum [label="Serum OPG\n(Bone Metabolism)", shape=ellipse, fillcolor="#B2EBF2"];
        LPA_serum [label="Serum Lp(a)\n(Cardiovascular Risk)", shape=ellipse, fillcolor="#B2EBF2"];
        NYHA_class [label="NYHA Functional Class\n(I–IV)", shape=diamond, fillcolor="#4DB6AC"];
        Symptom_angina [label="Exertional Angina\n(Coronary Steal)", shape=box, fillcolor="#80CBC4"];
        Symptom_syncope [label="Syncope / Pre-syncope\n(Reduced CO)", shape=box, fillcolor="#80CBC4"];
        Symptom_dyspnea [label="Exertional Dyspnea\n(↑ LVEDP, ↓ CO)", shape=box, fillcolor="#80CBC4"];
        six_mwd [label="6-Minute Walk Distance\n(6MWD, m)", shape=ellipse, fillcolor="#B2EBF2"];
        exercise_capacity [label="Exercise Capacity\n(VO₂ max, METs)", shape=ellipse, fillcolor="#B2EBF2"];
        survival [label="Survival / Event-Free\nSurvival (2-yr, 5-yr)", shape=diamond, fillcolor="#00897B"];
        MACE [label="MACE\n(Death, MI, Stroke)", shape=diamond, fillcolor="#00695C", fontcolor=white];
        AS_severity_grade [label="AS Severity Grade\n(Mild/Moderate/Severe)", shape=diamond, fillcolor="#4DB6AC"];
    }

    // ============================================================
    // SUBGRAPH 9: Drug PK — Statin & PCSK9 Inhibitor
    // ============================================================
    subgraph cluster_PK_statin {
        label="Drug PK: Statins & Lipid-lowering Agents";
        style=filled; fillcolor="#FCE4EC"; color="#880E4F"; penwidth=2;
        fontsize=10; fontcolor="#880E4F";

        statin_dose [label="Statin Dose\n(Rosuvastatin/Atorvastatin)", shape=parallelogram, fillcolor="#F48FB1"];
        statin_gut [label="Statin: GI Absorption\n(F ≈ 20%, first-pass)", shape=box, fillcolor="#F48FB1"];
        statin_central [label="Statin: Central/Plasma\nCp (ng/mL)", shape=box, fillcolor="#F06292"];
        statin_liver [label="Statin: Hepatic Conc.\n(Target Organ)", shape=box, fillcolor="#EC407A"];
        statin_elim [label="Statin: Elimination\n(CYP3A4/2C9, t½)", shape=box, fillcolor="#F48FB1"];
        PCSK9i_dose [label="PCSK9i Dose\n(Evolocumab 140mg Q2W)", shape=parallelogram, fillcolor="#F48FB1"];
        PCSK9i_central [label="PCSK9i: Plasma Conc.\n(Cp, μg/mL)", shape=box, fillcolor="#F06292"];
        PCSK9i_elim [label="PCSK9i: Elimination\n(Proteolytic, t½≈11d)", shape=box, fillcolor="#F48FB1"];
        denosumab_dose [label="Denosumab Dose\n(Anti-RANKL, 60mg Q6M)", shape=parallelogram, fillcolor="#F48FB1"];
        denosumab_central [label="Denosumab: Plasma\n(Cp, μg/mL)", shape=box, fillcolor="#F06292"];
        denosumab_effect_site [label="Denosumab: Tissue\nEffect Site", shape=box, fillcolor="#EC407A"];
    }

    // ============================================================
    // SUBGRAPH 10: Drug PD — Pharmacodynamic Effects
    // ============================================================
    subgraph cluster_PD {
        label="Drug Pharmacodynamic Effects";
        style=filled; fillcolor="#F9FBE7"; color="#558B2F"; penwidth=2;
        fontsize=10; fontcolor="#558B2F";

        statin_LDL [label="↓ LDL-C / oxLDL\n(HMG-CoA Inhibition)", shape=box, fillcolor="#DCEDC8"];
        statin_pleiotropic [label="Statin Pleiotropic Effects\n(Anti-inflammatory, ↑ eNOS)", shape=box, fillcolor="#C5E1A5"];
        statin_ALP_effect [label="↓ ALP Activity\n(Statin → ↓ Osteogenesis?)", shape=box, fillcolor="#AED581"];
        statin_RANKL_effect [label="↓ RANKL Expression\n(Mevalonate Pathway)", shape=box, fillcolor="#AED581"];
        PCSK9i_LDL [label="↓ PCSK9\n↑ LDL-R Recycling → ↓↓ LDL-C", shape=box, fillcolor="#C5E1A5"];
        PCSK9i_LPA [label="Modest ↓ Lp(a)\n(~25-30% reduction)", shape=box, fillcolor="#AED581"];
        denosumab_RANKL_block [label="Denosumab: RANKL Blockade\n(↓ Osteoclastogenesis-like)", shape=box, fillcolor="#C5E1A5"];
        denosumab_calcification [label="↓ Valve Calcification?\n(Hypothesis: RANKL in VIC)", shape=box, fillcolor="#8BC34A"];
        bisphosphonate_HAP [label="Bisphosphonate\n(Bind Hydroxyapatite, ↓ Resorption)", shape=box, fillcolor="#DCEDC8"];
        VK2_MGP [label="Vitamin K2 (MK-7)\n(Activate MGP → ↓ Calcification)", shape=box, fillcolor="#C5E1A5"];
        ACEi_ARB_effect [label="ACEi/ARB\n(↓ Ang-II, ↓ Fibrosis, BP Control)", shape=box, fillcolor="#AED581"];
        diuretic_effect [label="Diuretics\n(↓ Preload, Symptom Relief)", shape=box, fillcolor="#DCEDC8"];
        beta_blocker_effect [label="β-Blocker\n(↑ Diastolic Filling Time)", shape=box, fillcolor="#DCEDC8"];
    }

    // ============================================================
    // SUBGRAPH 11: Interventional Procedures
    // ============================================================
    subgraph cluster_intervention {
        label="Interventional Procedures (TAVR/SAVR)";
        style=filled; fillcolor="#EFEBE9"; color="#4E342E"; penwidth=2;
        fontsize=10; fontcolor="#4E342E";

        TAVR [label="TAVR\n(Transcatheter AVR)", shape=box, fillcolor="#D7CCC8"];
        SAVR [label="SAVR\n(Surgical AVR)", shape=box, fillcolor="#D7CCC8"];
        TAVR_AVA_restore [label="Post-TAVR AVA\n(≥1.5 cm², Restored)", shape=box, fillcolor="#BCAAA4"];
        post_intervention_gradient [label="Post-Intervention\n↓ Mean Gradient (<20 mmHg)", shape=box, fillcolor="#BCAAA4"];
        paravalvular_leak [label="Paravalvular Leak\n(TAVR Complication)", shape=ellipse, fillcolor="#D7CCC8"];
        stroke_risk [label="Periprocedural Stroke\nRisk (0.5-3%)", shape=ellipse, fillcolor="#D7CCC8"];
        pacemaker_need [label="Pacemaker Implantation\n(~10-25% post-TAVR)", shape=ellipse, fillcolor="#D7CCC8"];
        valve_in_valve [label="Valve-in-Valve\n(Redo Procedure)", shape=box, fillcolor="#BCAAA4"];
        DAPT_post [label="Dual Antiplatelet Therapy\n(DAPT post-TAVR)", shape=box, fillcolor="#D7CCC8"];
        OAC_post [label="OAC / DOAC\n(post-TAVR in AF)", shape=box, fillcolor="#D7CCC8"];
        LV_reverse_remodel [label="LV Reverse Remodeling\n(Post-intervention)", shape=box, fillcolor="#A1887F"];
    }

    // ============================================================
    // SUBGRAPH 12: Systemic Consequences & Comorbidities
    // ============================================================
    subgraph cluster_systemic {
        label="Systemic Consequences & Comorbidities";
        style=filled; fillcolor="#E8F5E9"; color="#1B5E20"; penwidth=2;
        fontsize=10; fontcolor="#1B5E20";

        HF_development [label="Heart Failure\n(Decompensated)", shape=box, fillcolor="#A5D6A7"];
        AF_development [label="Atrial Fibrillation\n(LA Enlargement)", shape=box, fillcolor="#A5D6A7"];
        coronary_disease [label="CAD / Coronary\nArtery Disease", shape=box, fillcolor="#A5D6A7"];
        pulm_HTN [label="Pulmonary Hypertension\n(Secondary)", shape=box, fillcolor="#A5D6A7"];
        right_HF [label="Right Heart Failure\n(Tricuspid Regurgitation)", shape=box, fillcolor="#81C784"];
        renal_failure [label="Cardiorenal Syndrome\n(↓ GFR, AKI risk)", shape=box, fillcolor="#A5D6A7"];
        frailty [label="Frailty / Sarcopenia\n(Elderly)", shape=box, fillcolor="#C8E6C9"];
        sudden_death [label="Sudden Cardiac Death\n(Ventricular Arrhythmia)", shape=box, fillcolor="#4CAF50", fontcolor=white];
        aortic_regurgitation [label="Aortic Regurgitation\n(Mixed Valve Disease)", shape=box, fillcolor="#A5D6A7"];
        endocarditis_risk [label="Infective Endocarditis\nRisk (Calcified Valve)", shape=box, fillcolor="#C8E6C9"];
    }

    // ============================================================
    // EDGES — Risk Factors to Initiating Processes
    // ============================================================
    RF_chol -> oxLDL_infiltration [label="↑ LDL infiltration", color="#E65100"];
    RF_LPA -> oxLDL_infiltration [label="OxPL on Lp(a)", color="#E65100"];
    RF_HTN -> shear_stress [label="Altered flow pattern", color="#E65100"];
    RF_bicuspid -> shear_stress [label="Turbulent flow", color="#E65100"];
    RF_age -> VEC_injury [label="Senescence ↑ susceptibility", color="#E65100"];
    RF_smoking -> ROS_production [label="↑ Oxidative stress", color="#E65100"];
    RF_DM -> BMP_signaling [label="AGEs activate BMP", color="#E65100"];
    RF_CKD -> inorganic_phosphate [label="↑ Pi retention", color="#E65100"];
    RF_genetics -> NOTCH1_loss [label="Loss-of-function variant", color="#E65100"];
    RF_male -> VIC_osteoblast [label="Androgen modulation", color="#E65100"];
    RF_calcium -> inorganic_phosphate [label="Ca/P imbalance", color="#E65100"];
    RF_obesity -> IL6 [label="Adipokine-driven", color="#E65100"];

    // ============================================================
    // EDGES — Endothelium Pathway
    // ============================================================
    shear_stress -> VEC_injury [color="#2E7D32"];
    VEC_injury -> VEC_activation [color="#2E7D32"];
    VEC_activation -> eNOS_down [color="#2E7D32"];
    VEC_activation -> ROS_production [color="#2E7D32"];
    oxLDL_infiltration -> ROS_production [color="#2E7D32"];
    ROS_production -> BMP_signaling [label="Activates BMP", color="#2E7D32"];
    NOTCH1_loss -> BMP_signaling [label="Derepression", color="#2E7D32"];
    BMP_signaling -> VIC_osteoblast [label="Osteogenic drive", color="#2E7D32"];
    TGFb_activation -> VIC_myofibroblast [label="myofibroblast transition", color="#2E7D32"];
    lipoprotein_deposition -> TGFb_activation [label="Lipotoxic TGF-β", color="#2E7D32"];
    oxLDL_infiltration -> monocyte_recruit [color="#2E7D32"];

    // ============================================================
    // EDGES — Inflammation Cascade
    // ============================================================
    monocyte_recruit -> macrophage_infiltration [color="#C62828"];
    macrophage_infiltration -> foam_cells [label="Lipid uptake", color="#C62828"];
    macrophage_infiltration -> IL1b [label="Inflammasome", color="#C62828"];
    macrophage_infiltration -> IL6 [color="#C62828"];
    macrophage_infiltration -> TNFa [color="#C62828"];
    macrophage_infiltration -> MMPs [label="↑ MMP-2/-9", color="#C62828"];
    IL1b -> VIC_myofibroblast [label="Paracrine activation", color="#C62828"];
    IL6 -> CRP [label="Hepatic production", color="#C62828"];
    TNFa -> BMP_signaling [label="↑ BMP via TNF-α", color="#C62828"];
    mast_cells -> TGFb_activation [label="Chymase-TGF-β", color="#C62828"];
    complement -> VEC_injury [label="MAC deposition", color="#C62828"];
    cathepsins -> MMPs [label="Activate latent MMPs", color="#C62828"];
    Tcell_infiltration -> RANKL_expr [label="T-cell RANKL", color="#C62828"];

    // ============================================================
    // EDGES — VIC Osteogenic Transformation
    // ============================================================
    VIC_quiescent -> VIC_myofibroblast [label="Activation", color="#1565C0"];
    VIC_myofibroblast -> VIC_osteoblast [label="Osteogenic switch", color="#1565C0"];
    VIC_osteoblast -> Runx2_expr [color="#1565C0"];
    Runx2_expr -> Osterix_expr [color="#1565C0"];
    Osterix_expr -> ALP_expr [color="#1565C0"];
