digraph FRDA_QSP {
    rankdir=LR;
    graph [fontname="Helvetica", fontsize=11, compound=true, splines=spline, nodesep=0.35, ranksep=0.55, overlap=false];
    node  [fontname="Helvetica", fontsize=10, style="filled,rounded", shape=box];
    edge  [fontname="Helvetica", fontsize=8, arrowsize=0.7];

    /* ============================================================
       FRIEDREICH ATAXIA (FRDA) — QSP MECHANISTIC MAP
       Mol-Genetics  ->  Mitochondrial Fe-S  ->  Oxidative stress
       Multi-organ:  DRG / spinocerebellum / dentate / cortex / heart / pancreas / bone
       Drugs:  Omaveloxolone (NRF2/KEAP1), Idebenone, Deferiprone, Frataxin replacement,
               Gene therapy (AAVrh10-FXN), ACEi/BB (cardiac), Insulin/Metformin (DM)
       ============================================================ */

    /* ---------- 1. Genetics ---------- */
    subgraph cluster_genetics {
        label="1. Genetics & FXN locus (9q21.11)";
        style="filled,rounded"; fillcolor="#fdecea"; color="#c0392b";
        node [fillcolor="#fadbd8"];
        FXN_gene  [label="FXN gene\n(9q21.11)"];
        Intron1   [label="Intron 1\nGAA·TTC repeat"];
        GAA_exp   [label="GAA expansion\n(66–1700 repeats)"];
        Hetero    [label="Compound heterozygotes\n(GAA + point mutation)"];
        Triplex   [label="Triplex/R-loop\n(sticky DNA)"];
        H3K9me3   [label="H3K9me3\nrepressive mark"];
        DNMT      [label="DNA methylation\n(upstream GAA)"];
        HDAC3     [label="HDAC3 recruitment"];
        FXN_mRNA  [label="FXN mRNA ↓\n(~5–30% normal)"];
        FXN_prot  [label="Frataxin protein ↓\n(~5–35% normal)"];
        Carrier   [label="Heterozygote carrier\n(asymptomatic)"];
    }

    /* ---------- 2. Mitochondrial Fe-S biogenesis ---------- */
    subgraph cluster_fes {
        label="2. Mitochondrial Fe-S cluster biogenesis";
        style="filled,rounded"; fillcolor="#eaf2f8"; color="#1f618d";
        node [fillcolor="#d6eaf8"];
        ISCU      [label="ISCU\nscaffold"];
        NFS1      [label="NFS1 cysteine desulfurase"];
        ISD11     [label="ISD11/LYRM4"];
        ACP       [label="ACP1 (mtACP)"];
        Frataxin  [label="Frataxin\n(Fe-donor & allosteric)"];
        FeS_cluster [label="[2Fe-2S] / [4Fe-4S]\nclusters"];
        HSC20     [label="HSC20–HSPA9\nchaperones"];
        GLRX5     [label="GLRX5 transfer"];
        ABCB7     [label="ABCB7\nmito→cyto export"];
        Cyto_FeS  [label="Cytosolic Fe-S\nbiogenesis (CIA)"];
        ApoFe     [label="Apo-Fe target proteins"];
    }

    /* ---------- 3. Mitochondrial iron handling ---------- */
    subgraph cluster_iron {
        label="3. Mito iron homeostasis";
        style="filled,rounded"; fillcolor="#fef9e7"; color="#b7950b";
        node [fillcolor="#fcf3cf"];
        Mfrn      [label="Mitoferrin (SLC25A37/28)"];
        Fe2_mito  [label="Mito Fe²⁺ ↑\nlabile pool"];
        Mito_ferritin [label="FtMt\n(mito ferritin)"];
        IRP1      [label="IRP1\n(cytosolic aconitase)"];
        IRP2      [label="IRP2"];
        TfR1      [label="TfR1 (cell surface)"];
        DMT1      [label="DMT1"];
        Ferritin  [label="Cyto ferritin H/L"];
        Hepcidin  [label="Hepcidin (systemic Fe)"];
        Heme_synth [label="Heme synthesis ↓\n(ferrochelatase)"];
    }

    /* ---------- 4. ETC & energy ---------- */
    subgraph cluster_etc {
        label="4. ETC, ATP & energy";
        style="filled,rounded"; fillcolor="#eafaf1"; color="#1e8449";
        node [fillcolor="#d4efdf"];
        ComplexI  [label="Complex I\n(NADH:Q oxidored, Fe-S)"];
        ComplexII [label="Complex II\n(SDH, [3Fe-4S][4Fe-4S])"];
        ComplexIII [label="Complex III\n(Rieske 2Fe-2S)"];
        ComplexIV [label="Complex IV"];
        Aconitase [label="Aconitase (m/c)\n[4Fe-4S]"];
        ATP_syn   [label="ATP synthase"];
        ATP       [label="ATP\nproduction ↓"];
        MMP       [label="Δψm (membrane potential)"];
        mtDNA     [label="mtDNA damage ↑"];
        mtUPR     [label="Mito UPR\n(ATF5 / CHOP)"];
        Mitophagy [label="Mitophagy\n(PINK1/Parkin)"];
        Biogenesis [label="Mito biogenesis\n(PGC-1α, TFAM)"];
    }

    /* ---------- 5. Oxidative stress & NRF2 ---------- */
    subgraph cluster_ox {
        label="5. Oxidative stress & NRF2-KEAP1 axis";
        style="filled,rounded"; fillcolor="#fdebd0"; color="#b9770e";
        node [fillcolor="#fad7a0"];
        ROS       [label="ROS ↑\n(O₂⁻, H₂O₂, •OH)"];
        Fenton    [label="Fenton reaction\n(Fe²⁺ + H₂O₂)"];
        Lipid_perox [label="Lipid peroxidation\n(4-HNE, MDA)"];
        GSH       [label="GSH/GSSG ↓"];
        NRF2      [label="NRF2"];
        KEAP1     [label="KEAP1 (Cys151 sensor)"];
        ARE       [label="ARE genes\n(NQO1, HO-1, GCLC, GCLM)"];
        Catalase  [label="Catalase"];
        SOD2      [label="SOD2 (MnSOD)"];
        GPX4      [label="GPX4"];
        Ferroptosis [label="Ferroptosis"];
        Aconitase_inact [label="Aconitase inactivation"];
        Thiol_ox  [label="Protein thiol oxidation"];
    }

    /* ---------- 6. CNS neurodegeneration ---------- */
    subgraph cluster_cns {
        label="6. CNS — DRG / spinocerebellar / dentate";
        style="filled,rounded"; fillcolor="#f4ecf7"; color="#6c3483";
        node [fillcolor="#e8daef"];
        DRG       [label="Dorsal root ganglia\nlarge sensory neurons"];
        DRG_loss  [label="DRG neuron loss"];
        Dorsal_col [label="Dorsal columns\n(F. gracilis/cuneatus)"];
        Spinocereb [label="Spinocerebellar tracts"];
        Pyramidal [label="Corticospinal tract"];
        Cerebellum [label="Cerebellum"];
        Dentate   [label="Dentate nucleus\natrophy"];
        Purkinje  [label="Purkinje cells"];
        Cortex_mot [label="Motor cortex"];
        Optic     [label="Optic atrophy"];
        Hearing   [label="Auditory neuropathy"];
        Vibration [label="↓ Vibration & proprioception"];
        Ataxia    [label="Sensory + cerebellar ataxia"];
        Dysarthria [label="Dysarthria"];
        Nystagmus [label="Nystagmus"];
        Areflexia [label="Areflexia"];
        Babinski  [label="Babinski (+)"];
    }

    /* ---------- 7. Cardiomyopathy ---------- */
    subgraph cluster_heart {
        label="7. Cardiomyopathy";
        style="filled,rounded"; fillcolor="#fdedec"; color="#922b21";
        node [fillcolor="#f5b7b1"];
        Cardiomyocyte [label="Cardiomyocyte"];
        LV_hyper  [label="LV hypertrophy\n(concentric)"];
        Mito_card [label="Cardiac mito\nFe overload"];
        Cardiac_ETC [label="Cardiac ETC ↓"];
        Fibrosis_h [label="Myocardial fibrosis"];
        Diastolic [label="Diastolic dysfunction\n→ HFpEF"];
        Systolic  [label="Late systolic dysfunction\n→ HFrEF"];
        Arrhythmia [label="Atrial fib / SVT"];
        Sudden    [label="Sudden cardiac death"];
        LVMI      [label="LVMI ↑\n(MRI)"];
        Troponin  [label="Troponin / NT-proBNP ↑"];
        T2_MRI    [label="Cardiac T2* MRI\n(Fe)"];
    }

    /* ---------- 8. Pancreas & metabolism ---------- */
    subgraph cluster_panc {
        label="8. Pancreas / diabetes mellitus";
        style="filled,rounded"; fillcolor="#e8f8f5"; color="#117a65";
        node [fillcolor="#a3e4d7"];
        Beta_cell [label="β-cell"];
        Beta_apop [label="β-cell apoptosis\n(ROS / Fe)"];
        Insulin   [label="Insulin secretion ↓"];
        IR        [label="Insulin resistance\n(muscle, liver)"];
        Glucose   [label="Hyperglycemia"];
        HbA1c     [label="HbA1c ↑"];
        DM        [label="Diabetes mellitus\n(~30% pts)"];
        Liver     [label="Hepatic glucose output ↑"];
        Adipose   [label="Adipose lipolysis"];
        Sarcopenia [label="Sarcopenia"];
    }

    /* ---------- 9. Bone/skeletal & systemic ---------- */
    subgraph cluster_skel {
        label="9. Skeletal & systemic complications";
        style="filled,rounded"; fillcolor="#fef5e7"; color="#9c640c";
        node [fillcolor="#fad7a0"];
        Scoliosis [label="Scoliosis\n(~60–80%)"];
        Pes_cavus [label="Pes cavus / equinovarus"];
        Spasticity [label="Spasticity"];
        Bladder   [label="Bladder dysfunction"];
        Bowel     [label="Bowel dysfunction"];
        Sleep     [label="Sleep apnea / RLS"];
        Depression [label="Depression / anxiety"];
        Restrictive [label="Restrictive lung disease"];
        Hearing_loss [label="Hearing loss"];
    }

    /* ---------- 10. Omaveloxolone PK/PD ---------- */
    subgraph cluster_omav {
        label="10. Omaveloxolone (Skyclarys) PK/PD";
        style="filled,rounded"; fillcolor="#e8f6f3"; color="#0e6655";
        node [fillcolor="#a2d9ce"];
        Omav_dose [label="Omaveloxolone PO\n150 mg QD"];
        Omav_PK   [label="Cmax/AUC PK\n(food-effect)"];
        Omav_KEAP1 [label="Bind KEAP1\nCys151 modification"];
        NRF2_act  [label="NRF2 stabilization\n→ nuclear translocation"];
        ARE_act   [label="ARE-gene induction"];
        Antiox    [label="↑ Antioxidant capacity"];
        Mito_func [label="↑ Mito function"];
        mFARS     [label="mFARS Δ\n(MOXIe trial)"];
        Liver_LFT [label="ALT/AST ↑\n(class effect)"];
        Lipid_chg [label="LDL ↑ / HDL ↓"];
        BNP_chg   [label="BNP ↑\n(transient)"];
        FT_ratio  [label="Fluid retention"];
        Headache  [label="Headache"];
    }

    /* ---------- 11. Other therapies & gene therapy ---------- */
    subgraph cluster_other_tx {
        label="11. Other therapies & investigational";
        style="filled,rounded"; fillcolor="#f5eef8"; color="#5b2c6f";
        node [fillcolor="#d2b4de"];
        Idebenone [label="Idebenone\n(CoQ analog)"];
        EPI743   [label="EPI-743 (vatiquinone)"];
        Deferiprone [label="Deferiprone\n(Fe chelator)"];
        Nomlabofusp [label="Nomlabofusp\n(CTI-1601, FXN-TAT)"];
        AAV_FXN   [label="AAVrh10-FXN\n(LX2006 gene Tx)"];
        DT216     [label="DT-216 / DT-216P2\n(STAT-RNA)"];
        Etravirine [label="Etravirine (off-label)"];
        HDACi     [label="HDAC inhibitors\n(experimental)"];
        EPO       [label="rhEPO / Resveratrol"];
        ACEi      [label="ACEi / ARB"];
        BetaB     [label="β-blocker"];
        SGLT2     [label="SGLT2i (cardio-renal)"];
        Insulin_tx [label="Insulin / metformin"];
        PT_OT     [label="PT / OT / balance training"];
        Riluzole  [label="Riluzole"];
    }

    /* ---------- 12. Clinical endpoints & biomarkers ---------- */
    subgraph cluster_endpoints {
        label="12. Clinical endpoints & biomarkers";
        style="filled,rounded"; fillcolor="#eaeded"; color="#2c3e50";
        node [fillcolor="#d5dbdb"];
        mFARS_score [label="mFARS\n(modified FARS)"];
        FARS_neuro [label="FARS-neuro"];
        T25FW    [label="Timed 25-foot walk"];
        Peg9     [label="9-Hole Peg Test"];
        SARA     [label="SARA score"];
        Functional [label="Functional staging\n(ADL)"];
        Plasma_FXN [label="Plasma frataxin\n(MS assay)"];
        Buccal_FXN [label="Buccal cell FXN"];
        ETC_assay [label="ETC complex activity"];
        Lipid_perox_bm [label="F2-isoprostane"];
        Echo      [label="Echo: IVSd, EF, e'"];
        MRI_brain [label="Brain MRI\n(cerebellum, cord)"];
        Cardiac_MRI [label="Cardiac MRI\nLVMI, T2*"];
        QoL       [label="QoL (SF-36)"];
        Time_loss_amb [label="Time to loss of ambulation\n(~10–15 y from onset)"];
    }

    /* ---------- Edges: Genetics → mRNA → FXN ---------- */
    FXN_gene -> Intron1 -> GAA_exp;
    GAA_exp -> Triplex -> H3K9me3;
    GAA_exp -> DNMT;
    DNMT -> H3K9me3;
    H3K9me3 -> HDAC3;
    HDAC3 -> FXN_mRNA [label="silencing", color="#c0392b"];
    Triplex -> FXN_mRNA [label="↓ transcription"];
    Hetero -> FXN_prot [label="point mut"];
    FXN_mRNA -> FXN_prot;
    FXN_gene -> Carrier;

    /* ---------- Frataxin → Fe-S → ETC ---------- */
    FXN_prot -> Frataxin;
    NFS1 -> ISCU; ISD11 -> NFS1; ACP -> NFS1;
    Frataxin -> NFS1 [label="allosteric activator"];
    Frataxin -> ISCU [label="Fe donor"];
    NFS1 -> FeS_cluster;
    FeS_cluster -> HSC20 -> GLRX5;
    GLRX5 -> ApoFe;
    ABCB7 -> Cyto_FeS;
    Cyto_FeS -> ApoFe;
    Frataxin -> Mfrn [label="iron handling", style=dashed];
    ApoFe -> ComplexI [label="N1a/N1b/N2/...", color="#1e8449"];
    ApoFe -> ComplexII [label="Fe-S sub", color="#1e8449"];
    ApoFe -> ComplexIII [label="Rieske", color="#1e8449"];
    ApoFe -> Aconitase;

    /* ---------- Iron handling ---------- */
    Mfrn -> Fe2_mito;
    Fe2_mito -> Mito_ferritin;
    Fe2_mito -> Fenton [label="Fe²⁺ + H₂O₂", color="#b9770e"];
    IRP1 -> TfR1 [label="↑ uptake"];
    IRP1 -> Ferritin [label="↓ storage"];
    IRP2 -> TfR1;
    Aconitase -> IRP1 [label="apo-IRP1=IRE-binding", style=dashed];
    TfR1 -> Fe2_mito;
    DMT1 -> Fe2_mito;
    Hepcidin -> TfR1 [style=dashed];
    Fe2_mito -> Heme_synth [label="impaired"];

    /* ---------- ETC dysfunction ---------- */
    ComplexI -> ATP_syn; ComplexII -> ATP_syn; ComplexIII -> ComplexIV -> ATP_syn;
    ATP_syn -> ATP;
    ComplexI -> ROS [label="electron leak", color="#b9770e"];
    ComplexIII -> ROS [color="#b9770e"];
    ATP -> Cardiomyocyte [label="energy demand"];
    ATP -> DRG;
    ATP -> Beta_cell;
    MMP -> ATP;
    Fenton -> ROS;
    Aconitase -> Aconitase_inact [label="ROS inactivation"];
    Aconitase_inact -> IRP1;
    ROS -> Lipid_perox;
    Lipid_perox -> Ferroptosis;
    GSH -> GPX4 -> Lipid_perox [label="quench", color="#1e8449"];
    SOD2 -> ROS [color="#1e8449"];
    Catalase -> ROS [color="#1e8449"];
    ROS -> mtDNA;
    mtDNA -> mtUPR -> Mitophagy;
    Biogenesis -> ATP;

    /* ---------- NRF2 axis ---------- */
    ROS -> KEAP1 [label="Cys oxidation"];
    KEAP1 -> NRF2 [label="ubiquitin/degradation", arrowhead=tee, color="#c0392b"];
    NRF2 -> ARE -> Catalase;
    ARE -> SOD2;
    ARE -> GPX4;
    ARE -> GSH;
    GSH -> Thiol_ox [arrowhead=tee];

    /* ---------- CNS path ---------- */
    Frataxin -> DRG [label="low FXN sensitive", color="#6c3483"];
    Frataxin -> Cardiomyocyte [color="#922b21"];
    Frataxin -> Beta_cell [color="#117a65"];
    Frataxin -> Dentate;
    Frataxin -> Purkinje;
    ATP -> DRG;
    Fe2_mito -> DRG_loss;
    DRG -> Dorsal_col -> Spinocereb -> Cerebellum;
    Cerebellum -> Dentate;
    Cerebellum -> Purkinje;
    Cortex_mot -> Pyramidal;
    DRG_loss -> Vibration;
    Spinocereb -> Ataxia;
    Dentate -> Ataxia;
    Pyramidal -> Spasticity;
    Pyramidal -> Babinski;
    Cerebellum -> Dysarthria;
    Cerebellum -> Nystagmus;
    DRG_loss -> Areflexia;
    DRG_loss -> Optic;
    DRG_loss -> Hearing;
    Hearing -> Hearing_loss;

    /* ---------- Heart path ---------- */
    Frataxin -> Mito_card [label="low FXN"];
    Mito_card -> Cardiac_ETC -> LV_hyper;
    Fe2_mito -> Mito_card;
    LV_hyper -> Fibrosis_h -> Diastolic -> Systolic;
    LV_hyper -> Arrhythmia;
    Arrhythmia -> Sudden;
    Mito_card -> LVMI;
    Fibrosis_h -> Troponin;
    Mito_card -> T2_MRI;

    /* ---------- Pancreas path ---------- */
    Beta_apop -> Insulin -> Glucose;
    Beta_cell -> Beta_apop [label="ROS / Fe"];
    Sarcopenia -> IR;
    IR -> Glucose;
    Glucose -> HbA1c;
    HbA1c -> DM;
    Liver -> Glucose;
    Adipose -> IR;

    /* ---------- Skeletal/systemic ---------- */
    Ataxia -> Scoliosis;
    DRG_loss -> Pes_cavus;
    Spasticity -> Bladder;
    Spasticity -> Bowel;
    Scoliosis -> Restrictive;
    DM -> Depression;
    Ataxia -> Depression;
    Ataxia -> Sleep;

    /* ---------- Omaveloxolone PK/PD ---------- */
    Omav_dose -> Omav_PK -> Omav_KEAP1;
    Omav_KEAP1 -> NRF2_act [label="block ubiq", color="#0e6655"];
    NRF2_act -> ARE_act;
    NRF2 -> ARE_act;
    ARE_act -> Antiox;
    Antiox -> Mito_func -> ATP;
    Antiox -> ROS [arrowhead=tee, color="#0e6655"];
    Mito_func -> Cardiomyocyte;
    Mito_func -> Beta_cell;
    Mito_func -> DRG;
    Omav_PK -> Liver_LFT;
    Omav_PK -> Lipid_chg;
    Omav_PK -> BNP_chg;
    Omav_PK -> FT_ratio;
    Omav_PK -> Headache;
    Omav_dose -> mFARS [label="MOXIe Δ=-2.4", color="#0e6655"];

    /* ---------- Other therapies ---------- */
    Idebenone -> ComplexI [label="electron carrier"];
    EPI743 -> Lipid_perox [arrowhead=tee];
    Deferiprone -> Fe2_mito [label="chelate Fe", arrowhead=tee];
    Deferiprone -> LV_hyper [arrowhead=tee, style=dashed];
    Nomlabofusp -> FXN_prot [label="TAT-FXN replacement", color="#5b2c6f"];
    AAV_FXN -> FXN_gene [label="AAVrh10 FXN cDNA", color="#5b2c6f"];
    AAV_FXN -> FXN_prot;
    DT216 -> FXN_mRNA [label="restore txn"];
    Etravirine -> FXN_mRNA [label="↑ mRNA (in vitro)"];
    HDACi -> H3K9me3 [arrowhead=tee, label="reverse silencing"];
    EPO -> Antiox;
    ACEi -> LV_hyper [arrowhead=tee];
    BetaB -> Arrhythmia [arrowhead=tee];
    BetaB -> LV_hyper [arrowhead=tee];
    SGLT2 -> LV_hyper [arrowhead=tee];
    Insulin_tx -> Glucose [arrowhead=tee];
    PT_OT -> Ataxia [arrowhead=tee];
    Riluzole -> Ataxia [arrowhead=tee, style=dashed];

    /* ---------- Endpoints ---------- */
    Ataxia -> mFARS_score;
    Ataxia -> FARS_neuro;
    Ataxia -> T25FW;
    Ataxia -> Peg9;
    Ataxia -> SARA;
    Ataxia -> Functional;
    Vibration -> mFARS_score;
    Spasticity -> mFARS_score;
    Dysarthria -> mFARS_score;
    FXN_prot -> Plasma_FXN;
    FXN_prot -> Buccal_FXN;
    ATP -> ETC_assay;
    Lipid_perox -> Lipid_perox_bm;
    LV_hyper -> Echo;
    LV_hyper -> Cardiac_MRI;
    Cerebellum -> MRI_brain;
    DRG_loss -> Time_loss_amb;
    Diastolic -> Sudden;
    Functional -> QoL;

    /* ---------- Cross-organ feedbacks ---------- */
    DM -> Cardiac_ETC [style=dashed, label="metabolic stress"];
    DM -> Beta_apop [style=dashed];
    Cardiac_MRI -> T2_MRI;
    ROS -> Beta_cell;
    ROS -> Cardiomyocyte;
    ROS -> DRG;

    /* ---------- Plasma frataxin biomarker feed-back ---------- */
    Nomlabofusp -> Plasma_FXN [color="#5b2c6f"];
    AAV_FXN -> Plasma_FXN [color="#5b2c6f"];
    Omav_dose -> ARE_act;
}
