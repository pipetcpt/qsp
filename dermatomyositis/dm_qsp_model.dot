digraph DermatomyositisQSP {
    graph [
        rankdir=LR
        fontname="Helvetica"
        fontsize=11
        label="Dermatomyositis QSP Mechanistic Map\n피부근염 정량적 시스템 약리학 기계론적 지도"
        labelloc=t
        labeljust=c
        splines=ortho
        nodesep=0.35
        ranksep=0.7
        bgcolor="#FAFAFA"
        pad=0.5
        size="36,24"
    ]
    node [fontname="Helvetica" fontsize=9 style=filled shape=box]
    edge [fontname="Helvetica" fontsize=8 arrowsize=0.7]

    /* =============================================
       CLUSTER 1: Innate Immune / Type I IFN Axis
       ============================================= */
    subgraph cluster_innate {
        label="1. Innate Immunity & Type I IFN Axis"
        style=filled fillcolor="#E8F4FD" color="#1A73E8" penwidth=2
        fontcolor="#0D47A1" fontsize=11

        pDC   [label="Plasmacytoid Dendritic Cell\n(pDC)" fillcolor="#90CAF9"]
        cDC   [label="Conventional DC\n(cDC)" fillcolor="#90CAF9"]
        TLR7  [label="TLR7\n(RNA sensing)" fillcolor="#42A5F5"]
        TLR9  [label="TLR9\n(DNA sensing)" fillcolor="#42A5F5"]
        TLR3  [label="TLR3 (dsRNA)" fillcolor="#42A5F5"]
        STING [label="cGAS-STING\nPathway" fillcolor="#1E88E5" fontcolor=white]
        IRF3  [label="IRF3\n(phosphorylated)" fillcolor="#1565C0" fontcolor=white]
        IRF7  [label="IRF7\n(phosphorylated)" fillcolor="#1565C0" fontcolor=white]
        IFNa  [label="IFN-α\n(Type I)" fillcolor="#0D47A1" fontcolor=white]
        IFNb  [label="IFN-β\n(Type I)" fillcolor="#0D47A1" fontcolor=white]
        IFNAR [label="IFNAR1/2\nReceptor" fillcolor="#1565C0" fontcolor=white]
        JAK1_i [label="JAK1\n(Innate)" fillcolor="#283593" fontcolor=white]
        TYK2  [label="TYK2" fillcolor="#283593" fontcolor=white]
        STAT1 [label="STAT1\n(Y701-P)" fillcolor="#1A237E" fontcolor=white]
        STAT2 [label="STAT2\n(Y689-P)" fillcolor="#1A237E" fontcolor=white]
        ISGF3 [label="ISGF3 Complex\n(STAT1/STAT2/IRF9)" fillcolor="#0D1B6E" fontcolor=white]
        ISG   [label="ISG Expression\n(ISG15, OAS1, MxA,\nIFIT1, RSAD2)" fillcolor="#1A237E" fontcolor=white]
        IFN_score [label="IFN Signature Score\n(Benveniste 6-gene)" fillcolor="#3949AB" fontcolor=white]
        NF_kB [label="NF-κB\nActivation" fillcolor="#283593" fontcolor=white]
        NLRP3 [label="NLRP3\nInflammasome" fillcolor="#1976D2"]
        macrophage [label="Tissue Macrophage\n(M1-like)" fillcolor="#64B5F6"]
        neutrophil [label="Neutrophil\nNETosis" fillcolor="#64B5F6"]
    }

    /* =============================================
       CLUSTER 2: Complement System
       ============================================= */
    subgraph cluster_complement {
        label="2. Complement System"
        style=filled fillcolor="#FFF3E0" color="#FB8C00" penwidth=2
        fontcolor="#E65100" fontsize=11

        C1q   [label="C1q\n(Classical)" fillcolor="#FFB74D"]
        C1r   [label="C1r/C1s" fillcolor="#FFA726"]
        C2    [label="C2" fillcolor="#FF9800"]
        C3    [label="C3" fillcolor="#FB8C00"]
        C3b   [label="C3b\n(Opsonin)" fillcolor="#F57C00"]
        C3a   [label="C3a\n(Anaphylatoxin)" fillcolor="#EF6C00"]
        C4b   [label="C4b" fillcolor="#FF9800"]
        C5    [label="C5" fillcolor="#E65100" fontcolor=white]
        C5a   [label="C5a\n(Chemoattractant)" fillcolor="#BF360C" fontcolor=white]
        C5b   [label="C5b" fillcolor="#BF360C" fontcolor=white]
        MAC   [label="MAC\n(C5b-9 TCC)\nPore-forming" fillcolor="#7F0000" fontcolor=white]
        C3_dep [label="C3 Deposition\non Endothelium" fillcolor="#FF8F00"]
        MBL   [label="MBL/Lectin\nPathway" fillcolor="#FFB300"]
        CFH   [label="Complement Factor H\n(Inhibitor)" fillcolor="#FFD54F"]
        C4BP  [label="C4b-Binding\nProtein" fillcolor="#FFE082"]
    }

    /* =============================================
       CLUSTER 3: Muscle Microvasculature
       ============================================= */
    subgraph cluster_microvasculature {
        label="3. Muscle Microvasculature & Endothelium"
        style=filled fillcolor="#E8F5E9" color="#43A047" penwidth=2
        fontcolor="#1B5E20" fontsize=11

        endothelium [label="Muscle Capillary\nEndothelium" fillcolor="#A5D6A7"]
        PECAM  [label="PECAM-1/CD31\nJunctions" fillcolor="#81C784"]
        eNOS   [label="eNOS\n(Nitric Oxide)" fillcolor="#66BB6A"]
        NO     [label="NO\n(Vasodilator)" fillcolor="#4CAF50" fontcolor=white]
        VEGF   [label="VEGF-A\n(Angiogenesis)" fillcolor="#43A047" fontcolor=white]
        VEGFR2 [label="VEGFR2\nSignaling" fillcolor="#388E3C" fontcolor=white]
        capillary_loss [label="Capillary Loss\n(Perifascicular)" fillcolor="#1B5E20" fontcolor=white]
        ischemia_muscle [label="Muscle Ischemia\n& Perifascicular\nAtrophy" fillcolor="#2E7D32" fontcolor=white]
        RBC_extravasation [label="RBC Extravasation\n& Microhemorrhage" fillcolor="#4E342E" fontcolor=white]
        endothelin [label="Endothelin-1\n(Vasoconstrictor)" fillcolor="#8BC34A"]
        von_willebrand [label="vWF Release\n(Endothelial\nActivation)" fillcolor="#AED581"]
    }

    /* =============================================
       CLUSTER 4: Myositis-Specific Autoantibodies
       ============================================= */
    subgraph cluster_MSA {
        label="4. Myositis-Specific / -Associated Antibodies"
        style=filled fillcolor="#FCE4EC" color="#E91E63" penwidth=2
        fontcolor="#880E4F" fontsize=11

        anti_MDA5  [label="Anti-MDA5\n(CADM-140)\nILD/Skin" fillcolor="#F48FB1"]
        anti_Mi2   [label="Anti-Mi-2\n(NuRD complex)\nClassic DM" fillcolor="#F06292"]
        anti_TIF1g [label="Anti-TIF1γ\n(p155/140)\nCancer-assoc." fillcolor="#EC407A"]
        anti_NXP2  [label="Anti-NXP2\n(MJ)\nCalcinosis" fillcolor="#E91E63" fontcolor=white]
        anti_SAE   [label="Anti-SAE\n(Swallowing)" fillcolor="#D81B60" fontcolor=white]
        anti_Jo1   [label="Anti-Jo-1\n(Antisynthetase)\nILD+Arthritis" fillcolor="#C2185B" fontcolor=white]
        anti_PL7   [label="Anti-PL-7/12\n(Antisynthetase)" fillcolor="#AD1457" fontcolor=white]
        anti_OJ    [label="Anti-OJ/EJ\n(Antisynthetase)" fillcolor="#880E4F" fontcolor=white]
        anti_SRP   [label="Anti-SRP\n(Necrotizing)" fillcolor="#4A148C" fontcolor=white]
        anti_HMGCR [label="Anti-HMGCR\n(Statin-assoc.)" fillcolor="#6A1B9A" fontcolor=white]
        B_cell_GC  [label="Germinal Center\nReaction (GC)" fillcolor="#F8BBD9"]
        plasma_cell [label="Long-lived\nPlasma Cell" fillcolor="#F48FB1"]
        IgG_auto   [label="IgG Autoantibody\nProduction" fillcolor="#F06292"]
    }

    /* =============================================
       CLUSTER 5: Adaptive Immunity
       ============================================= */
    subgraph cluster_adaptive {
        label="5. Adaptive Immune Cells"
        style=filled fillcolor="#F3E5F5" color="#9C27B0" penwidth=2
        fontcolor="#4A148C" fontsize=11

        naive_CD4  [label="Naive CD4+\nT Cell" fillcolor="#CE93D8"]
        Th1        [label="Th1\n(IFN-γ, TNF)" fillcolor="#BA68C8"]
        Th17       [label="Th17\n(IL-17, IL-22)" fillcolor="#AB47BC"]
        Tfh        [label="Tfh\n(CXCR5+, IL-21)" fillcolor="#9C27B0" fontcolor=white]
        Treg       [label="Treg\n(FoxP3+, IL-10)" fillcolor="#7B1FA2" fontcolor=white]
        CD8_CTL    [label="CD8+ CTL\n(Granzyme B+)" fillcolor="#6A1B9A" fontcolor=white]
        NK_cell    [label="NK Cell\n(CD56+)" fillcolor="#4A148C" fontcolor=white]
        naive_B    [label="Naive B Cell\n(CD19+)" fillcolor="#E1BEE7"]
        memory_B   [label="Memory B Cell\n(CD27+)" fillcolor="#CE93D8"]
        MHC_II     [label="MHC-II / HLA-DRB1\nAntigen Presentation" fillcolor="#BA68C8"]
        TCR_CD28   [label="TCR/CD28\nCostimulation" fillcolor="#AB47BC"]
        IL21       [label="IL-21\n(Tfh→B)" fillcolor="#9C27B0" fontcolor=white]
        CXCL10     [label="CXCL10/IP-10\n(T cell recruit)" fillcolor="#7B1FA2" fontcolor=white]
    }

    /* =============================================
       CLUSTER 6: Skin Pathology
       ============================================= */
    subgraph cluster_skin {
        label="6. Skin Pathology"
        style=filled fillcolor="#FFF8E1" color="#FFA000" penwidth=2
        fontcolor="#E65100" fontsize=11

        UV_trigger [label="UV Light\nTrigger" fillcolor="#FFF59D"]
        keratinocyte [label="Keratinocyte\nActivation" fillcolor="#FFEE58"]
        skin_IFN   [label="Skin IFN-κ\nPlasmacytoid\nInfiltrate" fillcolor="#FFD600"]
        gottron_pap [label="Gottron's Papules\n(MCP/PIP/DIP)" fillcolor="#FF8F00"]
        heliotrope  [label="Heliotrope Rash\n(Periorbital)" fillcolor="#FF6F00"]
        v_sign      [label="V-sign\n(Neckline)" fillcolor="#FF6F00"]
        shawl_sign  [label="Shawl Sign\n(Shoulders)" fillcolor="#F57F17"]
        mech_hands  [label="Mechanic's Hands\n(Antisynthetase)" fillcolor="#E65100" fontcolor=white]
        calcinosis  [label="Calcinosis\n(Hydroxyapatite)" fillcolor="#BF360C" fontcolor=white]
        CDASI       [label="CDASI Score\n(0-100)" fillcolor="#FF8C00"]
        skin_fibrosis [label="Dermal Fibrosis\n(TGF-β mediated)" fillcolor="#D84315" fontcolor=white]
        MMP_skin    [label="MMP-1/MMP-9\nSkin Remodeling" fillcolor="#FF7043"]
        skin_capillary [label="Skin Capillary\nNailfold Changes" fillcolor="#FFAB40"]
    }

    /* =============================================
       CLUSTER 7: Muscle Pathology
       ============================================= */
    subgraph cluster_muscle {
        label="7. Muscle Pathology & Biomarkers"
        style=filled fillcolor="#E3F2FD" color="#1976D2" penwidth=2
        fontcolor="#0D47A1" fontsize=11

        myofiber   [label="Myofiber (Type I/II)\nSkeletal Muscle" fillcolor="#BBDEFB"]
        perifascicular [label="Perifascicular\nAtrophy" fillcolor="#90CAF9"]
        necrosis   [label="Myofiber Necrosis\n& Regeneration" fillcolor="#64B5F6"]
        CK_enz     [label="Creatine Kinase\n(CK-MM, CK-MB)" fillcolor="#42A5F5"]
        LDH        [label="LDH\n(Muscle damage)" fillcolor="#2196F3"]
        aldolase   [label="Aldolase\n(Serum)" fillcolor="#1E88E5"]
        myoglobin  [label="Myoglobin\n(Urine/Blood)" fillcolor="#1565C0" fontcolor=white]
        troponin   [label="Cardiac Troponin\n(Cardiac ILD)" fillcolor="#0D47A1" fontcolor=white]
        MMT8       [label="MMT-8 Score\n(0-80)" fillcolor="#082F8B" fontcolor=white]
        CDASI_muscle [label="MAS Score\n(Myositis)" fillcolor="#0D2C6B" fontcolor=white]
        muscle_MRI [label="Muscle MRI\nEdema (STIR)" fillcolor="#1A237E" fontcolor=white]
        grip_strength [label="Grip Strength\n(kPa)" fillcolor="#283593" fontcolor=white]
        dystrophin [label="Dystrophin\nComplex" fillcolor="#3949AB" fontcolor=white]
        autophagy  [label="Autophagy\n(LC3-II↑)" fillcolor="#3F51B5" fontcolor=white]
    }

    /* =============================================
       CLUSTER 8: Cytokine Network
       ============================================= */
    subgraph cluster_cytokines {
        label="8. Cytokine & Chemokine Network"
        style=filled fillcolor="#E8EAF6" color="#3F51B5" penwidth=2
        fontcolor="#1A237E" fontsize=11

        IL6    [label="IL-6\n(Pleotropic)" fillcolor="#9FA8DA"]
        TNF    [label="TNF-α\n(Systemic)" fillcolor="#7986CB"]
        IL1b   [label="IL-1β\n(NLRP3)" fillcolor="#5C6BC0"]
        IL17   [label="IL-17A/F\n(Th17)" fillcolor="#3F51B5" fontcolor=white]
        IL10   [label="IL-10\n(Anti-inflam)" fillcolor="#3949AB" fontcolor=white]
        IFNg   [label="IFN-γ\n(Th1/NK)" fillcolor="#303F9F" fontcolor=white]
        TGFb   [label="TGF-β1\n(Fibrosis)" fillcolor="#283593" fontcolor=white]
        BAFF   [label="BAFF/BLyS\n(B-survival)" fillcolor="#1A237E" fontcolor=white]
        APRIL  [label="APRIL\n(B-survival)" fillcolor="#0D47A1" fontcolor=white]
        CXCL4  [label="CXCL4/PF4\n(ILD marker)" fillcolor="#7E57C2"]
        CCL2   [label="CCL2/MCP-1\n(Monocyte)" fillcolor="#9575CD"]
        CXCL9  [label="CXCL9\n(CXCR3 ligand)" fillcolor="#7986CB"]
        IL12   [label="IL-12/IL-23\n(Th1/Th17 axis)" fillcolor="#5C6BC0"]
        IL15   [label="IL-15\n(NK/CD8 activ)" fillcolor="#3F51B5" fontcolor=white]
    }

    /* =============================================
       CLUSTER 9: ILD (Interstitial Lung Disease)
       ============================================= */
    subgraph cluster_ILD {
        label="9. Interstitial Lung Disease (ILD)"
        style=filled fillcolor="#E0F7FA" color="#00838F" penwidth=2
        fontcolor="#004D40" fontsize=11

        ILD_type [label="ILD Subtypes\n(NSIP/UIP/OP/DAD)" fillcolor="#B2EBF2"]
        FVC      [label="FVC\n(Forced Vital Capacity)" fillcolor="#80DEEA"]
        DLCO     [label="DLCO\n(Diffusing Capacity)" fillcolor="#4DD0E1"]
        HRCT     [label="HRCT Score\n(Extent of ILD)" fillcolor="#00BCD4"]
        IPF_like [label="DAD Pattern\n(Rapid ILD)" fillcolor="#0097A7"]
        MUC5B    [label="MUC5B Promoter\n(Genetic Risk)" fillcolor="#00838F" fontcolor=white]
        MDA5_ILD [label="Rapid Progressive\nILD (Anti-MDA5)" fillcolor="#006064" fontcolor=white]
        lung_fibroblast [label="Lung Fibroblast\nActivation" fillcolor="#00897B"]
        SP_D     [label="Surfactant\nProtein D" fillcolor="#00ACC1"]
        KL6_krebs [label="KL-6 / Krebs\nvon den Lungen-6" fillcolor="#0097A7"]
    }

    /* =============================================
       CLUSTER 10: Drug PK (Pharmacokinetics)
       ============================================= */
    subgraph cluster_PK {
        label="10. Drug Pharmacokinetics"
        style=filled fillcolor="#F9FBE7" color="#689F38" penwidth=2
        fontcolor="#33691E" fontsize=11

        /* Corticosteroids */
        PRED_gut  [label="Prednisone\n(GI Abs)" fillcolor="#DCEDC8"]
        PRED_c    [label="Prednisolone\nCentral (C1)" fillcolor="#C5E1A5"]
        PRED_p    [label="Prednisolone\nPeripheral (C2)" fillcolor="#AED581"]
        GR_bound  [label="GR·Prednisolone\nComplex" fillcolor="#9CCC65"]

        /* IVIG */
        IVIG_c    [label="IVIG Central\nCompartment" fillcolor="#8BC34A"]
        IVIG_p    [label="IVIG Peripheral\nCompartment" fillcolor="#7CB342"]
        FcRn_sat  [label="FcRn Saturation\n(IgG catabolism↓)" fillcolor="#689F38" fontcolor=white]

        /* Methotrexate */
        MTX_gut   [label="MTX Oral Abs\n(F~0.70)" fillcolor="#CDDC39"]
        MTX_c     [label="MTX Central" fillcolor="#C0CA33"]
        MTX_poly  [label="MTX-Polyglutamates\n(Intracellular)" fillcolor="#AFB42B"]

        /* Mycophenolate */
        MMF_gut   [label="MMF Gut Abs\n(Prodrug)" fillcolor="#DCEDC8"]
        MPA_c     [label="MPA Central\n(Active)" fillcolor="#C5E1A5"]

        /* Rituximab */
        RTX_c     [label="Rituximab\nCentral (C1)" fillcolor="#8D6E63"]
        RTX_p     [label="Rituximab\nPeripheral (C2)" fillcolor="#795548"]
        CD20_b    [label="CD20-Rituximab\nBound (Tissue)" fillcolor="#6D4C41" fontcolor=white]

        /* JAK Inhibitors */
        JAKi_gut  [label="Baricitinib/Ruxo\nOral Abs" fillcolor="#FF7043"]
        JAKi_c    [label="JAKi Central\nConcentration" fillcolor="#F4511E"]
        JAKi_p    [label="JAKi Peripheral" fillcolor="#E64A19"]
    }

    /* =============================================
       CLUSTER 11: Drug Pharmacodynamics
       ============================================= */
    subgraph cluster_PD {
        label="11. Drug Pharmacodynamics"
        style=filled fillcolor="#FFF9C4" color="#F9A825" penwidth=2
        fontcolor="#F57F17" fontsize=11

        GR_transrep  [label="GR Trans-repression\n(NF-κB↓, AP-1↓)" fillcolor="#FFF176"]
        GR_transact  [label="GR Trans-activation\n(IκBα↑, GILZ↑)" fillcolor="#FFEE58"]
        B_depletion  [label="B Cell Depletion\n(Anti-CD20)" fillcolor="#FDD835"]
        IMPDH_inh   [label="IMPDH Inhibition\n(MMF → MPA)" fillcolor="#FBC02D"]
        DHFR_inh    [label="DHFR Inhibition\n(MTX)" fillcolor="#F9A825"]
        JAK1_inh    [label="JAK1 Inhibition\n(IC50: 5.7 nM bari)" fillcolor="#F57F17" fontcolor=white]
        JAK2_inh    [label="JAK2 Inhibition\n(IC50: 8.7 nM bari)" fillcolor="#EF6C00" fontcolor=white]
        STAT_block  [label="STAT1/STAT3\nPhosphorylation Block" fillcolor="#E65100" fontcolor=white]
        IFN_suppr   [label="Type I IFN\nSuppression" fillcolor="#BF360C" fontcolor=white]
        Treg_expand [label="Treg Expansion\n(Steroid)" fillcolor="#FFF9C4"]
        complement_inh [label="IVIG Complement\nScavenging" fillcolor="#FFEE58"]
    }

    /* =============================================
       CLUSTER 12: Clinical Endpoints & Outcomes
       ============================================= */
    subgraph cluster_endpoints {
        label="12. Clinical Endpoints & Outcomes"
        style=filled fillcolor="#EFEBE9" color="#795548" penwidth=2
        fontcolor="#3E2723" fontsize=11

        TIS        [label="Total Improvement\nScore (TIS, 0-100)" fillcolor="#D7CCC8"]
        MITAX      [label="MITAX Score\n(Disease Activity)" fillcolor="#BCAAA4"]
        MYOACT     [label="MYOACT Score" fillcolor="#A1887F"]
        PhysGA     [label="Physician Global\nActivity (0-10)" fillcolor="#8D6E63"]
        PtGA       [label="Patient Global\nActivity (0-10)" fillcolor="#795548" fontcolor=white]
        HAQ        [label="HAQ-DI\n(Function)" fillcolor="#6D4C41" fontcolor=white]
        dysphagia  [label="Dysphagia\n(GI/Throat)" fillcolor="#5D4037" fontcolor=white]
        aspiration [label="Aspiration\nPneumonia Risk" fillcolor="#4E342E" fontcolor=white]
        mortality  [label="5-Year Mortality\n(ILD/Malignancy)" fillcolor="#3E2723" fontcolor=white]
        malignancy [label="Associated\nMalignancy\n(Anti-TIF1γ)" fillcolor="#BF360C" fontcolor=white]
        remission  [label="Complete Clinical\nRemission (CCR)" fillcolor="#33691E" fontcolor=white]
        flare      [label="Disease Flare\n(CK 3× ULN)" fillcolor="#B71C1C" fontcolor=white]
        damage     [label="Myositis Damage\nIndex (MDI)" fillcolor="#880E4F" fontcolor=white]
    }

    /* =============================================
       EDGES: Innate Immune Pathways
       ============================================= */
    TLR7 -> IRF7 [label="MyD88" color="#1A73E8"]
    TLR9 -> IRF7 [label="MyD88" color="#1A73E8"]
    TLR3 -> IRF3 [label="TRIF" color="#1A73E8"]
    STING -> IRF3 [label="TBK1" color="#1A73E8"]
    IRF3 -> IFNb [color="#1A73E8"]
    IRF7 -> IFNa [color="#1A73E8"]
    pDC -> IFNa  [label="Primary source" color="#1A73E8" style=bold]
    pDC -> TLR7  [color="#1A73E8"]
    pDC -> TLR9  [color="#1A73E8"]
    cDC -> TLR3  [color="#1A73E8"]
    IFNa -> IFNAR [color="#0D47A1" style=bold]
    IFNb -> IFNAR [color="#0D47A1"]
    IFNAR -> JAK1_i [color="#283593"]
    IFNAR -> TYK2  [color="#283593"]
    JAK1_i -> STAT1 [label="Y701" color="#283593"]
    TYK2 -> STAT2  [label="Y689" color="#283593"]
    STAT1 -> ISGF3 [color="#1A237E"]
    STAT2 -> ISGF3 [color="#1A237E"]
    ISGF3 -> ISG   [label="ISRE binding" color="#1A237E" style=bold]
    ISG -> IFN_score [color="#3949AB"]
    NF_kB -> IL6   [color="#283593"]
    NF_kB -> TNF   [color="#283593"]
    NF_kB -> IL1b  [color="#283593"]
    NLRP3 -> IL1b  [label="Caspase-1" color="#1976D2"]
    macrophage -> NF_kB [color="#1976D2"]
    macrophage -> NLRP3 [color="#1976D2"]
    neutrophil -> NF_kB [color="#1976D2"]

    /* =============================================
       EDGES: Complement Cascade
       ============================================= */
    IgG_auto -> C1q [label="Classical\nactivation" color="#FB8C00" style=bold]
    C1q -> C1r      [color="#FB8C00"]
    C1r -> C2       [color="#FB8C00"]
    C1r -> C4b      [color="#FB8C00"]
    C2 -> C3        [label="C3 convertase" color="#FB8C00"]
    C4b -> C3       [color="#FB8C00"]
    MBL -> C3       [label="Lectin\npathway" color="#FF9800"]
    C3 -> C3b       [label="Cleavage" color="#F57C00"]
    C3 -> C3a       [label="Cleavage" color="#EF6C00"]
    C3b -> MAC      [label="→C5b-9\nassembly" color="#E65100"]
    C3b -> C3_dep   [color="#FF8F00"]
    C5 -> C5a       [label="C5 convertase" color="#BF360C"]
    C5 -> C5b       [label="C5 convertase" color="#BF360C"]
    C5b -> MAC      [color="#7F0000" style=bold]
    C3a -> macrophage [label="Activation" color="#EF6C00"]
    C5a -> neutrophil [label="Chemotaxis" color="#BF360C"]
    MAC -> endothelium [label="Pore\nformation" color="#7F0000" style=bold]
    CFH -> C3b      [label="Inactivation" color="#FFD54F" arrowhead=tee]
    C4BP -> C4b     [label="Inactivation" color="#FFE082" arrowhead=tee]
    C3_dep -> capillary_loss [color="#FF8F00" style=bold]

    /* =============================================
       EDGES: Microvasculature
       ============================================= */
    MAC -> capillary_loss [label="Endothelial\ndestruction" color="#7F0000" style=bold]
    capillary_loss -> ischemia_muscle [color="#2E7D32" style=bold]
    ischemia_muscle -> perifascicular [color="#1B5E20" style=bold]
    endothelium -> VEGF [label="Hypoxia" color="#43A047"]
    VEGF -> VEGFR2  [color="#388E3C"]
    VEGFR2 -> capillary_loss [label="Insufficient\nrepair" color="#388E3C"]
    eNOS -> NO      [color="#4CAF50"]
    NO -> endothelium [label="Protection" color="#4CAF50" arrowhead=tee]
    endothelin -> endothelium [label="Vasospasm" color="#8BC34A"]
    von_willebrand -> C1q [label="Triggers\nComplement" color="#AED581"]
    RBC_extravasation -> capillary_loss [color="#4E342E"]

    /* =============================================
       EDGES: MSA & B cells
       ============================================= */
    B_cell_GC -> plasma_cell [color="#E91E63" style=bold]
    plasma_cell -> IgG_auto  [color="#E91E63" style=bold]
    IgG_auto -> anti_MDA5    [color="#F06292"]
    IgG_auto -> anti_Mi2     [color="#F06292"]
    IgG_auto -> anti_TIF1g   [color="#EC407A"]
    IgG_auto -> anti_NXP2    [color="#E91E63"]
