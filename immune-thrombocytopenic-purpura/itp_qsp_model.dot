digraph ITP_QSP {
  graph [rankdir=LR, bgcolor="#0d1117",
         fontname="Helvetica", fontsize=16,
         label="Immune Thrombocytopenic Purpura (ITP) — QSP Mechanistic Map\nAnti-platelet Immunity · Megakaryopoiesis · Splenic Destruction · Multi-drug PK/PD",
         labelloc=t, labeljust=c, fontcolor="white",
         nodesep=0.5, ranksep=1.0, splines=ortho, concentrate=false];
  node [shape=box, style="rounded,filled", fontname="Helvetica", fontsize=9,
        width=1.8, height=0.45];
  edge [fontname="Helvetica", fontsize=8, penwidth=1.2, arrowsize=0.7];

  /* ================================================================
     CLUSTER 1 — Platelet Surface Antigens
     ================================================================ */
  subgraph cluster_platelet_antigens {
    label="Platelet Surface Antigens";
    fontcolor="white"; fontsize=12; fontname="Helvetica-Bold";
    style=filled; bgcolor="#0f1f0f"; color="#00cc66";

    GPIIb_IIIa      [label="αIIbβ3 (GPIIb/IIIa)\nCollagen binding",         fillcolor="#00cc66", fontcolor="black"];
    GPIb_IX_V       [label="GPIb/IX/V Complex\nvWF binding",                  fillcolor="#00cc66", fontcolor="black"];
    GPVI            [label="GPVI\nCollagen receptor",                          fillcolor="#22aa55", fontcolor="black"];
    GPIa_IIa        [label="GPIa/IIa (α2β1)\nCollagen adhesion",              fillcolor="#22aa55", fontcolor="black"];
    CD31_PECAM      [label="CD31 (PECAM-1)\nEndothelial adhesion",             fillcolor="#22aa55", fontcolor="black"];
    P_selectin      [label="P-selectin (CD62P)\nActivation marker",            fillcolor="#22aa55", fontcolor="black"];
    Sialic_acid     [label="Platelet Sialic Acid\nAnti-phagocytic shield",     fillcolor="#22aa55", fontcolor="black"];
    Platelet_surface [label="Platelet Membrane\n(phosphatidylserine)",         fillcolor="#009944", fontcolor="white"];
  }

  /* ================================================================
     CLUSTER 2 — B Cell Activation & Antibody Production
     ================================================================ */
  subgraph cluster_bcell {
    label="B Cell Activation & Antibody Production";
    fontcolor="white"; fontsize=12; fontname="Helvetica-Bold";
    style=filled; bgcolor="#0f0f2a"; color="#6688ff";

    Naive_Bcell      [label="Naïve B Cell\n(CD20+ CD27−)",                     fillcolor="#3355cc", fontcolor="white"];
    GC_Bcell         [label="Germinal Center B Cell\n(BCL6+ AID+)",             fillcolor="#3355cc", fontcolor="white"];
    Memory_Bcell     [label="Memory B Cell\n(CD20+ CD27+)",                     fillcolor="#3355cc", fontcolor="white"];
    Short_plasma     [label="Short-lived Plasma Cell\n(CD138+ CD20−)",          fillcolor="#2244bb", fontcolor="white"];
    Long_plasma      [label="Long-lived BMPC\n(CD138+ CD38hi CD20−)",           fillcolor="#2244bb", fontcolor="white"];
    Anti_GPIIb_IgG   [label="Anti-αIIbβ3 IgG\n(primary pathogenic Ab)",        fillcolor="#6688ff", fontcolor="black"];
    Anti_GPIb_IgG    [label="Anti-GPIb/IX IgG\n(hepatic desialylation path)",   fillcolor="#6688ff", fontcolor="black"];
    Anti_plt_IgM     [label="Anti-platelet IgM\n(early/complement-fixing)",     fillcolor="#5577ee", fontcolor="black"];
    Total_IgG        [label="Total Serum IgG\n(~10 g/L normal)",               fillcolor="#4466dd", fontcolor="white"];
    CD20_antigen     [label="CD20 Antigen\n(B cell membrane)",                  fillcolor="#2244bb", fontcolor="white"];
    BAFF             [label="BAFF / BLyS\n(B cell survival factor)",             fillcolor="#4466dd", fontcolor="white"];
    APRIL            [label="APRIL\n(plasma cell survival)",                     fillcolor="#4466dd", fontcolor="white"];
    FcRn             [label="FcRn\n(neonatal Fc receptor, IgG recycling)",       fillcolor="#2244bb", fontcolor="white"];
  }

  /* ================================================================
     CLUSTER 3 — T Cell Dysregulation
     ================================================================ */
  subgraph cluster_tcell {
    label="T Cell Dysregulation";
    fontcolor="white"; fontsize=12; fontname="Helvetica-Bold";
    style=filled; bgcolor="#2a0f0f"; color="#ff6666";

    Naive_CD4   [label="Naïve CD4+ T Cell\n(CD45RA+)",                         fillcolor="#cc3333", fontcolor="white"];
    Th1_cell    [label="Th1 Cell\n(T-bet+, IFN-γ↑)",                           fillcolor="#cc3333", fontcolor="white"];
    Th2_cell    [label="Th2 Cell\n(GATA3+, IL-4/IL-13)",                        fillcolor="#cc3333", fontcolor="white"];
    Th17_cell   [label="Th17 Cell ↑↑\n(RORγt+, IL-17A/F↑)",                    fillcolor="#ff4444", fontcolor="white"];
    Treg_cell   [label="Treg Cell ↓↓\n(FoxP3+ CD25hi) DEFICIENT",              fillcolor="#cc9900", fontcolor="black"];
    Tfh_cell    [label="Tfh Cell ↑\n(CXCR5+ PD-1+ BCL6+)",                     fillcolor="#cc3333", fontcolor="white"];
    CD8_Tcell   [label="CD8+ CTL\n(Perforin+ Granzyme B+)",                     fillcolor="#cc3333", fontcolor="white"];
    IL2_cyto    [label="IL-2\n(T cell proliferation)",                           fillcolor="#ee5555", fontcolor="white"];
    IFN_gamma   [label="IFN-γ\n(macrophage activation)",                         fillcolor="#ee5555", fontcolor="white"];
    IL17_cyto   [label="IL-17A\n(pro-inflammatory)",                             fillcolor="#ee5555", fontcolor="white"];
    TGF_beta    [label="TGF-β\n(Treg induction / fibrosis)",                     fillcolor="#cc9900", fontcolor="black"];
    IL21_cyto   [label="IL-21\n(GC formation / B cell help)",                    fillcolor="#ee5555", fontcolor="white"];
  }

  /* ================================================================
     CLUSTER 4 — Innate Immunity & Antigen Presentation
     ================================================================ */
  subgraph cluster_innate {
    label="Innate Immunity & Antigen Presentation";
    fontcolor="white"; fontsize=12; fontname="Helvetica-Bold";
    style=filled; bgcolor="#220a22"; color="#cc66cc";

    pDC            [label="Plasmacytoid DC\n(BDCA-2+ ILT7+)",                   fillcolor="#994499", fontcolor="white"];
    mDC            [label="Myeloid DC\n(CD1c+ HLA-DR++)",                        fillcolor="#994499", fontcolor="white"];
    Monocyte       [label="Monocyte\n(CD14+ CD16+)",                             fillcolor="#aa55aa", fontcolor="white"];
    Macrophage_gen [label="Tissue Macrophage\n(CD68+ MRC1+)",                    fillcolor="#aa55aa", fontcolor="white"];
    FcgRI_CD64     [label="FcγRI (CD64)\nHigh-affinity IgG receptor",            fillcolor="#cc66cc", fontcolor="black"];
    FcgRIIA_CD32a  [label="FcγRIIA (CD32a)\nActivating ITAM motif",             fillcolor="#cc66cc", fontcolor="black"];
    FcgRIIB_CD32b  [label="FcγRIIB (CD32b)\nInhibitory ITIM motif",             fillcolor="#9944aa", fontcolor="white"];
    FcgRIIIA_CD16a [label="FcγRIIIA (CD16a)\nNK / monocyte ADCC",               fillcolor="#cc66cc", fontcolor="black"];
    TNF_alpha      [label="TNF-α\n(pro-inflammatory)",                            fillcolor="#cc66cc", fontcolor="black"];
    IL6_cyto       [label="IL-6\n(acute phase / Th17 driver)",                    fillcolor="#cc66cc", fontcolor="black"];
    IL1_beta       [label="IL-1β\n(inflammasome / NLRP3)",                        fillcolor="#cc66cc", fontcolor="black"];
    IL10_cyto      [label="IL-10\n(anti-inflammatory / B cell survival)",          fillcolor="#7733aa", fontcolor="white"];
  }

  /* ================================================================
     CLUSTER 5 — Splenic Platelet Destruction
     ================================================================ */
  subgraph cluster_spleen {
    label="Splenic Platelet Destruction";
    fontcolor="white"; fontsize=12; fontname="Helvetica-Bold";
    style=filled; bgcolor="#2a1f00"; color="#ffaa00";

    Spleen_RP_mac    [label="Red Pulp Macrophage\n(Spleen, F4/80+ VCAM1+)",     fillcolor="#cc8800", fontcolor="white"];
    Spleen_MZ_mac    [label="Marginal Zone Mac\n(CD169+ SIGN-R1+)",              fillcolor="#cc8800", fontcolor="white"];
    Opsonized_plt    [label="Ab-opsonized Platelet\n(IgG+ platelet)",            fillcolor="#ffaa00", fontcolor="black"];
    SYK_kinase       [label="SYK Kinase\n(FcγR ITAM signaling)",                 fillcolor="#ffcc00", fontcolor="black"];
    PI3K_spleen      [label="PI3Kδ/γ\n(downstream SYK)",                         fillcolor="#ffaa00", fontcolor="black"];
    MAPK_ERK         [label="MAPK / ERK\n(phagocytosis signaling)",              fillcolor="#ffaa00", fontcolor="black"];
    Phagocytic_cup   [label="Phagocytic Cup\n(actin remodeling)",                fillcolor="#dd9900", fontcolor="white"];
    Phagolysosome    [label="Phagolysosome\n(platelet degradation)",             fillcolor="#cc8800", fontcolor="white"];
    Plt_clearance_sp [label="Splenic Platelet Clearance\n(×3–10× normal)",       fillcolor="#ff8800", fontcolor="white"];
    Antigen_release  [label="Platelet Antigen Release\n(→ APC cross-presentation)",fillcolor="#ffaa00", fontcolor="black"];
  }

  /* ================================================================
     CLUSTER 6 — Complement Activation
     ================================================================ */
  subgraph cluster_complement {
    label="Complement Activation Pathway";
    fontcolor="white"; fontsize=12; fontname="Helvetica-Bold";
    style=filled; bgcolor="#001f2a"; color="#00cccc";

    C1q           [label="C1q\n(classical pathway initiator)",                   fillcolor="#009999", fontcolor="white"];
    C3b_opsonin   [label="C3b\n(opsonin coating)",                               fillcolor="#00aaaa", fontcolor="white"];
    C3_convertase [label="C3 Convertase\n(C4b2a)",                               fillcolor="#009999", fontcolor="white"];
    C5a_anaph     [label="C5a\n(anaphylatoxin / chemotaxis)",                    fillcolor="#00cccc", fontcolor="black"];
    MAC_C5b9      [label="MAC (C5b-9)\n(membrane attack complex)",               fillcolor="#009999", fontcolor="white"];
    CR3_rec       [label="CR3 (CD11b/CD18)\n(complement receptor 3)",            fillcolor="#00aaaa", fontcolor="white"];
    Factor_H      [label="Factor H\n(complement regulator)",                     fillcolor="#007777", fontcolor="white"];
    Comp_plt_lysis [label="Complement-mediated\nPlatelet Lysis",                  fillcolor="#00cccc", fontcolor="black"];
  }

  /* ================================================================
     CLUSTER 7 — Bone Marrow Megakaryopoiesis
     ================================================================ */
  subgraph cluster_bm {
    label="Bone Marrow — Megakaryopoiesis";
    fontcolor="white"; fontsize=12; fontname="Helvetica-Bold";
    style=filled; bgcolor="#111111"; color="#aaaaaa";

    HSC             [label="HSC (CD34+)\nHematopoietic stem cell",               fillcolor="#555555", fontcolor="white"];
    CMP             [label="CMP\nCommon Myeloid Progenitor",                      fillcolor="#666666", fontcolor="white"];
    MEP             [label="MEP\nMeg-Erythroid Progenitor",                       fillcolor="#777777", fontcolor="white"];
    Megakaryoblast  [label="Megakaryoblast\n(2N, endomitosis begins)",            fillcolor="#888888", fontcolor="white"];
    Promegakaryocyte[label="Promegakaryocyte\n(8–32N, granule formation)",        fillcolor="#999999", fontcolor="black"];
    Megakaryocyte   [label="Megakaryocyte\n(64–128N, α-granule / DMS)",           fillcolor="#bbbbbb", fontcolor="black"];
    Proplatelet     [label="Proplatelet\n(sinusoid extension)",                    fillcolor="#dddddd", fontcolor="black"];
    TPO_bm          [label="Thrombopoietin (TPO)\n(liver-produced, platelet-regulated)", fillcolor="#aaaaaa", fontcolor="black"];
    cMpl            [label="c-Mpl (TPO-R)\n(CD110, TPOR)",                        fillcolor="#999999", fontcolor="black"];
    JAK2_BM         [label="JAK2\n(c-Mpl signaling kinase)",                      fillcolor="#888888", fontcolor="white"];
    STAT5_BM        [label="STAT3 / STAT5\n(transcription factors)",              fillcolor="#777777", fontcolor="white"];
    BM_Ab_inhibit   [label="Anti-MK Antibody\n(GPIIb/IIIa on MK surface)",       fillcolor="#cc5555", fontcolor="white"];
  }

  /* ================================================================
     CLUSTER 8 — Platelet Kinetics & Clearance
     ================================================================ */
  subgraph cluster_kinetics {
    label="Platelet Kinetics & Clearance";
    fontcolor="white"; fontsize=12; fontname="Helvetica-Bold";
    style=filled; bgcolor="#0f1a08"; color="#88ff66";

    Circ_plt_pool   [label="Circulating Platelet Pool\n(150–400 ×10⁹/L normal)",   fillcolor="#44bb22", fontcolor="white"];
    Sp_plt_pool     [label="Splenic Platelet Pool\n(~33% total)",                   fillcolor="#55cc33", fontcolor="white"];
    Plt_aging       [label="Platelet Aging\n(8–10 days normal lifespan)",           fillcolor="#66bb44", fontcolor="white"];
    Reduced_lifespan[label="Reduced Platelet Lifespan\n(<1 day in active ITP)",     fillcolor="#ff4444", fontcolor="white"];
    Desialylation   [label="Platelet Desialylation\n(Anti-GPIb → neuraminidase)",   fillcolor="#88cc66", fontcolor="black"];
    Ashwell_Morell  [label="Ashwell-Morell Receptor\n(Liver, Gal/GalNAc-R)",        fillcolor="#66aa44", fontcolor="white"];
    Hepatic_plt_clear[label="Hepatic Platelet Clearance\n(AMR-mediated)",           fillcolor="#55aa33", fontcolor="white"];
    Plt_activation  [label="Platelet Activation\n(GC, P-selectin exposure)",        fillcolor="#77bb55", fontcolor="white"];
  }

  /* ================================================================
     CLUSTER 9 — Drug Pharmacokinetics
     ================================================================ */
  subgraph cluster_drug_pk {
    label="Drug Pharmacokinetics";
    fontcolor="white"; fontsize=12; fontname="Helvetica-Bold";
    style=filled; bgcolor="#2a0f00"; color="#ff9966";

    Prednisone       [label="Prednisone/Prednisolone\n(1 mg/kg/d PO → taper)",    fillcolor="#cc4411", fontcolor="white"];
    Dexamethasone    [label="Dexamethasone\n(40 mg/d × 4d high-dose pulse)",       fillcolor="#cc4411", fontcolor="white"];
    IVIG_drug        [label="IVIG\n(1 g/kg IV × 2d)",                              fillcolor="#dd6633", fontcolor="white"];
    Romiplostim      [label="Romiplostim\n(1–10 μg/kg SC weekly, peptibody)",       fillcolor="#cc5522", fontcolor="white"];
    Eltrombopag      [label="Eltrombopag\n(25–75 mg PO QD, oral TPO-RA)",          fillcolor="#cc5522", fontcolor="white"];
    Avatrombopag     [label="Avatrombopag\n(20–40 mg PO QD)",                       fillcolor="#cc5522", fontcolor="white"];
    Rituximab        [label="Rituximab\n(375 mg/m² IV ×4 weekly)",                  fillcolor="#dd6644", fontcolor="white"];
    Fostamatinib     [label="Fostamatinib\n(100–150 mg PO BID, prodrug)",           fillcolor="#ee7755", fontcolor="white"];
    R788_active      [label="R788 (Tamatinib)\n(active SYK inhibitor)",             fillcolor="#ff8866", fontcolor="black"];
    Efgartigimod     [label="Efgartigimod\n(10 mg/kg IV q1w, FcRn blocker)",        fillcolor="#ee6644", fontcolor="white"];
    Rozanolixizumab  [label="Rozanolixizumab\n(SC FcRn inhibitor)",                 fillcolor="#ee6644", fontcolor="white"];
    Daratumumab      [label="Daratumumab\n(anti-CD38, BMPC depletion)",             fillcolor="#dd5533", fontcolor="white"];
    Cyclosporine_A   [label="Cyclosporine A\n(3–5 mg/kg/d, calcineurin inh.)",     fillcolor="#cc4422", fontcolor="white"];
    Splenectomy      [label="Splenectomy\n(surgical, CR ~66%)",                     fillcolor="#bb3311", fontcolor="white"];
  }

  /* ================================================================
     CLUSTER 10 — Clinical Endpoints & Outcomes
     ================================================================ */
  subgraph cluster_endpoints {
    label="Clinical Endpoints & Outcomes";
    fontcolor="white"; fontsize=12; fontname="Helvetica-Bold";
    style=filled; bgcolor="#0a0a20"; color="#8888ff";

    Plt_count      [label="Platelet Count\n(primary endpoint, ×10⁹/L)",           fillcolor="#4455cc", fontcolor="white"];
    Bleeding_score [label="Bleeding Score\n(WHO grade / ITP-BAT)",                 fillcolor="#5566dd", fontcolor="white"];
    CR_response    [label="Complete Response (CR)\n(PLT ≥100 ×10⁹/L ×2 meas.)",   fillcolor="#3344bb", fontcolor="white"];
    Partial_resp   [label="Partial Response (R)\n(PLT 30–99 ×10⁹/L ×2 meas.)",    fillcolor="#3344bb", fontcolor="white"];
    No_response    [label="No Response (NR)\n(PLT <30 ×10⁹/L)",                    fillcolor="#5544aa", fontcolor="white"];
    Severe_ITP     [label="Severe ITP\n(PLT <20 ×10⁹/L, high bleed risk)",         fillcolor="#ee2222", fontcolor="white"];
    ICH_risk       [label="ICH Risk\n(intracranial hemorrhage, ~0.2–0.5%/yr)",      fillcolor="#dd1111", fontcolor="white"];
    Fatigue_QoL    [label="Fatigue / HRQoL\n(FACT-Th, ITP-specific QoL)",          fillcolor="#6677dd", fontcolor="white"];
    TFR            [label="Treatment-Free Remission\n(TFR, durable off-therapy CR)", fillcolor="#4466cc", fontcolor="white"];
    Bleeding_event [label="Major Bleeding Event\n(CTCAE ≥ grade 3)",               fillcolor="#ee3333", fontcolor="white"];
  }

  /* ================================================================
     EDGES — ANTIGEN → B CELL
     ================================================================ */
  GPIIb_IIIa     -> Anti_GPIIb_IgG   [label="primary target\nantigen",      color="#6688ff"];
  GPIb_IX_V      -> Anti_GPIb_IgG    [label="secondary target\nantigen",     color="#6688ff"];
  GPIIb_IIIa     -> GC_Bcell         [label="Ag presentation",               color="#6688ff"];
  GPIb_IX_V      -> GC_Bcell         [label="Ag presentation",               color="#6688ff"];
  Platelet_surface -> C1q            [label="IgM binding site",              color="#00cccc"];
  Antigen_release -> mDC             [label="released platelet Ags",         color="#cc66cc"];
  mDC            -> Naive_CD4        [label="MHC II Ag\npresentation",       color="#cc66cc"];
  mDC            -> GC_Bcell         [label="T-B zone\ncooperation",         color="#cc66cc"];

  /* ================================================================
     EDGES — B CELL PATHWAY
     ================================================================ */
  Naive_Bcell    -> GC_Bcell         [label="activation",                    color="#6688ff"];
  GC_Bcell       -> Memory_Bcell     [color="#6688ff"];
  GC_Bcell       -> Short_plasma     [color="#6688ff"];
  Memory_Bcell   -> Short_plasma     [label="re-activation",                 color="#6688ff"];
  Short_plasma   -> Anti_GPIIb_IgG   [label="secrete",                       color="#6688ff"];
  Short_plasma   -> Anti_GPIb_IgG    [label="secrete",                       color="#6688ff"];
  Short_plasma   -> Long_plasma      [label="differentiation",               color="#6688ff"];
  Long_plasma    -> Anti_GPIIb_IgG   [label="persistent\nsecretion",         color="#2244bb"];
  Long_plasma    -> Anti_plt_IgM     [label="IgM early",                     color="#5577ee"];
  Anti_plt_IgM   -> C1q              [label="classical\ncomplement",         color="#00cccc"];
  Anti_GPIIb_IgG -> C1q              [label="Fc-mediated C1q\nbinding",      color="#00cccc"];
  BAFF           -> Naive_Bcell      [label="survival",                      color="#6688ff"];
  BAFF           -> Memory_Bcell     [label="survival",                      color="#6688ff"];
  APRIL          -> Long_plasma      [label="survival",                      color="#6688ff"];
  FcRn           -> Total_IgG        [label="IgG half-life\nregulation",     color="#6688ff"];
  Total_IgG      -> Anti_GPIIb_IgG   [label="contributes to",               color="#4466dd"];
  Total_IgG      -> Anti_GPIb_IgG    [label="contributes to",               color="#4466dd"];

  /* ================================================================
     EDGES — T CELL DYSREGULATION
     ================================================================ */
  Naive_CD4      -> Th1_cell         [label="IL-12 driven",                  color="#cc3333"];
  Naive_CD4      -> Th17_cell        [label="IL-6 + TGF-β",                  color="#cc3333"];
  Naive_CD4      -> Treg_cell        [label="TGF-β only",                    color="#cc9900"];
  Naive_CD4      -> Tfh_cell         [label="ICOS / CXCR5",                  color="#cc3333"];
  Tfh_cell       -> GC_Bcell         [label="T-B cooperation\nCD40L/IL-21",  color="#ff6666"];
  IL21_cyto      -> GC_Bcell         [label="GC formation",                  color="#ff6666"];
  Th17_cell      -> BAFF             [label="BAFF ↑",                        color="#ff6666"];
  Th17_cell      -> IL17_cyto        [label="produce",                       color="#cc3333"];
  IL17_cyto      -> Macrophage_gen   [label="activate",                      color="#cc66cc"];
  IFN_gamma      -> Macrophage_gen   [label="macrophage\nactivation",        color="#ff6666"];
  IFN_gamma      -> Spleen_RP_mac    [label="prime\nphagocytosis",           color="#ff6666"];
  Th1_cell       -> IFN_gamma        [label="produce",                       color="#cc3333"];
  TGF_beta       -> Treg_cell        [label="induction",                     color="#cc9900"];
  Treg_cell      -> GC_Bcell         [label="suppress ↓",                    color="#cc9900", style=dashed];
  Treg_cell      -> Short_plasma     [label="suppress ↓",                    color="#cc9900", style=dashed];
  Treg_cell      -> Th17_cell        [label="inhibit ↓",                     color="#cc9900", style=dashed];
  CD8_Tcell      -> Megakaryocyte    [label="direct MK\ncytotoxicity",       color="#ff4444", style=dashed];
  IL2_cyto       -> CD8_Tcell        [label="expand CTL",                    color="#cc3333"];

  /* ================================================================
     EDGES — INNATE IMMUNITY
     ================================================================ */
  pDC            -> IFN_gamma        [label="type I IFN\n→ IFN-γ axis",      color="#cc66cc"];
  pDC            -> Naive_Bcell      [label="B cell\nactivation",            color="#cc66cc"];
  Monocyte       -> Macrophage_gen   [label="differentiate",                 color="#aa55aa"];
  Macrophage_gen -> TNF_alpha        [label="produce",                       color="#cc66cc"];
  Macrophage_gen -> IL6_cyto         [label="produce",                       color="#cc66cc"];
  Macrophage_gen -> IL1_beta         [label="produce",                       color="#cc66cc"];
  TNF_alpha      -> Naive_Bcell      [label="co-stimulate",                  color="#cc66cc"];
  IL6_cyto       -> Short_plasma     [label="plasma cell\nsurvival",         color="#cc66cc"];
  IL6_cyto       -> Th17_cell        [label="Th17\ndifferentiation",         color="#cc66cc"];
  IL10_cyto      -> GC_Bcell         [label="support",                       color="#7733aa"];
  IL10_cyto      -> Short_plasma     [label="survival",                      color="#7733aa"];
  FcgRIIB_CD32b  -> SYK_kinase       [label="inhibitory\nITIM signaling",    color="#9944aa", style=dashed];

  /* ================================================================
     EDGES — SPLENIC DESTRUCTION
     ================================================================ */
  Anti_GPIIb_IgG  -> Opsonized_plt   [label="opsonize",                      color="#ffaa00"];
  Anti_GPIb_IgG   -> Opsonized_plt   [label="opsonize",                      color="#ffaa00"];
  C3b_opsonin     -> Opsonized_plt   [label="co-opsonize",                   color="#00cccc"];
  Opsonized_plt   -> FcgRI_CD64      [label="bind FcγRI\n(high affinity)",   color="#ffaa00"];
  Opsonized_plt   -> FcgRIIA_CD32a   [label="bind FcγRIIA",                  color="#ffaa00"];
  Opsonized_plt   -> FcgRIIIA_CD16a  [label="bind FcγRIIIA",                 color="#ffaa00"];
  Opsonized_plt   -> Spleen_RP_mac   [label="phagocytosis",                  color="#ffaa00"];
  Opsonized_plt   -> Spleen_MZ_mac   [label="marginal zone\nclearance",      color="#ffaa00"];
  FcgRI_CD64      -> SYK_kinase      [label="ITAM\nsignaling",               color="#ffcc00"];
  FcgRIIA_CD32a   -> SYK_kinase      [label="ITAM\nsignaling",               color="#ffcc00"];
  SYK_kinase      -> PI3K_spleen     [color="#ffaa00"];
  SYK_kinase      -> MAPK_ERK        [color="#ffaa00"];
  PI3K_spleen     -> Phagocytic_cup  [color="#ffaa00"];
  MAPK_ERK        -> Phagocytic_cup  [color="#ffaa00"];
  Phagocytic_cup  -> Phagolysosome   [label="internalize",                   color="#ffaa00"];
  Phagolysosome   -> Plt_clearance_sp [label="degradation",                  color="#ffaa00"];
  Phagolysosome   -> Antigen_release [label="Ag\nprocessing",                color="#cc66cc"];
  Spleen_RP_mac   -> Plt_clearance_sp [color="#ffaa00"];
  Spleen_MZ_mac   -> Plt_clearance_sp [color="#ffaa00"];
  C5a_anaph       -> Spleen_RP_mac   [label="recruit/activate",              color="#00cccc"];

  /* ================================================================
     EDGES — COMPLEMENT
     ================================================================ */
  C1q             -> C3_convertase   [label="C1s/C1r\nactivation",           color="#00cccc"];
  C3_convertase   -> C3b_opsonin     [label="cleave C3",                     color="#00cccc"];
  C3b_opsonin     -> CR3_rec         [label="bind CR3",                      color="#00cccc"];
  CR3_rec         -> Phagocytic_cup  [label="enhance\nphagocytosis",         color="#00cccc"];
  C3_convertase   -> C5a_anaph       [label="cleave C5",                     color="#00cccc"];
  C5a_anaph       -> MAC_C5b9        [label="assemble\nC5b-9",               color="#00cccc"];
  MAC_C5b9        -> Comp_plt_lysis  [label="membrane\nlysis",               color="#00cccc"];
  Comp_plt_lysis  -> Reduced_lifespan [label="accelerated\nclearance",       color="#ff4444"];
  Factor_H        -> C3_convertase   [label="inhibit\n(regulate)",           color="#007777", style=dashed];

  /* ================================================================
     EDGES — MEGAKARYOPOIESIS
     ================================================================ */
  HSC             -> CMP             [color="#aaaaaa"];
  CMP             -> MEP             [color="#aaaaaa"];
  MEP             -> Megakaryoblast  [label="TPO signal",                    color="#aaaaaa"];
  Megakaryoblast  -> Promegakaryocyte [label="endomitosis",                  color="#aaaaaa"];
  Promegakaryocyte -> Megakaryocyte  [label="polyploidization\n+ granule",   color="#aaaaaa"];
  Megakaryocyte   -> Proplatelet     [label="proplatelet\nformation",        color="#cccccc"];
  Proplatelet     -> Circ_plt_pool   [label="platelet\nrelease",             color="#88ff66"];
  TPO_bm          -> cMpl            [label="ligand binding",                color="#cccccc"];
  cMpl            -> JAK2_BM         [label="activate",                      color="#cccccc"];
  JAK2_BM         -> STAT5_BM        [label="phosphorylate",                 color="#aaaaaa"];
  STAT5_BM        -> Megakaryoblast  [label="proliferation",                 color="#aaaaaa"];
  STAT5_BM        -> Promegakaryocyte [label="maturation",                   color="#aaaaaa"];
  Anti_GPIIb_IgG  -> BM_Ab_inhibit   [label="Ab penetrates BM",             color="#ff4444"];
  BM_Ab_inhibit   -> Megakaryocyte   [label="impair maturation ↓",          color="#ff4444", style=dashed];
  BM_Ab_inhibit   -> Proplatelet     [label="inhibit release ↓",            color="#ff4444", style=dashed];
  Circ_plt_pool   -> TPO_bm          [label="TPO scavenging\n(feedback ↓)", color="#88ff66", style=dashed, dir=back];

  /* ================================================================
     EDGES — PLATELET KINETICS
     ================================================================ */
  Circ_plt_pool   -> Sp_plt_pool     [label="sequester 33%",                 color="#88ff66"];
  Sp_plt_pool     -> Circ_plt_pool   [label="release\n(equilibrium)",        color="#88ff66"];
  Circ_plt_pool   -> Plt_aging       [label="normal aging\n8–10 days",       color="#88ff66"];
  Plt_aging       -> Desialylation   [label="sialic acid\nloss with age",    color="#88ff66"];
  Desialylation   -> Ashwell_Morell  [label="Gal receptor\n(liver)",         color="#66aa44"];
  Ashwell_Morell  -> Hepatic_plt_clear [label="hepatic\nclearance",          color="#66aa44"];
  Plt_clearance_sp -> Reduced_lifespan [label="ITP-specific\ndestruction",   color="#ff4444"];
  Anti_GPIb_IgG   -> Desialylation   [label="Ab induces\ndesialylation ↑",  color="#6688ff"];
  Plt_activation  -> P_selectin      [label="P-sel exposure",                color="#00cc66"];
  Opsonized_plt   -> Plt_activation  [label="Ab induces\nactivation",        color="#ffaa00"];

  /* ================================================================
     EDGES — DRUG PD EFFECTS
     ================================================================ */
  // Corticosteroids
  Prednisone      -> Naive_Bcell     [label="B cell suppress ↓", color="#ff9966", style=dashed];
  Prednisone      -> Short_plasma    [label="apoptosis ↑",       color="#ff9966", style=dashed];
  Prednisone      -> Treg_cell       [label="Treg ↑",            color="#ffcc00"];
  Prednisone      -> FcgRI_CD64      [label="FcR ↓",             color="#ff9966", style=dashed];
  Prednisone      -> FcgRIIA_CD32a   [label="FcR ↓",             color="#ff9966", style=dashed];
  Prednisone      -> Anti_GPIIb_IgG  [label="Ab ↓ (indirect)",   color="#ff9966", style=dashed];
  Dexamethasone   -> Short_plasma    [label="pulse apoptosis",    color="#ff9966", style=dashed];
  Dexamethasone   -> Treg_cell       [label="Treg ↑↑",           color="#ffcc00"];
  Dexamethasone   -> Megakaryocyte   [label="MK survival ↑",     color="#ffcc00"];

  // IVIG
  IVIG_drug       -> FcgRI_CD64      [label="Fc receptor\ncompetitive block", color="#ff9966", style=dashed];
  IVIG_drug       -> FcgRIIA_CD32a   [label="block ↓",           color="#ff9966", style=dashed];
  IVIG_drug       -> FcRn            [label="FcRn saturation\n→ IgG↑ catabolism", color="#ff9966"];
  IVIG_drug       -> Treg_cell       [label="Treg ↑",            color="#ffcc00"];
  IVIG_drug       -> IL10_cyto       [label="IL-10 ↑",           color="#ff9966"];
  IVIG_drug       -> Factor_H        [label="complement\nregulation",  color="#00cccc"];

  // TPO receptor agonists
  Romiplostim     -> cMpl            [label="TPO-R peptibody\nagonist", color="#ff9966"];
  Eltrombopag     -> JAK2_BM         [label="non-peptide\nTPO-R agonist", color="#ff9966"];
  Avatrombopag    -> cMpl            [label="oral TPO-R\nagonist", color="#ff9966"];
  Eltrombopag     -> IL10_cyto       [label="immune modulation\n(Treg ↑?)", color="#ff9966"];

  // Rituximab
  Rituximab       -> CD20_antigen    [label="anti-CD20\nbinding",    color="#ff9966"];
  CD20_antigen    -> Naive_Bcell     [label="deplete ↓",             color="#ff4444", style=dashed];
  CD20_antigen    -> Memory_Bcell    [label="deplete ↓",             color="#ff4444", style=dashed];
  CD20_antigen    -> GC_Bcell        [label="deplete ↓",             color="#ff4444", style=dashed];
  Rituximab       -> Short_plasma    [label="ADCC / CDC",            color="#ff9966", style=dashed];

  // Fostamatinib → R788
  Fostamatinib    -> R788_active     [label="prodrug conversion\n(CYP3A4)", color="#ff9966"];
  R788_active     -> SYK_kinase      [label="SYK inhibition\n(ATP-competitive)", color="#ff9966", style=dashed];
  R788_active     -> FcgRIIA_CD32a   [label="ITAM signaling\nblocked", color="#ff9966", style=dashed];
  R788_active     -> PI3K_spleen     [label="PI3Kδ downstream\nblocked", color="#ff9966", style=dashed];

  // FcRn inhibitors
  Efgartigimod    -> FcRn            [label="FcRn blockade\n→ IgG half-life ↓", color="#ff9966"];
  Rozanolixizumab -> FcRn            [label="FcRn blockade",         color="#ff9966"];
  FcRn            -> Anti_GPIIb_IgG  [label="regulate\nhalf-life",   color="#6688ff"];
  FcRn            -> Anti_GPIb_IgG   [label="regulate\nhalf-life",   color="#6688ff"];

  // Daratumumab
  Daratumumab     -> Long_plasma     [label="anti-CD38\ndeplete BMPC ↓", color="#ff9966", style=dashed];

  // Cyclosporine
  Cyclosporine_A  -> Naive_CD4       [label="calcineurin\ninhibition", color="#ff9966", style=dashed];
  Cyclosporine_A  -> Th17_cell       [label="T cell\nsuppression ↓", color="#ff9966", style=dashed];
  Cyclosporine_A  -> IL2_cyto        [label="IL-2 ↓",                 color="#ff9966", style=dashed];

  // Splenectomy
  Splenectomy     -> Spleen_RP_mac   [label="removes spleen",         color="#ff9966", style=dashed];
  Splenectomy     -> Spleen_MZ_mac   [label="removes",                color="#ff9966", style=dashed];
  Splenectomy     -> Sp_plt_pool     [label="removes\nsplenic pool",  color="#ff9966", style=dashed];

  /* ================================================================
     EDGES — CLINICAL ENDPOINTS
     ================================================================ */
  Circ_plt_pool   -> Plt_count       [color="#8888ff"];
  Plt_count       -> Bleeding_score  [label="inversely\nrelated",     color="#8888ff"];
  Plt_count       -> CR_response     [label="PLT ≥100",               color="#3344bb"];
  Plt_count       -> Partial_resp    [label="PLT 30–99",              color="#3344bb"];
  Plt_count       -> No_response     [label="PLT <30",                color="#5544aa"];
  Plt_count       -> Severe_ITP      [label="PLT <20",                color="#ee2222"];
  Severe_ITP      -> ICH_risk        [label="risk ↑↑↑",               color="#ee2222"];
  Bleeding_score  -> Bleeding_event  [color="#ee2222"];
  ICH_risk        -> Bleeding_event  [color="#ee2222"];
  Plt_count       -> Fatigue_QoL     [label="HRQoL impact",           color="#6677dd"];
  CR_response     -> TFR             [label="sustained CR\n≥1 year",  color="#4455cc"];
}
