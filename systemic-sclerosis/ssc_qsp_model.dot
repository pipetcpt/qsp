digraph SSc_QSP_Model {
    graph [
        label="Systemic Sclerosis (Scleroderma) QSP Mechanistic Map\nVasculopathy · Autoimmunity · Fibrosis · Organ Manifestations",
        labelloc=t, labeljust=c,
        fontname="Helvetica", fontsize=22, fontcolor="#1a1a2e",
        bgcolor="#f8f9fa",
        rankdir=TB,
        splines=ortho,
        nodesep=0.4,
        ranksep=0.7,
        compound=true
    ]
    node [fontname="Helvetica", fontsize=10, style="filled,rounded", shape=box, margin="0.15,0.08"]
    edge [fontname="Helvetica", fontsize=8, arrowsize=0.7]

    // ─────────────────────────────────────────────
    // CLUSTER 1: Environmental / Genetic Triggers
    // ─────────────────────────────────────────────
    subgraph cluster_triggers {
        label="Triggers & Genetic Predisposition"
        style=filled; fillcolor="#e8f4f8"; color="#2c7bb6"; penwidth=2
        fontname="Helvetica Bold"; fontsize=13; fontcolor="#2c7bb6"

        GENET [label="Genetic Risk\n(HLA-DQ/DR, IRF5\nSTAT4, CD247)", fillcolor="#aed6f1"]
        EPIGEN [label="Epigenetic\nAlterations\n(DNA methylation)", fillcolor="#aed6f1"]
        MICRO [label="Microbiome\nDysbiosis", fillcolor="#aed6f1"]
        CHEMIC [label="Chemical/\nOccupational\nExposure", fillcolor="#aed6f1"]
        VIRAL [label="Viral Triggers\n(CMV, EBV,\nHHV-5)", fillcolor="#aed6f1"]
        OXSTRESS [label="Oxidative\nStress\n(ROS)", fillcolor="#f9e79f"]
    }

    // ─────────────────────────────────────────────
    // CLUSTER 2: Innate Immune Activation
    // ─────────────────────────────────────────────
    subgraph cluster_innate {
        label="Innate Immune System"
        style=filled; fillcolor="#fef9e7"; color="#f39c12"; penwidth=2
        fontname="Helvetica Bold"; fontsize=13; fontcolor="#f39c12"

        PDC [label="Plasmacytoid\nDendritic Cells\n(pDC)", fillcolor="#fad7a0"]
        MDC [label="Myeloid\nDendritic Cells\n(mDC)", fillcolor="#fad7a0"]
        MACRO [label="Macrophages\n(M1/M2\npolarization)", fillcolor="#fad7a0"]
        MAST [label="Mast Cells", fillcolor="#fad7a0"]
        NK [label="NK Cells", fillcolor="#fad7a0"]
        IFNa [label="IFN-α/β\n(Type I IFN\nsignature)", fillcolor="#f9e79f"]
        IFNg [label="IFN-γ\n(Type II IFN)", fillcolor="#f9e79f"]
        TNF [label="TNF-α", fillcolor="#f9e79f"]
        IL1B [label="IL-1β", fillcolor="#f9e79f"]
        IL6 [label="IL-6", fillcolor="#f9e79f"]
        IL4 [label="IL-4/IL-13\n(Th2 cytokines)", fillcolor="#f9e79f"]
        IL10 [label="IL-10\n(regulatory)", fillcolor="#d5f5e3"]
        NLRP3 [label="NLRP3\nInflammasome", fillcolor="#fad7a0"]
        TLR [label="TLR Activation\n(TLR3/7/9)", fillcolor="#fad7a0"]
    }

    // ─────────────────────────────────────────────
    // CLUSTER 3: Adaptive Immune Response
    // ─────────────────────────────────────────────
    subgraph cluster_adaptive {
        label="Adaptive Immune System"
        style=filled; fillcolor="#eafaf1"; color="#27ae60"; penwidth=2
        fontname="Helvetica Bold"; fontsize=13; fontcolor="#27ae60"

        TH1 [label="Th1 Cells\n(IFN-γ, TNF)", fillcolor="#a9dfbf"]
        TH2 [label="Th2 Cells\n(IL-4, IL-5\nIL-13)", fillcolor="#a9dfbf"]
        TH17 [label="Th17 Cells\n(IL-17A, IL-22)", fillcolor="#a9dfbf"]
        TREG [label="Regulatory T cells\n(Treg; FoxP3+)", fillcolor="#d5f5e3"]
        CD8T [label="CD8+ CTL\n(cytotoxic)", fillcolor="#a9dfbf"]
        BCELL [label="B Cells\n(activation,\nexpansion)", fillcolor="#a9dfbf"]
        PLASMA [label="Plasma Cells\n(Ab secretion)", fillcolor="#a9dfbf"]
        GC [label="Germinal Center\nReaction", fillcolor="#a9dfbf"]
        ANA [label="Anti-nuclear Ab\n(ANA)", fillcolor="#fadbd8"]
        ANTISCL70 [label="Anti-Scl-70\n(anti-topo I)", fillcolor="#fadbd8"]
        ANTICENTRO [label="Anti-centromere\nAb (ACA)", fillcolor="#fadbd8"]
        ANTIRNAPOL [label="Anti-RNA Pol III\nAb", fillcolor="#fadbd8"]
        ANTIU3RNP [label="Anti-U3-RNP\n(fibrillarin) Ab", fillcolor="#fadbd8"]
        IL17A [label="IL-17A", fillcolor="#f9e79f"]
        IL21 [label="IL-21\n(B cell help)", fillcolor="#f9e79f"]
        IL23 [label="IL-23\n(Th17 driver)", fillcolor="#f9e79f"]
        BAFF [label="BAFF/BLyS\n(B cell survival)", fillcolor="#f9e79f"]
        APRIL [label="APRIL\n(plasma cell\nsurvival)", fillcolor="#f9e79f"]
    }

    // ─────────────────────────────────────────────
    // CLUSTER 4: Vascular Pathology
    // ─────────────────────────────────────────────
    subgraph cluster_vascular {
        label="Vascular Pathology"
        style=filled; fillcolor="#fdf2f8"; color="#8e44ad"; penwidth=2
        fontname="Helvetica Bold"; fontsize=13; fontcolor="#8e44ad"

        ENDO [label="Endothelial\nCell Injury", fillcolor="#d7bde2"]
        ENDO_ACT [label="Endothelial\nActivation\n(ICAM-1, VCAM-1\nE-selectin)", fillcolor="#d7bde2"]
        ENDO_APO [label="Endothelial\nApoptosis", fillcolor="#d7bde2"]
        VEGF [label="VEGF\n(angiogenesis\nbut aberrant)", fillcolor="#d7bde2"]
        ET1 [label="Endothelin-1\n(ET-1)\nvasoconstriction", fillcolor="#d7bde2"]
        PGI2 [label="Prostacyclin\n(PGI2)\n↓ in SSc", fillcolor="#d7bde2"]
        NO [label="Nitric Oxide\n(NO) ↓", fillcolor="#d7bde2"]
        ETAR [label="ET(A) Receptor\n(ETA-R)\nsignaling", fillcolor="#d7bde2"]
        ETBR [label="ET(B) Receptor\n(ETB-R)\nclearing ET-1", fillcolor="#d7bde2"]
        RAYNAUD [label="Raynaud's\nPhenomenon", fillcolor="#e8daef", shape=ellipse]
        DIGIT [label="Digital Ulcers\n& Ischemia", fillcolor="#fadbd8", shape=ellipse]
        INTIMA [label="Intimal\nHyperplasia\n(mSMC proliferation)", fillcolor="#d7bde2"]
        PLATELET [label="Platelet\nActivation &\nAggregation", fillcolor="#d7bde2"]
        THROMBUS [label="Microthrombus\nFormation", fillcolor="#fadbd8"]
        PERIVASK [label="Perivascular\nFibrosis", fillcolor="#d7bde2"]
    }

    // ─────────────────────────────────────────────
    // CLUSTER 5: Fibrosis Core Pathways
    // ─────────────────────────────────────────────
    subgraph cluster_fibrosis {
        label="Fibrosis Core Mechanisms"
        style=filled; fillcolor="#fdfefe"; color="#e74c3c"; penwidth=2
        fontname="Helvetica Bold"; fontsize=13; fontcolor="#e74c3c"

        TGFB [label="TGF-β1/2/3\n(master fibrotic\ncytokine)", fillcolor="#fadbd8"]
        TGFBR [label="TGF-βR I/II\n(ALK5/TBRII)", fillcolor="#fadbd8"]
        SMAD23 [label="SMAD2/3\nPhosphorylation", fillcolor="#fadbd8"]
        SMAD4 [label="SMAD4\n(co-SMAD)", fillcolor="#fadbd8"]
        SMAD7 [label="SMAD7\n(inhibitory)", fillcolor="#d5f5e3"]
        NONSMAD [label="Non-SMAD TGF-β\nSignaling\n(ERK, PI3K, JNK)", fillcolor="#fadbd8"]
        PDGF [label="PDGF\n(PDGF-AA/BB\nRRα/β)", fillcolor="#fadbd8"]
        CTGF [label="CTGF/CCN2\n(pro-fibrotic\namplifier)", fillcolor="#fadbd8"]
        FGF [label="FGF\n(FGF-2/9\nmyofibroblasts)", fillcolor="#fadbd8"]
        LOXL2 [label="LOXL2\n(lysyl oxidase-\nlike 2)", fillcolor="#fadbd8"]
        FIBR_ACT [label="Fibroblast\nActivation\n(αSMA+)", fillcolor="#fadbd8"]
        MYOFIBR [label="Myofibroblast\nDifferentiation", fillcolor="#fadbd8"]
        COL1 [label="Collagen I\n(COL1A1/A2)\nSynthesis ↑", fillcolor="#f9e79f"]
        COL3 [label="Collagen III\nSynthesis ↑", fillcolor="#f9e79f"]
        MMP [label="MMPs\n(MMP-1/3/9)\n↓ in SSc", fillcolor="#d5f5e3"]
        TIMP [label="TIMPs\n(TIMP-1/2)\n↑ in SSc", fillcolor="#fadbd8"]
        ECM [label="ECM Remodeling\n& Accumulation", fillcolor="#e74c3c", fontcolor=white]
        WNT [label="WNT/β-catenin\nSignaling", fillcolor="#fadbd8"]
        YAP [label="YAP/TAZ\n(mechanosensing)", fillcolor="#fadbd8"]
        HEDGEHOG [label="Hedgehog\nSignaling\n(Gli1/2)", fillcolor="#fadbd8"]
        EPIT_MESEN [label="Epithelial-to-\nMesenchymal\nTransition (EMT)", fillcolor="#fadbd8"]
    }

    // ─────────────────────────────────────────────
    // CLUSTER 6: Skin Manifestations
    // ─────────────────────────────────────────────
    subgraph cluster_skin {
        label="Skin Manifestations"
        style=filled; fillcolor="#fffde7"; color="#f9a825"; penwidth=2
        fontname="Helvetica Bold"; fontsize=13; fontcolor="#f9a825"

        SKIN_FIBR [label="Skin Fibrosis\n(dermis)", fillcolor="#fff9c4"]
        MRSS [label="Modified Rodnan\nSkin Score (mRSS)\n0-51", fillcolor="#fff176", shape=ellipse]
        EDEMA [label="Puffy Fingers\n& Skin Edema\n(early SSc)", fillcolor="#fff9c4"]
        INDURA [label="Skin\nInduration", fillcolor="#fff9c4"]
        TELANG [label="Telangiectasia", fillcolor="#fff9c4"]
        CALCI [label="Calcinosis\nCutis", fillcolor="#fff9c4"]
        SCLEROD [label="Sclerodactyly", fillcolor="#fff9c4"]
        NFC [label="Nailfold\nCapillaroscopy\nAbnormalities", fillcolor="#fff9c4"]
        HYPERPIG [label="Hyper/Hypo-\npigmentation", fillcolor="#fff9c4"]
    }

    // ─────────────────────────────────────────────
    // CLUSTER 7: Pulmonary Manifestations
    // ─────────────────────────────────────────────
    subgraph cluster_lung {
        label="Pulmonary Manifestations"
        style=filled; fillcolor="#e8f5e9"; color="#2e7d32"; penwidth=2
        fontname="Helvetica Bold"; fontsize=13; fontcolor="#2e7d32"

        ILD [label="Interstitial Lung\nDisease (ILD)\n~70-80% SSc", fillcolor="#c8e6c9"]
        NSIP [label="NSIP Pattern\n(most common)", fillcolor="#c8e6c9"]
        UIP [label="UIP Pattern\n(worse prognosis)", fillcolor="#c8e6c9"]
        FVC [label="FVC % predicted\n(key ILD endpoint)", fillcolor="#a5d6a7", shape=ellipse]
        DLCO [label="DLCO % predicted", fillcolor="#a5d6a7", shape=ellipse]
        PAH_SSc [label="SSc-PAH\n(~15% SSc)\nworst prognosis", fillcolor="#c8e6c9"]
        mPAP [label="mean PAP\n(mmHg)", fillcolor="#a5d6a7", shape=ellipse]
        PVR [label="Pulmonary\nVascular\nResistance", fillcolor="#a5d6a7", shape=ellipse]
        RV_FUNC [label="RV Function\n(RVSP, TAPSE)", fillcolor="#c8e6c9"]
        ALVEOL [label="Alveolar\nInflammation\n(bronchoalveolar\nlavage)", fillcolor="#c8e6c9"]
        BAL_NEUT [label="BAL Neutrophils\n(ILD activity)", fillcolor="#c8e6c9"]
        LUNG_FIBR [label="Lung\nParenchymal\nFibrosis", fillcolor="#c8e6c9"]
        DYSPNEA [label="Dyspnea\n(mMRC scale)", fillcolor="#a5d6a7", shape=ellipse]
        SIX_MWD [label="6-Minute Walk\nDistance (6MWD)", fillcolor="#a5d6a7", shape=ellipse]
        SPIRO [label="Spirometry\nFEV1/FVC", fillcolor="#c8e6c9"]
        HRCT [label="HRCT Extent\nof Disease (%)", fillcolor="#c8e6c9"]
    }

    // ─────────────────────────────────────────────
    // CLUSTER 8: Renal Manifestations
    // ─────────────────────────────────────────────
    subgraph cluster_renal {
        label="Renal Manifestations"
        style=filled; fillcolor="#e3f2fd"; color="#1565c0"; penwidth=2
        fontname="Helvetica Bold"; fontsize=13; fontcolor="#1565c0"

        SRC [label="Scleroderma\nRenal Crisis (SRC)\n(~10% dcSSc)", fillcolor="#bbdefb"]
        MALIG_HT [label="Malignant\nHypertension\n(>150/85)", fillcolor="#bbdefb"]
        RENAL_FIBR [label="Renal\nArteriopathy\n& Fibrosis", fillcolor="#bbdefb"]
        RAAS [label="RAAS\nActivation\n(renin↑, AngII↑)", fillcolor="#bbdefb"]
        ANGIO [label="Angiotensin II\n(AngII)\nvasoconstriction", fillcolor="#bbdefb"]
        ACE [label="ACE\n(angiotensin\nconverting enzyme)", fillcolor="#bbdefb"]
        GFR [label="GFR\n(eGFR ml/min)", fillcolor="#90caf9", shape=ellipse]
        CREAT [label="Serum\nCreatinine", fillcolor="#90caf9", shape=ellipse]
        PROTEINURIA [label="Proteinuria\n(urine ACR)", fillcolor="#90caf9", shape=ellipse]
        THROMBO_MICRO [label="Thrombotic\nMicroangiopathy\n(TMA)", fillcolor="#bbdefb"]
    }

    // ─────────────────────────────────────────────
    // CLUSTER 9: GI Manifestations
    // ─────────────────────────────────────────────
    subgraph cluster_gi {
        label="Gastrointestinal Manifestations"
        style=filled; fillcolor="#fce4ec"; color="#c62828"; penwidth=2
        fontname="Helvetica Bold"; fontsize=13; fontcolor="#c62828"

        GERD_SSc [label="GERD\n(>70% SSc)", fillcolor="#f8bbd9"]
        DYSPHAG [label="Dysphagia\n(esophageal\ndysmotility)", fillcolor="#f8bbd9"]
        SIBO [label="Small Intestine\nBacterial\nOvergrowth", fillcolor="#f8bbd9"]
        MALABSORB [label="Malabsorption\n& Weight Loss", fillcolor="#f8bbd9"]
        GI_FIBR [label="GI Smooth Muscle\nAtrophy & Fibrosis", fillcolor="#f8bbd9"]
        GI_VASCU [label="Gastric Antral\nVascular Ectasia\n(GAVE)", fillcolor="#f8bbd9"]
        FECAL_INC [label="Fecal\nIncontinence", fillcolor="#f8bbd9"]
        ANO_FIBR [label="Anorectal\nFibrosis", fillcolor="#f8bbd9"]
    }

    // ─────────────────────────────────────────────
    // CLUSTER 10: Cardiac Manifestations
    // ─────────────────────────────────────────────
    subgraph cluster_cardiac {
        label="Cardiac Manifestations"
        style=filled; fillcolor="#ede7f6"; color="#4527a0"; penwidth=2
        fontname="Helvetica Bold"; fontsize=13; fontcolor="#4527a0"

        MYFIBR_HEART [label="Myocardial\nFibrosis", fillcolor="#d1c4e9"]
        PERI [label="Pericarditis\n& Effusion", fillcolor="#d1c4e9"]
        CARDIAC_COND [label="Conduction\nAbnormalities\n(arrhythmia)", fillcolor="#d1c4e9"]
        DIASTOLIC [label="Diastolic\nDysfunction", fillcolor="#d1c4e9"]
        LVEF [label="LVEF (%)", fillcolor="#b39ddb", shape=ellipse]
    }

    // ─────────────────────────────────────────────
    // CLUSTER 11: Drug PK - Immunosuppressants
    // ─────────────────────────────────────────────
    subgraph cluster_pk_immuno {
        label="Drug PK: Immunosuppressants"
        style=filled; fillcolor="#e8eaf6"; color="#283593"; penwidth=2
        fontname="Helvetica Bold"; fontsize=13; fontcolor="#283593"

        MMF_GUT [label="MMF\n(oral)\nGut absorption", fillcolor="#c5cae9"]
        MMF_C [label="MPA (active)\nPlasma Conc\n(Cplass)", fillcolor="#c5cae9"]
        MMF_T [label="MPA\nTissue", fillcolor="#c5cae9"]
        MTX_GUT [label="Methotrexate\n(MTX) oral/SC", fillcolor="#c5cae9"]
        MTX_C [label="MTX Plasma\nConc", fillcolor="#c5cae9"]
        CYC_C [label="Cyclophosphamide\n(CYC) IV\nPlasma Conc", fillcolor="#c5cae9"]
        CYC_M [label="4-OH-CYC\n(active metabolite)", fillcolor="#c5cae9"]
        AZA_C [label="Azathioprine\n(AZA) Plasma", fillcolor="#c5cae9"]
        PRED_C [label="Prednisone\nPlasma Conc", fillcolor="#c5cae9"]
        RTX_C [label="Rituximab (RTX)\nPlasma Conc\n(mAb PK)", fillcolor="#c5cae9"]
        TCZ_C [label="Tocilizumab (TCZ)\nPlasma Conc\n(anti-IL-6R)", fillcolor="#c5cae9"]
        LOCO_C [label="Lenabasum\n(cannabinoid\nreceptor agonist)", fillcolor="#c5cae9"]
    }

    // ─────────────────────────────────────────────
    // CLUSTER 12: Drug PK - Vascular / PAH drugs
    // ─────────────────────────────────────────────
    subgraph cluster_pk_vasc {
        label="Drug PK: Vascular / PAH Agents"
        style=filled; fillcolor="#e0f7fa"; color="#006064"; penwidth=2
        fontname="Helvetica Bold"; fontsize=13; fontcolor="#006064"

        BOSEN_C [label="Bosentan (ERA)\nPlasma Conc", fillcolor="#b2ebf2"]
        AMBRI_C [label="Ambrisentan\n(ERA-A) Plasma", fillcolor="#b2ebf2"]
        MACIT_C [label="Macitentan\n(ERA) Plasma", fillcolor="#b2ebf2"]
        SILDEN_C [label="Sildenafil\n(PDE5i) Plasma", fillcolor="#b2ebf2"]
        TADAL_C [label="Tadalafil\n(PDE5i) Plasma", fillcolor="#b2ebf2"]
        RIOCI_C [label="Riociguat\n(sGC stimulator)\nPlasma", fillcolor="#b2ebf2"]
        ILOP_C [label="Iloprost\n(prostacyclin\nanalogue) Plasma", fillcolor="#b2ebf2"]
        TREPR_C [label="Treprostinil\n(sc/IV) Plasma", fillcolor="#b2ebf2"]
        SELEXIPAG [label="Selexipag\n(IP receptor\nagonist) Plasma", fillcolor="#b2ebf2"]
        NIFED_C [label="Nifedipine\n(CCB) Plasma", fillcolor="#b2ebf2"]
    }

    // ─────────────────────────────────────────────
    // CLUSTER 13: Drug PK - Anti-fibrotic
    // ─────────────────────────────────────────────
    subgraph cluster_pk_fibrosis {
        label="Drug PK: Anti-fibrotic Agents"
        style=filled; fillcolor="#f3e5f5"; color="#6a1b9a"; penwidth=2
        fontname="Helvetica Bold"; fontsize=13; fontcolor="#6a1b9a"

        NINTEDANIB_C [label="Nintedanib\n(FGFR/PDGFR/\nVEGFR inhibitor)\nPlasma Conc", fillcolor="#e1bee7"]
        PIRFEN_C [label="Pirfenidone\n(TGF-β inh)\nPlasma Conc", fillcolor="#e1bee7"]
        BELIM_C [label="Belimumab\n(anti-BAFF)\nPlasma Conc", fillcolor="#e1bee7"]
        ABAT_C [label="Abatacept\n(CTLA4-Ig)\nPlasma Conc", fillcolor="#e1bee7"]
        POMALI [label="Pomalidomide\n(anti-fibrotic\nIMiD) Plasma", fillcolor="#e1bee7"]
        HALOF [label="Halofuginone\n(TGF-β/Smad3\ninh) Plasma", fillcolor="#e1bee7"]
    }

    // ─────────────────────────────────────────────
    // CLUSTER 14: Biomarkers
    // ─────────────────────────────────────────────
    subgraph cluster_biomarkers {
        label="Biomarkers & Disease Activity"
        style=filled; fillcolor="#fff8e1"; color="#ff6f00"; penwidth=2
        fontname="Helvetica Bold"; fontsize=13; fontcolor="#ff6f00"

        CRP [label="CRP / ESR\n(inflammation)", fillcolor="#ffe082"]
        KL6 [label="KL-6 / SP-D\n(ILD marker)", fillcolor="#ffe082"]
        BNP [label="NT-proBNP / BNP\n(cardiac/PAH)", fillcolor="#ffe082"]
        CCL2 [label="CCL2 / MCP-1\n(monocyte attract.)", fillcolor="#ffe082"]
        P3NP [label="PIIINP\n(collagen III\nsynthesis)", fillcolor="#ffe082"]
        CTXB [label="CTX-I/II\n(collagen\ndegradation)", fillcolor="#ffe082"]
        CXCL4 [label="CXCL4/PF4\n(SSc-ILD\nbiomarker)", fillcolor="#ffe082"]
        SPD [label="SP-D\n(surfactant prot.)", fillcolor="#ffe082"]
        VCAM_SERUM [label="Soluble VCAM-1\n(endothelial\ninjury)", fillcolor="#ffe082"]
        COMP [label="COMP\n(cartilage oligo\nmatrix prot.)", fillcolor="#ffe082"]
        TGFB_SERUM [label="TGF-β serum\nlevel", fillcolor="#ffe082"]
        IL6_SERUM [label="IL-6 serum\nlevel", fillcolor="#ffe082"]
        AUTOAB [label="Autoantibody\nPanel\n(Scl-70, ACA,\nRNA Pol III)", fillcolor="#ffe082"]
    }

    // ─────────────────────────────────────────────
    // CLUSTER 15: Clinical Endpoints
    // ─────────────────────────────────────────────
    subgraph cluster_endpoints {
        label="Clinical Endpoints & Outcomes"
        style=filled; fillcolor="#ffebee"; color="#b71c1c"; penwidth=2
        fontname="Helvetica Bold"; fontsize=13; fontcolor="#b71c1c"

        MRSS_END [label="mRSS\n(primary endpoint\nskin fibrosis)", fillcolor="#ef9a9a", shape=ellipse]
        FVC_END [label="FVC % pred\n(ILD primary)", fillcolor="#ef9a9a", shape=ellipse]
        HRCT_END [label="HRCT Extent\n(lung involvement)", fillcolor="#ef9a9a", shape=ellipse]
        HAQ_DI [label="HAQ-DI\n(disability index)", fillcolor="#ef9a9a", shape=ellipse]
        SIX_MWD_END [label="6MWD\n(functional\ncapacity)", fillcolor="#ef9a9a", shape=ellipse]
        WHO_FC [label="WHO-FC\n(PAH functional\nclass)", fillcolor="#ef9a9a", shape=ellipse]
        TTCW [label="Time to Clinical\nWorsening\n(TTCW)", fillcolor="#ef9a9a", shape=ellipse]
        SURVIVAL [label="Overall Survival\n& Transplant-\nfree Survival", fillcolor="#ef9a9a", shape=ellipse]
        QOL [label="Quality of Life\n(SF-36, SHAQ)", fillcolor="#ef9a9a", shape=ellipse]
        ACRSSC_RESP [label="ACR/EULAR\nSSc Response\nIndex (CRISS)", fillcolor="#ef9a9a", shape=ellipse]
    }

    // ======================================================
    // EDGES - Trigger → Immune activation
    // ======================================================
    GENET -> PDC [label="↑pDC\nactivation"]
    GENET -> BCELL [label="↑Ab\npredisposition"]
    VIRAL -> TLR [label="TLR3/7/9\nligands"]
    CHEMIC -> OXSTRESS [label="ROS\ngeneration"]
    EPIGEN -> FIBR_ACT [label="hypomethylation\nof fibroblasts"]
    MICRO -> TLR [label="PAMP\nactivation"]

    TLR -> PDC [label="type I IFN\ninduction"]
    TLR -> MDC [label="DC maturation"]
    PDC -> IFNa [label="major\nproducer"]
    MDC -> TH1 [label="Th1\npolarization"]
    MDC -> TH17 [label="Th17\npolarization"]
    OXSTRESS -> ENDO [label="endothelial\ndamage"]
    OXSTRESS -> FIBR_ACT [label="fibroblast\nactivation"]

    // Innate → Cytokines
    MACRO -> TNF [label="secretion"]
    MACRO -> IL6 [label="secretion"]
    MACRO -> TGF_B1 [style=invis]
    MACRO -> TGFB [label="secretion\n(M2)"]
    MACRO -> IL4 [label="M2\npolarization"]
    MAST -> TGFB [label="degranulation"]
    NLRP3 -> IL1B [label="caspase-1\ncleavage"]
    IL1B -> NLRP3 [label="auto-\namplification" style=dashed]

    // Innate → Adaptive
    IFNa -> TH1 [label="Th1\npolarization"]
    IFNa -> BCELL [label="B cell\nactivation"]
    IL6 -> TH17 [label="Th17\ndifferentiation"]
    IL23 -> TH17 [label="maintenance"]
    TH1 -> IFNg [label="production"]
    TH2 -> IL4 [label="production"]
    TH17 -> IL17A [label="production"]

    // Adaptive → B cells
    TH2 -> BCELL [label="B cell\nhelp"]
    IL21 -> BCELL [label="B cell\nactivation"]
    BCELL -> GC [label="GC reaction"]
    GC -> PLASMA [label="Ab-secreting\ncells"]
    GC -> BCELL [label="memory\nB cells"]
    BAFF -> BCELL [label="survival\nfactor"]
    APRIL -> PLASMA [label="survival"]

    // B cells / Ab production
    PLASMA -> ANA [label="secretion"]
    PLASMA -> ANTISCL70 [label="secretion\n(diffuse SSc)"]
