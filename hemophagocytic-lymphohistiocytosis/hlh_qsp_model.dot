digraph HLH_QSP {
    graph [
        label="Hemophagocytic Lymphohistiocytosis (HLH)\nQuantitative Systems Pharmacology Model",
        labelloc=t, fontsize=22, fontname="Helvetica-Bold",
        bgcolor="#F8F9FA", rankdir=TB,
        splines=ortho, nodesep=0.4, ranksep=0.6,
        compound=true
    ]
    node [fontname="Helvetica", fontsize=10, style=filled, shape=box, margin="0.15,0.08"]
    edge [fontname="Helvetica", fontsize=8, arrowsize=0.7]

    // =========================================================
    // CLUSTER 1: Genetic Background & Primary HLH
    // =========================================================
    subgraph cluster_genetics {
        label="Genetic Background\n(Primary HLH)"
        style=filled; color="#E8D5F5"; fontsize=13; fontcolor="#5B1FA3"
        node [fillcolor="#D4B5F0"]

        PRF1 [label="PRF1 Mutation\n(Perforin deficiency)", shape=octagon, fillcolor="#C49FDE"]
        UNC13D [label="UNC13D Mutation\n(MUNC13-4 defect)", shape=octagon]
        STX11 [label="STX11 Mutation\n(Syntaxin-11 defect)", shape=octagon]
        STXBP2 [label="STXBP2 Mutation\n(Munc18-2 defect)", shape=octagon]
        RAB27A [label="RAB27A Mutation\n(Rab27a defect)", shape=octagon]
        LYST [label="LYST Mutation\n(Chediak-Higashi)", shape=octagon]
        AP3B1 [label="AP3B1 Mutation\n(HPS type 2)", shape=octagon]
        SH2D1A [label="SH2D1A Mutation\n(SAP/XLP1)", shape=octagon]
        XIAP [label="XIAP Mutation\n(XLP2)", shape=octagon]

        FHL_TYPE [label="Familial HLH\n(FHL 1-5)", shape=diamond, fillcolor="#9B72CF"]
        SEC_GENE [label="Genetic Susceptibility\nfor Secondary HLH", shape=diamond]

        PRF1 -> FHL_TYPE
        UNC13D -> FHL_TYPE
        STX11 -> FHL_TYPE
        STXBP2 -> FHL_TYPE
        RAB27A -> FHL_TYPE
        LYST -> SEC_GENE
        AP3B1 -> SEC_GENE
        SH2D1A -> SEC_GENE
        XIAP -> SEC_GENE
    }

    // =========================================================
    // CLUSTER 2: Triggering Events
    // =========================================================
    subgraph cluster_triggers {
        label="Triggering Events\n(Secondary HLH / MAS)"
        style=filled; color="#FDEBD0"; fontsize=13; fontcolor="#A04000"
        node [fillcolor="#FAD7A0"]

        EBV [label="EBV Infection\n(Most common viral)", shape=ellipse, fillcolor="#F8C471"]
        CMV [label="CMV Infection", shape=ellipse]
        HSV [label="HSV/VZV Infection", shape=ellipse]
        HIV_TRIG [label="HIV Infection", shape=ellipse]
        LEISH [label="Leishmania sp.", shape=ellipse]
        BACTERIA [label="Bacterial Infection\n(Brucella, TB)", shape=ellipse]
        SLE_TRIG [label="SLE Flare\n(MAS trigger)", shape=pentagon, fillcolor="#F1948A"]
        SJIA [label="sJIA / AOSD\n(MAS trigger)", shape=pentagon]
        RA_TRIG [label="RA / SpA\n(MAS trigger)", shape=pentagon]
        MALIG [label="Malignancy\n(T/NK lymphoma)", shape=pentagon, fillcolor="#E59866"]
        DRUG_TRIG [label="Drug Reactions\n(biologics, phenytoin)", shape=pentagon]
        PREG [label="Pregnancy\n(Gestational MAS)", shape=pentagon]

        INFECT_HLH [label="Infection-Associated\nHLH", shape=diamond]
        AUTOIM_HLH [label="Autoimmune-Associated\nHLH / MAS", shape=diamond]
        MALIG_HLH [label="Malignancy-Associated\nHLH", shape=diamond]

        EBV -> INFECT_HLH
        CMV -> INFECT_HLH
        HSV -> INFECT_HLH
        HIV_TRIG -> INFECT_HLH
        LEISH -> INFECT_HLH
        BACTERIA -> INFECT_HLH
        SLE_TRIG -> AUTOIM_HLH
        SJIA -> AUTOIM_HLH
        RA_TRIG -> AUTOIM_HLH
        MALIG -> MALIG_HLH
        DRUG_TRIG -> AUTOIM_HLH
        PREG -> AUTOIM_HLH
    }

    // =========================================================
    // CLUSTER 3: NK Cell & CTL Dysfunction
    // =========================================================
    subgraph cluster_nk_ctl {
        label="NK Cell & CTL Dysfunction"
        style=filled; color="#D5E8D4"; fontsize=13; fontcolor="#1E5900"
        node [fillcolor="#B9DFB5"]

        NK_CELL [label="NK Cell\n(Natural Killer Cell)", shape=ellipse, fillcolor="#82C880"]
        CTL [label="CD8+ CTL\n(Cytotoxic T Cell)", shape=ellipse, fillcolor="#82C880"]

        LYT_GRAN [label="Lytic Granule\nBiogenesis", shape=box]
        PERF_EXPR [label="Perforin\nExpression", shape=box]
        GRAN_DOK [label="Granule Docking\n(Rab27a/MUNC13-4)", shape=box]
        GRAN_FUSE [label="Granule Fusion\n(STX11/STXBP2)", shape=box]
        PERF_PORE [label="Perforin Pore\nFormation", shape=box]
        GRAN_ENZ [label="Granzyme B/A\nDelivery", shape=box]
        TARGET_APO [label="Target Cell\nApoptosis", shape=diamond, fillcolor="#5DB85A"]

        NK_MIGR [label="NK Cell Migration\nto Lymph Nodes", shape=box]
        CTL_MIGR [label="CTL Migration\nto Infected Tissue", shape=box]

        NK_DYSFUNC [label="NK Cell Dysfunction\n(reduced cytotoxicity)", shape=diamond, fillcolor="#C0392B", fontcolor=white]
        CTL_DYSFUNC [label="CTL Dysfunction\n(impaired killing)", shape=diamond, fillcolor="#C0392B", fontcolor=white]

        NK_CELL -> LYT_GRAN
        NK_CELL -> NK_MIGR
        CTL -> LYT_GRAN
        CTL -> CTL_MIGR
        LYT_GRAN -> PERF_EXPR
        LYT_GRAN -> GRAN_DOK
        GRAN_DOK -> GRAN_FUSE
        PERF_EXPR -> PERF_PORE
        GRAN_FUSE -> GRAN_ENZ
        PERF_PORE -> TARGET_APO
        GRAN_ENZ -> TARGET_APO

        FHL_TYPE -> NK_DYSFUNC [lhead=cluster_nk_ctl, ltail=cluster_genetics, color=red, style=bold]
        NK_DYSFUNC -> TARGET_APO [dir=back, color=red, style=dashed]
        CTL_DYSFUNC -> TARGET_APO [dir=back, color=red, style=dashed]
    }

    // =========================================================
    // CLUSTER 4: Antigen Presentation & T Cell Activation
    // =========================================================
    subgraph cluster_apc_tcell {
        label="APC–T Cell Crosstalk &\nPersistent Antigen Presentation"
        style=filled; color="#D6EAF8"; fontsize=13; fontcolor="#1A5276"
        node [fillcolor="#AED6F1"]

        APC [label="Antigen-Presenting Cell\n(DC, Macrophage)", shape=ellipse, fillcolor="#85C1E9"]
        MHC2 [label="MHC-II / Antigen\nPresentation", shape=box]
        CD4_TCELL [label="CD4+ T Helper Cell\n(Th1 dominant)", shape=ellipse, fillcolor="#85C1E9"]
        CD8_TCELL [label="CD8+ T Cell\n(persistent activation)", shape=ellipse, fillcolor="#85C1E9"]
        TCR_ACT [label="TCR Signaling\n(ZAP70, LAT, PLC-γ)", shape=box]
        COSTIM [label="Co-stimulation\n(CD28/B7, CD40L/CD40)", shape=box]
        T_PROLIF [label="T Cell Proliferation\n(dysregulated)", shape=diamond, fillcolor="#2E86C1", fontcolor=white]
        T_ACTIV [label="T Cell Activation\n(persistent)", shape=diamond, fillcolor="#2E86C1", fontcolor=white]
        NF_KB [label="NF-κB Activation\n(T cells & APCs)", shape=box]
        AP1 [label="AP-1 / MAPK\nSignaling", shape=box]
        NFAT [label="NFAT Signaling\n(IL-2, IFN-γ production)", shape=box]
        CD25 [label="CD25 (IL-2Rα)\nUpregulation\n→ sCD25 release", shape=box]
        PERFORIN_FAIL [label="Failure of CTL\nClearance of APCs", shape=diamond, fillcolor="#C0392B", fontcolor=white]

        APC -> MHC2
        MHC2 -> CD4_TCELL
        MHC2 -> CD8_TCELL
        CD4_TCELL -> TCR_ACT
        CD8_TCELL -> TCR_ACT
        TCR_ACT -> COSTIM
        COSTIM -> T_ACT2 [label="", style=invis]
        TCR_ACT -> NF_KB
        TCR_ACT -> AP1
        TCR_ACT -> NFAT
        NF_KB -> T_PROLIF
        NFAT -> T_ACTIV
        AP1 -> T_ACTIV
        T_ACTIV -> CD25
        NK_DYSFUNC -> PERFORIN_FAIL [lhead=cluster_apc_tcell, ltail=cluster_nk_ctl]
        CTL_DYSFUNC -> PERFORIN_FAIL [ltail=cluster_nk_ctl]
        PERFORIN_FAIL -> APC [label="APCs not\neliminated", style=dashed, color=red]
        INFECT_HLH -> APC [lhead=cluster_apc_tcell, ltail=cluster_triggers, style=dashed]
        AUTOIM_HLH -> APC [ltail=cluster_triggers, style=dashed]
        MALIG_HLH -> APC [ltail=cluster_triggers, style=dashed]
        T_ACT2 [style=invis]
    }

    // =========================================================
    // CLUSTER 5: Cytokine Storm Network
    // =========================================================
    subgraph cluster_cytokine {
        label="Cytokine Storm Network\n(Central Pathophysiology)"
        style=filled; color="#FDEDEC"; fontsize=13; fontcolor="#7B241C"
        node [fillcolor="#FADBD8"]

        IFN_G [label="IFN-γ\n(T cells/NK cells)\n★ Key driver", shape=ellipse, fillcolor="#E74C3C", fontcolor=white]
        IL2 [label="IL-2\n(T cell growth)", shape=ellipse, fillcolor="#E67E22", fontcolor=white]
        IL6 [label="IL-6\n(Acute phase, hepatic)", shape=ellipse, fillcolor="#E67E22", fontcolor=white]
        IL10 [label="IL-10\n(Immunosuppressive\nbut amplifies HLH)", shape=ellipse, fillcolor="#F0B27A"]
        IL12 [label="IL-12\n(Th1 polarization,\nIFN-γ induction)", shape=ellipse, fillcolor="#E67E22", fontcolor=white]
        IL18 [label="IL-18\n(Macrophage activating,\nIFN-γ synergy)", shape=ellipse, fillcolor="#E74C3C", fontcolor=white]
        TNF_A [label="TNF-α\n(Macrophage activation,\nfever, shock)", shape=ellipse, fillcolor="#CB4335", fontcolor=white]
        IL1B [label="IL-1β\n(NLRP3 inflammasome,\nfever)", shape=ellipse, fillcolor="#CB4335", fontcolor=white]
        GMCSF [label="GM-CSF\n(Macrophage activation)", shape=ellipse]
        M_CSF [label="M-CSF\n(Monocyte recruitment)", shape=ellipse]
        MCP1 [label="MCP-1/CCL2\n(Monocyte chemotaxis)", shape=ellipse]
        CXCL9 [label="CXCL9\n(IFN-γ-induced\nT cell recruitment)", shape=ellipse]
        CXCL10 [label="CXCL10/IP-10\n(IFN-γ-induced\nbiomarker)", shape=ellipse]
        VEGF [label="VEGF\n(Vascular permeability)", shape=ellipse]
        IL33 [label="IL-33\n(DAMP signal,\ninnate activation)", shape=ellipse]
        HMGB1 [label="HMGB1\n(Alarmin, late\ncytokine)", shape=ellipse]

        FERRITIN [label="Ferritin\n(Macrophage-derived,\n★ Biomarker)", shape=box, fillcolor="#F1948A"]
        SOL_CD163 [label="sCD163\n(Hemophagocytosis\nmarker)", shape=box, fillcolor="#F1948A"]

        CYTOKINE_STORM [label="CYTOKINE STORM\n(Hyperferritinemic\nSyndrome)", shape=octagon, fillcolor="#922B21", fontcolor=white, fontsize=12]

        T_ACTIV -> IFN_G [lhead=cluster_cytokine, ltail=cluster_apc_tcell]
        T_ACTIV -> IL2 [ltail=cluster_apc_tcell]
        APC -> IL12 [ltail=cluster_apc_tcell]
        APC -> IL18 [ltail=cluster_apc_tcell]
        APC -> IL6 [ltail=cluster_apc_tcell]
        APC -> TNF_A [ltail=cluster_apc_tcell]
        IL12 -> IFN_G [label="induces"]
        IL18 -> IFN_G [label="synergy"]
        IFN_G -> IL12 [label="feedback"]
        IFN_G -> IL18 [label="feedback"]
        IFN_G -> TNF_A [label="induces"]
        IFN_G -> CXCL9
        IFN_G -> CXCL10
        TNF_A -> IL6
        TNF_A -> IL1B
        IL6 -> FERRITIN [label="↑ synthesis"]
        TNF_A -> FERRITIN
        IL1B -> IL6
        IFN_G -> IL10 [label="paradoxical"]
        IL10 -> IFN_G [label="↑ in HLH", style=dashed]
        IL33 -> IL1B [label="inflammasome\nactivation"]
        HMGB1 -> TNF_A
        IFN_G -> GMCSF
        GMCSF -> M_CSF
        M_CSF -> MCP1
        VEGF -> CYTOKINE_STORM
        IFN_G -> CYTOKINE_STORM
        IL6 -> CYTOKINE_STORM
        IL18 -> CYTOKINE_STORM
        TNF_A -> CYTOKINE_STORM
        IL1B -> CYTOKINE_STORM
        FERRITIN -> CYTOKINE_STORM
    }

    // =========================================================
    // CLUSTER 6: Macrophage Activation & Hemophagocytosis
    // =========================================================
    subgraph cluster_macrophage {
        label="Macrophage Activation &\nHemophagocytosis"
        style=filled; color="#FEF9E7"; fontsize=13; fontcolor="#7D6608"
        node [fillcolor="#FDEBD0"]

        MACRO [label="Macrophage\n(Tissue & BM)", shape=ellipse, fillcolor="#F39C12"]
        MONO [label="Monocyte\n(Blood)", shape=ellipse, fillcolor="#F39C12"]
        MACRO_ACT [label="Macrophage\nActivation State", shape=diamond, fillcolor="#D68910"]
        PHAGO [label="Phagocytic\nReceptors (FcγR, CR3)", shape=box]
        HEMOPHAG [label="HEMOPHAGOCYTOSIS\n(Engulfment of\nRBC, WBC, platelets)", shape=octagon, fillcolor="#A04000", fontcolor=white]
        BM_INFILT [label="BM Infiltration\nby Macrophages", shape=box]
        SPLEEN_MACRO [label="Spleen Macrophage\nActivation", shape=box]
        LIVER_KUPF [label="Kupffer Cell\nActivation", shape=box]
        LN_MACRO [label="Lymph Node\nMacrophage", shape=box]
        ROS_MACRO [label="ROS Production\n(Oxidative burst)", shape=box]
        PROTEASE [label="Metalloprotease /\nElastase Release", shape=box]
        PGE2 [label="PGE2\n(Fever, vasodilation)", shape=box]
        TRIG_MACRO [label="Triglyceride ↑\n(Lipoprotein lipase ↓)", shape=box, fillcolor="#F8C471"]
        FIBRINOGEN [label="Fibrinogen\nConsumption ↓\n(DIC risk)", shape=box, fillcolor="#F8C471"]

        IFN_G -> MACRO_ACT [lhead=cluster_macrophage, ltail=cluster_cytokine]
        TNF_A -> MACRO_ACT [ltail=cluster_cytokine]
        IL6 -> MACRO_ACT [ltail=cluster_cytokine]
        GM_CSF2 [label="", style=invis]
        MCP1 -> MONO [ltail=cluster_cytokine]
        MONO -> MACRO
        MACRO -> MACRO_ACT
        MACRO_ACT -> PHAGO
        PHAGO -> HEMOPHAG
        MACRO_ACT -> BM_INFILT
        BM_INFILT -> HEMOPHAG
        MACRO_ACT -> SPLEEN_MACRO
        MACRO_ACT -> LIVER_KUPF
        MACRO_ACT -> LN_MACRO
        MACRO_ACT -> ROS_MACRO
        MACRO_ACT -> PROTEASE
        MACRO_ACT -> PGE2
        MACRO_ACT -> TRIG_MACRO
        MACRO_ACT -> FIBRINOGEN
        MACRO_ACT -> SOL_CD163 [ltail=cluster_macrophage, lhead=cluster_cytokine]
        HEMOPHAG -> IL6 [ltail=cluster_macrophage, lhead=cluster_cytokine]
        HEMOPHAG -> IFN_G [ltail=cluster_macrophage, lhead=cluster_cytokine, label="amplification"]
    }

    // =========================================================
    // CLUSTER 7: Organ Damage
    // =========================================================
    subgraph cluster_organ_damage {
        label="Multi-Organ Damage"
        style=filled; color="#EBF5FB"; fontsize=13; fontcolor="#1A5276"
        node [fillcolor="#D6EAF8"]

        BONE_MARROW [label="Bone Marrow\nSuppression", shape=box, fillcolor="#85C1E9"]
        SPLENOMEG [label="Splenomegaly\n(Macrophage infiltration)", shape=box]
        HEPATOMEG [label="Hepatomegaly\n(Kupffer activation)", shape=box]
        LIVER_FAIL [label="Liver Failure\n(Hepatocyte damage)", shape=box, fillcolor="#2E86C1", fontcolor=white]
        COAGULO [label="Coagulopathy/DIC\n(Fibrinogen ↓)", shape=box, fillcolor="#2E86C1", fontcolor=white]
        CNS_HLH [label="CNS Involvement\n(Neurologic HLH)", shape=box, fillcolor="#2E86C1", fontcolor=white]
        PULM [label="Pulmonary Infiltration\n(ARDS risk)", shape=box, fillcolor="#2E86C1", fontcolor=white]
        RENAL [label="Renal Failure\n(Acute kidney injury)", shape=box, fillcolor="#2E86C1", fontcolor=white]
        VASCULAR [label="Vascular Endothelial\nDamage", shape=box]
        SEPSIS_LIKE [label="Sepsis-like\nHemodynamics", shape=box]
        ADRENAL [label="Adrenal\nInsufficiency", shape=box]

        HEMOPHAG -> BONE_MARROW [ltail=cluster_macrophage]
        HEMOPHAG -> SPLENOMEG [ltail=cluster_macrophage]
        LIVER_KUPF -> HEPATOMEG [ltail=cluster_macrophage]
        LIVER_KUPF -> LIVER_FAIL [ltail=cluster_macrophage]
        FIBRINOGEN -> COAGULO [ltail=cluster_macrophage]
        TNF_A -> CNS_HLH [ltail=cluster_cytokine]
        IFN_G -> CNS_HLH [ltail=cluster_cytokine]
        CYTOKINE_STORM -> PULM [ltail=cluster_cytokine]
        CYTOKINE_STORM -> RENAL [ltail=cluster_cytokine]
        CYTOKINE_STORM -> VASCULAR [ltail=cluster_cytokine]
        VASCULAR -> SEPSIS_LIKE
        TNF_A -> ADRENAL [ltail=cluster_cytokine]
        ROS_MACRO -> LIVER_FAIL [ltail=cluster_macrophage]
        ROS_MACRO -> RENAL [ltail=cluster_macrophage]
        PROTEASE -> VASCULAR [ltail=cluster_macrophage]
    }

    // =========================================================
    // CLUSTER 8: Clinical Manifestations & Biomarkers
    // =========================================================
    subgraph cluster_clinical {
        label="Clinical Manifestations &\nDiagnostic Criteria (HScore / HLH-2004)"
        style=filled; color="#F4ECF7"; fontsize=13; fontcolor="#6C3483"
        node [fillcolor="#E8DAEF"]

        FEVER [label="Fever\n(>38.5°C, >7 days)", shape=box, fillcolor="#AF7AC5"]
        CYTOPENIA [label="Cytopenias (≥2 lines)\nANC, Hgb, Plt ↓", shape=box, fillcolor="#AF7AC5"]
        FERR_HIGH [label="Ferritin ↑↑↑\n(>500 ng/mL;\n★ >10,000 = diagnostic)", shape=box, fillcolor="#8E44AD", fontcolor=white]
        TRIG_HIGH [label="Hypertriglyceridemia\n(>3 mmol/L)", shape=box, fillcolor="#AF7AC5"]
        FIB_LOW [label="Hypofibrinogenemia\n(<1.5 g/L)", shape=box, fillcolor="#AF7AC5"]
        SCD25_HIGH [label="sCD25 ↑↑↑\n(>2,400 U/mL)\n(soluble IL-2Rα)", shape=box, fillcolor="#8E44AD", fontcolor=white]
        NK_LOW [label="NK Cell Activity ↓\n(Flow cytometry)", shape=box, fillcolor="#AF7AC5"]
        BM_HEMOPHAG [label="BM Hemophagocytosis\n(Bone marrow biopsy)", shape=box, fillcolor="#AF7AC5"]
        HSCORE [label="HScore ≥169\n(93% sensitivity HLH)", shape=octagon, fillcolor="#6C3483", fontcolor=white]
        HLH2004 [label="HLH-2004 Criteria\n(≥5 of 8 criteria)", shape=octagon, fillcolor="#6C3483", fontcolor=white]

        BONE_MARROW -> CYTOPENIA [ltail=cluster_organ_damage]
        HEMOPHAG -> BM_HEMOPHAG [ltail=cluster_macrophage]
        FERRITIN -> FERR_HIGH [ltail=cluster_cytokine]
        TRIG_MACRO -> TRIG_HIGH [ltail=cluster_macrophage]
        FIBRINOGEN -> FIB_LOW [ltail=cluster_macrophage]
        CD25 -> SCD25_HIGH [ltail=cluster_apc_tcell]
        NK_DYSFUNC -> NK_LOW [ltail=cluster_nk_ctl]
        PGE2 -> FEVER [ltail=cluster_macrophage]
        TNF_A -> FEVER [ltail=cluster_cytokine]
        SPLENOMEG -> HSCORE [ltail=cluster_organ_damage]
        HEPATOMEG -> HSCORE [ltail=cluster_organ_damage]
        FEVER -> HSCORE
        CYTOPENIA -> HSCORE
        FERR_HIGH -> HSCORE
        TRIG_HIGH -> HSCORE
        FIB_LOW -> HSCORE
        BM_HEMOPHAG -> HSCORE
        FEVER -> HLH2004
        CYTOPENIA -> HLH2004
        FERR_HIGH -> HLH2004
        TRIG_HIGH -> HLH2004
        FIB_LOW -> HLH2004
        SCD25_HIGH -> HLH2004
        NK_LOW -> HLH2004
        BM_HEMOPHAG -> HLH2004
    }

    // =========================================================
    // CLUSTER 9: Drug PK/PD
    // =========================================================
    subgraph cluster_drugs {
        label="Drug Interventions: PK/PD"
        style=filled; color="#E8F8F5"; fontsize=13; fontcolor="#0E6655"
        node [fillcolor="#ABEBC6"]

        // Dexamethasone
        DEX_ORAL [label="Dexamethasone\n(Oral/IV)", shape=ellipse, fillcolor="#1ABC9C", fontcolor=white]
        DEX_PK [label="DEX PK\n(ka, Vd, CL)\n[2-cmt]", shape=box]
        DEX_PD [label="DEX PD\n(GR-mediated\nanti-inflammation)", shape=box]
        GR_ACT [label="Glucocorticoid Receptor\nActivation", shape=box]
        GR_GENE [label="GRE-driven\nGene Regulation\n(↓NF-κB, ↓AP-1)", shape=box]

        // Etoposide
        ETOP [label="Etoposide\n(VP-16, IV)", shape=ellipse, fillcolor="#16A085", fontcolor=white]
        ETOP_PK [label="Etoposide PK\n(linear PK, Vd, t1/2)", shape=box]
        ETOP_PD [label="Topo-II Inhibition\n→ T cell depletion", shape=box]
        ETOP_APO [label="DNA Strand Breaks\n→ Apoptosis of\nActivated T Cells", shape=box]

        // Cyclosporine
        CSA [label="Cyclosporine A\n(Oral, IV)", shape=ellipse, fillcolor="#1ABC9C", fontcolor=white]
        CSA_PK [label="CsA PK\n(saturable Vd,\nhigh protein binding)", shape=box]
        CSA_PD [label="Calcineurin Inhibition\n→ NFAT block", shape=box]
        CSA_IL2 [label="↓ IL-2, IFN-γ\nProduction", shape=box]

        // Emapalumab (anti-IFN-γ)
        EMAPA [label="Emapalumab\n(Anti-IFN-γ mAb\nIV infusion)", shape=ellipse, fillcolor="#148F77", fontcolor=white]
        EMAPA_PK [label="Emapalumab PK\n(2-cmt mAb model,\nMichaelis-Menten CL)", shape=box]
        EMAPA_PD [label="IFN-γ Neutralization\n(free IFN-γ ↓)", shape=box]
        TMDD [label="Target-Mediated Drug\nDisposition (TMDD)\nvs. IFN-γ", shape=box]

        // Anakinra (IL-1Ra)
        ANAKR [label="Anakinra\n(IL-1Ra, SC/IV)", shape=ellipse, fillcolor="#1ABC9C", fontcolor=white]
        ANAKR_PK [label="Anakinra PK\n(SC bioavailability,\nrenal CL)", shape=box]
        ANAKR_PD [label="IL-1R Blockade\n→ ↓ IL-1β signaling", shape=box]

        // Ruxolitinib
        RUXO [label="Ruxolitinib\n(JAK1/2 inhibitor\nOral)", shape=ellipse, fillcolor="#148F77", fontcolor=white]
        RUXO_PK [label="Ruxolitinib PK\n(CYP3A4 metabolism\nlinear 2-cmt)", shape=box]
        RUXO_PD [label="JAK1/2 Inhibition\n→ STAT1/STAT3 block", shape=box]
        JAK_STAT [label="JAK-STAT Pathway\nInhibition (STAT1,\nSTAT3, STAT5)", shape=box]

        // Tocilizumab
        TOCIL [label="Tocilizumab\n(Anti-IL-6R mAb\nIV/SC)", shape=ellipse, fillcolor="#1ABC9C", fontcolor=white]
        TOCIL_PK [label="Tocilizumab PK\n(mAb 2-cmt, nonlinear)", shape=box]
        TOCIL_PD [label="IL-6R Blockade\n→ JAK-STAT inhibition", shape=box]

        // Stem Cell Transplant
        HSCT [label="HSCT\n(Allogeneic SCT,\ncurative intent)", shape=ellipse, fillcolor="#0E6655", fontcolor=white]
        HSCT_MECH [label="Replacement of\nDefective NK/CTL\nPrecursors", shape=box]

        DEX_ORAL -> DEX_PK
        DEX_PK -> DEX_PD
        DEX_PD -> GR_ACT
        GR_ACT -> GR_GENE
        GR_GENE -> NF_KB [lhead=cluster_apc_tcell, ltail=cluster_drugs, label="↓", color=blue]
        GR_GENE -> IFN_G [lhead=cluster_cytokine, label="↓", color=blue]
        GR_GENE -> IL6 [lhead=cluster_cytokine, label="↓", color=blue]
        GR_GENE -> MACRO_ACT [lhead=cluster_macrophage, label="↓", color=blue]

        ETOP -> ETOP_PK
        ETOP_PK -> ETOP_PD
        ETOP_PD -> ETOP_APO
        ETOP_APO -> T_ACTIV [lhead=cluster_apc_tcell, ltail=cluster_drugs, label="depletes", color=blue]
        ETOP_APO -> NK_CELL [lhead=cluster_nk_ctl, label="depletes", color=blue]

        CSA -> CSA_PK
        CSA_PK -> CSA_PD
        CSA_PD -> CSA_IL2
        CSA_IL2 -> NFAT [lhead=cluster_apc_tcell, ltail=cluster_drugs, label="↓", color=blue]
        CSA_IL2 -> IL2 [lhead=cluster_cytokine, label="↓", color=blue]

        EMAPA -> EMAPA_PK
        EMAPA_PK -> TMDD
        TMDD -> EMAPA_PD
        EMAPA_PD -> IFN_G [lhead=cluster_cytokine, ltail=cluster_drugs, label="neutralizes", color=blue, style=bold]

        ANAKR -> ANAKR_PK
        ANAKR_PK -> ANAKR_PD
        ANAKR_PD -> IL1B [lhead=cluster_cytokine, ltail=cluster_drugs, label="blocks", color=blue]

        RUXO -> RUXO_PK
        RUXO_PK -> RUXO_PD
        RUXO_PD -> JAK_STAT
        JAK_STAT -> IFN_G [lhead=cluster_cytokine, ltail=cluster_drugs, label="↓ signaling", color=blue]
        JAK_STAT -> IL6 [lhead=cluster_cytokine, label="↓ signaling", color=blue]

        TOCIL -> TOCIL_PK
        TOCIL_PK -> TOCIL_PD
        TOCIL_PD -> IL6 [lhead=cluster_cytokine, ltail=cluster_drugs, label="blocks receptor", color=blue]

        HSCT -> HSCT_MECH
        HSCT_MECH -> NK_DYSFUNC [lhead=cluster_nk_ctl, ltail=cluster_drugs, label="corrects", color=green, style=bold]
        HSCT_MECH -> CTL_DYSFUNC [lhead=cluster_nk_ctl, label="corrects", color=green]
    }

    // =========================================================
    // CLUSTER 10: Clinical Endpoints & Outcomes
    // =========================================================
    subgraph cluster_outcomes {
        label="Clinical Endpoints & Outcomes"
        style=filled; color="#F9EBEA"; fontsize=13; fontcolor="#922B21"
        node [fillcolor="#FADBD8"]

        MORT_5W [label="5-Week Mortality\n(without treatment ~50%)", shape=box, fillcolor="#E74C3C", fontcolor=white]
        OVERALL_SURV [label="Overall Survival\n(treated)", shape=box, fillcolor="#E74C3C", fontcolor=white]
        HLH_RESP [label="HLH Response\n(Ferritin ↓, fever ↓,\ncytopenias resolve)", shape=box, fillcolor="#F1948A"]
        REMISSION [label="Complete Remission\n(≥8 weeks)", shape=box, fillcolor="#F1948A"]
        RELAPSE [label="Relapse\n(within 12 months)", shape=box, fillcolor="#E74C3C", fontcolor=white]
        HSCT_ELIG [label="HSCT Eligibility\n(Primary HLH)", shape=box, fillcolor="#F1948A"]
        NEUROCOG [label="Neurocognitive\nOutcome", shape=box]
        EFS [label="Event-Free Survival\n(EFS) post-HSCT", shape=box, fillcolor="#F1948A"]
        GRADE34_TOX [label="Grade 3-4 Toxicity\n(etoposide: BM,\nliver, infection)", shape=box]

        HSCORE -> MORT_5W
        HLH2004 -> MORT_5W
        CYTOKINE_STORM -> MORT_5W [ltail=cluster_cytokine]
        LIVER_FAIL -> MORT_5W [ltail=cluster_organ_damage]
        COAGULO -> MORT_5W [ltail=cluster_organ_damage]
        PULM -> MORT_5W [ltail=cluster_organ_damage]
        RENAL -> MORT_5W [ltail=cluster_organ_damage]
        DEX_PD -> HLH_RESP [ltail=cluster_drugs]
        ETOP_APO -> HLH_RESP [ltail=cluster_drugs]
        CSA_IL2 -> HLH_RESP [ltail=cluster_drugs]
        EMAPA_PD -> HLH_RESP [ltail=cluster_drugs]
        HLH_RESP -> REMISSION
        REMISSION -> RELAPSE [label="risk", style=dashed]
        REMISSION -> HSCT_ELIG
        HSCT -> EFS [ltail=cluster_drugs]
        HSCT_ELIG -> HSCT [ltail=cluster_outcomes, lhead=cluster_drugs]
        CNS_HLH -> NEUROCOG [ltail=cluster_organ_damage]
        ETOP_PD -> GRADE34_TOX [ltail=cluster_drugs]
        HLH_RESP -> OVERALL_SURV
        REMISSION -> OVERALL_SURV
        EFS -> OVERALL_SURV
        GRADE34_TOX -> OVERALL_SURV [label="negative", style=dashed]
    }

    // =========================================================
    // LEGEND
    // =========================================================
    subgraph cluster_legend {
        label="Legend" style=filled color="#ECECEC" fontsize=11
        node [shape=box, fontsize=9]
        L_GENE [label="Genetic Factor", fillcolor="#D4B5F0"]
        L_TRIG [label="Trigger/Stimulus", fillcolor="#FAD7A0"]
        L_CYTOK [label="Cytokine", fillcolor="#FADBD8"]
        L_DRUG [label="Drug/Treatment", fillcolor="#ABEBC6"]
        L_ENDPT [label="Outcome/Endpoint", fillcolor="#F1948A"]
        L_CRIT [label="Critical Pathway", fillcolor="#E74C3C", fontcolor=white]
        L_GENE -> L_TRIG [style=invis]
        L_TRIG -> L_CYTOK [style=invis]
        L_CYTOK -> L_DRUG [style=invis]
        L_DRUG -> L_ENDPT [style=invis]
        L_ENDPT -> L_CRIT [style=invis]
    }
}
