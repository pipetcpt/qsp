    cortisol -> GC_pit_feedback [label="cortisol\nfeedback" style=dashed]

    // HPA → Adrenal
    ACTH_receptor_MC2R -> StAR [label="PKA signaling\nactivates" color="#D62728"]
    ACTH_receptor_MC2R -> SF1 [label="induces" style=dashed]
    ACTH_plasma -> adrenal_blood_flow [label="increases\nperfusion"]
