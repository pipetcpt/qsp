digraph CAH_QSP {
    graph [
        rankdir=TB
        splines=ortho
        nodesep=0.35
        ranksep=0.55
        fontname="Helvetica"
        fontsize=12
        bgcolor="#F8F9FA"
        label="Congenital Adrenal Hyperplasia (21-Hydroxylase Deficiency)\nComprehensive QSP Mechanistic Map"
        labelloc=t
        labeljust=c
        pad=0.5
    ]
    node [shape=box style="rounded,filled" fontname="Helvetica" fontsize=9 margin="0.12,0.06"]
    edge [fontname="Helvetica" fontsize=8 arrowsize=0.7]

    // =========================================================
    // CLUSTER 1: Hypothalamus / CRH System
    // =========================================================
    subgraph cluster_hypothalamus {
        label="Hypothalamus"
        style=filled
        color="#C5D8F0"
        fillcolor="#EBF3FB"
        fontsize=11
        fontcolor="#1A3A5C"

        CRH [label="CRH\n(Corticotropin-Releasing\nHormone)" fillcolor="#6BAED6" fontcolor=white]
        CRH_receptor [label="CRF1 Receptor\n(CRH-R1)" fillcolor="#9ECAE1" shape=ellipse]
        AVP [label="AVP/ADH\n(Arginine Vasopressin)" fillcolor="#9ECAE1"]
        CRH_synthesis [label="CRH Synthesis\n(PVN Neurons)" fillcolor="#DEEBF7"]
        CRH_pulsatile [label="Pulsatile CRH\nRelease" fillcolor="#DEEBF7"]
        CRH_clearance [label="CRH Clearance\n(t½ ~6 min)" fillcolor="#DEEBF7"]
        NPY [label="NPY\n(Neuropeptide Y)" fillcolor="#DEEBF7"]
        GC_hypothal_feedback [label="Glucocorticoid\nFeedback (PVN)" fillcolor="#FFF3CD" shape=diamond]
        serotonin_CRH [label="Serotonin\nStimulation" fillcolor="#DEEBF7"]
        stress_input [label="Stress / Circadian\nInput" shape=parallelogram fillcolor="#FFF3CD"]
    }

    // =========================================================
    // CLUSTER 2: Anterior Pituitary
    // =========================================================
    subgraph cluster_pituitary {
        label="Anterior Pituitary"
        style=filled
        color="#B3D9A4"
        fillcolor="#EEF7EB"
        fontsize=11
        fontcolor="#1A4A1A"

        POMC [label="POMC\n(Pro-opiomelanocortin)" fillcolor="#74C476" fontcolor=white]
        ACTH [label="ACTH\n(Adrenocorticotropin)" fillcolor="#41AB5D" fontcolor=white]
        beta_endorphin [label="β-Endorphin" fillcolor="#A1D99B"]
        alpha_MSH [label="α-MSH\n(Melanocyte-Stim H)" fillcolor="#A1D99B"]
        ACTH_synthesis [label="ACTH Synthesis\n(Corticotrophs)" fillcolor="#E5F5E0"]
        ACTH_secretion [label="ACTH Secretion\n(Pulsatile)" fillcolor="#E5F5E0"]
        ACTH_plasma [label="ACTH Plasma\n(pg/mL)" fillcolor="#C7E9C0"]
        GC_pit_feedback [label="Glucocorticoid\nFeedback (Pit)" fillcolor="#FFF3CD" shape=diamond]
        ACTH_receptor_MC2R [label="MC2R\n(ACTH Receptor)" shape=ellipse fillcolor="#A1D99B"]
        pit_melanocortin [label="Melanocortin\nSignaling" fillcolor="#E5F5E0"]
    }

    // =========================================================
    // CLUSTER 3: Adrenal Cortex - Zones
    // =========================================================
    subgraph cluster_adrenal_zones {
        label="Adrenal Cortex – Zones"
        style=filled
        color="#E6B3D6"
        fillcolor="#F9EEF5"
        fontsize=11
        fontcolor="#4A1A4A"

        zona_glomerulosa [label="Zona Glomerulosa\n(Mineralocorticoids)" fillcolor="#DA9EC8"]
        zona_fasciculata [label="Zona Fasciculata\n(Glucocorticoids)" fillcolor="#DA9EC8"]
        zona_reticularis [label="Zona Reticularis\n(Androgens / DHEA)" fillcolor="#DA9EC8"]
        adrenal_volume [label="Adrenal Volume\n(cm³) [hyperplastic]" fillcolor="#F0D0E8" shape=cylinder]
        adrenal_hyperplasia [label="ACTH-Driven\nAdrenal Hyperplasia" fillcolor="#E8B4D8"]
        StAR [label="StAR Protein\n(Steroidogenic Acute\nRegulatory Protein)" fillcolor="#F0D0E8"]
        cholesterol_transport [label="Cholesterol\nTransport (IMM)" fillcolor="#F0D0E8"]
        SF1 [label="SF-1\n(Steroidogenic\nFactor 1)" fillcolor="#F0D0E8"]
        adrenal_blood_flow [label="Adrenal Blood\nFlow (ACTH↑)" fillcolor="#F0D0E8"]
    }

    // =========================================================
    // CLUSTER 4: Steroidogenesis Pathway (Core)
    // =========================================================
    subgraph cluster_steroidogenesis {
        label="Steroidogenesis Pathway (CYP21A2 Deficiency Block)"
        style=filled
        color="#FDAE6B"
        fillcolor="#FFF5EB"
        fontsize=11
        fontcolor="#8C4A00"

        cholesterol [label="Cholesterol\n(Substrate)" fillcolor="#FDD0A2"]
        pregnenolone [label="Pregnenolone" fillcolor="#FDD0A2"]
        P17alpha_preg [label="17α-Pregnenolone\n(17-OH Pregnenolone)" fillcolor="#FDAE6B"]
        DHEA_steroid [label="DHEA\n(Dehydroepi-\nandrosterone)" fillcolor="#FD8D3C"]
        DHEAS [label="DHEA-S" fillcolor="#FD8D3C"]
        progesterone [label="Progesterone" fillcolor="#FDAE6B"]
        OHP17 [label="17-OHP\n(17α-Hydroxy-\nprogesterone)\n[KEY BIOMARKER]" fillcolor="#E6550D" fontcolor=white shape=octagon]
        DOC [label="DOC\n(11-deoxy-\ncorticosterone)" fillcolor="#FDAE6B"]
        S_compound [label="Compound S\n(11-deoxycortisol)" fillcolor="#FDAE6B"]
        cortisol [label="CORTISOL\n(Hydrocortisone)\n[DEFICIENT in CAH]" fillcolor="#D95F0E" fontcolor=white shape=octagon]
        corticosterone [label="Corticosterone\n(B)" fillcolor="#FDD0A2"]
        aldosterone [label="ALDOSTERONE\n[DEFICIENT in SW-CAH]" fillcolor="#E6550D" fontcolor=white]
        androstenedione [label="Androstenedione\n(A4)\n[ELEVATED in CAH]" fillcolor="#FD8D3C" shape=octagon]
        testosterone_prod [label="Testosterone (T)\n[ELEVATED in CAH]" fillcolor="#E6550D" fontcolor=white shape=octagon]
        estradiol_prod [label="Estradiol (E2)\n(Peripheral Conversion)" fillcolor="#FDD0A2"]

        // Enzymes as edge labels - Key enzymes
        CYP11A1_node [label="CYP11A1\n(Cholesterol Side-chain\nCleavage)" shape=ellipse fillcolor="#FEE6CE"]
        HSD3B2_node [label="HSD3B2\n(3β-HSD)" shape=ellipse fillcolor="#FEE6CE"]
        CYP17A1_node [label="CYP17A1\n(17α-Hydroxylase/\n17,20-Lyase)" shape=ellipse fillcolor="#FEE6CE"]
        CYP21A2_BLOCK [label="⊗ CYP21A2\n(21-Hydroxylase)\n[DEFICIENT / MUTATED]" shape=doubleoctagon fillcolor="#CB181D" fontcolor=white fontsize=10]
        CYP11B1_node [label="CYP11B1\n(11β-Hydroxylase)" shape=ellipse fillcolor="#FEE6CE"]
        CYP11B2_node [label="CYP11B2\n(Aldosterone\nSynthase)" shape=ellipse fillcolor="#FEE6CE"]
        CYP19A1_node [label="CYP19A1\n(Aromatase)" shape=ellipse fillcolor="#FEE6CE"]
        HSD17B_node [label="HSD17B\n(17β-HSD)" shape=ellipse fillcolor="#FEE6CE"]
        SULT2A1_node [label="SULT2A1\n(DHEA Sulfotransferase)" shape=ellipse fillcolor="#FEE6CE"]
        adrenodoxin [label="Adrenodoxin\n(Electron Transfer)" fillcolor="#FEE6CE"]
    }

    // =========================================================
    // CLUSTER 5: Androgen Effects / Virilization
    // =========================================================
    subgraph cluster_androgen_effects {
        label="Androgen Excess Effects / Virilization"
        style=filled
        color="#FC8D59"
        fillcolor="#FEF0E6"
        fontsize=11
        fontcolor="#7F2900"

        AR_receptor [label="Androgen Receptor\n(AR)" shape=ellipse fillcolor="#FDBB84"]
        external_genitalia [label="External Genitalia\nVirilization (Females)" fillcolor="#FDBB84"]
        clitoromegaly [label="Clitoromegaly /\nLabial Fusion" fillcolor="#FEE0C6"]
        premature_adrenarche [label="Premature\nAdrenarche" fillcolor="#FDBB84"]
        premature_pubarche [label="Premature\nPubarche" fillcolor="#FEE0C6"]
        acne_androgen [label="Acne /\nSeborrhea" fillcolor="#FEE0C6"]
        hirsutism [label="Hirsutism\n(Adult Females)" fillcolor="#FEE0C6"]
        menstrual_irregul [label="Menstrual\nIrregularity / Anovulation" fillcolor="#FEE0C6"]
        fertility_female [label="Reduced Female\nFertility" fillcolor="#FDBB84"]
        TART [label="TART\n(Testicular Adrenal Rest\nTumors)" fillcolor="#FDBB84"]
        male_fertility [label="Male Infertility\n(TART / Azoospermia)" fillcolor="#FEE0C6"]
        DHT_peripheral [label="DHT\n(5α-Dihydrotestosterone)\n[Peripheral]" fillcolor="#FDBB84"]
        SRD5A_node [label="SRD5A\n(5α-Reductase)" shape=ellipse fillcolor="#FEE0C6"]
    }

    // =========================================================
    // CLUSTER 6: Growth / Bone Effects
    // =========================================================
    subgraph cluster_growth_bone {
        label="Growth / Bone Development Effects"
        style=filled
        color="#74C476"
        fillcolor="#EFF7EF"
        fontsize=11
        fontcolor="#1A4A1A"

        bone_age [label="Bone Age\nAdvancement" fillcolor="#A1D99B" shape=cylinder]
        height_velocity [label="Height Velocity\n(cm/year)" fillcolor="#A1D99B" shape=cylinder]
        height_SDS [label="Height SDS\n(Standard Deviation\nScore)" fillcolor="#74C476" fontcolor=white shape=cylinder]
        final_adult_height [label="Final Adult Height\n(cm) [Reduced]" fillcolor="#41AB5D" fontcolor=white]
        GH_axis [label="GH / IGF-1 Axis" fillcolor="#C7E9C0"]
        IGF1 [label="IGF-1\n(Insulin-like\nGrowth Factor 1)" fillcolor="#C7E9C0"]
        epiphyseal_fusion [label="Premature Epiphyseal\nFusion" fillcolor="#C7E9C0"]
        BMD [label="Bone Mineral\nDensity (BMD)\n[Reduced with GC]" fillcolor="#A1D99B" shape=cylinder]
        osteoblast_act [label="Osteoblast\nActivity\n[Suppressed by GC]" fillcolor="#C7E9C0"]
        osteoclast_act [label="Osteoclast\nActivity\n[Increased by GC]" fillcolor="#C7E9C0"]
        vertebral_fx [label="Vertebral Fracture\nRisk" fillcolor="#C7E9C0"]
        growth_plate [label="Growth Plate\nSensitivity" fillcolor="#C7E9C0"]
        androgen_growth [label="Early Androgen\nAccelerated Growth" fillcolor="#C7E9C0"]
    }

    // =========================================================
    // CLUSTER 7: Salt-Wasting / Mineralocorticoid Pathway
    // =========================================================
    subgraph cluster_saltwater {
        label="Salt-Wasting / Mineralocorticoid Axis"
        style=filled
        color="#6BAED6"
        fillcolor="#EBF5FB"
        fontsize=11
        fontcolor="#1A3A5C"

        renin [label="Plasma Renin Activity\n(PRA) [Elevated in SW]" fillcolor="#9ECAE1" shape=cylinder]
        angiotensinogen [label="Angiotensinogen\n(AGT)" fillcolor="#DEEBF7"]
        angiotensin1 [label="Angiotensin I" fillcolor="#C6DBEF"]
        angiotensin2 [label="Angiotensin II\n(AT-II)" fillcolor="#9ECAE1"]
        ACE_node [label="ACE\n(Angiotensin-\nConverting Enzyme)" shape=ellipse fillcolor="#DEEBF7"]
        MR_receptor [label="Mineralocorticoid\nReceptor (MR)" shape=ellipse fillcolor="#9ECAE1"]
        sodium_renal [label="Na⁺ Reabsorption\n(Renal Tubule)" fillcolor="#DEEBF7"]
        potassium_excretion [label="K⁺ Excretion\n(Renal Tubule)" fillcolor="#DEEBF7"]
        serum_Na [label="Serum Na⁺\n[Low in SW: <130 mEq/L]" fillcolor="#6BAED6" fontcolor=white shape=cylinder]
        serum_K [label="Serum K⁺\n[High in SW: >6 mEq/L]" fillcolor="#6BAED6" fontcolor=white shape=cylinder]
        adrenal_crisis [label="Adrenal Crisis\n[Life-threatening in SW]" fillcolor="#CB181D" fontcolor=white shape=diamond]
        DOC_effect [label="DOC Excess\n(Hypertension in\nSW-variant)" fillcolor="#DEEBF7"]
        blood_pressure [label="Blood Pressure\n[Hypertension risk]" fillcolor="#C6DBEF" shape=cylinder]
        dehydration [label="Dehydration /\nCirculatory Collapse" fillcolor="#DEEBF7"]
    }

    // =========================================================
    // CLUSTER 8: Drug PK - Standard Therapies
    // =========================================================
    subgraph cluster_drug_pk_standard {
        label="Standard Drug PK (Glucocorticoids / Fludrocortisone)"
        style=filled
        color="#9E9AC8"
        fillcolor="#F2F0FB"
        fontsize=11
        fontcolor="#3F007D"

        // Hydrocortisone
        HC_dose [label="Hydrocortisone\nDose (mg/m²/day)" shape=parallelogram fillcolor="#BCBDDC"]
        HC_gut [label="HC_GUT\n(GI Absorption)" fillcolor="#DADAEB"]
        HC_cent [label="HC_CENT\n(Central PK)" fillcolor="#BCBDDC"]
        HC_peri [label="HC_PERI\n(Peripheral PK)" fillcolor="#DADAEB"]
        HC_Cmax [label="HC Cmax\n(Peak Cortisol\nEquivalent)" fillcolor="#9E9AC8" fontcolor=white shape=cylinder]
        HC_trough [label="HC Trough\n(min cortisol)" fillcolor="#9E9AC8" fontcolor=white shape=cylinder]
        HC_bioav [label="HC Bioavailability\nF = 0.95, ka=2.5/h" fillcolor="#DADAEB"]
        HC_CL [label="HC Clearance\nCL = 17 L/h (adult)" fillcolor="#DADAEB"]
        HC_circadian [label="Circadian\nHC Dosing\n(AM > PM schedule)" fillcolor="#BCBDDC"]

        // Prednisolone
        PRED_dose [label="Prednisolone\nDose (mg/day)" shape=parallelogram fillcolor="#BCBDDC"]
        PRED_cent [label="PRED_CENT\n(Central PK)" fillcolor="#DADAEB"]

        // Dexamethasone
        DEX_dose [label="Dexamethasone\nDose (μg/day)" shape=parallelogram fillcolor="#BCBDDC"]
        DEX_cent [label="DEX_CENT\n(Central PK)" fillcolor="#DADAEB"]

        // Fludrocortisone
        FC_dose [label="Fludrocortisone\nDose (μg/day)" shape=parallelogram fillcolor="#BCBDDC"]
        FC_cent [label="FC_CENT\n(Central PK)" fillcolor="#DADAEB"]
        FC_MR_effect [label="FC → MR\nActivation" fillcolor="#BCBDDC"]

        GC_potency [label="Relative GC\nPotency:\nHC=1, PRED=4, DEX=25" fillcolor="#DADAEB"]
    }

    // =========================================================
    // CLUSTER 9: Drug PK - Novel CRF1 Antagonists
    // =========================================================
    subgraph cluster_drug_pk_novel {
        label="Novel Therapies – CRF1 Antagonists / Emerging"
        style=filled
        color="#FE9929"
        fillcolor="#FFF7EC"
        fontsize=11
        fontcolor="#7F2700"

        // Tildacerfont
        TILD_dose [label="Tildacerfont Dose\n(mg QD/BID)" shape=parallelogram fillcolor="#FEC44F"]
        TILD_gut [label="TILD_GUT\n(Absorption)" fillcolor="#FEE391"]
        TILD_cent [label="TILD_CENT\n(Central Plasma)" fillcolor="#FEC44F"]
        TILD_t12 [label="Tildacerfont\nt½ = 12-14 h" fillcolor="#FEE391"]
        TILD_CRF1 [label="TILD–CRF1R\nOccupancy" fillcolor="#FEC44F" shape=ellipse]

        // Crinecerfont
        CRINE_dose [label="Crinecerfont Dose\n(mg BID)" shape=parallelogram fillcolor="#FEC44F"]
        CRINE_gut [label="CRINE_GUT\n(Absorption)" fillcolor="#FEE391"]
        CRINE_cent [label="CRINE_CENT\n(Central Plasma)" fillcolor="#FEC44F"]
        CRINE_t12 [label="Crinecerfont\nt½ = 8-10 h" fillcolor="#FEE391"]
        CRINE_CRF1 [label="CRINE–CRF1R\nOccupancy" fillcolor="#FEC44F" shape=ellipse]

        // Abiraterone
        ABI_dose [label="Abiraterone Acetate\n(mg/day)" shape=parallelogram fillcolor="#FEC44F"]
        ABI_cent [label="ABI_CENT" fillcolor="#FEE391"]
        ABI_CYP17 [label="ABI–CYP17A1\nInhibition" fillcolor="#FEC44F" shape=ellipse]

        // mFSH/Gonadotropin support
        chronotherapy [label="Chronotherapy\n(Modified-release HC)" fillcolor="#FEE391"]
        modified_hc [label="Plenadren® /\nChronoCort®\n(Dual-release HC)" fillcolor="#FEE391"]
    }

    // =========================================================
    // CLUSTER 10: Glucocorticoid PD Effects
    // =========================================================
    subgraph cluster_GC_PD {
        label="Glucocorticoid PD – Genomic / Non-genomic Effects"
        style=filled
        color="#9ECAE1"
        fillcolor="#EBF5FB"
        fontsize=11
        fontcolor="#1A3A5C"

        GR_receptor [label="Glucocorticoid\nReceptor (GR, NR3C1)" shape=ellipse fillcolor="#6BAED6" fontcolor=white]
        GR_translocation [label="GR Nuclear\nTranslocation" fillcolor="#DEEBF7"]
        GRE_binding [label="GRE Binding\n(Transactivation)" fillcolor="#DEEBF7"]
        nGRE_binding [label="nGRE Binding\n(Transrepression)" fillcolor="#DEEBF7"]
        GC_ACTH_suppress [label="GC → ACTH\nSuppression" fillcolor="#C6DBEF"]
        GC_CRH_suppress [label="GC → CRH\nSuppression" fillcolor="#C6DBEF"]
        GILZ [label="GILZ\n(GC-Induced Leucine\nZipper)" fillcolor="#DEEBF7"]
        GC_metabolic [label="GC Metabolic\nSide-Effects" fillcolor="#DEEBF7"]
        GC_insulin_resist [label="Insulin Resistance\n(GC-induced)" fillcolor="#FFF3CD"]
        GC_BMD_effect [label="BMD Reduction\n(GC-induced)" fillcolor="#FFF3CD"]
        GC_growth_suppres [label="Growth Suppression\n(GC-induced)" fillcolor="#FFF3CD"]
        GC_immune_suppres [label="Immune Suppression\n(GC anti-inflammatory)" fillcolor="#DEEBF7"]
        FKBP51 [label="FKBP51\n(GR Sensitivity\nModulator)" fillcolor="#DEEBF7"]
    }

    // =========================================================
    // CLUSTER 11: Clinical Endpoints / Biomarkers
    // =========================================================
    subgraph cluster_clinical_endpoints {
        label="Clinical Endpoints & Biomarkers"
        style=filled
        color="#74C476"
        fillcolor="#F7FCF5"
        fontsize=11
        fontcolor="#1A4A1A"

        serum_17OHP [label="Serum 17-OHP\n(nmol/L)\nTarget: <36 nmol/L" fillcolor="#41AB5D" fontcolor=white shape=cylinder]
        serum_ACTH_ep [label="Serum ACTH\n(pg/mL)\nTarget: <100 pg/mL" fillcolor="#74C476" fontcolor=white shape=cylinder]
        serum_andros [label="Serum\nAndrostenedione\n(nmol/L)\nTarget: <7 nmol/L" fillcolor="#41AB5D" fontcolor=white shape=cylinder]
        serum_testost [label="Serum Testosterone\n(nmol/L)\nTarget: Age-appropriate" fillcolor="#74C476" fontcolor=white shape=cylinder]
        serum_DHEAS_ep [label="Serum DHEA-S\n(μmol/L)" fillcolor="#A1D99B" shape=cylinder]
        serum_cortisol_ep [label="Serum Cortisol\n(nmol/L)\nTarget: Normal range" fillcolor="#A1D99B" shape=cylinder]
        urinary_17keto [label="Urinary 17-Keto-\nsteroids (mg/24h)" fillcolor="#C7E9C0" shape=cylinder]
        urine_pregnanetriol [label="Urine\nPregnantriol" fillcolor="#C7E9C0" shape=cylinder]
        PRA_endpoint [label="Plasma Renin Activity\n(PRA)\nTarget: Normal range" fillcolor="#A1D99B" shape=cylinder]
        height_SDS_ep [label="Height SDS" fillcolor="#74C476" fontcolor=white shape=cylinder]
        bone_age_ep [label="Bone Age\nAdvancement (yr)" fillcolor="#A1D99B" shape=cylinder]
        weight_BMI [label="Weight / BMI\n(GC overtreatment\nrisk)" fillcolor="#A1D99B" shape=cylinder]
        CAH_severity [label="CAH Severity\n(SW > SV > NC)" fillcolor="#41AB5D" fontcolor=white shape=diamond]
        genotype [label="Genotype\n(CYP21A2 mutation\nclass I–IV)" fillcolor="#C7E9C0"]
    }

    // =========================================================
    // CLUSTER 12: Metabolic / Cardiometabolic Complications
    // =========================================================
    subgraph cluster_metabolic {
        label="Metabolic / Cardiometabolic Complications"
        style=filled
        color="#FC8D59"
        fillcolor="#FEF5E7"
        fontsize=11
        fontcolor="#7F2900"

        obesity_GC [label="Obesity / Adiposity\n(GC excess)" fillcolor="#FDBB84"]
        metabolic_syndrome_CAH [label="Metabolic Syndrome\n(Androgen + GC)" fillcolor="#FDBB84"]
        insulin_resistance_CAH [label="Insulin Resistance\n/ Type 2 DM risk" fillcolor="#FDBB84"]
        cardiovascular_risk [label="Cardiovascular Risk\n(Androgen/GC/HTN)" fillcolor="#FC8D59" fontcolor=white]
        hypertension_CAH [label="Hypertension\n(GC/MC excess)" fillcolor="#FDBB84"]
        dyslipidemia_CAH [label="Dyslipidemia\n(GC-induced)" fillcolor="#FDBB84"]
        visceral_fat [label="Visceral Fat\nAccumulation" fillcolor="#FEE0C6"]
        liver_GC [label="GC-induced\nLiver Steatosis" fillcolor="#FEE0C6"]
        adrenal_androgens_cardio [label="Excess Adrenal\nAndrogens → CVD risk" fillcolor="#FEE0C6"]
    }

    // =========================================================
    // CLUSTER 13: Psychosocial / Quality of Life
    // =========================================================
    subgraph cluster_psychosocial {
        label="Psychosocial / Quality of Life Outcomes"
        style=filled
        color="#BCBDDC"
        fillcolor="#F5F4FB"
        fontsize=11
        fontcolor="#3F007D"

        QoL [label="Quality of Life\n(SF-36 / EQ-5D)" fillcolor="#9E9AC8" fontcolor=white shape=cylinder]
        anxiety_depression [label="Anxiety /\nDepression\n(Prevalence ↑ in CAH)" fillcolor="#BCBDDC"]
        gender_identity [label="Gender Identity\n(Atypical rates\nin 46,XX CAH)" fillcolor="#DADAEB"]
        surgical_outcomes [label="Genital Surgery\nOutcomes" fillcolor="#DADAEB"]
        body_image [label="Body Image\nDisturbance" fillcolor="#DADAEB"]
        sexual_function [label="Sexual Function\nImpairment" fillcolor="#DADAEB"]
        daily_pill_burden [label="Daily Treatment\nBurden (2-3×/day)" fillcolor="#DADAEB"]
        adrenal_crisis_fear [label="Fear of\nAdrenal Crisis" fillcolor="#DADAEB"]
        patient_adherence [label="Treatment\nAdherence\n(Pediatric challenge)" fillcolor="#9E9AC8" fontcolor=white]
    }

    // =========================================================
    // CLUSTER 14: Genetic / Molecular Basis
    // =========================================================
    subgraph cluster_genetics {
        label="Genetic Basis (CYP21A2 Locus)"
        style=filled
        color="#F768A1"
        fillcolor="#FFF0F6"
        fontsize=11
        fontcolor="#7F0058"

        CYP21A2_gene [label="CYP21A2 Gene\n(6p21.33 / HLA region)" fillcolor="#FA9FB5"]
        CYP21A1P [label="CYP21A1P\n(Pseudogene 98%\nhomology)" fillcolor="#FCCDE5"]
        gene_conversion [label="Gene Conversion\n(Major mutation\nmechanism)" fillcolor="#FCCDE5"]
        mutation_class1 [label="Class 1 (Null)\n→ Salt-Wasting (SW)\n>95% loss of function" fillcolor="#FA9FB5"]
        mutation_class2 [label="Class 2\n→ Simple Virilizing (SV)\n~1-2% residual activity" fillcolor="#FDD3E8"]
        mutation_class3 [label="Class 3 (NC)\n→ Non-Classical (NC)\n~20-50% residual" fillcolor="#FCCDE5"]
        del30kb [label="30 kb Deletion\n(Most common\nnull allele)" fillcolor="#FCCDE5"]
        I2G_splice [label="I2G Splice Mutation\nQ318X / R356W" fillcolor="#FCCDE5"]
        V281L [label="V281L\n(Frequent in\nNon-Classical CAH)" fillcolor="#FCCDE5"]
        P30L [label="P30L\n(Mild phenotype)" fillcolor="#FCCDE5"]
        HLA_region [label="HLA Region\n(6p21 Linkage)" fillcolor="#FCCDE5"]
        carrier_state [label="Carrier State\n(1/50-60 in general\npopulation)" fillcolor="#FCCDE5"]
        newborn_screen [label="Newborn Screening\n(17-OHP dried blood spot)" fillcolor="#FA9FB5"]
        prenatal_dx [label="Prenatal Diagnosis\n/ DEX prenatal Rx" fillcolor="#FCCDE5"]
    }

    // ==========================================================
    // EDGES - HPA Axis
    // ==========================================================
    stress_input -> CRH_synthesis [label="stimulates" color="#D62728"]
