    CYP21A2_BLOCK -> S_compound [label="→ Compound S\n[BLOCKED]" style=dashed color="#CB181D"]
    DOC -> CYP11B2_node [label="to corticosterone"]
    CYP11B2_node -> corticosterone [label="→ B"]
    corticosterone -> CYP11B2_node [label="to aldosterone"]
    CYP11B2_node -> aldosterone [label="→ Aldosterone\n[DEFICIENT SW]" color="#E6550D"]
    S_compound -> CYP11B1_node [label="substrate"]
    CYP11B1_node -> cortisol [label="→ Cortisol\n[DEFICIENT]" color="#E6550D"]
    androstenedione -> HSD17B_node [label="17β-HSD"]
