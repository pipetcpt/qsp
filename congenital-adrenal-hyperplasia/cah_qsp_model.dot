    adrenodoxin -> CYP11B1_node [label="electron donor" style=dashed]

    // Aldosterone / mineralocorticoid axis
    aldosterone -> MR_receptor [label="activates" color="#2171B5"]
    FC_cent -> MR_receptor [label="activates\n(fludrocortisone)"]
