    // HPA Feedback
    GC_hypothal_feedback -> CRH_synthesis [label="⊣ suppresses" color="#2171B5" arrowhead=tee]
    GC_pit_feedback -> ACTH_synthesis [label="⊣ suppresses" color="#2171B5" arrowhead=tee]
