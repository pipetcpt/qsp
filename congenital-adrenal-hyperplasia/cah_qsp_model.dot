    adrenal_hyperplasia -> adrenal_volume [label="enlarges"]
    ACTH_receptor_MC2R -> cholesterol_transport [label="activates\nStAR" color="#D62728"]

    // Steroidogenesis pathway
    cholesterol_transport -> cholesterol [label="IMM transport\n(rate-limiting)"]
