digraph TrigeminalNeuralgia_QSP {
    rankdir=LR;
    fontname="Helvetica";
    labelloc="t";
    fontsize=26;
    label="Trigeminal Neuralgia (TN) — Mechanistic QSP Map\nNeurovascular Compression · Nav Channelopathy · Central Sensitization · Anticonvulsant PK/PD · Interventional Therapy";
    node [style=filled, fontname="Helvetica", fontsize=11, shape=box, margin="0.12,0.08"];
    edge [fontname="Helvetica", fontsize=9, color="gray35"];

    subgraph cluster_etio {
        label="1. 병인/위험인자 (Etiology & Risk Factors)"; style=filled; color="#f2e2c4"; node [fillcolor="#f7d896"];
        Age_risk [label="고령 (50-70세 발병 피크)"];
        Sex_risk [label="여성:남성 ~1.5-1.7:1"];
        HTN_risk [label="고혈압 (동맥 만곡/박동성↑)"];
        Genetic_pred [label="유전적 소인 (가족성 TN, 상염색체 우성 일부)"];
        Vascular_ectasia [label="추골-뇌저동맥 확장/만곡(dolichoectasia)"];
        MS_assoc [label="다발성경화증 동반 (secondary TN, ~2-4%)"];
        Tumor_assoc [label="종양 압박 (뇌교소각 종양, 표피낭종)"];
        AVM_assoc [label="동정맥기형/정맥압박"];
    }

    subgraph cluster_nvc {
        label="2. 신경혈관 압박 (Neurovascular Compression, NVC)"; style=filled; color="#d9e4f5"; node [fillcolor="#a9c6ec"];
        SCA_compression [label="상소뇌동맥(SCA) 압박 (~75-80%)"];
        AICA_compression [label="전하소뇌동맥(AICA) 압박"];
        Vein_compression [label="정맥 압박 (petrosal vein 등)"];
        REZ [label="삼차신경근 진입부(REZ) 압박 부위"];
        Pulsatile_compression [label="박동성 기계적 압박 (심박동 동조)"];
        Compression_chronicity [label="만성 압박 지속시간"];
    }

    subgraph cluster_demyelin {
        label="3. 국소 탈수초화 (Focal Demyelination)"; style=filled; color="#e3d3ef"; node [fillcolor="#c9a8e3"];
        Schwann_injury [label="슈반세포/희소돌기세포 손상"];
        Focal_demyelination [label="REZ 국소 탈수초 병변"];
        Naked_axon [label="나출축삭(naked axon) 노출"];
        Myelin_biomarker [label="MRI FIESTA/CISS 압박·탈수초 영상소견"];
    }

    subgraph cluster_ionchannel {
        label="4. 이온채널 병태생리 (Nav Channelopathy)"; style=filled; color="#f5dede"; node [fillcolor="#eda9a9"];
        Nav17_upreg [label="Nav1.7 (SCN9A) 발현 증가"];
        Nav13_upreg [label="Nav1.3 (SCN3A) 재발현 (배아형 재활성)"];
        Nav16_redistrib [label="Nav1.6 (SCN8A) 재분포"];
        Nav18_altered [label="Nav1.8 (SCN10A) 발현 변화"];
        Ectopic_discharge [label="이소성 자발 방전(ectopic discharge) 생성"];
        Afterdischarge [label="후발방전(afterdischarge)/폭발성 발화"];
        Threshold_lowering [label="발화 임계값 저하"];
    }

    subgraph cluster_ephaptic {
        label="5. 말초 신호누출·과민화 (Ephaptic Crosstalk & Peripheral Sensitization)"; style=filled; color="#dff0df"; node [fillcolor="#a7d8a7"];
        Ephaptic_crosstalk [label="탈수초 축삭간 전기적 누출(ephaptic transmission)"];
        AB_to_Adelta_crossover [label="Aβ(경촉각)→Aδ/C(통각) 신호 오배선"];
        Light_touch_trigger [label="경촉각(trigger zone) 자극→통증 유발"];
        Peripheral_sensitization [label="말초 과민화"];
        Neuroinflammation_local [label="국소 신경염증 (TNF-α, IL-1β, CGRP 방출)"];
    }

    subgraph cluster_central {
        label="6. 중추 경로/전달 (Central Trigeminal Pathway)"; style=filled; color="#fdeccb"; node [fillcolor="#f7cd7a"];
        TG_ganglion [label="삼차신경절(Gasserian ganglion)"];
        Spinal_trigeminal_nucleus [label="삼차신경핵 미부(Vc, nucleus caudalis)"];
        Trigeminothalamic_tract [label="삼차시상로(trigeminothalamic tract)"];
        VPM_thalamus [label="시상 VPM 핵"];
        Somatosensory_cortex [label="일차 체감각피질(S1, 안면 대표부위)"];
        Descending_modulation [label="하행성 통증조절 (PAG-RVM, 5-HT/NE)"];
    }

    subgraph cluster_sensitization {
        label="7. 중추 감작 (Central Sensitization)"; style=filled; color="#fbdad0"; node [fillcolor="#f2a58c"];
        NMDA_activation [label="NMDA 수용체 활성화"];
        Windup [label="점증반응(wind-up)"];
        Central_sensitization_idx [label="중추 감작 지수"];
        Glial_activation [label="위성세포/미세아교세포 활성화"];
        Allodynia [label="이질통(allodynia) 확산"];
    }

    subgraph cluster_secondary {
        label="8. 이차성 TN 병인 (Secondary TN Etiologies)"; style=filled; color="#e6e6e6"; node [fillcolor="#bfbfbf"];
        MS_plaque [label="교뇌 삼차신경 진입부 MS 플라크"];
        CPA_tumor_mass [label="뇌교소각 종양 (뇌수막종·신경초종)"];
        Bilateral_TN [label="양측성 TN (이차성 시사 소견)"];
        Sensory_loss_flag [label="객관적 감각소실 (red flag)"];
    }

    subgraph cluster_pk_cbz {
        label="9. Carbamazepine PK"; style=filled; color="#cfe8e0"; node [fillcolor="#79c2ac"];
        CBZ_dose [label="CBZ 경구 200-1200 mg/day (분할)"];
        CBZ_gut [label="위장관 (느린/가변적 흡수)"];
        CBZ_central [label="중심 구획 (Vd ~1L/kg, PPB ~75%)"];
        CBZ_epoxide [label="활성대사체 CBZ-10,11-epoxide"];
        CBZ_autoinduction [label="CYP3A4 자가유도 (반감기 36h→12-17h)"];
        CBZ_HLAB1502 [label="HLA-B*1502 (아시아인 SJS/TEN 위험)"];
    }

    subgraph cluster_pk_oxc {
        label="10. Oxcarbazepine PK"; style=filled; color="#cfe0ea"; node [fillcolor="#77a6c9"];
        OXC_dose [label="OXC 경구 600-1800 mg/day"];
        OXC_prodrug [label="전구약물 → MHD(monohydroxy metabolite)"];
        OXC_MHD_active [label="MHD 활성대사체 (Nav 차단)"];
        OXC_hyponatremia [label="저나트륨혈증 위험 (SIADH 유사)"];
    }

    subgraph cluster_pk_others {
        label="11. 병용/2차 약물 PK (Adjuncts)"; style=filled; color="#e6d9ef"; node [fillcolor="#bb98d9"];
        Baclofen_pk [label="바클로펜 경구 30-80 mg/day (GABA-B 효능제)"];
        Lamotrigine_pk [label="라모트리진 경구 (병용, 서서히 적정)"];
        Gabapentin_pk [label="가바펜틴 경구 (포화성 흡수, α2δ 결합)"];
        Pregabalin_pk [label="프레가발린 경구 (선형 PK, α2δ 결합)"];
        BoNTA_pk [label="보툴리눔독소A 안면 피하주사"];
    }

    subgraph cluster_pd {
        label="12. 약물 PD — Nav 차단 및 하류 효과"; style=filled; color="#f7dede"; node [fillcolor="#e88080"];
        Nav_blockade [label="전압의존적 Na+채널 사용의존적 차단"];
        Ectopic_suppression [label="이소성 발화 억제"];
        Synaptic_glutamate_reduction [label="시냅스 글루타메이트 방출 감소"];
        CaV_alpha2delta_block [label="α2δ 서브유닛 결합 → CaV 전류 감소 (가바펜티노이드)"];
        GABAB_activation [label="GABA-B 활성화 → 척수/뇌간 억제성 시냅스전달 증강 (바클로펜)"];
        SNARE_cleavage [label="SNAP-25 절단 → 신경전달물질/CGRP 방출 억제 (BoNT-A)"];
    }

    subgraph cluster_intervention {
        label="13. 시술/수술적 치료 (Interventional Therapy)"; style=filled; color="#d7ecd7"; node [fillcolor="#8fcf8f"];
        MVD_proc [label="미세혈관감압술(MVD, Jannetta)"];
        GammaKnife_proc [label="감마나이프 방사선수술(SRS)"];
        RF_rhizotomy [label="경피 고주파 신경근절제술(RF rhizotomy)"];
        Balloon_compression [label="경피 풍선압박술(PBC)"];
        Glycerol_rhizotomy [label="글리세롤 신경근절제술"];
        Postop_deafferentation [label="시술 후 감각차단(deafferentation)"];
        Recurrence_postop [label="시술 후 재발"];
    }

    subgraph cluster_safety {
        label="14. 이상반응/안전성 (Adverse Effects)"; style=filled; color="#f0e6d2"; node [fillcolor="#d9b979"];
        Sedation_ae [label="졸림/운동실조(ataxia)"];
        Hepatotox_ae [label="간독성/효소상승"];
        Hyponatremia_ae [label="저나트륨혈증"];
        SJS_TEN_ae [label="스티븐스-존슨증후군/TEN"];
        Agranulocytosis_ae [label="무과립구증/재생불량성빈혈"];
        Cognitive_ae [label="인지둔화"];
        FacialWeakness_ae [label="시술 후 안면감각저하/무감각통(anesthesia dolorosa)"];
        CorneaAE [label="각막반사 소실→노출성 각막염 (안신경분지 침범시)"];
    }

    subgraph cluster_endpoint {
        label="15. 임상 평가/엔드포인트 (Clinical Endpoints)"; style=filled; color="#dedff5"; node [fillcolor="#a6a9e8"];
        Paroxysm_frequency [label="발작 빈도 (회/일)"];
        Pain_intensity_NRS [label="통증 강도 (NRS 0-10)"];
        BNI_score [label="BNI Pain Intensity Scale (I-V)"];
        Remission_rate [label="완전 무통 관해율"];
        Time_to_recurrence [label="재발까지 시간"];
        QoL_PSSQ [label="삶의 질 (PSSQ/EQ-5D)"];
        Refractory_flag [label="약물난치성 판정 (2제 이상 실패)"];
    }

    subgraph cluster_natural {
        label="16. 자연경과/재발-관해 (Natural History)"; style=filled; color="#ece0e0"; node [fillcolor="#c99a9a"];
        Remitting_relapsing [label="관해-재발성 경과"];
        Disease_progression [label="발작 빈도/강도 진행성 악화"];
        Autonomic_features [label="자율신경 동반증상(유루/충혈, 비전형 TN)"];
        Atypical_TN [label="비전형 TN(TN2)/지속적 배경통 동반"];
    }

    subgraph cluster_branch {
        label="17. 삼차신경 분지/임상양상 (Trigeminal Branch & Presentation)"; style=filled; color="#d5efe9"; node [fillcolor="#8ed1bd"];
        V1_branch [label="V1 안신경분지 (~4%)"];
        V2_branch [label="V2 상악신경분지 (~40%)"];
        V3_branch [label="V3 하악신경분지 (~35%)"];
        Multi_branch [label="복합분지 침범 (~15-20%)"];
        ICHD3_criteria [label="ICHD-3 진단기준 (전기충격양 발작통)"];
        Diagnostic_MRI [label="고해상도 3D MRI(FIESTA/CISS) 신경혈관 확인"];
        Prevalence_epi [label="연간 발생률 ~4-13/100,000"];
    }

    subgraph cluster_comorbid {
        label="18. 정신건강/기능 동반영향 (Psychosocial Comorbidity)"; style=filled; color="#f2dfe9"; node [fillcolor="#d999bb"];
        Depression_comorbid [label="우울증 동반"];
        Anxiety_comorbid [label="불안/발작예기불안"];
        Sleep_disruption [label="수면장애"];
        Functional_disability [label="기능적 장애/실직·사회활동 감소"];
        Caregiver_burden [label="돌봄부담/의료비용 증가"];
    }

    subgraph cluster_2ndline {
        label="19. 2차 약물요법 (Second-line Agents)"; style=filled; color="#e7ecd2"; node [fillcolor="#b9cf85"];
        Topiramate_pk [label="토피라메이트 (병용, Nav/CA 억제)"];
        Phenytoin_pk [label="페니토인 (급성기 정맥/경구, Nav 차단)"];
        Levetiracetam_pk [label="레베티라세탐 (병용, SV2A)"];
        Sumatriptan_acute [label="수마트립탄 (급성발작기 실험적 사용)"];
    }

    /* ---- Cross-cluster mechanistic edges ---- */
    Age_risk -> Vascular_ectasia; HTN_risk -> Vascular_ectasia; Vascular_ectasia -> Pulsatile_compression;
    Genetic_pred -> SCA_compression;
    SCA_compression -> REZ; AICA_compression -> REZ; Vein_compression -> REZ; Pulsatile_compression -> REZ;
    REZ -> Compression_chronicity -> Schwann_injury -> Focal_demyelination;
    Focal_demyelination -> Naked_axon -> Myelin_biomarker;
    MS_assoc -> MS_plaque -> Focal_demyelination;
    Tumor_assoc -> CPA_tumor_mass -> REZ;
    AVM_assoc -> Vein_compression;
    CPA_tumor_mass -> Bilateral_TN; MS_plaque -> Bilateral_TN;
    Bilateral_TN -> Sensory_loss_flag;

    Naked_axon -> Nav17_upreg; Naked_axon -> Nav13_upreg; Naked_axon -> Nav16_redistrib; Naked_axon -> Nav18_altered;
    Nav17_upreg -> Ectopic_discharge; Nav13_upreg -> Ectopic_discharge; Nav16_redistrib -> Ectopic_discharge;
    Ectopic_discharge -> Afterdischarge -> Threshold_lowering;
    Naked_axon -> Ephaptic_crosstalk;
    Ephaptic_crosstalk -> AB_to_Adelta_crossover -> Light_touch_trigger;
    Threshold_lowering -> Peripheral_sensitization;
    Peripheral_sensitization -> Neuroinflammation_local;
    Neuroinflammation_local -> Peripheral_sensitization [style=dashed, label="양성 피드백"];

    Light_touch_trigger -> TG_ganglion -> Spinal_trigeminal_nucleus;
    Ectopic_discharge -> TG_ganglion;
    Spinal_trigeminal_nucleus -> Trigeminothalamic_tract -> VPM_thalamus -> Somatosensory_cortex;
    Descending_modulation -> Spinal_trigeminal_nucleus [style=dashed, label="하행성 억제/촉진"];

    Spinal_trigeminal_nucleus -> NMDA_activation -> Windup -> Central_sensitization_idx;
    Glial_activation -> Central_sensitization_idx;
    Central_sensitization_idx -> Allodynia;
    Allodynia -> Atypical_TN;
    Central_sensitization_idx -> Disease_progression;
    Disease_progression -> Remitting_relapsing;
    Remitting_relapsing -> Autonomic_features;

    CBZ_dose -> CBZ_gut -> CBZ_central -> CBZ_epoxide;
    CBZ_central -> CBZ_autoinduction [style=dashed, label="자가유도"];
    CBZ_autoinduction -> CBZ_central [style=dashed, label="CL↑"];
    CBZ_HLAB1502 -> SJS_TEN_ae;

    OXC_dose -> OXC_prodrug -> OXC_MHD_active;
    OXC_MHD_active -> Hyponatremia_ae [style=dashed];
    OXC_hyponatremia -> Hyponatremia_ae;

    Baclofen_pk -> GABAB_activation;
    Lamotrigine_pk -> Nav_blockade;
    Gabapentin_pk -> CaV_alpha2delta_block;
    Pregabalin_pk -> CaV_alpha2delta_block;
    BoNTA_pk -> SNARE_cleavage;

    CBZ_epoxide -> Nav_blockade;
    OXC_MHD_active -> Nav_blockade;
    Nav_blockade -> Ectopic_suppression -> Afterdischarge [style=dashed, label="억제"];
    Nav_blockade -> Synaptic_glutamate_reduction -> NMDA_activation [style=dashed, label="억제"];
    CaV_alpha2delta_block -> Synaptic_glutamate_reduction;
    GABAB_activation -> Spinal_trigeminal_nucleus [style=dashed, label="억제성 조절"];
    SNARE_cleavage -> Neuroinflammation_local [style=dashed, label="억제"];
    SNARE_cleavage -> Ectopic_discharge [style=dashed, label="말초 억제"];

    Ectopic_suppression -> Paroxysm_frequency [style=dashed, label="감소"];
    Central_sensitization_idx -> Pain_intensity_NRS;
    Paroxysm_frequency -> BNI_score;
    Pain_intensity_NRS -> BNI_score;
    BNI_score -> QoL_PSSQ;
    BNI_score -> Refractory_flag;
    Refractory_flag -> MVD_proc; Refractory_flag -> GammaKnife_proc; Refractory_flag -> RF_rhizotomy;
    Refractory_flag -> Balloon_compression; Refractory_flag -> Glycerol_rhizotomy;

    REZ -> MVD_proc [style=dashed, label="병인 제거"];
    MVD_proc -> Remission_rate; GammaKnife_proc -> Remission_rate; RF_rhizotomy -> Remission_rate;
    Balloon_compression -> Remission_rate; Glycerol_rhizotomy -> Remission_rate;
    MVD_proc -> Postop_deafferentation; RF_rhizotomy -> Postop_deafferentation; Balloon_compression -> Postop_deafferentation;
    Postop_deafferentation -> FacialWeakness_ae;
    Postop_deafferentation -> CorneaAE;
    Remission_rate -> Time_to_recurrence -> Recurrence_postop -> Refractory_flag [style=dashed, label="재시술 필요"];

    CBZ_dose -> Sedation_ae; OXC_dose -> Sedation_ae; Baclofen_pk -> Sedation_ae;
    CBZ_dose -> Hepatotox_ae; CBZ_dose -> Agranulocytosis_ae; CBZ_dose -> Cognitive_ae;
    Gabapentin_pk -> Sedation_ae; Pregabalin_pk -> Sedation_ae;

    Sedation_ae -> QoL_PSSQ [style=dashed, label="악화"];
    Hyponatremia_ae -> QoL_PSSQ [style=dashed, label="악화"];

    Light_touch_trigger -> V1_branch; Light_touch_trigger -> V2_branch; Light_touch_trigger -> V3_branch; Light_touch_trigger -> Multi_branch;
    V2_branch -> ICHD3_criteria; V3_branch -> ICHD3_criteria; V1_branch -> CorneaAE;
    ICHD3_criteria -> Diagnostic_MRI -> Myelin_biomarker;
    Prevalence_epi -> Age_risk;

    Refractory_flag -> Depression_comorbid; BNI_score -> Anxiety_comorbid; Paroxysm_frequency -> Sleep_disruption;
    Depression_comorbid -> Functional_disability; Anxiety_comorbid -> Functional_disability;
    Sleep_disruption -> QoL_PSSQ [style=dashed, label="악화"];
    Functional_disability -> Caregiver_burden;
    QoL_PSSQ -> Depression_comorbid [style=dashed, label="악순환"];

    Topiramate_pk -> Nav_blockade; Phenytoin_pk -> Nav_blockade; Levetiracetam_pk -> Synaptic_glutamate_reduction;
    Sumatriptan_acute -> Ectopic_discharge [style=dashed, label="실험적 억제"];
    Refractory_flag -> Topiramate_pk; Refractory_flag -> Phenytoin_pk; Refractory_flag -> Levetiracetam_pk;
}
