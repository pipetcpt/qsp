digraph IPF_QSP {
  graph [
    label="Idiopathic Pulmonary Fibrosis (IPF) — Quantitative Systems Pharmacology Model\nTGF-β/SMAD · Fibroblast Activation · ECM Remodeling · Pirfenidone & Nintedanib PK/PD",
    labelloc=t, labeljust=c,
    fontname="Helvetica-Bold", fontsize=22,
    rankdir=LR,
    splines=spline,
    nodesep=0.45, ranksep=0.9,
    bgcolor="#f9f9f9",
    pad=0.6
  ]
  node [fontname="Helvetica", fontsize=10, style=filled, shape=box, margin="0.12,0.06"]
  edge [fontname="Helvetica", fontsize=8, arrowsize=0.7]

  // ─── CLUSTER 1: Alveolar Epithelium ───────────────────────────────────────
  subgraph cluster_epithelium {
    label="Alveolar Epithelium (AEC I/II)"
    style=filled; bgcolor="#E8F4FD"; color="#2980B9"; penwidth=2;
    fontname="Helvetica-Bold"; fontsize=13;

    AEC2_normal   [label="AEC II\n(Normal)", fillcolor="#AED6F1"]
    AEC2_damage   [label="AEC II\n(Damaged/Senescent)", fillcolor="#F1948A"]
    AEC1          [label="AEC I\n(Gas Exchange)", fillcolor="#AED6F1"]
    AEC_apoptosis [label="AEC Apoptosis", fillcolor="#E74C3C", fontcolor=white]
    AEC_senes     [label="Cellular\nSenescence", fillcolor="#CB4335", fontcolor=white]
    AEC_EMT       [label="Epithelial-Mesenchymal\nTransition (EMT)", fillcolor="#F0B27A"]
    AEC_repair    [label="Epithelial\nRepair/Regeneration", fillcolor="#82E0AA"]
    SP_D          [label="Surfactant\nProtein-D (SP-D)", fillcolor="#D6EAF8"]
    SP_C          [label="Surfactant\nProtein-C (SP-C)", fillcolor="#D6EAF8"]
    KL6           [label="KL-6\nBiomarker", fillcolor="#D6EAF8", shape=diamond]
    ER_stress     [label="ER Stress\n(UPR Activation)", fillcolor="#FADBD8"]
    Telomere_short[label="Telomere\nShortening", fillcolor="#FDEBD0"]
    TERT          [label="TERT / TERC\nDysfunction", fillcolor="#FDEBD0"]
    p53_AEC       [label="p53 / p21\nSenescence Pathway", fillcolor="#FDEBD0"]
    Wnt_AEC       [label="Wnt/β-catenin\nAbnormal Activation", fillcolor="#D7BDE2"]
  }

  // ─── CLUSTER 2: Innate Immune / Macrophage ────────────────────────────────
  subgraph cluster_macrophage {
    label="Macrophages & Innate Immunity"
    style=filled; bgcolor="#FEF9E7"; color="#D4AC0D"; penwidth=2;
    fontname="Helvetica-Bold"; fontsize=13;

    AM_resting    [label="Alveolar Macrophage\n(Resting/M0)", fillcolor="#F9E79F"]
    M1_mac        [label="M1 Macrophage\n(Pro-inflammatory)", fillcolor="#F0B27A"]
    M2_mac        [label="M2 Macrophage\n(Pro-fibrotic)", fillcolor="#A9CCE3"]
    Neutrophil    [label="Neutrophil\nInflux", fillcolor="#FAD7A0"]
    DAMP          [label="DAMPs\n(HMGB1, HSP70)", fillcolor="#FDEBD0"]
    TLR4_signaling[label="TLR4/TLR9\nSignaling", fillcolor="#FAD7A0"]
    NLRP3         [label="NLRP3\nInflammasome", fillcolor="#F0B27A"]
    IL1b          [label="IL-1β", fillcolor="#F1948A"]
    IL18          [label="IL-18", fillcolor="#F1948A"]
    TNFa          [label="TNF-α", fillcolor="#F1948A"]
    IL6           [label="IL-6", fillcolor="#F1948A"]
    IL10          [label="IL-10\n(Anti-inflammatory)", fillcolor="#82E0AA"]
    IL13          [label="IL-13\n(Pro-fibrotic)", fillcolor="#F8C471"]
    IL4           [label="IL-4\n(Th2)", fillcolor="#F8C471"]
    Osteopontin   [label="Osteopontin\n(OPN)", fillcolor="#FDEBD0"]
    MMP12         [label="MMP-12\n(Macrophage Elastase)", fillcolor="#D5D8DC"]
  }

  // ─── CLUSTER 3: TGF-β Signaling Cascade ──────────────────────────────────
  subgraph cluster_tgfb {
    label="TGF-β Signaling (Central Fibrotic Driver)"
    style=filled; bgcolor="#FDEDEC"; color="#C0392B"; penwidth=2;
    fontname="Helvetica-Bold"; fontsize=13;

    TGFb1_latent  [label="Latent TGF-β1\n(LLC Complex)", fillcolor="#FADBD8"]
    TGFb1_active  [label="Active TGF-β1", fillcolor="#E74C3C", fontcolor=white]
    TGFb_receptor [label="TGFβRI / TGFβRII\nComplex", fillcolor="#FADBD8"]
    SMAD2_3       [label="pSMAD2/3\n(Activated)", fillcolor="#CB4335", fontcolor=white]
    SMAD4         [label="SMAD4\n(Co-SMAD)", fillcolor="#E74C3C", fontcolor=white]
    SMAD7         [label="SMAD7\n(Inhibitory)", fillcolor="#82E0AA"]
    SMAD_complex  [label="SMAD2/3-4\nNuclear Complex", fillcolor="#C0392B", fontcolor=white]
    TGIF          [label="TGIF / SKI / SnoN\n(Transcriptional Repressors)", fillcolor="#A9CCE3"]
    non_SMAD      [label="Non-SMAD Pathways\n(PI3K/AKT, MAPK, Rho)", fillcolor="#FADBD8"]
    CTGF_gene     [label="CTGF Gene\nTranscription", fillcolor="#FADBD8"]
    PAI1          [label="PAI-1\n(Plasminogen Inhibitor)", fillcolor="#F1948A"]
    Fibronectin   [label="Fibronectin\nUpregulation", fillcolor="#F1948A"]
    alpha_SMA_gene[label="α-SMA Gene\nExpression", fillcolor="#C0392B", fontcolor=white]
    Integrin_avb6 [label="αvβ6 Integrin\n(TGF-β Activator)", fillcolor="#FADBD8"]
    TSP1          [label="Thrombospondin-1\n(TSP-1)", fillcolor="#FADBD8"]
    MMP2_LTGF     [label="MMP-2/9\n(Latent TGF-β Activation)", fillcolor="#D5D8DC"]
    LOX           [label="Lysyl Oxidase\n(ECM Crosslinking)", fillcolor="#FADBD8"]
  }

  // ─── CLUSTER 4: Fibroblast & Myofibroblast ───────────────────────────────
  subgraph cluster_fibroblast {
    label="Fibroblast / Myofibroblast Activation"
    style=filled; bgcolor="#F4ECF7"; color="#7D3C98"; penwidth=2;
    fontname="Helvetica-Bold"; fontsize=13;

    Fibro_quiesc  [label="Quiescent\nFibroblast", fillcolor="#E8DAEF"]
    Fibro_activ   [label="Activated\nFibroblast", fillcolor="#BB8FCE"]
    Myofibro      [label="Myofibroblast\n(α-SMA+)", fillcolor="#7D3C98", fontcolor=white]
    Fibro_prolif  [label="Fibroblast\nProliferation", fillcolor="#D7BDE2"]
    Fibro_migrate [label="Fibroblast\nMigration", fillcolor="#D7BDE2"]
    Fibro_apop    [label="Fibroblast\nApoptosis Resistance", fillcolor="#F1948A"]
    IPF_fibro     [label="IPF Fibroblast\n(Epigenetically Altered)", fillcolor="#6C3483", fontcolor=white]
    HSP47         [label="HSP47\n(Collagen Chaperone)", fillcolor="#E8DAEF"]
    Fibro_senesc  [label="Fibroblast\nSenescence (SASP)", fillcolor="#F0B27A"]
    PDGF_R        [label="PDGFR-α/β\n(Growth Factor Receptor)", fillcolor="#D7BDE2"]
    FGF_R         [label="FGFR1/2\n(FGF Receptor)", fillcolor="#D7BDE2"]
    IGF1_R        [label="IGF-1R\n(Survival Signal)", fillcolor="#D7BDE2"]
    YAP_TAZ       [label="YAP/TAZ\n(Mechanotransduction)", fillcolor="#A569BD"]
    FAK           [label="FAK\n(Focal Adhesion Kinase)", fillcolor="#BB8FCE"]
    Rho_ROCK      [label="Rho/ROCK\nPathway", fillcolor="#BB8FCE"]
  }

  // ─── CLUSTER 5: ECM Remodeling ────────────────────────────────────────────
  subgraph cluster_ecm {
    label="ECM Remodeling (MMP / TIMP Balance)"
    style=filled; bgcolor="#EAFAF1"; color="#1E8449"; penwidth=2;
    fontname="Helvetica-Bold"; fontsize=13;

    Col1A1        [label="Collagen I\n(COL1A1)", fillcolor="#A9DFBF"]
    Col3A1        [label="Collagen III\n(COL3A1)", fillcolor="#A9DFBF"]
    Fibronectin_ECM[label="Fibronectin\n(ECM)", fillcolor="#A9DFBF"]
    CTGF          [label="CTGF/CCN2\n(Pro-fibrotic)", fillcolor="#F8C471"]
    MMP1          [label="MMP-1\n(Collagenase)", fillcolor="#ABEBC6"]
    MMP2          [label="MMP-2\n(Gelatinase A)", fillcolor="#ABEBC6"]
    MMP7          [label="MMP-7\n(Matrilysin)\n★Biomarker", fillcolor="#27AE60", fontcolor=white, shape=diamond]
    MMP9          [label="MMP-9\n(Gelatinase B)", fillcolor="#ABEBC6"]
    MMP13         [label="MMP-13\n(Collagenase 3)", fillcolor="#ABEBC6"]
    TIMP1         [label="TIMP-1\n(MMP Inhibitor)", fillcolor="#F1948A"]
    TIMP2         [label="TIMP-2\n(MMP Inhibitor)", fillcolor="#F1948A"]
    Periostin     [label="Periostin\n★Biomarker", fillcolor="#27AE60", fontcolor=white, shape=diamond]
    TNC           [label="Tenascin-C", fillcolor="#D5D8DC"]
    Versican      [label="Versican\n(Proteoglycan)", fillcolor="#D5D8DC"]
    HA            [label="Hyaluronic Acid\n(HA)", fillcolor="#D5D8DC"]
    Elastin_degrad[label="Elastin\nDegradation", fillcolor="#F1948A"]
    Stiffness     [label="Matrix Stiffness\nIncrease", fillcolor="#7DCEA0", shape=hexagon]
  }

  // ─── CLUSTER 6: Growth Factors & Angiogenesis ────────────────────────────
  subgraph cluster_growth {
    label="Growth Factors & Vascular/Angiogenesis"
    style=filled; bgcolor="#FDF2E9"; color="#CA6F1E"; penwidth=2;
    fontname="Helvetica-Bold"; fontsize=13;

    PDGF_AB       [label="PDGF-AA/BB\n(Platelet-Derived GF)", fillcolor="#F0B27A"]
    FGF2          [label="FGF-2\n(Basic FGF)", fillcolor="#F0B27A"]
    VEGF          [label="VEGF-A\n(Angiogenesis)", fillcolor="#F0B27A"]
    VEGFR2        [label="VEGFR-2\n(Kinase Insert Domain R)", fillcolor="#FDEBD0"]
    EGF           [label="EGF / HGF\n(Epithelial Repair)", fillcolor="#82E0AA"]
    HGF           [label="HGF\n(Hepatocyte GF)", fillcolor="#82E0AA"]
    CTGF_protein  [label="CTGF Protein\n(CCN2 Secreted)", fillcolor="#F8C471"]
    ET1           [label="Endothelin-1\n(ET-1)", fillcolor="#F5CBA7"]
    ET_receptor   [label="ETA/ETB\nReceptors", fillcolor="#FDEBD0"]
    Angiopoietin  [label="Angiopoietin-1/2\n(Vessel Stabilization)", fillcolor="#F0B27A"]
    Neovascularization[label="Abnormal\nNeovascularization", fillcolor="#F8C471"]
    Platelet_activ[label="Platelet\nActivation", fillcolor="#FADBD8"]
    TXA2          [label="Thromboxane A2\n(TXA2)", fillcolor="#FADBD8"]
    CXCL12        [label="CXCL12/SDF-1\n(Fibrocyte Recruitment)", fillcolor="#D6EAF8"]
    Fibrocyte     [label="Circulating\nFibrocytes (CD45+/Col+)", fillcolor="#D6EAF8"]
  }

  // ─── CLUSTER 7: Oxidative Stress & Mitochondria ──────────────────────────
  subgraph cluster_oxidative {
    label="Oxidative Stress & Mitochondrial Dysfunction"
    style=filled; bgcolor="#FDFEFE"; color="#717D7E"; penwidth=2;
    fontname="Helvetica-Bold"; fontsize=13;

    ROS           [label="ROS\n(Reactive Oxygen Species)", fillcolor="#F1948A"]
    NOX4          [label="NOX4\n(NADPH Oxidase 4)", fillcolor="#F1948A"]
    Mito_ROS      [label="Mitochondrial\nROS", fillcolor="#F1948A"]
    Nrf2          [label="Nrf2\n(Antioxidant Defense)", fillcolor="#82E0AA"]
    GSH           [label="Glutathione\n(GSH)", fillcolor="#82E0AA"]
    NAC_target    [label="N-Acetylcysteine\nTarget (GSH Precursor)", fillcolor="#A9CCE3"]
    SOD           [label="Superoxide\nDismutase (SOD)", fillcolor="#82E0AA"]
    HO1           [label="Heme Oxygenase-1\n(HO-1)", fillcolor="#82E0AA"]
    Mito_dysfunc  [label="Mitochondrial\nDysfunction", fillcolor="#F1948A"]
    AMPK          [label="AMPK\n(Energy Sensor)", fillcolor="#D5D8DC"]
    mTOR          [label="mTOR\n(Pro-fibrotic Signaling)", fillcolor="#F8C471"]
    Autophagy     [label="Autophagy\nImpairment", fillcolor="#F1948A"]
    Lipid_perox   [label="Lipid\nPeroxidation", fillcolor="#F1948A"]
    Ferroptosis   [label="Ferroptosis\nSusceptibility", fillcolor="#F1948A"]
    mtDNA_damage  [label="mtDNA\nDamage", fillcolor="#F1948A"]
  }

  // ─── CLUSTER 8: Drug PK — Pirfenidone ────────────────────────────────────
  subgraph cluster_pk_pirf {
    label="Pirfenidone PK (ESBRIET® / Pirespa®)"
    style=filled; bgcolor="#EAF2FF"; color="#2471A3"; penwidth=2.5;
    fontname="Helvetica-Bold"; fontsize=13;

    PIRF_dose     [label="Pirfenidone Dose\n801 mg TID oral", fillcolor="#2471A3", fontcolor=white, shape=cylinder]
    PIRF_gut      [label="Gut Absorption\n(ka=1.74 h⁻¹)", fillcolor="#AED6F1"]
    PIRF_plasma   [label="Plasma\nConcentration (Cp)\nT½=2.4h", fillcolor="#2471A3", fontcolor=white]
    PIRF_periph   [label="Peripheral\nCompartment", fillcolor="#AED6F1"]
    PIRF_CYP1A2   [label="CYP1A2\nMetabolism (85%)", fillcolor="#D6EAF8"]
    PIRF_CYP2C9   [label="CYP2C9/3A4\nMetabolism (15%)", fillcolor="#D6EAF8"]
    PIRF_met      [label="5-Hydroxymethyl\nMetabolite", fillcolor="#D6EAF8"]
    PIRF_elim     [label="Renal\nElimination (80%)", fillcolor="#D6EAF8"]
    PIRF_food     [label="Food Effect\n(Tmax 3h fed vs 1h fasted)", fillcolor="#FDEBD0"]
    PIRF_F        [label="Bioavailability\nF~81%", fillcolor="#AED6F1"]
  }

  // ─── CLUSTER 9: Drug PK — Nintedanib ─────────────────────────────────────
  subgraph cluster_pk_nint {
    label="Nintedanib PK (OFEV®)"
    style=filled; bgcolor="#E8F8F5"; color="#1A5276"; penwidth=2.5;
    fontname="Helvetica-Bold"; fontsize=13;

    NINT_dose     [label="Nintedanib Dose\n150 mg BID oral", fillcolor="#1A5276", fontcolor=white, shape=cylinder]
    NINT_gut      [label="Gut Absorption\n(ka=0.8 h⁻¹)", fillcolor="#A3E4D7"]
    NINT_plasma   [label="Plasma\nConcentration (Cn)\nT½=9-11h", fillcolor="#1A5276", fontcolor=white]
    NINT_periph   [label="Peripheral\nCompartment", fillcolor="#A3E4D7"]
    NINT_CYP3A4   [label="CYP3A4\nMetabolism", fillcolor="#D1F2EB"]
    NINT_UGT      [label="UGT1A/FMO3\nGlucuronidation", fillcolor="#D1F2EB"]
    NINT_P_gp     [label="P-gp/BCRP\nEfflux Transporter", fillcolor="#FDEBD0"]
    NINT_biliary  [label="Biliary\nElimination (93%)", fillcolor="#D1F2EB"]
    NINT_F        [label="Bioavailability\nF~4.7% (Variable)", fillcolor="#A3E4D7"]
    NINT_met1     [label="BIBF1202\n(Active Metabolite)", fillcolor="#D1F2EB"]
  }

  // ─── CLUSTER 10: Drug PD & Targets ───────────────────────────────────────
  subgraph cluster_pd {
    label="Drug Pharmacodynamics & Molecular Targets"
    style=filled; bgcolor="#F5EEF8"; color="#6C3483"; penwidth=2.5;
    fontname="Helvetica-Bold"; fontsize=13;

    PIRF_TGFb_inh [label="Pirfenidone →\nTGF-β1 ↓ (Transcription)", fillcolor="#BB8FCE"]
    PIRF_PDGF_inh [label="Pirfenidone →\nPDGF ↓", fillcolor="#BB8FCE"]
    PIRF_TNF_inh  [label="Pirfenidone →\nTNF-α ↓", fillcolor="#BB8FCE"]
    PIRF_FGF_inh  [label="Pirfenidone →\nFGF ↓", fillcolor="#BB8FCE"]
    PIRF_ROS_inh  [label="Pirfenidone →\nROS ↓ (Antioxidant)", fillcolor="#BB8FCE"]
    NINT_VEGFR    [label="Nintedanib →\nVEGFR-1/2/3 Inhibition", fillcolor="#76D7C4"]
    NINT_PDGFR    [label="Nintedanib →\nPDGFRα/β Inhibition", fillcolor="#76D7C4"]
    NINT_FGFR     [label="Nintedanib →\nFGFR-1/2/3 Inhibition", fillcolor="#76D7C4"]
    NINT_Src      [label="Nintedanib →\nSrc/Lck Inhibition", fillcolor="#76D7C4"]
    NINT_RET      [label="Nintedanib →\nRET/CSF1R Inhibition", fillcolor="#76D7C4"]
    EC50_pirf     [label="Pirfenidone EC50\n~30 μg/mL (TGF-β inh)", fillcolor="#E8DAEF", shape=note]
    EC50_nint     [label="Nintedanib IC50\n~20 nM (FGFR1)", fillcolor="#D1F2EB", shape=note]
  }

  // ─── CLUSTER 11: Clinical Endpoints & Disease Progression ────────────────
  subgraph cluster_endpoints {
    label="Clinical Endpoints & Disease Progression"
    style=filled; bgcolor="#F8F9FA"; color="#2C3E50"; penwidth=2.5;
    fontname="Helvetica-Bold"; fontsize=13;

    FVC           [label="FVC % Predicted\n(Primary Endpoint)", fillcolor="#2C3E50", fontcolor=white, shape=hexagon]
    FVC_decline   [label="FVC Decline Rate\n~200 mL/year (untreated)", fillcolor="#E74C3C", fontcolor=white, shape=hexagon]
    DLCO          [label="DLCO % Predicted\n(Gas Exchange)", fillcolor="#5D6D7E", fontcolor=white, shape=hexagon]
    FEV1          [label="FEV1/FVC Ratio\n(Restrictive Pattern)", fillcolor="#D5D8DC", shape=hexagon]
    TLC           [label="TLC % Predicted\n(Total Lung Capacity)", fillcolor="#D5D8DC", shape=hexagon]
    SixMWT        [label="6-Minute Walk\nDistance (6MWD)", fillcolor="#85C1E9", shape=hexagon]
    SpO2          [label="SpO2 at Rest\n& Exercise", fillcolor="#85C1E9"]
    AE_IPF        [label="Acute Exacerbation\n(AE-IPF)", fillcolor="#E74C3C", fontcolor=white]
    Dyspnea       [label="Dyspnea Score\n(mMRC/Borg)", fillcolor="#AED6F1"]
    QoL           [label="Health-Related QoL\n(SGRQ, SF-36)", fillcolor="#AED6F1"]
    Mortality     [label="All-Cause\nMortality", fillcolor="#17202A", fontcolor=white, shape=hexagon]
    GAP_index     [label="GAP Index\n(Gender/Age/Physiology)", fillcolor="#D5D8DC"]
    CT_score      [label="HRCT Score\n(Honeycombing/GGO)", fillcolor="#D5D8DC"]
    Lung_volume   [label="Lung Volume\nLoss", fillcolor="#F1948A"]
    SPT           [label="Serum Periostin\n(Biomarker)", fillcolor="#27AE60", fontcolor=white, shape=diamond]
    MMP7_serum    [label="Serum MMP-7\n(Biomarker)", fillcolor="#27AE60", fontcolor=white, shape=diamond]
    CCL18         [label="CCL-18\n(Macrophage Biomarker)", fillcolor="#27AE60", fontcolor=white, shape=diamond]
  }

  // ─── CLUSTER 12: Comorbidities & Disease Modifiers ───────────────────────
  subgraph cluster_comorbid {
    label="Risk Factors, Comorbidities & Environmental Factors"
    style=filled; bgcolor="#FEF9E7"; color="#9A7D0A"; penwidth=2;
    fontname="Helvetica-Bold"; fontsize=13;

    Smoking       [label="Cigarette Smoking\n(Major Risk Factor)", fillcolor="#F5CBA7"]
    Micro_aspir   [label="Microaspiration /\nGERD", fillcolor="#FDEBD0"]
    Viral_trigger [label="Viral Triggers\n(EBV, CMV, COVID-19)", fillcolor="#FDEBD0"]
    Genetic_risk  [label="Genetic Risk\n(MUC5B, TERT, SFTPC)", fillcolor="#D6EAF8"]
    Age           [label="Age (>60 yrs)\nEpigenetic Changes", fillcolor="#FDEBD0"]
    MUC5B_variant [label="MUC5B Promoter\nVariant (rs35705950)", fillcolor="#D6EAF8"]
    TERT_mutation [label="TERT/TERC\nMutations (10-15%)", fillcolor="#D6EAF8"]
    SFTPC_mutation[label="SFTPC / SFTPA2\nMutations", fillcolor="#D6EAF8"]
    Microbiome    [label="Lung\nMicrobiome Dysbiosis", fillcolor="#A9DFBF"]
    Hyperox       [label="Oxidative Stress\nTriggers (Pollutants)", fillcolor="#F1948A"]
    PH_comorbid   [label="Pulmonary\nHypertension", fillcolor="#FADBD8"]
    GERD          [label="GERD / Acid Reflux", fillcolor="#FDEBD0"]
    Emphysema     [label="Combined Pulmonary\nFibrosis/Emphysema (CPFE)", fillcolor="#FDEBD0"]
    OSA_comorbid  [label="Obstructive Sleep\nApnea", fillcolor="#FDEBD0"]
    Lung_Ca       [label="Lung Cancer Risk\n(↑2-3x)", fillcolor="#C0392B", fontcolor=white]
  }

  // ═══════════════════════════════════════════════════════════════════════════
  // EDGES
  // ═══════════════════════════════════════════════════════════════════════════

  // Risk factors → Epithelial injury
  Smoking       -> AEC2_damage [color="#E67E22", label="↑Injury"]
  Micro_aspir   -> AEC2_damage [color="#E67E22"]
  Viral_trigger -> AEC2_damage [color="#E67E22"]
  Age           -> AEC_senes   [color="#E67E22"]
  Genetic_risk  -> Telomere_short [color="#5D6D7E"]
  MUC5B_variant -> AEC2_damage [color="#5D6D7E", style=dashed]
  TERT_mutation -> Telomere_short [color="#5D6D7E"]
  SFTPC_mutation -> ER_stress [color="#5D6D7E"]
  Microbiome    -> AM_resting  [color="#1E8449", label="Dysbiosis"]
  Hyperox       -> ROS         [color="#CB4335"]

  // AEC2 status transitions
  AEC2_normal   -> AEC2_damage [color="#E74C3C", label="Injury"]
  AEC2_damage   -> AEC_apoptosis [color="#CB4335"]
  AEC2_damage   -> AEC_senes   [color="#CB4335"]
  AEC2_damage   -> ER_stress   [color="#E74C3C"]
  AEC2_damage   -> DAMP        [color="#F0B27A", label="Release"]
  AEC2_damage   -> TGFb1_latent [color="#E74C3C", label="↑Secrete"]
  AEC2_damage   -> AEC_EMT     [color="#F0B27A"]
  AEC_senes     -> p53_AEC     [color="#CB4335"]
  AEC_senes     -> Fibro_senesc [color="#F0B27A", label="SASP paracrine", style=dashed]
  AEC_EMT       -> Fibro_activ  [color="#F0B27A"]
  AEC2_damage   -> SP_D        [color="#D5D8DC", label="↓SP-D", dir=none]
  AEC2_damage   -> KL6         [color="#2471A3", label="↑KL-6"]
  ER_stress     -> AEC_apoptosis [color="#E74C3C"]
  ER_stress     -> TGFb1_latent [color="#E74C3C"]
  Telomere_short -> AEC_senes  [color="#CB4335"]
  Telomere_short -> TERT       [color="#5D6D7E"]
  Wnt_AEC       -> AEC2_damage [color="#7D3C98", label="Block repair"]
  Wnt_AEC       -> Fibro_prolif [color="#7D3C98"]
  AEC2_normal   -> AEC_repair  [color="#27AE60", style=dashed]
  EGF           -> AEC_repair  [color="#27AE60"]
  HGF           -> AEC_repair  [color="#27AE60"]
  Integrin_avb6 -> TGFb1_active [color="#E74C3C", label="Activate TGF-β"]

  // Surfactant proteins
  SP_D          -> AM_resting  [color="#2471A3", label="↑Clearance", style=dashed]
  SP_C          -> AEC2_normal [color="#AED6F1", dir=both]

  // Macrophage pathways
  DAMP          -> TLR4_signaling [color="#F0B27A"]
  TLR4_signaling -> NLRP3     [color="#F0B27A"]
  NLRP3         -> IL1b        [color="#E74C3C", label="Cleave"]
  NLRP3         -> IL18        [color="#E74C3C"]
  AM_resting    -> M1_mac      [color="#F0B27A", label="Pro-inflam"]
  AM_resting    -> M2_mac      [color="#A9CCE3", label="IL-4/IL-13"]
  M1_mac        -> TNFa        [color="#E74C3C"]
  M1_mac        -> IL6         [color="#E74C3C"]
  M1_mac        -> IL1b        [color="#E74C3C"]
  M1_mac        -> MMP12       [color="#D5D8DC"]
  M2_mac        -> TGFb1_latent [color="#E74C3C", label="↑Secrete"]
  M2_mac        -> CTGF_protein [color="#F8C471"]
  M2_mac        -> IL10        [color="#27AE60"]
  M2_mac        -> Osteopontin [color="#FDEBD0"]
  IL4           -> M2_mac      [color="#A9CCE3", label="Polarize"]
  IL13          -> M2_mac      [color="#A9CCE3", label="Polarize"]
  IL10          -> M1_mac      [color="#27AE60", arrowhead=tee, label="Suppress"]
  TNFa          -> Fibro_activ [color="#E74C3C"]
  IL6           -> Fibro_prolif [color="#E74C3C"]
  Neutrophil    -> ROS         [color="#F1948A"]
  Neutrophil    -> MMP9        [color="#ABEBC6"]

  // TGF-β signaling cascade
  TGFb1_latent  -> TGFb1_active [color="#C0392B", label="Activation\n(Integrin/Protease)"]
  TSP1          -> TGFb1_active [color="#C0392B", label="Activate"]
  MMP2_LTGF     -> TGFb1_active [color="#C0392B"]
  TGFb1_active  -> TGFb_receptor [color="#C0392B", label="Bind"]
  TGFb_receptor -> SMAD2_3     [color="#C0392B", label="Phosphorylate"]
  SMAD2_3       -> SMAD4       [color="#C0392B", label="Complex"]
  SMAD4         -> SMAD_complex [color="#C0392B"]
  SMAD_complex  -> CTGF_gene   [color="#C0392B", label="Transcribe"]
  SMAD_complex  -> PAI1        [color="#C0392B", label="Transcribe"]
  SMAD_complex  -> Fibronectin  [color="#C0392B"]
  SMAD_complex  -> alpha_SMA_gene [color="#C0392B"]
  SMAD_complex  -> Col1A1      [color="#C0392B", label="↑Collagen"]
  SMAD_complex  -> TIMP1       [color="#E74C3C", label="↑TIMP-1"]
  SMAD7         -> TGFb_receptor [color="#27AE60", arrowhead=tee, label="Inhibit (SMURF)"]
  TGIF          -> SMAD_complex [color="#27AE60", arrowhead=tee]
  non_SMAD      -> Fibro_activ [color="#E74C3C", label="PI3K/AKT→proliferation"]
  non_SMAD      -> ROS         [color="#E74C3C"]
  TGFb1_active  -> non_SMAD   [color="#C0392B"]
  LOX           -> Stiffness   [color="#E74C3C"]
  Stiffness     -> TGFb1_active [color="#C0392B", label="Mechanotransduction"]
  Stiffness     -> YAP_TAZ     [color="#A569BD"]

  // Fibroblast cascade
  Fibro_quiesc  -> Fibro_activ  [color="#7D3C98", label="TGF-β/PDGF"]
  Fibro_activ   -> Myofibro     [color="#6C3483", label="α-SMA Express"]
  Myofibro      -> Col1A1       [color="#6C3483", label="↑↑ Secrete"]
  Myofibro      -> Col3A1       [color="#6C3483"]
  Myofibro      -> Fibronectin_ECM [color="#6C3483"]
  Myofibro      -> CTGF_protein [color="#6C3483"]
  Myofibro      -> TIMP1        [color="#E74C3C"]
  Myofibro      -> MMP2         [color="#ABEBC6"]
  Fibro_activ   -> Fibro_prolif [color="#BB8FCE"]
  Fibro_activ   -> Fibro_migrate [color="#BB8FCE"]
  Fibro_activ   -> IPF_fibro    [color="#6C3483", label="Epigenetic\nReprogramming"]
  IPF_fibro     -> Fibro_apop   [color="#E74C3C", label="bcl-2↑"]
  Fibro_apop    -> Fibro_activ  [color="#E74C3C", label="Persist", style=dashed]
  PDGF_R        -> Fibro_prolif [color="#F0B27A"]
  FGF_R         -> Fibro_prolif [color="#F0B27A"]
  IGF1_R        -> Fibro_apop   [color="#F0B27A"]
  YAP_TAZ       -> Fibro_activ  [color="#A569BD"]
  FAK           -> Rho_ROCK     [color="#BB8FCE"]
  Rho_ROCK      -> Myofibro     [color="#6C3483"]
  HSP47         -> Col1A1       [color="#A9DFBF", label="Fold/Secrete"]
  alpha_SMA_gene -> Myofibro    [color="#6C3483"]
  Fibro_senesc  -> IL6          [color="#F0B27A", label="SASP"]
  Fibro_senesc  -> TGFb1_active [color="#E74C3C", label="SASP"]
  Fibrocyte     -> Fibro_activ  [color="#D6EAF8", label="Differentiate"]
  CXCL12        -> Fibrocyte    [color="#D6EAF8", label="Recruit"]

  // ECM remodeling
  Col1A1        -> Stiffness    [color="#E74C3C"]
  Col3A1        -> Stiffness    [color="#E74C3C"]
  Fibronectin_ECM -> Stiffness  [color="#E74C3C"]
  MMP1          -> Col1A1       [color="#ABEBC6", arrowhead=tee, label="Degrade"]
  MMP2          -> Fibronectin_ECM [color="#ABEBC6", arrowhead=tee]
  MMP7          -> TGFb1_latent [color="#ABEBC6", label="Activate TGF-β"]
  MMP7          -> MMP7_serum   [color="#27AE60"]
  MMP9          -> TGFb1_latent [color="#ABEBC6"]
  MMP13         -> Col3A1       [color="#ABEBC6", arrowhead=tee]
  TIMP1         -> MMP1         [color="#E74C3C", arrowhead=tee, label="Inhibit"]
  TIMP1         -> MMP9         [color="#E74C3C", arrowhead=tee]
  TIMP2         -> MMP2         [color="#E74C3C", arrowhead=tee]
  Periostin     -> Col1A1       [color="#27AE60", label="Stabilize"]
  Periostin     -> Fibro_activ  [color="#27AE60"]
  Periostin     -> SPT          [color="#27AE60"]
  TNC           -> Fibro_migrate [color="#D5D8DC"]
  HA            -> TLR4_signaling [color="#F0B27A", style=dashed]
  Elastin_degrad -> Lung_volume  [color="#F1948A"]
  CTGF          -> Fibro_prolif [color="#F8C471"]
  CTGF          -> Col1A1       [color="#F8C471"]
  PAI1          -> Fibronectin_ECM [color="#F1948A"]
  MMP2_LTGF     -> MMP2         [color="#ABEBC6", dir=both]
  MMP12         -> Elastin_degrad [color="#ABEBC6"]

  // Growth factors
  PDGF_AB       -> PDGF_R       [color="#F0B27A"]
  FGF2          -> FGF_R        [color="#F0B27A"]
  VEGF          -> VEGFR2       [color="#F0B27A"]
  VEGFR2        -> Neovascularization [color="#F0B27A"]
  ET1           -> ET_receptor  [color="#F5CBA7"]
  ET_receptor   -> Fibro_prolif [color="#F5CBA7"]
  ET_receptor   -> Myofibro     [color="#F5CBA7"]
  Platelet_activ -> TGFb1_latent [color="#FADBD8"]
  Platelet_activ -> PDGF_AB     [color="#FADBD8"]
  Platelet_activ -> TXA2        [color="#FADBD8"]
  CTGF_protein  -> CTGF_gene   [color="#F8C471", dir=both]
  Angiopoietin  -> Neovascularization [color="#F0B27A"]
  EGF           -> AEC2_normal  [color="#82E0AA"]
  HGF           -> AEC2_normal  [color="#82E0AA"]

  // Oxidative stress
  NOX4          -> ROS          [color="#E74C3C"]
  Mito_ROS      -> ROS          [color="#E74C3C"]
  ROS           -> TGFb1_active [color="#E74C3C", label="↑Activate"]
  ROS           -> ER_stress    [color="#E74C3C"]
  ROS           -> AEC2_damage  [color="#E74C3C"]
  ROS           -> Fibro_activ  [color="#E74C3C"]
  Nrf2          -> GSH          [color="#27AE60", label="↑Synthesis"]
  Nrf2          -> HO1          [color="#27AE60"]
  Nrf2          -> SOD          [color="#27AE60"]
  GSH           -> ROS          [color="#27AE60", arrowhead=tee]
  SOD           -> ROS          [color="#27AE60", arrowhead=tee]
  AMPK          -> mTOR         [color="#ABEBC6", arrowhead=tee]
  mTOR          -> Fibro_prolif [color="#F8C471"]
  mTOR          -> Autophagy    [color="#F8C471", arrowhead=tee]
  Autophagy     -> AEC_apoptosis [color="#F1948A"]
  Mito_dysfunc  -> Mito_ROS    [color="#E74C3C"]
  Lipid_perox   -> AEC2_damage  [color="#E74C3C"]
  Ferroptosis   -> AEC2_damage  [color="#E74C3C"]
  mtDNA_damage  -> NLRP3        [color="#F0B27A"]
  NAC_target    -> GSH          [color="#82E0AA", label="↑GSH (NAC)"]
  NOX4          -> Myofibro     [color="#E74C3C", label="TGF-β→NOX4"]
  TGFb1_active  -> NOX4         [color="#E74C3C"]

  // Pirfenidone PK cascade
  PIRF_dose     -> PIRF_gut     [color="#2471A3"]
  PIRF_food     -> PIRF_gut     [color="#2471A3", style=dashed]
  PIRF_gut      -> PIRF_plasma  [color="#2471A3", label="F×ka"]
  PIRF_F        -> PIRF_gut     [color="#2471A3"]
  PIRF_plasma   -> PIRF_periph  [color="#AED6F1", dir=both]
  PIRF_plasma   -> PIRF_CYP1A2  [color="#AED6F1"]
  PIRF_plasma   -> PIRF_CYP2C9  [color="#AED6F1"]
  PIRF_CYP1A2   -> PIRF_met    [color="#D6EAF8"]
  PIRF_CYP2C9   -> PIRF_met    [color="#D6EAF8"]
  PIRF_met      -> PIRF_elim    [color="#D6EAF8"]

  // Pirfenidone PD
  PIRF_plasma   -> PIRF_TGFb_inh [color="#2471A3", label="Cp → Effect"]
  PIRF_plasma   -> PIRF_PDGF_inh [color="#2471A3"]
  PIRF_plasma   -> PIRF_TNF_inh  [color="#2471A3"]
  PIRF_plasma   -> PIRF_FGF_inh  [color="#2471A3"]
  PIRF_plasma   -> PIRF_ROS_inh  [color="#2471A3"]
  PIRF_TGFb_inh -> TGFb1_active  [color="#2471A3", arrowhead=tee, label="Suppress TGF-β"]
  PIRF_PDGF_inh -> PDGF_AB      [color="#2471A3", arrowhead=tee]
  PIRF_TNF_inh  -> TNFa         [color="#2471A3", arrowhead=tee]
  PIRF_FGF_inh  -> FGF2         [color="#2471A3", arrowhead=tee]
  PIRF_ROS_inh  -> ROS          [color="#2471A3", arrowhead=tee]
  EC50_pirf     -> PIRF_TGFb_inh [color="#E8DAEF", style=dashed]

  // Nintedanib PK cascade
  NINT_dose     -> NINT_gut     [color="#1A5276"]
  NINT_gut      -> NINT_plasma  [color="#1A5276", label="F×ka"]
  NINT_F        -> NINT_gut     [color="#1A5276"]
  NINT_plasma   -> NINT_periph  [color="#A3E4D7", dir=both]
  NINT_plasma   -> NINT_CYP3A4  [color="#A3E4D7"]
  NINT_plasma   -> NINT_UGT     [color="#A3E4D7"]
  NINT_CYP3A4   -> NINT_met1   [color="#D1F2EB"]
  NINT_UGT      -> NINT_biliary [color="#D1F2EB"]
  NINT_P_gp     -> NINT_F       [color="#E74C3C", arrowhead=tee, label="↓F"]

  // Nintedanib PD
  NINT_plasma   -> NINT_VEGFR   [color="#1A5276", label="Cn → Effect"]
  NINT_plasma   -> NINT_PDGFR   [color="#1A5276"]
  NINT_plasma   -> NINT_FGFR    [color="#1A5276"]
  NINT_plasma   -> NINT_Src     [color="#1A5276"]
  NINT_plasma   -> NINT_RET     [color="#1A5276"]
  NINT_VEGFR    -> VEGF         [color="#1A5276", arrowhead=tee, label="Block VEGFR"]
  NINT_PDGFR    -> PDGF_AB      [color="#1A5276", arrowhead=tee, label="Block PDGFR"]
  NINT_FGFR     -> FGF2         [color="#1A5276", arrowhead=tee, label="Block FGFR"]
  NINT_FGFR     -> Fibro_prolif [color="#1A5276", arrowhead=tee]
  NINT_Src      -> Fibro_migrate [color="#1A5276", arrowhead=tee]
  EC50_nint     -> NINT_FGFR    [color="#D1F2EB", style=dashed]

  // Disease endpoints
  Col1A1        -> Lung_volume  [color="#E74C3C", label="↓FVC"]
  Stiffness     -> Lung_volume  [color="#E74C3C"]
  Lung_volume   -> FVC          [color="#2C3E50"]
  FVC           -> FVC_decline  [color="#E74C3C", label="Rate"]
  AEC_apoptosis -> DLCO         [color="#E74C3C", label="↓Gas exchange"]
  Neovascularization -> DLCO    [color="#F0B27A", label="Abnormal", style=dashed]
  FVC           -> GAP_index    [color="#2C3E50"]
  DLCO          -> GAP_index    [color="#2C3E50"]
  FVC           -> Mortality    [color="#2C3E50"]
  GAP_index     -> Mortality    [color="#2C3E50"]
  AE_IPF        -> Mortality    [color="#E74C3C"]
  TGFb1_active  -> AE_IPF      [color="#E74C3C", label="↑Risk", style=dashed]
  FVC_decline   -> SixMWT       [color="#E74C3C"]
  FVC_decline   -> Dyspnea      [color="#E74C3C"]
  Dyspnea       -> QoL          [color="#5D6D7E"]
  SixMWT        -> QoL          [color="#5D6D7E"]
  CT_score      -> FVC          [color="#D5D8DC", style=dashed]
  PH_comorbid   -> SixMWT       [color="#E74C3C"]
  PH_comorbid   -> Mortality    [color="#E74C3C"]
  CCL18         -> M2_mac       [color="#27AE60", dir=both]
  SPT           -> Periostin    [color="#27AE60", dir=both]
  MMP7_serum    -> MMP7         [color="#27AE60", dir=both]

  // Comorbidities
  GERD          -> Micro_aspir  [color="#9A7D0A"]
  OSA_comorbid  -> Hyperox      [color="#9A7D0A"]
  Emphysema     -> FVC          [color="#9A7D0A", style=dashed]
  Lung_Ca       -> Stiffness    [color="#C0392B", style=dashed]
  PH_comorbid   -> ET1          [color="#F5CBA7"]

  // Treatment response on endpoints
  PIRF_TGFb_inh -> FVC_decline  [color="#2471A3", arrowhead=tee, label="−47% decline\n(ASCEND trial)"]
  NINT_FGFR     -> FVC_decline  [color="#1A5276", arrowhead=tee, label="−50% decline\n(INPULSIS trial)"]

}
