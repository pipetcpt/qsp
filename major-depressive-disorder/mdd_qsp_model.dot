digraph MDD_QSP {
    graph [rankdir=LR, fontname="Helvetica", fontsize=10, splines=ortho, nodesep=0.4, ranksep=1.2, label="Major Depressive Disorder: Comprehensive QSP Mechanistic Map\nQSP Model — 2026", labelloc=t, labelfontsize=16, bgcolor=white];
    node [fontname="Helvetica", fontsize=8, style=filled, shape=box];
    edge [fontname="Helvetica", fontsize=7];

    // =====================================================
    // CLUSTER 1: Drug PK — SSRI, SNRI, TCA, MAOI, Ketamine
    // =====================================================
    subgraph cluster_Drug_PK {
        label="Drug Pharmacokinetics";
        style=filled; fillcolor="#FFF8E1"; color="#E65100"; penwidth=2;

        // Escitalopram (SSRI)
        ESC_DOSE [label="Escitalopram\n10-20mg PO", fillcolor=gold, shape=ellipse];
        ESC_GUT  [label="Gut Absorption\nEsc (F=80%)", fillcolor=lightyellow];
        ESC_PLASMA [label="Escitalopram\nPlasma [Cp]", fillcolor=orange];
        ESC_PROTEIN [label="Protein Binding\nEsc (56%)", fillcolor=lightyellow];
        ESC_CYP [label="CYP2C19/3A4\nMetabolism", fillcolor=lightgreen];
        ESC_METAB [label="S-DCT\n(Active Metabolite)", fillcolor=lightyellow];

        // Venlafaxine (SNRI)
        VEN_DOSE [label="Venlafaxine\n75-225mg PO", fillcolor=gold, shape=ellipse];
        VEN_PLASMA [label="Venlafaxine\nPlasma [Cp]", fillcolor=orange];
        VEN_CYP [label="CYP2D6\nMetabolism", fillcolor=lightgreen];
        VEN_ODV [label="O-Desmethyl-\nvenlafaxine (ODV)", fillcolor=lightyellow];

        // TCA (Amitriptyline)
        AMI_DOSE [label="Amitriptyline\n75-150mg PO", fillcolor=gold, shape=ellipse];
        AMI_PLASMA [label="Amitriptyline\nPlasma [Cp]", fillcolor=orange];
        AMI_CYP [label="CYP2D6/2C19\nN-demethylation", fillcolor=lightgreen];
        AMI_NTP [label="Nortriptyline\n(Active Metabolite)", fillcolor=lightyellow];

        // MAOI (Phenelzine)
        PHEN_DOSE [label="Phenelzine\n15-45mg PO", fillcolor=gold, shape=ellipse];
        PHEN_PLASMA [label="Phenelzine\nPlasma [Cp]", fillcolor=orange];

        // Ketamine / Esketamine
        KET_DOSE [label="Ketamine IV\n0.5mg/kg", fillcolor=gold, shape=ellipse];
        KET_PLASMA [label="Ketamine\nPlasma [Cp]", fillcolor=orange];
        KET_NK [label="Norketamine\n(Active Metabolite)", fillcolor=lightyellow];
        ESKET_DOSE [label="Esketamine\n56-84mg IN", fillcolor=gold, shape=ellipse];

        // Lithium
        LITH_DOSE [label="Lithium\n600-1200mg PO", fillcolor=gold, shape=ellipse];
        LITH_PLASMA [label="Lithium\nSerum [Li+]", fillcolor=orange];

        // Bupropion
        BUP_DOSE [label="Bupropion\n150-300mg PO", fillcolor=gold, shape=ellipse];
        BUP_PLASMA [label="Bupropion\nPlasma [Cp]", fillcolor=orange];
        BUP_HBB [label="Hydroxybupropion\n(Active Metabolite)", fillcolor=lightyellow];

        // Aripiprazole (Augmentation)
        ARI_DOSE [label="Aripiprazole\n2-15mg PO", fillcolor=gold, shape=ellipse];
        ARI_PLASMA [label="Aripiprazole\nPlasma [Cp]", fillcolor=orange];

        ESC_DOSE -> ESC_GUT -> ESC_PLASMA -> ESC_PROTEIN;
        ESC_PLASMA -> ESC_CYP -> ESC_METAB;
        VEN_DOSE -> VEN_PLASMA -> VEN_CYP -> VEN_ODV;
        AMI_DOSE -> AMI_PLASMA -> AMI_CYP -> AMI_NTP;
        PHEN_DOSE -> PHEN_PLASMA;
        KET_DOSE -> KET_PLASMA -> KET_NK;
        ESKET_DOSE -> KET_PLASMA;
        LITH_DOSE -> LITH_PLASMA;
        BUP_DOSE -> BUP_PLASMA -> BUP_HBB;
        ARI_DOSE -> ARI_PLASMA;
    }

    // =====================================================
    // CLUSTER 2: Monoamine Synthesis
    // =====================================================
    subgraph cluster_Monoamine_Synthesis {
        label="Monoamine Synthesis & Degradation";
        style=filled; fillcolor="#E8F5E9"; color="#2E7D32"; penwidth=2;

        TRP [label="Tryptophan (TRP)\nDietary Intake", fillcolor=lightyellow];
        TRP_TRANSPORT [label="TRP Transport\nLAT1/2 (BBB)", fillcolor=lightblue];
        X5HTP [label="5-Hydroxytryptophan\n(5-HTP)", fillcolor=lightyellow];
        TPH1 [label="TPH1\n(Peripheral)", fillcolor=lightgreen];
        TPH2 [label="TPH2\n(Brain/Raphe)", fillcolor=lightgreen];
        DDC_5HT [label="Aromatic L-amino acid\ndecarboxylase (DDC)", fillcolor=lightgreen];
        X5HT_SYNTH [label="5-HT Synthesized\n(Cytoplasmic)", fillcolor=lightyellow];
        X5HT_VES [label="5-HT Vesicular\nStorage (VMAT2)", fillcolor=lightyellow];

        TYR [label="Tyrosine (TYR)\nDietary/Phe", fillcolor=lightyellow];
        TH [label="Tyrosine Hydroxylase\n(TH, rate-limiting)", fillcolor=lightgreen];
        DOPA [label="L-DOPA", fillcolor=lightyellow];
        AADC [label="AADC/DDC\n(Decarboxylase)", fillcolor=lightgreen];
        DA_SYNTH [label="Dopamine (DA)\nSynthesized", fillcolor=lightyellow];
        DBH [label="Dopamine β-\nHydroxylase (DBH)", fillcolor=lightgreen];
        NE_SYNTH [label="Norepinephrine (NE)\nSynthesized", fillcolor=lightyellow];
        PNMT [label="PNMT\n(Epi synthesis)", fillcolor=lightgreen];
        EPI [label="Epinephrine", fillcolor=lightyellow];

        MAO_A [label="MAO-A\n(5-HT, NE, DA)", fillcolor=lightgreen];
        MAO_B [label="MAO-B\n(DA, PEA)", fillcolor=lightgreen];
        COMT [label="COMT\n(Methylation)", fillcolor=lightgreen];
        ALDH [label="ALDH\n(Aldehyde oxidation)", fillcolor=lightgreen];
        X5HIAA [label="5-HIAA\n(5-HT metabolite)", fillcolor=lightyellow];
        DOPAC [label="DOPAC/HVA\n(DA metabolites)", fillcolor=lightyellow];
        MHPG [label="MHPG/VMA\n(NE metabolites)", fillcolor=lightyellow];

        TRP -> TRP_TRANSPORT -> X5HTP [label="TPH2"];
        TRP -> X5HTP [label="TPH1\n(gut)"];
        X5HTP -> X5HT_SYNTH [label="DDC"];
        X5HT_SYNTH -> X5HT_VES [label="VMAT2"];

        TYR -> DOPA [label="TH"];
        DOPA -> DA_SYNTH [label="AADC"];
        DA_SYNTH -> NE_SYNTH [label="DBH"];
        NE_SYNTH -> EPI [label="PNMT"];

        X5HT_SYNTH -> MAO_A -> X5HIAA;
        X5HT_SYNTH -> ALDH -> X5HIAA;
        DA_SYNTH -> MAO_B -> DOPAC;
        DA_SYNTH -> COMT -> DOPAC;
        NE_SYNTH -> MAO_A -> MHPG;
        NE_SYNTH -> COMT -> MHPG;
    }

    // =====================================================
    // CLUSTER 3: Serotonergic System
    // =====================================================
    subgraph cluster_Serotonergic {
        label="Serotonergic Signaling";
        style=filled; fillcolor="#E3F2FD"; color="#1565C0"; penwidth=2;

        SER_RAPHE [label="Dorsal Raphe\nNucleus (DRN)", fillcolor=lightyellow];
        X5HT_REL [label="5-HT Release\n(Synaptic)", fillcolor=lightyellow];
        SERT [label="SERT\n(5-HTT, SLC6A4)", fillcolor=lightblue, shape=diamond];
        X5HT_REUP [label="5-HT Reuptake\n(SERT-mediated)", fillcolor=lightyellow];
        X5HT_SYN [label="Synaptic [5-HT]\nConcentration", fillcolor=orange];

        X5HT1A_AUTO [label="5-HT1A\nAutoreceptor\n(Somatodendritic)", fillcolor=lightblue];
        X5HT1A_POST [label="5-HT1A\nPostsynaptic\n(Hippocampus/PFC)", fillcolor=lightblue];
        X5HT1A_DESENS [label="5-HT1A\nDesensitization\n(Chronic SSRI)", fillcolor=salmon];
        X5HT1B [label="5-HT1B/D\nTerminal Autoreceptor", fillcolor=lightblue];
        X5HT2A [label="5-HT2A Receptor\n(Cortex/Limbic)", fillcolor=lightblue];
        X5HT2C [label="5-HT2C Receptor\n(Appetite/Mood)", fillcolor=lightblue];
        X5HT3 [label="5-HT3 Receptor\n(Ion Channel)", fillcolor=lightblue];
        X5HT4 [label="5-HT4 Receptor\n(Hippocampus)", fillcolor=lightblue];
        X5HT7 [label="5-HT7 Receptor\n(Circadian/Mood)", fillcolor=lightblue];

        AC_5HT [label="Adenylyl Cyclase\n(5-HT1A-coupled)", fillcolor=lightgreen];
        CAMP_5HT [label="cAMP\n(5-HT pathway)", fillcolor=lightyellow];
        PKA_5HT [label="PKA\n(cAMP-dependent)", fillcolor=lightgreen];
        CREB_5HT [label="CREB\nPhosphorylation", fillcolor=lightyellow];
        PLC_5HT [label="PLC\n(5-HT2A-coupled)", fillcolor=lightgreen];
        IP3_5HT [label="IP3/DAG\n(Second messengers)", fillcolor=lightyellow];
        GI_5HT [label="Gi/Go Protein\n(5-HT1A)", fillcolor=lightblue];
        GQ_5HT [label="Gq/G11 Protein\n(5-HT2A/2C)", fillcolor=lightblue];

        SER_RAPHE -> X5HT_REL -> X5HT_SYN;
        X5HT_SYN -> SERT -> X5HT_REUP;
        X5HT_SYN -> X5HT1A_AUTO -> SER_RAPHE [label="neg feedback", color=red];
        X5HT1A_AUTO -> X5HT1A_DESENS [label="chronic", color=red];
        X5HT_SYN -> X5HT1A_POST -> GI_5HT -> AC_5HT -> CAMP_5HT -> PKA_5HT -> CREB_5HT;
        X5HT_SYN -> X5HT2A -> GQ_5HT -> PLC_5HT -> IP3_5HT;
        X5HT_SYN -> X5HT2C;
        X5HT_SYN -> X5HT3;
        X5HT_SYN -> X5HT4;
        X5HT_SYN -> X5HT7;
        X5HT_SYN -> X5HT1B -> X5HT_REL [label="inhibit", color=red];
    }

    // =====================================================
    // CLUSTER 4: Noradrenergic System
    // =====================================================
    subgraph cluster_Noradrenergic {
        label="Noradrenergic & Dopaminergic Signaling";
        style=filled; fillcolor="#F3E5F5"; color="#6A1B9A"; penwidth=2;

        LC [label="Locus Coeruleus\n(LC-NE System)", fillcolor=lightyellow];
        NE_REL [label="NE Release\n(Synaptic)", fillcolor=lightyellow];
        NET [label="NET\n(SLC6A2)", fillcolor=lightblue, shape=diamond];
        NE_REUP [label="NE Reuptake\n(NET-mediated)", fillcolor=lightyellow];
        NE_SYN_CONC [label="Synaptic [NE]\nConcentration", fillcolor=orange];

        ALPHA1 [label="α1 Receptor\n(Gq-coupled)", fillcolor=lightblue];
        ALPHA2_AUTO [label="α2 Autoreceptor\n(Gi-coupled)", fillcolor=lightblue];
        ALPHA2_POST [label="α2 Postsynaptic\n(PFC cognitive)", fillcolor=lightblue];
        BETA1 [label="β1 Receptor\n(Gs-coupled)", fillcolor=lightblue];
        BETA2 [label="β2 Receptor\n(Gs-coupled)", fillcolor=lightblue];

        VTA [label="VTA\n(Dopamine neurons)", fillcolor=lightyellow];
        DA_REL [label="DA Release\n(Mesolimbic/PFC)", fillcolor=lightyellow];
        DAT [label="DAT\n(SLC6A3)", fillcolor=lightblue, shape=diamond];
        DA_SYN_CONC [label="Synaptic [DA]\nConcentration", fillcolor=orange];
        D1R [label="D1/D5 Receptor\n(Gs/Golf)", fillcolor=lightblue];
        D2R [label="D2/D3 Receptor\n(Gi-coupled)", fillcolor=lightblue];

        ANHEDONIA [label="Anhedonia\n(↓ DA reward)", fillcolor=salmon];

        LC -> NE_REL -> NE_SYN_CONC;
        NE_SYN_CONC -> NET -> NE_REUP;
        NE_SYN_CONC -> ALPHA2_AUTO -> NE_REL [label="neg feedback", color=red];
        NE_SYN_CONC -> ALPHA1;
        NE_SYN_CONC -> ALPHA2_POST;
        NE_SYN_CONC -> BETA1;
        NE_SYN_CONC -> BETA2;

        VTA -> DA_REL -> DA_SYN_CONC;
        DA_SYN_CONC -> DAT -> DA_REL [label="reuptake"];
        DA_SYN_CONC -> D1R;
        DA_SYN_CONC -> D2R;
        DA_SYN_CONC -> ANHEDONIA [dir=back, label="↓DA", color=red];
    }

    // =====================================================
    // CLUSTER 5: HPA Axis
    // =====================================================
    subgraph cluster_HPA_Axis {
        label="HPA Axis & Stress Response";
        style=filled; fillcolor="#FFF3E0"; color="#E65100"; penwidth=2;

        STRESS [label="Psychosocial\nStress", fillcolor=salmon, shape=diamond];
        CRH_HYPO [label="CRH\n(Hypothalamus)", fillcolor=lightblue];
        AVP [label="AVP/Vasopressin\n(Synergistic)", fillcolor=lightyellow];
        ACTH_PIT [label="ACTH\n(Pituitary)", fillcolor=lightyellow];
        CORTISOL [label="Cortisol\n(Adrenal Cortex)", fillcolor=orange];
        GR [label="Glucocorticoid\nReceptor (GR)", fillcolor=lightblue];
        MR [label="Mineralocorticoid\nReceptor (MR)", fillcolor=lightblue];
        GR_DOWN [label="GR Downregulation\n(Chronic Stress)", fillcolor=salmon];
        HIPPO_NEG [label="Hippocampal\nNeg Feedback (↓)", fillcolor=lightyellow];
        HIPPO_NEURO [label="Hippocampal\nNeurogenesis (↓)", fillcolor=salmon];
        PFC_ATROPHY [label="PFC/Amygdala\nAtrophy", fillcolor=salmon];
        HIPPO_VOL [label="Hippocampal\nVolume Loss", fillcolor=salmon];
        DEXAM_TEST [label="Dexamethasone\nSuppression Test", fillcolor=gold];
        CRH_STIM [label="CRH Stimulation\nTest (Blunted)", fillcolor=lightyellow];

        STRESS -> CRH_HYPO [color=red];
        CRH_HYPO -> AVP [label="co-release"];
        CRH_HYPO -> ACTH_PIT;
        AVP -> ACTH_PIT;
        ACTH_PIT -> CORTISOL;
        CORTISOL -> GR;
        CORTISOL -> MR;
        GR -> CRH_HYPO [label="neg feedback", color=blue];
        GR -> ACTH_PIT [label="neg feedback", color=blue];
        CORTISOL -> GR_DOWN [label="chronic", color=red];
        GR_DOWN -> HIPPO_NEG [label="impaired", color=red];
        CORTISOL -> HIPPO_NEURO [label="inhibit", color=red];
        HIPPO_NEURO -> HIPPO_VOL [color=red];
        CORTISOL -> PFC_ATROPHY [color=red];
        DEXAM_TEST -> CORTISOL [style=dashed];
    }

    // =====================================================
    // CLUSTER 6: Neuroinflammation
    // =====================================================
    subgraph cluster_Neuroinflammation {
        label="Neuroinflammation & Kynurenine Pathway";
        style=filled; fillcolor="#FCE4EC"; color="#880E4F"; penwidth=2;

        MICRO_ACT [label="Microglia\nActivation (M1)", fillcolor=salmon];
        ASTRO_ACT [label="Astrocyte\nDysfunction", fillcolor=salmon];
        NFKB [label="NF-κB\nSignaling", fillcolor=lightgreen];
        IL1B [label="IL-1β\n(Inflammasome)", fillcolor=pink];
        IL6 [label="IL-6\n(Pleiotropic)", fillcolor=pink];
        TNF [label="TNF-α\n(Pro-inflammatory)", fillcolor=pink];
        CRP [label="CRP\n(Systemic marker)", fillcolor=pink];
        COX2 [label="COX-2\n(Prostaglandins)", fillcolor=lightgreen];
        PGE2 [label="PGE2\n(Neuroinflammation)", fillcolor=lightyellow];
        BBB_PERM [label="BBB Permeability\n(Increased)", fillcolor=salmon];
        IDO1 [label="IDO1\n(Rate-limiting, KP)", fillcolor=lightgreen];
        KMO [label="KMO\n(Kynurenine→3-OH-KYN)", fillcolor=lightgreen];
        TDO [label="TDO\n(Hepatic)", fillcolor=lightgreen];
        KYN [label="Kynurenine\n(KYN)", fillcolor=lightyellow];
        X3OH_KYN [label="3-Hydroxy-\nkynurenine", fillcolor=lightyellow];
        QUIN [label="Quinolinic Acid\n(QUIN, NMDA agonist)", fillcolor=salmon];
        KA [label="Kynurenic Acid\n(KA, NMDA antagonist)", fillcolor=lightyellow];
        PICOLINIC [label="Picolinic Acid\n(Neuroprotective)", fillcolor=lightyellow];
        TRP_DEPL [label="Tryptophan\nDepletion (brain)", fillcolor=salmon];

        STRESS -> MICRO_ACT [color=red];
        STRESS -> NFKB [color=red];
        MICRO_ACT -> IL1B;
        MICRO_ACT -> IL6;
        MICRO_ACT -> TNF;
        MICRO_ACT -> NFKB;
        NFKB -> COX2 -> PGE2;
        IL6 -> CRP;
        IL1B -> BBB_PERM [color=red];
        TNF -> BBB_PERM [color=red];
        BBB_PERM -> MICRO_ACT [label="→ CNS", color=red];

        IL6 -> IDO1 [label="induce", color=red];
        TNF -> IDO1 [label="induce", color=red];
        IDO1 -> KYN [label="TRP→KYN", color=red];
        TDO -> KYN;
        KYN -> KMO -> X3OH_KYN -> QUIN [color=red];
        KYN -> KA [label="KAT enzyme"];
        KYN -> PICOLINIC;
        QUIN -> TRP_DEPL [label="5-HT ↓", color=red];
        IDO1 -> TRP_DEPL [color=red];
        QUIN -> NFKB [label="→ excitotox", color=red];
    }

    // =====================================================
    // CLUSTER 7: Glutamate / NMDA System
    // =====================================================
    subgraph cluster_Glutamate_NMDA {
        label="Glutamate/NMDA & GABAergic System";
        style=filled; fillcolor="#E8EAF6"; color="#283593"; penwidth=2;

        GLUT_SYNTH [label="Glutamate\nSynthesis (Gln→Glu)", fillcolor=lightyellow];
        GLUT_REL [label="Glutamate\nRelease", fillcolor=lightyellow];
        GLUT_SYN [label="Synaptic\n[Glutamate]", fillcolor=orange];
        NMDA_R [label="NMDA Receptor\n(GluN1/GluN2A/B)", fillcolor=lightblue, shape=diamond];
        AMPA_R [label="AMPA Receptor\n(GluA1/GluA2)", fillcolor=lightblue, shape=diamond];
        MGLU23 [label="mGluR2/3\n(Presynaptic, Gi)", fillcolor=lightblue];
        MGLU5 [label="mGluR5\n(Postsynaptic)", fillcolor=lightblue];
        GABA_IN [label="GABA Interneurons\n(PV+, SST+)", fillcolor=lightblue];
        GABA_A [label="GABAA Receptor\n(Inhibitory)", fillcolor=lightblue];
        GABA_B [label="GABAB Receptor\n(Metabotropic)", fillcolor=lightblue];
        CA_INFL [label="Ca2+ Influx\n(NMDA-mediated)", fillcolor=lightyellow];
        CAMKII [label="CaMKII\n(Synaptic plasticity)", fillcolor=lightgreen];
        LTP [label="Long-Term\nPotentiation (LTP)", fillcolor=lightyellow];
        LTD [label="Long-Term\nDepression (LTD)", fillcolor=salmon];
        EAAT [label="EAAT1/2\n(Glutamate transporter)", fillcolor=lightblue];
        GLUT_EXCITOTOX [label="Glutamate\nExcitotoxicity", fillcolor=salmon];
        HCNR [label="HCN1 Channel\n(Ih current, PFC)", fillcolor=lightblue];

        GLUT_SYNTH -> GLUT_REL -> GLUT_SYN;
        GLUT_SYN -> NMDA_R -> CA_INFL -> CAMKII -> LTP;
        GLUT_SYN -> AMPA_R;
        AMPA_R -> LTP;
        GLUT_SYN -> MGLU23 -> GLUT_REL [label="neg fb", color=red];
        GLUT_SYN -> MGLU5;
        GLUT_SYN -> EAAT [label="reuptake"];
        GABA_IN -> GABA_A;
        GABA_IN -> GABA_B;
        GABA_A -> GLUT_REL [label="inhibit", color=blue];
        QUIN -> NMDA_R [label="agonist", color=red];
        GLUT_SYN -> GLUT_EXCITOTOX [label="excess", color=red];
        GLUT_EXCITOTOX -> HIPPO_NEURO [color=red];
        NMDA_R -> LTD [label="weak stim", color=red];
        CAMKII -> HCNR;
    }

    // =====================================================
    // CLUSTER 8: Neuroplasticity & BDNF
    // =====================================================
    subgraph cluster_Neuroplasticity {
        label="Neuroplasticity & BDNF Signaling";
        style=filled; fillcolor="#E0F2F1"; color="#00695C"; penwidth=2;

        BDNF_GENE [label="BDNF Gene\n(Val66Met polymorphism)", fillcolor=lightyellow];
        BDNF_PRO [label="proBDNF\n(Precursor)", fillcolor=lightyellow];
        BDNF [label="BDNF\n(Mature)", fillcolor=orange];
        TRKB [label="TrkB Receptor\n(NTRK2)", fillcolor=lightblue];
        P75NTR [label="p75NTR\n(Death receptor)", fillcolor=salmon];
        SHC [label="Shc/Grb2\nAdaptor", fillcolor=lightgreen];
        RAS_ERK [label="Ras/ERK1/2\nSignaling", fillcolor=lightgreen];
        PI3K [label="PI3K\nSignaling", fillcolor=lightgreen];
        AKT [label="AKT/PKB\n(Survival kinase)", fillcolor=lightgreen];
        GSK3B [label="GSK-3β\n(Tau/β-catenin)", fillcolor=lightgreen];
        BCAT [label="β-Catenin\n(Wnt/GSK-3β target)", fillcolor=lightyellow];
        MTORC1 [label="mTORC1\nComplex", fillcolor=lightgreen];
        P70S6K [label="p70S6K\n(Translation)", fillcolor=lightgreen];
        X4EBP1 [label="4E-BP1\n(Translational regulator)", fillcolor=lightgreen];
        CREB_BDNF [label="CREB\n(Transcription factor)", fillcolor=lightyellow];
        ARC [label="ARC/Arg3.1\n(Synaptic plasticity)", fillcolor=lightyellow];
        PSD95 [label="PSD-95\n(Scaffolding protein)", fillcolor=lightyellow];
        SYN [label="Synapsin I/II\n(Vesicle docking)", fillcolor=lightyellow];
        VEGF [label="VEGF\n(Neurogenesis)", fillcolor=lightyellow];
        PROG_CELLS [label="Neural Progenitor\nCells (SGZ)", fillcolor=lightyellow];
        NEW_NEURONS [label="New Neurons\n(Hippocampal)", fillcolor=lightyellow];
        SPINE_DENS [label="Dendritic Spine\nDensity", fillcolor=lightyellow];
        SYNAP_STR [label="Synaptic\nStrength", fillcolor=lightyellow];

        BDNF_GENE -> BDNF_PRO -> BDNF;
        BDNF -> TRKB -> SHC -> RAS_ERK -> CREB_BDNF;
        TRKB -> PI3K -> AKT -> MTORC1;
        AKT -> GSK3B [label="inhibit", color=blue];
        GSK3B -> BCAT [label="phospho/degrade", color=red];
        BCAT -> BDNF_GENE [label="transcription", color=blue];
        MTORC1 -> P70S6K -> ARC;
        MTORC1 -> X4EBP1;
        CREB_BDNF -> BDNF_GENE [label="autoregulate"];
        CREB_BDNF -> ARC;
        CREB_BDNF -> SYN;
        BDNF -> VEGF;
        BDNF -> PROG_CELLS -> NEW_NEURONS;
        VEGF -> PROG_CELLS;
        BDNF -> SPINE_DENS;
        PSD95 -> SYNAP_STR;
        SYN -> SYNAP_STR;
        BDNF -> P75NTR [label="proBDNF→apoptosis", color=red];
        ARC -> PSD95;
        NEW_NEURONS -> HIPPO_VOL [dir=back, label="restore", color=blue];
    }

    // =====================================================
    // CLUSTER 9: Circadian Rhythm
    // =====================================================
    subgraph cluster_Circadian {
        label="Circadian Rhythm & Sleep";
        style=filled; fillcolor="#EDE7F6"; color="#4527A0"; penwidth=2;

        SCN [label="SCN\n(Suprachiasmatic Nucleus)", fillcolor=lightyellow];
        CLOCK [label="CLOCK Protein\n(Core oscillator)", fillcolor=lightblue];
        BMAL1 [label="BMAL1\n(Heterodimer w/ CLOCK)", fillcolor=lightblue];
        PER1 [label="PER1\n(Period gene)", fillcolor=lightyellow];
        PER2 [label="PER2\n(Period gene)", fillcolor=lightyellow];
        CRY1 [label="CRY1/2\n(Cryptochrome)", fillcolor=lightyellow];
        ROR [label="RORα/γ\n(Nuclear receptor)", fillcolor=lightblue];
        REV_ERB [label="REV-ERBα/β\n(Repressor)", fillcolor=lightyellow];
        MELATONIN [label="Melatonin\n(Pineal gland)", fillcolor=lightyellow];
        MT1 [label="MT1 Receptor\n(Agomelatine)", fillcolor=lightblue];
        MT2 [label="MT2 Receptor\n(Phase shift)", fillcolor=lightblue];
        SLEEP_REM [label="REM Sleep\n(Disrupted in MDD)", fillcolor=salmon];
        SLEEP_SWS [label="SWS/NREM\n(Reduced in MDD)", fillcolor=salmon];
        SLEEP_LAT [label="Sleep Onset\nLatency (↑ MDD)", fillcolor=salmon];
        AGOMELATINE [label="Agomelatine\n(MT1/2 agonist,\n5-HT2C ant.)", fillcolor=gold, shape=ellipse];
        DIURNAL [label="Diurnal Mood\nVariation (AM worse)", fillcolor=salmon];

        SCN -> CLOCK;
        CLOCK -> BMAL1 [label="heterodimerize"];
        BMAL1 -> PER1;
        BMAL1 -> PER2;
        BMAL1 -> CRY1;
        PER1 -> CLOCK [label="neg fb", color=red];
        CRY1 -> CLOCK [label="neg fb", color=red];
        BMAL1 -> ROR;
        REV_ERB -> BMAL1 [label="repress", color=red];
        SCN -> MELATONIN;
        MELATONIN -> MT1;
        MELATONIN -> MT2;
        MT2 -> SCN [label="phase shift", color=blue];
        AGOMELATINE -> MT1 [label="agonist", color=blue, style=dashed];
        AGOMELATINE -> MT2 [label="agonist", color=blue, style=dashed];
        SLEEP_REM -> DIURNAL;
        SLEEP_SWS -> DIURNAL;
        SLEEP_LAT -> DIURNAL;
        CRH_HYPO -> SLEEP_REM [label="↑ REM", color=red];
        CORTISOL -> SLEEP_SWS [label="↓ SWS", color=red];
    }

    // =====================================================
    // CLUSTER 10: Clinical Endpoints
    // =====================================================
    subgraph cluster_Clinical {
        label="Clinical Endpoints & Biomarkers";
        style=filled; fillcolor="#FFFDE7"; color="#F57F17"; penwidth=2;

        PHQ9 [label="PHQ-9 Score\n(0-27)", fillcolor=lightyellow, penwidth=2];
        HDRS17 [label="HDRS-17\n(Hamilton Rating)", fillcolor=lightyellow, penwidth=2];
        MADRS [label="MADRS\n(Montgomery-Åsberg)", fillcolor=lightyellow, penwidth=2];
        RESPONSE [label="Clinical Response\n(≥50% symptom reduction)", fillcolor=lightgreen, penwidth=2];
        REMISSION [label="Remission\n(PHQ-9 < 5)", fillcolor=lightgreen, penwidth=2];
        COGNITIVE [label="Cognitive Function\n(Processing speed, Memory)", fillcolor=lightyellow];
        ANHEDONIA_SCORE [label="Anhedonia Score\n(SHAPS)", fillcolor=lightyellow];
        SUICIDALITY [label="Suicidality Risk\n(C-SSRS)", fillcolor=salmon];
        QOL [label="Quality of Life\n(SF-36, EQ-5D)", fillcolor=lightyellow];
        STAR_D [label="STAR*D Study\n(Remission 33%)", fillcolor=lightyellow, shape=note];
        TRD [label="Treatment-Resistant\nDepression (TRD)", fillcolor=salmon];
        RECURRENCE [label="Recurrence Risk\n(↑ episodes)", fillcolor=salmon];
        EARLY_RESP [label="Early Response\n(Week 2 predictor)", fillcolor=lightyellow];
        BIOMARKER_BDNF [label="Serum BDNF\n(Biomarker)", fillcolor=lightyellow];
        BIOMARKER_CRP [label="hsCRP\n(Inflammatory marker)", fillcolor=lightyellow];
        BIOMARKER_CORT [label="AM Cortisol\n(HPA marker)", fillcolor=lightyellow];

        PHQ9 -> RESPONSE;
        PHQ9 -> REMISSION;
        HDRS17 -> RESPONSE;
        MADRS -> RESPONSE;
        RESPONSE -> QOL [color=blue];
        REMISSION -> QOL [color=blue];
        SUICIDALITY -> TRD [color=red];
        REMISSION -> RECURRENCE [dir=back];
        TRD -> STAR_D;
        EARLY_RESP -> RESPONSE;
        BIOMARKER_BDNF -> PHQ9 [style=dashed, label="inverse"];
        BIOMARKER_CRP -> TRD [style=dashed, label="predict"];
        BIOMARKER_CORT -> HDRS17 [style=dashed];
        COGNITIVE -> PHQ9;
        ANHEDONIA_SCORE -> PHQ9;
    }

    // =====================================================
    // Drug Mechanism Arrows (Inter-cluster)
    // =====================================================

    // SSRI: Block SERT
    ESC_PLASMA -> SERT [label="Block SERT\n(Ki=1.1nM)", color=blue, style=dashed, penwidth=2];
    ESC_METAB -> SERT [label="Block SERT", color=blue, style=dashed];

    // SNRI: Block SERT + NET
    VEN_PLASMA -> SERT [label="Block SERT", color=blue, style=dashed, penwidth=2];
    VEN_ODV -> NET [label="Block NET\n(Ki=2.7nM)", color=blue, style=dashed, penwidth=2];

    // TCA: Block SERT + NET + receptors
    AMI_PLASMA -> SERT [label="Block SERT", color=blue, style=dashed];
    AMI_NTP -> NET [label="Block NET", color=blue, style=dashed];
    AMI_PLASMA -> ALPHA1 [label="Block α1", color=orange, style=dashed];

    // MAOI: Inhibit MAO-A/B
    PHEN_PLASMA -> MAO_A [label="Irreversible\nMAO-A inhibition", color=blue, style=dashed, penwidth=2];
    PHEN_PLASMA -> MAO_B [label="Irreversible\nMAO-B inhibition", color=blue, style=dashed];

    // Ketamine: Block NMDA
    KET_PLASMA -> NMDA_R [label="NMDA block\n(open channel)", color=blue, style=dashed, penwidth=2];
    KET_PLASMA -> AMPA_R [label="Disinhibit AMPA", color=blue, style=dashed];
    AMPA_R -> BDNF [label="→ BDNF release", color=blue];
    KET_PLASMA -> MTORC1 [label="Rapid activate", color=blue, style=dashed];
    KET_PLASMA -> GABA_IN [label="Block PV\ninterneurons", color=orange, style=dashed];

    // Bupropion: Block NET + DAT
    BUP_PLASMA -> NET [label="Block NET", color=blue, style=dashed];
    BUP_PLASMA -> DAT [label="Block DAT", color=blue, style=dashed, penwidth=2];
    BUP_HBB -> DAT [label="Block DAT", color=blue, style=dashed];

    // Lithium: GSK-3β inhibition
    LITH_PLASMA -> GSK3B [label="Inhibit GSK-3β\n(Ki~2mM)", color=blue, style=dashed, penwidth=2];
    LITH_PLASMA -> MTORC1 [label="→ neuroprotect", color=blue, style=dashed];
    LITH_PLASMA -> BDNF [label="↑ BDNF", color=blue, style=dashed];

    // Aripiprazole (augmentation)
    ARI_PLASMA -> D2R [label="Partial agonist", color=blue, style=dashed];
    ARI_PLASMA -> X5HT2A [label="Antagonist", color=blue, style=dashed];
    ARI_PLASMA -> X5HT1A_POST [label="Partial agonist", color=blue, style=dashed];

    // Cross-cluster pathophysiology
    X5HT_SYN -> BDNF [label="↑ BDNF", color=blue];
    CORTISOL -> BDNF [label="↓ BDNF", color=red];
    IL6 -> BDNF [label="↓ BDNF", color=red];
    TNF -> BDNF [label="↓ BDNF", color=red];
    BDNF -> PHQ9 [dir=back, label="restore", color=blue];
    BDNF -> HDRS17 [dir=back, label="improve", color=blue];
    CREB_5HT -> BDNF_GENE [label="transcription", color=blue];
    CREB_BDNF -> SERT [label="↑ SERT expr", color=red];
    X5HT_SYN -> PHQ9 [dir=back, label="↑5HT→improve", color=blue];
    NE_SYN_CONC -> COGNITIVE [label="↑ NE → cognition", color=blue];
    DA_SYN_CONC -> ANHEDONIA [dir=back, label="↑ DA", color=blue];
    ANHEDONIA -> ANHEDONIA_SCORE;
    HIPPO_VOL -> COGNITIVE [color=red, dir=back];
    HIPPO_VOL -> PHQ9 [color=red];
    CORTISOL -> SUICIDALITY [label="↑ HPA", color=red];
    IL6 -> SUICIDALITY [color=red];
    TRP_DEPL -> X5HT_SYN [label="↓ 5-HT synth", color=red];
    QUIN -> SUICIDALITY [color=red];
    SLEEP_REM -> PHQ9 [color=red];
    KA -> NMDA_R [label="NMDA antagonist\n(endogenous)", color=blue];
    MTORC1 -> SYNAP_STR [color=blue];
    SYNAP_STR -> COGNITIVE [color=blue];
    NEW_NEURONS -> PHQ9 [dir=back, label="neurogenesis\n→ antidepressant", color=blue];
    BIOMARKER_BDNF -> BDNF [style=dashed];
    BIOMARKER_CRP -> IL6 [style=dashed];
    BIOMARKER_CORT -> CORTISOL [style=dashed];
    ANHEDONIA_SCORE -> DA_SYN_CONC [style=dashed, dir=back];
    SUICIDALITY -> TRD;
    PHQ9 -> HDRS17 [style=invis];
    HDRS17 -> MADRS [style=invis];
}
