digraph MCTD_QSP {
  graph [
    label="Mixed Connective Tissue Disease (MCTD) — QSP Mechanistic Map\nAnti-U1-RNP Autoimmunity · Vascular Inflammation · Multi-organ Overlap (SLE+SSc+PM)"
    labelloc=t fontsize=22 fontname="Helvetica-Bold"
    bgcolor="#F8F9FA" rankdir=TB
    splines=curved nodesep=0.5 ranksep=0.7
    fontcolor="#2C3E50"
  ]
  node [style=filled fontname="Helvetica" fontsize=10 shape=box]
  edge [fontsize=9 fontname="Helvetica" color="#555555"]

  /* ============================================================
     CLUSTER 1: Genetic & Environmental Triggers
  ============================================================ */
  subgraph cluster_triggers {
    label="Genetic & Environmental Triggers" style=filled color="#EBF5FB"
    fontsize=13 fontname="Helvetica-Bold" fontcolor="#1A5276"

    HLA_DR4 [label="HLA-DR4/DR1\n(MHC-II alleles)" fillcolor="#AED6F1" shape=ellipse]
    HLA_DQ [label="HLA-DQ\nPolymorphisms" fillcolor="#AED6F1" shape=ellipse]
    STAT4 [label="STAT4 SNPs\n(Cytokine signaling)" fillcolor="#AED6F1" shape=ellipse]
    IRF5 [label="IRF5 Gene\nVariants" fillcolor="#AED6F1" shape=ellipse]
    EV_infect [label="Viral Infection\n(EBV, Parvovirus B19)" fillcolor="#F9E79F" shape=diamond]
    UV_expo [label="UV Radiation\n/ Stress" fillcolor="#F9E79F" shape=diamond]
    Estrogen [label="Estrogen\n(Hormonal influence)" fillcolor="#FDEBD0" shape=diamond]
    Smoking [label="Cigarette Smoke\n/ Silica Exposure" fillcolor="#F9E79F" shape=diamond]
  }

  /* ============================================================
     CLUSTER 2: U1-RNP Antigen & Autoantibody Production
  ============================================================ */
  subgraph cluster_autoantigen {
    label="U1-RNP Antigen Presentation & Autoantibody Generation" style=filled color="#EBF5FB"
    fontsize=13 fontname="Helvetica-Bold" fontcolor="#1A5276"

    U1snRNP [label="U1-snRNP Complex\n(70K, A, C proteins)" fillcolor="#D5D8DC" shape=cylinder]
    Apoptosis [label="Apoptotic Cell Death\nU1-snRNP Release" fillcolor="#FADBD8" shape=box]
    SecondaryNecr [label="Secondary Necrosis\nDAMP Release" fillcolor="#FADBD8" shape=box]
    HMGB1 [label="HMGB1\nDAMP" fillcolor="#F1948A"]
    pDC [label="Plasmacytoid\nDendritic Cell" fillcolor="#A9CCE3"]
    TLR7 [label="TLR7\n(ssRNA sensing)" fillcolor="#AED6F1" shape=ellipse]
    TLR8 [label="TLR8\n(ssRNA sensing)" fillcolor="#AED6F1" shape=ellipse]
    mDC [label="Myeloid\nDendritic Cell" fillcolor="#A9CCE3"]
    MHC2_present [label="MHC-II Antigen\nPresentation" fillcolor="#A9CCE3"]
    anti_U1RNP [label="Anti-U1-RNP IgG\nAutoantibodies\n(MCTD hallmark)" fillcolor="#E74C3C" fontcolor=white shape=hexagon]
    anti_Sm [label="Anti-Sm\nAutoantibodies" fillcolor="#F1948A"]
    anti_SSA [label="Anti-SSA/Ro\nAutoantibodies" fillcolor="#F1948A"]
    IFN_alpha [label="IFN-α\n(Type I Interferon)" fillcolor="#BB8FCE"]
    IFN_sig [label="IFN Signature\n(ISG15, MX1, OAS1)" fillcolor="#D2B4DE"]
  }

  /* ============================================================
     CLUSTER 3: T Cell Activation & Differentiation
  ============================================================ */
  subgraph cluster_Tcell {
    label="T Cell Activation & Differentiation" style=filled color="#E8F8F5"
    fontsize=13 fontname="Helvetica-Bold" fontcolor="#0E6655"

    NaiveCD4 [label="Naive CD4+\nT Cell" fillcolor="#ABEBC6"]
    Th1 [label="Th1 Cell\n(IFN-γ, IL-2)" fillcolor="#58D68D"]
    Th2 [label="Th2 Cell\n(IL-4, IL-5, IL-13)" fillcolor="#58D68D"]
    Th17 [label="Th17 Cell\n(IL-17A, IL-22)" fillcolor="#58D68D"]
    Treg [label="Regulatory T Cell\n(FoxP3+, IL-10, TGF-β)" fillcolor="#82E0AA"]
    Tfh [label="Follicular Helper T\n(IL-21, CXCR5)" fillcolor="#A9CCE3"]
    CD8_T [label="CD8+ Cytotoxic T\n(Perforin, Granzyme B)" fillcolor="#58D68D"]
    NKT [label="NKT Cell\n(iNKT, Vα24Jα18)" fillcolor="#ABEBC6"]
    TCR_act [label="TCR Activation\n+ CD28 Costimulation" fillcolor="#A9CCE3"]
    IL2 [label="IL-2\n(T cell proliferation)" fillcolor="#D5F5E3"]
    ICOS [label="ICOS/ICOSL\nCostimulation" fillcolor="#AED6F1" shape=ellipse]
    PD1 [label="PD-1/PD-L1\nCheckpoint" fillcolor="#FAD7A0" shape=ellipse]
    CTLA4 [label="CTLA-4\nInhibitory" fillcolor="#FAD7A0" shape=ellipse]
  }

  /* ============================================================
     CLUSTER 4: B Cell Activation & Plasma Cells
  ============================================================ */
  subgraph cluster_Bcell {
    label="B Cell Activation & Autoantibody Secretion" style=filled color="#FEF9E7"
    fontsize=13 fontname="Helvetica-Bold" fontcolor="#7D6608"

    NaiveB [label="Naive B Cell\n(IgM+IgD+)" fillcolor="#FAD7A0"]
    GC_B [label="Germinal Center\nB Cell" fillcolor="#F39C12"]
    MemoryB [label="Memory B Cell\n(IgG+)" fillcolor="#F39C12"]
    PlasmaBL [label="Plasmablast\n(Short-lived)" fillcolor="#E59866"]
    LLplasma [label="Long-lived Plasma Cell\n(Bone marrow)" fillcolor="#CA6F1E" fontcolor=white]
    BCR [label="BCR Signaling\n(PI3K, BTK, PLCγ2)" fillcolor="#FAD7A0" shape=ellipse]
    IL21 [label="IL-21\n(B cell differentiation)" fillcolor="#FAD7A0"]
    BAFF [label="BAFF/BLyS\n(B cell survival)" fillcolor="#FAD7A0"]
    APRIL [label="APRIL\n(Plasma cell survival)" fillcolor="#FAD7A0"]
    CD40L [label="CD40L/CD40\nInteraction" fillcolor="#FAD7A0" shape=ellipse]
    AID [label="AID\n(Somatic Hypermutation)" fillcolor="#F0B27A"]
    IgG_class [label="IgG Class Switch\n(IgG1, IgG2, IgG4)" fillcolor="#F0B27A"]
  }

  /* ============================================================
     CLUSTER 5: Cytokine Network
  ============================================================ */
  subgraph cluster_cytokines {
    label="Inflammatory Cytokine Network" style=filled color="#FDEDEC"
    fontsize=13 fontname="Helvetica-Bold" fontcolor="#922B21"

    TNF [label="TNF-α\n(NF-κB, Apoptosis)" fillcolor="#F1948A"]
    IL1b [label="IL-1β\n(Inflammasome)" fillcolor="#F1948A"]
    IL6 [label="IL-6\n(Acute phase, Th17)" fillcolor="#EC7063"]
    IL10 [label="IL-10\n(Anti-inflammatory)" fillcolor="#82E0AA"]
    IL17A [label="IL-17A\n(Neutrophil recruitment)" fillcolor="#F1948A"]
    IL18 [label="IL-18\n(Macrophage activation)" fillcolor="#F1948A"]
    IL33 [label="IL-33\n(Mast cell, ILC2)" fillcolor="#FAD7A0"]
    IL4 [label="IL-4\n(Th2, B cell switch)" fillcolor="#A9CCE3"]
    IL13 [label="IL-13\n(Fibrosis, Th2)" fillcolor="#A9CCE3"]
    IFNg [label="IFN-γ\n(Macrophage activation)" fillcolor="#D7BDE2"]
    TGFb [label="TGF-β\n(Fibrosis, Treg)" fillcolor="#FDEBD0"]
    MCP1 [label="MCP-1 (CCL2)\n(Monocyte recruitment)" fillcolor="#F0B27A"]
    CXCL10 [label="CXCL10/IP-10\n(T cell chemoattract)" fillcolor="#F0B27A"]
    RANTES [label="RANTES (CCL5)\n(T/NK cell recruit)" fillcolor="#F0B27A"]
    IL12 [label="IL-12\n(Th1 polarization)" fillcolor="#D2B4DE"]
    IL23 [label="IL-23\n(Th17 maintenance)" fillcolor="#D2B4DE"]
  }

  /* ============================================================
     CLUSTER 6: Vascular & Endothelial Pathology
  ============================================================ */
  subgraph cluster_vascular {
    label="Vascular & Endothelial Pathology (SSc overlap)" style=filled color="#F5EEF8"
    fontsize=13 fontname="Helvetica-Bold" fontcolor="#6C3483"

    VE_act [label="Vascular Endothelial\nActivation / Injury" fillcolor="#D7BDE2"]
    VCAM1 [label="VCAM-1\n(Adhesion molecule)" fillcolor="#C39BD3" shape=ellipse]
    ICAM1 [label="ICAM-1\n(Adhesion molecule)" fillcolor="#C39BD3" shape=ellipse]
    ET1 [label="Endothelin-1\n(Vasoconstriction)" fillcolor="#A569BD"]
    Prostacyclin [label="Prostacyclin (PGI2)\n(Vasodilation)" fillcolor="#76D7C4"]
    NO [label="Nitric Oxide\n(eNOS, vasodilation)" fillcolor="#76D7C4"]
    TXA2 [label="Thromboxane A2\n(Vasoconstriction, platelet)" fillcolor="#EC7063"]
    Raynaud [label="Raynaud's Phenomenon\n(Digital vasospasm)" fillcolor="#A569BD" shape=parallelogram]
    Telangiectasia [label="Telangiectasia\n(Capillary dilation)" fillcolor="#C39BD3" shape=parallelogram]
    Puffy_hands [label="Puffy Hands\n(Edema, early feature)" fillcolor="#D7BDE2" shape=parallelogram]
    VWF [label="Von Willebrand Factor\n(Endothelial marker)" fillcolor="#C39BD3"]
    VEGF [label="VEGF\n(Angiogenesis)" fillcolor="#A9CCE3"]
    AngII [label="Angiotensin II\n(RAAS, vasoconstriction)" fillcolor="#F0B27A"]
    Thrombin [label="Thrombin\n(Coagulation cascade)" fillcolor="#EC7063"]
    PAI1 [label="PAI-1\n(Fibrinolysis inhibition)" fillcolor="#F1948A"]
  }

  /* ============================================================
     CLUSTER 7: Pulmonary Pathology (PAH + ILD)
  ============================================================ */
  subgraph cluster_lung {
    label="Pulmonary Pathology — PAH & ILD" style=filled color="#EAF2FF"
    fontsize=13 fontname="Helvetica-Bold" fontcolor="#1B4F72"

    PA_endo [label="Pulmonary Arterial\nEndothelium" fillcolor="#AED6F1"]
    PASMC [label="Pulmonary Arterial\nSmooth Muscle Cell" fillcolor="#85C1E9"]
    BMPR2 [label="BMPR2 Signaling\n(Reduced)" fillcolor="#AED6F1" shape=ellipse]
    PDGF [label="PDGF\n(SMC proliferation)" fillcolor="#F0B27A"]
    PAH [label="Pulmonary Arterial\nHypertension (PAH)" fillcolor="#2E86C1" fontcolor=white shape=parallelogram]
    RVSP [label="RVSP\n(RV systolic pressure)" fillcolor="#1A5276" fontcolor=white]
    PVR [label="Pulmonary Vascular\nResistance (PVR)" fillcolor="#2980B9" fontcolor=white]
    mPAP [label="Mean PAP\n(Clinical endpoint)" fillcolor="#1A5276" fontcolor=white]
    RV_failure [label="Right Ventricular\nFailure" fillcolor="#1A5276" fontcolor=white shape=parallelogram]
    ILD [label="Interstitial Lung\nDisease (ILD)" fillcolor="#2E86C1" fontcolor=white shape=parallelogram]
    Fibroblast_lung [label="Lung Fibroblast\n(Activated)" fillcolor="#85C1E9"]
    Collagen_lung [label="Collagen Deposition\n(Type I, III)" fillcolor="#AED6F1"]
    FVC [label="Forced Vital Capacity\n(FVC %pred)" fillcolor="#85C1E9"]
    DLCO [label="DLCO\n(Diffusing capacity)" fillcolor="#85C1E9"]
    Alveolitis [label="Alveolitis\n(Ground-glass opacity)" fillcolor="#AED6F1" shape=parallelogram]
    Macrophage_lung [label="Alveolar Macrophage\n(M1/M2)" fillcolor="#A9CCE3"]
  }

  /* ============================================================
     CLUSTER 8: Musculoskeletal (PM overlap)
  ============================================================ */
  subgraph cluster_muscle {
    label="Musculoskeletal Pathology — Myositis & Arthritis (PM overlap)" style=filled color="#FEF9E7"
    fontsize=13 fontname="Helvetica-Bold" fontcolor="#784212"

    Myositis [label="Inflammatory Myositis\n(Proximal weakness)" fillcolor="#F0B27A" shape=parallelogram]
    MuscleCD8 [label="CD8+ T Cell\nMuscle Infiltration" fillcolor="#58D68D"]
    MHC1_muscle [label="MHC-I Upregulation\n(Muscle fibers)" fillcolor="#A9CCE3"]
    CK_serum [label="Serum CK\n(Elevated)" fillcolor="#F39C12"]
    Aldolase [label="Aldolase\n(Muscle enzyme)" fillcolor="#F39C12"]
    LDH_muscle [label="LDH\n(Muscle necrosis)" fillcolor="#F39C12"]
    EMG_change [label="EMG Changes\n(Myopathic pattern)" fillcolor="#F0B27A"]
    Muscle_MRI [label="MRI STIR\n(Muscle edema)" fillcolor="#F0B27A"]
    Synovitis [label="Synovial Inflammation\n(Arthritis)" fillcolor="#EC7063" shape=parallelogram]
    Pannus [label="Pannus Formation\n(Destructive)" fillcolor="#E74C3C"]
    Bone_erosion [label="Bone Erosion\n(Limited in MCTD)" fillcolor="#CD6155"]
    HAQ [label="HAQ Score\n(Functional disability)" fillcolor="#F39C12"]
    DAS28 [label="DAS28\n(Joint activity)" fillcolor="#F39C12"]
    Swollen_joints [label="Swollen Joint Count\n(SJC)" fillcolor="#F0B27A"]
    Tender_joints [label="Tender Joint Count\n(TJC)" fillcolor="#F0B27A"]
    Esophagus [label="Esophageal Dysmotility\n(SSc-like)" fillcolor="#FDEBD0" shape=parallelogram]
    GERD_mctd [label="GERD\n(Reflux symptoms)" fillcolor="#FDEBD0" shape=parallelogram]
  }

  /* ============================================================
     CLUSTER 9: Renal & Hematologic
  ============================================================ */
  subgraph cluster_renal_heme {
    label="Renal & Hematologic Manifestations" style=filled color="#FDEDEC"
    fontsize=13 fontname="Helvetica-Bold" fontcolor="#78281F"

    GN [label="Membranous GN\n(Mild proteinuria)" fillcolor="#F1948A" shape=parallelogram]
    Complement_act [label="Complement\nActivation (C3, C4)" fillcolor="#F1948A"]
    C3 [label="C3\n(Decreased in flare)" fillcolor="#F1948A"]
    C4 [label="C4\n(Decreased in flare)" fillcolor="#F1948A"]
    Proteinuria [label="Proteinuria\n(Renal damage marker)" fillcolor="#F0B27A"]
    Hematuria [label="Hematuria\n(Renal involvement)" fillcolor="#F0B27A"]
    Thrombocytopenia [label="Thrombocytopenia\n(Immune-mediated)" fillcolor="#F1948A" shape=parallelogram]
    Anemia [label="Hemolytic Anemia\n(Coombs+)" fillcolor="#F1948A" shape=parallelogram]
    Lymphopenia [label="Lymphopenia\n(Disease activity)" fillcolor="#F1948A"]
    eGFR [label="eGFR\n(Renal function)" fillcolor="#F0B27A"]
    Pleuritis [label="Pleuritis/Pericarditis\n(Serositis)" fillcolor="#F9E79F" shape=parallelogram]
    Leukopenia [label="Leukopenia\n(SLE-like feature)" fillcolor="#F1948A"]
  }

  /* ============================================================
     CLUSTER 10: PK — Hydroxychloroquine
  ============================================================ */
  subgraph cluster_PK_HCQ {
    label="Hydroxychloroquine (HCQ) PK" style=filled color="#E8F8F5"
    fontsize=13 fontname="Helvetica-Bold" fontcolor="#0B5345"

    HCQ_dose [label="HCQ Dose\n(200-400 mg/day)" fillcolor="#A9DFBF" shape=diamond]
    HCQ_gut [label="HCQ\nGI Absorption (F=79%)" fillcolor="#76D7C4"]
    HCQ_central [label="HCQ Central\nPlasma Compartment" fillcolor="#48C9B0"]
    HCQ_tissue [label="HCQ Tissue\nDistribution (Vd=800L/kg)" fillcolor="#1ABC9C"]
    HCQ_WBC [label="HCQ in\nLeukocytes (High conc.)" fillcolor="#17A589"]
    HCQ_hepatic [label="Hepatic Metabolism\n(CYP2C8, CYP3A4)" fillcolor="#76D7C4"]
    HCQ_renal [label="Renal Excretion\n(CrCl-dependent)" fillcolor="#76D7C4"]
    HCQ_t12 [label="t½ = 40-50 days\n(Whole blood)" fillcolor="#A9DFBF" shape=ellipse]
  }

  /* ============================================================
     CLUSTER 11: PK — MMF/MPA
  ============================================================ */
  subgraph cluster_PK_MMF {
    label="Mycophenolate Mofetil (MMF) / MPA PK" style=filled color="#EBF5FB"
    fontsize=13 fontname="Helvetica-Bold" fontcolor="#1A5276"

    MMF_dose [label="MMF Dose\n(1-3 g/day)" fillcolor="#AED6F1" shape=diamond]
    MMF_abs [label="MMF GI Absorption\nRapid hydrolysis→MPA" fillcolor="#85C1E9"]
    MPA_central [label="MPA Central\n(Free + Protein-bound)" fillcolor="#5DADE2"]
    MPA_EHC [label="Enterohepatic\nRecirculation (EHC)" fillcolor="#2E86C1"]
    IMPDH [label="IMPDH Inhibition\n(De novo purine synthesis)" fillcolor="#1A5276" fontcolor=white shape=ellipse]
    MPA_t12 [label="MPA t½ = 17 h\n(Target AUC 30-60 mg·h/L)" fillcolor="#AED6F1" shape=ellipse]
    MPA_MPAG [label="MPAG (Glucuronide)\nInactive metabolite" fillcolor="#85C1E9"]
    MPA_renal [label="MPAG Renal\nExcretion" fillcolor="#85C1E9"]
  }

  /* ============================================================
     CLUSTER 12: PK — Corticosteroids
  ============================================================ */
  subgraph cluster_PK_GCS {
    label="Corticosteroid (Prednisone/Prednisolone) PK" style=filled color="#FDFEFE"
    fontsize=13 fontname="Helvetica-Bold" fontcolor="#212F3D"

    Pred_dose [label="Prednisone Dose\n(5-60 mg/day)" fillcolor="#D5DBDB" shape=diamond]
    Pred_convert [label="Prednisone→Prednisolone\n(Liver activation)" fillcolor="#BFC9CA"]
    Prednisolone_C [label="Prednisolone\nPlasma Conc." fillcolor="#808B96"]
    GR_binding [label="Glucocorticoid Receptor\n(GR) Binding" fillcolor="#717D7E" fontcolor=white shape=ellipse]
    GR_nuclear [label="GR Nuclear\nTranslocation" fillcolor="#5D6D7E" fontcolor=white]
    NF_kB_inhib [label="NF-κB Inhibition\n(Anti-inflammatory)" fillcolor="#2E4057" fontcolor=white shape=ellipse]
    AP1_inhib [label="AP-1 Inhibition\n(Cytokine suppression)" fillcolor="#2E4057" fontcolor=white shape=ellipse]
    GCS_t12 [label="Prednisolone t½ = 2-4 h\n(Rapid elimination)" fillcolor="#D5DBDB" shape=ellipse]
  }

  /* ============================================================
     CLUSTER 13: PK — Rituximab
  ============================================================ */
  subgraph cluster_PK_RTX {
    label="Rituximab (anti-CD20) PK/PD" style=filled color="#F5EEF8"
    fontsize=13 fontname="Helvetica-Bold" fontcolor="#6C3483"

    RTX_dose [label="Rituximab\n(375 mg/m² weekly×4\nor 1000 mg×2)" fillcolor="#D2B4DE" shape=diamond]
    RTX_central [label="Rituximab\nPlasma Compartment" fillcolor="#C39BD3"]
    RTX_periph [label="Rituximab\nPeripheral Compartment" fillcolor="#A569BD"]
    CD20_bind [label="CD20 Binding\n(Target-mediated)" fillcolor="#884EA0" fontcolor=white shape=ellipse]
    ADCC [label="ADCC\n(NK cell cytotoxicity)" fillcolor="#7D3C98" fontcolor=white]
    CDC [label="CDC\n(Complement-mediated)" fillcolor="#7D3C98" fontcolor=white]
    B_depletion [label="B Cell Depletion\n(>99% reduction)" fillcolor="#6C3483" fontcolor=white shape=parallelogram]
    B_repletion [label="B Cell Repopulation\n(6-12 months)" fillcolor="#A569BD" shape=parallelogram]
    RTX_t12 [label="Rituximab t½ = 22 days\n(Terminal phase)" fillcolor="#D2B4DE" shape=ellipse]
  }

  /* ============================================================
     CLUSTER 14: PK — Bosentan (PAH treatment)
  ============================================================ */
  subgraph cluster_PK_Bosentan {
    label="Bosentan (ERA) PK/PD — PAH Treatment" style=filled color="#FEF9E7"
    fontsize=13 fontname="Helvetica-Bold" fontcolor="#7D6608"

    Bos_dose [label="Bosentan Dose\n(62.5→125 mg BID)" fillcolor="#FAD7A0" shape=diamond]
    Bos_abs [label="Bosentan GI\nAbsorption (F=50%)" fillcolor="#F8C471"]
    Bos_central [label="Bosentan Plasma\nCompartment" fillcolor="#F39C12"]
    ETA_inhib [label="ETA Receptor\nBlockade (>95%)" fillcolor="#E67E22" fontcolor=white shape=ellipse]
    ETB_partial [label="ETB Receptor\nPartial Blockade" fillcolor="#E59866" shape=ellipse]
    ET1_reduction [label="ET-1 Effect\nReduction" fillcolor="#CA6F1E" fontcolor=white]
    Bos_hepatic [label="Hepatic Metabolism\n(CYP2C9, CYP3A4)\nAutoinduce" fillcolor="#F0B27A"]
    Bos_t12 [label="Bosentan t½ = 5 h\nSteady-state 3-5 days" fillcolor="#FAD7A0" shape=ellipse]
    LFT [label="Liver Function Tests\n(ALT/AST monitoring)" fillcolor="#FDEBD0"]
  }

  /* ============================================================
     CLUSTER 15: Clinical Endpoints & Disease Activity
  ============================================================ */
  subgraph cluster_endpoints {
    label="Clinical Endpoints & Disease Activity Scores" style=filled color="#F2F3F4"
    fontsize=13 fontname="Helvetica-Bold" fontcolor="#212F3D"

    MCTD_AI [label="MCTD Activity Index\n(Yamanaka score)" fillcolor="#85C1E9" shape=hexagon]
    SLAM [label="SLAM Score\n(Systemic Lupus Activity)" fillcolor="#85C1E9"]
    MMT [label="Manual Muscle Testing\n(MMT-8 / HAQ-DI)" fillcolor="#F0B27A"]
    Nailfold_cap [label="Nailfold Capillaroscopy\n(Capillary morphology)" fillcolor="#D7BDE2"]
    ESR [label="ESR\n(Inflammatory marker)" fillcolor="#F1948A"]
    CRP [label="CRP\n(Acute phase)" fillcolor="#F1948A"]
    anti_U1RNP_titer [label="Anti-U1-RNP Titer\n(IgG, AU/mL)" fillcolor="#E74C3C" fontcolor=white]
    ANA_titer [label="ANA Titer\n(Speckled pattern)" fillcolor="#EC7063"]
    Spiro [label="Spirometry\n(FVC, FEV1/FVC)" fillcolor="#AED6F1"]
    Echo_PASP [label="Echo PASP\n(Estimated PAP)" fillcolor="#AED6F1"]
    SixMWT [label="6-Minute Walk Test\n(Exercise tolerance)" fillcolor="#AED6F1"]
    WHO_FC [label="WHO Functional\nClass (I-IV)" fillcolor="#1A5276" fontcolor=white]
    GlobAssess [label="Physician/Patient\nGlobal Assessment" fillcolor="#D5DBDB"]
    PROMIS [label="PROMIS Fatigue\n& Pain Measures" fillcolor="#D5DBDB"]
  }

  /* ============================================================
     INTER-CLUSTER EDGES
  ============================================================ */

  // Triggers → Autoantigen
  EV_infect -> Apoptosis [label="triggers"]
  UV_expo -> Apoptosis [label="induces"]
  HLA_DR4 -> MHC2_present [label="presents U1-RNP"]
  HLA_DQ -> anti_U1RNP [label="susceptibility"]
  STAT4 -> Th1 [label="enhances"]
  IRF5 -> IFN_alpha [label="transcription"]
  Estrogen -> anti_U1RNP [label="↑ autoAb"]
  Smoking -> VE_act [label="oxidative stress"]

  // Autoantigen processing
  U1snRNP -> Apoptosis [style=dashed label="source"]
  Apoptosis -> SecondaryNecr [label="if not cleared"]
  SecondaryNecr -> HMGB1 [label="releases"]
  Apoptosis -> pDC [label="U1-RNA activates"]
  HMGB1 -> TLR7 [label="activates"]
  TLR7 -> pDC [label="signaling"]
  TLR8 -> mDC [label="signaling"]
  pDC -> IFN_alpha [label="produces"]
  IFN_alpha -> IFN_sig [label="induces ISGs"]
  mDC -> MHC2_present [label="APC function"]
  MHC2_present -> TCR_act [label="activates CD4+"]
  U1snRNP -> BCR [label="cross-links BCR"]

  // T cell differentiation
  TCR_act -> NaiveCD4 [label="activates"]
  NaiveCD4 -> Th1 [label="IL-12 →"]
  NaiveCD4 -> Th2 [label="IL-4 →"]
  NaiveCD4 -> Th17 [label="IL-6+TGFβ →"]
  NaiveCD4 -> Treg [label="TGFβ+IL-2 →"]
  NaiveCD4 -> Tfh [label="ICOS →"]
  IL12 -> Th1 [label="polarizes"]
  IL23 -> Th17 [label="sustains"]
  IL4 -> Th2 [label="polarizes"]
  ICOS -> Tfh [label="activates"]
  Treg -> Th17 [label="suppresses" style=dashed color=green]
  PD1 -> TCR_act [label="inhibits" style=dashed color=red]
  CTLA4 -> TCR_act [label="inhibits" style=dashed color=red]
  Tfh -> CD40L [label="expresses"]
  Th1 -> IFNg [label="secretes"]
  Th2 -> IL4 [label="secretes"]
  Th2 -> IL13 [label="secretes"]
  Th17 -> IL17A [label="secretes"]
  Treg -> IL10 [label="secretes"]
  Tfh -> IL21 [label="secretes"]
